{"tag":"section","attrib":{"id":"iddd091745-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2171a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2171a"},"text":"§ 2171a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Battery recharging stations for privately owned vehicles in parking areas under the jurisdiction of the Librarian of Congress at no net cost to the Federal Government","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd091746-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2171a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered employee” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd091747-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2171a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee of the Library of Congress; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd091748-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2171a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other individual who is authorized to park in any parking area under the jurisdiction of the Library of Congress on the Library of Congress buildings and grounds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd091749-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2171a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd09174a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2171a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (3), funds appropriated to the Architect of the Capitol under the heading “Capitol Power Plant” under the heading “ARCHITECT OF THE CAPITOL” in any fiscal year are available to construct, operate, and maintain on a reimbursable basis battery recharging stations in parking areas under the jurisdiction of the Library of Congress on Library of Congress buildings and grounds for use by privately owned vehicles used by covered employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd09174b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2171a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vendors authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out paragraph (1), the Architect of the Capitol may use one or more vendors on a commission basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd09174c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2171a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Architect of the Capitol may construct or direct the construction of battery recharging stations described under paragraph (1) after—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd09174d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2171a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submission of written notice detailing the numbers and locations of the battery recharging stations to the Joint Committee on the Library; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd09174e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2171a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approval by that Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd09174f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2171a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees and charges","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd091750-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2171a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Architect of the Capitol shall charge fees or charges for electricity provided to covered employees sufficient to cover the costs to the Architect of the Capitol to carry out this section, including costs to any vendors or other costs associated with maintaining the battery charging stations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd091751-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2171a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of fees or charges","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Architect of the Capitol may establish and adjust fees or charges under paragraph (1) after—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd091752-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2171a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submission of written notice detailing the amount of the fee or charge to be established or adjusted to the Joint Committee on the Library; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd091753-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2171a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approval by that Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd091754-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2171a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit and availability of fees, charges, and commissions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any fees, charges, or commissions collected by the Architect of the Capitol under this section shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd091755-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2171a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deposited in the Treasury to the credit of the appropriations account described under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd091756-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2171a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" available for obligation without further appropriation during the fiscal year collected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd091757-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2171a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd091758-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2171a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the end of each fiscal year, the Architect of the Capitol shall submit a report on the financial administration and cost recovery of activities under this section with respect to that fiscal year to the Joint Committee on the Library and the Committees on Appropriations of the House of Representatives and Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd091759-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2171a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Avoiding subsidy","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd09175a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2171a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2015-12-18"},"text":"December 18, 2015","children":[],"tail":", and every 3 years thereafter, the Architect of the Capitol shall submit a report to the Joint Committee on the Library determining whether covered employees using battery charging stations as authorized by this section are receiving a subsidy from the taxpayers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd09175b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2171a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification of rates and fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a determination is made under subparagraph (A) that a subsidy is being received, the Architect of the Capitol shall submit a plan to the Joint Committee on the Library on how to update the program to ensure no subsidy is being received. If the Joint Committee does not act on the plan within 60 days, the Architect of the Capitol shall take appropriate steps to increase rates or fees to ensure reimbursement for the cost of the program consistent with an appropriate schedule for amortization, to be charged to those using the charging stations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd09175c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2171a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to fiscal year 2016 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd09175d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dI/tII/s209"},"text":"Pub. L. 114–113, div. I, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2673"},"text":"129 Stat. 2673","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
