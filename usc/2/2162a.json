{"tag":"section","attrib":{"id":"iddd06a6ad-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2162a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2162a"},"text":"§ 2162a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promoting maximum efficiency in operation of Capitol Power Plant","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd06a6ae-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2162a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Steam boilers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd06a6af-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2162a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Architect of the Capitol shall take such steps as may be necessary to operate the steam boilers at the Capitol Power Plant in the most energy efficient manner possible to minimize carbon emissions and operating costs, including adjusting steam pressures and adjusting the operation of the boilers to take into account variations in demand, including seasonality, for the use of the system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06a6b0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2162a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Architect shall implement the steps required under paragraph (1) not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd06a6b1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2162a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chiller plant","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd06a6b2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2162a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Architect of the Capitol shall take such steps as may be necessary to operate the chiller plant at the Capitol Power Plant in the most energy efficient manner possible to minimize carbon emissions and operating costs, including adjusting water temperatures and adjusting the operation of the chillers to take into account variations in demand, including seasonality, for the use of the system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06a6b3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2162a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Architect shall implement the steps required under paragraph (1) not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd06a6b4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2162a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meters","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Architect of the Capitol shall evaluate the accuracy of the meters in use at the Capitol Power Plant and correct them as necessary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd06a6b5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2162a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Architect of the Capitol shall complete the implementation of the requirements of this section and submit a report describing the actions taken and the energy efficiencies achieved to the Committee on Transportation and Infrastructure of the House of Representatives, the Committee on Commerce, Science, and Transportation of the Senate, the Committee on House Administration of the House of Representatives, and the Committee on Rules and Administration of the Senate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd06a6b6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tV/s504"},"text":"Pub. L. 110–140, title V, § 504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1656"},"text":"121 Stat. 1656","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd06a6b7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd06a6b8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd06a6b9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
