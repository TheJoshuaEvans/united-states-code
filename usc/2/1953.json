{"tag":"section","attrib":{"id":"iddcf3942c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1953"},"text":null,"children":[{"tag":"num","attrib":{"value":"1953"},"text":"§ 1953.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax treatment of Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcf3942d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1953/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions to Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of title 26, any contribution or gift to or for the use of the Fund shall be treated as a contribution or gift for exclusively public purposes to or for the use of an organization described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s170/c/1"},"text":"section 170(c)(1) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf3942e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1953/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of payments from Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any payment from the Fund shall not be subject to any Federal, State, or local income or gift tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf3942f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1953/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of title 26, notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/1/A"},"text":"section 501(c)(1)(A) of title 26","children":[],"tail":", the Fund shall be treated as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/1"},"text":"section 501(c)(1) of title 26","children":[],"tail":" and exempt from tax under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/a"},"text":"section 501(a) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcf39430-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/223/s3"},"text":"Pub. L. 105–223, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1250"},"text":"112 Stat. 1250","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf39431-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf39432-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcf39433-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 207c–2 of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","ch