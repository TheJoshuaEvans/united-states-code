{"tag":"section","attrib":{"id":"iddc85dd47-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s141b"},"text":null,"children":[{"tag":"num","attrib":{"value":"141b"},"text":"§ 141b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collections, physical security, control, and preservation of order and decorum within the library","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc85dd48-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s141b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Librarian of Congress shall establish standards and regulations for the physical security, control, and preservation of the Library of Congress collections and property, and for the maintenance of suitable order and decorum within Library of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc85dd49-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s141b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of security systems","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc85dd4a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s141b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility for security systems","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with the authority of the Capitol Police and the Librarian of Congress established under this Act, the amendments made by this Act, and the provisions of law referred to in paragraph (3), the Chief of the Capitol Police and the Librarian of Congress shall be responsible for the operation of security systems at the Library of Congress buildings and grounds described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s167j"},"text":"section 167j of this title","children":[],"tail":", in consultation and coordination with each other, subject to the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc85dd4b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s141b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Librarian of Congress shall be responsible for the design of security systems for the control and preservation of Library collections and property, subject to the review and approval of the Chief of the Capitol Police.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc85dd4c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s141b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Librarian of Congress shall be responsible for the operation of security systems at any building or facility of the Library of Congress which is located outside of the District of Columbia, subject to the review and approval of the Chief of the Capitol Police.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc85dd4d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s141b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial proposal for operation of systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2008-10-01"},"text":"October 1, 2008","children":[],"tail":", the Chief of the Capitol Police, in coordination with the Librarian of Congress, shall prepare and submit to the Committee on House Administration of the House of Representatives, the Committee on Rules and Administration of the Senate, and the Committees on Appropriations of the House of Representatives and the Senate an initial proposal for carrying out this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc85dd4e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s141b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions of law","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions of law referred to in this paragraph are as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc85dd4f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s141b/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s141"},"text":"Section 141 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc85dd50-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s141b/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s141a"},"text":"Section 141a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc85dd51-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s141b/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1964"},"text":"Section 1964 of this title","children":[],"ta