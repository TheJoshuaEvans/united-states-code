{"tag":"section","attrib":{"id":"iddc72caee-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s30"},"text":null,"children":[{"tag":"num","attrib":{"value":"30"},"text":"§ 30.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of service of Members of Congress as trustees or directors of corporations or institutions appropriated for","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In all cases where Members of Congress or Senators are appointed to represent Congress on any board of trustees or board of directors of any corporation or institution to which Congress makes any appropriation, the term of said Members or Senators, as such trustee or director, shall continue until the expiration of two months after the first meeting of the Congress chosen next after their appointment.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc72caef-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1893-03-03/ch199/s1"},"text":"Mar. 3, 1893, ch. 199, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/27/553"},"text":"27 Stat. 553","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc72caf0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc72caf1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc72caf2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s722"},"text":"section 722 of Title 31","children":[],"tail":" prior to the general revision and enactment of Title 31, Money and Finance, by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s1"},"text":"Pub. L. 97–258, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/877"},"text":"96 Stat. 877","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
