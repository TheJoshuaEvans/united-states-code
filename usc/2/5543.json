{"tag":"section","attrib":{"id":"iddd2f3ce0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5543"},"text":null,"children":[{"tag":"num","attrib":{"value":"5543"},"text":"§ 5543.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rebates under Government Travel Charge Card Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Effective with respect to fiscal years beginning with fiscal year 1995, amounts received by the Chief Administrative Officer of the House of Representatives from the Administrator of General Services for rebates under the Government Travel Charge Card Program shall be deposited in the Treasury as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd2f3ce1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/53/tI/s102"},"text":"Pub. L. 104–53, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-19"},"text":"Nov. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/520"},"text":"109 Stat. 520","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2f3ce2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2f3ce3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2f3ce4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s117k"},"text":"section 117k of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Congressional Operations Appropriations Act, 1996, which is title I of the Legislative Branch Appropriations Act, 1996.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
