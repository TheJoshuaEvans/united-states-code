{"tag":"section","attrib":{"id":"iddceed8a6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1905a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1905a"},"text":"§ 1905a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement for salaries paid for service at Federal Law Enforcement Training Center","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Chief of the Capitol Police is authorized to receive moneys from the Department of the Treasury as reimbursements for salaries paid by the Capitol Police in connection with certain officers and members of the United States Capitol Police serving as instructors at the Federal Law Enforcement Training Center. Moneys so received shall be deposited in the Treasury of the United States as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddceed8a7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/26/tI/s111"},"text":"Pub. L. 95–26, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-05-04"},"text":"May 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/87"},"text":"91 Stat. 87","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/dH/tI/s1018/h/3"},"text":"Pub. L. 108–7, div. H, title I, § 1018(h)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/369"},"text":"117 Stat. 369","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddceed8a8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddceed8a9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddceed8aa-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s64–3"},"text":"section 64–3 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Supplemental Appropriations Act, 1977.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddceed8ab-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":" substituted “Chief of the Capitol Police” for “Secretary of the Senate” and “the Capitol Police” for “the United States Senate”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddceed8ac-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddceed8ad-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", and applicable to fiscal year 2003 and each fiscal year thereafter, see "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1907/i"},"text":"section 1907(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"iddceed8ae-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions, personnel, assets, and liabilities of the Federal Law Enforcement Training Center of the Department of the Treasury to the Secretary of Homeland Security, and for treatment of related references, see sections 203(4), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
