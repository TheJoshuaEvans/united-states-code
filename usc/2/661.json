, "},{"tag":"ref","attrib":{"href":"/us/stat/99/1060"},"text":"99 Stat. 1060","children":[],"tail":", 1100, effective "},{"tag":"date","attrib":{"date":"1985-12-12"},"text":"Dec. 12, 1985","children":[],"tail":", and applicable with respect to fiscal years beginning after "},{"tag":"date","attrib":{"date":"1985-09-30"},"text":"Sept. 30, 1985","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344/s501"},"text":"section 501 of Pub. L. 93–344","children":[],"tail":", title V, "},{"tag":"date","attrib":{"date":"1974-07-12"},"text":"July 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/321"},"text":"88 Stat. 321","children":[],"tail":", was classified to section 1020 of former Title 31, prior to repeal and reenactment as "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1102"},"text":"section 1102 of Title 31","children":[],"tail":", Money and Finance, by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s5/b"},"text":"Pub. L. 97–258, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1068"},"text":"96 Stat. 1068","children":[],"tail":", the first section of which enacted Title 31."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcb59fb9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"iddcb59fba-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344"},"text