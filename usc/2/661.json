{"tag":"section","attrib":{"id":"iddcb59fb0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s661"},"text":null,"children":[{"tag":"num","attrib":{"value":"661"},"text":"§ 661.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this subchapter are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcb59fb1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s661/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measure more accurately the costs of Federal credit programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb59fb2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s661/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" place the cost of credit programs on a budgetary basis equivalent to other Federal spending;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb59fb3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s661/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage the delivery of benefits in the form most appropriate to the needs of beneficiaries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb59fb4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s661/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the allocation of resources among credit programs and between credit and other spending programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcb59fb5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","chi