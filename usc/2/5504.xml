<section xmlns="http://xml.house.gov/schemas/uslm/1.0" style="-uslm-lc:I80" id="iddd2ccbc0-3a6e-11f1-a0f3-db3efcbbb4ee" identifier="/us/usc/t2/s5504"><num value="5504">§ 5504.</num><heading> Officers of Senate</heading><content>
<p style="-uslm-lc:I11" class="indent0"><ref href="/us/usc/t2/s5503">Section 5503 of this title</ref> shall not apply to officers of the Senate.</p>
</content><sourceCredit id="iddd2ccbc1-3a6e-11f1-a0f3-db3efcbbb4ee">(<ref href="/us/pl/95/521/tVII/s714/d">Pub. L. 95–521, title VII, § 714(d)</ref>, <date date="1978-10-26">Oct. 26, 1978</date>, <ref href="/us/stat/92/1884">92 Stat. 1884</ref>.)</sourceCredit>
<notes type="uscNote" id="iddd2ccbc2-3a6e-11f1-a0f3-db3efcbbb4ee">
<note style="-uslm-lc:I74" role="crossHeading" topic="editorialNotes" id="iddd2ccbc3-3a6e-11f1-a0f3-db3efcbbb4ee"><heading class="centered"><b>Editorial Notes</b></heading></note>
<note style="-uslm-lc:I76" topic="codification" id="iddd2ccbc4-3a6e-11f1-a0f3-db3efcbbb4ee"><heading class="centered smallCaps">Codification</heading>
<p style="-uslm-lc:I21" class="indent0">Section was formerly classified to <ref href="/us/usc/t2/s118a">section 118a of this title</ref> prior to editorial reclassification and renumbering as this section.</p>
</note>
<note style="-uslm-lc:I74" role="crossHeading" topic="statutoryNotes" id="iddd2ccbc5-3a6e-11f1-a0f3-db3efcbbb4ee"><heading class="centered"><b>Statutory Notes and Related Subsidiaries</b></heading></note>
<note style="-uslm-lc:I74" topic="effectiveDate" id="iddd2ccbc6-3a6e-11f1-a0f3-db3efcbbb4ee"><heading class="centered smallCaps">Effective Date</heading><p style="-uslm-lc:I21" class="indent0">Section effective <date date="1979-01-03">Jan. 3, 1979</date>, see <ref href="/us/pl/95/521/s717">section 717 of Pub. L. 95–521</ref>, set out as a note under <ref href="/us/usc/t2/s288">section 288 of this title</ref>.</p>
</note>
</notes>
