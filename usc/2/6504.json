{"tag":"section","attrib":{"id":"iddd38b2df-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6504"},"text":null,"children":[{"tag":"num","attrib":{"value":"6504"},"text":"§ 6504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committee on Rules and Administration; designation of employees to approve vouchers for payments from Senate contingent fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Committee on Rules and Administration may authorize its chairman to designate any employee or employees of such Committee to approve in his behalf, all vouchers making payments from the contingent fund of the Senate, such approval to be deemed and held to be approval by the Committee on Rules and Administration for all intents and purposes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd38b2e0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/145"},"text":"Pub. L. 93–145","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-11-01"},"text":"Nov. 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/529"},"text":"87 Stat. 529","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/51/s126"},"text":"Pub. L. 97–51, § 126","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/965"},"text":"95 Stat. 965","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tI/s123A/c"},"text":"Pub. L. 98–473, title I, § 123A(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1970"},"text":"98 Stat. 1970","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd38b2e1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd38b2e2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd38b2e3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s68–1"},"text":"section 68–1 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd38b2e4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":" substituted “any employee or employees of such Committee” for “the committee Auditor and the committee Assistant Auditor”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/51"},"text":"Pub. L. 97–51","children":[],"tail":" substituted “the committee Auditor and the committee Assistant Auditor” for “one committee employee”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
