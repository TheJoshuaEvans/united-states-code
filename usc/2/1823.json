{"tag":"section","attrib":{"id":"iddce7ad76-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1823"},"text":null,"children":[{"tag":"num","attrib":{"value":"1823"},"text":"§ 1823.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of real property for Sergeant at Arms and Doorkeeper of the Senate","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce7ad77-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1823/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Architect of the Capitol may acquire (through purchase, lease, transfer from another Federal entity, or otherwise) real property, for the use of the Sergeant at Arms and Doorkeeper of the Senate to support the operations of the Senate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce7ad78-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1823/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the approval of the Committee on Rules and Administration of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce7ad79-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1823/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the availability of appropriations and upon approval of an obligation plan by the Committee on Appropriations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7ad7a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1823/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the approval of the Committee on Appropriations of the Senate, the Secretary of the Senate may transfer funds for the acquisition or maintenance of any property under paragraph (1) from the account under the heading “Senate, Contingent Expenses of the Senate, Sergeant at Arms and Doorkeeper of the Senate” to the account under the heading “Architect of the Capitol, Senate Office Buildings”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7ad7b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1823/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall apply with respect to fiscal year 2007 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce7ad7c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/289/dB/tII/s20701/b"},"text":"Pub. L. 109–289, div. B, title II, § 20701(b)","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/5/s2"},"text":"Pub. L. 110–5, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-02-15"},"text":"Feb. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/37"},"text":"121 Stat. 37","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce7ad7d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddce7ad7e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddce7ad7f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Continuing Appropriations Resolution, 2007.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
