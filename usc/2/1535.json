{"tag":"section","attrib":{"id":"iddce08126-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1535"},"text":null,"children":[{"tag":"num","attrib":{"value":"1535"},"text":"§ 1535.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Least burdensome option or explanation required","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce08127-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1535/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), before promulgating any rule for which a written statement is required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1532"},"text":"section 1532 of this title","children":[],"tail":", the agency shall identify and consider a reasonable number of regulatory alternatives and from those alternatives select the least costly, most cost-effective or least burdensome alternative that achieves the objectives of the rule, for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce08128-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1535/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State, local, and tribal governments, in the case of a rule containing a Federal intergovernmental mandate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce08129-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1535/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the private sector, in the case of a rule containing a Federal private sector mandate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce0812a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1535/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions of subsection (a) shall apply unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce0812b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1535/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of the affected agency publishes with the final rule an explanation of why the least costly, most cost-effective or least burdensome method of achieving the objectives of the rule was not adopted; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce0812c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1535/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions are inconsistent with law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce0812d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1535/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" OMB certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No later than 1 year after ","children":[{"tag":"date","attrib":{"date":"1995-03-22"},"text":"March 22, 1995","children":[],"tail":", the Director of the Office of Management and Budget shall certify to Congress, with a written explanation, agency compliance with this section and include in that certification agencies and rulemakings that fail to adequately comply with this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce0812e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/4/tII/s205"},"text":"Pub. L. 104–4, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-03-22"},"text":"Mar. 22, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/66"},"text":"109 Stat. 66","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
