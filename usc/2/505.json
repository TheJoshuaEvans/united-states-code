{"tag":"section","attrib":{"id":"iddca4ff29-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s505"},"text":null,"children":[{"tag":"num","attrib":{"value":"505"},"text":"§ 505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mass mailing of information by Senators under frank; quarterly registration with Secretary of Senate","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In fiscal year 1991 and thereafter, when a Senator disseminates information under the frank by a mass mailing (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3210/a/6/E"},"text":"section 3210(a)(6)(E) of title 39","children":[],"tail":"), the Senator shall register quarterly with the Secretary of the Senate such mass mailings. Such registration shall be made by filing with the Secretary a copy of the matter mailed and providing, on a form supplied by the Secretary, a description of the group or groups of persons to whom the mass mailing was mailed and the number of pieces mailed."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddca4ff2a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/520/tIII/s320"},"text":"Pub. L. 101–520, title III, § 320","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2285"},"text":"104 Stat. 2285","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddca4ff2b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddca4ff2c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddca4ff2d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s59g"},"text":"section 59g of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 1991.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
