{"tag":"section","attrib":{"id":"iddcec6810-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1881b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1881b"},"text":"§ 1881b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations and procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcec6811-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1881b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"2016-05-16"},"text":"May 16, 2016","children":[],"tail":", the Architect of the Capitol shall issue regulations for carrying out this subchapter, including regulations to establish procedures (including any appropriate forms, guidelines, and accompanying certificates) for requesting a Capitol-flown flag."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec6812-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1881b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations issued under subsection (a) shall take effect upon approval by the Committee on House Administration of the House of Representatives and the Committee on Rules and Administration of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcec6813-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/156/s4"},"text":"Pub. L. 114–156, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-05-16"},"text":"May 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/392"},"text":"130 Stat. 392","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
