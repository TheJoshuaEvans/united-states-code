{"tag":"section","attrib":{"id":"iddd0b8875-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2261"},"text":null,"children":[{"tag":"num","attrib":{"value":"2261"},"text":"§ 2261.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer date","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In this subchapter, the term “transfer date” means the date occurring on the first day of the first pay period (applicable to employees transferred under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2241"},"text":"section 2241 of this title","children":[],"tail":") occurring on or after 30 days after "},{"tag":"date","attrib":{"date":"2008-10-20"},"text":"October 20, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd0b8876-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/437/tIV/s421"},"text":"Pub. L. 110–437, title IV, § 421","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-20"},"text":"Oct. 20, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4996"},"text":"122 Stat. 4996","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd0b8877-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd0b8878-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd0b8879-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in text, was in the original “this title”, meaning title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/437"},"text":"Pub. L. 110–437","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-20"},"text":"Oct. 20, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4990"},"text":"122 Stat. 4990","children":[],"tail":", which is classified principally to this subchapter. For complete classification of title IV to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
