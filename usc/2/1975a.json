{"tag":"section","attrib":{"id":"iddcf60517-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1975a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1975a"},"text":"§ 1975a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overseas travel to accompany members of House leadership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcf60518-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1975a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf60519-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1975a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member of the Capitol Police may travel outside of the United States for official duty if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcf6051a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1975a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that travel is with, or in preparation for, travel of a Member of the House of Representatives who holds a position in a House Leadership Office, including travel of the Member as part of a congressional delegation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf6051b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1975a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Sergeant at Arms of the House of Representatives gives prior approval to the travel of the member of the Capitol Police.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf6051c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1975a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcf6051d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1975a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “House Leadership office” ","children":[{"tag":"ref","attrib":{"idref":"fn002075"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002075"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “office” probably should be capitalized."}],"tail":" means an office of the House of Representatives for which the appropriation for salaries and expenses of the office for the year involved is provided under the heading “House Leadership Offices” in the act making appropriations for the Legislative Branch for the fiscal year involved;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf6051e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1975a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Member of the House of Representatives” includes a Delegate or Resident Commissioner to the Congress; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf6051f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1975a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “United States” means each of the several States of the United States, the District of Columbia, and the territories and possessions of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf60520-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1975a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement from Sergeant at Arms","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf60521-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1975a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts made available for salaries and expenses of the Office of the Sergeant at Arms of the House of Representatives, the Sergeant at Arms of the House of Representatives shall reimburse the Capitol Police for the overtime pay, travel, and related expenses of any member of the Capitol Police who travels under the authority of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf60522-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1975a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of amounts received","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amounts received by the Capitol Police for reimbursements under paragraph (1) shall be credited to the accounts established for the general expenses or salaries of the Capitol Police, and shall be available to carry out the purposes of such accounts during the fiscal year in which the amounts are received and the following fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf60523-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1975a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to fiscal year 2017 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcf87524-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/dI/tI/s110"},"text":"Pub. L. 115–31, div. I, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/575"},"text":"131 Stat. 575","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
