{"tag":"section","attrib":{"id":"iddcf8752c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1977"},"text":null,"children":[{"tag":"num","attrib":{"value":"1977"},"text":"§ 1977.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Settlement and payment of tort claims","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcf8752d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1977/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Tort Claims Act","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf8752e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1977/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the Chief of the Capitol Police, in accordance with regulations prescribed by the Attorney General and any regulations as the Capitol Police Board may prescribe, may consider, ascertain, determine, compromise, adjust, and settle, in accordance with the provisions of chapter 171 of title 28, any claim for money damages against the United States for injury or loss of property or personal injury or death caused by the negligent or wrongful act or omission of any employee of the Capitol Police while acting within the scope of his office or employment, under circumstances where the United States, if a private person, would be liable to the claimant in accordance with the law of the place where the act or omission occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf8752f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1977/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for claims made by Members of Congress and congressional employees","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcf87530-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1977/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to any claim described in paragraph (1) which is made by a Member of Congress or any officer or employee of Congress, the Chief of the Capitol Police shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcf87531-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1977/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 14 days after the receipt of such a claim, notify the Chairman of the applicable Committee of the receipt of the claim; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcf87532-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1977/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 90 days after the receipt of such a claim, submit a proposal for the resolution of such claim which shall be subject to the approval of the Chairman of the applicable Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf87533-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1977/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The 90-day period in subparagraph (A)(ii) may be extended for an additional period (not to exceed 90 days) for good cause by the Chairman of the applicable Committee, upon the request of the Chief of the Capitol Police.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf87534-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1977/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval consistent with Federal Tort Claims Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this paragraph may be construed to permit the Chairman of an applicable Committee to approve a proposal for the resolution of a claim described in paragraph (1) which is not consistent with the terms and conditions applicable under chapter 171 of title 28 to the resolution of claims for money damages against the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf87535-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1977/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable Committee defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this paragraph, the term “applicable Committee” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcf87536-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1977/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Rules and Administration of the Senate, in the case of a claim of a Senator or an officer or employee whose pay is disbursed by the Secretary of the Senate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcf87537-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1977/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on House Administration of the House of Representatives, in the case of a Member of the House of Representatives (including a Delegate or Resident Commissioner to the Congress) or an officer or employee whose pay is disbursed by the Chief Administrative Officer of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf87538-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1977/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Head of agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2672"},"text":"section 2672 of title 28","children":[],"tail":", the Chief of the Capitol Police shall be the head of a Federal agency with respect to the Capitol Police."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf87539-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1977/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Capitol Police Board may prescribe regulations to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf8753a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1977/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claims of employees of Capitol Police","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf8753b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1977/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Capitol Police Board may prescribe regulations to apply the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3721"},"text":"section 3721 of title 31","children":[],"tail":" for the settlement and payment of a claim against the Capitol Police by an employee of the Capitol Police for damage to, or loss of personal property incident to service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf8753c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1977/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No settlement and payment of a claim under regulations prescribed under this subsection may exceed the limits applicable to the settlement and payment of claims under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3721"},"text":"section 3721 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf8753d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1977/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section may be construed to affect—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf8753e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1977/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any payment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1304"},"text":"section 1304 of title 31","children":[],"tail":" of a final judgment, award, compromise settlement, and interest and costs specified in the judgment based on a claim against the Capitol Police; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf8753f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1977/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any authority for any—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcf87540-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1977/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" settlement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1414"},"text":"section 1414 of this title","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf87541-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1977/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1415"},"text":"section 1415 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf87542-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1977/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to fiscal year 2005 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcf87543-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dG/tI/s1006"},"text":"Pub. L. 108–447, div. G, title I, § 1006","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3180"},"text":"118 Stat. 3180","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf87544-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf87545-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcf87546-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2005, which is div. G of the Consolidated Appropriations Act, 2005.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
