{"tag":"section","attrib":{"id":"iddd2a81c9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5306"},"text":null,"children":[{"tag":"num","attrib":{"value":"5306"},"text":"§ 5306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deductions for absence","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Chief Administrative Officer of the House of Representatives (upon certification by the Clerk of the House of Representatives) shall deduct from the monthly payments (or other periodic payments authorized by law) of each Member or Delegate the amount of his salary for each day that he has been absent from the House, unless such Member or Delegate assigns as the reason for such absence the sickness of himself or of some member of his family.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd2a81ca-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(R.S. § 40; ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/51/s112/d"},"text":"Pub. L. 97–51, § 112(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/963"},"text":"95 Stat. 963","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s203/7"},"text":"Pub. L. 104–186, title II, § 203(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1726"},"text":"110 Stat. 1726","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/55/tI/s5"},"text":"Pub. L. 109–55, title I, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-02"},"text":"Aug. 2, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/568"},"text":"119 Stat. 568","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2a81cb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2a81cc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2a81cd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s39"},"text":"section 39 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 40 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1856-08-16/ch123/s6"},"text":"act Aug. 16, 1856, ch. 123, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/11/49"},"text":"11 Stat. 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd2a81ce-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/55"},"text":"Pub. L. 109–55","children":[],"tail":" struck out “Secretary of the Senate and the” before “Chief Administrative Officer”, “, respectively,” before “shall deduct from”, “, respectively” before “, unless such Member”, and “Senate or” after “absent from the”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “the Chief Administrative Officer of the House of Representatives (upon certification by the Clerk of the House of Representa