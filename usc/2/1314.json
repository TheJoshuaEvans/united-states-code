{"tag":"section","attrib":{"id":"iddcd229b6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1314"},"text":null,"children":[{"tag":"num","attrib":{"value":"1314"},"text":"§ 1314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights and protections under Employee Polygraph Protection Act of 1988","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcd229b7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Polygraph practices prohibited","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd229b8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1314/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No employing office, irrespective of whether a covered employee works in that employing office, may require a covered employee to take a lie detector test where such a test would be prohibited if required by an employer under paragraph (1), (2), or (3) of section 3 of the Employee Polygraph Protection Act of 1988 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2002/1"},"text":"29 U.S.C. 2002(1)","children":[],"tail":", (2), or (3)). In addition, the waiver provisions of section 6(d) of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2005/d"},"text":"29 U.S.C. 2005(d)","children":[],"tail":") shall apply to covered employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd229b9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1314/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “covered employee” shall include employees of the Government Accountability Office and the term “employing office” shall include the Government Accountability Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd229ba-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1314/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capitol Police","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall preclude the Capitol Police from using lie detector tests in accordance with regulations under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd229bb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The remedy for a violation of subsection (a) shall be such remedy as would be appropriate if awarded under section 6(c)(1) of the Employee Polygraph Protection Act of 1988 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2005/c/1"},"text":"29 U.S.C. 2005(c)(1)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd229bc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1314/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations to implement section","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd229bd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1314/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1384"},"text":"section 1384 of this title","children":[],"tail":", issue regulations to implement this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd229be-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1314/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations issued under paragraph (1) shall be the same as substantive regulations promulgated by the Secretary of Labor to implement the statutory provisions referred to in subsections (a) and (b) except insofar as the Board may determine, for good cause shown and stated together with the regulation, that a modification of such regulations would be more effective for the implementation of the rights and protections under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd229bf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1314/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd229c0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1314/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), subsections (a) and (b) shall be effective 1 year after ","children":[{"tag":"date","attrib":{"date":"1995-01-23"},"text":"January 23, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd229c1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1314/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government Accountability Office and Library of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall be effective with respect to the Government Accountability Office and the Library of Congress 1 year after transmission to the Congress of the study under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1371"},"text":"section 1371 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcd229c2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/tII/s204"},"text":"Pub. L. 104–1, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/10"},"text":"109 Stat. 10","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dI/tI/s153/a/2/A"},"text":"Pub. L. 115–141, div. I, title I, § 153(a)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/785"},"text":"132 Stat. 785","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcd229c3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcd229c4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcd229c5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" struck out “and the Library of Congress” after “the Government Accountability Office” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office” in heading and text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
