":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/50"},"text":"109 Stat. 50","children":[],"tail":", which enacted this subchapter and sections 658 to 658g of this title, amended sections 602, 632, and 653 of this title, and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1511"},"text":"section 1511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcde3808-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddcde3809-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", or on the date 90 days after appropriations are made available as authorized under this section, whichever is earlier, and applicable to legislation considered on and after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/4/s110"},"text":"section 110 of Pub. L. 104–4","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1511"},"text":"section 1511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
