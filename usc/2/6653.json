{"tag":"section","attrib":{"id":"iddd424fbd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6653"},"text":null,"children":[{"tag":"num","attrib":{"value":"6653"},"text":"§ 6653.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Postage allowance for Chaplain of Senate","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Senate is authorized and directed to procure and furnish each fiscal year (commencing with the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1982-09-30"},"text":"September 30, 1982","children":[],"tail":") to the Chaplain of the Senate, upon the request of the Chaplain of the Senate, United States postage stamps in such amounts as may be necessary for the mailing of postal matters arising in connection with his official business."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd424fbe-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/51/s127/b/1"},"text":"Pub. L. 97–51, § 127(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/966"},"text":"95 Stat. 966","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd424fbf-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd424fc0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd424fc1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s61d–2"},"text":"section 61d–2 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
