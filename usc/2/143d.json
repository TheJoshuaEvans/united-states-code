{"tag":"section","attrib":{"id":"iddc884eb0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s143d"},"text":null,"children":[{"tag":"num","attrib":{"value":"143d"},"text":"§ 143d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds available for workers compensation payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc884eb1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s143d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Available balances of expired Library of Congress appropriations shall be available to the Library of Congress to make the deposit to the credit of the Employees’ Compensation Fund required by sub","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8147/b"},"text":"section 8147(b) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc884eb2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s143d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to appropriations for fiscal year 2012 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc884eb3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74/dG/tI/s1303"},"text":"Pub. L. 112–74, div. G, title I, § 1303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1131"},"text":"