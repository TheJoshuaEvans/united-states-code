{"tag":"section","attrib":{"id":"iddcf14a21-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1910"},"text":null,"children":[{"tag":"num","attrib":{"value":"1910"},"text":"§ 1910.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report of disbursements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcf14a22-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1910/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the last day of each semiannual period, the Chief of the Capitol Police shall submit to Congress, with respect to that period, a detailed, itemized report of the disbursements for the operations of the United States Capitol Police.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf14a23-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1910/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required by subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf14a24-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1910/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of each person or entity who receives a payment from the Capitol Police and the amount thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf14a25-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1910/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any service rendered to the Capitol Police, together with service dates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf14a26-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1910/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of all amounts appropriated to, or received or expended by, the Capitol Police and any unexpended balances of such amounts for any open fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf14a27-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1910/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such additional information as may be required by regulation of the Committee on House Administration of the House of Representatives or the Committee on Rules and Administration of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf14a28-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1910/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Printing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report under this section shall be printed as a House document.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf14a29-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1910/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to the semiannual periods of October 1 through March 31 and April 1 through September 30 of each year, beginning with the semiannual period in which this section is enacted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcf14a2a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/55/tI/s1005"},"text":"Pub. L. 109–55, title I, § 1005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-02"},"text":"Aug. 2, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/575"},"text":"119 Stat. 575","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf14a2b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf14a2c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcf14a2d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2006.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
