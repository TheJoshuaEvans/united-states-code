{"tag":"section","attrib":{"id":"iddccd6e01-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1103"},"text":null,"children":[{"tag":"num","attrib":{"value":"1103"},"text":"§ 1103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of John C. Stennis Center for Public Service Training and Development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddccd6e02-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the legislative branch of the Government a center to be known as the “John C. Stennis Center for Public Service Training and Development”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddccd6e03-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Trustees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Center shall be subject to the supervision and direction of a Board of Trustees. The Board shall be composed of seven members, as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddccd6e04-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members to be appointed by the majority leader of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd6e05-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member to be appointed by the minority leader of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd6e06-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1103/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members to be appointed by the Speaker of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd6e07-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1103/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member to be appointed by the minority leader of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd6e08-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1103/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Executive Director of the Center, who shall serve as an ex officio member of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddccd6e09-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of office","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term of office of each member of the Board appointed under paragraphs (1), (2), (3), and (4) of subsection (b) shall be six years, except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddccd6e0a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the members first appointed under paragraphs (1) and (2) shall serve, as designated by the majority leader of the Senate, one for a term of two years, one for a term of four years, and one for a term of six years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd6e0b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the members first appointed under paragraphs (3) and (4) shall serve, as designated by the Speaker of the House of Representatives, one for a term of two years, one for a term of four years, and one for a term of six years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd6e0c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1103/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member appointed to fill a vacancy shall serve for the remainder of the term for which his predecessor was appointed and shall be appointed in the same manner as the original appointment for that vacancy was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddccd6e0d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel and subsistence pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Board (other than the Executive Director) shall serve without pay, but shall be entitled to reimbursement for travel, subsistence, and other necessary expenses incurred in the performance of their duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddccd6e0e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1103/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location of Center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Center shall be located at or near Starkville, Mississippi, the location of Mississippi State University.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddccd6e0f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/458/tI/s114"},"text":"Pub. L. 100–458, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-01"},"text":"Oct. 1, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2173"},"text":"102 Stat. 2173","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
