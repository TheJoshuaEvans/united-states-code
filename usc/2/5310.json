{"tag":"section","attrib":{"id":"iddd2a81e3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5310"},"text":null,"children":[{"tag":"num","attrib":{"value":"5310"},"text":"§ 5310.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certificate of salary during recess","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Clerk of the House of Representatives is authorized and directed to sign, during the recess of Congress after the first session and until the first day of the second session, the certificates for the monthly compensation of Members and Delegates in Congress, which certificate shall be in the form in use on ","children":[{"tag":"date","attrib":{"date":"1876-08-15"},"text":"August 15, 1876","children":[],"tail":", and shall have the like force and effect as is given to the certificate of the Speaker."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd2a81e4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1876-08-15/ch287/s1"},"text":"Aug. 15, 1876, ch. 287, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/19/145"},"text":"19 Stat. 145","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2a81e5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2a81e6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2a81e7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s49"},"text":"section 49 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
