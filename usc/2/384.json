{"tag":"section","attrib":{"id":"iddc9dd32a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s384"},"text":null,"children":[{"tag":"num","attrib":{"value":"384"},"text":"§ 384.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service and filing of papers other than notice of contest","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc9dd32b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s384/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modes of service","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except for the notice of contest, every paper required to be served shall be served upon the attorney representing the party, or, if he is not represented by an attorney, upon the party himself. Service upon the attorney or upon a party shall be made:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc9dd32c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s384/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by delivering a copy to him personally;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9dd32d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s384/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by leaving it at his principal office with some person then in charge thereof; or if the office is closed or the person to be served has no office, leaving it at his dwelling house or usual place of abode with a person of discretion not less than sixteen years of age then residing therein; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9dd32e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s384/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by mailing it addressed to the person to be served at his residence or principal office. Service by mail is complete upon mailing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc9dd32f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s384/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing of papers with clerk","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All papers subsequent to the notice of contest required to be served upon the opposing party shall be filed with the Clerk either before service or within a reasonable time thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc9dd330-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s384/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proof of service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Papers filed subsequent to the notice of contest shall be accompanied by proof of service showing the time and manner of service, made by affidavit of the person making service or by certificate of an attorney representing the party in whose behalf service is made. Failure to make proof of service does not affect the validity of such service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc9dd331-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/138/s5"},"text":"Pub. L. 91–138, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-05"},"text":"Dec. 5, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/286"},"text":"83 Stat. 286","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc9dd332-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc9dd333-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddc9dd334-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to any general or special election for Representative in, or Resident Commissioner to, the Congress of the United States occurring after ","children":[{"tag":"date","attrib":{"date":"1969-12-05"},"text":"Dec. 5, 1969","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/138/s19"},"text":"section 19 of Pub. L. 91–138","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s381"},"text":"section 381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
