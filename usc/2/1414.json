{"tag":"section","attrib":{"id":"iddcdbc5bd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1414"},"text":null,"children":[{"tag":"num","attrib":{"value":"1414"},"text":"§ 1414.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Settlement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any settlement entered into by the parties to a process described in section 1331, 1341, 1351, or 1401 of this title shall be in writing and not become effective unless it is approved by the Executive Director. Nothing in this chapter shall affect the power of the Senate and the House of Representatives, respectively, to establish rules governing the process by which a settlement may be entered into by such House or by any employing office of such House.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcdbc5be-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/tIV/s414"},"text":"Pub. L. 104–1, title IV, § 414","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/38"},"text":"109 Stat. 38","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/397/tI/s103/f"},"text":"Pub. L. 115–397, title I, § 103(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5305"},"text":"132 Stat. 5305","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcdbc5bf-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcdbc5c0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[