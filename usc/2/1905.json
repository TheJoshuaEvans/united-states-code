{"tag":"section","attrib":{"id":"iddceed899-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1905"},"text":null,"children":[{"tag":"num","attrib":{"value":"1905"},"text":"§ 1905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit and use of reimbursements for law enforcement assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddceed89a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddceed89b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1905/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any funds received by the Capitol Police as reimbursement for law enforcement assistance from any Federal, State, or local government agency (including any agency of the District of Columbia), and from any other source in the case of assistance provided in connection with an activity that was not sponsored by Congress shall be deposited in the United States Treasury for credit to the appropriation for “general expenses” under the heading “United States Capitol Police”, or “security enhancements” under the heading “United States Capitol Police”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddceed89c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1905/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds deposited under this subsection may be expended by the Chief of the United States Capitol Police for any authorized purpose, including overtime pay expenditures relating to any law enforcement assistance for which reimbursement described in paragraph (1) is made, and shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddceed89d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall take effect on ","children":[{"tag":"date","attrib":{"date":"2001-07-24"},"text":"July 24, 2001","children":[],"tail":", and shall apply to fiscal year 2001 and each fiscal year thereafter."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddceed89e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/20/tII/s2802"},"text":"Pub. L. 107–20, title II, § 2802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-07-24"},"text":"July 24, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/184"},"text":"115 Stat. 184","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/145/s2/b/1"},"text":"Pub. L. 111–145, § 2(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-04"},"text":"Mar. 4, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/51"},"text":"124 Stat. 51","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dI/tI/s1001/a"},"text":"Pub. L. 114–113, div. I, title I, § 1001(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2663"},"text":"129 Stat. 2663","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddceed89f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddceed8a0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddceed8a1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 207e of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Supplemental Appropriations Act, 2001.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddceed8a2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s1001/a"},"text":"Pub. L. 114–113, § 1001(a)","children":[],"tail":", substituted “District of Columbia), and from any other source in the case of assistance provided in connection with an activity that was not sponsored by Congress” for “District of Columbia)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s1001/b"},"text":"Pub. L. 114–113, § 1001(b)","children":[],"tail":", substituted “any law enforcement assistance for which reimbursement described in paragraph (1) is made” for “law enforcement assistance to any Federal, State, or local government agency (including any agency of the District of Columbia)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/145/s2/b/1/A"},"text":"Pub. L. 111–145, § 2(b)(1)(A)","children":[],"tail":", substituted “United States Capitol Police” for “Capitol Police Board” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/145/s2/b/1/B"},"text":"Pub. L. 111–145, § 2(b)(1)(B)","children":[],"tail":", substituted “Chief of the United States Capitol Police” for “Capitol Police Board”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddceed8a3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddceed8a4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dI/tI/s1001/c"},"text":"Pub. L. 114–113, div. I, title I, § 1001(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2663"},"text":"129 Stat. 2663","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/113/dI/tI/s1001/c"},"text":"“The amendments made by this section [amending this section] shall only apply with respect to any reimbursement received before, on, or after the date of the enactment of the Act [","children":[{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddceed8a5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/145/s2/b/2"},"text":"Pub. L. 111–145, § 2(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-04"},"text":"Mar. 4, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/51"},"text":"124 Stat. 51","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/145/s2/b/2"},"text":"“The amendments made by paragraph (1) [amending this section] shall take effect as if included in the enactment of the Supplemental Appropriations Act, 2001 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/20"},"text":"Pub. L. 107–20","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
