{"tag":"section","attrib":{"id":"iddcd70aba-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1362"},"text":null,"children":[{"tag":"num","attrib":{"value":"1362"},"text":"§ 1362.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcd70abb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1362/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every employing office shall post and keep posted (in conspicuous places upon its premises where notices to covered employees are customarily posted) a notice provided by the Office that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd70abc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1362/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the rights, protections, and procedures applicable to covered employees of the employing office under this chapter, concerning violations described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd70abd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1362/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes contact information for the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd70abe-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1362/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A violation described i