{"tag":"section","attrib":{"id":"iddd33f8bb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6159"},"text":null,"children":[{"tag":"num","attrib":{"value":"6159"},"text":"§ 6159.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expense allowance for Chairmen of Majority and Minority Conference Committees of Senate; method of payment; taxability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For each fiscal year (commencing with the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1985-09-30"},"text":"September 30, 1985","children":[],"tail":"), there is hereby authorized an expense allowance for the Chairmen of the Majority and Minority Conference Committees which shall not exceed $5,000 each fiscal year for each such Chairman; and amounts from such allowance shall be paid to either of such Chairmen only as reimbursement for actual expenses incurred by him and upon certification and documentation of such expenses, and amounts so paid shall not be reported as income and shall not be allowed as a deduction under title 26."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd33f8bc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/88/tI"},"text":"Pub. L. 99–88, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-15"},"text":"Aug. 15, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/348"},"text":"99 Stat. 348","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/dH/tI/s1/d"},"text":"Pub. L. 108–7, div. H, title I, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/349"},"text":"117 Stat. 349","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd33f8bd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd33f8be-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd33f8bf-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s31a–3"},"text":"section 31a–3 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Supplemental Appropriations Act, 1985.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd33f8c0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":" substituted “not exceed $5,000” for “not exceed $3,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd33f8c1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd33f8c2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":" applicable to fiscal year 2003 and each fiscal year thereafter, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/s1/f"},"text":"section 1(f) of Pub. L. 108–7","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s6102"},"text":"section 6102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
