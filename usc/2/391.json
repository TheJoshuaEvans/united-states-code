{"tag":"section","attrib":{"id":"iddca01c5b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s391"},"text":null,"children":[{"tag":"num","attrib":{"value":"391"},"text":"§ 391.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification and filing of depositions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddca01c5c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s391/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sealing of papers; deposit with clerk","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The officer before whom any deposition is taken shall certify thereon that the witness was duly sworn by him and that the deposition is a true record of the testimony given by the witness. He shall then securely seal the deposition, together with any papers produced by the witness and the notice of deposition or stipulation, if the deposition was taken without notice, in an envelope endorsed with the title of the contested election case and marked “Deposition of (here insert name of witness)” and shall within thirty days after completion of the witness’ testimony, file it with the Clerk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca01c5d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s391/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of filing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After filing the deposition, the officer shall promptly notify the parties of its filing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca01c5e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s391/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copy of deposition to parties or deponents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon payment of reasonable charges therefor, not to exceed the charges allowed in the district court of the United States for the district wherein the place of examination is located, the officer shall furnish a copy of deposition to any party or the deponent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddca01c5f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/138/s12"},"text":"Pub. L. 91–138, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-05"},"text":"Dec. 5, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/289"},"text":"83 Stat. 289","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddca01c60-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddca01c61-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddca01c62-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to any general or special election for Representative in, or Resident Commissioner to, the Congress of the United States occurring after ","children":[{"tag":"date","attrib":{"date":"1969-12-05"},"text":"Dec. 5, 1969","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/138/s19"},"text":"section 19 of Pub. L. 91–138","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s381"},"text":"section 381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
