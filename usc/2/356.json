{"tag":"section","attrib":{"id":"iddc9b6290-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s356"},"text":null,"children":[{"tag":"num","attrib":{"value":"356"},"text":"§ 356.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Commission shall conduct, in each of the respective fiscal years referred to in subparagraphs (A) and (B) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s352/8"},"text":"section 352(8) of this title","children":[],"tail":", a review of the rates of pay of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc9b6291-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s356/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Vice President of the United States, Senators, Members of the House of Representatives, the Resident Commissioner from Puerto Rico, the Speaker of the House of Representatives, the President pro tempore of the Senate, and the majority and minority leaders of the Senate and the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b6292-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s356/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offices and positions in the legislative branch referred to in subsections (a), (b), (c), and (d) of section 203 of the Federal Legislative Salary Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/78/415"},"text":"78 Stat. 415","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/426"},"text":"Public Law 88–426","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b6293-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s356/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" justices, judges, and other personnel in the judicial branch referred to in section 403 of the Federal Judicial Salary Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/78/434"},"text":"78 Stat. 434","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/426"},"text":"Public Law 88–426","children":[],"tail":") except bankruptcy judges, but including the judges of the United States Court of Federal Claims;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b6294-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s356/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offices and positions under the Executive Schedule in subchapter II of chapter 53 of title 5; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b6295-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s356/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Governors of the Board of Governors of the United States Postal Service appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s202"},"text":"section 202 of title 39","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such review by the Commission shall be made for the purpose of determining and providing—","children":[],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc9b6296-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s356/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate pay levels and relationships between and among the respective offices and positions covered by such review, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc9b6297-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s356/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate pay relationships between such offices and positions and the offices and positions subject to the provisions of chapter 51 and subchapter III of chapter 53 of title 5, relating to classification and General Schedule pay rates.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In reviewing the rates of pay of the offices or positions referred to in subparagraph (D) of this section, the Commission shall determine and consider the appropriateness of the executive levels of such offices and positions.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc9b6298-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/206/tII/s225/f"},"text":"Pub. L. 90–206, title II, § 225(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-16"},"text":"Dec. 16, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/643"},"text":"81 Stat. 643","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s6/a"},"text":"Pub. L. 91–375, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/775"},"text":"84 Stat. 775","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/82/tII/s206/a"},"text":"Pub. L. 94–82, title II, § 206(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-08-09"},"text":"Aug. 9, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/423"},"text":"89 Stat. 423","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/tIII/s301"},"text":"Pub. L. 95–598, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2673"},"text":"92 Stat. 2673","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s143"},"text":"Pub. L. 97–164, title I, § 143","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/45"},"text":"96 Stat. 45","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/190/s135/b"},"text":"Pub. L. 99–190, § 135(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-19"},"text":"Dec. 19, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1322"},"text":"99 Stat. 1322","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/a/tIV/s408/c"},"text":"Pub. L. 100–202, § 101(a) [title IV, § 408(c)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329"},"text":"101 Stat. 1329","children":[],"tail":", 1329–27; "},{"tag":"ref","attrib":{"href":"/us/pl/101/194/tVII/s701/d"},"text":"Pub. L. 101–194, title VII, § 701(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-30"},"text":"Nov. 30, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1764"},"text":"103 Stat. 1764","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tIX/s902/b/1"},"text":"Pub. L. 102–572, title IX, § 902(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4516"},"text":"106 Stat. 4516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc9b6299-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc9b629a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddc9b629b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsections (a), (b), (c), and (d) of section 203 of the Federal Legislative Salary Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/78/415"},"text":"78 Stat. 415","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/426"},"text":"Public Law 88–426","children":[],"tail":"), referred to in par. (B), are subsecs. (a) to (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/88/426/s203"},"text":"section 203 of Pub. L. 88–426","children":[],"tail":", title II, "},{"tag":"date","attrib":{"date":"1964-08-14"},"text":"Aug. 14, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/415"},"text":"78 Stat. 415","children":[],"tail":". Subsecs. (a) and (b), which originally related to compensation of the Comptroller General and Assistant Comptroller General, respectively, of the United States, were classified to section 42a of former Title 31, Money and Finance. Subsec. (c), which originally related to compensation of the General Counsel of the United States General Accounting Office, the Librarian of Congress, the Public Printer, and the Architect of the Capitol, was classified to sections 136a and 1802 of this title, section 51a of former Title 31, and section 39a of former Title 44, Public Printing and Documents. Subsec. (d), which originally related to compensation of the Deputy Librarian of Congress, the Deputy Public Printer, and the Assistant Architect of the Capitol, was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s136a–1"},"text":"section 136a–1 of this title","children":[],"tail":", section 166b of former Title 40, Public Buildings, Property, and Works, and section 39a of former Title 44. Sections 136a (Librarian of Congress) and 136a–1 (Deputy Librarian of Congress) of this title were omitted from the Code as superseded by "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s136a–2"},"text":"section 136a–2 of this title","children":[],"tail":". Sections 42a (Comptroller General and Deputy Comptroller General) and 51a (General Counsel of General Accounting Office) of former Title 31 were repealed, and restated in sections 703(f) and 731(c) of Title 31, Money and Finance, by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", §§ 1, 5(b), "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/889"},"text":"96 Stat. 889","children":[],"tail":", 897, 1068. Section 166b (Assistant Architect of the Capitol) of former Title 40 was omitted from the Code as superseded by section 166b–3a of former Title 40 (now "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1848"},"text":"section 1848 of this title","children":[],"tail":") and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s6/b"},"text":"Pub. L. 107–217, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1304"},"text":"116 Stat. 1304","children":[],"tail":". Section 39a (Public Printer and Deputy Public Printer) of former Title 44 was repealed, and restated in "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s303"},"text":"section 303 of Title 44","children":[],"tail":", Public Printing and Documents, by "},{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", §§ 1, 3, "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1239"},"text":"82 Stat. 1239","children":[],"tail":", 1306."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The rates of pay of justices, judges, and other personnel in the judicial branch, referred to in par. (C), are set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s867"},"text":"section 867 of Title 10","children":[],"tail":", Armed Forces; "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s7443"},"text":"section 7443 of Title 26","children":[],"tail":", Internal Revenue Code; and sections 5, 44, 135, 173, 213, 252, 603, and 792 of Title 28, Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc9dd29c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Par. (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" substituted “United States Court of Federal Claims” for “United States Claims Court”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/194"},"text":"Pub. L. 101–194","children":[],"tail":" substituted “subparagraphs (A) and (B) of "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s352/8"},"text":"section 352(8) of this title","children":[],"tail":"” for “section 352(2) and (3) of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Par. (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":" substituted “except bankruptcy judges, but including” for “and magistrates and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/190"},"text":"Pub. L. 99–190","children":[],"tail":" inserted last sentence relating to review of rates of pay of offices or positions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Par. (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" inserted reference to judges of the United States Claims Court."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Par. (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":" struck out reference to section 402(d) and inserted reference to magistrates."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Par. (A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/82"},"text":"Pub. L. 94–82","children":[],"tail":" inserted “the Vice President of the United States” before “Senators”, and “the Speaker of the House of Representatives, the President pro tempore of the Senate, and the majority and minority leaders of the Senate and the House of Representatives” after “Puerto Rico”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Par. (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":" added par. (E)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc9dd29d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc9dd29e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/s911"},"text":"section 911 of Pub. L. 102–572","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"section 171 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc9dd29f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1988-10-01"},"text":"Oct. 1, 1988","children":[],"tail":", and any salary affected by the amendment to be adjusted at beginning of first applicable pay period commencing on or after such date, see section 101(a) [title IV, § 408(d)] of "},{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s153"},"text":"section 153 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc9dd2a0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/s402"},"text":"section 402 of Pub. L. 97–164","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"section 171 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc9dd2a1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/s402/a"},"text":"section 402(a) of Pub. L. 95–598","children":[],"tail":", set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":", Bankruptcy."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc9dd2a2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":" effective within 1 year after "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", on date established therefor by the Board of Governors of the United States Postal Service and published by it in the Federal Register, see "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of Title 39","children":[],"tail":", Postal Service."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddc9dd2a3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1967-12-16"},"text":"Dec. 16, 1967","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/206/s220/a/1"},"text":"section 220(a)(1) of Pub. L. 90–206","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3110"},"text":"section 3110 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddc9dd2a4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Rates of Pay Pending Changes in Rates Pursuant to Federal Salary Act of 1967","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/82/tII/s206/b"},"text":"Pub. L. 94–82, title II, § 206(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-08-09"},"text":"Aug. 9, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/423"},"text":"89 Stat. 423","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/82/tII/s206/b"},"text":"“Until such time as a change in the rate of pay of the offices referred to in the amendment made by subsection (a) of this section [amending par. (A) of this section] occurs under the provisions of the Federal Salary Act of 1967 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s351–361"},"text":"2 U.S.C. 351–361","children":[],"tail":"), as amended by subsection (a) of this section, such rates of pay shall be the rates of pay in effect immediately prior to the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1975-08-09"},"text":"Aug. 9, 1975","children":[],"tail":"], as adjusted under sections 203 and 204 of this title [amending sections 60a note, 136a, 136a–1, and 4501 of this title, "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s104"},"text":"section 104 of Title 3","children":[],"tail":", The President, sections 42a and 51a of former Title 31, Money and Finance, sections 162a and 166b of former Title 40, Public Buildings, Property, and Works, and "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s303"},"text":"section 303 of Title 44","children":[],"tail":", Public Printing and Documents].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
