{"tag":"section","attrib":{"id":"iddc98f115-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288d"},"text":null,"children":[{"tag":"num","attrib":{"value":"288d"},"text":"§ 288d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of Senate subpena or order","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc98f116-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution of civil actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When directed to do so pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s288b/b"},"text":"section 288b(b) of this title","children":[],"tail":", the Counsel shall bring a civil action under any statute conferring jurisdiction on any court of the United States (including "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1365"},"text":"section 1365 of title 28","children":[],"tail":"), to enforce, to secure a declaratory judgment concerning the validity of, or to prevent a threatened failure or refusal to comply with, any subpena or order issued by the Senate or a committee or a subcommittee of the Senate authorized to issue a subpena or order."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc98f117-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions in name of committees and subcommittees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any directive to the Counsel to bring a civil action pursuant to subsection (a) in the name of a committee or subcommittee of the Senate shall, for such committee or subcommittee, constitute authorization to bring such action within the meaning of any statute conferring jurisdiction on any court of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc98f118-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of resolutions authorizing actions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall not be in order in the Senate to consider a resolution to direct the Counsel to bring a civil action pursuant to subsection (a) in the name of a committee or subcommittee unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc98f119-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such resolution is reported by a majority of the members voting, a majority being present, of such committee or committee of which such subcommittee is a subcommittee, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc98f11a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the report filed by such committee or committee of which such subcommittee is a subcommittee contains a statement of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc98f11b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288d/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procedure followed in issuing such subpena;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc98f11c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288d/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the party sub­penaed has complied with such subpena;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc98f11d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288d/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any objections or privileges raised by the subpenaed party; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc98f11e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288d/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the comparative effectiveness of bringing a civil action under this section, certification of a criminal action for contempt of Congress, and initiating a contempt proceeding before the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc98f11f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of Senate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions of subsection (c) are enacted—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc98f120-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as an exercise of the rulemaking power of the Senate, and, as such, they shall be considered as part of the rules of the Senate, and such rules shall supersede any other rule of the Senate only to the extent that rule is inconsistent therewith; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc98f121-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with full recognition of the constitutional right of the Senate to change such rules (so far as relating to the procedure in the Senate) at any time, in the same manner, and to the same extent as in the case of any other rule of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc98f122-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committee reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A report filed pursuant to subsection (c)(2) shall not be receivable in any court of law to the extent such report is in compliance with such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc98f123-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288d/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc98f124-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288d/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of failure to testify; contempt","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall limit the discretion of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc98f125-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288d/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President pro tempore of the Senate in certifying to the United States Attorney for the District of Columbia any matter pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s194"},"text":"section 194 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc98f126-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288d/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Senate to hold any individual or entity in contempt of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc98f127-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/521/tVII/s705"},"text":"Pub. L. 95–521, title VII, § 705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-26"},"text":"Oct. 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1878"},"text":"92 Stat. 1878","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/336/s6/a/2"},"text":"Pub. L. 99–336, § 6(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-19"},"text":"June 19, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/639"},"text":"100 Stat. 639","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc98f128-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc98f129-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc98f12a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f) of this section amended title 28 by adding section 1364 and by adding item 1364 to the chapter analysis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc98f12b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/336"},"text":"Pub. L. 99–336","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1365"},"text":"section 1365 of title 28","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1364"},"text":"section 1364 of title 28","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc98f12c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddc98f12d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1979-01-03"},"text":"Jan. 3, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/521/s717"},"text":"section 717 of Pub. L. 95–521","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s288"},"text":"section 288 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
