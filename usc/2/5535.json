{"tag":"section","attrib":{"id":"iddd2ccc6a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5535"},"text":null,"children":[{"tag":"num","attrib":{"value":"5535"},"text":"§ 5535.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report of disbursements for House of Representatives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2ccc6b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5535/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the last day of each semiannual period, the Chief Administrative Officer of the House of Representatives shall submit to the House of Representatives, with respect to that period, a detailed, itemized report of the disbursements for the operations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2ccc6c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5535/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required by subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2ccc6d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5535/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of each person who receives a payment from the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2ccc6e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5535/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity and price of any item furnished to the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2ccc6f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5535/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any service rendered to the House of Representatives, together with a statement of the time required for the service, and the name, title, and amount paid to each person who renders the service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2ccc70-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5535/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of all amounts appropriated to, or received, or expended by the House of Representatives, and any unexpended balances of such amounts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2ccc71-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5535/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information submitted to the Comptroller General under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3523/a"},"text":"section 3523(a) of title 31","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2ccc72-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5535/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such additional information as may be required by regulation of the Committee on House Oversight of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2ccc73-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5535/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (b), if a voucher is for payment to an individual for attendance as a witness before a committee of the Congress in executive session, the report for the semiannual period in which the appearance occurs shall show only the date of payment, voucher number, and amount paid. Any information excluded from a report under the preceding sentence shall be included in the report for the next period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2ccc74-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5535/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" House document","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report under this section shall be printed as a House document.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2ccc75-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5535/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conforming provision","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2ccc76-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5535/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 102, 103, and 104 ","children":[{"tag":"ref","attrib":{"idref":"fn002113"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002113"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2ccc77-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5535/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s4108"},"text":"section 4108 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"that require submission and printing of statements and reports are not applicable to the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2ccc78-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5535/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to the semiannual periods of January 1 through June 30 and July 1 through December 31 of each year, beginning with the semiannual period in which this section is enacted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2ccc79-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/tI/s106"},"text":"Pub. L. 104–186, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1722"},"text":"110 Stat. 1722","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2ccc7a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2ccc7b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd2ccc7c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s102"},"text":"Section 102 of this title","children":[],"tail":", referred to in subsec. (e)(1), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s204/52"},"text":"Pub. L. 104–186, title II, § 204(52)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1737"},"text":"110 Stat. 1737","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 103 and 104 of this title, referred to in subsec. (e)(1), were omitted from the Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2ccc7d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s104b"},"text":"section 104b of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd2ccc7e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddd2ccc7f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on House Oversight of House of Representatives changed to Committee on House Administration of House of Representatives by House Resolution No. 5, One Hundred Sixth Congress, ","children":[{"tag":"date","attrib":{"date":"1999-01-06"},"text":"Jan. 6, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"similarProvisions","id":"iddd2ccc80-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Similar Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section are contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s4108"},"text":"section 4108 of this title","children":[],"tail":", but were made inapplicable to the House of Representatives by subsec. (e) of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
