{"tag":"section","attrib":{"id":"iddd33f8ac-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6157"},"text":null,"children":[{"tag":"num","attrib":{"value":"6157"},"text":"§ 6157.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services of consultants to Majority and Minority Conference Committee of Senate","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd33f8ad-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6157/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of expenditure with approval of Committee on Rules and Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds authorized to be expended under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s6155"},"text":"section 6155 of this title","children":[],"tail":" may be used by the Majority or Minority Conference Committee of the Senate, with the approval of the Committee on Rules and Administration, to procure the temporary services (not in excess of one year) or intermittent services of individual consultants, or organizations thereof, to make studies or advise the committee with respect to any matter within its jurisdiction or with respect to the administration of the affairs of the committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd33f8ae-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6157/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement by contract or employment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such services in the case of individuals or organizations may be procured by contract as independent contractors, or in the case of individuals, by employment at daily rates of compensation not in excess of the per diem equivalent of the highest gross rate of compensation which may be paid to a regular employee of such committee. Such contracts shall not be subject to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":" or any other provision of law requiring advertising."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd33f8af-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6157/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of consultant or organization by Conference Committee chairman","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any such consultant or organization shall be selected for the Majority or Minority Conference Committee of the Senate by the chairman thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd33f8b0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/88/tI/s195"},"text":"Pub. L. 99–88, title I, § 195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-15"},"text":"Aug. 15, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/349"},"text":"99 Stat. 349","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/197/tI/s1"},"text":"Pub. L. 104–197, title I, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-16"},"text":"Sept. 16, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2396"},"text":"110 Stat. 2396","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd33f8b1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd33f8b2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd33f8b3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s61g–7"},"text":"section 61g–7 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":"” substituted for “"},{"tag":"ref","attrib":{"href":"/us/usc/t41/s5"},"text":"section 5 of title 41","children":[],"tail":"” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Supplemental Appropriations Act, 1985.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd33f8b4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/197"},"text":"Pub. L. 104–197","children":[],"tail":" inserted “or with respect to the administration of the affairs of the committee” before period at end."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
