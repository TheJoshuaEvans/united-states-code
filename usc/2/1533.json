{"tag":"section","attrib":{"id":"iddcde3823-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1533"},"text":null,"children":[{"tag":"num","attrib":{"value":"1533"},"text":"§ 1533.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small government agency plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcde3824-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1533/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effects on small governments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before establishing any regulatory requirements that might significantly or uniquely affect small governments, agencies shall have developed a plan under which the agency shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcde3825-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1533/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide notice of the requirements to potentially affected small governments, if any;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde3826-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1533/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable officials of affected small governments to provide meaningful and timely input in the development of regulatory proposals containing significant Federal intergovernmental mandates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde3827-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1533/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform, educate, and advise small governments on compliance with the requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcde3828-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1533/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to each agency to carry out the provisions of this section and for no other purpose, such sums as are necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcde3829-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/4/tII/s203"},"text":"Pub. L. 104–4, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-03-22"},"text":"Mar. 22, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/65"},"text":"109 Stat. 65","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
