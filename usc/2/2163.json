{"tag":"section","attrib":{"id":"iddd06a6ba-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2163"},"text":null,"children":[{"tag":"num","attrib":{"value":"2163"},"text":"§ 2163.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capitol Grounds shuttle service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Funds appropriated for any available account of the Architect of the Capitol after ","children":[{"tag":"date","attrib":{"date":"1976-10-01"},"text":"October 1, 1976","children":[],"tail":", shall be available for the purchase or rental, maintenance and operation of passenger motor vehicles to provide shuttle service for Members and employees of Congress to and from the buildings in the Legislative group."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd06a6bb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/440/tVI"},"text":"Pub. L. 94–440, title VI","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-01"},"text":"Oct. 1, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1453"},"text":"90 Stat. 1453","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/31/dI/tI/s1206/a"},"text":"Pub. L. 115–31, div. I, title I, § 1206(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/582"},"text":"131 Stat. 582","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd06a6bc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd06a6bd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd06a6be-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 223 of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd06a6bf-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31"},"text":"Pub. L. 115–31","children":[],"tail":" substituted “appropriated for any available account of the Architect of the Capitol” for “appropriated under this heading”, which had been editorially changed to read “appropriated for the Capitol Grounds” to reflect the heading appearing in the Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd06a6c0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd06a6c1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/dI/tI/s1206/b"},"text":"Pub. L. 115–31, div. I, title I, § 1206(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/582"},"text":"131 Stat. 582","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/31/dI/tI/s1206/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply with respect to fiscal year 2017 and each succeeding fiscal year.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
