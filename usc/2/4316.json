{"tag":"section","attrib":{"id":"iddd1043e3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4316"},"text":null,"children":[{"tag":"num","attrib":{"value":"4316"},"text":"§ 4316.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowances for compensation of interns in House committee offices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd1043e4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4316/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of allowances","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are established for the House of Representatives the following allowances:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1043e5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4316/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An allowance which shall be available for the compensation of interns who serve in offices of a standing, special, or select committee of the House (other than the Committee on Appropriations).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1043e6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4316/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An allowance which shall be available for the compensation of interns who serve in offices of the Committee on Appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1043e7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4316/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefit exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s5321/b"},"text":"Section 5321(b) of this title","children":[],"tail":" shall apply with respect to an intern who is compensated under an allowance under this section in the same manner as such section applies with respect to an intern who is compensated under the Members’ Representational Allowance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1043e8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4316/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “intern”, with respect to a committee of the House, has the meaning given such term with respect to a Member of the House of Representatives in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s5321/c/2"},"text":"section 5321(c)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1043e9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4316/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1043ea-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4316/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized 