{"tag":"section","attrib":{"id":"iddce2f27f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1609"},"text":null,"children":[{"tag":"num","attrib":{"value":"1609"},"text":"§ 1609.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of clients and covered officials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce2f280-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1609/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oral lobbying contacts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person or entity that makes an oral lobbying contact with a covered legislative branch official or a covered executive branch official shall, on the request of the official at the time of the lobbying contact—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce2f281-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1609/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state whether the person or entity is registered under this chapter and identify the client on whose behalf the lobbying contact is made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f282-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1609/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state whether such client is a foreign entity and identify any foreign entity required to be disclosed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1603/b/4"},"text":"section 1603(b)(4) of this title","children":[],"tail":" that has a direct interest in the outcome of the lobbying activity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce2f283-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1609/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written lobbying contacts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person or entity registered under this chapter that makes a written lobbying contact (including an electronic communication) with a covered legislative branch official or a covered executive branch official shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce2f284-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1609/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the client on whose behalf the lobbying contact was made is a foreign entity, identify such client, state that the client is considered a foreign entity under this chapter, and state whether the person making the lobbying contact is registered on behalf of that client under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1603"},"text":"section 1603 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f285-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1609/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify any other foreign entity identified pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1603/b/4"},"text":"section 1603(b)(4) of this title","children":[],"tail":" that has a direct interest in the outcome of the lobbying activity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce2f286-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1609/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification as covered official","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon request by a person or entity making a lobbying contact, the individual who is contacted or the office employing that individual shall indicate whether or not the individual is a covered legislative branch official or a covered executive branch official.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce2f287-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/65/s14"},"text":"Pub. L. 104–65, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-19"},"text":"Dec. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/702"},"text":"109 Stat. 702","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce2f288-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddce2f289-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddce2f28a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a)(1) and (b), was in the original “this Act” meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/65"},"text":"Pub. L. 104–65","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-19"},"text":"Dec. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/691"},"text":"109 Stat. 691","children":[],"tail":", known as the Lobbying Disclosure Act of 1995. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1601"},"text":"section 1601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddce2f28b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddce2f28c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/65/s24"},"text":"section 24 of Pub. L. 104–65","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1601"},"text":"section 1601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
