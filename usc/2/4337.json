{"tag":"section","attrib":{"id":"iddd104427-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4337"},"text":null,"children":[{"tag":"num","attrib":{"value":"4337"},"text":"§ 4337.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of funds by Chairman of Senate Committee on Appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd128d18-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4337/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd128d19-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4337/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman of the Appropriations Committee of the Senate may, during any fiscal year, at his or her election transfer funds from the appropriation account for salaries for the Appropriations Committee of the Senate, to the account, within the contingent fund of the Senate, from which expenses are payable for such committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd128d1a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4337/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman of the Appropriations Committee of the Senate may, during any fiscal year, at his or her election transfer funds from the appropriation account for expenses, within the contingent fund of the Senate, for the Appropriations Committee of the Senate, to the account from which salaries are payable for such committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd128d1b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4337/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds; times of transfer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any funds transferred under this section shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd128d1c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4337/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" available for expenditure by such committee in like manner and for the same purposes as are other moneys which are available for expenditure by such committee from the account to which the funds were transferred; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd128d1d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4337/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made at such time or times as the Chairman shall specify in writing to the Senate Disbursing Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd128d1e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4337/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall take effect on ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"October 1, 1998","children":[],"tail":", and shall be effective with respect to fiscal years beginning on or after that date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd128d1f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/275/tI/s11"},"text":"Pub. L. 105–275, title I, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2435"},"text":"112 Stat. 2435","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd128d20-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd128d21-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd128d22-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s72d–1"},"text":"section 72d–1 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Congressional Operations Appropriations Act, 1999, which is title I of the Legislative Branch Appropriations Act, 1999.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
