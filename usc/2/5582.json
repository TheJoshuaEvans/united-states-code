{"tag":"section","attrib":{"id":"iddd2f3d63-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5582"},"text":null,"children":[{"tag":"num","attrib":{"value":"5582"},"text":"§ 5582.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Interparliamentary Affairs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2f3d64-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5582/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established in the House of Representatives an office to be known as the “Office of Interparliamentary Affairs” (hereafter in this section referred to as the “Office”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f3d65-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5582/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The duties of the Office are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2f3d66-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5582/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To receive and respond to inquiries from foreign parliamentarians or foreign legislative bodies regarding official visits to the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f3d67-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5582/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To coordinate official visits to the House of Representatives by parliamentarians, officers, or employees of foreign legislative bodies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f3d68-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5582/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To coordinate with the Sergeant at Arms, the Clerk, and other officers of the House of Representatives in providing services for delegations of Members on official visits to foreign nations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f3d69-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5582/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To carry out other activities to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2f3d6a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5582/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discharge and coordinate the activities and responsibilities of the House of Representatives in connection with participation in various interparliamentary exchanges and organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2f3d6b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5582/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the interchange and reception in the United States of members of foreign legislative bodies and permanent officials of foreign governments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2f3d6c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5582/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable the House to host meetings with senior government officials and other dignitaries in order to discuss matters relevant to United States relations with other nations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f3d6d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5582/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2f3d6e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5582/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office shall be headed by the Director of Interparliamentary Affairs of the House of Representatives (hereafter in this section referred to as the “Director”), who shall be appointed by the Speaker without regard to political affiliation and solely on the basis of fitness to perform the duties of the position. Any person so appointed shall serve at the pleasure of the Speaker.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f3d6f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5582/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall be paid at an annual rate determined by the Speaker.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f3d70-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5582/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other staff","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2f3d71-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5582/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With the approval of the Speaker, or in accordance with policies and procedures approved by the Speaker, the Director may appoint and set the pay of such other employees as may be necessary to carry out the functions of the Office. Any such appointment shall be made without regard to political affiliation and solely on the basis of fitness to perform the duties of the position. Any person so appointed may be removed by the Director with the approval of the Speaker, or in accordance with policies and procedures approved by the Speaker.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f3d72-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5582/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any employee of the Office appointed under this subsection shall be paid at an annual rate determined by the Director with the approval of the Speaker or in accordance with policies approved by the Speaker.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f3d73-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5582/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f3d74-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5582/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for fiscal year 2003 and each succeeding fiscal year such sums as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f3d75-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5582/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall take effect on ","children":[{"tag":"date","attrib":{"date":"2003-09-30"},"text":"September 30, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2f3d76-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/83/tI/s103"},"text":"Pub. L. 108–83, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-09-30"},"text":"Sept. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1016"},"text":"117 Stat. 1016","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2f3d77-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2f3d78-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2f3d79-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s130–2"},"text":"section 130–2 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/83/s103"},"text":"section 103 of Pub. L. 108–83","children":[],"tail":". Subsec. (e) of "},{"tag":"ref","attrib":{"href":"/us/pl/108/83/s103"},"text":"section 103 of Pub. L. 108–83","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s5581"},"text":"section 5581 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2004.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
