{"tag":"section","attrib":{"id":"iddd2ccc25-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5513"},"text":null,"children":[{"tag":"num","attrib":{"value":"5513"},"text":"§ 5513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" House of Representatives Modernization Initiatives Account","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2ccc26-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5513/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established in the Treasury of the United States an account for the House of Representatives to be known as the “House of Representatives Modernization Initiatives Account” (hereafter in this section referred to as the “Account”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2ccc27-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5513/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds in the Account shall be used by the House of Representatives to carry out initiatives to modernize the operations of the House, including initiatives to promote administrative efficiencies and expand the use of innovative technologies in offices of the House.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2ccc28-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5513/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds in the Account are available without fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2ccc29-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5513/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2ccc2a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5513/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section and the amendments made by this section shall apply with respect to fiscal year 2021 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2ccc2b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dI/tI/s115"},"text":"Pub. L. 116–260, div. I, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1637"},"text":"134 Stat. 1637","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2ccc2c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2ccc2d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2ccc2e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dI/s115"},"text":"section 115 of div. I of Pub. L. 116–260","children":[],"tail":". Subsec. (d) of section 115 amended "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s5507"},"text":"section 5507 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
