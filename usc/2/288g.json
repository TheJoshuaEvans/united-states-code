{"tag":"section","attrib":{"id":"iddc98f13b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288g"},"text":null,"children":[{"tag":"num","attrib":{"value":"288g"},"text":"§ 288g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory and other functions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc98f13c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation with persons, committees, subcommittees, and offices","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Counsel shall advise, consult, and cooperate with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc98f13d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Attorney for the District of Columbia with respect to any criminal proceeding for contempt of Congress certified by the President pro tempore of the Senate pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s194"},"text":"section 194 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc98f13e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the committee of the Senate with the responsibility to identify any court proceeding or action which is of vital interest to the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc98f13f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288g/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Comptroller General, the Government Accountability Office, the Office of Legislative Counsel of the Senate, and the Congressional Research Service, except that none of the responsibilities and authority assigned by this chapter to the Counsel shall be construed to affect or infringe upon any functions, powers, or duties of the aforementioned;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc98f140-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288g/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Member, officer, or employee of the Senate not represented under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s288c"},"text":"section 288c of this title","children":[],"tail":" with regard to obtaining private legal counsel for such Member, officer, or employee;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc98f141-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288g/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President pro tempore of the Senate, the Secretary of ","children":[{"tag":"ref","attrib":{"idref":"fn002020"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002020"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “of the”."}],"tail":" Senate, the Sergeant-at-Arms of the Senate, and the Parliamentarian of the Senate, regarding any subpena, order, or request for withdrawal of papers presented to the Senate which raises a question of the privileges of the Senate; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc98f142-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288g/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any committee or subcommittee of the Senate in promulgating and revising their rules and procedures for the use of congressional investigative powers and with respect to questions which may arise in the course of any investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc98f143-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legal research files","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Counsel shall compile and maintain legal research files of materials from court proceedings which have involved Congress, a House of Congress, an office or agency of Congress, or any committee, subcommittee, Member, officer, or employee of Congress. Public court papers and other research memoranda which do not contain information of a confidential or privileged nature shall be made available to the public consistent with any applicable procedures set forth in such rules of the Senate as may apply and the interests of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc98f144-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Miscellaneous duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Counsel shall perform such other duties consistent with the purposes and limitations of this chapter as the Senate may direct.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc98f145-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/521/tVII/s708"},"text":"Pub. L. 95–521, title VII, § 708","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-26"},"text":"Oct. 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1880"},"text":"92 Stat. 1880","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc98f146-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc98f147-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddc98f148-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a)(3) and (c), was in the original “this title”, meaning title VII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/521"},"text":"Pub. L. 95–521","children":[],"tail":", which enacted this chapter, "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s5504"},"text":"section 5504 of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1364"},"text":"section 1364 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure, and amended sections 3210, 3216, and 3219 of Title 39, Postal Service. For complete classification of title VII to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc98f149-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc98f14a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddc98f14b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1979-01-03"},"text":"Jan. 3, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/521/s717"},"text":"section 717 of Pub. L. 95–521","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s288"},"text":"section 288 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
