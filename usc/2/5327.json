{"tag":"section","attrib":{"id":"iddd2a823f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5327"},"text":null,"children":[{"tag":"num","attrib":{"value":"5327"},"text":"§ 5327.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of service of Members of House","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2a8240-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5327/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Until otherwise provided by law, for purposes of sections 5324, 5325, and 5326 of this title, any termination of service during a term of office of a Member of the House that is not described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s5324"},"text":"section 5324 of this title","children":[],"tail":" shall be treated as if such termination were described in such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2a8241-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5327/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Clerk of the House shall take such action as may be necessary to apply the principles of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s5325"},"text":"section 5325 of this title","children":[],"tail":" in the carrying out of sections 5327 to 5329 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2a8242-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/51/s101/c"},"text":"Pub. L. 97–51, § 101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/959"},"text":"95 Stat. 959","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2a8243-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2a8244-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2a8245-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s92b–1"},"text":"section 92b–1 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 1 of House Resolution 804, Ninety-sixth Congress, ","children":[{"tag":"date","attrib":{"date":"1980-10-02"},"text":"Oct. 2, 1980","children":[],"tail":", as enacted into permanent law by H.R. 4120, as reported "},{"tag":"date","attrib":{"date":"1981-07-09"},"text":"July 9, 1981","children":[],"tail":", which was enacted into permanent law by "},{"tag":"ref","attrib":{"href":"/us/pl/97/51/s101/c"},"text":"section 101(c) of Pub. L. 97–51","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
