{"tag":"section","attrib":{"id":"iddc8f7ba0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s183"},"text":null,"children":[{"tag":"num","attrib":{"value":"183"},"text":"§ 183.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written history of the House of Representatives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc8f7ba1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s183/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to available funding and in accordance with the requirements of this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s183a"},"text":"section 183a of this title","children":[],"tail":", the Librarian of Congress shall prepare, print, distribute, and arrange for the funding of, a new and complete written history of the House of Representatives, in consultation with the Committee on House Administration. In preparing this written history, the Librarian of Congress shall consult, commission, or engage the services or participation of, eminent historians, Members, and former Members of the House of Representatives."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f7ba2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s183/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), the Librarian of Congress shall take into account the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc8f7ba3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s183/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The history should be an illustrated, narrative history of the House of Representatives, organized chronologically.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f7ba4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s183/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The history’s intended audience is the general reader, as well as Members of Congress and their staffs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f7ba5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s183/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The history should include a discussion of the First and Second Continental Congresses and the Constitutional Convention, especially with regard to their roles in creating the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f7ba6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s183/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Printing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc8f7ba7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s183/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Librarian of Congress shall arrange for the printing of the history.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f7ba8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s183/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Printing arrangements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The printing may be performed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc8f7ba9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s183/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the Director of the Government Publishing Office pursuant to the provisions of chapter 5 of title 44;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f7baa-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s183/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under a cooperative arrangement among the Librarian of Congress, a private funding source obtained pursuant to subsection (e), and a publisher in the private sector; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc91ebab-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s183/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under subparagraphs (A) and (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91ebac-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s183/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internet dissemination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any arrangement under paragraph (2) shall include terms for dissemination of excerpts of the history over the Internet via facilities maintained by the United States Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91ebad-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s183/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Member copies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent that the history is printed by the Director of the Government Publishing Office, copies of the history provided to the Congress under subsection (d) shall be charged to the Government Publishing Office’s congressional allotment for printing and binding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc91ebae-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s183/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Librarian of Congress shall make the history available for sale to the public, and shall make available, free of charge, 5 copies to each Member of the House of Representatives and 250 copies to the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc91ebaf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s183/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Librarian of Congress shall solicit and accept funding for the preparation, publication, marketing, and public distribution of the history from private individuals, organizations, or entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc91ebb0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/99/s2"},"text":"Pub. L. 106–99, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1330"},"text":"113 Stat. 1330","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/dH/tI/s1305"},"text":"Pub. L. 108–7, div. H, title I, § 1305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/379"},"text":"117 Stat. 379","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/b"},"text":"Pub. L. 113–235, div. H, title I, § 1301(b)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc91ebb1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc91ebb2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddc91ebb3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s183a"},"text":"section 183a of this title","children":[],"tail":", referred to in subsec. (a), was in the original “this Act”, meaning "},{"tag":"ref","attrib":{"href":"/us/pl/106/99"},"text":"Pub. L. 106–99","children":[],"tail":", which enacted this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s183a"},"text":"section 183a of this title","children":[],"tail":" and provisions set out as a note under this section. For complete classification of this Act to the Code, see Short Title note set out under this section and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc91ebb4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":" inserted “excerpts of” after “dissemination of”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc91ebb5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddc91ebb6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Director of the Government Publishing Office” substituted for “Public Printer” in subsec. (c)(2)(A), (4) on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/d"},"text":"section 1301(d) of Pub. L. 113–235","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s301"},"text":"section 301 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Government Publishing Office’s” substituted for “Government Printing Office’s” in subsec. (c)(4) on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/b"},"text":"section 1301(b) of Pub. L. 113–235","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s301"},"text":"section 301 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"iddc91ebb7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/99/s1"},"text":"Pub. L. 106–99, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1330"},"text":"113 Stat. 1330","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/99/s1"},"text":"“This Act [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s183a"},"text":"section 183a of this title","children":[],"tail":"] may be cited as the ‘History of the House Awareness and Preservation Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
