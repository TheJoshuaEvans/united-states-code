{"tag":"section","attrib":{"id":"iddc98f100-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288b"},"text":null,"children":[{"tag":"num","attrib":{"value":"288b"},"text":"§ 288b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for authorizing representation activity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc98f101-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direction of Joint Leadership Group or Senate resolution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Counsel shall defend the Senate or a committee, subcommittee, Member, officer, or employee of the Senate under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s288c"},"text":"section 288c of this title","children":[],"tail":" only when directed to do so by two-thirds of the Members of the Joint Leadership Group or by the adoption of a resolution by the Senate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc98f102-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil action to enforce subpena","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Counsel shall bring a civil action to enforce a subpena of the Senate or a committee or subcommittee of the Senate under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s288d"},"text":"section 288d of this title","children":[],"tail":" only when directed to do so by the adoption of a resolution by the Senate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc98f103-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intervention or appearance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Counsel shall intervene or appear as amicus curiae under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s288e"},"text":"section 288e of this title","children":[],"tail":" only when directed to do so by a resolution adopted by the Senate when such intervention or appearance is to be made in the name of the Senate or in the name of an officer, committee, subcommittee, or chairman of a committee or subcommittee of the Senate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc98f104-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immunity proceedings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Counsel shall serve as the duly authorized representative in obtaining an order granting immunity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s288f"},"text":"section 288f of this title","children":[],"tail":" of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc98f105-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Senate when directed to do so by an affirmative vote of a majority of the Members present of the Senate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc98f106-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a committee or subcommittee of the Senate when directed to do so by an affirmative vote of two-thirds of the members of the full committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc98f107-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s288b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resolution recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office shall make no recommendation with respect to the consideration of a resolution under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc98f108-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/521/tVII/s703"},"text":"Pub. L. 95–521, title VII, § 703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-26"},"text":"Oct. 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1877"},"text":"92 Stat. 1877","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc98f109-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc98f10a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddc98f10b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1979-01-03"},"text":"Jan. 3, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/521/s717"},"text":"section 717 of Pub. L. 95–521","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s288"},"text":"section 288 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
