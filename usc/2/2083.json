{"tag":"section","attrib":{"id":"iddcff7a74-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2083"},"text":null,"children":[{"tag":"num","attrib":{"value":"2083"},"text":"§ 2083.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capitol Preservation Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcff7a75-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2083/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury a fund, to be known as the “Capitol Preservation Fund” (hereafter in this part referred to as the “fund”), which shall consist of (1) amounts deposited, and interest and proceeds credited, under subsection (d), (2) obligations obtained under subsection (e), and (3) all surcharges received by the Secretary of the Treasury from the sale of coins minted under the Bicentennial of the United States Congress Commemorative Coin Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff7a76-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2083/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The fund shall be available to the Commission—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcff7a77-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2083/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for payment of transaction costs and similar expenses incurred under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2082"},"text":"section 2082 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcff7a78-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2083/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the approval of the Committee on Appropriations of the House of Representatives and the Committee on Appropriations of the Senate, for improvement and preservation projects for the United States Capitol;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcff7a79-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2083/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for disbursement with respect to works of fine art and other property as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2082"},"text":"section 2082 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcff7a7a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2083/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for such other payments as may be required to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2081"},"text":"section 2081 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s2082"},"text":"section 2082 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff7a7b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2083/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transaction costs and proportionality","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Commission shall, to the extent practicable, take such action as may be necessary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcff7a7c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2083/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to minimize disbursements under subsection (b)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcff7a7d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2083/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to equalize disbursements under subsection (b) between the Senate and the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff7a7e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2083/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits, credits, and disbursements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall deposit in the fund gifts of money and proceeds of transactions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2082"},"text":"section 2082 of this title","children":[],"tail":". The Secretary of the Treasury shall credit to the fund the interest on, and the proceeds from sale or redemption of, obligations held in the fund. Disbursements from the fund shall be made on vouchers approved by the Commission and signed by the co-chairmen."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff7a7f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2083/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall invest any portion of the fund that, as determined by the Commission, is not required to meet current withdrawals. Each investment shall be made in an interest bearing obligation of the United States or an obligation guaranteed as to principal and interest by the United States that, as determined by the Commission has a maturity suitable for the fund. In carrying out this subsection, the Secretary may make such purchases, sales, and redemptions of obligations as may be approved by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcff7a80-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/696/tVIII/s803"},"text":"Pub. L. 100–696, title VIII, § 803","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4609"},"text":"102 Stat. 4609","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/302/tIII/s312/b"},"text":"Pub. L. 101–302, title III, § 312(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-05-25"},"text":"May 25, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/245"},"text":"104 Stat. 245","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcff7a81-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcff7a82-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcff7a83-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Bicentennial of the United States Congress Commemorative Coin Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/673"},"text":"Pub. L. 100–673","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-17"},"text":"Nov. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3992"},"text":"102 Stat. 3992","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5112"},"text":"section 5112 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcff7a84-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 188a–2 of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcff7a85-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/302/s312/b/1"},"text":"Pub. L. 101–302, § 312(b)(1)","children":[],"tail":", struck out “subject to the approval, except for the purchase of fine art and antiques, of the Committees on Appropriations of the House of Representatives and Senate, respectively” after “The fund shall be available to the Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/302/s312/b/2"},"text":"Pub. L. 101–302, § 312(b)(2)","children":[],"tail":", inserted “subject to the approval of the Committee on Appropriations of the House of Representatives and the Committee on Appropriations of the Senate,” before “For improvement”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcff7a86-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddcff7a87-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Capitol Visitor Center Funding","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/117/dB/s913"},"text":"Pub. L. 107–117, div. B, § 913","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-10"},"text":"Jan. 10, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2324"},"text":"115 Stat. 2324","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/117/dB/s913"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, the United States Capitol Preservation Commission established under section 801 of the Arizona-Idaho Conservation Act of 1988 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s188a"},"text":"40 U.S.C. 188a","children":[],"tail":") [now "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s2081"},"text":"2 U.S.C. 2081","children":[],"tail":"] may transfer to the Architect of the Capitol amounts in the Capitol Preservation Fund established under section 803 of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s188a–2"},"text":"40 U.S.C. 188a–2","children":[],"tail":") [now "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s2083"},"text":"2 U.S.C. 2083","children":[],"tail":"] if the amounts are to be used by the Architect for the planning, engineering, design, or construction of the Capitol Visitor Center."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amounts transferred pursuant to subsection (a) shall remain available for the use of the Architect of the Capitol until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall apply with respect to fiscal year 2002 and each succeeding fiscal year.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
