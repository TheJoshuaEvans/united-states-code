{"tag":"section","attrib":{"id":"iddce7adbd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1827"},"text":null,"children":[{"tag":"num","attrib":{"value":"1827"},"text":"§ 1827.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support and maintenance during emergencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce7adbe-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1827/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" During an emergency involving the safety of human life or the protection of property, as determined or declared by the Capitol Police Board, the Architect of the Capitol—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce7adbf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1827/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may accept contributions of comfort and other incidental items and services to support employees of the Office of the Architect of the Capitol while such employees are on duty in response to the emergency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7adc0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1827/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may incur obligations and make expenditures out of available appropriations for meals, refreshments, and other support and maintenance for the Office of the Architect of the Capitol if, in the judgment of the Architect, such obligations and expenditures are necessary to respond to the emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7adc1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1827/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall apply with respect to fiscal year 2010 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce7adc2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/68/dA/tI/s1305"},"text":"Pub. L. 111–68, div. A, title I, § 1305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2035"},"text":"123 Stat. 2035","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce7adc3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddce7adc4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddce7adc5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2010, which is div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/68"},"text":"Pub. L. 111–68","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
