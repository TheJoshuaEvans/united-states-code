{"tag":"section","attrib":{"id":"iddd2810d3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4931"},"text":null,"children":[{"tag":"num","attrib":{"value":"4931"},"text":"§ 4931.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Daniel Webster Senate Page Residence Revolving Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2810d4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4931/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a revolving fund within the contingent fund of the Senate to be known as the Daniel Webster Senate Page Residence Revolving Fund (hereafter referred to in this section as the “fund”). The fund shall consist of all rental payments and other moneys collected or received by the Sergeant at Arms with regard to the Daniel Webster Senate Page Residence. All moneys in the fund shall be available without fiscal year limitation for disbursement by the Secretary of the Senate in connection with operation and maintenance of the Daniel Webster Senate Page Residence not normally performed by the Architect of the Capitol. In addition, such moneys may be used by the Sergeant at Arms to purchase food and food related items and fund activities for the pages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2810d5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4931/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of moneys","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All moneys received from rental payments and other moneys (including donated moneys) collected or received by the Sergeant at Arms with regard to the Daniel Webster Senate Page Residence shall be deposited in the fund and shall be available for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2810d6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4931/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vouchers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Disbursements from the fund shall be made upon vouchers approved by the Sergeant at Arms, or the designee of the Sergeant at Arms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2810d7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4931/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Sergeant at Arms is authorized to prescribe such regulations as may be necessary to carry out the provisions of this section and to provide for the operations of the Daniel Webster Senate Page Residence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2810d8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/283/tI/s4"},"text":"Pub. L. 103–283, title I, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-22"},"text":"July 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1427"},"text":"108 Stat. 1427","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/53/tI/s6"},"text":"Pub. L. 104–53, title I, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-19"},"text":"Nov. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/518"},"text":"109 Stat. 518","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2810d9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2810da-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2810db-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s88b–7"},"text":"section 88b–7 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Congressional Operations Appropriations Act, 1995, which is title I of the Legislative Branch Appropriations Act, 1995.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd2810dc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1995—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/53"},"text":"Pub. L. 104–53","children":[],"tail":" inserted “(including donated moneys)” after “other moneys”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
