{"tag":"section","attrib":{"id":"iddd3fded2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6617"},"text":null,"children":[{"tag":"num","attrib":{"value":"6617"},"text":"§ 6617.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law enforcement authority of Sergeant-at-Arms and Doorkeeper of the Senate","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3fded3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6617/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Sergeant-at-Arms and Doorkeeper of the Senate shall have the same law enforcement authority, including the authority to carry firearms, as a member of the Capitol Police. The law enforcement authority under the preceding sentence shall be subject to the requirement that the Sergeant-at-Arms and Doorkeeper of the Senate have the qualifications specified in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fded4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6617/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The qualifications referred to in subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3fded5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6617/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A minimum of 5 years of experience as a law enforcement officer before beginning service as the Sergeant-at-Arms and Doorkeeper of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fded6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6617/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Current certification in the use of firearms by the appropriate Federal law enforcement entity or an equivalent non-Federal entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fded7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6617/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other firearms qualification required for members of the Capitol Police.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fded8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6617/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee on Rules and Administration of the Senate shall have authority to prescribe regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3fded9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/145/s8"},"text":"Pub. L. 111–145, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-04"},"text":"Mar. 4, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/56"},"text":"124 Stat. 56","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3fdeda-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3fdedb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3fdedc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s61f–14"},"text":"section 61f–14 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
