{"tag":"section","attrib":{"id":"iddce562fc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1812"},"text":null,"children":[{"tag":"num","attrib":{"value":"1812"},"text":"§ 1812.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Care and superintendence of Capitol","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Architect of the Capitol shall on and after ","children":[{"tag":"date","attrib":{"date":"1977-03-03"},"text":"March 3, 1977","children":[],"tail":", have the care and superintendence of the Capitol, including lighting. His office shall be in the Capitol Building."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddce562fd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1876-08-15/ch287"},"text":"Aug. 15, 1876, ch. 287","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/19/147"},"text":"19 Stat. 147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1877-03-03/ch102"},"text":"Mar. 3, 1877, ch. 102","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/19/298"},"text":"19 Stat. 298","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1951-10-31/ch654/s3/14"},"text":"Oct. 31, 1951, ch. 654, § 3(14)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/708"},"text":"65 Stat. 708","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce562fe-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddce562ff-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddce56300-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 163 of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The first sentence of this section is from act ","children":[{"tag":"date","attrib":{"date":"1877-03-03"},"text":"Mar. 3, 1877","children":[],"tail":". The second sentence of this section is from act "},{"tag":"date","attrib":{"date":"1876-08-15"},"text":"Aug. 15, 1876","children":[],"tail":", popularly known as the “Sundry Civil Appropriation Act”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddce56301-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising the first sentence of this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1876-08-15/ch287"},"text":"act Aug. 15, 1876, ch. 287","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/19/147"},"text":"19 Stat. 147","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddce56302-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1951—Act ","children":[{"tag":"date","attrib":{"date":"1951-10-31"},"text":"Oct. 31, 1951","children":[],"tail":", struck out “, and shall submit through the Secretary of the Interior estimates thereof” at end of first sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddce56303-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddce56304-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Change of name of Architect of the Capitol, functions abolished, transferred, etc., by prior acts, see Prior Provisions and Change of Name notes set out under former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1801"},"text":"section 1801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
