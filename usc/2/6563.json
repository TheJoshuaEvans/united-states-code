{"tag":"section","attrib":{"id":"iddd3d94e6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6563"},"text":null,"children":[{"tag":"num","attrib":{"value":"6563"},"text":"§ 6563.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of certain expenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3d94e7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6563/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the approval of the Committee on Appropriations of the Senate, if in any fiscal year amounts in any appropriations account under the heading “SENATE” under the heading “LEGISLATIVE BRANCH” are available for more than 1 fiscal year, the Secretary of the Senate may establish procedures for the payment of expenses with respect to that account from any amounts available for that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3d94e8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6563/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to fiscal year 2012 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3d94e9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74/dG/tI/s1"},"text":"Pub. L. 112–74, div. G, title I, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1118"},"text":"125 Stat. 1118","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3d94ea-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3d94eb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3d94ec-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s68f"},"text":"section 68f of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2012, which is div. G of the Consolidated Appropriations Act, 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
