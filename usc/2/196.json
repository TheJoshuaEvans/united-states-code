{"tag":"section","attrib":{"id":"iddc943592-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s196"},"text":null,"children":[{"tag":"num","attrib":{"value":"196"},"text":"§ 196.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senate resolutions for investigations; limit of cost","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Senate resolutions providing for inquiries and investigations shall contain a limit of cost of such investigation, which limit shall not be exceeded except by vote of the Senate authorizing additional amounts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc943593-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-03-03/ch44/s1"},"text":"Mar. 3, 1926, ch. 44, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/162"},"text":"44 Stat. 162","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
