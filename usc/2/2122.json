{"tag":"section","attrib":{"id":"iddd045c16-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2122"},"text":null,"children":[{"tag":"num","attrib":{"value":"2122"},"text":"§ 2122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of gifts on behalf of the House of Representatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Board is authorized to accept, on behalf of the House of Representatives, gifts of works of fine art, historical objects, and similar property, including transfers from the United States Capitol Preservation Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2082"},"text":"section 2082 of this title","children":[],"tail":", for display or other use in the House of Representatives wing of the Capitol, the House of Representatives Office Buildings, or any other location under the control of the House of Representatives."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd045c17-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/696/tX/s1002"},"text":"Pub. L. 100–696, title X, § 1002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4612"},"text":"102 Stat. 4612","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd045c18-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd045c19-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd045c1a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 188c–1 of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
