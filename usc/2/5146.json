{"tag":"section","attrib":{"id":"iddd28118a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5146"},"text":null,"children":[{"tag":"num","attrib":{"value":"5146"},"text":"§ 5146.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lump-sum allowances for House Majority Whip and Minority Whip","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Effective with respect to fiscal year 2010 and each succeeding fiscal year, the aggregate amount otherwise authorized to be appropriated for a fiscal year for the lump-sum allowance for each of the following offices is increased as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd28118b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5146/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The allowance for the office of the Majority Whip is increased by $96,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd28118c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5146/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The allowance for the office of the Minority Whip is increased by $96,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd28118d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/68/dA/tI/s102"},"text":"Pub. L. 111–68, div. A, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2029"},"text":"123 Stat. 2029","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd28118e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd28118f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd281190-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s74a–10b"},"text":"section 74a–10b of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2010, which is div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/68"},"text":"Pub. L. 111–68","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
