{"tag":"section","attrib":{"id":"iddd045c45-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2133"},"text":null,"children":[{"tag":"num","attrib":{"value":"2133"},"text":"§ 2133.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance and supervision of works of fine arts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Joint Committee on the Library, whenever, in their judgment, it is expedient, are authorized to accept any work of the fine arts, on behalf of Congress, which may be offered, and to assign the same such place in the Capitol as they may deem suitable, and shall have the supervision of all works of art that may be placed in the Capitol.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd045c46-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(R.S. § 1831.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd045c47-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd045c48-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd045c49-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 188 of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 1831 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1872-06-10/ch415/s1"},"text":"act June 10, 1872, ch. 415, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/17/362"},"text":"17 Stat. 362","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd045c4a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd045c4b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Works of Art Accepted or Removed","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The following provisions relate to works of art accepted or removed by the Joint Committee on the Library:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/326"},"text":"Pub. L. 117–326","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4452"},"text":"136 Stat. 4452","children":[],"tail":".—Replacement of bust of Roger Brooke Taney with bust of Thurgood Marshall."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/111"},"text":"Pub. L. 117–111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-04-13"},"text":"Apr. 13, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1166"},"text":"136 Stat. 1166","children":[],"tail":".—Statues of Sandra Day O’Connor and Ruth Bader Ginsburg."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/174"},