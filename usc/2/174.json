{"tag":"section","attrib":{"id":"iddc8d094e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s174"},"text":null,"children":[{"tag":"num","attrib":{"value":"174"},"text":"§ 174.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Function of Center for the Book","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Librarian through the Center shall stimulate public interest and research in the role of the book in the diffusion of knowledge through such activities as a visiting scholar program accompanied by lectures, exhibits, publications, and any other related activities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc8d094f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/129/s4"},"text":"Pub. L. 95–129, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-13"},"text":"Oct. 13, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1152"},"text":"91 Stat. 1152","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
