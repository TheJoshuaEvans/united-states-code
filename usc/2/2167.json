{"tag":"section","attrib":{"id":"iddd06a6d3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2167"},"text":null,"children":[{"tag":"num","attrib":{"value":"2167"},"text":"§ 2167.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional Award Youth Park","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd06a6d4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2167/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The parcel of approximately 5 acres of land located on the Capitol Grounds and described in subsection (b) shall be known and designated as the “Congressional Award Youth Park”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd06a6d5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2167/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area included","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd06a6d6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2167/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The parcel of land described in subsection (a) is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd06a6d7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2167/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bounded on the north by Constitution Avenue, N.W.;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd06a6d8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2167/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bounded on the east by First Street, N.W.;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd06a6d9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2167/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bounded on the south by Pennsylvania Avenue, N.W.; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd06a6da-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2167/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bounded on the west by Third Street N.W.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06a6db-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2167/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The park shall extend to the curbs of the streets described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd06a6dc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2167/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Design","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd06a6dd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2167/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Architect of the Capitol shall sponsor a competition for the design of the park, based on specifications developed by the Architect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06a6de-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2167/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specifications","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd06a6df-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2167/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2002-06-30"},"text":"June 30, 2002","children":[],"tail":", the Architect, in consultation with the majority leader and the minority leader of the Senate, and the Speaker and the minority leader of the House of Representatives, shall develop the specifications for the park."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd06a6e0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2167/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd06a6e1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2167/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The specifications shall require an outdoor design that is accessible to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd06a6e2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2167/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the maximum extent practicable, the specifications shall include requirements for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddd06a6e3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2167/c/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fountain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd06a6e4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2167/c/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extensive use of trees and flowering plants from each of the 50 States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd06a6e5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2167/c/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" large-scale replicas of the medals awarded under the Congressional Award Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd06a6e6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2167/c/2/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the inscription of the names of all Congressional Award recipients.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06a6e7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2167/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd06a6e8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2167/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after the competition is completed, the Architect shall forward at least 3 designs, with recommendations, to the United States Capitol Preservation Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd06a6e9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2167/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Capitol Preservation Commission shall select and approve the final design from among the 3 designs submitted under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd06a6ea-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2167/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds otherwise made available to the Architect of the Capitol under this Act shall be available to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd06a6eb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/68/tI/s134"},"text":"Pub. L. 107–68, title I, § 134","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-12"},"text":"Nov. 12, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/582"},"text":"115 Stat. 582","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd06a6ec-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd06a6ed-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd06a6ee-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/68"},"text":"Pub. L. 107–68","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-12"},"text":"Nov. 12, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/560"},"text":"115 Stat. 560","children":[],"tail":", known as the Legislative Branch Appropriations Act, 2002. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd06a6ef-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 217c of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
