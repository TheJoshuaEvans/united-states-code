{"tag":"section","attrib":{"id":"iddca748aa-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s607"},"text":null,"children":[{"tag":"num","attrib":{"value":"607"},"text":"§ 607.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lump-sum payments for annual leave to separated employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddca748ab-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s607/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Congressional Budget Office shall have the authority to make lump-sum payments to separated employees of the Congressional Budget Office for unused annual leave.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca748ac-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s607/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) shall apply with respect to fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"September 30, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddca748ad-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/197/tI/s106"},"text":"Pub. L. 104–197, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-16"},"text":"Sept. 16, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2404"},"text":"110 Stat. 2404","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddca748ae-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddca748af-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddca748b0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Congressional Operations Appropriations Act, 1997, which is title I of the Legislative Branch Appropriations Act, 1997, and not as part of title II of the Congressional Budget and Impoundment Control Act of 1974 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
