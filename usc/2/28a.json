{"tag":"section","attrib":{"id":"iddc72ca92-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s28a"},"text":null,"children":[{"tag":"num","attrib":{"value":"28a"},"text":"§ 28a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compilation of the Precedents of House of Representatives; date of completion; biennial update; printing and availability of copies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Speaker is authorized and directed to complete the Compilation of the Precedents of the House of Representatives by ","children":[{"tag":"date","attrib":{"date":"1977-01-01"},"text":"January 1, 1977","children":[],"tail":", and prepare an updated compilation of such precedents every two years thereafter. Copies of the Compilation of Precedents shall be printed in sufficient quantity to be available to every Member and the standing committees of the House of Representatives."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc72ca93-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/554/tI"},"text":"Pub. L. 93–554, title I","children":[],"tail":", ch. III, "},{"tag":"date","attrib":{"date":"1974-12-27"},"text":"Dec. 27, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1777"},"text":"88 Stat. 1777","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc72ca94-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc72ca95-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc72ca96-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 208 of House Resolution No. 988, Ninety-third Congress, ","children":[{"tag":"date","attrib":{"date":"1974-10-08"},"text":"Oct. 8, 1974","children":[],"tail":", which was enacted into permanent law by "},{"tag":"ref","attrib":{"href":"/us/pl/93/554"},"text":"Pub. L. 93–554","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc72ca97-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddc72ca98-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/554"},"text":"Pub. L. 93–554","children":[],"tail":" provided that the enactment of House Resolution No. 988, Ninety-third Congress, into permanent law is effective "},{"tag":"date","attrib":{"date":"1975-01-02"},"text":"Jan. 2, 1975","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
