{"tag":"section","attrib":{"id":"iddc91ebb8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s183a"},"text":null,"children":[{"tag":"num","attrib":{"value":"183a"},"text":"§ 183a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oral history of the House of Representatives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc91ebb9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s183a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Librarian of Congress shall accept for deposit, preserve, maintain, and make accessible an oral history of the House of Representatives, as told by its Members and former Members, compiled and updated (on a voluntary or contract basis) by the United States Association of Former Members of Congress or other private organization. In carrying out this section, the Librarian of Congress may enlist the voluntary aid or assistance of such organization, or may contract with it for such services as may be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc91ebba-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s183a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of oral history","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “oral history” means a story or history consisting of personal recollection as recorded by any one or more of the following means:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc91ebbb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s183a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Interviews.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91ebbc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s183a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transcripts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91ebbd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s183a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Audio recordings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91ebbe-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s183a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Video recordings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91ebbf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s183a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other form or means as may be suitable for the recording and preservation of such information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc91ebc0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/99/s3"},"text":"Pub. L. 106–99, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1331"},"text":"113 Stat. 1331","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
