{"tag":"section","attrib":{"id":"iddd3fdeb6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6613"},"text":null,"children":[{"tag":"num","attrib":{"value":"6613"},"text":"§ 6613.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advances to Sergeant at Arms of Senate for extraordinary expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Senate on and after ","children":[{"tag":"date","attrib":{"date":"1958-07-31"},"text":"July 31, 1958","children":[],"tail":", is authorized, in his discretion, to advance to the Sergeant at Arms of the Senate such sums as may be necessary, not exceeding $4,000, to meet any extraordinary expenses of the Senate."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd3fdeb7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/570"},"text":"Pub. L. 85–570","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-07-31"},"text":"July 31, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/442"},"text":"72 Stat. 442","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/440/tI/s108"},"text":"Pub. L. 94–440, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-01"},"text":"Oct. 1, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1445"},"text":"90 Stat. 1445","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/26/tI/s104"},"text":"Pub. L. 95–26, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-05-04"},"text":"May 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/82"},"text":"91 Stat. 82","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3fdeb8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3fdeb9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3fdeba-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s65b"},"text":"section 65b of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd3fdebb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/26"},"text":"Pub. L. 95–26","children":[],"tail":" struck out “during any fiscal year” after “$4,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/440"},"text":"Pub. L. 94–440","children":[],"tail":" substituted “$4,000 during any fiscal year” for “$2,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
