{"tag":"section","attrib":{"id":"iddcd49a19-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331"},"text":null,"children":[{"tag":"num","attrib":{"value":"1331"},"text":"§ 1331.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights and protections under Americans with Disabilities Act of 1990 relating to public services and accommodations; procedures for remedy of violations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcd49a1a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entities subject to this section","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements of this section shall apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd49a1b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each office of the Senate, including each office of a Senator and each committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a1c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each office of the House of Representatives, including each office of a Member of the House of Representatives and each committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a1d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each joint committee of the Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a1e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Congressional Accessibility Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a1f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Capitol Police;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a20-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Congressional Budget Office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a21-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the Architect of the Capitol (including the Botanic Garden);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a22-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the Attending Physician;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a23-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Congressional Workplace Rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a24-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Technology Assessment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a25-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Library of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd49a26-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discrimination in public services and accommodations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd49a27-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights and protections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rights and protections against discrimination in the provision of public services and accommodations established by sections 201 through 230, 302, 303, and 309 of the Americans with Disabilities Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12131–121"},"text":"42 U.S.C. 12131–121","children":[],"tail":"50, 12182, 12183, and 12189) shall apply to the entities listed in subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a28-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of the application of title II of the Americans with Disabilities Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12131"},"text":"42 U.S.C. 12131","children":[],"tail":" et seq.) under this section, the term “public entity” means any entity listed in subsection (a) that provides public services, programs, or activities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd49a29-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The remedy for a violation of subsection (b) shall be such remedy as would be appropriate if awarded under section 203 or 308(a) of the Americans with Disabilities Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12133"},"text":"42 U.S.C. 12133","children":[],"tail":", 12188(a)), except that, with respect to any claim of employment discrimination asserted by any covered employee, the exclusive remedy shall be under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1311"},"text":"section 1311 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd49a2a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Available procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd49a2b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charge filed with General Counsel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A qualified individual with a disability, as defined in section 201(2) of the Americans with Disabilities Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12131/2"},"text":"42 U.S.C. 12131(2)","children":[],"tail":"), who alleges a violation of subsection (b) by an entity listed in subsection (a), may file a charge against any entity responsible for correcting the violation with the General Counsel within 180 days of the occurrence of the alleged violation. The General Counsel shall investigate the charge."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a2c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mediation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, upon investigation under paragraph (1), the General Counsel believes that a violation of subsection (b) may have occurred and that mediation may be helpful in resolving the dispute, the General Counsel may request, but not participate in, mediation under subsections (b) through (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1403"},"text":"section 1403 of this title","children":[],"tail":" between the charging individual and any entity responsible for correcting the alleged violation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a2d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Complaint, hearing, Board review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If mediation under paragraph (2) has not succeeded in resolving the dispute, and if the General Counsel believes that a violation of subsection (b) may have occurred, the General Counsel may file with the Office a complaint against any entity responsible for correcting the violation. The complaint shall be submitted to a hearing officer for decision pursuant to subsections (b) through (h) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1405"},"text":"section 1405 of this title","children":[],"tail":" and any person who has filed a charge under paragraph (1) may intervene as of right, with the full rights of a party. The decision of the hearing officer shall be subject to review by the Board pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1406"},"text":"section 1406 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a2e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A charging individual who has intervened under paragraph (3) or any respondent to the complaint, if aggrieved by a final decision of the Board under paragraph (3), may file a petition for review in the United States Court of Appeals for the Federal Circuit, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1407"},"text":"section 1407 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a2f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If new appropriated funds are necessary to comply with an order requiring correction of a violation of subsection (b), compliance shall take place as soon as possible, but no later than the fiscal year following the end of the fiscal year in which the order requiring correction becomes final and not subject to further review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd49a30-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations to implement section","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd49a31-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1384"},"text":"section 1384 of this title","children":[],"tail":", issue regulations to implement this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a32-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations issued under paragraph (1) shall be the same as substantive regulations promulgated by the Attorney General and the Secretary of Transportation to implement the statutory provisions referred to in subsection (b) except to the extent that the Board may determine, for good cause shown and stated together with the regulation, that a modification of such regulations would be more effective for the implementation of the rights and protections under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a33-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entity responsible for correction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations issued under paragraph (1) shall include a method of identifying, for purposes of this section and for categories of violations of subsection (b), the entity responsible for correction of a particular violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd49a34-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic inspections; report to Congress; initial study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd49a35-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic inspections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On a regular basis, and at least once each Congress, the General Counsel shall inspect the facilities of the entities listed in subsection (a) to ensure compliance with subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a36-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On the basis of each periodic inspection, the General Counsel shall, at least once every Congress, prepare and submit a report—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd49a37-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Speaker of the House of Representatives, the President pro tempore of the Senate, and the Office of the Architect of the Capitol, or other entity responsible,","children":[{"tag":"ref","attrib":{"idref":"fn002057"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002057"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" for correcting the violation of this section uncovered by such inspection, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd49a38-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" containing the results of the periodic inspection, describing any steps necessary to correct any violation of this section, assessing any limitations in accessibility to and usability by individuals with disabilities associated with each violation, and the estimated cost and time needed for abatement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a39-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial period for study and corrective action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The period from ","children":[{"tag":"date","attrib":{"date":"1995-01-23"},"text":"January 23, 1995","children":[],"tail":", until "},{"tag":"date","attrib":{"date":"1996-12-31"},"text":"December 31, 1996","children":[],"tail":", shall be available to the Office of the Architect of the Capitol and other entities subject to this section to identify any violations of subsection (b), to determine the costs of compliance, and to take any necessary corrective action to abate any violations. The Office shall assist the Office of the Architect of the Capitol and other entities listed in subsection (a) by arranging for inspections and other technical assistance at their request. Prior to "},{"tag":"date","attrib":{"date":"1996-07-01"},"text":"July 1, 1996","children":[],"tail":", the General Counsel shall conduct a thorough inspection under paragraph (1) and shall submit the report under paragraph (2) for the One Hundred Fourth Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a3a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detailed personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General, the Secretary of Transportation, and the Architectural and Transportation Barriers Compliance Board may, on request of the Executive Director, detail to the Office such personnel as may be necessary to advise and assist the Office in carrying out its duties under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd49a3b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd49a3c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election of remedies relating to rights to public services and accommodations for Library visitors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd49a3d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of Library visitor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “Library visitor” means an individual who is eligible to bring a claim for a violation under title II or III of the Americans with Disabilities Act of 1990 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12131"},"text":"42 U.S.C. 12131","children":[],"tail":" et seq., 12181 et seq.] (other than a violation for which the exclusive remedy is under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1311"},"text":"section 1311 of this title","children":[],"tail":") against the Library of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd49a3e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election of remedies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd49a3f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Library visitor who alleges a violation of subsection (b) by the Library of Congress may, subject to subparagraph (B)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcd49a40-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/h/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" file a charge against the Library of Congress under subsection (d); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcd49a41-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/h/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the remedies and procedures set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e–16"},"text":"section 2000e–16 of title 42","children":[],"tail":", as provided under section 510 (other than paragraph (5)) of the Americans with Disabilities Act of 1990 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12209"},"text":"42 U.S.C. 12209","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd49a42-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Library visitor that has initiated proceedings under clause (i) or (ii) of subparagraph (A) may elect to change and initiate a proceeding under the other clause—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcd49a43-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/h/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a Library visitor who first filed a charge pursuant to subparagraph (A)(i), before the General Counsel files a complaint under subsection (d)(3); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcd49a44-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/h/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a Library visitor who first initiated a proceeding under subparagraph (A)(ii), before the Library visitor requests a hearing under the procedures of the Library of Congress described in such subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd49a45-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd49a46-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1331/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsections (b), (c), and (d) s