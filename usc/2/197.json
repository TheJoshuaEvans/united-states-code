{"tag":"section","attrib":{"id":"iddc943594-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s197"},"text":null,"children":[{"tag":"num","attrib":{"value":"197"},"text":"§ 197.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation of employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The rate of compensation for any position under the appropriations now available for, or hereafter made for, expenses of inquiries and investigations of the Senate or expenses of special and select committees of the House of Representatives shall not exceed the rates fixed under chapter 51 and subchapter III of chapter 53 of title 5, for positions with comparable duties; and the salary limitations of $3,600 attached to appropriations heretofore made for expenses of inquiries and investigations of the Senate or for expenses of special and select committees of the House of Representatives are repealed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc943595-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-02-09/ch9"},"text":"Feb. 9, 1937, ch. 9","children":[],"tail":", title I, § 1, "},{"tag":"ref","attrib":{"href":"/us/stat/50/9"},"text":"50 Stat. 9","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-10-28/ch782"},"text":"Oct. 28, 1949, ch. 782","children":[],"tail":", title XI, § 1106(a), "},{"tag":"ref","attrib":{"href":"/us/stat/63/972"},"text":"63 Stat. 972","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc943596-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc943597-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":n