{"tag":"section","attrib":{"id":"iddd3d9553-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6577"},"text":null,"children":[{"tag":"num","attrib":{"value":"6577"},"text":"§ 6577.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senate legislative information system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3d9554-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6577/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development and implementation by Secretary of Senate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Senate, with the oversight and approval of the Committee on Rules and Administration of the Senate, shall oversee the development and implementation of a comprehensive Senate legislative information system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3d9555-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6577/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative effort","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary of the Senate shall consult and work with officers and employees of the House of Representatives. Legislative branch agencies and departments and agencies of the executive branch shall provide cooperation, consultation, and assistance as requested by the Secretary of the Senate to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3d9556-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6577/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any funds that were appropriated under the heading “Secretary of the Senate” for expenses of the Office of the Secretary of the Senate by the Legislative Branch Appropriations Act, 1995, to remain available until ","children":[{"tag":"date","attrib":{"date":"1998-09-30"},"text":"September 30, 1998","children":[],"tail":", and that the Secretary determines are not needed for development of a financial management system for the Senate may, with the approval of the Committee on Appropriations of the Senate, be used to carry out the provisions of this section, and such funds shall be available through "},{"tag":"date","attrib":{"date":"2000-09-30"},"text":"September 30, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3d9557-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6577/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee on Rules and Administration of the Senate may prescribe such regulations as may be necessary to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3d9558-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6577/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall be effective for fiscal years beginning on or after ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"October 1, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3d9559-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/197/tI/s8"},"text":"Pub. L. 104–197, title I, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-16"},"text":"Sept. 16, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2398"},"text":"110 Stat. 2398","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3d955a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3d955b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd3d955c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Legislative Branch Appropriations Act, 1995, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/283"},"text":"Pub. L. 103–283","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-22"},"text":"July 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1423"},"text":"108 Stat. 1423","children":[],"tail":". Provisions under the heading “Secretary of the Senate” in "},{"tag":"ref","attrib":{"href":"/us/pl/103/283"},"text":"Pub. L. 103–283","children":[],"tail":" appear at "},{"tag":"ref","attrib":{"href":"/us/stat/108/1425"},"text":"108 Stat. 1425","children":[],"tail":", and are not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3d955d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s123e"},"text":"section 123e of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Congressional Operations Appropriations Act, 1997, which is title I of the Legislative Branch Appropriations Act, 1997.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
