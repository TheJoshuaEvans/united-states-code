{"tag":"section","attrib":{"id":"iddcec67d4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1868a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1868a"},"text":"§ 1868a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Semiannual report of disbursements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcec67d5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1868a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the last day of each semiannual period, the Architect of the Capitol shall submit to Congress, with respect to that period, a detailed, itemized report of the disbursements for the operations of the Office of the Architect of the Capitol.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec67d6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1868a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required by subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcec67d7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1868a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of each person who receives a payment from the Office of the Architect of the Capitol;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec67d8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1868a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity and price of any item furnished to the Office of the Architect of the Capitol;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec67d9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1868a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any service rendered to the Office of the Architect of the Capitol, together with a statement of the time required for the service, and the name, title, and amount paid to each person who renders the service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec67da-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1868a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of all amounts appropriated to, or received or expended by, the Office of the Architect of the Capitol and any unexpended balances of such amounts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec67db-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1868a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information submitted to the Comptroller General under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3523/b"},"text":"section 3523(b) of title 31","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec67dc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1868a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such additional information as may be required by regulation of the Committee on House Administration of the House of Representatives or the Committee on Rules and Administration of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec67dd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1868a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Printing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report under this section shall be printed as a House document.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec67de-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1868a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to the semiannual periods of January 1 through June 30 and July 1 through December 31 of each year, beginning with the semiannual period in which this section is enacted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcec67df-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/76/dI/tI/s1301"},"text":"Pub. L. 113–76, div. I, title I, § 1301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-01-17"},"text":"Jan. 17, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/428"},"text":"128 Stat. 428","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
