{"tag":"section","attrib":{"id":"iddd104417-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4336"},"text":null,"children":[{"tag":"num","attrib":{"value":"4336"},"text":"§ 4336.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary authority of Senate Committee on Appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd104418-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4336/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee on Appropriations is authorized in its discretion—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd104419-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4336/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to hold hearings, report such hearings, and make investigations as authorized by paragraph 1 of rule XXVI of the Standing Rules of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd10441a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4336/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make expenditures from the contingent fund of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd10441b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4336/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to employ personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd10441c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4336/a/4"},"text":null,"children":[{"ta