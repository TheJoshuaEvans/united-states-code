{"tag":"section","attrib":{"id":"iddca9b937-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s623"},"text":null,"children":[{"tag":"num","attrib":{"value":"623"},"text":"§ 623.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing study of additional budget reform proposals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddca9b938-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s623/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Committees on the Budget of the House of Representatives and the Senate shall study on a continuing basis proposals designed to improve and facilitate methods of congressional budgetmaking. The proposals to be studied shall include, but are not limited to, proposals for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca9b939-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s623/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the information base required for determining the effectiveness of new programs by such means as pilot testing, survey research, and other experimental and analytical techniques;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca9b93a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s623/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving analytical and systematic evaluation of the effectiveness of existing programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca9b93b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s623/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing maximum and minimum time limitations for program authorization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca9b93c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s623/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing techniques of human resource accounting and other means of providing noneconomic as well as economic evaluation measures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca9b93d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s623/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on the Budget of each House shall, from time to time, report to its House the results of the study carried on by it under subsection (a), together with its recommendations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca9b93e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s623/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section shall preclude studies to improve the budgetary process by any other committee of the House of Representatives or the Senate or any joint committee of the Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddca9b93f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344/tVII/s703"},"text":"Pub. L. 93–344, title VII, § 703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-07-12"},"text":"July 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/326"},"text":"88 Stat. 326","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddca9b940-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddca9b941-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddca9b942-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1303"},"text":"section 1303 of Title 31","children":[],"tail":" prior to the general revision and enactment of Title 31, Money and Finance, by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s1"},"text":"Pub. L. 97–258, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/877"},"text":"96 Stat. 877","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
