{"tag":"section","attrib":{"id":"iddd2a81be-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5304"},"text":null,"children":[{"tag":"num","attrib":{"value":"5304"},"text":"§ 5304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Salaries of Representatives, Delegates, and Resident Commissioners elected for unexpired terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The salaries of Representatives in Congress, Delegates from Territories, and Resident Commissioners, elected for unexpired terms, shall commence on the date of their election and not before.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd2a81bf-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-07-16/ch141/s1"},"text":"July 16, 1914, ch. 141, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/458"},"text":"38 Stat. 458","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2a81c0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2a81c1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2a81c2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s37"},"text":"section 37 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
