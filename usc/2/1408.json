{"tag":"section","attrib":{"id":"iddcdbc593-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1408"},"text":null,"children":[{"tag":"num","attrib":{"value":"1408"},"text":"§ 1408.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil action","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcdbc594-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1408/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The district courts of the United States shall have jurisdiction over any civil action commenced under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1401"},"text":"section 1401 of this title","children":[],"tail":" and this section by a covered employee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcdbc595-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1408/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The defendant shall be the employing office alleged to have committed the violation, or in which the violation is alleged to have occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcdbc596-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1408/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jury trial","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any party may demand a jury trial where a jury trial would be available in an action against a private defendant under the relevant law made applicable by this chapter. In any case in which a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1311"},"text":"section 1311 of this title","children":[],"tail":" is alleged, the court shall not inform the jury of the maximum amount of compensatory damages available under section 1311(b)(1) or 1311(b)(3) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcdbc597-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1408/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appearances by House Employment Counsel","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcdbc598-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1408/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The House Employment Counsel of the House of Representatives and any other counsel in the Office of House Employment Counsel of the House of Representatives, including any counsel specially retained by the Office of House Employment Counsel, shall be entitled, for the purpose of providing legal assistance and representation to employing offices of the House of Representatives under this chapter, to enter an appearance in any proceeding before any court of the United States or of any State or political subdivision thereof without compliance with any requirements for admission to practice before such court, except that the authorization conferred by this paragraph shall not apply with respect to the admission of any such person to practice before the United States Supreme Court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcdbc599-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1408/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" House Employment Counsel defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “Office of House Employment Counsel of the House of Representatives” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcdbc59a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1408/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of House Employment Counsel established and operating under the authority of the Clerk of the House of Representatives as of ","children":[{"tag":"date","attrib":{"date":"2001-11-12"},"text":"November 12, 2001","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcdbc59b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1408/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any successor office to the Office of House Employment Counsel which is established after ","children":[{"tag":"date","attrib":{"date":"2001-11-12"},"text":"November 12, 2001","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcdbc59c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1408/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other person authorized and directed in accordance with the Rules of the House of Representatives to provide legal assistance and representation to employing offices of the House of Representatives in connection with actions brought under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcdbc59d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/tIV/s408"},"text":"Pub. L. 104–1, title IV, § 408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/37"},"text":"109 Stat. 37","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/68/tI/s119/a"},"text":"Pub. L. 107–68, title I, § 119(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-12"},"text":"Nov. 12, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/573"},"text":"115 Stat. 573","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/397/tI/s101/b"},"text":"Pub. L. 115–397, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5300"},"text":"132 Stat. 5300","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcdbc59e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcdbc59f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcdbc5a0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (c) and (d)(1), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1"},"text":"Pub. L. 104–1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/3"},"text":"109 Stat. 3","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1301"},"text":"section 1301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcdbc5a1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/397"},"text":"Pub. L. 115–397","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1401"},"text":"section 1401 of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1404"},"text":"section 1404 of this title","children":[],"tail":"” and struck out “who has completed counseling under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1402"},"text":"section 1402 of this title","children":[],"tail":" and mediation under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1403"},"text":"section 1403 of this title","children":[],"tail":". A civil action may be commenced by a covered employee only to seek redress for a violation for which the employee has completed counseling and mediation” after “covered employee”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/68"},"text":"Pub. L. 107–68","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcdbc5a2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcdbc5a3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/397"},"text":"Pub. L. 115–397","children":[],"tail":" effective upon expiration of the 180-day period beginning on "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", with provisions for effect on pending proceedings, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/397/s401"},"text":"section 401 of Pub. L. 115–397","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcdbc5a4-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2001 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/68/tI/s119/b"},"text":"Pub. L. 107–68, title I, § 119(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-12"},"text":"Nov. 12, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/574"},"text":"115 Stat. 574","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/68/tI/s119/b"},"text":"“The amendment made by this section [amending this section] shall apply with respect to proceedings occurring on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2001-11-12"},"text":"Nov. 12, 2001","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
