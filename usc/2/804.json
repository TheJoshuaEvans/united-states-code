{"tag":"section","attrib":{"id":"iddcb81207-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s804"},"text":null,"children":[{"tag":"num","attrib":{"value":"804"},"text":"§ 804.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcb81208-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s804/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director; status; appointment and term; removal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the administration of the Congressional Award Program, the Board shall be assisted by a Director, who shall be the principal executive of the program and who shall supervise the affairs of the Board. The Director shall be appointed by a majority vote of the Board, and shall serve for such term as the Board may determine. The Director may be removed by a majority vote of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb81209-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s804/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Director","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall, in consultation with the Board—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcb8120a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s804/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" formulate programs to carry out the policies of the Congressional Award Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb8120b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s804/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish such divisions within the Congressional Award Program as may be appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb8120c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s804/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employ and provide for the compensation of such personnel as may be necessary to carry out the Congressional Award Program, subject to such policies as the Board shall prescribe under its bylaws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb8120d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s804/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements regarding financial operations; noncompliance with requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcb8120e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s804/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall, in consultation with the Board, ensure that appropriate policies and procedures for fiscal control and accounting are established for the financial operations of the Congressional Award Program, and that such operations are administered by personnel with expertise in accounting and financial management. Such personnel may be retained under contract. In carrying out this paragraph, the Director shall ensure that the liabilities of the Board do not in any fiscal year exceed the assets of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb8120f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s804/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcb81210-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s804/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The independent public accountant conducting the annual audit of the financial records of the Board pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s807/a"},"text":"section 807(a) of this title","children":[],"tail":" shall determine for each fiscal year whether the Director has substantially complied with paragraph (1). The findings made by the independent public accountant under the preceding sentence shall be included in the reports submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s807/b"},"text":"section 807(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcb81211-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s804/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Director fails to substantially comply with paragraph (1), the Board shall instruct the Director to take such actions as may be necessary to correct such deficiencies, and shall remove and replace the Director if such deficiencies are not promptly corrected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcb81212-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/114/tI/s104"},"text":"Pub. L. 96–114, title I, § 104","children":[],"tail":", formerly § 5, "},{"tag":"date","attrib":{"date":"1979-11-16"},"text":"Nov. 16, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/853"},"text":"93 Stat. 853","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/457/s2"},"text":"Pub. L. 102–457, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2265"},"text":"106 Stat. 2265","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tV/s5401/a"},"text":"Pub. L. 104–208, div. A, title V, § 5401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-511"},"text":"110 Stat. 3009–511","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/63/s1/c"},"text":"Pub. L. 106–63, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"Oct. 1, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/510"},"text":"113 Stat. 510","children":[],"tail":"; renumbered title I, § 104, "},{"tag":"ref","attrib":{"href":"/us/pl/106/533/s1/b/1"},"text":"Pub. L. 106–533, § 1(b)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2553"},"text":"114 Stat. 2553","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/143/s1/a"},"text":"Pub. L. 109–143, § 1(a)","children":[],"tail":", (c)(2), "},{"tag":"date","attrib":{"date":"2005-12-22"},"text":"Dec. 22, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2659"},"text":"119 Stat. 2659","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/200/s2/c"},"text":"Pub. L. 111–200, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-07"},"text":"July 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1369"},"text":"124 Stat. 1369","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/188/tIX/s902/c/2"},"text":"Pub. L. 113–188, title IX, § 902(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2021"},"text":"128 Stat. 2021","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcb81213-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcb81214-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcb81215-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/188/s902/c/2/A"},"text":"Pub. L. 113–188, § 902(c)(2)(A)","children":[],"tail":", inserted “policies and” before “procedures” and struck out “fund” before “accounting are established”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/188/s902/c/2/B"},"text":"Pub. L. 113–188, § 902(c)(2)(B)","children":[],"tail":", substituted “The independent public accountant conducting the annual audit of the financial records of the Board pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s807/a"},"text":"section 807(a) of this title","children":[],"tail":"” for “The Comptroller General of the United States” and “the independent public accountant” for “the Comptroller General”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/200/s2/c/1"},"text":"Pub. L. 111–200, § 2(c)(1)","children":[],"tail":", which directed substitution of “in any fiscal year” for “, in any calendar year,” in third sentence, was executed by making the substitution for “, for any calendar year,” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/200/s2/c/2"},"text":"Pub. L. 111–200, § 2(c)(2)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2)(A) The Comptroller General of the United States shall determine, for calendar years 1993, 1994, 1995, 1996, 1997, 1998, 1999, 2000, 2001, 2002, 2003, 2004, 2005, 2006, 2007, 2008, and 2009, whether the Director has substantially complied with paragraph (1). The findings made by the Comptroller General under the preceding sentence shall be included in the first report submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s807/b"},"text":"section 807(b) of this title","children":[],"tail":" after "},{"tag":"date","attrib":{"date":"1994-12-31"},"text":"December 31, 1994","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) If the Director fails to substantially comply with paragraph (1), the Board shall take such actions as may be necessary to prepare, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s808"},"text":"section 808 of this title","children":[],"tail":", for the orderly cessation of the activities of the Board.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/143"},"text":"Pub. L. 109–143","children":[],"tail":" inserted comma after “1993” and substituted “2004, 2005, 2006, 2007, 2008, and 2009” for “and 2004”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/63"},"text":"Pub. L. 106–63","children":[],"tail":" substituted “1998, 1999, 2000, 2001, 2002, 2003, and 2004” for “and 1998”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" substituted “1994, 1995, 1996, 1997, and 1998” for “and 1994”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/457"},"text":"Pub. L. 102–457","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcb81216-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcb81217-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/188/tIX/s902/c/3"},"text":"Pub. L. 113–188, title IX, § 902(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2022"},"text":"128 Stat. 2022","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/188/tIX/s902/c/3"},"text":"“The amendments made by this subsection [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s807"},"text":"section 807 of this title","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"2014-10-01"},"text":"October 1, 2014","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
