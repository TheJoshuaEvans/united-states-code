{"tag":"section","attrib":{"id":"iddcb8117e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s686"},"text":null,"children":[{"tag":"num","attrib":{"value":"686"},"text":"§ 686.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports by Comptroller General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcb8117f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s686/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to transmit special message","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Comptroller General finds that the President, the Director of the Office of Management and Budget, the head of any department or agency of the United States, or any other officer or employee of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcb81180-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s686/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is to establish a reserve or proposes to defer budget authority with respect to which the President is required to transmit a special message under section 683 or 684 of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcb81181-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s686/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has ordered, permitted, or approved the establishment of such a reserve or a deferral of budget authority;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"and that the President has failed to transmit a special message with respect to such reserve or deferral, the Comptroller General shall make a report on such reserve or deferral and any available information concerning it to both Houses of Congress. The provisions of sections 682 to 688 of this title shall apply with respect to such reserve or deferral in the same manner and with the same effect as if such report of the Comptroller General were a special message transmitted by the President under section 683 or 684 of this title, and, for purposes of sections 682 to 688 of this title, such report shall be considered a special message transmitted under section 683 or 684 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb81182-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s686/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incorrect classification of special message","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the President has transmitted a special message to both Houses of Congress in accordance with section 683 or 684 of this title, and the Comptroller General believes that the President so transmitted the special message in accordance with one of those sections when the special message should have been transmitted in accordance with the other of those sections, the Comptroller General shall make a report to both Houses of the Congress setting forth his reasons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcb81183-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344/tX/s1015"},"text":"Pub. L. 93–344, title X, § 1015","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-07-12"},"text":"July 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/336"},"text":"88 Stat. 336","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcb81184-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcb81185-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcb81186-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1405"},"text":"section 1405 of Title 31","children":[],"tail":" prior to the general revision and enactment of Title 31, Money and Finance, by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s1"},"text":"Pub. L. 97–258, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/877"},"text":"96 Stat. 877","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcb81187-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddcb81188-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reaffirmation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/119/tII/s206/c"},"text":"Pub. L. 100–119, title II, § 206(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-09-29"},"text":"Sept. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/786"},"text":"101 Stat. 786","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/119/tII/s206/c"},"text":"“Sections 1015 and 1016 of the Impoundment Control Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s686"},"text":"2 U.S.C. 686","children":[],"tail":", 687] are reaffirmed.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
