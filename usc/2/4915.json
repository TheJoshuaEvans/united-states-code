{"tag":"section","attrib":{"id":"iddd2810ab-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4915"},"text":null,"children":[{"tag":"num","attrib":{"value":"4915"},"text":"§ 4915.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of page during academic year and summer term; filling of vacancies; eligibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2810ac-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4915/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2810ad-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4915/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsection (b), a page serving during an academic year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2810ae-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4915/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be in the eleventh grade; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2810af-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4915/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall serve for one full semester or two full semesters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2810b0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4915/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsection (b), a page serving during the summer term—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2810b1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4915/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have completed the tenth grade; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2810b2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4915/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not have begun the twelfth grade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2810b3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4915/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2810b4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4915/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An unforeseen vacancy occurring in a page position during an academic year may be filled, except that no appointment may be made under this paragraph for service to begin on or after October 1 with respect to the first semester or on or after March 1 with respect to the second semester.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2810b5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4915/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual who has served as a congressional page at any time during each of any three semesters or terms, as the case may be, shall not be eligible to serve as a page.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2810b6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/367/tI/s103"},"text":"Pub. L. 98–367, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-17"},"text":"July 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/479"},"text":"98 Stat. 479","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s204/40/C"},"text":"Pub. L. 104–186, title II, § 204(40)(C)","children":[],"tail":"–(E), "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1736"},"text":"110 Stat. 1736","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2810b7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2810b8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2810b9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s88c–3"},"text":"section 88c–3 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 3 of House Resolution No. 234, Ninety-eighth Congress, ","children":[{"tag":"date","attrib":{"date":"1983-06-29"},"text":"June 29, 1983","children":[],"tail":", which was enacted into permanent law by "},{"tag":"ref","attrib":{"href":"/us/pl/98/367"},"text":"Pub. L. 98–367","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd2810ba-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/s204/40/C"},"text":"Pub. L. 104–186, § 204(40)(C)","children":[],"tail":", substituted “semester or two full semesters” for “term or two full terms”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/s204/40/D"},"text":"Pub. L. 104–186, § 204(40)(D)","children":[],"tail":", substituted “except that no appointment may be made under this paragraph for service to begin on or after October 1 with respect to the first semester or on or after March 1 with respect to the second semester” for “but no appointment to fill that vacancy shall be for a period of less than two months”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186/s204/40/E"},"text":"Pub. L. 104–186, § 204(40)(E)","children":[],"tail":", substituted “semesters or terms, as the case may be,” for “terms”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd2810bb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd2810bc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1983-06-29"},"text":"June 29, 1983","children":[],"tail":", except that subsecs. (a)(1)(A) and (b)(2) applicable to terms beginning after "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", see note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4914"},"text":"section 4914 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
