{"tag":"section","attrib":{"id":"iddce7ad1a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1816a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1816a"},"text":"§ 1816a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Design-build contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce7ad1b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1816a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, the Architect of the Capitol may use the two-phase selection procedures authorized in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3309"},"text":"section 3309 of title 41","children":[],"tail":" for entering into a contract for the design and construction of a public building, facility, or work in the same manner and under the same terms and conditions as the head of an executive agency under such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7ad1c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1816a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall apply with respect to fiscal year 2008 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce7ad1d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/dH/tI/s1308"},"text":"Pub. L. 110–161, div. H, title I, § 1308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2244"},"text":"121 Stat. 2244","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce7ad1e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddce7ad1f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddce7ad20-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3309"},"text":"section 3309 of title 41","children":[],"tail":"” substituted for “section 303M of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s253m"},"text":"41 U.S.C. 253m","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2008, which is div. H of the Consolidated Appropriations Act, 2008.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
