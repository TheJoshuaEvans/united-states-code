{"tag":"section","attrib":{"id":"iddc708168-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"§ 22.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oath of President of Senate","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When a President of the Senate has not taken the oath of office, it shall be administered to him by any Member of the Senate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc708169-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(R.S. § 29.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc70816a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc70816b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc70816c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 29 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1789-06-01/ch1/s2"},"text":"act June 1, 1789, ch. 1, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/1/23"},"text":"1 Stat. 23","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
