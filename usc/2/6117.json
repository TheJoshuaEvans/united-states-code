tion","id":"iddd31ae23-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s46a"},"text":"section 46a of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from Legislative Branch Appropriation Act, 1942, and subsequent Legislative Branch Appropriation Acts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd31ae24-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":" substituted “$8,000” for “$4,500”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/32"},"text":"Pub. L. 94–32","children":[],"tail":" substituted “Effective "},{"tag":"date","attrib":{"date":"1975-04-01"},"text":"April 1, 1975","children":[],"tail":", and each fiscal year thereafter” for “Effective with the fiscal year 1972 and thereafter” and “$4,500” for “$3,600”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/607"},"text":"Pub. L. 92–607","children":[],"tail":" repealed this section insofar as it related to Senators. For purposes of codification this entailed substituting a period for a comma following “President of the Senate shall be $3,600” and striking out provisions which allowed Senators from $3,600 to $5,000 annually depending on the population of the Senator’s home State. See "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s6314"},"text":"section 6314 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag"