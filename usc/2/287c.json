{"tag":"section","attrib":{"id":"iddc96a6d7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s287c"},"text":null,"children":[{"tag":"num","attrib":{"value":"287c"},"text":"§ 287c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc96a6d8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s287c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Parliamentarian shall be paid at a per annum gross rate established by the Speaker but not in excess of the greater of $173,900 or the rate of pay in effect for such position under an order issued by the Speaker of the House of Representatives pursuant to the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s4532"},"text":"section 4532 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc96a6d9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s287c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the staff of the Office other than the Parliamentarian shall be paid at per annum gross rates fixed by the Parliamentarian with the approval of the Speaker or in accordance with policies approved by the Speaker but not in excess of the applicable rate of pay in effect under an order issued by the Speaker of the House of Representatives pursuant to the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s4532"},"text":"section 4532 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc98f0ca-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/94/tI/s115"},"text":"Pub. L. 95–94, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-05"},"text":"Aug. 5, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/668"},"text":"91 Stat. 668","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dE/tII/s212/b/3/C"},"text":"Pub. L. 116–94, div. E, title II, § 212(b)(3)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2777"},"text":"133 Stat. 2777","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc98f0cb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc98f0cc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc98f0cd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 4 of House Resolution No. 502, Ninety-fifth Congress, ","children":[{"tag":"date","attrib":{"date":"1977-04-20"},"text":"Apr. 20, 1977","children":[],"tail":", which was enacted into permanent law by "},{"tag":"ref","attrib":{"href":"/us/pl/95/94"},"text":"Pub. L. 95–94","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddc98f0ce-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"House Resolution No. 904, Eighty-eighth Congress, ","children":[{"tag":"date","attrib":{"date":"1964-10-03"},"text":"Oct. 3, 1964","children":[],"tail":", provided: “That effective "},{"tag":"date","attrib":{"date":"1965-01-01"},"text":"January 1, 1965","children":[],"tail":", the salary of the Parliamentarian of the House of Representatives shall be at the gross rate of $28,500. The additional sums necessary to carry out this resolution shall be paid out of the contingent fund of the House until otherwise provided by law.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc98f0cf-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s212/b/3/C/i"},"text":"Pub. L. 116–94, § 212(b)(3)(C)(i)","children":[],"tail":", substituted “but not in excess of the greater of $173,900 or the rate of pay in effect for such position under an order issued by the Speaker of the House of Representatives pursuant to the authority of "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4532"},"text":"section 4532 of this title","children":[],"tail":".” for “but not in excess of the rate of basic pay determined from time to time under subsection (b) of section 3 of the Speaker’s salary directive of "},{"tag":"date","attrib":{"date":"1968-06-11"},"text":"June 11, 1968","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s212/b/3/C/ii"},"text":"Pub. L. 116–94, § 212(b)(3)(C)(ii)","children":[],"tail":", substituted “but not in excess of the applicable rate of pay in effect under an order issued by the Speaker of the House of Representatives pursuant to the authority of "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4532"},"text":"section 4532 of this title","children":[],"tail":"” for “, but not in excess of the rate of basic pay set forth in subsection (a) of this section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc98f0d0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"c