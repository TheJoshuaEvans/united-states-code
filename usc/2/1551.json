{"tag":"section","attrib":{"id":"iddce0813f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1551"},"text":null,"children":[{"tag":"num","attrib":{"value":"1551"},"text":"§ 1551.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Baseline study of costs and benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce08140-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1551/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No later than 18 months after ","children":[{"tag":"date","attrib":{"date":"1995-03-22"},"text":"March 22, 1995","children":[],"tail":", the Advisory Commission on Intergovernmental Relations (hereafter in this subchapter referred to as the “Advisory Commission”), in consultation with the Director, shall complete a study to examine the measurement and definition issues involved in calculating the total costs and benefits to State, local, and tribal governments of compliance with Federal law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce08141-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1551/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study required by this section shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce08142-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1551/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the feasibility of measuring indirect costs and benefits as well as direct costs and benefits of the Federal, State, local, and tribal relationship; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce08143-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1551/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how to measure both the direct and indirect benefits of Federal financial assistance and tax benefits to State, local, and tribal governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce08144-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/4/tIII/s301"},"text":"Pub. L. 104–4, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-03-22"},"text":"Mar. 22, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/67"},"text":"109 Stat. 67","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
