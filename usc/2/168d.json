{"tag":"section","attrib":{"id":"iddc8d0924-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s168d"},"text":null,"children":[{"tag":"num","attrib":{"value":"168d"},"text":"§ 168d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations for Constitution Annotated","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums, to remain available until expended, as may be necessary to carry out the provisions of sections 168 to 168d of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc8d0925-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/589/s5"},"text":"Pub. L. 91–589, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1587"},"text":"84 Stat. 1587","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
