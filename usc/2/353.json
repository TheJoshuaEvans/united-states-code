{"tag":"section","attrib":{"id":"iddc9b627a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s353"},"text":null,"children":[{"tag":"num","attrib":{"value":"353"},"text":"§ 353.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Director; additional personnel; detail of personnel of other agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc9b627b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s353/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Without regard to the provisions of title 5 governing appointments in the competitive service, and the provisions of chapter 51 and subchapter III of chapter 53 of such title, relating to classification and General Schedule pay rates, and on a temporary basis for periods covering all or part of any fiscal year referred to in subparagraphs (A) and (B) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s352/8"},"text":"section 352(8) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc9b627c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s353/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission is authorized to appoint an Executive Director and fix his basic pay at the rate provided for level V of the Executive Schedule by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5316"},"text":"section 5316 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9b627d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s353/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the approval of the Commission, the Executive Director is authorized to appoint and fix the basic pay (at respective rates not in excess of the maximum rate of the General Schedule in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":") of such additional personnel as may be necessary to carry out the function of the Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9b627e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s353/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon the request of the Commission, the head of any department, agency, or establishment of any branch of the Federal Government is authorized to detail, on a reimbursable basis, for periods covering all or part of any fiscal year referred to in subparagraphs (A) and (B) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s352/8"},"text":"section 352(8) of this title","children":[],"tail":", any of the personnel of such department, agency, or establishment to assist the Commission in carrying out its function."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc9b627f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/206/tII/s225/c"},"text":"Pub. L. 90–206, title II, § 225(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-16"},"text":"Dec. 16, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/643"},"text":"81 Stat. 643","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/194/tVII/s701/c"},"text":"Pub. L. 101–194, title VII, § 701(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-30"},"text":"Nov. 30, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1764"},"text":"103 Stat. 1764","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc9b6280-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc9b6281-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc9b6282-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/194"},"text":"Pub. L. 101–194","children":[],"tail":" substituted “subparagraphs (A) and (B) of "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s352/8"},"text":"section 352(8) of this title","children":[],"tail":"” for “section 352(2) and (3) of this title” in pars. (1) and (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc9b6283-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddc9b6284-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1967-12-16"},"text":"Dec. 16, 1967","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/206/s220/a/1"},"text":"section 220(a)(1) of Pub. L. 90–206","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3110"},"text":"section 3110 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddc9b6285-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References in Other Laws to GS–16, 17, or 18 Pay Rates","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References in laws to the rates of pay for GS–16, 17, or 18, or to maximum rates of pay under the General Schedule, to be considered references to rates payable under specified sections of Title 5, Government Organization and Employees, see section 529 [title I, § 101(c)(1)] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
