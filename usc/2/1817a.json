{"tag":"section","attrib":{"id":"iddce7ad31-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1817a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1817a"},"text":"§ 1817a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of surplus or obsolete personal property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce7ad32-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1817a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Architect of the Capitol shall have the authority, within the limits of available appropriations, to dispose of surplus or obsolete personal property by inter-agency transfer, donation, sale, trade-in, or discarding. Amounts received for the sale or trade-in of personal property shall be credited to funds available for the operations of the Architect of the Capitol and be available for the costs of acquiring the same or similar property. Such funds shall be available for such purposes during the fiscal year received and the following fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7ad33-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1817a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to fiscal year 2010, and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce7ad34-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/68/dA/tI/s1301"},"text":"Pub. L. 111–68, div. A, title I, § 1301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2034"},"text":"123 Stat. 2034","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce7ad35-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddce7ad36-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddce7ad37-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2010, which is div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/68"},"text":"Pub. L. 111–68","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
