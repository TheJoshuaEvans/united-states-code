{"tag":"section","attrib":{"id":"iddcff7a4b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2081"},"text":null,"children":[{"tag":"num","attrib":{"value":"2081"},"text":"§ 2081.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Capitol Preservation Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcff7a4c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2081/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established in the Congress the United States Capitol Preservation Commission (hereinafter in this part referred to as the “Commission”) for the purposes of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcff7a4d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2081/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for improvements in, preservation of, and acquisitions for, the United States Capitol;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcff7a4e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2081/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for works of fine art and other property for display in the United States Capitol and at other locations under the control of the Congress; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcff7a4f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2081/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting other activities that directly facilitate, encourage, or otherwise support any purposes specified in paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff7a50-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2081/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall be composed of the following Members of Congress:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcff7a51-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2081/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President pro tempore of the Senate and the Speaker of the House of Representatives, who shall be co-chairmen.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcff7a52-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2081/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman and Vice-Chairman of the Joint Committee on the Library.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcff7a53-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2081/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman and the ranking minority party member of the Committee on Rules and Administration of the Senate, and the Chairman and the ranking minority party member of the Committee on House Oversight of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcff7a54-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2081/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The majority leader and the minority leader of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcff7a55-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2081/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The majority leader and the minority leader of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcff7a56-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2081/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman of the Commission on the Bicentennial of the United States Senate and the Chairman of the Commission of the House of Representatives Bicentenary, to be succeeded upon expiration of such commissions, by a Senator or Member of the House of Representatives, as appropriate, appointed by the Senate or House of Representatives co-chairman of the Commission, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcff7a57-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2081/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One Senator appointed by the President pro tempore of the Senate and one Senator appointed by the minority leader of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcff7a58-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2081/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One Member of the House of Representatives appointed by the Speaker of the House of Representatives and one Member of the House of Representatives appointed by the minority leader of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff7a59-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2081/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Commission specified under subsection (b) (other than a member under paragraph (7) or (8) of such subsection) may designate a Senator or Member of the House of Representatives, as the case may be, to serve as a member of the Commission in place of the member so specified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff7a5a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2081/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Architect of the Capitol","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the members under subsection (b), the Architect of the Capitol shall participate in the activities of the Commission, ex officio, and without the right to vote.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcff7a5b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2081/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff support and assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Senate Commission on Art, the House of Representatives Fine Arts Board, and the Architect of the Capitol shall provide to the Commission such staff support and assistance as the Commission may request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcff7a5c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/696/tVIII/s801"},"text":"Pub. L. 100–696, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4608"},"text":"102 Stat. 4608","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s221/7"},"text":"Pub. L. 104–186, title II, § 221(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1749"},"text":"110 Stat. 1749","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcff7a5d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcff7a5e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcff7a5f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 188a of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcff7a60-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “House Oversight” for “House Administration”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcff7a61-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddcff7a62-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on House Oversight of House of Representatives changed to Committee on House Administration of House of Representatives by House Resolution No. 5, One Hundred Sixth Congress, ","children":[{"tag":"date","attrib":{"date":"1999-01-06"},"text":"Jan. 6, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
