{"tag":"section","attrib":{"id":"iddcf604ec-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1972"},"text":null,"children":[{"tag":"num","attrib":{"value":"1972"},"text":"§ 1972.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions of comfort and other incidental items and services during emergency duty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In addition to the authority provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1971"},"text":"section 1971 of this title","children":[],"tail":", at any time on or after "},{"tag":"date","attrib":{"date":"2002-01-10"},"text":"January 10, 2002","children":[],"tail":", the Capitol Police Board may accept contributions of comfort and other incidental items and services to support officers and employees of the United States Capitol Police while such officers and employees are on duty in response to emergencies involving the safety of human life or the protection of property."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcf604ed-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/117/dB/s910"},"text":"Pub. L. 107–117, div. B, § 910","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-10"},"text":"Jan. 10, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2322"},"text":"115 Stat. 2322","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf604ee-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf604ef-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcf604f0-3a6e-11f1