{"tag":"section","attrib":{"id":"iddd045c31-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2132"},"text":null,"children":[{"tag":"num","attrib":{"value":"2132"},"text":"§ 2132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Replacement of statue in Statuary Hall","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd045c32-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2132/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request by State","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd045c33-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2132/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any State may request the Joint Committee on the Library of Congress to approve the replacement of a statue the State has provided for display in Statuary Hall in the Capitol of the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2131"},"text":"section 2131 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd045c34-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2132/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A request shall be considered under paragraph (1) only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd045c35-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2132/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the request has been approved by a resolution adopted by the legislature of the State and the request has been approved by the Governor of the State, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd045c36-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2132/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the statue to be replaced has been displayed in the Capitol of the United States for at least 10 years as of the time the request is made, except that the Joint Committee may waive this requirement for cause at the request of a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd045c37-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2132/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement upon approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Joint Committee on the Library of Congress approves a request under subsection (a), the Architect of the Capitol shall enter into an agreement with the State to carry out the replacement in accordance with the request and any conditions the Joint Committee may require for its approval. Such agreement shall provide that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd045c38-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2132/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the new statue shall be subject to the same conditions and restrictions as apply to any statue provided by a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2131"},"text":"section 2131 of this title","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd045c39-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2132/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State shall pay any costs related to the replacement, including costs in connection with the design, construction, transportation, and placement of the new statue, the removal and transportation of the statue being replaced, and any unveiling ceremony.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd045c3a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2132/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on number of State statues","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be interpreted to permit a State to have more than two statues on display in the Capitol of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd045c3b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2132/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ownership of replaced statue; removal","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd045c3c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2132/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the approval of the Joint Committee on the Library, ownership of any statue replaced under this section shall be transferred to the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd045c3d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2132/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If any statue is removed from the Capitol of the United States as part of a transfer of ownership under paragraph (1), then it may not be returned to the Capitol for display unless such display is specifically authorized by Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd045c3e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2132/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relocation of statues","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Architect of the Capitol, upon the approval of the Joint Committee on the Library and with the advice of the Commission of Fine Arts as requested, is authorized and directed to relocate within the United States Capitol any of the statues received from the States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s2131"},"text":"section 2131 of this title","children":[],"tail":" prior to "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"December 21, 2000","children":[],"tail":", and to provide for the reception, location, and relocation of the statues received on and after "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"December 21, 2000","children":[],"tail":", from the States under such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd045c3f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/2/tIII/s311"},"text":"Pub. L. 106–554, § 1(a)(2) [title III, § 311]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–119.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd045c40-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd045c41-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd045c42-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 187a of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s1"},"text":"Pub. L. 107–217, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd045c43-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd045c44-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Location of Statues","children":[],"tail":null},{"tag":"p","attrib":{},"text":"House Concurrent Resolution 47, passed ","children":[{"tag":"date","attrib":{"date":"1933-02-24"},"text":"Feb. 24, 1933","children":[],"tail":", 47 Stat. Part 2, 1784, provided: “That the Architect of the Capitol, upon the approval of the Joint Committee on the Library, with the advice of the Commission of Fine Arts, is hereby authorized and directed to relocate within the Capitol any of the statues already received and placed in Statuary Hall, and to provide for the reception and location of the statues received hereafter from the States.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
