{"tag":"section","attrib":{"id":"iddc943566-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s191"},"text":null,"children":[{"tag":"num","attrib":{"value":"191"},"text":"§ 191.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oaths to witnesses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President of the Senate, the Speaker of the House of Representatives, or a chairman of any joint committee established by a joint or concurrent resolution of the two Houses of Congress, or of a committee of the whole, or of any committee of either House of Congress, is empowered to administer oaths to witnesses in any case under their examination.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Any member of either House of Congress may administer oaths to witnesses in any matter depending in either House of Congress of which he is a Member, or any committee thereof.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc943567-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(R.S. § 101; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1884-06-26/ch123"},"text":"June 26, 1884, ch. 123","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/23/60"},"text":"23 Stat. 60","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1938-06-22/ch594"},"text":"June 22, 1938, ch. 594","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/942"},"text":"52 Stat. 942","children":[],"tail":", 943.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc943568-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc943569-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc94356a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 101 derived from acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1798-05-03/ch36/s1"},"text":"May 3, 1798, ch. 36, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/1/554"},"text":"1 Stat. 554","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/act/1817-02-08/ch10"},"text":"Feb. 8, 1817, ch. 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/3/345"},"text":"3 Stat. 345","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 101 constitutes first sentence, and act ","children":[{"tag":"date","attrib":{"date":"1884-06-26"},"text":"June 26, 1884","children":[],"tail":", constitutes second sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc94356b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1938—Act ","children":[{"tag":"date","attrib":{"date":"1938-06-22"},"text":"June 22, 1938","children":[],"tail":", reenacted section without change."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
