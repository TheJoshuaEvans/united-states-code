{"tag":"section","attrib":{"id":"iddd3b243b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6515"},"text":null,"children":[{"tag":"num","attrib":{"value":"6515"},"text":"§ 6515.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of fees for services of Attending Physician and for use of Senate health and fitness facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3b243c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6515/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Senate Committee on Rules and Administration shall promulgate regulations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3b243d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6515/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pertaining to the services provided by the Attending Physician and the operation and use of the Senate health and fitness facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3b243e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6515/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requiring the payment of fees for services received from the Attending Physician and for the use of the Senate health and fitness facilities pursuant to such regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3b243f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6515/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding of fees from salary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Senate is authorized to withhold fees from the salary of an individual authorized by such regulations to receive such services from the Attending Physician and to use the Senate health and fitness facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3b2440-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6515/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit in General Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Senate shall remit all fees required by subsection (a)(2) that are collected pursuant to subsection (b) or by direct payment to the General Fund of the Treasury as miscellaneous receipts unless otherwise provided by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3b2441-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6515/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provision ","children":[{"tag":"ref","attrib":{"idref":"fn002119"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002119"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “provisions”."}],"tail":" of this section shall take effect on "},{"tag":"date","attrib":{"date":"1992-04-09"},"text":"April 9, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3b2442-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/392/tIII/s314"},"text":"Pub. L. 102–392, title III, § 314","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1723"},"text":"106 Stat. 1723","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3b2443-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3b2444-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3b2445-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s121e"},"text":"section 121e of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 1993.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
