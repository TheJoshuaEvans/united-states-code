{"tag":"section","attrib":{"id":"iddc8d094c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s173"},"text":null,"children":[{"tag":"num","attrib":{"value":"173"},"text":"§ 173.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Center for the Book","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is hereby established in the Library of Congress a Center for the Book.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Center shall be under the direction of the Librarian of Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc8d094d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/129/s3"},"text":"Pub. L. 95–129, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-13"},"text":"Oct. 13, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1151"},"text":"91 Stat. 1151","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
