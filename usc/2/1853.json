{"tag":"section","attrib":{"id":"iddcea1e89-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1853"},"text":null,"children":[{"tag":"num","attrib":{"value":"1853"},"text":"§ 1853.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption of officers and employees of Architect of Capitol from certain Federal pay provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The classes of employees whose compensation is authorized by section 3 of the Legislative Pay Act of 1929, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/stat/46/38"},"text":"46 Stat. 38","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/55/615"},"text":"55 Stat. 615","children":[],"tail":"), to be fixed by the Architect of the Capitol without regard to the Classification Act of 1923, as amended, are authorized to be compensated without regard to chapter 51 and subchapter III of chapter 53 of title 5."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcea1e8a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-28/ch782"},"text":"Oct. 28, 1949, ch. 782","children":[],"tail":", title II, § 204(a), "},{"tag":"ref","attrib":{"href":"/us/stat/63/957"},"text":"63 Stat. 957","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcea1e8b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcea1e8c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcea1e8d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag