{"tag":"section","attrib":{"id":"iddccd6e2f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1106"},"text":null,"children":[{"tag":"num","attrib":{"value":"1106"},"text":"§ 1106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures and audit of trust fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddccd6e30-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury is authorized to pay to the Center from the interest and earnings of the fund, and moneys credited to the fund pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1108/a"},"text":"section 1108(a) of this title","children":[],"tail":", such sums as the Board determines are necessary and appropriate to enable the Center to carry out the provisions of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddccd6e31-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit by GAO","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The activities of the Center under this chapter may be audited by the Government Accountability Office under such rules and regulations as may be prescribed by the Comptroller General of the United States. Representatives of the Government Accountability Office shall have access to all books, accounts, records, reports, and files and all other papers, things, or property belonging to or in use by the Center, pertaining to such activities and necessary to facilitate the audit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddccd6e32-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/458/tI/s117"},"text":"Pub. L. 100–458, title I, § 117","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-01"},"text":"Oct. 1, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2175"},"text":"102 Stat. 2175","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/520/tIII/s313/b"},"text":"Pub. L. 101–520, title III, § 313(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2282"},"text":"104 Stat. 2282","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddccd6e33-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddccd6e34-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddccd6e35-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/520"},"text":"Pub. L. 101–520","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “The Secretary of the Treasury is authorized to pay to the Center from the interest and earnings of the fund such sums as the Board determines are necessary and appropriate to enable the Center to carry out the provisions of this chapter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
