{"tag":"section","attrib":{"id":"iddd235656-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4581"},"text":null,"children":[{"tag":"num","attrib":{"value":"4581"},"text":"§ 4581.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregate gross compensation of employee of Senator of State with population under 5,000,000","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd235657-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4581/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s4575/d/1"},"text":"section 4575(d)(1) of this title","children":[],"tail":", and except as otherwise provided in subparagraph (C) of such subsection (d)(1), the aggregate of gross compensation paid employees in the office of a Senator shall not exceed during each fiscal year $1,012,083 if the population of his State is less than 5,000,000."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd235658-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4581/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) shall take effect ","children":[{"tag":"date","attrib":{"date":"1991-10-01"},"text":"October 1, 1991","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd235659-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/90/tI/s5"},"text":"Pub. L. 102–90, title I, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/450"},"text":"105 Stat. 450","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd23565a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd23565b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd23565c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s61–1c"},"text":"section 61–1c of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Congressional Operations Appropriations Act, 1992, which is title I of the Legislative Branch Appropriations Act, 1992.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
