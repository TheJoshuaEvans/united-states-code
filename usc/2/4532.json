{"tag":"section","attrib":{"id":"iddd14fe27-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4532"},"text":null,"children":[{"tag":"num","attrib":{"value":"4532"},"text":"§ 4532.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rates of compensation disbursed by Chief Administrative Officer of House; adjustments by Speaker; “Member of the House of Representatives” defined","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd14fe28-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4532/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any other provision of this Act, or any other provision of law, rule, or regulation, on and after ","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":", each time the President pro tempore of the Senate exercises any authority pursuant to any of the amendments made by this section with respect to rates of pay or any other matter relating to personnel whose pay is disbursed by the Secretary of the Senate, or whenever any of the events described in paragraph (2) occurs, the Speaker of the House of Representatives may adjust the rates of pay (and any minimum or maximum rate, limitation, or allowance) applicable to personnel whose pay is disbursed by the Chief Administrative Officer of the House of Representatives to the extent necessary to ensure—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd14fe29-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4532/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate pay levels and relationships between and among positions held by personnel of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd14fe2a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4532/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" appropriate pay relationships between—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd14fe2b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4532/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" positions referred to in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd14fe2c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4532/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddd14fe2d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4532/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" positions under subparagraphs (A) through (D) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s356"},"text":"section 356 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd14fe2e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4532/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" positions held by personnel whose pay is disbursed by the Secretary of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd14fe2f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4532/1/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" positions to which the General Schedule applies; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd14fe30-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4532/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maintenance of the pay relationship described in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd14fe31-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4532/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The other events permitting an exercise of authority under this section are either—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd14fe32-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4532/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an adjustment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5303"},"text":"section 5303 of title 5","children":[],"tail":" in rates of pay under the General Schedule; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd14fe33-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4532/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an adjustment in rates of pay for Members of the House of Representatives (other than an adjustment which occurs by virtue of an adjustment described in subparagraph (A)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd14fe34-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4532/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The pay relationship described in this paragraph is the relationship in existence as of the effective date of the amendments made by section 212 of the Legislative Branch Appropriations Act, 2020 between—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd14fe35-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4532/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an annual rate of pay of $173,900; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd14fe36-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4532/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the annual rate of pay of a Member of the House of Representatives who is not the Speaker, Majority Leader, or Minority Leader of the House.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd14fe37-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4532/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of this section, the term “Member of the House of Representatives” means a Member of the House of Representatives, a Delegate to the House of Representatives, and the Resident Commissioner from Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd14fe38-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/i/tIII/s311/d"},"text":"Pub. L. 100–202, § 101(i) [title III, § 311(d)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-290"},"text":"101 Stat. 1329–290","children":[],"tail":", 1329–310; "},{"tag":"ref","attrib":{"href":"/us/pl/101/520/tIII/s308"},"text":"Pub. L. 101–520, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2277"},"text":"104 Stat. 2277","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/90/tIII/s308"},"text":"Pub. L. 102–90, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/466"},"text":"105 Stat. 466","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s204/2"},"text":"Pub. L. 104–186, title II, § 204(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1729"},"text":"110 Stat. 1729","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dE/tII/s212/b/1"},"text":"Pub. L. 116–94, div. E, title II, § 212(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2776"},"text":"133 Stat. 2776","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd14fe39-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd14fe3a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd14fe3b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in par. (1), probably means the Legislative Branch Appropriations Act, 1988, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/i"},"text":"Pub. L. 100–202, § 101(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-290"},"text":"101 Stat. 1329–290","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The amendments made by this section, referred to in par. (1), means the amendments made by section 101(i) [title III, § 311] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-290"},"text":"101 Stat. 1329–290","children":[],"tail":", 1329–310, which enacted this section, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4571"},"text":"section 4571 of this title","children":[],"tail":", and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4571"},"text":"section 4571 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The General Schedule, referred to in pars. (1)(B)(i)(III) and (2)(A), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The effective date of the amendments made by section 212 of the Legislative Branch Appropriations Act, 2020, referred to in par. (3), is the effective date of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dE/s212"},"text":"section 212 of div. E of Pub. L. 116–94","children":[],"tail":", which is set out in a note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd14fe3c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s60a–2a"},"text":"section 60a–2a of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Congressional Operations Appropriations Act, 1988, which is title I of the Legislative Branch Appropriations Act, 1988.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd14fe3d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Par. (1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s212/b/1/A"},"text":"Pub. L. 116–94, § 212(b)(1)(A)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s212/b/1/B"},"text":"Pub. L. 116–94, § 212(b)(1)(B)","children":[],"tail":", (C), added par. (3) and redesignated former par. (3) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “Chief Administrative Officer of the House of Representatives” for “Clerk of the House of Representatives”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Par. (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/90"},"text":"Pub. L. 102–90","children":[],"tail":" substituted “5303” for “5305”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/520"},"text":"Pub. L. 101–520","children":[],"tail":" designated existing provisions as par. (1), inserted “or whenever any of the events described in par. (2) occurs,” after “Secretary of the Senate,”, substituted “may adjust the rates of pay (and any minimum or maximum rate, limitation, or allowance) applicable to personnel whose pay is disbursed by the Clerk of the House of Representatives to the extent necessary to ensure—” and subpars. (A) and (B) for “may, with respect to personnel whose pay is disbursed by the Clerk of the House of Representatives, exercise the same authority to the extent necessary to ensure parity of treatment between personnel of the respective Houses of Congress having comparable duties and responsibilities.”, and added pars. (2) and (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd14fe3e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd14fe3f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" effective on the later of the first day of the first applicable pay period beginning on or after "},{"tag":"date","attrib":{"date":"2020-01-01"},"text":"Jan. 1, 2020","children":[],"tail":", or the first day of the first applicable pay period beginning on or after "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/s212/c"},"text":"section 212(c) of Pub. L. 116–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s282b"},"text":"section 282b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd14fe40-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Order of the Speaker of the House of Representatives","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd14fe41-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Speaker Johnson, ","children":[{"tag":"date","attrib":{"date":"2025-01-17"},"text":"January 17, 2025","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"Pursuant to the authority vested in the Speaker by section 311(d) of the Legislative Branch Appropriations Act, 1988, as amended by section 212(b) of the Legislative Branch Appropriations Act, 2020 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s4532"},"text":"2 U.S.C. 4532","children":[],"tail":"), in order to ensure parity of treatment and preserve an appropriate pay relationship between employees of the House of Representatives and certain other employees of the Government, it is hereby–"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"Ordered,","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd14fe42-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"pay for specified positions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"SEC. 1. (a) The annual rate of pay for the Clerk, the Sergeant-at-Arms, the Chief Administrative Officer, the Chaplain, the General Counsel to the House, the Inspector General, the Director of Interparliamentary Affairs, the Attending Physician, and one additional position in the Office of the Sergeant at Arms with duties related to emergency preparedness, planning and operations shall be equal to the annual rate of basic pay for level II of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of title 5","children":[],"tail":", United States Code, including any adjustment to such rate after the date of this Order ["},{"tag":"date","attrib":{"date":"2025-01-17"},"text":"Jan. 17, 2025","children":[],"tail":"]."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) Subject to the maximum established under subsection (a), the annual rate of pay for the following positions is subject to the approval of the Speaker:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(1) The Parliamentarian.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(2) The Legislative Counsel.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(3) The Law Revision Counsel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd14fe43-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"maximum and minimum rates of pay","children":[],"tail":null},{"tag":"p","attrib":{},"text":"SEC. 2. (a) The maximum annual rate of pay for any employee whose pay is disbursed by the Chief Administrative Officer and is not otherwise provided for in this Order or otherwise limited by law, rule, or regulation, shall be equal to the annual rate of basic pay for level II of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of title 5","children":[],"tail":", United States Code, including any adjustment to such rate after the date of this Order."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) The minimum annual rate of pay for any full-time employee whose pay is disbursed by the Chief Administrative Officer, subject to the rules and regulations promulgated by the Committee on House Administration, shall be $45,000.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(c) The Chief Administrative Officer shall promptly notify the Speaker whenever the annual rate of basic pay for level II of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of title 5","children":[],"tail":", United States Code is adjusted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd14fe44-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"pay for shared employees","children":[],"tail":null},{"tag":"p","attrib":{},"text":"SEC. 3. An employee who, under applicable rules and regulations, is paid from two (2) or more House sources may receive pay totaling the highest limitation applicable to any of the positions the employee occupies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd14fe45-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"effective date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"SEC. 4. This Order shall be effective ","children":[{"tag":"date","attrib":{"date":"2025-01-01"},"text":"January 1, 2025","children":[],"tail":", and each provision herein shall continue in place until such time as it is superseded by the issuance of a future Order."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior Orders of the Speaker of the House of Representatives were issued on the following dates:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"2022-12-30"},"text":"December 30, 2022","children":[],"tail":", eff. "},{"tag":"date","attrib":{"date":"2023-01-01"},"text":"Jan. 1, 2023","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"2022-05-06"},"text":"May 6, 2022","children":[],"tail":", eff. for pay periods on or after "},{"tag":"date","attrib":{"date":"2022-05-06"},"text":"May 6, 2022","children":[],"tail":"; section 2(b) eff. "},{"tag":"date","