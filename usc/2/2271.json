{"tag":"section","attrib":{"id":"iddd0b887b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2271"},"text":null,"children":[{"tag":"num","attrib":{"value":"2271"},"text":"§ 2271.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdictions unaffected","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd0b887c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2271/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security jurisdiction unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter granting any authority to the Architect of the Capitol or Chief Executive Officer shall be construed to affect the exclusive jurisdiction of the Capitol Police, the Capitol Police Board, the Sergeant at Arms and Doorkeeper of the Senate, and the Sergeant at Arms of the House of Representatives to provide security for the Capitol, including the Capitol Visitor Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0b887d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2271/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Architect of the Capitol jurisdiction unaffected","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd0b887e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2271/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter granting any authority to the Chief Executive Officer shall be construed to affect the exclusive jurisdiction of the Architect of the Capitol for the care and superintendence of the Capitol Visitor Center. All maintenance services, groundskeeping services, improvements, alterations, additions, and repairs for the Capitol Visitor Center shall be made under the direction and supervision of the Architect, subject to the approval of the Committee on Rules and Administration of the Senate and the House Office Building Commission as to matters of general policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0b887f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s2271/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd0b8880-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/437/tV/s501"},"text":"Pub. L. 110–437, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-20"},"text":"Oct. 20, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4997"},"text":"122 Stat. 4997","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd0b8881-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd0b8882-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd0b8883-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/437"},"text":"Pub. L. 110–437","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-20"},"text":"Oct. 20, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4983"},"text":"122 Stat. 4983","children":[],"tail":", known as the Capitol Visitor Center Act of 2008, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s2201"},"text":"section 2201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd0b8884-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/437/s501"},"text":"section 501 of Pub. L. 110–437","children":[],"tail":". Subsec. (b)(2) of "},{"tag":"ref","attrib":{"href":"/us/pl/110/437/s501"},"text":"section 501 of Pub. L. 110–437","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1825"},"text":"section 1825 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
