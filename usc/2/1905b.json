{"tag":"section","attrib":{"id":"iddceed8af-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1905b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1905b"},"text":"§ 1905b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of obligation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddceed8b0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1905b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Beginning on ","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"March 15, 2022","children":[],"tail":", the Chief of the United States Capitol Police shall provide written notice to the Committee on Appropriations of the Senate and the Committee on Appropriations of the House of Representatives before any obligation of funds under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1905/a/2"},"text":"section 1905(a)(2) of this title","children":[],"tail":" that equals or exceeds $100,000."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddceed8b1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1905b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall apply with respect to fiscal year 2022 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddceed8b2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dI/tI/s120"},"text":"Pub. L. 117–103, div. I, title I, § 120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/513"},"text":"136 Stat. 513","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
