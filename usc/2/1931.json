{"tag":"section","attrib":{"id":"iddcf393c8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1931"},"text":null,"children":[{"tag":"num","attrib":{"value":"1931"},"text":"§ 1931.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional compensation for employees with specialty assignments and proficiencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcf393c9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1931/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of positions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief of the Capitol Police may establish and determine, from time to time, positions in salary classes of employees of the Capitol Police to be designated as employees with specialty assignments or proficiencies, based on the experience, education, training, or other appropriate factors required to carry out the duties of such employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf393ca-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1931/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional compensation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the regularly scheduled rate of basic pay, each employee holding a position designated under this section shall receive an amount determined by the Chief, except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf393cb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1931/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such amount may not exceed 25 percent of the employee’s annual rate of basic pay; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf393cc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1931/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such amount may not be paid in a calendar year to the extent that, when added to the total basic pay paid or payable to such employee for service performed in the year, such amount would cause the total to exceed the annual rate of basic pay payable for level II of the Executive Schedule, as of the end of such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf393cd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1931/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner of payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The additional compensation authorized by this subsection shall be paid to an employee in a manner determined by the Chief or his designee except when the employee ceases to be assigned to the specialty assignment or ceases to maintain the required proficiency. The loss of such additional compensation shall not constitute an adverse action for any purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf393ce-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1931/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination not appealable or reviewable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any determination under section ","children":[{"tag":"ref","attrib":{"idref":"fn002072"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002072"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection”."}],"tail":" (a) shall not be appealable or reviewable in any manner."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcf393cf-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dH/tI/s1011"},"text":"Pub. L. 108–7, div. H, title I, § 1011","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/360"},"text":"117 Stat. 360","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf393d0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf393d1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcf393d2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Level II of the Executive Schedule, referred to in subsec. (b)(2), is set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddcf393d3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2003, which is div. H of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
