{"tag":"section","attrib":{"id":"iddc9dd2a9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s357"},"text":null,"children":[{"tag":"num","attrib":{"value":"357"},"text":"§ 357.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report by Commission to President with respect to pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commission shall submit to the President a report of the results of each review conducted by the Commission with respect to rates of pay for the offices and positions within the purview of subparagraphs (A), (B), (C), and (D) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s356"},"text":"section 356 of this title","children":[],"tail":", together with its recommendations. Each such report shall be submitted on such date as the President may designate but not later than December 15 next following the close of the fiscal year in which the review is conducted by the Commission."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc9dd2aa-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/206/tII/s225/g"},"text":"Pub. L. 90–206, title II, § 225(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-16"},"text":"Dec. 16, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/644"},"text":"81 Stat. 644","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/190/s135/c"},"text":"Pub. L. 99–190, § 135(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-19"},"text":"Dec. 19, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1322"},"text":"99 Stat. 1322","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/194/tVII/s701/e"},"text":"Pub. L. 101–194, title VII, § 701(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-30"},"text":"Nov. 30, 1989","children":[],"tail":", 