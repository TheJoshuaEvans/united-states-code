{"tag":"section","attrib":{"id":"iddd31ae69-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6138"},"text":null,"children":[{"tag":"num","attrib":{"value":"6138"},"text":"§ 6138.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of funds from appropriations account of Majority and Minority Whips of Senate to appropriations account, Miscellaneous Items, within Senate contingent fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd31ae6a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6138/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests for transfers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the written request of the Majority or Minority Whip of the Senate, the Secretary of the Senate shall transfer during any fiscal year, from the appropriations account appropriated under the headings “","children":[{"tag":"inline","attrib":{},"text":"Salaries, Officers and Employees","children":[],"tail":"” and “"},{"tag":"inline","attrib":{},"text":"offices of the majority and minority whips","children":[],"tail":"”, such amount as either whip shall specify to the appropriations account, within the contingent fund of the Senate, “"},{"tag":"inline","attrib":{},"text":"miscellaneous items","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd31ae6b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6138/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to incur expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Majority and Minority Whips of the Senate are each authorized to incur such expenses as may be necessary or appropriate. Expenses incurred by either such whip shall be paid from the amount transferred pursuant to subsection (a) by such whip and upon vouchers approved by such whip.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd33f85c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6138/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to advance sums","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Senate is authorized to advance such sums as may be necessary to defray expenses incurred in carrying out subsections (a) and (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd33f85d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/55/tI/s2"},"text":"Pub. L. 105–55, title I, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-10-07"},"text":"Oct. 7, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1180"},"text":"111 Stat. 1180","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd33f85e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd33f85f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd33f860-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s31a–2c"},"text":"section 31a–2c of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Congressional Operations Appropriations Act, 1998, which is title I of the Legislative Branch Appropriations Act, 1998.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
