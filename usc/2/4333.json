{"tag":"section","attrib":{"id":"iddd104400-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4333"},"text":null,"children":[{"tag":"num","attrib":{"value":"4333"},"text":"§ 4333.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses of committees payable from Senate contingent fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When any duty is imposed upon a committee involving expenses that are ordered to be paid out of the contingent fund of the Senate, upon vouchers to be approved by the chairman of the committee charged with such duty, the receipt of such chairman for any sum advanced to him or his order out of said contingent fund by the Secretary of the Senate for committee expenses not involving personal services shall be taken and passed by the accounting officers of the Government as a full and sufficient voucher; but it shall be the duty of such chairman, as soon as practicable, to furnish to the Secretary of the Senate vouchers in detail for the expenses so incurred.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd104401-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1879-03-03/ch183"},"text":"Mar. 3, 1879, ch. 183","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/20/419"},"text":"20 Stat. 419","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1921-06-10/ch18"},"text":"June 10, 1921, ch. 18","children":[],"tail":", title III, § 304, "},{"tag":"ref","attrib":{"href":"/us/stat/42/24"},"text":"42 Stat. 24","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-06-22/ch235/s101"},"text":"June 22, 1949, ch. 235, § 101","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/218"},"text":"63 Stat. 218","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd104402-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd104403-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd104404-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s69"},"text":"section 69 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd104405-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1949—Act ","children":[{"tag":"date","attrib":{"date":"1949-06-22"},"text":"June 22, 1949","children":[],"tail":", inserted “for committee expenses not involving personal services” after “Secretary of the Senate”, and omitted the requirement that the Secretary of the Senate file the vouchers with the General Accounting Office."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd104406-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"iddd104407-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1921-06-10"},"text":"June 10, 1921","children":[],"tail":", transferred powers and duties of Comptroller, six auditors, and certain other officers of the Treasury to General Accounting Office."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
