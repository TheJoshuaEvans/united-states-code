{"tag":"section","attrib":{"id":"iddce0819a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602"},"text":null,"children":[{"tag":"num","attrib":{"value":"1602"},"text":"§ 1602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce0819b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “agency” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s551/1"},"text":"section 551(1) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce0819c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Client","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “client” means any person or entity that employs or retains another person for financial or other compensation to conduct lobbying activities on behalf of that person or entity. A person or entity whose employees act as lobbyists on its own behalf is both a client and an employer of such employees. In the case of a coalition or association that employs or retains other persons to conduct lobbying activities, the client is the coalition or association and not its individual members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce0819d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered executive branch official","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered executive branch official” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce0819e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce0819f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Vice President;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce081a0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any officer or employee, or any other individual functioning in the capacity of such an officer or employee, in the Executive Office of the President;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce081a1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any officer or employee serving in a position in level I, II, III, IV, or V of the Executive Schedule, as designated by statute or Executive order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce081a2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any member of the uniformed services whose pay grade is at or above O–7 under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s201"},"text":"section 201 of title 37","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce081a3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any officer or employee serving in a position of a confidential, policy-determining, policy-making, or policy-advocating character described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7511/b/2/B"},"text":"section 7511(b)(2)(B) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce081a4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered legislative branch official","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered legislative branch official” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce081a5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Member of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce081a6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an elected officer of either House of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce081a7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any employee of, or any other individual functioning in the capacity of an employee of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddce081a8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Member of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081a9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a committee of either House of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081aa-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the leadership staff of the House of Representatives or the leadership staff of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081ab-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/4/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a joint committee of Congress; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081ac-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/4/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a working group or caucus organized to provide legislative services or other assistance to Members of Congress; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce081ad-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other legislative branch employee serving in a position described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s13101/13"},"text":"section 13101(13) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce081ae-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “employee” means any individual who is an officer, employee, partner, director, or proprietor of a person or entity, but does not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce081af-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" independent contractors; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce081b0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" volunteers who receive no financial or other compensation from the person or entity for their services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce081b1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “foreign entity” means a foreign principal (as defined in section 1(b) of the Foreign Agents Registration Act of 1938 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s611/b"},"text":"22 U.S.C. 611(b)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce081b2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lobbying activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “lobbying activities” means lobbying contacts and efforts in support of such contacts, including preparation and planning activities, research and other background work that is intended, at the time it is performed, for use in contacts, and coordination with the lobbying activities of others.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce081b3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lobbying contact","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce081b4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “lobbying contact” means any oral or written communication (including an electronic communication) to a covered executive branch official or a covered legislative branch official that is made on behalf of a client with regard to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddce081b5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the formulation, modification, or adoption of Federal legislation (including legislative proposals);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081b6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the formulation, modification, or adoption of a Federal rule, regulation, Executive order, or any other program, policy, or position of the United States Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081b7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the administration or execution of a Federal program or policy (including the negotiation, award, or administration of a Federal contract, grant, loan, permit, or license); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081b8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nomination or confirmation of a person for a position subject to confirmation by the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce081b9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “lobbying contact” does not include a communication that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddce081ba-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made by a public official acting in the public official’s official capacity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081bb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made by a representative of a media organization if the purpose of the communication is gathering and disseminating news and information to the public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081bc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made in a speech, article, publication or other material that is distributed and made available to the public, or through radio, television, cable television, or other medium of mass communication;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081bd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made on behalf of a government of a foreign country or a foreign political party and disclosed under the Foreign Agents Registration Act of 1938 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s611"},"text":"22 U.S.C. 611","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081be-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a request for a meeting, a request for the status of an action, or any other similar administrative request, if the request does not include an attempt to influence a covered executive branch official or a covered legislative branch official;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081bf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made in the course of participation in an advisory committee subject to chapter 10 of title 5;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081c0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" testimony given before a committee, subcommittee, or task force of the Congress, or submitted for inclusion in the public record of a hearing conducted by such committee, subcommittee, or task force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081c1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information provided in writing in response to an oral or written request by a covered executive branch official or a covered legislative branch official for specific information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081c2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" required by subpoena, civil investigative demand, or otherwise compelled by statute, regulation, or other action of the Congress or an agency, including any communication compelled by a Federal contract, grant, loan, permit, or license;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081c3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/B/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made in response to a notice in the Federal Register, Commerce Business Daily, or other similar publication soliciting communications from the public and directed to the agency official specifically designated in the notice to receive such communications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081c4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/B/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not possible to report without disclosing information, the unauthorized disclosure of which is prohibited by law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081c5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/B/xii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xii"},"text":"(xii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" made to an official in an agency with regard to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddce081c6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/B/xii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a judicial proceeding or a criminal or civil law enforcement inquiry, investigation, or proceeding; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddce081c7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/B/xii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a filing or proceeding that the Government is specifically required by statute or regulation to maintain or conduct on a confidential basis,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":" if that agency is charged with responsibility for such proceeding, inquiry, investigation, or filing;","children":[],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081c8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/B/xiii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xiii"},"text":"(xiii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made in compliance with written agency procedures regarding an adjudication conducted by the agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s554"},"text":"section 554 of title 5","children":[],"tail":" or substantially similar provisions;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081c9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/B/xiv"},"text":null,"children":[{"tag":"num","attrib":{"value":"xiv"},"text":"(xiv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a written comment filed in the course of a public proceeding or any other communication that is made on the record in a public proceeding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081ca-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/B/xv"},"text":null,"children":[{"tag":"num","attrib":{"value":"xv"},"text":"(xv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a petition for agency action made in writing and required to be a matter of public record pursuant to established agency procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081cb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/B/xvi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xvi"},"text":"(xvi)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" made on behalf of an individual with regard to that individual’s benefits, employment, or other personal matters involving only that individual, except that this clause does not apply to any communication with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddce081cc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/B/xvi/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a covered executive branch official, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddce081cd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/B/xvi/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a covered legislative branch official (other than the individual’s elected Members of Congress or employees who work under such Members’ direct supervision),","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":" with respect to the formulation, modification, or adoption of private legislation for the relief of that individual;","children":[],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081ce-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/B/xvii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xvii"},"text":"(xvii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a disclosure by an individual that is protected under the amendments made by the Whistleblower Protection Act of 1989, under chapter 4 of title 5, or under another provision of law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081cf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/B/xviii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xviii"},"text":"(xviii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" made by—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddce081d0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/B/xviii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a church, its integrated auxiliary, or a convention or association of churches that is exempt from filing a Federal income tax return under paragraph 2(A)(i) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6033/a"},"text":"section 6033(a) of title 26","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddce081d1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/B/xviii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a religious order that is exempt from filing a Federal income tax return under paragraph (2)(A)(iii) of such section 6033(a); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081d2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/B/xix"},"text":null,"children":[{"tag":"num","attrib":{"value":"xix"},"text":"(xix)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" between—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddce081d3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/B/xix/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" officials of a self-regulatory organization (as defined in section 3(a)(26) of the Securities Exchange Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a/26"},"text":"15 U.S.C. 78c(a)(26)","children":[],"tail":"]) that is registered with or established by the Securities and Exchange Commission as required by that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"15 U.S.C. 78a","children":[],"tail":" et seq.] or a similar organization that is designated by or registered with the Commodities Future Trading Commission as provided under the Commodity Exchange Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1"},"text":"7 U.S.C. 1","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddce081d4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/8/B/xix/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Securities and Exchange Commission or the Commodities Future Trading Commission, respectively;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":" relating to the regulatory responsibilities of such organization under that Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce081d5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lobbying firm","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “lobbying firm” means a person or entity that has 1 or more employees who are lobbyists on behalf of a client other than that person or entity. The term also includes a self-employed individual who is a lobbyist.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce081d6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lobbyist","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “lobbyist” means any individual who is employed or retained by a client for financial or other compensation for services that include more than one lobbying contact, other than an individual whose lobbying activities constitute less than 20 percent of the time engaged in the services provided by such individual to that client over a 3-month period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce081d7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Media organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “media organization” means a person or entity engaged in disseminating information to the general public through a newspaper, magazine, other publication, radio, television, cable television, or other medium of mass communication.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce081d8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Member of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Member of Congress” means a Senator or a Representative in, or Delegate or Resident Commissioner to, the Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce081d9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “organization” means a person or entity other than an individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce081da-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person or entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person or entity” means any individual, corporation, company, foundation, association, labor organization, firm, partnership, society, joint stock company, group of organizations, or State or local government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce081db-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public official","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “public official” means any elected official, appointed official, or employee of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce081dc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a Federal, State, or local unit of government in the United States other than—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddce081dd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/15/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a college or university;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081de-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/15/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a government-sponsored enterprise (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s622/8"},"text":"section 622(8) of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081df-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/15/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public utility that provides gas, electricity, water, or communications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081e0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/15/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a guaranty agency (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1085/j"},"text":"section 1085(j) of title 20","children":[],"tail":"), including any affiliate of such an agency; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddce081e1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/15/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agency of any State functioning as a student loan secondary market pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1085/d/1/F"},"text":"section 1085(d)(1)(F) of title 20","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce081e2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Government corporation (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s9101"},"text":"section 9101 of title 31","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce081e3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/15/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization of State or local elected or appointed officials other than officials of an entity described in clause (i), (ii), (iii), (iv), or (v) of subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce081e4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/15/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304/e"},"text":"section 5304(e) of title 25","children":[],"tail":"; "},{"tag":"ref","attrib":{"idref":"fn002066"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002066"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. A closing parenthesis probably should precede the semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce081e5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/15/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national or State political party or any organizational unit thereof; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce081e6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/15/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national, regional, or local unit of any foreign government, or a group of governments acting together as an international organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce081e7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1602/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States, the District of Columbia, and any commonwealth, territory, or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce081e8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/65/s3"},"text":"Pub. L. 104–65, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-19"},"text":"Dec. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/691"},"text":"109 Stat. 691","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/166"},"text":"Pub. L. 105–166","children":[],"tail":", §§ 2, 3, "},{"tag":"date","attrib":{"date":"1998-04-06"},"text":"Apr. 6, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/38"},"text":"112 Stat. 38","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/81/tII/s201/b/1"},"text":"Pub. L. 110–81, title II, § 201(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/742"},"text":"121 Stat. 742","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/2"},"text":"Pub. L. 117–286, § 4(a)(2)","children":[],"tail":", (b)(2), (c)(3), "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4305"},"text":"136 Stat. 4305","children":[],"tail":", 4342, 4353.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce081e9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddce081ea-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddce081eb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act” meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/65"},"text":"Pub. L. 104–65","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-19"},"text":"Dec. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/691"},"text":"109 Stat. 691","children":[],"tail":", known as the Lobbying Disclosure Act of 1995. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1601"},"text":"section 1601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Levels I, II, III, IV, and V of the Executive Schedule, referred to in par. (3)(D), are set out in sections 5312, 5313, 5314, 5315, and 5316, respectively, of Title 5, Government Organization and Employees.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Foreign Agents Registration Act of 1938, referred to in par. (8)(B)(iv), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-08/ch327"},"text":"act June 8, 1938, ch. 327","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/631"},"text":"52 Stat. 631","children":[],"tail":", which is classified generally to subchapter II (§ 611 et seq.) of chapter 11 of Title 22, Foreign Relations and Intercourse. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s611"},"text":"section 611 of Title 22","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Whistleblower Protection Act of 1989, referred to in par. (8)(B)(xvii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/12"},"text":"Pub. L. 101–12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-04-10"},"text":"Apr. 10, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/16"},"text":"103 Stat. 16","children":[],"tail":", which enacted subchapters II ["},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1211"},"text":"5 U.S.C. 1211","children":[],"tail":" et seq.] and III ["},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1221"},"text":"5 U.S.C. 1221","children":[],"tail":" et seq.] of chapter 12 and "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3352"},"text":"section 3352 of Title 5","children":[],"tail":", Government Organization and Employees, amended sections 1201 to 1206, 1209, 1211, 2302, 2303, 3393, 7502, 7512, 7521, 7542, 7701, and 7703 of Title 5 and "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4139"},"text":"section 4139 of Title 22","children":[],"tail":", Foreign Relations and Intercourse, repealed sections 1207 and 1208 of Title 5, and enacted provisions set out as notes under sections 1201, 1211, and 5509 of Title 5. For complete classification of this Act to the Code, see Short Title of 1989 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1201"},"text":"section 1201 of Title 5","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Securities Exchange Act, referred to in par. (8)(B)(xix), probably means the Securities Exchange Act of 1934, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-06/ch404"},"text":"act June 6, 1934, ch. 404","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/881"},"text":"48 Stat. 881","children":[],"tail":", which is classified principally to chapter 2B (§ 78a et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"section 78a of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Commodity Exchange Act, referred to in par. (8)(B)(xix), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch369"},"text":"act Sept. 21, 1922, ch. 369","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/998"},"text":"42 Stat. 998","children":[],"tail":", which is classified generally to chapter 1 (§ 1 et seq.) of Title 7, Agriculture. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1"},"text":"section 1 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddce081ec-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Par. (4)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/c/3"},"text":"Pub. L. 117–286, § 4(c)(3)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s13101/13"},"text":"section 13101(13) of title 5","children":[],"tail":".” for “section 109(13) of the Ethics in Government Act of 1978 (5 U.S.C. App.).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8)(B)(vi). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/2"},"text":"Pub. L. 117–286, § 4(a)(2)","children":[],"tail":", substituted “chapter 10 of title 5;” for “the Federal Advisory Committee Act;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8)(B)(xvii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/2"},"text":"Pub. L. 117–286, § 4(b)(2)","children":[],"tail":", substituted “chapter 4 of title 5,” for “the Inspector General Act of 1978,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Par. (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81"},"text":"Pub. L. 110–81","children":[],"tail":" substituted “3-month period” for “six month period”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Par. (3)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/166/s2"},"text":"Pub. L. 105–166, § 2","children":[],"tail":", substituted “7511(b)(2)(B)” for “7511(b)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8)(B)(ix). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/166/s3/a"},"text":"Pub. L. 105–166, § 3(a)","children":[],"tail":", inserted before semicolon at end “, including any communication compelled by a Federal contract, grant, loan, permit, or license”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (15)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/166/s3/b"},"text":"Pub. L. 105–166, § 3(b)","children":[],"tail":", inserted before period at end “, or a group of governments acting together as an international organization”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddce081ed-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddce081ee-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Except as otherwise provided, amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81"},"text":"Pub. L. 110–81","children":[],"tail":" applicable with respect to registrations under the Lobbying Disclosure Act of 1995 (this chapter) having an effective date of "},{"tag":"date","attrib":{"date":"2008-01-01"},"text":"Jan. 1, 2008","children":[],"tail":", or later and with respect to quarterly reports under that Act covering calendar quarters beginning on or after "},{"tag":"date","attrib":{"date":"2008-01-01"},"text":"Jan. 1, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/81/s215"},"text":"section 215 of Pub. L. 110–81","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30104"},"text":"section 30104 of Title 52","children":[],"tail":", Voting and Elections."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddce081ef-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/65/s24"},"text":"section 24 of Pub. L. 104–65","children":[],"tail":", set out as a note under "},{"tag":"