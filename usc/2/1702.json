{"tag":"section","attrib":{"id":"iddce2f2d3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1702"},"text":null,"children":[{"tag":"num","attrib":{"value":"1702"},"text":"§ 1702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Librarian of Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce2f2d4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of criteria and procedures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of carrying out this subchapter, the Librarian shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce2f2d5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1702/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish criteria and procedures under which sound recordings may be included in the National Recording Registry, except that no sound recording shall be eligible for inclusion in the National Recording Registry until 10 years after the recording’s creation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f2d6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1702/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish procedures under which the general public may make recommendations to the National Recording Preservation Board established under subchapter III regarding the inclusion of sound recordings in the National Recording Registry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce2f2d7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1702/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine which sound recordings satisfy the criteria established under paragraph (1) and select such recordings for inclusion in the National Recording Registry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce2f2d8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of sound recordings in the Registry","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Librarian shall publish in the Federal Register the name of each sound recording that is selected for inclusion in the National Recording Registry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce2f2d9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/474/tI/s102"},"text":"Pub. L. 106–474, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2085"},"text":"114 Stat. 2085","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
