{"tag":"section","attrib":{"id":"iddc91ebcc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185"},"text":null,"children":[{"tag":"num","attrib":{"value":"185"},"text":"§ 185.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspector General of the Library of Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc91ebcd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may be cited as the “Library of Congress Inspector General Act of 2005”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc91ebce-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Inspector General","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is an Office of Inspector General within the Library of Congress which is an independent objective office to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc91ebcf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct and supervise audits and investigations (excluding incidents involving violence and personal property) relating to the Library of Congress, except that nothing in this paragraph may be construed to authorize the Inspector General to audit or investigate any operations or activities of the United States Capitol Police;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91ebd0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide leadership and coordination and recommend policies to promote economy, efficiency, and effectiveness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91ebd1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a means of keeping the Librarian of Congress and the Congress fully and currently informed about problems and deficiencies relating to the administration and operations of the Library of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc91ebd2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of Inspector General; supervision; removal; pay; limits on bonuses; counsel","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc91ebd3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment and supervision","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc91ebd4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be at the head of the Office of Inspector General, an Inspector General who shall be appointed by the Librarian of Congress without regard to political affiliation and solely on the basis of integrity and demonstrated ability in accounting, auditing, financial analysis, law, management analysis, public administration, or investigations. The Inspector General shall report to, and be under the general supervision of, the Librarian of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc91ebd5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits, investigations, and reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Librarian of Congress shall have no authority to prevent or prohibit the Inspector General from—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc91ebd6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initiating, carrying out, or completing any audit or investigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc91ebd7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issuing any subpoena during the course of any audit or investigation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc91ebd8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issuing any report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91ebd9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal or transfer","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc91ebda-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Inspector General may be removed from office, or transferred to another position within, or another location of, the Library of Congress, by the Librarian of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc91ebdb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days before the Librarian of Congress removes or transfers the Inspector General under subparagraph (A), the Librarian of Congress shall communicate in writing the reason for the removal or transfer to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc91ebdc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on House Administration and the Committee on Appropriations of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc91ebdd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Rules and Administration and the Committee on Appropriations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc91ebde-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this paragraph shall prohibit a personnel action (except for removal or transfer) that is otherwise authorized by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91ebdf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc91ebe0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The position of Inspector General shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc91ebe1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be classified as a position above GS–15 in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5108"},"text":"section 5108 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc91ebe2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a rate of basic pay that is not less than the average rate of basic pay of all other employees in positions classified as above GS–15 of the Library of Congress calculated on an annual basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc91ebe3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Librarian of Congress shall establish the amount of the annual adjustment in the rate of basic pay for the Inspector General in an amount equal to the average of the annual adjustments in the rate of basic pay provided to all other employees in positions classified as above GS–15 of the Library of Congress, in a manner consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91ebe4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No bonuses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Inspector General may not receive any cash award or cash bonus, including a cash award under chapter 45 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91ebe5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counsel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Inspector General shall, in accordance with applicable laws and regulations governing selections, appointments, and employment at the Library of Congress, obtain legal advice from a counsel reporting directly to the Inspector General or another Inspector General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc91ebe6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties, responsibilities, authority, and reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc91ebe7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Sections 404, 405 (other than subsection (b)(13)), 406(a) (other than paragraphs (7) and (8) thereof),","children":[{"tag":"ref","attrib":{"idref":"fn002015"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002015"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and 407 of title 5 shall apply to the Inspector General of the Library of Congress and the Office of such Inspector General and such sections shall be applied to the Library of Congress and the Librarian of Congress by substituting—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc91ebe8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Library of Congress” for “establishment”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc91ebe9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Librarian of Congress” for “head of the establishment”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91ebea-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc91ebeb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Inspector General, in carrying out the provisions of this section, is authorized, without the supervision or approval of any other employee, office, or other entity within the Library of Congress, to select, appoint, and employ such officers and employees (including consultants) as may be necessary for carrying out the functions, powers, and duties of the Office of Inspector General subject to the provisions of law governing selections, appointments, and employment in the Library of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc91ebec-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security and suitability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Appointments under the authority under subparagraph (A) shall be made consistent with personnel security and suitability requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc91ebed-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any appointment of a consultant under the authority under subparagraph (A) shall be made consistent with section 6(a)(8) of the Inspector General Act of 1978 (5 U.S.C. App.).","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91ebee-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law enforcement authority","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc91ebef-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraph (B), any supervisory special agent under the Inspector General and any special agent supervised by such a supervisory special agent is authorized to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc91ebf0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make an arrest without a warrant while engaged in official duties as authorized under this section or any other statute for any offense against the United States committed in the presence of such supervisory special agent or special agent, or for any felony cognizable under the laws of the United States if such supervisory special agent or special agent has reasonable grounds to believe that the person to be arrested has committed or is committing such felony;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc91ebf1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek and execute warrants for arrest, search of a premises, or seizure of evidence issued under the authority of the United States upon probable cause to believe that a violation has been committed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc91ebf2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry a firearm while engaged in official duties as authorized under this section or any other statute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc91ebf3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements to exercise authority","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc91ebf4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required certification","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddc91ebf5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to exercise the authority under subparagraph (A), a supervisory special agent or a special agent supervised by such a supervisory special agent shall certify that he or she—","children":[],"tail":null},{"tag":"item","attrib":{"id":"iddc91ebf6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/3/B/i/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a citizen of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"iddc91ebf7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/3/B/i/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has successfully completed a basic law enforcement training program or military or other equivalent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"iddc91ebf8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/3/B/i/I/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not prohibited from receiving a firearm under Federal law, including under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s922/g/9"},"text":"section 922(g)(9) of title 18","children":[],"tail":", because of a conviction of a misdemeanor crime of domestic violence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddc91ebf9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After providing notice to the appropriate committees of Congress, the Inspector General may add requirements to the certification required under subclause (I), as determined appropriate by the Inspector General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc91ebfa-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Inspector General shall maintain firearms-related requirements (including quarterly firearms qualifications) and use of force training requirements that, except to the extent the Inspector General determines necessary to effectively carry out the duties of the Office of the Inspector General, are in accordance with the Council of the Inspectors General on Integrity and Efficiency use of force policies, which incorporate Department of Justice guidelines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc91ebfb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility determination","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddc91ebfc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/3/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Inspector General shall—","children":[],"tail":null},{"tag":"item","attrib":{"id":"iddc91ebfd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/3/B/iii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine whether an individual meets the requirements under this paragraph; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"iddc91ebfe-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/3/B/iii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revoke any authority granted to an individual under subparagraph (A) if the individual is not in compliance with the requirements of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddc91ebff-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/3/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reauthorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Inspector General may reauthorize an individual to exercise the authority granted under subparagraph (A) if the Inspector General determines the individual has achieved compliance with the requirements under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddc91ec00-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/3/B/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on appeal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A revocation of the authority granted under subparagraph (A) shall not be subject to administrative, judicial, or other review, unless the revocation results in an adverse action. Such an adverse action may, at the election of the applicable individual, be reviewed in accordance with the otherwise applicable procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc91ec01-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Semiannual certification of program","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc91ec02-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before the first grant of authority under subparagraph (A), and semiannually thereafter as part of the report under section 5 of the Inspector General Act of 1978 (5 U.S.C. App.),","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" the Inspector General shall submit to the appropriate committees of Congress a written certification that adequate internal safeguards and management procedures exist that, except to the extent the Inspector General determines necessary to effectively carry out the duties of the Office of the Inspector General, are in compliance with standards established by the Council of the Inspectors General on Integrity and Efficiency, which incorporate Department of Justice guidelines, to ensure proper exercise of the powers authorized under this paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc91ec03-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority granted under this paragraph (including any grant of authority to an individual under subparagraph (A), without regard to whether the individual is in compliance with subparagraph (B)) may be suspended by the Inspector General if the Office of Inspector General fails to comply with the reporting and review requirements under clause (i) of this subparagraph or subparagraph (D). Any suspension of authority under this clause shall be reported to the appropriate committees of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc91ec04-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To ensure the proper exercise of the law enforcement powers authorized under this paragraph, the Office of Inspector General shall submit to and participate in the external review process established by the Council of the Inspectors General on Integrity and Efficiency for ensuring that adequate internal safeguards and management procedures continue to exist. Under the review process, the exercise of the law enforcement powers by the Office of Inspector General shall be reviewed periodically by another Office of Inspector General or by a committee of Inspectors General. The results of each review shall be communicated in writing to the Inspector General, the Council of the Inspectors General on Integrity and Efficiency, and the appropriate committees of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc91ec05-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alleged misconduct","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any allegation of misconduct by an individual granted authority under subparagraph (A) may be reviewed by the Integrity Committee of the Council of the Inspectors General on Integrity and Efficiency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc91ec06-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate committees of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this paragraph, the term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc91ec07-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/3/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Rules and Administration and the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc91ec08-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/3/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on House Administration and the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc91ec09-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget independence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Librarian of Congress shall include the annual budget request of the Inspector General in the budget of the Library of Congress without change.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc91ec0a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All functions, personnel, and budget resources of the Office of Investigations of the Library of Congress are transferred to the Office of Inspector General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc91ec0b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incumbent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The individual who serves in the position of Inspector General of the Library of Congress on ","children":[{"tag":"date","attrib":{"date":"2005-08-02"},"text":"August 2, 2005","children":[],"tail":", shall continue to serve in that position, subject to removal in accordance with this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc91ec0c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"References in any other Federal law, Executive order, rule, regulation, or delegation of authority, or any document of or relating to the Inspector General of the Library of Congress shall be deemed to refer to the Inspector General of the Library of Congress as set forth under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc91ec0d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s185/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall be effective on ","children":[{"tag":"date","attrib":{"date":"2005-08-02"},"text":"August 2, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc91ec0e-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/55/tI/s1307"},"text":"Pub. L. 109–55, title I, § 1307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-02"},"text":"Aug. 2, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/583"},"text":"119 Stat. 583","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dH/tI/s1004/d/3"},"text":"Pub. L. 110–161, div. H, title I, § 1004(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2234"},"text":"121 Stat. 2234","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/178/s4/c"},"text":"Pub. L. 110–178, § 4(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-07"},"text":"Jan. 7, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2552"},"text":"121 Stat. 2552","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/145/s6/d/1"},"text":"Pub. L. 111–145, § 6(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-04"},"text":"Mar. 4, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/54"},"text":"124 Stat. 54","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dP/tXVI"},"text":"Pub. L. 116–94, div. P, title XVI","children":[],"tail":", §§ 1602(a), 1603(a), 1604(a)(1), 1605(a), "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3209"},"text":"133 Stat. 3209","children":[],"tail":", 3212, 3218, 3219; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/1"},"text":"Pub. L. 117–286, § 4(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4342"},"text":"136 Stat. 4342","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc91ec0f-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc91ec10-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddc91ec11-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 406(a) (other than paragraphs (7) and (8) thereof) of title 5, referred to in subsec. (d)(1), probably should be a reference to section “406 (other than subsection (a)(7))” of title 5. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s1602/a/2"},"text":"Pub. L. 116–94, § 1602(a)(2)","children":[],"tail":", had amended subsec. (d)(1) by substituting a reference to section “6 (other than subsection (a)(7))” of the Inspector General Act of 1978 for a reference to section “6(a) (other than paragraphs (7) and (8) thereof)” of that Act. The reference was subsequently amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" to reflect the repeal of section 6 of the Act and its restatement as "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s406"},"text":"section 406 of title 5","children":[],"tail":", but that amendment was based on the text as it existed prior to the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":". See 2019 and 2022 Amendment notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 5 and 6(a)(8) of the Inspector General Act of 1978, referred to in subsec. (d)(2)(C), (3)(C)(i), are sections 5 and 6(a)(8) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/452"},"text":"Pub. L. 95–452","children":[],"tail":", which were set out in the Appendix to Title 5, Government Organization and Employees, and were repealed and restated as sections 405 and 406(a)(8), respectively, of Title 5 by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":", §§ 3(b), 7, "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4212"},"text":"136 Stat. 4212","children":[],"tail":", 4219, 4361."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc91ec12-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2006.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc91ec13-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":", which directed the substitution of “Sections 404, 405 (other than subsection (b)(13)), 406(a) (other than paragraphs (7) and (8) thereof), and 407 of title 5” for “Sections 4, 5 (other than subsections (a)(13)), 6(a) (other than paragraphs (7) and (8) thereof), and 7 of the Inspector General Act of 1978 (5 U.S.C. App.)”, was executed by making the substitution for “Sections 4, 5 (other than subsection (a)(13)), 6 (other than subsection (a)(7)), and 7 of the Inspector General Act of 1978 (5 U.S.C. App.)” to reflect the probable intent of Congress and the prior amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/s1602/a/2"},"text":"Pub. L. 116–94, § 1602(a)(2)","children":[],"tail":". See 2019 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s1602/a/1/A"},"text":"Pub. L. 116–94, § 1602(a)(1)(A)","children":[],"tail":", inserted “; pay; limits on bonuses; counsel” after “removal” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s1602/a/1/B"},"text":"Pub. L. 116–94, § 1602(a)(1)(B)","children":[],"tail":", added par. (2) and struck out former par. (2). Prior to amendment, text read as follows: “The Inspector General may be removed from office by the Librarian of Congress. The Librarian of Congress shall, promptly upon such removal, communicate in writing the reasons for any such removal to each House of the Congress.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s1602/a/1/C"},"text":"Pub. L. 116–94, § 1602(a)(1)(C)","children":[],"tail":", added pars. (3) to (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s1602/a/2"},"text":"Pub. L. 116–94, § 1602(a)(2)","children":[],"tail":", substituted “Sections 4, 5 (other than subsection (a)(13)), 6 (other than subsection (a)(7)), and 7” for “Sections 4, 5 (other than subsections (a)(13)), 6(a) (other than paragraphs (7) and (8) thereof), and 7”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s1605/a"},"text":"Pub. L. 116–94, § 1605(a)","children":[],"tail":", designated existing provisions as subpar. (A), inserted subpar. heading and “, without the supervision or approval of any other employee, office, or other entity within the Library of Congress,” after “is authorized”, and added subpars. (B) and (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s1603/a"},"text":"Pub. L. 116–94, § 1603(a)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s1604/a/1"},"text":"Pub. L. 116–94, § 1604(a)(1)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/145"},"text"