{"tag":"section","attrib":{"id":"iddd31ae37-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6132"},"text":null,"children":[{"tag":"num","attrib":{"value":"6132"},"text":"§ 6132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistants to Senate Majority and Minority Leaders for Floor Operations; establishment of positions; appointment; compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Effective ","children":[{"tag":"date","attrib":{"date":"1983-10-01"},"text":"October 1, 1983","children":[],"tail":", there is established within the Offices of the Majority and Minority Leaders the positions of Assistant to the Majority Leader for Floor Operations and Assistant to the Minority Leader for Floor Operations, respectively. Individuals appointed to such positions by the Majority Leader and Minority Leader, respectively, shall receive compensation at a rate fixed by the appropriate Leader not to exceed the maximum annual rate of gross compensation of the Assistant Secretary of the Senate."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd31ae38-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/51/tI/s101/a"},"text":"Pub. L. 98–51, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-07-14"},"text":"July 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/265"},"text":"97 Stat. 265","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd31ae39-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd31ae3a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd31ae3b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s61h–5"},"text":"section 61h–5 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Congressional Operations Appropriation Act, 1984, which is title I of the Legislative Branch Appropriation Act, 1984.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd31ae3c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd31ae3d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Increases in Compensation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Increases in compensation for Senate officers and employees under authority of Federal Pay Comparability Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/656"},"text":"Pub. L. 91–656","children":[],"tail":"), see Salary Directives of President pro tempore of the Senate, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4571"},"text":"section 4571 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
