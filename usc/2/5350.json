{"tag":"section","attrib":{"id":"iddd2a82a4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5350"},"text":null,"children":[{"tag":"num","attrib":{"value":"5350"},"text":"§ 5350.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delivery of reports of disbursements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2a82a5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5350/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" None of the funds made available in any fiscal year may be used to deliver a printed copy of the report of disbursements for the operations of the House of Representatives under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s5535"},"text":"section 5535 of this title","children":[],"tail":" to the office of a Member of the House of Representatives (including a Delegate or Resident Commissioner to the Congress)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2a82a6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s5350/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall apply with respect to fiscal year 2019 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2a82a7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/244/dB/tI/s115"},"text":"Pub. L. 115–244, div. B, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-21"},"text":"Sept. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2930"},"text":"132 Stat. 2930","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
