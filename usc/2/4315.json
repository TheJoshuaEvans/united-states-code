{"tag":"section","attrib":{"id":"iddd1043de-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4315"},"text":null,"children":[{"tag":"num","attrib":{"value":"4315"},"text":"§ 4315.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overtime pay for FBI employees detailed to House Committee on Appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Federal Bureau of Investigation, notwithstanding any other provision of law, may in any fiscal year pay all administrative uncontrollable overtime accrued by its employees while on detail to the Committee on Appropriations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd1043df-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/283/tI"},"text":"Pub. L. 103–283, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-22"},"text":"July 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1430"},"text":"108 Stat. 1430","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd1043e0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd1043e1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd1043e2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s72a"},"text":"section 72a of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
