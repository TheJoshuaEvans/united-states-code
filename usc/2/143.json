{"tag":"section","attrib":{"id":"iddc884e97-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s143"},"text":null,"children":[{"tag":"num","attrib":{"value":"143"},"text":"§ 143.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations for Library Building and Grounds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All appropriations made to the Architect of the Capitol on account of the Library Building and Grounds shall be disbursed for that purpose in the same manner as other appropriations under his control.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc884e98-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-06-29/ch251/s3"},"text":"June 29, 1922, ch. 251, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/715"},"text":"42 Stat. 715","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc884e99-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"iddc884e9a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"iddc884e9b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Disbursement functions of all Government agencies except Departments of the Army, Navy, and Air Force and Panama Canal transferred to Division of Disbursements, Treasury Department, by Ex. Ord. No. 6166, § 4, ","children":[{"tag":"date","attrib":{"date":"1933-06-10"},"text":"June 10, 1933","children":[],"tail":", and Ex. Ord. No. 6728, "},{"tag":"date","attrib":{"date":"1934-05-29"},"text":"May 29, 1934","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Division subsequently consolidated with other agencies into Fiscal Service in Treasury Department by Reorg. Plan No. III of 1940, § 1(a)(1), eff. ","children":[{"tag":"date","attrib":{"date":"1940-06-30"},"text":"June 30, 1940","children":[],"tail":", 5 F.R. 2107, "},{"tag":"ref","attrib":{"href":"/us/stat/54/1231"},"text":"54 Stat. 1231","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s306"},"text":"section 306 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
