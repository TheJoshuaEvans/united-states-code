[],"tail":" et seq.), and related provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s2302"},"text":"section 2302 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd70ad2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1371/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Americans with Disabilities Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"42 U.S.C. 12101","children":[],"tail":" et seq.), and related provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s2302"},"text":"section 2302 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd70ad3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1371/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Family and Medical Leave Act of 1993 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2611"},"text":"29 U.S.C. 2611","children":[],"tail":" et seq.), and related provisions of sections 6381 through 6387 of title 5."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd70ad4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1371/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Fair Labor Standards Act of 1938 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s201"},"text":"29 U.S.C. 201","children":[],"tail":" et seq.), and related provisions of sections 5541 through 5550a of title 5."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd70ad5-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1371/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Occupational Safety and Health Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s651"},"text":"29 U.S.C. 651","children":[],"tail":" et seq.), and related provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s7902"},"text":"section 7902 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd70ad6-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1371/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Rehabilitation Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s701"},"text":"29 U.S.C. 701","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd70ad7-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1371/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 71 (relating to Federal service labor-management relations) of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd70ad8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1371/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The General Accounting Office Personnel Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s731"},"text":"31 U.S.C. 731","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd70ad9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1371/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Employee Polygraph Protection Act of 1988 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2001"},"text":"29 U.S.C. 2001","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd70ada-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1371/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Worker Adjustment and Retraining Notification Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2101"},"text":"29 U.S.C. 2101","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd70adb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1371/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 43 (relating to veterans’ employment and reemployment) of title 38.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd70adc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1371/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of study and recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The study under this section shall evaluate whether the rights, protections, and procedures, including administrative and judicial relief, applicable to the entities listed in paragraph (1) of subsection (a) and their employees are comprehensive and effective and shall include recommendations for any improvements in regulations or legislation, including proposed regulatory or legislative language.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd70add-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1371/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline and delivery of study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1996-12-31"},"text":"December 31, 1996","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd70ade-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1371/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board shall prepare and complete the study and recommendations required under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd70adf-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1371/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board shall transmit such study and recommendations (with the Board’s comments) to the head of each entity considered in the study, and to the Congress by delivery to the Speaker of the House of Representatives and President pro tempore of the Senate for referral to the appropriate committees of the House of Representatives and of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcd70ae0-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/tII/s230"},"text":"Pub. L. 104–1, title II, § 230","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/23"},"text":"109 Stat. 23","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/53/tIII/s309/a"},"text":"Pub. L. 104–53, title III, § 309(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1995-11-19"},"text":"Nov. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/538"},"text":"109 Stat. 538","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcd70ae1-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcd70ae2-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcd70ae3-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Civil Rights Act of 1964, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/352"},"text":"Pub. L. 88–352","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-02"},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/252"},"text":"78 Stat. 252","children":[],"tail":". Title VII of the Act is classified generally to subchapter VI (§ 2000e et seq.) of chapter 21 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000a"},"text":"section 2000a of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Age Discrimination in Employment Act of 1967, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/202"},"text":"Pub. L. 90–202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-15"},"text":"Dec. 15, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/602"},"text":"81 Stat. 602","children":[],"tail":", which is classified generally to chapter 14 (§ 621 et seq.) of Title 29, Labor. For complete classification of this Act to the C