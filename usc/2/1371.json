{"tag":"section","attrib":{"id":"iddcd70ac8-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1371"},"text":null,"children":[{"tag":"num","attrib":{"value":"1371"},"text":"§ 1371.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and recommendations regarding General Accounting Office, Government Printing Office, and Library of Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcd70ac9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1371/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall undertake a study of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd70aca-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1371/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the application of the laws listed in subsection (b) to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcd70acb-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1371/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the General Accounting Office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd70acc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1371/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Government Printing Office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcd70acd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s1371/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"