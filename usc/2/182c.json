{"tag":"section","attrib":{"id":"iddc8f7b6d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182c"},"text":null,"children":[{"tag":"num","attrib":{"value":"182c"},"text":"§ 182c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revolving fund for FEDLINK program and Federal Research program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc8f7b6e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established in the Treasury a revolving fund for the Federal Library and Information Network program (hereafter in sections 182a to 182d of this title referred to as the “FEDLINK program”) of the Library of Congress (as described in subsection (f)(1)) and the Federal Research program of the Library of Congress (as described in subsection (f)(2)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f7b6f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individual accounting requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A separate account shall be maintained in the revolving fund under this section with respect to the programs described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f7b70-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees for services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc8f7b71-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Librarian may charge a fee for services under the FEDLINK program and the Federal Research program, and shall deposit any such fees charged into the account of the revolving fund under this section for such program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f7b72-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advances of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Participants in the FEDLINK program and the Federal Research program shall pay for products and services of the program by advance of funds—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc8f7b73-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182c/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Librarian determines that amounts in the Revolving Fund ","children":[{"tag":"ref","attrib":{"idref":"fn002013"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002013"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" are otherwise insufficient to cover the costs of providing such products and services; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f7b74-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182c/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon agreement between participants and the Librarian.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f7b75-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc8f7b76-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each account of the revolving fund under this section shall consist of the following amounts:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc8f7b77-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182c/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts deposited by the Librarian under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f7b78-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182c/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other amounts received by the Librarian which are attributable to the program covered by such account.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f7b79-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182c/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts deposited by the Librarian under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f7b7a-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182c/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other amounts as may be appropriated under law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f7b7b-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of funds during transition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1535/d"},"text":"section 1535(d) of title 31","children":[],"tail":", the Librarian shall transfer to the appropriate account of the revolving fund under this section the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc8f7b7c-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182c/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any obligated, unexpended balances existing as of the date of the transfer which are attributable to the FEDLINK program or the Federal Research program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f7b7d-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182c/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An amount equal to the difference as of such date between—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc8f7b7e-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182c/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total value of the supplies, inventories, equipment, gift fund balances, and other assets attributable to such program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc8f7b7f-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182c/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total value of the liabilities attributable to such program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f7b80-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of amounts in fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the accounts of the revolving fund under this section shall be available to the Librarian, in amounts specified in appropriations Acts and without fiscal year limitation, to carry out the program covered by each such account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f7b81-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs described","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc8f7b82-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182c/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FEDLINK","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the “FEDLINK program” is the program of the Library of Congress under which the Librarian provides the following services on behalf of participating Federal libraries, Federal information centers, other entities of the Federal Government, tribal governments (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s502/c/2/B"},"text":"40 U.S.C. 502(c)(2)(B)","children":[],"tail":") and the District of Columbia:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc8f7b83-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182c/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The procurement of commercial information services, publications in any format, and library support services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f7b84-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182c/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Related accounting services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f7b85-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182c/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Related education, information, and support services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f7b86-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s182c/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Research program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the “Federal Research program” is the program of the Library of Congress under which the Librarian provides research reports, translations, and analytical studies for entities of the Federal Government and the District of Columbia (other than any program of the Congressional Research Service).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc8f7b87-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/481/tI/s103"},"text":"Pub. L. 106–481, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2189"},"text":"114 Stat. 2189","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dI/tI/s151/2"},"text":"Pub. L. 115–141, div. I, title I, § 151(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/784"},"text":"132 Stat. 784","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc8f7b88-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc8f7b89-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddc8f7b8a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 182a to 182d of this title, referred to in subsec. (a), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/481"},"text":"Pub. L. 106–481","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2187"},"text":"114 Stat. 2187","children":[],"tail":", known as the Library of Congress Fiscal Operations Improvement Act of 2000, which enacted this section and sections 182b to 182d of this title, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s154"},"text":"section 154 of this title","children":[],"tail":", and enacted provisions set out as notes under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s154"},"text":"section 154 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s182a"},"text":"section 182a of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc8f7b8b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" inserted “tribal governments (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s502/c/2/B"},"text":"40 U.S.C. 502(c)(2)(B)","children":[],"tail":")” after “the Federal Government,” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc8f7b8c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddc8f7b8d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to fiscal year 2002 and each succeeding fiscal year, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/481/s105"},"text":"section 105 of Pub. L. 106–481","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s182a"},"text":"section 182a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
