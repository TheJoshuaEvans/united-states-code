{"tag":"section","attrib":{"id":"iddd0dd231-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4122"},"text":null,"children":[{"tag":"num","attrib":{"value":"4122"},"text":"§ 4122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of fees for services by Office of Attending Physician; availability of amounts deposited","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd0dd232-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established a subaccount in the appropriation account for salaries and expenses of the House of Representatives for the deposit of fees received from Members and officers of the House of Representatives for services provided to such Members and officers by the Office of the Attending Physician. The amounts so deposited shall be available, subject to appropriation, for the operations of the Office of the Attending Physician.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0dd233-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall take effect at the beginning of the first month after October 1992.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd0dd234-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/392/tI/s104"},"text":"Pub. L. 102–392, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1710"},"text":"106 Stat. 1710","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd0dd235-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd0dd236-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd0dd237-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s117h"},"text":"section 117h of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Congressional Operations Appropriations Act, 1993, which is title I of the Legislative Branch Appropriations Act, 1993.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
