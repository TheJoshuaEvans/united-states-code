{"tag":"section","attrib":{"id":"iddd2356d9-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4712"},"text":null,"children":[{"tag":"num","attrib":{"value":"4712"},"text":"§ 4712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Posting of travel and financial disclosure reports on public website of Clerk of the House of Representatives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2356da-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4712/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requiring posting on Internet","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Clerk of the House of Representatives shall post on the public Internet site of the Office of the Clerk, in a format that is searchable, sortable, and downloadable, to the extent technically practicable, each of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2356db-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4712/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The advance authorizations, certifications, and disclosures filed with respect to transportation, lodging, and related expenses for travel under clause 5(b) of rule XXV of the Rules of the House of Representatives by Members (including Delegates and Resident Commissioners to the Congress), officers, and employees of the House.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2356dc-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4712/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The reports filed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s13105/h/1"},"text":"section 13105(h)(1) of title 5","children":[],"tail":" by Members of the House of Representatives (including Delegates and Resident Commissioners to the Congress)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2356dd-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4712/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability and timing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2356de-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4712/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), subsection (a) shall apply with respect to information received by the Clerk of the House of Representatives on or after ","children":[{"tag":"date","attrib":{"date":"2007-09-14"},"text":"September 14, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2356df-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4712/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Clerk of the House of Representatives shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2356e0-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4712/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than ","children":[{"tag":"date","attrib":{"date":"2008-08-01"},"text":"August 1, 2008","children":[],"tail":", post the information required by subsection (a) that the Clerk receives by "},{"tag":"date","attrib":{"date":"2008-06-01"},"text":"June 1, 2008","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2356e1-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4712/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than the end of each 45-day period occurring after information is required to be posted under subparagraph (A), post the information required by subsection (a) that the Clerk has received since the last posting under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2356e2-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4712/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omission of personally identifiable information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the House of Representatives (including Delegates and Resident Commissioners to the Congress) shall be permitted to omit personally identifiable information not required to be disclosed on the reports posted on the public Internet site under this section (such as home address, Social Security numbers, personal bank account numbers, home telephone, and names of children) prior to the posting of such reports on such public Internet site.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2356e3-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4712/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance in protecting personal information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Clerk of the House of Representatives, in consultation with the Committee on Standards of Official Conduct, shall include in any informational materials concerning any disclosure that will be posted on the public Internet site under this section an explanation of the procedures for protecting personally identifiable information as described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2356e4-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s4712/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Clerk shall maintain the information posted on the public Internet site of the Office of the Clerk under this section for a period of 6 years after receiving the information, or, in the case of reports filed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s13105/h/1"},"text":"section 13105(h)(1) of title 5","children":[],"tail":", until the expiration of the 6-year period which begins on the date the individual is no longer a Member of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2356e5-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/tIII/s304"},"text":"Pub. L. 110–81, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/752"},"text":"121 Stat. 752","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/105/s19/b/1"},"text":"Pub. L. 112–105, § 19(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-04-04"},"text":"Apr. 4, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/304"},"text":"126 Stat. 304","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/c/4"},"text":"Pub. L. 117–286, § 4(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4353"},"text":"136 Stat. 4353","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2356e6-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2356e7-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd2356e8-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s104e"},"text":"section 104e of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd2356e9-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/c/4/A"},"text":"Pub. L. 117–286, § 4(c)(4)(A)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s13105/h/1"},"text":"section 13105(h)(1) of title 5","children":[],"tail":"” for “section 103(h)(1) of the Ethics in Government Act of 1978”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/c/4/B"},"text":"Pub. L. 117–286, § 4(c)(4)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s13105/h/1"},"text":"section 13105(h)(1) of title 5","children":[],"tail":",” for “section 103(h)(1) of the Ethics in Government Act of 1978,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/105"},"text":"Pub. L. 112–105","children":[],"tail":" substituted “, or, in the case of reports filed under section 103(h)(1) of the Ethics in Government Act of 1978, until the expiration of the 6-year period which begins on the date the individual is no longer a Member of Congress.” for period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd259fda-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddd259fdb-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Standards of Official Conduct of House of Representatives changed to Committee on Ethics of House of Representatives by House Resolution No. 5, One Hundred Twelfth Congress, ","children":[{"tag":"date","attrib":{"date":"2011-01-05"},"text":"Jan. 5, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd259fdc-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/105/s19/b/2"},"text":"Pub. L. 112–105, § 19(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-04-04"},"text":"Apr. 4, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/305"},"text":"126 Stat. 305","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/105/s19/b/2"},"text":"“The amendment made by paragraph (1) [amending this section] shall apply with respect to any report which is filed on or after the date on which the systems developed by the Secretary and Sergeant at Arms of the Senate and the Clerk of the House of Representatives under section 8(b) [of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/105"},"text":"Pub. L. 112–105","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/pl/95/521/s105"},"text":"section 105 of Pub. L. 95–521","children":[],"tail":", in the Appendix to Title 5, Government Organization and Employees] first take effect.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd259fdd-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/105/s10"},"text":"Pub. L. 112–105, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-04-04"},"text":"Apr. 4, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/298"},"text":"126 Stat. 298","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/105/s10"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Nothing in this Act [see Tables for classification], the amendments made by this Act, or the interpretive guidance to be issued pursuant to sections 3 and 9[(a)] of this Act [set out as notes preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s13101"},"text":"section 13101 of Title 5","children":[],"tail":", Government Organization and Employees], shall be construed to—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impair or limit the construction of the antifraud provisions of the securities laws or the Commodity Exchange Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1"},"text":"7 U.S.C. 1","children":[],"tail":" et seq.] or the authority of the Securities and Exchange Commission or the Commodity Futures Trading Commission under those provisions;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be in derogation of the obligations, duties, and functions of a Member of Congress, an employee of Congress, an executive branch employee, a judicial officer, or a judicial employee, arising from such person’s official position; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be in derogation of existing laws, regulations, or ethical obligations governing Members of Congress, employees of Congress, executive branch employees, judicial officers, or judicial employees.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd259fde-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Exercise of Rulemaking Authority","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/tIII/s306"},"text":"Pub. L. 110–81, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/754"},"text":"121 Stat. 754","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/81/tIII/s306"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The provisions of this title [enacting this section] are adopted by the House of Representatives—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as an exercise of the rulemaking power of the House; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with full recognition of the constitutional right of the House to change those rules at any time, in the same manner, and to the same extent as in the case of any other rule of the House.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
