{"tag":"section","attrib":{"id":"iddc8d0950-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s175"},"text":null,"children":[{"tag":"num","attrib":{"value":"175"},"text":"§ 175.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Librarian of Congress, in carrying out the Center’s functions, is authorized to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc8d0951-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s175/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe such regulations as he deems necessary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8d0952-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s175/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive money and other property donated, bequeathed, or devised for the purposes of the Center, and to use, sell, or otherwise dispose of such property for the purposes of carrying out the Center’s functions, without reference to Federal disposal statutes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8d0953-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s175/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept and utilize the services of voluntary and noncompensated personnel and reimburse them for travel expenses, including per diem, as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc8d0954-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/129/s5"},"text":"Pub. L. 95–129, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-13"},"text":"Oct. 13, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1152"},"text":"91 Stat. 1152","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
