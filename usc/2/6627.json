{"tag":"section","attrib":{"id":"iddd3fdf26-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6627"},"text":null,"children":[{"tag":"num","attrib":{"value":"6627"},"text":"§ 6627.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation for lost or damaged property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3fdf27-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6627/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amounts received by the Sergeant at Arms and Doorkeeper of the Senate (in this section referred to as the “Sergeant at Arms”) for compensation for damage to, loss of, or loss of use of property of the Sergeant at Arms that was procured using amounts available to the Sergeant at Arms in the account for Contingent Expenses, Sergeant at Arms and Doorkeeper of the Senate, shall be credited to that account or, if applicable, to any subaccount of that account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fdf28-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6627/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts credited to any account or subaccount under subsection (a) shall be merged with amounts in that account or subaccount and shall be available to the same extent, and subject to the same terms and conditions, as amounts in that account or subaccount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fdf29-3a6e-11f1-a0f3-db3efcbbb4ee","identifier":"/us/usc/t2/s6627/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to fiscal year 2005 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3fdf2a-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dG/tI/s8"},"text":"Pub. L. 108–447, div. G, title I, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3170"},"text":"118 Stat. 3170","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3fdf2b-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3fdf2c-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd3fdf2d-3a6e-11f1-a0f3-db3efcbbb4ee"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s117d–1"},"text":"section 117d–1 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Legislative Branch Appropriations Act, 2005, which is div. G of the Consolidated Appropriations Act, 2005.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
