{"tag":"section","attrib":{"id":"idd1c470f5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234"},"text":null,"children":[{"tag":"num","attrib":{"value":"3234"},"text":"§ 3234.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited personnel practices in the intelligence community","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1c470f6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c470f7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “agency” means an executive department or independent establishment, as defined under sections 101 and 104 of title 5, that contains an intelligence community element, except the Federal Bureau of Investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c470f8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered intelligence community element","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered intelligence community element”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c470f9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1c470fa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Central Intelligence Agency, the Defense Intelligence Agency, the National Geospatial-Intelligence Agency, the National Security Agency, the Office of the Director of National Intelligence, and the National Reconnaissance Office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1c470fb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any executive agency or unit thereof determined by the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2302/a/2/C/ii"},"text":"section 2302(a)(2)(C)(ii) of title 5","children":[],"tail":" to have as its principal function the conduct of foreign intelligence or counterintelligence activities; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c470fc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include the Federal Bureau of Investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c470fd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel action","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “personnel action” means, with respect to an employee in a position in a covered intelligence community element (other than a position excepted from the competitive service due to its confidential, policy-determining, policymaking, or policy-advocating character) or a contractor employee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c470fe-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appointment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c470ff-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a promotion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c47100-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a disciplinary or corrective action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c47101-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detail, transfer, or reassignment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c47102-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a demotion, suspension, or termination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c47103-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reinstatement or restoration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c47104-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a performance evaluation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c47105-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/a/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a decision concerning pay, benefits, or awards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c47106-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/a/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a decision concerning education or training if such education or training may reasonably be expected to lead to an appointment, promotion, or performance evaluation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c47107-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/a/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other significant change in duties, responsibilities, or working conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c47108-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contractor employee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “contractor employee” means an employee of a contractor, subcontractor, grantee, subgrantee, or personal services contractor, of a covered intelligence community element.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c47109-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency employees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any employee of a covered intelligence community element or an agency who has authority to take, direct others to take, recommend, or approve any personnel action, shall not, with respect to such authority, take or fail to take, or threaten to take or fail to take, a personnel action with respect to any employee of a covered intelligence community element as a reprisal for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c4710a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any lawful disclosure of information by the employee to the Director of National Intelligence (or an employee designated by the Director of National Intelligence for such purpose), the Inspector General of the Intelligence Community, a supervisor in the employee’s direct chain of command, or a supervisor of the employing agency with responsibility for the subject matter of the disclosure, up to and including the head of the employing agency (or an employee designated by the head of that agency for such purpose), the appropriate inspector general of the employing agency or covered intelligence community element, a congressional intelligence committee, or a member of a congressional intelligence committee, which the employee reasonably believes evidences—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c4710b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a violation of any Federal law, rule, or regulation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c4710c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mismanagement, a gross waste of funds, an abuse of authority, or a substantial and specific danger to public health or safety;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c4710d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any lawful disclosure that complies with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c4710e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsections (b)(1), (e), and (h) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s416"},"text":"section 416 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c4710f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subparagraphs (A), (D), and (H) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3517/d/5"},"text":"section 3517(d)(5) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c47110-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subparagraphs (A), (D), and (I) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3033/k/5"},"text":"section 3033(k)(5) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c47111-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the actions do not result in the employee unlawfully disclosing information specifically required by Executive order to be kept classified in the interest of national defense or the conduct of foreign affairs, any lawful disclosure in conjunction with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c47112-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the exercise of any appeal, complaint, or grievance right granted by any law, rule, or regulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c47113-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" testimony for or otherwise lawfully assisting any individual in the exercise of any right referred to in subparagraph (A); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c47114-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperation with or disclosing information to the Inspector General of an agency, in accordance with applicable provisions of law in connection with an audit, inspection, or investigation conducted by the Inspector General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c47115-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contractor employees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c47116-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any employee of an agency or of a contractor, subcontractor, grantee, subgrantee, or personal services contractor, of a covered intelligence community element who has authority to take, direct others to take, recommend, or approve any personnel action, shall not, with respect to such authority, take or fail to take, or threaten to take or fail to take, a personnel action with respect to any contractor employee as a reprisal for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c47117-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any lawful disclosure of information by the contractor employee to the Director of National Intelligence (or an employee designated by the Director of National Intelligence for such purpose), the Inspector General of the Intelligence Community, a supervisor in the contractor employee’s direct chain of command, or a supervisor of the employing or contracting agency or employing contractor with responsibility for the subject matter of the disclosure, up to and including the head of the employing or contracting agency (or an employee designated by the head of that agency for that purpose) or employing contractor, the appropriate inspector general of the employing or contracting agency or covered intelligence community element, a congressional intelligence committee, or a member of a congressional intelligence committee, which the contractor employee reasonably believes evidences—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1c47118-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a violation of any Federal law, rule, or regulation (including with respect to evidence of another employee or contractor employee accessing or sharing classified information without authorization); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1c47119-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mismanagement, a gross waste of funds, an abuse of authority, or a substantial and specific danger to public health or safety;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c4711a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any lawful disclosure that complies with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1c4711b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsections (b)(1), (e), and (h) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s416"},"text":"section 416 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1c4711c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subparagraphs (A), (D), and (H) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3517/d/5"},"text":"section 3517(d)(5) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1c4711d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subparagraphs (A), (D), and (I) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3033/k/5"},"text":"section 3033(k)(5) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c4711e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the actions do not result in the contractor employee unlawfully disclosing information specifically required by Executive order to be kept classified in the interest of national defense or the conduct of foreign affairs, any lawful disclosure in conjunction with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1c4711f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the exercise of any appeal, complaint, or grievance right granted by any law, rule, or regulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1c47120-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" testimony for or otherwise lawfully assisting any individual in the exercise of any right referred to in clause (i); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1c47121-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperation with or disclosing information to the Inspector General of an agency, in accordance with applicable provisions of law in connection with an audit, inspection, or investigation conducted by the Inspector General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c47122-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A personnel action under paragraph (1) is prohibited even if the action is undertaken at the request of an agency official, unless the request takes the form of a nondiscretionary directive and is within the authority of the agency official making the request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c47123-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consistent with the protection of intelligence sources and methods, nothing in subsection (b) or (c) shall be construed to authorize—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c47124-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the withholding of information from Congress; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c47125-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taking of any personnel action against an employee who lawfully discloses information to Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c47126-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A disclosure shall not be excluded from this section because—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c47127-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disclosure was made to an individual, including a supervisor, who participated in an activity that the employee reasonably believed to be covered under subsection (b)(1)(B) or the contractor employee reasonably believed to be covered under subsection (c)(1)(A)(ii);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c47128-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disclosure revealed information that had been previously disclosed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c47129-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disclosure was not made in writing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c4712a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disclosure was made while the employee was off duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c4712b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the amount of time which has passed since the occurrence of the events described in the disclosure; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c4712c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disclosure was made during the normal course of duties of an employee or contractor employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c4712d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall provide for the enforcement of this section consistent, to the fullest extent possible, with the policies and procedures used to adjudicate alleged violations of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2302/b/8"},"text":"section 2302(b)(8) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c4712e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing rights preserved","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c4712f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preempt or preclude any employee, contractor employee, or applicant for employment, at the Federal Bureau of Investigation from exercising rights provided under any other law, rule, or regulation, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2303"},"text":"section 2303 of title 5","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c47130-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3234/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repeal ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2303"},"text":"section 2303 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1c47131-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title XI, § 1104, as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/126/tVI/s601/a"},"text":"Pub. L. 113–126, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-07"},"text":"July 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1414"},"text":"128 Stat. 1414","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/118/tI/s110/a"},"text":"Pub. L. 115–118, title I, § 110(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-01-19"},"text":"Jan. 19, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/15"},"text":"132 Stat. 15","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dX/tV/s501/a"},"text":"Pub. L. 117–103, div. X, title V, § 501(a)","children":[],"tail":", (d)(2), (e)(1), (f), (g), "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/981-984"},"text":"136 Stat. 981–984","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dF/tLXVI/s6608"},"text":"Pub. L. 117–263, div. F, title LXVI, § 6608","children":[],"tail":", title LXVIII, § 6824(a)(8), "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3559"},"text":"136 Stat. 3559","children":[],"tail":", 3615; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dF/tLXVII/s6703"},"text":"Pub. L. 118–159, div. F, title LXVII, § 6703","children":[],"tail":", title LXIX, § 6902(a)(4), "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2515"},"text":"138 Stat. 2515","children":[],"tail":", 2517.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1c47132-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1c47133-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1c47134-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s6703/1"},"text":"Pub. L. 118–159, § 6703(1)","children":[],"tail":", inserted “or covered intelligence community element” after “the appropriate inspector general of the employing agency” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s6902/a/4/A"},"text":"Pub. L. 118–159, § 6902(a)(4)(A)","children":[],"tail":", substituted “subsections (b)(1), (e), and (h) of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s416"},"text":"section 416 of title 5","children":[],"tail":"” for “subsections (a)(1), (d), and (g) of section 8H of the Inspector General Act of 1978 (5 U.S.C. App.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s6703/2"},"text":"Pub. L. 118–159, § 6703(2)","children":[],"tail":", inserted “or covered intelligence community element” after “the appropriate inspector general of the employing or contracting agency” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s6902/a/4/B/i"},"text":"Pub. L. 118–159, § 6902(a)(4)(B)(i)","children":[],"tail":", substituted semicolon for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s6902/a/4/B/ii"},"text":"Pub. L. 118–159, § 6902(a)(4)(B)(ii)","children":[],"tail":", substituted “subsections (b)(1), (e), and (h) of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s416"},"text":"section 416 of title 5","children":[],"tail":"” for “subsections (a)(1), (d), and (g) of section 8H of the Inspector General Act of 1978 (5 U.S.C. App.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s501/f/1"},"text":"Pub. L. 117–103, § 501(f)(1)","children":[],"tail":", substituted “(1) any lawful disclosure” for “a lawful disclosure”, inserted dash after “for”, redesignated former pars. (1) and (2) as subpars. (A) and (B), respectively, of par. (1), realigned margins, and added pars. (2) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s501/a/1/A"},"text":"Pub. L. 117–103, § 501(a)(1)(A)","children":[],"tail":", (e)(1)(A), in introductory provisions, substituted “Any employee of a covered intelligence community element or an agency” for “Any employee of an agency” and inserted “, or threaten to take or fail to take,” after “take or fail to take” and “a supervisor in the employee’s direct chain of command, or a supervisor of the employing agency with responsibility for the subject matter of the disclosure, up to and including” before “the head of the employing agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s6824/a/8"},"text":"Pub. L. 117–263, § 6824(a)(8)","children":[],"tail":", substituted semicolon for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s501/f/2"},"text":"Pub. L. 117–103, § 501(f)(2)","children":[],"tail":", substituted “(A) any lawful disclosure” for “a lawful disclosure”, inserted dash after “for”, redesignated former subpars. (A) and (B) as cls. (i) and (ii), respectively, of subpar. (A), realigned margins, and added subpars. (B) and (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s501/a/1/B"},"text":"Pub. L. 117–103, § 501(a)(1)(B)","children":[],"tail":", (2), (e)(1)(B), in introductory provisions, inserted “of an agency or” after “Any employee”, “, or threaten to take or fail to take,” after “take or fail to take”, and “a supervisor in the contractor employee’s direct chain of command, or a supervisor of the contracting agency with responsibility for the subject matter of the disclosure, up to and including” before “the head of the contracting agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s6608"},"text":"Pub. L. 117–263, § 6608","children":[],"tail":", in introductory provisions, substituted “a supervisor of the employing or contracting agency or employing contractor” for “a supervisor of the contracting agency”, “employing or contracting agency (or an employee designated by the head of that agency for that purpose) or employing contractor” for “contracting agency (or an employee designated by the head of that agency for such purpose)”, and “appropriate inspector general of the employing or contracting agency” for “appropriate inspector general of the contracting agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s501/d/2"},"text":"Pub. L. 117–103, § 501(d)(2)","children":[],"tail":", substituted “mismanagement” for “gross mismanagement”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s501/g/2"},"text":"Pub. L. 117–103, § 501(g)(2)","children":[],"tail":", added subsec. (d). Former subsec. (d) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s501/a/3"},"text":"Pub. L. 117–103, § 501(a)(3)","children":[],"tail":", amended subsec. (d) generally. Prior to amendment, text read as follows: “The President shall provide for the enforcement of this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s501/g/2"},"text":"Pub. L. 117–103, § 501(g)(2)","children":[],"tail":", added subsec. (e). Former subsec. (e) redesignated (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s501/g/1"},"text":"Pub. L. 117–103, § 501(g)(1)","children":[],"tail":", redesignated subsecs. (d) and (e) as (f) and (g), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/118/s110/a/1/A"},"text":"Pub. L. 115–118, § 110(a)(1)(A)","children":[],"tail":", inserted “or a contractor employee” after “character)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/118/s110/a/1/B"},"text":"Pub. L. 115–118, § 110(a)(1)(B)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/118/s110/a/4"},"text":"Pub. L. 115–118, § 110(a)(4)","children":[],"tail":", substituted “Agency employees” for “In general” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/118/s110/a/2"},"text":"Pub. L. 115–118, § 110(a)(2)","children":[],"tail":", (3), added subsec. (c) and redesignated former subsecs. (c) and (d) as (d) and (e), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/118/s110/a/5"},"text":"Pub. L. 115–118, § 110(a)(5)","children":[],"tail":", inserted “contractor employee,” after “any employee,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1c47135-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1c47136-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Policies and Procedures; Nonapplicability to Certain Terminations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/126/tVI/s604"},"text":"Pub. L. 113–126, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-07"},"text":"July 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1421"},"text":"128 Stat. 1421","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dF/tLXIV/s6402/c/2/H"},"text":"Pub. L. 119–60, div. F, title LXIV, § 6402(c)(2)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1616"},"text":"139 Stat. 1616","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dF/tLXIV/s6402/c/2/H"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Intelligence Community Element Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term ‘covered intelligence community element’—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Central Intelligence Agency, the Defense Intelligence Agency, the National Geospatial-Intelligence Agency, the National Security Agency, the Office of the Director of National Intelligence, and the National Reconnaissance Office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any executive agency or unit thereof determined by the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2302/a/2/C/ii"},"text":"section 2302(a)(2)(C)(ii) of title 5","children":[],"tail":", United States Code, to have as its principal function the conduct of foreign intelligence or counterintelligence activities; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include the Federal Bureau of Investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In consultation with the Secretary of Defense, the Director of National Intelligence shall develop policies and procedures to ensure that a personnel action shall not be taken against an employee of a covered intelligence community element as a reprisal for any disclosure of information described in [section] 1104 of the National Security Act of 1947 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3234"},"text":"50 U.S.C. 3234","children":[],"tail":"], as added by section 601 of this Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report on the Status of Implementation of Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 2 years after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2014-07-07"},"text":"July 7, 2014","children":[],"tail":"], the Director of National Intelligence shall submit a report on the status of the implementation of the regulations promulgated under subsection (b) to the congressional intelligence committees."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplicability to Certain Terminations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Section 1104 of the National Security Act of 1947, as added by section 601 of this Act, and section 3001 of the Intelligence Reform and Terrorism Prevention Act of 2004 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3341"},"text":"50 U.S.C. 3341","children":[],"tail":"), as amended by section 602 of this Act, shall not apply if—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the affected employee is concurrently terminated under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1609"},"text":"section 1609 of title 10","children":[],"tail":", United States Code;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority of the Director of National Intelligence under section 102A(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of the National Security Act of 1947 ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3024/m"},"text":"50 U.S.C. 3024(m)","children":[],"tail":" [now "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3024"},"text":"50 U.S.C. 3024","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")]), if the Director determines that the termination is in the interest of the United States;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority of the Director of the Central Intelligence Agency under section 104A(e) of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3036/e"},"text":"50 U.S.C. 3036(e)","children":[],"tail":"), if the Director determines that the termination is in the interest of the United States; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7532"},"text":"section 7532 of title 5","children":[],"tail":", United States Code, if the head of the agency determines that the termination is in the interest of the United States; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 30 days after such termination, the head of the agency that employed the affected employee notifies the congressional intelligence committees of the termination.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “congressional intelligence committees” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/126/s604"},"text":"section 604 of Pub. L. 113–126","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/113/126/s2"},"text":"section 2 of Pub. L. 113–126","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
