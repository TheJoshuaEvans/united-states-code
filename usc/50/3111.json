{"tag":"section","attrib":{"id":"idd1aa3269-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3111"},"text":null,"children":[{"tag":"num","attrib":{"value":"3111"},"text":"§ 3111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Briefings and notifications on counterintelligence activities of the Federal Bureau of Investigation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1aa326a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarterly briefings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to, and without any derogation of, the requirement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3091"},"text":"section 3091 of this title","children":[],"tail":" to keep the congressional intelligence committees fully and currently informed of the intelligence and counterintelligence activities of the United States, not less frequently than once each quarter, or more frequently if requested by the congressional intelligence committees, the Director of the Federal Bureau of Investigation shall provide to the congressional intelligence committees a briefing on the counterintelligence activities of the Federal Bureau of Investigation. Such briefings shall include, at a minimum, an overview and update of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1aa326b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3111/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the counterintelligence posture of the Bureau;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1aa326c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3111/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" counterintelligence investigations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1aa326d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3111/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information relating to the counterintelligence activities of the Bureau that the Director determines necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1aa326e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the quarterly briefings under subsection (a), the Director of the Federal Bureau of Investigation shall promptly notify the congressional intelligence committees of any counterintelligence investigation carried out by the Bureau with respect to any counterintelligence risk or threat that is related to an election or campaign for Federal office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1aa326f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3111/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1aa3270-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3111/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development and consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall develop guidelines governing the scope of the briefings provided under subsection (a), the notifications provided under subsection (b), and the information required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3371/a/2"},"text":"section 3371(a)(2) of this title","children":[],"tail":". The Director shall consult the congressional intelligence committees during such development."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1aa3271-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3111/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall submit to the congressional intelligence committees—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1aa3272-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3111/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the guidelines under paragraph (1) upon issuance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1aa3273-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3111/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any updates to such guidelines by not later than 15 days after making such update.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1aa3274-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title V, § 512, as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLIII/s5304/b/1"},"text":"Pub. L. 116–92, div. E, title LIII, § 5304(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2120"},"text":"133 Stat. 2120","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
