{"tag":"section","attrib":{"id":"idd20e4b0b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4025a"},"text":"§ 4025a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Portability of professional licenses of servicemembers and their spouses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd20e4b0c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a servicemember or the spouse of a servicemember has a covered license and relocates residence because such servicemember receives military orders for military service in a State other than the State of the licensing authority that issued the covered license, such covered license shall be considered valid for the scope of practice in the State of the new residence if such servicemember or spouse submits to the licensing authority of such State an application described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4b0d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary licenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a licensing authority is required to consider a covered license valid under subsection (a) but cannot carry out such requirement during the 30 days after receiving an application described in subsection (c), the licensing authority may issue to the applicant a temporary license that confers the same rights, privileges, and responsibilities as a permanent license.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4b0e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application described in this subsection includes the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20e4b0f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Proof of military orders described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4b10-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the applicant is the spouse of a servicemember, a copy of the marriage certificate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4b11-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A notarized affidavit affirming, under the penalty of law, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd20e4b12-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant is the person described and identified in the application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd20e4b13-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all statements made in the application are true and correct and complete;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd20e4b14-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025a/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant has read and understands the requirements to receive a license, and the scope of practice, of the State of the licensing authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd20e4b15-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025a/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant certifies that the applicant meets and shall comply with requirements described in subparagraph (C); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd20e4b16-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025a/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant is in good standing in all States in which the applicant holds or has held a license.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4b17-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Background checks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A licensing authority that receives an application described in subsection (b) may conduct a background check of the applicant before carrying out subsection (a) or (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4b18-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interstate compacts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a servicemember or spouse of a servicemember has a covered license to operate in multiple States pursuant to an interstate compact described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1784"},"text":"section 1784 of title 10","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20e4b19-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the servicemember or spouse of a servicemember shall be subject to the requirements of such compact or the applicable provisions of law of the applicable State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4b1a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this section shall not apply to such servicemember or spouse of a servicemember.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4b1b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20e4b1c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered license” means a professional license that, with respect to a scope of practice—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd20e4b1d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025a/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in good standing with the licensing authority that issued such license;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd20e4b1e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025a/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not been revoked or had discipline imposed by any State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd20e4b1f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025a/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not have an investigation relating to unprofessional conduct pending in any State relating to it; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd20e4b20-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025a/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not been voluntarily surrendered while under investigation for unprofessional conduct in any State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4b21-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “license” means any license, certificate, or other evidence of qualification that an individual is required to obtain before the individual may engage in, or represent himself or herself to be a member of, a particular profession.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4b22-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025a/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “licensing authority” means any State board, commission, department, or agency that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd20e4b23-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025a/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is established in the State for the primary purpose of regulating the entry of persons into or the conduct of persons within, a particular profession; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd20e4b24-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025a/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is authorized to issue licenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4b25-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025a/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “military orders” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3955"},"text":"section 3955 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4b26-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025a/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “scope of practice” means the defined parameters of various duties or services that may be provided by an individual under a license.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd20e4b27-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title VII, § 705A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/333/s19/a"},"text":"Pub. L. 117–333, § 19(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6137"},"text":"136 Stat. 6137","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s587"},"text":"Pub. L. 118–159, div. A, title V, § 587","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1912"},"text":"138 Stat. 1912","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd20e4b28-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd20e4b29-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd20e4b2a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" amended section generally. Prior to amendment, section related to portability of professional licenses of servicemembers and their spouses."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
