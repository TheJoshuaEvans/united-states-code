{"tag":"section","attrib":{"id":"idd20e4b34-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4027"},"text":null,"children":[{"tag":"num","attrib":{"value":"4027"},"text":"§ 4027.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guarantee of residency for spouses of servicemembers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purposes of establishing the residency of a spouse of a servicemember for any purpose (including the registration of a business), the spouse of a servicemember may elect to use the same residence as the servicemember regardless of the date on which the marriage of the spouse and the servicemember occurred.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd20e4b35-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title VII, § 707, as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXVII/s1739/a"},"text":"Pub. L. 116–92, div. A, title XVII, § 1739(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1820"},"text":"133 Stat. 1820","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tX/s1081/c"},"text":"Pub. L. 117–81, div. A, title X, § 1081(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1922"},"text":"135 Stat. 1922","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd20e4b36-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd20e4b37-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attr