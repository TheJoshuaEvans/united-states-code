{"tag":"section","attrib":{"id":"idd1a7c1ad-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103"},"text":null,"children":[{"tag":"num","attrib":{"value":"3103"},"text":"§ 3103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Future budget projections","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1a7c1ae-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Future Year Intelligence Plans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1a7c1af-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director of National Intelligence, with the concurrence of the Director of the Office of Management and Budget, shall provide to the congressional intelligence committees a Future Year Intelligence Plan, as described in paragraph (2), for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1a7c1b0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each expenditure center in the National Intelligence Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a7c1b1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each major system in the National Intelligence Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a7c1b2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1a7c1b3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Future Year Intelligence Plan submitted under this subsection shall include the year-by-year proposed funding for each center or system referred to in subparagraph (A) or (B) of paragraph (1), for the budget year for which the Plan is submitted and not less than the 4 subsequent fiscal years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a7c1b4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A Future Year Intelligence Plan submitted under subparagraph (B) of paragraph (1) for a major system shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1a7c1b5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated total life-cycle cost of such major system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1a7c1b6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" major milestones that have significant resource implications for such major system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1a7c1b7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Long-term Budget Projections","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1a7c1b8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of National Intelligence, with the concurrence of the Director of the Office of Management and Budget, shall provide to the congressional intelligence committees a Long-term Budget Projection for each element of the intelligence community funded under the National Intelligence Program acquiring a major system that includes the budget for such element for the 5-year period that begins on the day after the end of the last fiscal year for which year-by-year proposed funding is included in a Future Year Intelligence Plan for such major system in accordance with subsection (a)(2)(A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a7c1b9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A Long-term Budget Projection submitted under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1a7c1ba-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" projections for the appropriate element of the intelligence community for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1a7c1bb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay and benefits of officers and employees of such element;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1a7c1bc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other operating and support costs and minor acquisitions of such element;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1a7c1bd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research and technology required by such element;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1a7c1be-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" current and planned major system acquisitions for such element;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1a7c1bf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/b/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any future major system acquisitions for such element; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1a7c1c0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/b/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any additional funding projections that the Director of National Intelligence considers appropriate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a7c1c1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a budget projection based on effective cost and schedule execution of current or planned major system acquisitions and application of Office of Management and Budget inflation estimates to future major system acquisitions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a7c1c2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any additional assumptions and projections that the Director of National Intelligence considers appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a7c1c3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of whether, and to what extent, the total projection for each year exceeds the level that would result from applying the most recent Office of Management and Budget inflation estimate to the budget of that element of the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1a7c1c4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence, with the concurrence of the Director of the Office of Management and Budget, shall submit to the congressional intelligence committees each Future Year Intelligence Plan or Long-term Budget Projection required under subsection (a) or (b) for a fiscal year at the time that the President submits to Congress the budget for such fiscal year pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1a7c1c5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major system affordability report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1a7c1c6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of National Intelligence, with the concurrence of the Director of the Office of Management and Budget, shall prepare a report on the acquisition of a major system funded under the National Intelligence Program before the time that the President submits to Congress the budget for the first fiscal year in which appropriated funds are anticipated to be obligated for the development or procurement of such major system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1aa31c7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The report on such major system shall include an assessment of whether, and to what extent, such acquisition, if developed, procured, and operated, is projected to cause an increase in the most recent Future Year Intelligence Plan and Long-term Budget Projection submitted under this section for an element of the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1aa31c8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of National Intelligence shall update the report whenever an independent cost estimate must be updated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3097/a/4"},"text":"section 3097(a)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1aa31c9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of National Intelligence shall submit each report required by this subsection at the time that the President submits to Congress the budget for a fiscal year pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1aa31ca-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1aa31cb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “budget year” means the next fiscal year for which the President is required to submit to Congress a budget pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1aa31cc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3103/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent cost estimate; major system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “independent cost estimate” and “major system” have the meaning given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3097/e"},"text":"section 3097(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1aa31cd-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title V, § 506G, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/tIII/s325/a"},"text":"Pub. L. 111–259, title III, § 325(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2681"},"text":"124 Stat. 2681","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dF/tLXVIII/s6824/a/5"},"text":"Pub. L. 117–263, div. F, title LXVIII, § 6824(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3615"},"text":"136 Stat. 3615","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1aa31ce-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1aa31cf-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1aa31d0-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s415a–9"},"text":"section 415a–9 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1aa31d1-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “pursuant to section” for “pursuant section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1aa31d2-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1aa31d3-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/tIII/s325/b"},"text":"Pub. L. 111–259, title III, § 325(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2683"},"text":"124 Stat. 2683","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/259/tIII/s325/b"},"text":"“The first Future Year Intelligence Plan and Long-term Budget Projection required to be submitted under subsection (a) and (b) of section 506G of the National Security Act of 1947 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3103/a"},"text":"50 U.S.C. 3103(a)","children":[],"tail":", (b)], as added by subsection (a), shall be submitted to the congressional intelligence committees at the time that the President submits to Congress the budget for fiscal year 2012 pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “congressional intelligence committees” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s325/b"},"text":"section 325(b) of Pub. L. 111–259","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/s2"},"text":"section 2 of Pub. L. 111–259","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1aa31d4-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Future-Years Intelligence Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/245/dA/tVIII/s8089"},"text":"Pub. L. 115–245, div. A, title VIII, § 8089","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-28"},"text":"Sept. 28, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3021"},"text":"132 Stat. 3021","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/245/dA/tVIII/s8089"},"text":"“The Director of National Intelligence shall submit to Congress each year, at or about the time that the President’s budget is submitted to Congress that year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":", United States Code, a future-years intelligence program (including associated annexes) reflecting the estimated expenditures and proposed appropriations included in that budget. Any such future-years intelligence program shall cover the fiscal year with respect to which the budget is submitted and at least the four succeeding fiscal years.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dC/tVIII/s8090"},"text":"Pub. L. 115–141, div. C, title VIII, § 8090","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/484"},"text":"132 Stat. 484","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/dC/tVIII/s8091"},"text":"Pub. L. 115–31, div. C, title VIII, § 8091","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/268"},"text":"131 Stat. 268","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dC/tVIII/s8091"},"text":"Pub. L. 114–113, div. C, title VIII, § 8091","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015