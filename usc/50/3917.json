{"tag":"section","attrib":{"id":"idd2071faa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3917"},"text":null,"children":[{"tag":"num","attrib":{"value":"3917"},"text":"§ 3917.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of rights and protections to reserves ordered to report for military service and to persons ordered to report for induction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2071fab-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3917/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserves ordered to report for military service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of a reserve component who is ordered to report for military service is entitled to the rights and protections of this subchapter and subchapters II and III during the period beginning on the date of the member’s receipt of the order and ending on the date on which the member reports for military service (or, if the order is revoked before the member so reports, or the date on which the order is revoked).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2071fac-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3917/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons ordered to report for induction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person who has been ordered to report for induction under the Military Selective Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3801"},"text":"50 U.S.C. 3801","children":[],"tail":" et seq.] is entitled to the rights and protections provided a servicemember under this subchapter and subchapters II and III during the period beginning on the date of receipt of the order for induction and ending on the date on which the person reports for induction (or, if the order to report for induction is revoked before the date on which the person reports for induction, on the date on which the order is revoked)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2071fad-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3917/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Member of the Space Force ordered to report for military service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of subsection (a) apply to a member of the Space Force who is ordered to report for military service in the same manner as to a member of a reserve component who is ordered to report for military service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2071fae-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title I, § 106, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s1"},"text":"Pub. L. 108–189, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2839"},"text":"117 Stat. 2839","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1742/c/2"},"text":"Pub. L. 118–31, div. A, title XVII, § 1742(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/681"},"text":"137 Stat. 681","children":[],"tail":".)"}],"tail":"\n"},{"ta