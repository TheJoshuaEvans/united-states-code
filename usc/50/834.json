{"tag":"section","attrib":{"id":"idd103439f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s834"},"text":null,"children":[{"tag":"num","attrib":{"value":"834"},"text":"§ 834.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Classified information” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purposes of this section, the term “classified information” means information which, for reasons of national security, is specifically designated by a United States Government agency for limited or restricted dissemination or distribution.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd10343a0-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-23/ch1024"},"text":"Sept. 23, 1950, ch. 1024","children":[],"tail":", title III, § 304, as added "},{"tag":"ref","attrib":{"href":"/us/pl/88/290"},"text":"Pub. L. 88–290","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-03-26"},"text":"Mar. 26, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/170"},"text":"78 Stat. 170","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
