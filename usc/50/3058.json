{"tag":"section","attrib":{"id":"idd19e4b65-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3058"},"text":null,"children":[{"tag":"num","attrib":{"value":"3058"},"text":"§ 3058.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Intelligence Centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd19e4b66-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3058/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to establish","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence may establish one or more national intelligence centers to address intelligence priorities, including, but not limited to, regional issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19e4b67-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3058/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resources of directors of centers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd19e4b68-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3058/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of National Intelligence shall ensure that the head of each national intelligence center under subsection (a) has appropriate authority, direction, and control of such center, and of the personnel assigned to such center, to carry out the assigned mission of such center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd19e4b69-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3058/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of National Intelligence shall ensure that each national intelligence center has appropriate personnel to accomplish effectively the mission of such center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19e4b6a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3058/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence shall, to the extent appropriate and practicable, ensure that each national intelligence center under subsection (a) and the other elements of the intelligence community share information in order to facilitate the mission of such center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19e4b6b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3058/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mission of centers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Pursuant to the direction of the Director of National Intelligence, each national intelligence center under subsection (a) may, in the area of intelligence responsibility assigned to such center—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd19e4b6c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3058/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have primary responsibility for providing all-source analysis of intelligence based upon intelligence gathered both domestically and abroad;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd19e4b6d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3058/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have primary responsibility for identifying and proposing to the Director of National Intelligence intelligence collection and analysis and production requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd19e4b6e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3058/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other duties as the Director of National Intelligence shall specify.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19e4b6f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3058/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and modification of centers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of National Intelligence shall determine on a regular basis whether—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd19e4b70-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3058/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the area of intelligence responsibility assigned to each national intelligence center under subsection (a) continues to meet appropriate intelligence priorities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd19e4b71-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3058/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the staffing and management of such center remains appropriate for the accomplishment of the mission of such center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19e4b72-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3058/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence may terminate any national intelligence center under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19e4b73-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3058/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate budget account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence shall, as appropriate, include in the National Intelligence Program budget a separate line item for each national intelligence center under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd19e4b74-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title I, § 119B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI/s1023"},"text":"Pub. L. 108–458, title I, § 1023","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3676"},"text":"118 Stat. 3676","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd19e4b75-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd19e4b76-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd19e4b77-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 404","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–2 of this title prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd19e4b78-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd19e4b79-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For Determination by President that section take effect on ","children":[{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", see Memorandum of President of the United States, "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", 70 F.R. 23925, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section effective not later than six months after ","children":[{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1097/a"},"text":"section 1097(a) of Pub. L. 108–458","children":[],"tail":", set out in an Effective Date of 2004 Amendment; Transition Provisions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
