{"tag":"section","attrib":{"id":"idd1aa3275-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3111a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3111a"},"text":"§ 3111a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on Federal Bureau of Investigation case data","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1aa3276-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3111a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"December 18, 2025","children":[],"tail":", and annually thereafter, the Director of the Federal Bureau of Investigation shall submit to the congressional intelligence committees, the Committee on the Judiciary of the Senate, and the Committee on the Judiciary of the House of Representatives a report containing data on cases of the Federal Bureau of Investigation for the fiscal year preceding the fiscal year in which the report is submitted."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1aa3277-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3111a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report required by subsection (a) shall include, for the fiscal year covered by the report, the number of active cases, the number of unique cases, and the number of cases opened, for each of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ac7b68-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3111a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Russia counterintelligence cases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ac7b69-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3111a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" China counterintelligence cases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ac7b6a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3111a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Espionage or leak cases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ac7b6b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3111a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All other counterintelligence cases, disaggregated by country affiliation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ac7b6c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3111a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cartel and other transnational criminal organization counterterrorism cases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ac7b6d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3111a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All other international counterterrorism cases, disaggregated by country affiliation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ac7b6e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3111a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Russia cyber national security cases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ac7b6f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3111a/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" China cyber national security cases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ac7b70-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3111a/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All other cyber national security cases, disaggregated by country affiliation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ac7b71-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3111a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report required by subsection (a) shall be submitted in unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1ac7b72-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title V, § 512A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dF/tLXV/s6524"},"text":"Pub. L. 119–60, div. F, title LXV, § 6524","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1632"},"text":"139 Stat. 1632","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
