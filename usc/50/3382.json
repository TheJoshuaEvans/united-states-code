{"tag":"section","attrib":{"id":"idd1e0f93f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3382"},"text":null,"children":[{"tag":"num","attrib":{"value":"3382"},"text":"§ 3382.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of the National Counterintelligence and Security Center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1e0f940-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3382/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be a Director of the National Counterintelligence and Security Center (referred to in this section as the “Director”), who shall be appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1e0f941-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3382/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The mission of the Director shall be to serve as the head of national counterintelligence for the United States Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1e0f942-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3382/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the direction and control of the Director of National Intelligence, the duties of the Director are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1e0f943-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3382/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To carry out the mission referred to in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1e0f944-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3382/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To act as chairperson of the National Counterintelligence Policy Board established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3381"},"text":"section 3381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1e0f945-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3382/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To act as head of the National Counterintelligence and Security Center established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3383"},"text":"section 3383 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1e0f946-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3382/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To participate as an observer on such boards, committees, and entities of the executive branch as the Director of National Intelligence considers appropriate for the discharge of the mission and functions of the Director and the National Counterintelligence and Security Center under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3383"},"text":"section 3383 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1e0f947-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/tIX/s902"},"text":"Pub. L. 107–306, title IX, § 902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2432"},"text":"116 Stat. 2432","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI/s1072/d/1/B"},"text":"Pub. L. 108–458, title I, § 1072(d)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3693"},"text":"118 Stat. 3693","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dM/tIV/s401/a"},"text":"Pub. L. 114–113, div. M, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2920"},"text":"129 Stat. 2920","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/31/dN/tIV/s401/a/1"},"text":"Pub. L. 115–31, div. N, title IV, § 401(a)(1)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/816"},"text":"131 Stat. 816","children":[],"tail":", 817.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1e0f948-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1e0f949-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1e0f94a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s402b"},"text":"section 402b of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1e0f94b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/s401/a/1"},"text":"Pub. L. 115–31, § 401(a)(1)","children":[],"tail":", amended section generally. Prior to amendment, section related to the National Counterintelligence Executive."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/s401/a/3"},"text":"Pub. L. 115–31, § 401(a)(3)","children":[],"tail":", provided that the amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/s401/a"},"text":"Pub. L. 114–113, § 401(a)","children":[],"tail":", was deemed to not have taken effect. See 2015 Amendment and Effective Date of 2015 Amendment notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113"},"text":"Pub. L. 114–113","children":[],"tail":", which directed that subsec. (a) be amended to read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—There shall be a National Counterintelligence Executive who shall be appointed by the President, by and with the advice and consent of the Senate.”,"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"was deemed to not have taken effect by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/s401/a/3"},"text":"Pub. L. 115–31, § 401(a)(3)","children":[],"tail":". See 2017 Amendment note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1072/d/1/B/i"},"text":"Pub. L. 108–458, § 1072(d)(1)(B)(i)","children":[],"tail":", substituted “Director of National Intelligence” for “President”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1072/d/1/B"},"text":"Pub. L. 108–458, § 1072(d)(1)(B)","children":[],"tail":", substituted “Director of National Intelligence” for “President” and “Director of the Central Intelligence Agency” for “Director of Central Intelligence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1072/d/1/B/i"},"text":"Pub. L. 108–458, § 1072(d)(1)(B)(i)","children":[],"tail":", substituted “Director of National Intelligence” for “President” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1e0f94c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd1e0f94d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/dN/tIV/s401/a/3"},"text":"Pub. L. 115–31, div. N, title IV, § 401(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/817"},"text":"131 Stat. 817","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/31/dN/tIV/s401/a/3"},"text":"“The amendment made by subsection (a) of section 401 of the Intelligence Authorization Act for Fiscal Year 2016 (division M of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113"},"text":"Public Law 114–113","children":[],"tail":") [amending this section] shall not take effect, or, if the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":"] is on or after the effective date specified in subsection (b) of such section ["},{"tag":"date","attrib":{"date":"2016-12-18"},"text":"Dec. 18, 2016","children":[],"tail":", see note below], such amendment shall be deemed to not have taken effect.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dM/tIV/s401/b"},"text":"Pub. L. 114–113, div. M, title IV, § 401(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2921"},"text":"129 Stat. 2921","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/113/dM/tIV/s401/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect on the date that is one year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd1e0f94e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For Determination by President that amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" take effect on "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", see Memorandum of President of the United States, "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", 70 F.R. 23925, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" effective not later than six months after "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1097/a"},"text":"section 1097(a) of Pub. L. 108–458","children":[],"tail":", set out in an Effective Date of 2004 Amendment; Transition Provisions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1e0f94f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purpose","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/tIX/s901/b"},"text":"Pub. L. 107–306, title IX, § 901(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2432"},"text":"116 Stat. 2432","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/306/tIX/s901/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The purpose of this title [see Tables for classification] is to facilitate the enhancement of the counterintelligence activities of the United States Government by—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enabling the counterintelligence community of the United States Government to fulfill better its mission of identifying, assessing, prioritizing, and countering the intelligence threats to the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that the counterintelligence community of the United States Government acts in an efficient and effective manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for the integration of all the counterintelligence activities of the United States Government.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
