{"tag":"section","attrib":{"id":"idd1c6bb0a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3244"},"text":null,"children":[{"tag":"num","attrib":{"value":"3244"},"text":"§ 3244.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on reporting requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1c6bb0b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3244/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than March 1 of each fiscal year, the Director of National Intelligence shall submit to the congressional intelligence committees, the Committee on Appropriations of the Senate, and the Committee on Appropriations of the House of Representatives a report detailing all congressionally mandated reporting requirements applicable to the Office of the Director of National Intelligence for the upcoming fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c6bb0c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3244/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted pursuant to subsection (a) shall include, for the fiscal year covered by the report and for each congressionally mandated reporting requirement detailed in the report:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c6bb0d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3244/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the reporting requirement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c6bb0e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3244/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A citation to the provision of law (or other source of congressional directive) imposing the reporting requirement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c6bb0f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3244/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the reporting requirement is recurring, conditional, or subject to a termination provision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c6bb10-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3244/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the Director recommends repealing or modifying the requirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c6bb11-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3244/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report submitted pursuant to subsection (a) may be submitted in classified form.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1c6bb12-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title XI, § 1114, as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tIII/s7314/a"},"text":"Pub. L. 118–31, div. G, title III, § 7314(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1031"},"text":"137 Stat. 1031","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dF/tLXIX/s6902/a/5"},"text":"Pub. L. 118–159, div. F, title LXIX, § 6902(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2517"},"text":"138 Stat. 2517","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1c6bb13-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1c6bb14-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1c6bb15-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" inserted “the” before “Office of the Director”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
