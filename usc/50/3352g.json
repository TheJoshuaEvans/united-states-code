{"tag":"section","attrib":{"id":"idd1d78363-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g"},"text":null,"children":[{"tag":"num","attrib":{"value":"3352g"},"text":"§ 3352g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to authorize additional security clearances for certain contractors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1d78364-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d78365-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate committees of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d78366-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional intelligence committees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d78367-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Subcommittee on Defense of the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d78368-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Subcommittee on Defense of the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d78369-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered contract or agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered contract or agreement”, with respect to an entity, means a contract or other agreement between that entity and an element of the intelligence community the performance of which requires a specified number of covered persons to hold a security clearance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d7836a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered person”, with respect to an entity, means a contractor or employee of that entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d7836b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan and study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d7836c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No later than ","children":[{"tag":"date","attrib":{"date":"2024-04-01"},"text":"April 1, 2024","children":[],"tail":", the Director of National Intelligence shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d7836d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete a study on the feasibility and advisability of implementing a program to authorize additional security clearances for certain contractors as described in subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d7836e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a plan to implement the program described in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d7836f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the appropriate committees of Congress—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1d78370-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a report on the findings of the Director with respect to the study completed pursuant to subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1d78371-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan developed pursuant to subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d78372-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study completed pursuant to paragraph (1)(A) shall address the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d78373-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For contracts agreed to after ","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"December 22, 2023","children":[],"tail":", how private entities that contract with the intelligence community would make payments for additional clearances for their employees and how the intelligence community would receive payments."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d78374-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A list of and changes to provisions of law required in order to fully implement the program required by subsection (c) and achieve the intent indicated in subparagraph (A) of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d78375-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such considerations as the Director may have for carrying out the program required by subsection (c) and achieving the intent indicated in subparagraph (A) of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d78376-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program to authorize additional security clearances for certain contractors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to the limitations described in subsection (d), the Director shall establish a program under which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d78377-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any entity that enters into a covered contract or agreement with an element of the intelligence community may designate an additional number of covered persons who may submit an application for a security clearance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d78378-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the appropriate authorized investigative agency and authorized adjudicative agency, as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3341/a"},"text":"section 3341(a) of this title","children":[],"tail":", shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d78379-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" upon receiving such an application—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1d7837a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct an appropriate investigation of the background of the additional covered person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1d7837b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a determination as to whether the additional covered person is eligible for access to classified information; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d7837c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the determination under subparagraph (A)(ii) is favorable, upon any of the specified number of covered persons required to hold a security clearance for the performance of work under that covered contract or agreement becoming unable to perform such work, make a determination as to whether the additional covered person has a demonstrated need-to-know under Executive Order 12968 (60 Fed. Reg. 40245; relating to access to classified information), or any successor thereto, or Executive Order 10865 (25 Fed. Reg. 1583; relating to safeguarding classified information within industry), or any successor thereto (without requiring an additional investigation to be conducted under subparagraph (A)(i)); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d7837d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the additional covered person receives a favorable determination regarding the need-to-know under paragraph (2)(B) and signs an approved nondisclosure agreement, the additional covered person may perform such work in lieu of such covered person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d7837e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The limitations described in this subsection are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d7837f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on number designated per contract","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The additional number designated by an entity under the program established pursuant to subsection (c) for each covered contract or agreement may not exceed the greater of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d78380-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 percent of the number of security clearances required to be held by covered persons to perform work under the covered contract or agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d78381-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d78382-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on number designated per entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The total additional number designated by an entity under the program established pursuant to subsection (c) may not exceed the greater of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d78383-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 percent of the sum total number of security clearances required to be held by covered persons to perform work under all covered contracts or agreements of the entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d78384-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d78385-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d78386-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No application for a security clearance may be submitted by a covered person of an entity or granted pursuant to the program established under subsection (c) in excess of the limitations under subsection (d) applicable to such entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d78387-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on bearing costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No head of an element of the intelligence community may bear any cost associated with granting or maintaining a security clearance the application for which is submitted pursuant to subsection (c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d78388-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352g/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed as requiring the head of an element of the intelligence community to grant any covered person access to classified information if a favorable determination of eligibility to access such classified information is not made with respect to such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1d78389-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tV/s7505"},"text":"Pub. L. 118–31, div. G, title V, § 7505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1084"},"text":"137 Stat. 1084","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1d7838a-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1d7838b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1d7838c-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order 12968, referred to in subsec. (c)(2)(B), is Ex. Ord. No. 12968, ","children":[{"tag":"date","attrib":{"date":"1995-08-02"},"text":"Aug. 2, 1995","children":[],"tail":", 60 F.R. 40245, which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"text":"section 3161 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Executive Order 10865, referred to in subsec. (c)(2)(B), is Ex. Ord. No. 10865, ","children":[{"tag":"date","attrib":{"date":"1960-02-20"},"text":"Feb. 20, 1960","children":[],"tail":", 25 F.R. 1583, which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"text":"section 3161 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1d7838d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd1d7838e-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “intelligence community” and “congressional intelligence committees” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s7002"},"text":"section 7002 of Pub. L. 118–31","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
