{"tag":"section","attrib":{"id":"idd1d7832e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352d"},"text":null,"children":[{"tag":"num","attrib":{"value":"3352d"},"text":"§ 3352d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports on reciprocity for security clearances inside of departments and agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1d7832f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Security Executive Agent","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of each Federal department or agency shall submit an annual report to the Security Executive Agent that, with respect to the period covered by the report—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d78330-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the number of individuals whose security clearances took more than 2 weeks for reciprocity recognition after such individuals move to another part of such department or agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d78331-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" breaks out the information described in paragraph (1) by type of clearance and the reasons for any delays.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d78332-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less frequently than once each year, the Security Executive Agent shall submit to the appropriate congressional committees and make available to industry partners a report that summarizes the information received pursuant to subsection (b) during the period covered by such report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1d78333-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLXVI/s6608"},"text":"Pub. L. 116–92, div. E, title LXVI, § 6608","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2216"},"text":"133 Stat. 2216","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1d78334-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1d78335-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd1d78336-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Security Executive Agent”, “reciprocity”, and “appropriate congressional committees”, referred to in text, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3352"},"text":"section 3352 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
