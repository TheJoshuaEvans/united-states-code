{"tag":"section","attrib":{"id":"idd2405784-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4582"},"text":null,"children":[{"tag":"num","attrib":{"value":"4582"},"text":"§ 4582.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification on investments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2405785-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4582/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 450 days after ","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"December 18, 2025","children":[],"tail":", the Secretary shall issue regulations prescribed in accordance with subsection (b), to require a United States person that itself or whose controlled foreign entity knowingly engages in a covered national security transaction in a prohibited technology (unless the Secretary has exercised the authority provided by "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4581/a"},"text":"section 4581(a) of this title","children":[],"tail":" to prohibit knowingly engaging in such covered national security transaction) or a notifiable technology to submit to the Secretary a written notification of the transaction not later than 30 days after the completion date of the transaction."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2405786-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4582/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2405787-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4582/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 450 days after ","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"December 18, 2025","children":[],"tail":", the Secretary, in consultation with the Secretary of Commerce, the Secretary of State, and, as appropriate, the heads of other relevant Federal departments and agencies, shall issue regulations to carry out this section subject to public notice and comment in accordance with subchapter II of chapter 5 and chapter 7 of title 5, and not subject to the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4559"},"text":"section 4559 of this title","children":[],"tail":". The regulations issued pursuant to this paragraph shall as necessary, amend, terminate, supersede, revoke, or streamline existing requirements in part 850 of title 31, Code of Federal Regulations (the Outbound Investment Rule) and shall provide a reasonable timeframe for compliance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2405788-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4582/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-burden regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In issuing regulations under paragraph (1), the Secretary should balance the priority of protecting the national security interest of the United States while, to the extent practicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2405789-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4582/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimizing the cost and complexity of compliance for affected parties, including the duplication of reporting requirements under current regulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd240578a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4582/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopting the least burdensome alternative that achieves regulatory objectives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd240578b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4582/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritizing transparency and stakeholder involvement in the process of issuing the rules.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd240578c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4582/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Burden of proof","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s556/d"},"text":"section 556(d) of title 5","children":[],"tail":", in an enforcement action for a violation of the prohibition set forth in subsection (a), the burden of proof shall be upon the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd240578d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4582/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Completeness of notification","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd240578e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4582/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, upon receipt of a notification under subsection (a), promptly inspect the notification for completeness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd240578f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4582/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incomplete notifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a notification submitted under subsection (a) is incomplete, the Secretary shall promptly inform the United States person that submits the notification that the notification is not complete and provide an explanation of relevant material respects in which the notification is not complete.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2405790-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4582/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of non-notified activity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a process to identify covered national security transactions in a prohibited technology or a notifiable technology for which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2405791-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4582/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a notification is not submitted to the Secretary under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2405792-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4582/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information is reasonably available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2405793-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4582/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary prohibits a covered national security transaction in a prohibited technology under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4581"},"text":"section 4581 of this title","children":[],"tail":", the requirements of this section shall not apply with respect to the covered national security transaction."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2405794-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-08/ch932"},"text":"Sept. 8, 1950, ch. 932","children":[],"tail":", title VIII, § 802, as added "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXV/s8521"},"text":"Pub. L. 119–60, div. H, title LXXXV, § 8521","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1925"},"text":"139 Stat. 1925","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
