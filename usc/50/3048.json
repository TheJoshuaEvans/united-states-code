{"tag":"section","attrib":{"id":"idd19bda64-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3048"},"text":null,"children":[{"tag":"num","attrib":{"value":"3048"},"text":"§ 3048.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detail of intelligence community personnel—Intelligence Community Assignment Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd19bda65-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3048/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detail","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd19bda66-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3048/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, the head of a department with an element in the intelligence community or the head of an intelligence community agency or element may detail any employee within that department, agency, or element to serve in any position in the Intelligence Community Assignment Program on a reimbursable or a nonreimbursable basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd19bda67-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3048/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nonreimbursable details may be for such periods as are agreed to between the heads of the parent and host agencies, up to a maximum of three years, except that such details may be extended for a period not to exceed one year when the heads of the parent and host agencies determine that such extension is in the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19bda68-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3048/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits, allowances, travel, incentives","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd19bda69-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3048/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee detailed under subsection (a) may be authorized any benefit, allowance, travel, or incentive otherwise provided to enhance staffing by the organization from which the employee is detailed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd19bda6a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3048/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The head of an agency of an employee detailed under subsection (a) may pay a lodging allowance for the employee subject to the following conditions:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd19bda6b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3048/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The allowance shall be the lesser of the cost of the lodging or a maximum amount payable for the lodging as established jointly by the Director of National Intelligence and—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd19bda6c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3048/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to detailed employees of the Department of Defense, the Secretary of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd19bda6d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3048/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to detailed employees of other agencies and departments, the head of such agency or department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd19bda6e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3048/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The detailed employee maintains a primary residence for the employee’s immediate family in the local commuting area of the parent agency duty station from which the employee regularly commuted to such duty station before the detail.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd19bda6f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3048/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The lodging is within a reasonable proximity of the host agency duty station.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd19bda70-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3048/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The distance between the detailed employee’s parent agency duty station and the host agency duty station is greater than 20 miles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd19bda71-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3048/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The distance between the detailed employee’s primary residence and the host agency duty station is 10 miles greater than the distance between such primary residence and the employees parent duty station.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd19bda72-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3048/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rate of pay applicable to the detailed employee does not exceed the rate of basic pay for grade GS–15 of the General Schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd19bda73-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title I, § 113, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/107/tIII/s303/a"},"text":"Pub. L. 105–107, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-20"},"text":"Nov. 20, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2251"},"text":"111 Stat. 2251","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/108/tIII/s304"},"text":"Pub. L. 107–108, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1398"},"text":"115 Stat. 1398","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/306/tVIII/s841/a"},"text":"Pub. L. 107–306, title VIII, § 841(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2431"},"text":"116 Stat. 2431","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI/s1071/a/1/M"},"text":"Pub. L. 108–458, title I, § 1071(a)(1)(M)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3689"},"text":"118 Stat. 3689","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd19bda74-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd19bda75-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd19bda76-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"GS–15 of the General Schedule, referred to in subsec. (b)(2)(F), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd19bda77-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s404h"},"text":"section 404h of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd19bda78-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" substituted “Director of National Intelligence” for “Director of Central Intelligence” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306"},"text":"Pub. L. 107–306","children":[],"tail":" struck out heading and text of subsec. (c). Text read as follows: “Not later than "},{"tag":"date","attrib":{"date":"1999-03-01"},"text":"March 1, 1999","children":[],"tail":", and annually thereafter, the Director of Central Intelligence shall submit to the Permanent Select Committee on Intelligence of the House of Representatives and the Select Committee on Intelligence of the Senate a report describing the detail of intelligence community personnel pursuant to subsection (a) during the 12-month period ending on the date of the report. The report shall set forth the number of personnel detailed, the identity of parent and host agencies or elements, and an analysis of the benefits of the details.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/108"},"text":"Pub. L. 107–108","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd19bda79-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd19bda7a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For Determination by President that amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" take effect on "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", see Memorandum of President of the United States, "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", 70 F.R. 23925, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" effective not later than six months after "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1097/a"},"text":"section 1097(a) of Pub. L. 108–458","children":[],"tail":", set out in an Effective Date of 2004 Amendment; Transition Provisions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd19bda7b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/107/tIII/s303/d"},"text":"Pub. L. 105–107, title III, § 303(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-20"},"text":"Nov. 20, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2252"},"text":"111 Stat. 2252","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/107/tIII/s303/d"},"text":"“The amendment made by subsection (a) [enacting this section] shall apply to an employee on detail on or after ","children":[{"tag":"date","attrib":{"date":"1997-01-01"},"text":"January 1, 1997","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
