{"tag":"section","attrib":{"id":"idd15de780-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2113"},"text":null,"children":[{"tag":"num","attrib":{"value":"2113"},"text":"§ 2113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reemployment compensation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd15de781-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deduction from basic pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An annuitant who has retired under this subchapter and who is reemployed in the Federal Government service in any appointive position (either on a part-time or full-time basis) shall be entitled to receive the annuity payable under this subchapter, but there shall be deducted from the annuitant’s basic pay a sum equal to the annuity allocable to the period of actual employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15de782-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Part-time reemployed annuitants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall have the authority to reemploy an annuitant on a part-time basis in accordance with section 8344(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of title 5."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15de783-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2113/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of overpayments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event of an overpayment under this section, the amount of the overpayment shall be recovered by withholding the amount involved from the basic pay payable to such reemployed annuitant or from any other moneys, including the annuitant’s annuity, payable in accordance with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15de784-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2113/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit in fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sums deducted from the basic pay of a reemployed annuitant under this section shall be deposited in the Treasury of the United States to the credit of the fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd15de785-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/tII/s273"},"text":"Pub. L. 88–643, title II, § 273","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s802"},"text":"Pub. L. 102–496, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3238"},"text":"106 Stat. 3238","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLXII/s6202/d"},"text":"Pub. L. 116–92, div. E, title LXII, § 6202(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2186"},"text":"133 Stat. 2186","children":[