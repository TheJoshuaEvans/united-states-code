 ","children":[{"tag":"date","attrib":{"date":"2001-11-27"},"text":"Nov. 27, 2001","children":[],"tail":", 66 F.R. 59671, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2141"},"text":"section 2141 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
