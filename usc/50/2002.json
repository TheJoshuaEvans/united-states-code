{"tag":"section","attrib":{"id":"idd154498b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002"},"text":null,"children":[{"tag":"num","attrib":{"value":"2002"},"text":"§ 2002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions relating to participants and annuitants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd154498c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"When used in subchapter II:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd154498d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Former participant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “former participant” means a person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd154498e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while an employee of the Agency was a participant in the system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd154498f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" separates from the Agency without entitlement to immediate receipt of an annuity from the fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1544990-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retired participant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “retired participant” means a person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1544991-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while an employee of the Agency was a participant in the system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1544992-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entitled to receive an annuity from the fund based upon such person’s service as a participant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1544993-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surviving spouse","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1544994-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “surviving spouse” means the surviving wife or husband of a participant or retired participant who (i) was married to the participant or retired participant for at least 9 months immediately preceding the participant’s or retired participant’s death, or (ii) who is the parent of a child born of the marriage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1544995-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment when participant dies less than 9 months after marriage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In a case in which the participant or retired participant dies within the 9-month period beginning on the date of the marriage, the requirement under subparagraph (A)(i) that a marriage have a duration of at least 9 months immediately preceding the death of the participant or retired participant shall be treated as having been met if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1544996-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the death of the participant or retired participant was accidental; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1544997-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the surviving wife or husband had been previously married to the participant or retired participant (and subsequently divorced) and the aggregate time married is at least 9 months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1544998-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Former spouse","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “former spouse” means a former wife or husband of a participant, former participant, or retired participant as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1544999-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Divorces on or before ","children":[{"tag":"date","attrib":{"date":"1991-12-04"},"text":"December 4, 1991","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a divorce that became final on or before ","children":[{"tag":"date","attrib":{"date":"1991-12-04"},"text":"December 4, 1991","children":[],"tail":", such term means a former wife or husband of a participant, former participant, or retired participant who was married to such participant for not less than 10 years during periods of the participant’s creditable service, at least 5 years of which were spent outside the United States by both such participant and former wife or husband during the participant’s service as an employee of the Agency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd154499a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Divorces after ","children":[{"tag":"date","attrib":{"date":"1991-12-04"},"text":"December 4, 1991","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a divorce that becomes final after ","children":[{"tag":"date","attrib":{"date":"1991-12-04"},"text":"December 4, 1991","children":[],"tail":", such term means a former wife or husband of a participant, former participant, or retired participant who was married to such participant for not less than 10 years during periods of the participant’s creditable service, at least 5 years of which were spent by the participant during the participant’s service as an employee of the Agency (i) outside the United States, or (ii) otherwise in a position the duties of which qualified the participant for designation by the Director as a participant under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2013"},"text":"section 2013 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd154499b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creditable service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraphs (A) and (B), the term “creditable service” means all periods of a participant’s service that are creditable under sections 2081, 2082, and 2083 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd154499c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Previous spouse","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “previous spouse” means an individual who was married for at least 9 months to a participant, former participant, or retired participant who had at least 18 months of service which are creditable under sections 2081, 2082, and 2083 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd154499d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spousal agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “spousal agreement” means an agreement between a participant, former participant, or retired participant and the participant, former participant, or retired participant’s spouse or former spouse that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd154499e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in writing, is signed by the parties, and is notarized;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd154499f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not been modified by court order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd15449a0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been authenticated by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15449a1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Court order","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “court order” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd15449a2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a court decree of divorce, annulment, or legal separation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd15449a3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a court order or court-approved property settlement agreement incident to such court decree of divorce, annulment, or legal separation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15449a4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Court","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “court” means a court of a State, the District of Columbia, the Commonwealth of Puerto Rico, Guam, the Northern Mariana Islands, or the Virgin Islands, and any Indian court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15449a5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Child” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of sections 2031 and 2052 of this title:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15449a6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “child” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd15449a7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minor children","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An unmarried dependent child under 18 years of age, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd15449a8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an adopted child;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd15449a9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a stepchild, but only if the stepchild lived with the participant or retired participant in a regular parent-child relationship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd15449aa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a recognized natural child; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd15449ab-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a child who lived with the participant, for whom a petition of adoption was filed by the participant or retired participant, and who is adopted by the surviving spouse after the death of the participant or retired participant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd15449ac-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disabled adult children","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An unmarried dependent child, regardless of age, who is incapable of self-support because of a physical or mental disability incurred before age 18.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd15449ad-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Students","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An unmarried dependent child between 18 and 22 years of age who is a student regularly pursuing a full-time course of study or training in residence in a high school, trade school, technical or vocational institute, junior college, college, university, or comparable recognized educational institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15449ae-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for students","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd15449af-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of age termination of status as “child”","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, a child whose 22nd birthday occurs before July 1 or after August 31 of a calendar year, and while regularly pursuing such a course of study or training, shall be treated as having attained the age of 22 on the first day of July following that birthday.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd15449b0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of interim period between school years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A child who is a student is deemed not to have ceased to be a student during an interim between school years if the interim does not exceed 5 months and if the child shows to the satisfaction of the Director that the child has a bona fide intention of continuing to pursue a course of study or training in the same or different school during the school semester (or other period into which the school year is divided) immediately following the interim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15449b1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Dependent” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “dependent”, with respect to the child of a participant or retired participant, means that the participant or retired participant was, at the time of the death of the participant or retired participant, either living with or contributing to the support of the child, as determined in accordance with regulations prescribed under subchapter II.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15449b2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2002/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of stepchildren from lump-sum payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2071/c"},"text":"section 2071(c) of this title","children":[],"tail":", the term “child” includes an adopted child and a natural child, but does not include a stepchild."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd15449b3-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/tI/s102"},"text":"Pub. L. 88–643, title I, § 102","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s802"},"text":"Pub. L. 102–496, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3198"},"text":"106 Stat. 3198","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd15449b4-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd15449b5-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd15449b6-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/s111"},"text":"section 111 of Pub. L. 88–643","children":[],"tail":", title I, "},{"tag":"date","attrib":{"date":"1964-10-13"},"text":"Oct. 13, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1043"},"text":"78 Stat. 1043","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/522/tI/s101"},"text":"Pub. L. 94–522, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-17"},"text":"Oct. 17, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2467"},"text":"90 Stat. 2467","children":[],"tail":", provided definitions for "},{"tag":"ref","attrib":{"href":"/us/pl/88/643"},"text":"Pub. L. 88–643","children":[],"tail":" and was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403"},"text":"section 403 of this title","children":[],"tail":" prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/88/643"},"text":"Pub. L. 88–643","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s802"},"text":"section 802 of Pub. L. 102–496","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd15449b7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd15449b8-47c4-11f1-8b