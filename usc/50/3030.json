{"tag":"section","attrib":{"id":"idd1923cc1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3030"},"text":null,"children":[{"tag":"num","attrib":{"value":"3030"},"text":"§ 3030.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of Science and Technology","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1923cc2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3030/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of Science and Technology","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is a Director of Science and Technology within the Office of the Director of National Intelligence who shall be appointed by the Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1923cc3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3030/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement relating to appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual appointed as Director of Science and Technology shall have a professional background and experience appropriate for the duties of the Director of Science and Technology. In making such appointment, the Director of National Intelligence may give preference to an individual with experience outside of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1923cc4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3030/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of Science and Technology shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1923cc5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3030/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" act as the chief representative of the Director of National Intelligence for science and technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1923cc6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3030/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chair the Director of National Intelligence Science and Technology Committee under subsection (d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1923cc7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3030/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the Director in formulating a long-term strategy for scientific advances in the field of intelligence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1923cc8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3030/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the Director on the science and technology elements of the budget of the Office of the Director of National Intelligence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1923cc9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3030/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform other such duties as may be prescribed by the Director of National Intelligence or specified by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1923cca-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3030/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of National Intelligence Science and Technology Committee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1923ccb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3030/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is within the Office of the Director of Science and Technology a Director of National Intelligence Science and Technology Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1923ccc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3030/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee shall be composed of the principal science officers of the National Intelligence Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1923ccd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3030/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Committee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1923cce-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3030/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate advances in research and development related to intelligence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1923ccf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3030/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other functions as the Director of Science and Technology shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1923cd0-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title I, § 103E, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI/s1011/a"},"text":"Pub. L. 108–458, title I, § 1011(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3659"},"text":"118 Stat. 3659","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dF/tLXVII/s6703/b"},"text":"Pub. L. 117–263, div. F, title LXVII, § 6703(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3562"},"text":"136 Stat. 3562","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1923cd1-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1923cd2-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1923cd3-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s403–3e"},"text":"section 403–3e of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1923cd4-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" inserted at end “In making such appointment, the Director of National Intelligence may give preference to an individual with experience outside of the United States Government.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1923cd5-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd1923cd6-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For Determination by President that section take effect on ","children":[{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", see Memorandum of President of the United States, "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", 70 F.R. 23925, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section effective not later than six months after ","children":[{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1097/a"},"text":"section 1097(a) of Pub. L. 108–458","children":[],"tail":", set out in an Effective Date of 2004 Amendment; Transition Provisions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1923cd7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Emerging Technology Adoption","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dF/tLXVII/s6703/a"},"text":"Pub. L. 117–263, div. F, title LXVII, § 6703(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3562"},"text":"136 Stat. 3562","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dF/tLXVII/s6703/a"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Director of Science and Technology may—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct reviews of the policies, standards, and procedures of the intelligence community that relate to emerging technologies and, as appropriate, recommend to the Director of National Intelligence changes to such policies, standards, and procedures, to accelerate and increase the adoption of emerging technologies by the intelligence community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations, in coordination with the heads of the elements of the intelligence community, to the Director of National Intelligence with respect to the budgets of such elements, to accelerate and increase the adoption of emerging technologies by such elements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with the Under Secretary of Defense for Research and Engineering on initiatives, policies, and programs carried out jointly between the intelligence community and the Department of Defense to accelerate and increase the adoption of emerging technologies.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “intelligence community” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s6703/a"},"text":"section 6703(a) of Pub. L. 117–263","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s6002"},"text":"section 6002 of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":".]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “emerging technology” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s6703/a"},"text":"section 6703(a) of Pub. L. 117–263","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s6701"},"text":"section 6701 of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3024"},"text":"section 3024 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
