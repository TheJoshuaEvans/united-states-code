{"tag":"section","attrib":{"id":"idd1d05714-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334h"},"text":null,"children":[{"tag":"num","attrib":{"value":"3334h"},"text":"§ 3334h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection on attrition in intelligence community","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1d05715-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards for data collection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d05716-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334h/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Director of National Intelligence shall establish standards for collecting data relating to attrition in the intelligence community workforce across demographics, specialities, and length of service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d05717-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334h/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of certain candidates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall include, in the standards established under paragraph (1), standards for collecting data from candidates who accepted conditional offers of employment but chose to withdraw from the hiring process before entering into service, including data with respect to the reasons such candidates chose to withdraw.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d05718-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", each element of the intelligence community shall begin collecting data on workforce and candidate attrition in accordance with the standards established under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1d05719-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dW/tIII/s306"},"text":"Pub. L. 116–260, div. W, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2367"},"text":"134 Stat. 2367","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dF/tLXIX/s6901/f"},"text":"Pub. L. 118–159, div. F, title LXIX, § 6901(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2517"},"text":"138 Stat. 2517","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1d0571a-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1d0571b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1d0571c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" struck out subsec. (c) which required annual reports to Congress regarding workforce and candidate attrition in the intelligence community."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1d0571d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd1d0571e-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “intelligence community” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dW/s2"},"text":"section 2 of div. W of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
