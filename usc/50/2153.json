{"tag":"section","attrib":{"id":"idd1603121-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2153"},"text":null,"children":[{"tag":"num","attrib":{"value":"2153"},"text":"§ 2153.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for other employees for service abroad","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1603122-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2153/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special computation rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any provision of chapter 84 of title 5, the annuity under subchapter II of such chapter of a retired employee of the Agency who is not designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2152/a"},"text":"section 2152(a) of this title","children":[],"tail":" and who has served abroad as an employee of the Agency after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":", shall be computed as provided in subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1603123-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2153/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1603124-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2153/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service abroad","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The portion of the annuity relating to such service abroad shall be computed as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8415/e"},"text":"section 8415(e) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1603125-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2153/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The portions of the annuity relating to other creditable service shall be computed as provided in section 8415 of such title that is applicable to such service under the conditions prescribed in chapter 84 of such title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1603126-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/tIII/s303"},"text":"Pub. L. 88–643, title III, § 303","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s802"},"text":"Pub. L. 102–496, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3244"},"text":"106 Stat. 3244","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/96/tV/s5001/c/2/G"},"text":"Pub. L. 112–96, title V, § 5001(c)(2)(G)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/200"},"text":"126 Stat. 200","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1603127-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1603128-47c4-11f1-8