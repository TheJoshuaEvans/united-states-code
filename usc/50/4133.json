{"tag":"section","attrib":{"id":"idd21576b4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4133"},"text":null,"children":[{"tag":"num","attrib":{"value":"4133"},"text":"§ 4133.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers and assignments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The transfer or assignment for value of any property forming the subject matter of a claim under subsection (a) or (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4132"},"text":"section 4132 of this title","children":[],"tail":" subsequent to its damage, loss, or destruction shall not operate to extinguish any claim of the transferor otherwise compensable under either of such subsections. If a claim which could otherwise be allowed under subsection (a) or (b) of "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4132"},"text":"section 4132 of this title","children":[],"tail":" has been assigned for value prior to "},{"tag":"date","attrib":{"date":"1962-10-22"},"text":"October 22, 1962","children":[],"tail":", the assignee shall be the party entitled to claim thereunder."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd21576b5-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-07-03/ch826"},"text":"July 3, 1948, ch. 826","children":[],"tail":", title II, § 203, as added "},{"tag":"ref","attrib":{"href":"/us/pl/87/846/tI/s103"},"text":"Pub. L. 87–846, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-22"},"text":"Oct. 22, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1109"},"text":"76 Stat. 1109","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd21576b6-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd21576b7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd21576b8-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 2017b of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
