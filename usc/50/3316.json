{"tag":"section","attrib":{"id":"idd1c92be3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316"},"text":null,"children":[{"tag":"num","attrib":{"value":"3316"},"text":"§ 3316.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of intelligence community policies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1c92be4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c92be5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic repository","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “electronic repository” means the electronic distribution mechanism, in use as of ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", or any successor electronic distribution mechanism, by which the Director of National Intelligence submits to the congressional intelligence committees information."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c92be6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “policy”, with respect to the intelligence community, includes unclassified or classified—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c92be7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directives, policy guidance, and policy memoranda of the intelligence community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c92be8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" executive correspondence of the Director of National Intelligence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c92be9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any equivalent successor policy instruments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c92bea-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of policies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c92beb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Current policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", the Director of National Intelligence shall submit to the congressional intelligence committees using the electronic repository all nonpublicly available policies issued by the Director of National Intelligence for the intelligence community that are in effect as of the date of the submission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c92bec-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuous updates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 15 days after the date on which the Director of National Intelligence issues, modifies, or rescinds a policy of the intelligence community, the Director shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c92bed-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the congressional intelligence committees of such addition, modification, or removal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c92bee-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" update the electronic repository with respect to such addition, modification, or removal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1c92bef-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLXIII/s6315"},"text":"Pub. L. 116–92, div. E, title LXIII, § 6315","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2194"},"text":"133 Stat. 2194","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1c92bf0-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1c92bf1-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd1c92bf2-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “intelligence community” and “congressional intelligence committees” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/s5003"},"text":"section 5003 of div. E of Pub. L. 116–92","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
