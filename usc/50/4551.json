{"tag":"section","attrib":{"id":"idd22d44ea-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4551"},"text":null,"children":[{"tag":"num","attrib":{"value":"4551"},"text":"§ 4551.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small business","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd22d44eb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4551/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Small business concerns shall be given the maximum practicable opportunity to participate as contractors, and subcontractors at various tiers, in all programs to maintain and strengthen the Nation’s industrial base and technology base undertaken pursuant to this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd22d44ec-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4551/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of chapter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In administering the programs, implementing regulations, policies, and procedures under this chapter, requests, applications, or appeals from small business concerns shall, to the maximum extent practicable, be expeditiously handled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd22d44ed-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4551/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory committee participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Representatives of small business concerns shall be afforded the maximum opportunity to participate in such advisory committees as may be established pursuant to this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd22d44ee-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4551/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Information about this chapter and activities undertaken in accordance with this chapter shall be made available to small business concerns.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd22d44ef-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4551/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocations under section 4511","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the President makes a determination to exercise any authority to allocate any material pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4511"},"text":"section 4511 of this title","children":[],"tail":", small business concerns shall be accorded, to the extent practicable, a fair share of such material, in proportion to the share received by such business concerns under normal conditions, giving such special consideration as may be possible to emerging small business concerns."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd22d44f0-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-08/ch932"},"text":"Sept. 8, 1950, ch. 932","children":[],"tail":", title VII, § 701, "},{"tag":"ref","attrib":{"href":"/us/stat/64/815"},"text":"64 Stat. 815","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1951-07-31/ch275"},"text":"July 31, 1951, ch. 275","children":[],"tail":", title I, § 108, "},{"tag":"ref","attrib":{"href":"/us/stat/65/138"},"text":"65 Stat. 138","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1953-06-30/ch171/s7"},"text":"June 30, 1953, ch. 171, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/130"},"text":"67 Stat. 130","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1955-08-09/ch655"},"text":"Aug. 9, 1955, ch. 655","children":[],"tail":", §§ 4, 5, "},{"tag":"ref","attrib":{"href":"/us/stat/69/580"},"text":"69 Stat. 580","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/294/tI/s105/c"},"text":"Pub. L. 96–294, title I, § 105(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/633"},"text":"94 Stat. 633","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/558/tI/s131"},"text":"Pub. L. 102–558, title I, § 131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4209"},"text":"106 Stat. 4209","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd22d44f1-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"idd22d44f2-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4564/a"},"text":"section 4564(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd22d44f3-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd22d44f4-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-08/ch932"},"text":"act Sept. 8, 1950, ch. 932","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/798"},"text":"64 Stat. 798","children":[],"tail":", known as the Defense Production Act of 1950, which is classified principally to this chapter. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4501"},"text":"section 4501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd22d44f5-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 2151 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd22d44f6-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/558"},"text":"Pub. L. 102–558","children":[],"tail":" amended section generally, substituting present provisions for provisions stating policy to encourage small business enterprises and providing for measures to carry out this policy, for allocation of materials in the civilian market, and for distribution of defense contracts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294"},"text":"Pub. L. 96–294","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1955-08-09"},"text":"August 9, 1955","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1955—Subsec. (c). Act ","children":[{"tag":"date","attrib":{"date":"1955-08-09"},"text":"Aug. 9, 1955","children":[],"tail":", § 4, struck out specific dates which were the basis for determination of materials in civilian market and inserted provisions requiring that a business receive its fair share based on a representative period before imposition of the allocation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). Act ","children":[{"tag":"date","attrib":{"date":"1955-08-09"},"text":"Aug. 9, 1955","children":[],"tail":", § 5, added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1953—Subsec. (c). Act ","children":[{"tag":"date","attrib":{"date":"1953-06-30"},"text":"June 30, 1953","children":[],"tail":", amended subsec. (c) generally, the principal change being to provide, in the allocation to business of a fair share of available civilian supply, a new base period for allocating materials not under control on "},{"tag":"date","attrib":{"date":"1953-07-01"},"text":"July 1, 1953","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1951—Subsec. (c). Act ","children":[{"tag":"date","attrib":{"date":"1951-07-31"},"text":"July 31, 1951","children":[],"tail":", provided that limitations and restrictions on production of specific items shall not exclude new concerns."}],"tail":"\n"}],"ta