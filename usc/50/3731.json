{"tag":"section","attrib":{"id":"idd1f67d39-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3731"},"text":null,"children":[{"tag":"num","attrib":{"value":"3731"},"text":"§ 3731.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on use of funds for specified purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1f67d3a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3731/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Cooperative Threat Reduction funds may not be obligated or expended for any of the following purposes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1f67d3b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3731/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conducting any peacekeeping exercise or other peacekeeping-related activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67d3c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3731/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provision of housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67d3d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3731/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provision of assistance to promote environmental restoration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67d3e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3731/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provision of assistance to promote job retraining.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67d3f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3731/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provision of assistance to promote defense conversion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f67d40-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3731/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation with respect to conventional weapons","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Cooperative Threat Reduction funds may not be obligated or expended for the elimination of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1f67d41-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3731/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conventional weapons; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67d42-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3731/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delivery vehicles of conventional weapons, unless such delivery vehicles could reasonably be used or adapted to be used for the delivery of chemical, nuclear, or biological weapons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1f67d43-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tXIII/s1331"},"text":"Pub. L. 113–291, div. A, title XIII, § 1331","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3601"},"text":"128 Stat. 3601","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
