{"tag":"section","attrib":{"id":"idd15904ce-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2034"},"text":null,"children":[{"tag":"num","attrib":{"value":"2034"},"text":"§ 2034.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survivor annuity for certain other former spouses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd15904cf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2034/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survivor annuity","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15904d0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2034/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual who was a former spouse of a participant or retired participant on ","children":[{"tag":"date","attrib":{"date":"1982-11-15"},"text":"November 15, 1982","children":[],"tail":", shall be entitled, except to the extent such former spouse is disqualified under subsection (b), to a survivor annuity equal to 55 percent of the greater of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd15904d1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2034/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the unreduced amount of the participant’s or retired participant’s annuity, as computed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2031/a"},"text":"section 2031(a) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd15904d2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2034/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the unreduced amount of what such annuity as so computed would be if the participant, former participant, or retired participant had not elected payment of the lump-sum credit under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2143"},"text":"section 2143 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15904d3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2034/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction in survivor annuity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A survivor annuity payable under this section shall be reduced by an amount equal to any survivor annuity payments made to the former spouse under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2033"},"text":"section 2033 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15904d4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2034/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A former spouse is not entitled to a survivor annuity under this section if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15904d5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2034/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the former spouse remarries before age 55, except that the entitlement of the former spouse to such a survivor annuity shall be restored on the date such remarriage is dissolved by death, annulment, or divorce; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15904d6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2034/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the former spouse is less than 50 years of age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15904d7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2034/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement and termination of annuity","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15904d8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2034/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement of annuity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The entitlement of a former spouse to a survivor annuity under this section shall commence—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd15904d9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2034/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a former spouse of a participant or retired participant who is deceased as of ","children":[{"tag":"date","attrib":{"date":"1986-10-01"},"text":"October 1, 1986","children":[],"tail":", beginning on the later of—"}],"tail":null},{"tag":"clause","attrib":{"id":"idd15904da-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2034/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 60th day after such date; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd15904db-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2034/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the former spouse reaches age 50; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd15904dc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2034/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of any other former spouse, beginning on the latest of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd15904dd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2034/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the participant or retired participant to whom the former spouse was married dies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd15904de-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2034/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 60th day after ","children":[{"tag":"date","attrib":{"date":"1986-10-01"},"text":"October 1, 1986","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd15904df-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2034/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the former spouse attains age 50.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15904e0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2034/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of annuity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The entitlement of a former spouse to a survivor annuity under this section terminates on the last day of the month before the former spouse’s death or remarriage before attaining age 55. The entitlement of a former spouse to such a survivor annuity shall be restored on the date such remarriage is dissolved by death, annulment, or divorce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15904e1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2034/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15904e2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2034/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time limit; waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A survivor annuity under this section shall not be payable unless appropriate written application is provided to the Director, complete with any supporting documentation which the Director may by regulation require. Any such application shall be submitted not later than ","children":[{"tag":"date","attrib":{"date":"1989-04-01"},"text":"April 1, 1989","children":[],"tail":". The Director may waive the application deadline under the preceding sentence in any case in which the Director determines that the circumstances warrant such a waiver."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15904e3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2034/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retroactive benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon approval of an application provided under paragraph (1), the appropriate survivor annuity shall be payable to the former spouse with respect to all periods before such approval during which the former spouse was entitled to such annuity under this section, but in no event shall a survivor annuity be payable under this section with respect to any period before ","children":[{"tag":"date","attrib":{"date":"1986-10-01"},"text":"October 1, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15904e4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2034/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restoration of annuity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (d)(1), the deadline by which an application for a survivor annuity must be submitted shall not apply in cases in which a former spouse’s entitlement to such a survivor annuity is restored under subsection (b)(1) or (c)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd15904e5-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/tII/s224"},"text":"Pub. L. 88–643, title II, § 224","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s802"},"text":"Pub. L. 102–496, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3217"},"text":"106 Stat. 3217","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/178/tII/s202/a/6"},"text":"Pub. L. 103–178, title II, § 202(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2026"},"text":"107 Stat. 2026","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd15904e6-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd15904e7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd15904e8-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/s224"},"text":"section 224 of Pub. L. 88–643","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/569/tIII/s302/a"},"text":"Pub. L. 99–569, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3192"},"text":"100 Stat. 3192","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/453/tIII/s302/b/1"},"text":"Pub. L. 100–453, title III, § 302(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1907"},"text":"102 Stat. 1907","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/193/tIII/s304/a"},"text":"Pub. L. 101–193, title III, § 304(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-30"},"text":"Nov. 30, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1703"},"text":"103 Stat. 1703","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/88/tIII/s307/a"},"text":"Pub. L. 102–88, title III, § 307(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/432"},"text":"105 Stat. 432","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/183/tIII/s304"},"text":"Pub. L. 102–183, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-04"},"text":"Dec. 4, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1264"},"text":"105 Stat. 1264","children":[],"tail":", related to survivor annuities for certain other former spouses and was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403"},"text":"section 403 of this title","children":[],"tail":" prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/88/643"},"text":"Pub. L. 88–643","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s802"},"text":"section 802 of Pub. L. 102–496","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd15904e9-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (c)(1)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/178"},"text":"Pub. L. 103–178","children":[],"tail":" substituted “retired participant” for “former participant”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd15904ea-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd15904eb-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/178"},"text":"Pub. L. 103–178","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-02-01"},"text":"Feb. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/178/s202/b"},"text":"section 202(b) of Pub. L. 103–178","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd15904ec-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of fourth month beginning after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s805"},"text":"section 805 of Pub. L. 102–496","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
