{"tag":"section","attrib":{"id":"idd249f489-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801"},"text":null,"children":[{"tag":"num","attrib":{"value":"4801"},"text":"§ 4801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd249f48a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controlled","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “controlled” refers to an item subject to the jurisdiction of the United States under subchapter I.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd249f48b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dual-use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “dual-use”, with respect to an item, means the item has civilian applications and military, terrorism, weapons of mass destruction, or law-enforcement-related applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd249f48c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Export","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “export”, with respect to an item subject to controls under subchapter I, includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd249f48d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the shipment or transmission of the item out of the United States, including the sending or taking of the item out of the United States, in any manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd249f48e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the release or transfer of technology or source code relating to the item to a foreign person in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd249f48f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Export Administration Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Export Administration Regulations” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd249f490-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Export Administration Regulations as promulgated, maintained, and amended under the authority of the International Emergency Economic Powers Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" et seq.] and codified, as of "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"August 13, 2018","children":[],"tail":", in subchapter C of chapter VII of title 15, Code of Federal Regulations; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd249f491-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulations that are promulgated, maintained, and amended under the authority of subchapter I on or after ","children":[{"tag":"date","attrib":{"date":"2018-08-13"},"text":"August 13, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd249f492-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “foreign person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd249f493-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any natural person who is not a lawful permanent resident of the United States, citizen of the United States, or any other protected individual (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1324b/a/3"},"text":"section 1324b(a)(3) of title 8","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd249f494-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any corporation, business association, partnership, trust, society or any other entity or group that is not incorporated in the United States or organized to do business in the United States, as well as international organizations, foreign governments and any agency or subdivision of a foreign government (e.g., diplomatic mission).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd249f495-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In-country transfer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “in-country transfer”, with respect to an item subject to controls under subchapter I, means a change in the end-use or end user of the item within the same foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd249f496-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Item","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “item” means a commodity, software, or technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd249f497-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd249f498-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a natural person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd249f499-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation, business association, partnership, society, trust, financial institution, insurer, underwriter, guarantor, and any other business organization, any other nongovernmental entity, organization, or group, or any government or agency thereof; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd249f49a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any successor to any entity described in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd249f49b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reexport","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “reexport”, with respect to an item subject to controls under subchapter I, includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd249f49c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the shipment or transmission of the item from a foreign country to another foreign country, including the sending or taking of the item from the foreign country to the other foreign country, in any manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd249f49d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the release or transfer of technology or source code relating to the item to a foreign person outside the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd249f49e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided, the term “Secretary” means the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd249f49f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technology","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “technology” includes information, in tangible or intangible form, necessary for the development, production, or use of an item.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd249f4a0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States” means the several States, the District of Columbia, the Commonwealth of Puerto Rico, the Commonwealth of the Northern Mariana Islands, American Samoa, Guam, the United States Virgin Islands, and any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd249f4a1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “United States person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd249f4a2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for purposes of subchapter I—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd249f4a3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/13/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual who is a citizen or national of the United States or who is an individual described in subparagraph (B) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1324b/a/3"},"text":"section 1324b(a)(3) of title 8","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd249f4a4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/13/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation or other legal entity which is organized under the laws of the United States, any State or territory thereof, or the District of Columbia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd249f4a5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/13/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person in the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd249f4a6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of subchapter II, any United States resident or national (other than an individual resident outside the United States and employed by other than a United States person), any domestic concern (including any permanent domestic establishment of any foreign concern) and any foreign subsidiary or affiliate (including any permanent foreign establishment) of any domestic concern which is controlled in fact by such domestic concern, as determined under regulations by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd249f4a7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4801/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Weapons of mass destruction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “weapons of mass destruction” means nuclear, radiological, chemical, and biological weapons and delivery systems for such weapons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd249f4a8-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVII/s1742"},"text":"Pub. L. 115–232, div. A, title XVII, § 1742","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2208"},"text":"132 Stat. 2208","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd249f4a9-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd249f4aa-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd249f4ab-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this subtitle”, meaning subtitle B (§§ 1741–1781) of title XVII of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2208"},"text":"132 Stat. 2208","children":[],"tail":", known as the Export Control Reform Act of 2018, which is classified principally to this chapter. For complete classification of subtitle B to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s1741"},"text":"section 1741 of Pub. L. 115–232","children":[],"tail":", set out as a Short Title note below and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subchapter I, referred to in pars. (1), (3), (4)(B), (6), (9), and (13)(A), was in the original “part I”, meaning part I (§§ 1751–1768) of subtitle B of title XVII of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":", known as the Export Controls Act of 2018, which is classified principally to subchapter I of this chapter. For complete classification of part I to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s1751"},"text":"section 1751 of Pub. L. 115–232","children":[],"tail":", set out as a Short Title note below and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The International Emergency Economic Powers Act, referred to in par. (4)(A), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/223"},"text":"Pub. L. 95–223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-28"},"text":"Dec. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1626"},"text":"91 Stat. 1626","children":[],"tail":", which is classified generally to chapter 35 (§ 1701 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd249f4ac-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idd249f4ad-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/34/s1"},"text":"Pub. L. 119–34, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-08-19"},"text":"Aug. 19, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/488"},"text":"139 Stat. 488","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/34/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4815"},"text":"section 4815 of this title","children":[],"tail":"] may be cited as the ‘Maintaining American Superiority by Improving Export Control Transparency Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idd249f4ae-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVII/s1741"},"text":"Pub. L. 115–232, div. A, title XVII, § 1741","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2208"},"text":"132 Stat. 2208","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/232/dA/tXVII/s1741"},"text":"“This subtitle [subtitle B (§§ 1741–1781) of title XVII of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":", enacting this chapter, amending "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of Title 5","children":[],"tail":", Government Organization and Employees, and "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2516"},"text":"section 2516 of Title 18","children":[],"tail":", Crimes and Criminal Procedure, repealing sections 4601 to 4610 and 4614 to 4623 of this title, enacting provisions set out as notes under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4601"},"text":"section 4601 of this title","children":[],"tail":", and repealing provisions set out as notes under sections 4601, 4606, and 4609 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3108"},"text":"section 3108 of Title 22","children":[],"tail":", Foreign Relations and Intercourse] may be cited as the ‘Export Control Reform Act of 2018’.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVII/s1751"},"text":"Pub. L. 115–232, div. A, title XVII, § 1751","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2209"},"text":"132 Stat. 2209","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/232/dA/tXVII/s1751"},"text":"“This part [part I (§§ 1751–1768) of subtitle B of title XVII of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":", enacting subchapter I of this chapter, amending "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2516"},"text":"section 2516 of Title 18","children":[],"tail":", Crimes and Criminal Procedure, repealing sections 4601 to 4610 and 4614 to 4623 of this title, enacting provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4601"},"text":"section 4601 of this title","children":[],"tail":", and repealing provisions set out as notes under sections 4601, 4606, and 4609 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3108"},"text":"section 3108 of Title 22","children":[],"tail":", Foreign Relations and Intercourse] may be cited as the ‘Export Controls Act of 2018’.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVII/s1771"},"text":"Pub. L. 115–232, div. A, title XVII, § 1771","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2234"},"text":"132 Stat. 2234","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/232/dA/tXVII/s1771"},"text":"“This part [part II (§§ 1771–1774) of subtitle B of title XVII of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":", enacting subchapter II of this chapter] may be cited as the ‘Anti-Boycott Act of 2018’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
