{"tag":"section","attrib":{"id":"idd16e88aa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2461"},"text":null,"children":[{"tag":"num","attrib":{"value":"2461"},"text":"§ 2461.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental protection, safety, and health requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd16e88ab-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2461/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall ensure that the Administration complies with all applicable environmental, safety, and health statutes and substantive requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16e88ac-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2461/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall develop procedures for meeting such requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16e88ad-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2461/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall diminish the authority of the Secretary of Energy to ascertain and ensure that such compliance occurs.","children":[],"tail":"\n"}],"tail":"\n