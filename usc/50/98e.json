:"60 Stat. 598","children":[],"tail":"; Ex. Ord. No. 9809, eff. "},{"tag":"date","attrib":{"date":"1946-12-12"},"text":"Dec. 12, 1946","children":[],"tail":", 11 F.R. 14281; Ex. Ord. No. 9841, eff. "},{"tag":"date","attrib":{"date":"1947-04-23"},"text":"Apr. 23, 1947","children":[],"tail":", 12 F.R. 2645; "},{"tag":"ref","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title I, § 105, "},{"tag":"ref","attrib":{"href":"/us/stat/63/381"},"text":"63 Stat. 381","children":[],"tail":"; 1953 Reorg. Plan No. 3, § 2(b), eff. "},{"tag":"date","attrib":{"date":"1953-06-12"},"text":"June 12, 1953","children":[],"tail":", 18 F.R. 3375, "},{"tag":"ref","attrib":{"href":"/us/stat/67/634"},"text":"67 Stat. 634","children":[],"tail":"; 1958 Reorg. Plan No. 1, § 2, eff. "},{"tag":"date","attrib":{"date":"1958-07-01"},"text":"July 1, 1958","children":[],"tail":", 23 F.R. 4991, "},{"tag":"ref","attrib":{"href":"/us/stat/72/1799"},"text":"72 Stat. 1799","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1968-10-21"},"text":"Oct. 21, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/90/608/s402"},"text":"Pub. L. 90–608, § 402","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1194"},"text":"82 Stat. 1194","children":[],"tail":"; Ex. Ord. No. 11725, § 3, eff. "},{"tag":"date","attrib":{"date":"1973-06-29"},"text":"June 29, 1973","children":[],"tail":", 38 F.R. 17175, related to transfer of surplus materials to stock piles, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/96/41/s2/a"},"text":"section 2(a) of Pub. L. 96–41","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s98c/b"},"text":"section 98c(b) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s98b"},"text":"section 98b of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/96/41"},"text":"Pub. L. 96–41","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd0edbfc3-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1411/b/2/A"},"text":"Pub. L. 119–60, § 1411(b)(2)(A)","children":[],"tail":", substituted “National Defense Stockpile Manager” for “President” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1411/b/2/B"},"text":"Pub. L. 119–60, § 1411(b)(2)(B)","children":[],"tail":", amended par. (7) generally. Prior to amendment, par. (7) read as follows: “subject to the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s98d/b"},"text":"section 98d(b) of this title","children":[],"tail":", dispose of materials in the stockpile the disposal of which is specifically authorized by law.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1411/c"},"text":"Pub. L. 119–60, § 1411(c)","children":[],"tail":", substituted “30 days” for “45 days” in pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1411/b/1"},"text":"Pub. L. 118–31, § 1411(b)(1)","children":[],"tail":", substituted “from other Federal agencies, either directly as materials or embedded in excess-to-need, end-of-life items, or waste streams;” for “from excess materials made available for recovery purposes by other Federal agencies;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1411/b/2"},"text":"Pub. L. 118–31, § 1411(b)(2)","children":[],"tail":", substituted “subsection (a)(6) or (a)(7)” for “subsection (a)(5) or (a)(6)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1411/b/3"},"text":"Pub. L. 118–31, § 1411(b)(3)","children":[],"tail":", substituted “subsection (a)(6)” for “subsection (a)(5)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1411/b/4"},"text":"Pub. L. 118–31, § 1411(b)(4)","children":[],"tail":", added subsecs. (g) and (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1411/1"},"text":"Pub. L. 117–81, § 1411(1)","children":[],"tail":", inserted “to consult with producers and processors of such materials” before “to avoid”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1412"},"text":"Pub. L. 117–81, § 1412","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a)(5) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66"},"text":"Pub. L. 113–66","children":[],"tail":" added par. (5) and redesignated former pars. (5) and (6) as (6) and (7), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “and the Committee on Armed Services” for “and the Committee on National Security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":", in first sentence, substituted “strategic and critical materials from the stockpile shall be made in accordance with the next sentence” for “materials from the stockpile shall be made by formal advertising or competitive negotiation procedures”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s3312/b"},"text":"Pub. L. 104–201, § 3312(b)","children":[],"tail":", substituted “45 days” for “thirty days”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s1502/e/1/A"},"text":"Pub. L. 104–106, § 1502(e)(1)(A)","children":[],"tail":", substituted “Committee on Armed Services of the Senate and the Committee on National Security of the House of Representatives” for “Committees on Armed Services of the Senate and House of Representatives”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s3312/c"},"text":"Pub. L. 104–201, § 3312(c)","children":[],"tail":", substituted “45 days” for “thirty days”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s1502/e/1/B"},"text":"Pub. L. 104–106, § 1502(e)(1)(B)","children":[],"tail":", substituted “such congressional committees” for “the Committees on Armed Services of the Senate and House of Representatives”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" inserted “or technological obsolescence” after “deterioration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" inserted before semicolon “or better material”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s3301/b/1"},"text":"Pub. L. 101–510, § 3301(b)(1)","children":[],"tail":", substituted “upgrading, refining,” for “refining”, inserted “(notwithstanding any intermediate stockpile quantity established for such material)” after “stockpile”, and substituted “storage, subsequent disposition, and immediate use in a national emergency” for “storage and subsequent disposition”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s3301/b/2"},"text":"Pub. L. 101–510, § 3301(b)(2)","children":[],"tail":", inserted “under subsection (a)(1)” after “the acquisition” and “under subsection (a)(5) or (a)(6)” after “the disposal”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s3301/b/3"},"text":"Pub. L. 101–510, § 3301(b)(3)","children":[],"tail":", substituted “(the disposition of which is authorized by paragraph (3) to finance the upgrading, refining, or processing of a material in the stockpile, or is otherwise authorized by law)” for “, the disposition of which is authorized by law,” and “of upgrading, refining” for “of refining”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s3301/a"},"text":"Pub. L. 101–510, § 3301(a)","children":[],"tail":", added par. (3) and redesignated former par. (3) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s3314/1"},"text":"Pub. L. 101–189, § 3314(1)","children":[],"tail":", inserted “and” at end of par. (1), substituted a period for “; and” at end of par. (2), and struck out par. (3) which read as follows: “disposal of such materials shall be made for domestic consumption.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s3314/2"},"text":"Pub. L. 101–189, § 3314(2)","children":[],"tail":", substituted “paragraph (1) or (2)” for “paragraph (1), (2), or (3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661"},"text":"Pub. L. 99–661","children":[],"tail":" substituted “a form more” for “the form most”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" inserted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s98d/b"},"text":"section 98d(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd0edbfc4-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd0edbfc5-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Recycling for Critical Minerals","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXIV/s1412"},"text":"Pub. L. 119–60, div. A, title XIV, § 1412","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1135"},"text":"139 Stat. 1135","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tXIV/s1412"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Under Secretary of Defense for Acquisition and Sustainment, in coordination with the Director of the Defense Logistics Agency, shall expand the recovery and reuse of strategic and critical materials under the Strategic Material Recovery and Reuse Program of the Defense Logistics Agency established pursuant to section 6(a)(5) of the Strategic and Critical Materials Stock Piling Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s98e/a/5"},"text":"50 U.S.C. 98e(a)(5)","children":[],"tail":") (in this section referred to as the ‘Program’)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefing on Expansion","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2026-03-01"},"text":"March 1, 2026","children":[],"tail":", the Director of the Defense Logistics Agency shall provide to the Committees on Armed Services of the Senate and House of Representatives a briefing on a plan for expansion of the Program which shall include—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of strategic and critical materials that are determined to be in shortfall in the National Defense Stockpile in the most recent report on stockpile requirements submitted to Congress under section 14(a) of the Strategic and Critical Materials Stock Piling Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s98h–5/a"},"text":"50 U.S.C. 98h–5(a)","children":[],"tail":") that will be prioritized for inclusion in the Program;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of resources required to include the additional strategic and critical materials identified under paragraph (1) in the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any barriers to expansion of the Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" best practices from the efforts of the Director under the Program with respect to optical-grade germanium that can be implemented to expand the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Strategic and Critical Materials Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘strategic and critical materials’ means materials determined to be strategic and critical materials under section 3(a) of the Strategic and Critical Materials Stock Piling Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s98b/a"},"text":"50 U.S.C. 98b(a)","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd0edbfc6-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Acquisition of Depleted Uranium for National Defense Stockpile","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/511/tVIII/s8095"},"text":"Pub. L. 101–511, title VIII, § 8095","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1896"},"text":"104 Stat. 1896","children":[],"tail":", directed President, using funds available in National Defense Stockpile Transaction Fund, to acquire over a period of ten years from current domestic sources not less than thirty-six million pounds of depleted uranium to be held in National Defense Stockpile, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/172/tVIII/s8027A"},"text":"Pub. L. 102–172, title VIII, § 8027A","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-26"},"text":"Nov. 26, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1177"},"text":"105 Stat. 1177","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idd0edbfc7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"idd0edbfc8-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under this section delegated to Secretary of Defense by section 1 of Ex. Ord. No. 12636, ","children":[{"tag":"date","attrib":{"date":"1988-02-25"},"text":"Feb. 25, 1988","children":[],"tail":", 53 F.R. 6114, set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s98"},"text":"section 98 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
