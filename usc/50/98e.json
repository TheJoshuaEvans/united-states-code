{"tag":"section","attrib":{"id":"idd0eb75a5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e"},"text":null,"children":[{"tag":"num","attrib":{"value":"98e"},"text":"§ 98e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stockpile management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd0eb75a6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential powers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Defense Stockpile Manager shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0eb75a7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire the materials determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s98b/a"},"text":"section 98b(a) of this title","children":[],"tail":" to be strategic and critical materials;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0eb75a8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the proper storage, security, and maintenance of materials in the stockpile;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0eb75a9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the upgrading, refining, or processing of any material in the stockpile (notwithstanding any intermediate stockpile quantity established for such material) when necessary to convert such material into a form more suitable for storage, subsequent disposition, and immediate use in a national emergency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0eb75aa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the rotation of any material in the stockpile when necessary to prevent deterioration or technological obsolescence of such material by replacement of such material with an equivalent quantity of substantially the same material or better material;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0eb75ab-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the appropriate recovery of any strategic and critical materials under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s98b/a"},"text":"section 98b(a) of this title","children":[],"tail":" that may be available from other Federal agencies, either directly as materials or embedded in excess-to-need, end-of-life items, or waste streams;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0eb75ac-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the notification required by subsection (d)(2), provide for the timely disposal of materials in the stockpile that (A) are excess to stockpile requirements, and (B) may cause a loss to the Government if allowed to deteriorate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0eb75ad-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dispose of materials in the stockpile in accordance with the most recent annual materials plan submitted to the congressional defense committees (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a"},"text":"section 101(a) of title 10","children":[],"tail":") under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s98h–2/b/1/G"},"text":"section 98h–2(b)(1)(G) of this title","children":[],"tail":" and notify the congressional defense committees of such disposals as required by "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s98d/b/2"},"text":"section 98d(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0eb75ae-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal procurement practices","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsections (c) and (d), acquisition of strategic and critical materials under this subchapter shall be made in accordance with established Federal procurement practices, and, except as provided in subsections (c) and (d) and in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s98f/a"},"text":"section 98f(a) of this title","children":[],"tail":", disposal of strategic and critical materials from the stockpile shall be made in accordance with the next sentence. To the maximum extent feasible—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0eb75af-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" competitive procedures shall be used in the acquisition and disposal of such materials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0eb75b0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts shall be made in the acquisition and disposal of such materials to consult with producers and processors of such materials to avoid undue disruption of the usual markets of producers, processors, and consumers of such materials and to protect the United States against avoidable loss.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0eb75b1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Barter; use of stockpile materials as payment for expenses of acquiring, refining, processing, or rotating materials","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0eb75b2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall encourage the use of barter in the acquisition under subsection (a)(1) of strategic and critical materials for, and the disposal under subsection (a)(6) or (a)(7) of materials from, the stockpile when acquisition or disposal by barter is authorized by law and is practical and in the best interest of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0eb75b3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Materials in the stockpile (the disposition of which is authorized by paragraph (3) to finance the upgrading, refining, or processing of a material in the stockpile, or is otherwise authorized by law) shall be available for transfer at fair market value as payment for expenses (including transportation and other incidental expenses) of acquisition of materials, or of upgrading, refining, processing, or rotating materials, under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0eb75b4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s98b/c"},"text":"section 98b(c) of this title","children":[],"tail":" or any other provision of law, whenever the President provides under subsection (a)(3) for the upgrading, refining, or processing of a material in the stockpile to convert that material into a form more suitable for storage, subsequent disposition, and immediate use in a national emergency, the President may barter a portion of the same material (or any other material in the stockpile that is authorized for disposal) to finance that upgrading, refining, or processing."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0eb75b5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent otherwise authorized by law, property owned by the United States may be bartered for materials needed for the stockpile.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0eb75b6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver; notification of proposed disposal of materials","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0eb75b7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may waive the applicability of any provision of the first sentence of subsection (b) to any acquisition of material for, or disposal of material from, the stockpile. Whenever the President waives any such provision with respect to any such acquisition or disposal, or whenever the President determines that the application of paragraph (1) or (2) of such subsection to a particular acquisition or disposal is not feasible, the President shall notify the Committee on Armed Services of the Senate and the Committee on Armed Services of the House of Representatives in writing of the proposed acquisition or disposal at least 30 days before any obligation of the United States is incurred in connection with such acquisition or disposal and shall include in such notification the reasons for not complying with any provision of such subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0eb75b8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Materials in the stockpile may be disposed of under subsection (a)(6) only if such congressional committees are notified in writing of the proposed disposal at least 30 days before any obligation of the United States is incurred in connection with such disposal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0eb75b9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leasehold interests in property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may acquire leasehold interests in property, for periods not in excess of twenty years, for storage, security, and maintenance of materials in the stockpile.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0eb75ba-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan of stockpile materials","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may loan stockpile materials to the Department of Energy or the military departments if the President—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0eb75bb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a reasonable assurance that stockpile materials of a similar or superior quantity and quality to the materials loaned will be returned to the stockpile or paid for;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0eb75bc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notifies the congressional defense committees (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a"},"text":"section 101(a) of title 10","children":[],"tail":"), in writing, not less than 30 days before making any such loan; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0eb75bd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes in the written notification under paragraph (2) sufficient support for the assurance described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0eb75be-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program to use commercial best practices in acquiring and disposing of strategic and critical materials","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0eb75bf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Defense Stockpile Manager shall establish a pilot program to use, to the maximum extent practicable, commercial best practices in the acquisition and disposal of strategic and critical materials for the stockpile.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0eb75c0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd0eb75c1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Stockpile Manager shall brief the congressional defense committees (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a"},"text":"section 101(a) of title 10","children":[],"tail":")—"}],"tail":null},{"tag":"clause","attrib":{"id":"idd0eb75c2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/g/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as soon as practicable after the establishment of the pilot program under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd0eb75c3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/g/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annually thereafter until the termination of the pilot program under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0eb75c4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The briefing required by subparagraph (A)(i) shall address—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd0eb75c5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/g/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the commercial best practices selected for use under the pilot program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd0eb75c6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/g/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the Stockpile Manager determined which commercial best practices to select; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd0eb75c7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/g/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan of the Stockpile Manager for using such practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0eb75c8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each briefing required by subparagraph (A)(ii) shall provide a summary of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd0eb75c9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/g/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the Stockpile Manager has used commercial best practices under the pilot program during the year preceding the briefing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd0eb75ca-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/g/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how many times the Stockpile Manager has used such practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd0eb75cb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/g/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the outcome of each use of such practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd0eb75cc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/g/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any savings achieved or lessons learned as a result of the use of such practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0eb75cd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The pilot program established under paragraph (1) shall terminate effective on the date that is 5 years after ","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"December 22, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0eb75ce-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98e/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ensuring programs achieve positive cash flow","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except to the extent necessary for the national defense, the National Defense Stockpile Manager shall ensure that each program for the recovery of strategic and critical materials implemented under subsection (a)(5) operates in a manner designed to achieve positive cash flow.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd0edbfbf-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-06-07/ch190/s6"},"text":"June 7, 1939, ch. 190, § 6","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/41/s2/a"},"text":"Pub. L. 96–41, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-30"},"text":"July 30, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/321"},"text":"93 Stat. 321","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tII/s203/c"},"text":"Pub. L. 97–35, title II, § 203(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/382"},"text":"95 Stat. 382","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dC/tII/s3207/b"},"text":"Pub. L. 99–661, div. C, title II, § 3207(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4069"},"text":"100 Stat. 4069","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dC/tXXXIII/s3314"},"text":"Pub. L. 101–189, div. C, title XXXIII, § 3314","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1688"},"text":"103 Stat. 1688","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dC/tXXXIII/s3301/a"},"text":"Pub. L. 101–510, div. C, title XXXIII, § 3301(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1844"},"text":"104 Stat. 1844","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dC/tXXXIII/s3312"},"text":"Pub. L. 102–190, div. C, title XXXIII, § 3312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1584"},"text":"105 Stat. 1584","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dC/tXXXIII/s3302"},"text":"Pub. L. 103–337, div. C, title XXXIII, § 3302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3098"},"text":"108 Stat. 3098","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/