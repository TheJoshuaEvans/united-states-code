{"tag":"section","attrib":{"id":"idd1675c33-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2361"},"text":null,"children":[{"tag":"num","attrib":{"value":"2361"},"text":"§ 2361.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress concerning contracting policy","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that the Secretary of Defense, the Secretary of Energy, the Secretary of the Treasury, and the Secretary of State, to the extent authorized by law, should—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1675c34-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2361/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contract directly with suppliers in independent states of the former Soviet Union when such action would—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1675c35-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2361/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" result in significant savings of the programs referred to in subchapter III; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1675c36-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2361/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantially expedite completion of the programs referred to in subchapter III; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1675c37-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2361/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek means to use innovative contracting approaches to avoid delay and increase the effectiveness of such programs and of the exercise of such authorities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1675c38-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXIV/s1451"},"text":"Pub. L. 104–201, div. A, title XIV, § 1451","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2730"},"text":"110 Stat. 2730","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
