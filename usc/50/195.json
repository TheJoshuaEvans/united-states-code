{"tag":"section","attrib":{"id":"idd0f9a675-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s195"},"text":null,"children":[{"tag":"num","attrib":{"value":"195"},"text":"§ 195.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this Act:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0f9a676-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s195/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"United states","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “United States” includes all territory and waters, continental or insular, subject to the jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f9a677-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s195/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Territorial waters","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “territorial waters of the United States” includes all waters of the territorial sea of the United States as described in Presidential Proclamation 5928 of ","children":[{"tag":"date","attrib":{"date":"1988-12-27"},"text":"December 27, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd0f9a678-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-06-15/ch30"},"text":"June 15, 1917, ch. 30","children":[],"tail":", title XIII, § 1, "},{"tag":"ref","attrib":{"href":"/us/stat/40/231"},"text":"40 Stat. 231","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/70/tIII/s3302/b"},"text":"Pub. L. 96–70, title III, § 3302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/498"},"text":"93 Stat. 498","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/295/tI/s104/a"},"text":"Pub. L. 107–295, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2085"},"text":"116 Stat. 2085","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd0f9a679-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd0f9a67a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd0f9a67b-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, means ","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-06-15/ch30"},"text":"act June 15, 1917, ch. 30","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/217"},"text":"40 Stat. 217","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Presidential Proclamation 5928 of ","children":[{"tag":"date","attrib":{"date":"1988-12-27"},"text":"December 27, 1988","children":[],"tail":", referred to in par. (2), is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1331"},"text":"section 1331 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd0f9a67c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s40"},"text":"section 40 of this title","children":[],"tail":". In the original this section defined “United States” as used in act "},{"tag":"date","attrib":{"date":"1917-06-15"},"text":"June 15, 1917","children":[],"tail":". Other provisions of that act were contained in sections 31 to 42 of this title and certain sections of former Title 18, Criminal Code and Criminal Procedure. The definition of “United States” as used in present provisions derived from those former sections is covered by "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s5"},"text":"section 5 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd0f9a67d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295"},"text":"Pub. L. 107–295","children":[],"tail":" added introductory provisions, designated existing provisions as par. (1), inserted heading, struck out “as used in this Act” before “includes”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70"},"text":"Pub. L. 96–70","children":[],"tail":" struck out “the Canal Zone and” after “this Act includes”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd0f9a67e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd0f9a67f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70"},"text":"Pub. L. 96–70","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/70/s3304"},"text":"section 3304 of Pub. L. 96–70","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3601"},"text":"section 3601 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"separability","id":"idd0f9a680-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Separability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1917-06-15/ch30/tXIII/s4"},"text":"Act June 15, 1917, ch. 30, title XIII, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/231"},"text":"40 Stat. 231","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1917-06-15/ch30/tXIII/s4"},"text":"“If any clause, sentence, paragraph, or part of this Act [see Tables for classification] shall for any reason be adjudged by any court of competent jurisdiction to be invalid, such judgment shall not affect, impair, or invalidate the remainder thereof but shall be confined in its operation to the clause, sentence, paragraph, or part thereof directly involved in the controversy in which such judgment shall have been rendered.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
