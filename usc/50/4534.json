{"tag":"section","attrib":{"id":"idd22d44bb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4534"},"text":null,"children":[{"tag":"num","attrib":{"value":"4534"},"text":"§ 4534.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defense Production Act Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd22d44bc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4534/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a separate fund to be known as the “Defense Production Act Fund” (in this section referred to as the “Fund”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd22d44bd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4534/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Moneys in Fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There shall be credited to the Fund—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd22d44be-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4534/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all moneys appropriated for the Fund, as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4561"},"text":"section 4561 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd22d44bf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4534/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all moneys received by the Fund on transactions entered into pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4533"},"text":"section 4533 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd22d44c0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4534/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Fund shall be available to carry out the provisions and purposes of this subchapter, subject to the limitations set forth in this chapter and in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd22d44c1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4534/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Moneys in the Fund shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd22d44c2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4534/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund balance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Fund balance at the close of each fiscal year shall not exceed $750,000,000, excluding any moneys appropriated to the Fund during that fiscal year or obligated funds. If, at the close of any fiscal year, the Fund balance exceeds $750,000,000, the amount in excess of $750,000,000 shall be paid into the general fund of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd22d44c3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4534/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund manager","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall designate a Fund manager. The duties of the Fund manager shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd22d44c4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4534/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining the liability of the Fund in accordance with subsection (g);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd22d44c5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4534/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring the visibility and accountability of transactions engaged in through the Fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd22d44c6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4534/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reporting to the Congress each year regarding activities of the Fund during the previous fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd22d44c7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4534/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liabilities against Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When any agreement entered into pursuant to this subchapter after ","children":[{"tag":"date","attrib":{"date":"1991-12-31"},"text":"December 31, 1991","children":[],"tail":", imposes any contingent liability upon the United States, such liability shall be considered an obligation against the Fund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd22d44c8-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-08/ch932"},"text":"Sept. 8, 1950, ch. 932","children":[],"tail":", title III, § 304, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/67/s7"},"text":"Pub. L. 111–67, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2017"},"text":"123 Stat. 2017","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd22d44c9-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"idd22d44ca-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4564/a"},"text":"section 4564(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd22d44cb-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd22d44cc-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children