{"tag":"section","attrib":{"id":"idd1cb9c89-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3325"},"text":null,"children":[{"tag":"num","attrib":{"value":"3325"},"text":"§ 3325.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reaffirmation of longstanding prohibition against drug trafficking by employees of the intelligence community","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1cb9c8a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3325/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Congress finds that longstanding statutes, regulations, and policies of the United States prohibit employees, agents, and assets of the elements of the intelligence community, and of every other Federal department and agency, from engaging in the illegal manufacture, purchase, sale, transport, and distribution of drugs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cb9c8b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3325/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligation of employees of intelligence community","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any employee of the intelligence community having knowledge of a fact or circumstance that reasonably indicates that an employee, agent, or asset of an element of the intelligence community is involved in any activity that violates a statute, regulation, or policy described in subsection (a) shall report such knowledge to an appropriate official.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cb9c8c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3325/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intelligence community defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “intelligence community” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003/4"},"text":"section 3003(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1cb9c8d-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/120/tIII/s313"},"text":"Pub. L. 106–120, title III, § 313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-03"},"text":"Dec. 3, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1615"},"text":"113 Stat. 1615","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1cb9c8e-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1cb9c8f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1cb9c90-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s403–8"},"text":"section 403–8 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
