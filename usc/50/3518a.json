{"tag":"section","attrib":{"id":"idd1ece04d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3518a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3518a"},"text":"§ 3518a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Portability of overseas service retirement benefit","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The special accrual rates provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2153"},"text":"section 2153 of this title","children":[],"tail":" and by "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3518"},"text":"section 3518 of this title","children":[],"tail":" for computation of the annuity of an individual who has served abroad as an officer or employee of the Central Intelligence Agency shall be used to compute that portion of the annuity of such individual relating to such service abroad whether or not the individual is employed by the Central Intelligence Agency at the time of retirement from Federal service."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd1ece04e-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/193/tIII/s306"},"text":"Pub. L. 101–193, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-30"},"text":"Nov. 30, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1704"},"text":"103 Stat. 1704","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/178/tII/s204/a"},"text":"Pub. L. 103–178, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2033"},"text":"107 Stat. 2033","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1ece04f-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1ece050-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1ece051-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s403r–1"},"text":"section 403r–1 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Intelligence Authorization Act, Fiscal Year 1990, and not as part of the Central Intelligence Agency Act of 1949 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1ece052-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/178"},"text":"Pub. L. 103–178","children":[],"tail":" substituted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2153"},"text":"section 2153 of this title","children":[],"tail":" for reference in original to section 303 of the Central Intelligence Agency Retirement Act of 1964 for Certain Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
