{"tag":"section","attrib":{"id":"idd0fe892f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s513"},"text":null,"children":[{"tag":"num","attrib":{"value":"513"},"text":"§ 513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion of existing facilities; appropriations; testing of models","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd0fe8930-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s513/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator is authorized to expand the facilities at his existing laboratories and centers by the construction of additional transsonic, supersonic, and hypersonic wind tunnels, including buildings, equipment, and accessory construction, and by the acquisition of land and installation of utilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0fe8931-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s513/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is authorized to be appropriated such sums as may be necessary to carry out the purposes of this section, but not to exceed $136,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0fe8932-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s513/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The facilities authorized by this section shall be operated and staffed by the Administrator but shall be available primarily to industry for testing experimental models in connection with the development of aircraft and missiles. Such tests shall be scheduled and conducted in accordance with industry’s requirements and allocation of facility time shall be made in accordance with the public interest, with proper emphasis upon the requirements of each military service and due consideration of civilian needs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd0fe8933-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-27/ch766"},"text":"Oct. 27, 1949, ch. 766","children":[],"tail":", title I, § 103, "},{"tag":"ref","attrib":{"href":"/us/stat/63/937"},"text":"63 Stat. 937","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/568/tIII/s301/d/2"},"text":"Pub. L. 85–568, title III, § 301(d)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1958-07-29"},"text":"July 29, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/433"},"text":"72 Stat. 433","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/391/tIII/s312/2"},"text":"Pub. L. 106–391, title III, § 312(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1594"},"text":"114 Stat. 1594","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd0fe8934-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd0fe8935-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd0fe8936-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/391/s312/2/A"},"text":"Pub. L. 106–391, § 312(2)(A)","children":[],"tail":", (B), substituted “laboratories and centers” for “laboratories” and “transsonic, supersonic, and hypersonic” for “supersonic”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/391/s312/2/C"},"text":"Pub. L. 106–391, § 312(2)(C)","children":[],"tail":", substituted “facility” for “laboratory”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsecs. (a), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/568"},"text":"Pub. L. 85–568","children":[],"tail":" substituted “Administrator” for “Committee” in subsecs. (a) and (c), and “his” for “its” in subsec. (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd0fe8937-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd0fe8938-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1958 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/568"},"text":"Pub. L. 85–568","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"1958-07-29"},"text":"July 29, 1958","children":[],"tail":", or on any earlier date on which the Administrator of the National Aeronautics and Space Administration determines, and announces by proclamation, that the Administration has been organized and is prepared to discharge the duties and exercise the powers conferred upon it, see "},{"tag":"ref","attrib":{"href":"/us/pl/85/568/s301/e"},"text":"section 301(e) of Pub. L. 85–568","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s511"},"text":"section 511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd0fe8939-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Additional Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1950-06-29/ch405/s801"},"text":"Act June 29, 1950, ch. 405, § 801","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/286"},"text":"64 Stat. 286","children":[],"tail":", provided in part for an additional appropriation of $75,000,000, to remain available until expended; for the construction and completion and equipment of facilities at the Langley Aeronautical Laboratory, Langley Air Force Base, Virginia."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
