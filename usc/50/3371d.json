{"tag":"section","attrib":{"id":"idd1deb041-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371d"},"text":null,"children":[{"tag":"num","attrib":{"value":"3371d"},"text":"§ 3371d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of counterintelligence officer to lead election security matters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1deb042-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence shall designate a national counterintelligence officer within the National Counterintelligence and Security Center to lead, manage, and coordinate counterintelligence matters relating to election security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1deb043-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The person designated under subsection (a) shall also lead, manage, and coordinate counterintelligence matters relating to risks posed by interference from foreign powers (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801"},"text":"section 1801 of this title","children":[],"tail":") to the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1deb044-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal Government election security supply chain.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1deb045-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Election voting systems and software.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1deb046-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Voter registration databases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1deb047-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Critical infrastructure related to elections.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1deb048-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371d/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other Government goods and services as the Director of National Intelligence considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1deb049-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLXV/s6508"},"text":"Pub. L. 116–92, div. E, title LXV, § 6508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2208"},"text":"133 Stat. 2208","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
