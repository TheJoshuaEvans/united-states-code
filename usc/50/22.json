{"tag":"section","attrib":{"id":"idd0e44984-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"§ 22.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time allowed to settle affairs and depart","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When an alien who becomes liable as an enemy, in the manner prescribed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s21"},"text":"section 21 of this title","children":[],"tail":", is not chargeable with actual hostility, or other crime against the public safety, he shall be allowed, for the recovery, disposal, and removal of his goods and effects, and for his departure, the full time which is or shall be stipulated by any treaty then in force between the United States and the hostile nation or government of which he is a native citizen, denizen, or subject; and where no such treaty exists, or is in force, the President may ascertain and declare such reasonable time as may be consistent with the public safety, and according to the dictates of humanity and national hospitality."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd0e44985-47c4-11f1-8bcf-c89722bddd2e"},"text":"(R.S. § 4068.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd0e44986-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd0e44987-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd0e44988-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 4068 derived from acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1798-07-06/ch66/s1"},"text":"July 6, 1798, ch. 66, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/1/577"},"text":"1 Stat. 577","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1812-07-06/ch130"},"text":"July 6, 1812, ch. 130","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/2/781"},"text":"2 Stat. 781","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
