{"tag":"section","attrib":{"id":"idd10343ff-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s856"},"text":null,"children":[{"tag":"num","attrib":{"value":"856"},"text":"§ 856.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing offense","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Failure to file a registration statement as required by this subchapter is a continuing offense for as long as such failure exists, notwithstanding any statute of limitation or other statute to the contrary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd1034400-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch849/s7"},"text":"Aug. 1, 1956, ch. 849, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/900"},"text":"70 Stat. 900","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1034401-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1034402-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1034403-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Internal Security Act of 1950 which comprises subchapters I to III of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
