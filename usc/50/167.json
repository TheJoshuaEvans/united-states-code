{"tag":"section","attrib":{"id":"idd0f27b1d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167"},"text":null,"children":[{"tag":"num","attrib":{"value":"167"},"text":"§ 167.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0f27b1e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cliffside Field","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Cliffside Field” means the helium storage reservoir in which the Federal Helium Reserve is stored.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f27b1f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Helium Pipeline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal Helium Pipeline” means the federally owned pipeline system through which helium for the Federal Helium Reserve may be transported.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f27b20-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Helium Reserve","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal Helium Reserve” means helium reserves owned by the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f27b21-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Helium System","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal Helium System” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd0f27b22-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Helium Reserve;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0f27b23-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Cliffside Field;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0f27b24-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Helium Pipeline; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0f27b25-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all other infrastructure owned, leased, or managed under contract by the Secretary for the storage, transportation, withdrawal, enrichment, purification, or management of helium.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f27b26-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal user","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal user” means a Federal agency or extramural holder of one or more Federal research grants using helium.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f27b27-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-Btu gas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “low-Btu gas” means a fuel gas with a heating value of less than 250 Btu per standard cubic foot measured as the higher heating value resulting from the inclusion of noncombustible gases, including nitrogen, helium, argon, and carbon dioxide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f27b28-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means any individual, corporation, partnership, firm, association, trust, estate, public or private institution, or State or political subdivision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f27b29-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority pipeline access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “priority pipeline access” means the first priority of delivery of crude helium under which the Secretary schedules and ensures the delivery of crude helium to a helium refinery through the Federal Helium System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f27b2a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified bidder","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd0f27b2b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified bidder” means a person the Secretary determines is seeking to purchase helium for their own use, refining, or redelivery to users.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0f27b2c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified bidder” does not include a person who was previously determined to be a qualified bidder if the Secretary determines that the person did not meet the requirements of a qualified bidder under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f27b2d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying domestic helium transaction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualifying domestic helium transaction” means any agreement entered into or renegotiated agreement during the preceding 1-year period in the United States for the purchase or sale of at least 15,000,000 standard cubic feet of crude or pure helium to which any holder of a contract with the Secretary for the acceptance, storage, delivery, or redelivery of crude helium from the Federal Helium System is a party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f27b2e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refiner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “refiner” means a person with the ability to take delivery of crude helium from the Federal Helium Pipeline and refine the crude helium into pure helium.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f27b2f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd0f27b30-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1925-03-03/ch426/s2"},"text":"Mar. 3, 1925, ch. 426, § 2","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/86/777/s2"},"text":"Pub. L. 86–777, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-13"},"text":"Sept. 13, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/918"},"text":"74 Stat. 918","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/40/s2"},"text":"Pub. L. 113–40, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-10-02"},"text":"Oct. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/534"},"text":"127 Stat. 534","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd0f27b31-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd0f27b32-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd0f27b33-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2 of act ","children":[{"tag":"date","attrib":{"date":"1925-03-03"},"text":"Mar. 3, 1925","children":[],"tail":", authorized Bureau of Mines to produce helium gas and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s163"},"text":"section 163 of this title","children":[],"tail":", prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/86/777"},"text":"Pub. L. 86–777","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd0f4eb34-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/40"},"text":"Pub. L. 113–40","children":[],"tail":" amended section generally. Prior to amendment, section defined “Secretary”, “person”, “helium-bearing natural gas”, and “helium-gas mixture”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd0f4eb35-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd0f4eb36-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1960 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/86/777/s3"},"text":"Pub. L. 86–777, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-13"},"text":"Sept. 13, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/923"},"text":"74 Stat. 923","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/86/777/s3"},"text":"“The amendment made by this Act [enacting this section and sections 167a to 167n of this title] shall become effective on ","children":[{"tag":"date","attrib":{"date":"1961-03-01"},"text":"March 1, 1961","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idd0f4eb37-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/40/s1"},"text":"Pub. L. 113–40, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-10-02"},"text":"Oct. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/534"},"text":"127 Stat. 534","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/40/s1"},"text":"“This Act [see Tables for classification] may be cited as the ‘Helium Stewardship Act of 2013’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idd0f4eb38-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/273/s1"},"text":"Pub. L. 104–273, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3315"},"text":"110 Stat. 3315","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/273/s1"},"text":"“This Act [amending sections 167a to 167d, 167f, 167j, and 167m of this title] may be cited as the ‘Helium Privatization Act of 1996’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idd0f4eb39-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1960 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/86/777/s1"},"text":"Pub. L. 86–777, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-13"},"text":"Sept. 13, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/918"},"text":"74 Stat. 918","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/86/777/s1"},"text":"“This Act [enacting this section, sections 167a to 167n of this title, and provisions set out as notes below] may be cited as the ‘Helium Act Amendments of 1960’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idd0f4eb3a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1 of act ","children":[{"tag":"date","attrib":{"date":"1925-03-03"},"text":"Mar. 3, 1925","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/86/777/s2"},"text":"Pub. L. 86–777, § 2","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/86/777/s2"},"text":"“This Act [enacting this section, sections 167a to 167n of this title, and provisions set out as a note below] may be cited as the ‘Helium Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd0f4eb3b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/40/s9"},"text":"Pub. L. 113–40, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-10-02"},"text":"Oct. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/544"},"text":"127 Stat. 544","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/40/s9"},"text":"“The Secretary of the Interior shall promulgate such regulations as are necessary to carry out this Act [see Tables for classification] and the amendments made by this Act, including regulations necessary to prevent unfair acts and practices.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"separability","id":"idd0f4eb3c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Separability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1925-03-03/ch426/s20"},"text":"Act Mar. 3, 1925, ch. 426, § 20","children":[],"tail":", formerly § 17, as added "},{"tag":"ref","attrib":{"href":"/us/pl/86/777/s2"},"text":"Pub. L. 86–777, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-13"},"text":"Sept. 13, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/923"},"text":"74 Stat. 923","children":[],"tail":", renumbered § 20, "},{"tag":"ref","attrib":{"href":"/us/pl/113/40/s6/2"},"text":"Pub. L. 113–40, § 6(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-10-02"},"text":"Oct. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/540"},"text":"127 Stat. 540","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/40/s6/2"},"text":"“If any provision of this Act [enacting this section, sections 167a to 167n of this title, and provisions set out as a note above], or the application of such provision to any person or circumstance, is held invalid, the remainder of this Act or the application of such provision to persons or circumstances other than those as to which it is held invalid, shall not be affected thereby.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd0f4eb3d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Existing Agreements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/40/s8"},"text":"Pub. L. 113–40, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-10-02"},"text":"Oct. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/544"},"text":"127 Stat. 544","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/40/s8"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This Act [see Tables for classification] and the amendments made by this Act shall not affect or diminish the rights and obligations of the Secretary of the Interior and private parties under agreements in existence on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2013-10-02"},"text":"Oct. 2, 2013","children":[],"tail":"], except to the extent that the agreements are renewed or extended after that date."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delivery","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No agreement described in subsection (a) shall affect or diminish the right of any party that purchases helium after the date of enactment of this Act in accordance with section 6 of the Helium Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s167d"},"text":"50 U.S.C. 167d","children":[],"tail":") (as amended by section 5) to receive delivery of the helium in accordance with section 5(e)(2) of the Helium Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s167c/e/2"},"text":"50 U.S.C. 167c(e)(2)","children":[],"tail":") (as amended by section 4).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd0f4eb3e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Severance Package for Helium Operations Employees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/3/tI/s112"},"text":"Pub. L. 106–113, div. B, § 1000(a)(3) [title I, § 112]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1535"},"text":"113 Stat. 1535","children":[],"tail":", 1501A–157, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/113/dB/s1000/a/3/tI/s112"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Employees of Helium Operations, Bureau of Land Management, entitled to severance pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5595"},"text":"5 U.S.C. 5595","children":[],"tail":", may apply for, and the Secretary of the Interior may pay, the total amount of the severance pay to the employee in a lump sum. Employees paid severance pay in a lump sum and subsequently reemployed by the Federal Government shall be subject to the repayment provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5595/i/2"},"text":"5 U.S.C. 5595(i)(2)","children":[],"tail":" and (3), except that any repayment shall be made to the Helium Fund."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Helium Operations employees who elect to continue health benefits after separation shall be liable for not more than the required employee contribution under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8905a/d/1/A"},"text":"5 U.S.C. 8905a(d)(1)(A)","children":[],"tail":". The Helium Fund shall pay for 18 months the remaining portion of required contributions."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Interior may provide for training to assist Helium Operations employees in the transition to other Federal or private sector jobs during the facility shut-down and disposition process and for up to 12 months following separation from Federal employment, including retraining and relocation incentives on the same terms and conditions as authorized for employees of the Department of Defense in section 348 of the National Defense Authorization Act for Fiscal Year 1995 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1597"},"text":"10 U.S.C. 1597","children":[],"tail":" note]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of the annual leave restoration provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s6304/d/1/B"},"text":"5 U.S.C. 6304(d)(1)(B)","children":[],"tail":", the cessation of helium production and sales, and other related Helium Program activities shall be deemed to create an exigency of public business under, and annual leave that is lost during leave years 1997 through 2001 because of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s6304"},"text":"5 U.S.C. 6304","children":[],"tail":" (regardless of whether such leave was scheduled in advance) shall be restored to the employee and shall be credited and available in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s6304/d/2"},"text":"5 U.S.C. 6304(d)(2)","children":[],"tail":". Annual leave so restored and remaining unused upon the transfer of a Helium Program employee to a position of the executive branch outside of the Helium Program shall be liquidated by payment to the employee of a lump sum from the Helium Fund for such leave."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Benefits under this section shall be paid from the Helium Fund in accordance with section 4(c)(4) of the Helium Privatization Act of 1996 [probably means the Helium Act, which is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s167b/c/4"},"text":"section 167b(c)(4) of this title","children":[],"tail":"]. Funds may be made available to Helium Program employees who are or will be separated before "},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"October 1, 2002","children":[],"tail":" because of the cessation of helium production and sales and other related activities. Retraining benefits, including retraining and relocation incentives, may be paid for retraining commencing on or before "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"September 30, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall remain in effect through fiscal year 2002.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tI/s112"},"text":"Pub. L. 105–277, div. A, § 101(e) [title I, § 112]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–254."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/83/tI/s113"},"text":"Pub. L. 105–83, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-14"},"text":"Nov. 14, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1562"},"text":"111 Stat. 1562","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
