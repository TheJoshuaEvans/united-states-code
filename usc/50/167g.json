{"tag":"section","attrib":{"id":"idd0f75cd2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167g"},"text":null,"children":[{"tag":"num","attrib":{"value":"167g"},"text":"§ 167g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promulgation of rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to establish and promulgate such rules and regulations, as are consistent with the directions of this chapter and are necessary to carry out the provisions hereof.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd0f75cd3-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1925-03-03/ch426/s9"},"text":"Mar. 3, 1925, ch. 426, § 9","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/86/777/s2"},"text":"Pub. L. 86–777, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-13"},"text":"Sept. 13, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/922"},"text":"74 Stat. 922","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
