{"tag":"section","attrib":{"id":"idd1c6ba51-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236"},"text":null,"children":[{"tag":"num","attrib":{"value":"3236"},"text":"§ 3236.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspector General external review panel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1c6ba52-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request for review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual with a claim described in subsection (b) may submit to the Inspector General of the Intelligence Community a request for a review of such claim by an external review panel convened under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c6ba53-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claims and individuals described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A claim described in this subsection is any—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c6ba54-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" claim by an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c6ba55-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the individual has been subjected to a personnel action that is prohibited under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3234"},"text":"section 3234 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c6ba56-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has exhausted the applicable review process for the claim pursuant to enforcement of such section; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c6ba57-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" claim by an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c6ba58-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that he or she has been subjected to a reprisal prohibited by paragraph (1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3341/j"},"text":"section 3341(j) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c6ba59-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who received a decision on an appeal regarding that claim under paragraph (4) of such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c6ba5a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" External review panel convened","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c6ba5b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretion to convene","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon receipt of a request under subsection (a) regarding a claim, the Inspector General of the Intelligence Community may, at the discretion of the Inspector General, convene an external review panel under this subsection to review the claim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c6ba5c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c6ba5d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An external review panel convened under this subsection shall be composed of three members as follows:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1c6ba5e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Inspector General of the Intelligence Community.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1c6ba5f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subparagraph (B), two members selected by the Inspector General as the Inspector General considers appropriate on a case-by-case basis from among inspectors general of the following:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idd1c6ba60-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/c/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd1c6ba61-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/c/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd1c6ba62-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/c/2/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd1c6ba63-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/c/2/A/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Justice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd1c6ba64-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/c/2/A/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd1c6ba65-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/c/2/A/ii/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd1c6ba66-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/c/2/A/ii/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Central Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd1c6ba67-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/c/2/A/ii/VIII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VIII"},"text":"(VIII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Defense Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd1c6ba68-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/c/2/A/ii/IX"},"text":null,"children":[{"tag":"num","attrib":{"value":"IX"},"text":"(IX)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Geospatial-Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd1c6ba69-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/c/2/A/ii/X"},"text":null,"children":[{"tag":"num","attrib":{"value":"X"},"text":"(X)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Reconnaissance Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd1c6ba6a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/c/2/A/ii/XI"},"text":null,"children":[{"tag":"num","attrib":{"value":"XI"},"text":"(XI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Security Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c6ba6b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An inspector general of an agency may not be selected to sit on the panel under subparagraph (A)(ii) to review any matter relating to a decision made by such agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c6ba6c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1c6ba6d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clause (ii), the chairperson of any panel convened under this subsection shall be the Inspector General of the Intelligence Community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1c6ba6e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflicts of interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Inspector General of the Intelligence Community finds cause to recuse himself or herself from a panel convened under this subsection, the Inspector General of the Intelligence Community shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idd1c6ba6f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/c/2/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select a chairperson from inspectors general of the elements listed under subparagraph (A)(ii) whom the Inspector General of the Intelligence Community considers appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd1c6ba70-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/c/2/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the congressional intelligence committees of such selection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c6ba71-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each external review panel convened under this subsection to review a claim shall complete review of the claim no later than 270 days after the date on which the Inspector General convenes the external review panel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c6ba72-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c6ba73-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Panel recommendations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an external review panel convened under subsection (c) determines, pursuant to a review of a claim submitted by an individual under subsection (a), that the individual was the subject of a personnel action prohibited under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3234"},"text":"section 3234 of this title","children":[],"tail":" or was subjected to a reprisal prohibited by "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3341/j/1"},"text":"section 3341(j)(1) of this title","children":[],"tail":", the panel may recommend that the agency head take corrective action—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c6ba74-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an employee or former employee—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1c6ba75-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to return the employee or former employee, as nearly as practicable and reasonable, to the position such employee or former employee would have held had the reprisal not occurred; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1c6ba76-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reconsider the employee’s or former employee’s eligibility for access to classified information consistent with national security; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c6ba77-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any other case, such other action as the external review panel considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c6ba78-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency action","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c6ba79-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date on which the head of an agency receives a recommendation from an external review panel under paragraph (1), the head shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1c6ba7a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give full consideration to such recommendation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1c6ba7b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform the panel and the Director of National Intelligence of what action the head has taken with respect to the recommendation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c6ba7c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to inform","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall notify the President of any failures to comply with subparagraph (A)(ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c6ba7d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c6ba7e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less frequently than once each year, the Inspector General of the Intelligence Community shall submit to the congressional intelligence committees and the Director of National Intelligence a report on the activities under this section during the previous year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c6ba7f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to such limitations as the Inspector General of the Intelligence Community considers necessary to protect the privacy of an individual who has made a claim described in subsection (b), each report submitted under paragraph (1) shall include, for the period covered by the report, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c6ba80-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The determinations and recommendations made by the external review panels convened under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c6ba81-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3236/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The responses of the heads of agencies that received recommendations from the external review panels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1c6ba82-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title XI, § 1106, as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLIII/s5332/a/1"},"text":"Pub. L. 116–92, div. E, title LIII, § 5332(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2137"},"text":"133 Stat. 2137","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
