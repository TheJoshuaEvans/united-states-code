{"tag":"section","attrib":{"id":"idd1bf8e96-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3191"},"text":null,"children":[{"tag":"num","attrib":{"value":"3191"},"text":"§ 3191.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scholarships and work-study for pursuit of graduate degrees in science and technology","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1bf8e97-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3191/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence may carry out a program to provide scholarships and work-study for individuals who are pursuing graduate degrees in fields of study in science and technology that are identified by the Director as appropriate to meet the future needs of the intelligence community for qualified scientists and engineers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1bf8e98-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3191/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Director of National Intelligence carries out the program under subsection (a), the Director of National Intelligence shall administer the program through the Office of the Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1bf8e99-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3191/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of fields of study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Director of National Intelligence carries out the program under subsection (a), the Director shall identify fields of study under subsection (a) in consultation with the other heads of the elements of the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1bf8e9a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3191/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for participation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual eligible to participate in the program is any individual who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1bf8e9b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3191/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" either—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1bf8e9c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3191/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an employee of the intelligence community; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1bf8e9d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3191/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets criteria for eligibility for employment in the intelligence community that are established by the Director of National Intelligence;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1bf8e9e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3191/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is accepted in a graduate degree program in a field of study in science or technology identified under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1bf8e9f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3191/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is eligible for a security clearance at the level of Secret or above.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1bf8ea0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3191/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Director of National Intelligence carries out the program under subsection (a), the Director shall prescribe regulations for purposes of the administration of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1bf8ea1-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title X, § 1001, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/306/tIII/s331/a/3"},"text":"Pub. L. 107–306, title III, § 331(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2394"},"text":"116 Stat. 2394","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI"},"text":"Pub. L. 108–458, title I","children":[],"tail":", §§ 1071(a)(1)(MM), (3)(C)–(F), 1072(a)(8), "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3689"},"text":"118 Stat. 3689","children":[],"tail":", 3690, 3692.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1bf8ea2-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1bf8ea3-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1bf8ea4-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s441g"},"text":"section 441g of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd1bf8ea5-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1001 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"act July 26, 1947, ch. 343","children":[],"tail":", was renumbered section 1101 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3231"},"text":"section 3231 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1bf8ea6-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1071/a/1/MM"},"text":"Pub. L. 108–458, § 1071(a)(1)(MM)","children":[],"tail":", substituted “Director of National Intelligence” for “Director of Central Intelligence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1072/a/8"},"text":"Pub. L. 108–458, § 1072(a)(8)","children":[],"tail":", substituted “Office of the Director of National Intelligence” for “Assistant Director of Central Intelligence for Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1071/a/3/C"},"text":"Pub. L. 108–458, § 1071(a)(3)(C)","children":[],"tail":", which directed amendment of subsec. (b) by substituting “Director of National Intelligence” for “Director” each place it appeared, was executed by making the substitution the first two places it appeared to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1071/a/3/D"},"text":"Pub. L. 108–458, § 1071(a)(3)(D)","children":[],"tail":", substituted “If the Director of National Intelligence” for “If the Director”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1071/a/3/E"},"text":"Pub. L. 108–458, § 1071(a)(3)(E)","children":[],"tail":", substituted “Director of National Intelligence” for “Director”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1071/a/3/F"},"text":"Pub. L. 108–458, § 1071(a)(3)(F)","children":[],"tail":", substituted “If the Director of National Intelligence” for “If the Director”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1bf8ea7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd1bf8ea8-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For Determination by President that amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" take effect on "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", see Memorandum of President of the United States, "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", 70 F.R. 23925, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" effective not later than six months after "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1097/a"},"text":"section 1097(a) of Pub. L. 108–458","children":[],"tail":", set out in an Effective Date of 2004 Amendment; Transition Provisions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1bf8ea9-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Pilot Program on Recruitment and Training of Intelligence Analysts","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177/tIII/s318"},"text":"Pub. L. 108–177, title III, § 318","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-13"},"text":"Dec. 13, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2613"},"text":"117 Stat. 2613","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI"},"text":"Pub. L. 108–458, title I","children":[],"tail":", §§ 1071(g)(3)(A)(iii), 1072(d)(2)(B), "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3692"},"text":"118 Stat. 3692","children":[],"tail":", 3693, which required the Director of National Intelligence to carry out a pilot program during fiscal years 2004 through 2006 to provide financial assistance for academic training in areas of deficiency in the analytic capabilities of the intelligence community, and to submit reports to Congress not later than 120 days after "},{"tag":"date","attrib":{"date":"2003-12-13"},"text":"Dec. 13, 2003","children":[],"tail":", and not later than one year after the commencement of the program, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/tIII/s311/b/2/A"},"text":"Pub. L. 111–259, title III, § 311(b)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2663"},"text":"124 Stat. 2663","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
