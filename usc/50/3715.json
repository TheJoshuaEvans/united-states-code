{"tag":"section","attrib":{"id":"idd1f67d23-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3715"},"text":null,"children":[{"tag":"num","attrib":{"value":"3715"},"text":"§ 3715.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of contributions to Department of Defense Cooperative Threat Reduction Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1f67d24-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3715/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to enter into agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1f67d25-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3715/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Secretary of Defense may enter into one or more agreements with any person (including a foreign government, international organization, multinational entity, or any other entity) that the Secretary considers appropriate under which the person contributes funds for activities conducted under the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67d26-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3715/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concurrence by Secretary of State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into an agreement under paragraph (1) only with the concurrence of the Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f67d27-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3715/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention and use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":" and subject to subsections (c) and (d), the Secretary of Defense may retain and obligate or expend funds contributed pursuant to subsection (a) for purposes of the Program. Funds so contributed shall be retained in a separate fund established in the Treasury for such purposes and shall be available to be obligated or expended without further appropriation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f67d28-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3715/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return of funds not obligated or expended within three years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary does not obligate or expend funds contributed pursuant to subsection (a) by the date that is three years after the date on which the contribution was made, the Secretary shall return the amount to the person who made the contribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f67d29-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3715/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1f67d2a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3715/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after receiving funds contributed pursuant to subsection (a), the Secretary shall submit to the appropriate congressional committees a notice—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1f67d2b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3715/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifying the value of the contribution and the purpose for which the contribution was made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f67d2c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3715/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying the person who made the contribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67d2d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3715/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not obligate funds contributed pursuant to subsection (a) until a period of 15 days elapses following the date on which the Secretary submits the notice under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f67d2e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3715/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit to the congressional defense committees—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1f67d2f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3715/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an implementation plan for the authority provided under this section prior to obligating or expending any funds contributed pursuant to subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67d30-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3715/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any updates to such plan that the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f67d31-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3715/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate congressional committees” means the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1f67d32-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3715/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The congressional defense committees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67d33-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3715/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Foreign Affairs of the House of Representatives and the Committee on Foreign Relations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1f67d34-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tXIII/s1325"},"text":"Pub. L. 113–291, div. A, title XIII, § 1325","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3600"},"text":"128 Stat. 3600","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1051/t/6"},"text":"Pub. L. 115–91, div. A, title X, § 1051(t)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1566"},"text":"131 Stat. 1566","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1f67d35-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1f67d36-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1f67d37-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsecs. (e) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" redesignated subsecs. (f) and (g) as (e) and (f), respectively, and struck out former subsec. (e) which required annual reports on contributions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
