{"tag":"section","attrib":{"id":"idd0e4498e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s24"},"text":null,"children":[{"tag":"num","attrib":{"value":"24"},"text":"§ 24.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of marshals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When an alien enemy is required by the President, or by order of any court, judge, or justice, to depart and to be removed, it shall be the duty of the marshal of the district in which he shall be apprehended to provide therefor and to execute such order in person, or by his deputy or other discreet person to be employed by him, by causing a removal of such alien out of the territory of the United States; and for such removal the marshal shall have the warrant of the President, or of the court, judge, or justice ordering the same, as the case may be.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd0e4498f-47c4-11f1-8bcf-c89722bddd2e"},"text":"(R.S. § 4070.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd0e44990-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd0e44991-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd0e44992-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 4070 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1798-07-06/ch66/s3"},"text":"act July 6, 1798, ch. 66, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/1/578"},"text":"1 Stat. 578","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
