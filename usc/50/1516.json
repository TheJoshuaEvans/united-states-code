{"tag":"section","attrib":{"id":"idd10a6fde-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1516"},"text":null,"children":[{"tag":"num","attrib":{"value":"1516"},"text":"§ 1516.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delivery systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"None of the funds authorized to be appropriated by this Act shall be used for the procurement of delivery systems specifically designed to disseminate lethal chemical or any biological warfare agents, or for the procurement of delivery system parts or components specifically designed for such purpose, unless the President shall certify to the Congress that such procurement is essential to the safety and security of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd10a6fdf-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/441/tV/s506/a"},"text":"Pub. L. 91–441, title V, § 506(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-07"},"text":"Oct. 7, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/912"},"text":"84 Stat. 912","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd10a6fe0-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd10a6fe1-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd10a6fe2-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/441"},"text":"Pub. L. 91–441","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-07"},"text":"Oct. 7, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/912"},"text":"84 Stat. 912","children":[],"tail":". Provisions authorizing the appropriation of funds are not classified to the Code. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd10a6fe3-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/121/tIV/s409"},"text":"Pub. L. 91–121, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-11-19"},"text":"Nov. 19, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/209"},"text":"83 Stat. 209","children":[],"tail":", which comprises this chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Armed Forces-Military Procurement, 1971 act, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/441"},"text":"Pub. L. 91–441","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd10a6fe4-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/121/tIV/s409/f"},"text":"Pub. L. 91–121, title IV, § 409(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-11-19"},"text":"Nov. 19, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/210"},"text":"83 Stat. 210","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n