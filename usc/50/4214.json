{"tag":"section","attrib":{"id":"idd2157757-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4214"},"text":null,"children":[{"tag":"num","attrib":{"value":"4214"},"text":"§ 4214.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trust Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2157758-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4214/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States the Civil Liberties Public Education Fund, which shall be administered by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2157759-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4214/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment of amounts in the Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the Fund shall be invested in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s9702"},"text":"section 9702 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd215775a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4214/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of the Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the Fund shall be available only for disbursement by the Attorney General under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4215"},"text":"section 4215 of this title","children":[],"tail":" and by the Board under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4216"},"text":"section 4216 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd215775b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4214/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Fund shall terminate not later than the earlier of the date on which an amount has been expended from the Fund which is equal to the amount authorized to be appropriated to the Fund by subsection (e), and any income earned on such amount, or 10 years after ","children":[{"tag":"date","attrib":{"date":"1988-08-10"},"text":"August 10, 1988","children":[],"tail":". If all of the amounts in the Fund have not been expended by the end of that 10-year period, investments of amounts in the Fund shall be liquidated and receipts thereof deposited in the Fund and all funds remaining in the Fund shall be deposited in the miscellaneous receipts account in the Treasury."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd215775c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4214/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Fund $1,650,000,000, of which not more than $500,000,000 may be appropriated for any fiscal year. Any amounts appropriated pursuant to this section are authorized to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd215775d-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/383/tI/s104"},"text":"Pub. L. 100–383, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-10"},"text":"Aug. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/905"},"text":"102 Stat. 905","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/371/s2"},"text":"Pub. L. 102–371, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-09-27"},"text":"Sept. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1167"},"text":"106 Stat. 1167","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd215775e-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd215775f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd2157760-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 1989b–3 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd2157761-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/371"},"text":"Pub. L. 102–371","children":[],"tail":" substituted “$1,650,000,000” for “$1,250,000,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd2157762-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd2157763-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Maximum Amount Authorized for Fund","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/162/tII"},"text":"Pub. L. 101–162, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-21"},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/996"},"text":"103 Stat. 996","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/162/tII"},"text":"“Subject to the provisions of section 104(e) of the Civil Liberties Act of 1988 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/383"},"text":"Public Law 100–383","children":[],"tail":"; 50 U.S.C. App. 1989(b-3(e) [1989b–3(e)]) [now "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4214/e"},"text":"50 U.S.C. 4214(e)","children":[],"tail":"], the maximum amount authorized under such section for any fiscal year is appropriated, from money in the Treasury not otherwise appropriated, for each fiscal year beginning on or after "},{"tag":"date","attrib":{"date":"1990-10-01"},"text":"October 1, 1990","children":[],"tail":", to the Civil Liberties Public Education Fund established by section 104(a) of the Civil Liberties Act of 1988 ["},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4214/a"},"text":"50 U.S.C. 4214(a)","children":[],"tail":"], for payments to eligible individuals under section 105 of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4215"},"text":"50 U.S.C. 4215","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
