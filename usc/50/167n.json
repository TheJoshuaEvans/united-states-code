{"tag":"section","attrib":{"id":"idd0f75d0d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167n"},"text":null,"children":[{"tag":"num","attrib":{"value":"167n"},"text":"§ 167n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Helium gas resource assessment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd0f75d0e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2013-10-02"},"text":"October 2, 2013","children":[],"tail":", the Secretary, acting through the Director of the United States Geological Survey, shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0f75d0f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167n/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in coordination with appropriate heads of State geological surveys—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd0f75d10-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167n/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete a national helium gas assessment that identifies and quantifies the quantity of helium, including the isotope helium-3, in each reservoir, including assessments of the constituent gases found in each helium resource, such as carbon dioxide, nitrogen, and natural gas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0f75d11-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167n/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available the modern seismic and geophysical log data for characterization of the Bush Dome Reservoir;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f75d12-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167n/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in coordination with appropriate international agencies and the global geology community, complete a global helium gas assessment that identifies and quantifies the quantity of the helium, including the isotope helium-3, in each reservoir;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f75d13-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167n/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in coordination with the Secretary of Energy, acting through the Administrator of the Energy Information Administration, complete—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd0f75d14-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167n/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of trends in global demand for helium, including the isotope helium-3;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0f75d15-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167n/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a 10-year forecast of domestic demand for helium across all sectors, including scientific and medical research, commercial, manufacturing, space technologies, cryogenics, and national defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0f75d16-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167n/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an inventory of medical, scientific, industrial, commercial, and other uses of helium in the United States, including Federal uses, that identifies the nature of the helium use, the amounts required, the technical and commercial viability of helium recapture and recycling in that use, and the availability of material substitutes wherever possible; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f75d17-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167n/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Committee on Energy and Natural Resources of the Senate and the Committee on Natural Resources of the House of Representatives a report describing the results of the assessments required under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0f75d18-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $1,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd0f75d19-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1925-03-03/ch426/s16"},"text":"Mar. 3, 1925, ch. 426, § 16","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/40/s6/3"},"text":"Pub. L. 113–40, § 6(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-10-02"},"text":"Oct. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/542"},"text":"127 Stat. 542","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd0f75d1a-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd0f75d1b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd0f75d1c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 167n, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1925-03-03/ch426/s16"},"text":"act Mar. 3, 1925, ch. 426, § 16","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/86/777/s2"},"text":"Pub. L. 86–777, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-13"},"text":"Sept. 13, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/923"},"text":"74 Stat. 923","children":[],"tail":", directed the Secretary of the Interior to make annual reports to Congress, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/362/tIX/s901/q"},"text":"Pub. L. 105–362, title IX, § 901(q)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-10"},"text":"Nov. 10, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3291"},"text":"112 Stat. 3291","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
