83"},"text":"106 Stat. 3183","children":[],"tail":", related to death in service and was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403"},"text":"section 403 of this title","children":[],"tail":" prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/88/643"},"text":"Pub. L. 88–643","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s802"},"text":"section 802 of Pub. L. 102–496","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd15b7557-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “2031(i),” for “2031(h),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/178"},"text":"Pub. L. 103–178","children":[],"tail":" substituted “eligible for an annuity under section 2034” for “eligible for an annuity under section 2032”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd15b7558-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd15b7559-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/178"},"text":"Pub. L. 103–178","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-02-01"},"text":"Feb. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/178/s202/b"},"text":"section 202(b) of Pub. L. 103–178","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd15b755a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of fourth month beginning after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s805"},"text":"section 805 of Pub. L. 102–496","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
