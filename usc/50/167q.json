{"tag":"section","attrib":{"id":"idd0f75d39-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167q"},"text":null,"children":[{"tag":"num","attrib":{"value":"167q"},"text":"§ 167q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal agency helium acquisition strategy","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In anticipation of the implementation of Phase D described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s167d/d"},"text":"section 167d(d) of this title","children":[],"tail":", and not later than 2 years after "},{"tag":"date","attrib":{"date":"2013-10-02"},"text":"October 2, 2013","children":[],"tail":", the Secretary (in consultation with the Secretary of Energy, the Secretary of Defense, the Director of the National Science Foundation, the Administrator of the National Aeronautics and Space Administration, the Director of the National Institutes of Health, and other agencies as appropriate) shall submit to Congress a report that provides for Federal users—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0f75d3a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167q/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the consumption of, and projected demand for, crude and refined helium;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f75d3b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167q/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of a 20-year Federal strategy for securing access to helium;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f75d3c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167q/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a determination of a date prior to ","children":[{"tag":"date","attrib":{"date":"2021-09-30"},"text":"September 30, 2021","children":[],"tail":", for the implementation of Phase D as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s167d/d"},"text":"section 167d(d) of this title","children":[],"tail":" that minimizes any potential supply disruptions for Federal users;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f75d3d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167q/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the effects of increases in the price of refined helium and methods and policies for mitigating any determined effects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f75d3e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167q/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of a process for prioritization of uses that accounts for diminished availability of helium supplies that may occur over time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd0f75d3f-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1925-03-03/ch426/s19"},"text":"Mar. 3, 1925, ch. 426, § 19","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/40/s6/3"},"text":"Pub. L. 113–40, § 6(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-10-02"},"text":"Oct. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/544"},"text":"127 Stat. 544","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
