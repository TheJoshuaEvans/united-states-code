{"tag":"section","attrib":{"id":"idd2071f51-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3911"},"text":null,"children":[{"tag":"num","attrib":{"value":"3911"},"text":"§ 3911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2071f52-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3911/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Servicemember","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “servicemember” means a member of the uniformed services, as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a/5"},"text":"section 101(a)(5) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2071f53-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3911/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military service","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “military service” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2071f54-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3911/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a servicemember who is a member of the Army, Navy, Air Force, Marine Corps, Space Force, or Coast Guard—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd2071f55-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3911/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" active duty, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/d/1"},"text":"section 101(d)(1) of title 10","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2071f56-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3911/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a member of the National Guard, includes service under a call to active service authorized by the President or the Secretary of Defense for a period of more than 30 consecutive days under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s502/f"},"text":"section 502(f) of title 32","children":[],"tail":" for purposes of responding to a national emergency declared by the President and supported by Federal funds;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2071f57-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3911/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a servicemember who is a commissioned officer of the Public Health Service or the National Oceanic and Atmospheric Administration, active service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2071f58-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3911/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any period during which a servicemember is absent from duty on account of sickness, wounds, leave, or other lawful cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2071f59-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3911/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of military service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “period of military service” means the period beginning on the date on which a servicemember enters military service and ending on the date on which the servicemember is released from military service or dies while in military service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2071f5a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3911/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dependent","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “dependent”, with respect to a servicemember, means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2071f5b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3911/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the servicemember’s spouse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2071f5c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3911/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the servicemember’s child (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s101/4"},"text":"section 101(4) of title 38","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2071f5d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3911/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual for whom the servicemember provided more than one-half of the individual’s support for 180 days immediately preceding an application for relief under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2071f5e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3911/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Court","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “court” means a court or an administrative agency of the United States or of any State (including any political subdivision of a State), whether or not a court or administrative agency of record.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2071f5f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3911/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2071f60-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3911/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a commonwealth, territory, or possession of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2071f61-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3911/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2071f62-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3911/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary concerned","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Secretary concerned”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2071f63-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3911/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a member of the armed forces, has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a/9"},"text":"section 101(a)(9) of title 10","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2071f64-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3911/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a commissioned officer of the Public Health Service, means the Secretary of Health and Human Services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2071f65-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3911/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a commissioned officer of the National Oceanic and Atmospheric Administration, means the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2071f66-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3911/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motor vehicle","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “motor vehicle” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30102/a/6"},"text":"section 30102(a)(6) of title 49","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn002118"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002118"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2071f67-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3911/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judgment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “judgment” means any judgment, decree, order, or ruling, final or temporary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2071f68-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title I, § 101, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s1"},"text":"Pub. L. 108–189, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2836"},"text":"117 Stat. 2836","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/454/tVII/s701"},"text":"Pub. L. 108–454, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3624"},"text":"118 Stat. 3624","children":[],"tail":"; "