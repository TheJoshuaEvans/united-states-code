{"tag":"section","attrib":{"id":"idd16e88c8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2465"},"text":null,"children":[{"tag":"num","attrib":{"value":"2465"},"text":"§ 2465.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhancing private-sector employment through cooperative research and development activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd16e88c9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2465/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator for Nuclear Security shall encourage cooperative research and development activities at the national security laboratories (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2471"},"text":"section 2471 of this title","children":[],"tail":") that lead to the creation of new private-sector employment opportunities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16e88ca-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2465/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than January 31 of each year from 2012 through 2017, the Administrator shall submit to Congress a report detailing the number of new private-sector employment opportunities created as a result of the previous years’ cooperative research and development activities at each national security laboratory.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd16e88cb-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/dC/tXXXI/s3122"},"text":"Pub. L. 111–383, div. C, title XXXI, § 3122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4514"},"text":"124 Stat. 4514","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd16e88cc-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd16e88cd-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd16e88ce-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Ike Skelton National Defense Authorization Act for Fiscal Year 2011, and not as part of the National Nuclear Security Administration Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
