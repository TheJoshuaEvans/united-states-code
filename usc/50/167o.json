{"tag":"section","attrib":{"id":"idd0f75d1d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167o"},"text":null,"children":[{"tag":"num","attrib":{"value":"167o"},"text":"§ 167o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-Btu gas separation and helium conservation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd0f75d1e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167o/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Energy shall support programs of research, development, commercial application, and conservation (including the programs described in subsection (b))—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0f75d1f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167o/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expand the domestic production of low-Btu gas and helium resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f75d20-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167o/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to separate and capture helium from natural gas streams; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f75d21-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167o/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce the venting of helium and helium-bearing low-Btu gas during natural gas exploration and production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0f75d22-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167o/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0f75d23-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167o/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membrane technology research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy, in consultation with other appropriate agencies, shall support a civilian research program to develop advanced membrane technology that is used in the separation of low-Btu gases, including technologies that remove helium and other constituent gases that lower the Btu content of natural gas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f75d24-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167o/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Helium separation technology","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Energy shall support a research program to develop technologies for separating, gathering, and processing helium in low concentrations that occur naturally in geological reservoirs or formations, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd0f75d25-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167o/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" low-Btu gas production streams; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0f75d26-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167o/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technologies that minimize the atmospheric venting of helium gas during natural gas production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f75d27-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167o/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industrial helium program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Energy, working through the Advanced Manufacturing Office of the Department of Energy, shall carry out a research program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd0f75d28-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167o/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop low-cost technologies and technology systems for recycling, reprocessing, and reusing helium for all medical, scientific, industrial, commercial, aerospace, and other uses of helium in the United States, including Federal uses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0f75d29-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167o/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop industrial gathering technologies to capture helium from other chemical processing, including ammonia processing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0f75d2a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167o/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $3,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd0f75d2b-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1925-03-03/ch426/s17"},"text":"Mar. 3, 1925, ch. 426, § 17","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/40/s6/3"},"text":"Pub. L. 113–40, § 6(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-10-02"},"text":"Oct. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/542"},"text":"127 Stat. 542","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd0f75d2c-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd0f75d2d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd0f75d2e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 17 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1925-03-03/ch426"},"text":"act Mar. 3, 1925, ch. 426","children":[],"tail":", was redesignated section 20 and is set out as a Separability note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s167"},"text":"section 167 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
