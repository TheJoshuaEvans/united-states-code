{"tag":"section","attrib":{"id":"idd1e36ab7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3385"},"text":null,"children":[{"tag":"num","attrib":{"value":"3385"},"text":"§ 3385.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benjamin Tallmadge Institute as primary Central Intelligence Agency entity for education and training in counterintelligence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1e36ab8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3385/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Central Intelligence Agency shall maintain the Benjamin Tallmadge Institute as the primary entity within the Central Intelligence Agency for education and training related to all aspects of counterintelligence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1e36ab9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3385/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of Director","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Central Intelligence Agency shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1e36aba-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3385/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the Institute is fully and properly organized and has the resources necessary to provide counterintelligence education and training for all career fields within the Agency, including specialized certifications for Agency counterintelligence personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1e36abb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3385/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop appropriate certification courses that are designed to educate, train, and certify Agency personnel in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1e36abc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3385/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" counterintelligence threats, insider threats, and other counterintelligence processes and issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1e36abd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3385/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct and support of counterintelligence inquiries and investigations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1e36abe-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3385/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relevant skills necessary for coordination with Federal law enforcement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1e36abf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3385/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other skills as the Director determines necessary;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1e36ac0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3385/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and designate specific positions for which an individual shall be required to have a certification described in paragraph (2) prior to filling such a position; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1e36ac1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3385/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop necessary infrastructure and capacity to support the availability of courses under subsection (c) to increase participation by personnel from other components of the intelligence community in the courses offered by the Institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1e36ac2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3385/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and familiarization courses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1e36ac3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3385/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of the Institute shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1e36ac4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3385/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop training and familiarization courses at different classification levels, including courses at an unclassified level; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1e36ac5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3385/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offer instruction in the courses developed under subparagraph (A) or make training curricula available to other intelligence community components, as appropriate, to support outreach efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1e36ac6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3385/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of courses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The training and familiarization courses developed under paragraph (1) shall be made available to any of the following that have a need and appropriate clearance, as determined by the Director of the National Counterintelligence and Security Center in consultation with the Director of the Central Intelligence Agency, for a general education on counterintelligence threats, briefings on specific topics, or other training related to counterintelligence:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1e36ac7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3385/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal departments and agencies that are not elements of the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1e36ac8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3385/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State, local, and Tribal governments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1e36ac9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3385/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Private sector entities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1e36aca-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3385/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other personnel and entities as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1e36acb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3385/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Baseline certification course","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1e36acc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3385/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Institute shall develop, in coordination with the National Counterintelligence and Security Center and the Defense Intelligence Agency, and implement a baseline certification course for all counterintelligence career professionals that aligns the minimum certification requirements of the course and the Defense Counterintelligence Agent Course of the Joint Counterintelligence Training Activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1e36acd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3385/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of course","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The baseline certification course developed under paragraph (1) shall be made available, on a space-available basis, to all intelligence community professionals and appropriate personnel with appropriate security clearance from any other agency, committee, commission, office, or other establishment in the executive, legislative, or judicial branch of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1e36ace-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tIII/s7334"},"text":"Pub. L. 118–31, div. G, title III, § 7334","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1046"},"text":"137 Stat. 1046","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1e36acf-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1e36ad0-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd1e36ad1-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “intelligence community” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s7002"},"text":"section 7002 of Pub. L. 118–31","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
