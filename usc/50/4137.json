{"tag":"section","attrib":{"id":"idd21576d0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4137"},"text":null,"children":[{"tag":"num","attrib":{"value":"4137"},"text":"§ 4137.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidated awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"With respect to any claim which, at the time of the award, is vested in persons other than the person by whom the loss was sustained, the Commission may issue a consolidated award in favor of all claimants then entitled thereto, which award shall indicate the respective interests of such claimant therein; and all such claimants shall participate, in proportion to their indicated interests, in the payments authorized by this subchapter in all respects as if the award had been in favor of a single person.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd21576d1-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-07-03/ch826"},"text":"July 3, 1948, ch. 826","children":[],"tail":", title II, § 207, as added "},{"tag":"ref","attrib":{"href":"/us/pl/87/846/tI/s103"},"text":"Pub. L. 87–846, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-22"},"text":"Oct. 22, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1110"},"text":"76 Stat. 1110","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd21576d2-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd21576d3-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd21576d4-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 2017f of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
