{"tag":"section","attrib":{"id":"idd1d512d0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3344"},"text":null,"children":[{"tag":"num","attrib":{"value":"3344"},"text":"§ 3344.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classification training program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1d512d1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3344/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of each Executive agency, in accordance with Executive Order 13526, shall require annual training for each employee who has original classification authority. For employees who perform derivative classification, or are responsible for analysis, dissemination, preparation, production, receipt, publication, or otherwise communication of classified information, training shall be provided at least every two years. Such training shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d512d2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3344/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" educate the employee, as appropriate, regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d512d3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3344/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the guidance established under subparagraph (G) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3024/f/1"},"text":"section 3024(f)(1) of this title","children":[],"tail":", as added by section 5(a)(3),"},{"tag":"ref","attrib":{"idref":"fn002095"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002095"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" regarding the formatting of finished intelligence products;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d512d4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3344/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proper use of classification markings, including portion markings that indicate the classification of portions of information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d512d5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3344/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any incentives and penalties related to the proper classification of intelligence information; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d512d6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3344/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure such training is a prerequisite, once completed successfully, as evidenced by an appropriate certificate or other record, for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d512d7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3344/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtaining original classification authority or derivatively classifying information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d512d8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3344/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining such authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d512d9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3344/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of each Executive agency shall ensure that the training required by subsection (a) is conducted efficiently and in conjunction with any other required security, intelligence, or other training programs to reduce the costs and administrative burdens associated with carrying out the training required by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1d512da-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/258/s7"},"text":"Pub. L. 111–258, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2652"},"text":"124 Stat. 2652","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dF/tLXIV/s6402/c/2/D"},"text":"Pub. L. 119–60, div. F, title LXIV, § 6402(c)(2)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1616"},"text":"139 Stat. 1616","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1d512db-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1d512dc-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1d512dd-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order 13526, referred to in subsec. (a), is set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"text":"section 3161 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 5(a)(3), referred to in subsec. (a)(1)(A), probably means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/258/s5/a/3"},"text":"section 5(a)(3) of Pub. L. 111–258","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1d512de-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s435d"},"text":"section 435d of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1d512df-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “of section 3024(f)(1)” for “of section 3024(g)(1)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1d512e0-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd1d512e1-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/258/s3"},"text":"Pub. L. 111–258, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2648"},"text":"124 Stat. 2648","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/258/s3"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this Act [see Short Title of 2010 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of Title 6","children":[],"tail":", Domestic Security]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Derivative classification and original classification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms ‘derivative classification’ and ‘original classification’ have the meanings given those terms in Executive Order No. 13526 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"text":"50 U.S.C. 3161","children":[],"tail":" note]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Executive agency’ has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of title 5","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive order no. 13526","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Executive Order No. 13526’ means Executive Order No. 13526 (75 Fed. Reg. 707; relating to classified national security information) or any subsequent corresponding executive order.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
