{"tag":"section","attrib":{"id":"idd1f67d6c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3735"},"text":null,"children":[{"tag":"num","attrib":{"value":"3735"},"text":"§ 3735.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on availability of funds for Cooperative Threat Reduction activities in People’s Republic of China","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1f67d6d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3735/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Semiannual installments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out activities under the Program in the People’s Republic of China, the Secretary of Defense shall ensure that Cooperative Threat Reduction funds for such activities are obligated in semiannual installments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f67d6e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3735/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1f67d6f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3735/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to carrying out activities under the Program in the People’s Republic of China, the Secretary of Defense shall submit to the congressional defense committees the reports required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3711/g"},"text":"section 3711(g) of this title","children":[],"tail":" on a semiannual basis by not later than 15 days before any obligation of Cooperative Threat Reduction funds for such activities during the covered semiannual period. In addition to the matters required by such section, each such report shall include, in coordination with the Secretary of State—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1f67d70-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3735/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" whether China has taken material steps to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1f67d71-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3735/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disrupt the proliferation activities of Li Fangwei (also known as Karl Lee, or any other alias known by the United States); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1f67d72-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3735/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arrest Li Fangwei pursuant the indictment charged in the United States District Court for the Southern District of New York on ","children":[{"tag":"date","attrib":{"date":"2014-04-29"},"text":"April 29, 2014","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f67d73-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3735/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether China has proliferated to any non-nuclear weapons state, or any nuclear weapons state in violation of the Treaty on the Non-Proliferation of Nuclear Weapons, any item that contributes to a ballistic missile or nuclear weapons delivery system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f67d74-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3735/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number, type, and summary of any demarches between the United States and China with respect to the matters described in subparagraphs (A) and (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67d75-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3735/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional submissions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the same time as the Secretary of Defense submits to the congressional defense committees the information described in subparagraphs (A), (B), and (C) of paragraph (1) as part of the reports required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3711/g"},"text":"section 3711(g) of this title","children":[],"tail":", the Secretary shall submit to the Committee on Foreign Affairs of the House of Representatives and the Committee on Foreign Relations of the Senate such information."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67d76-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3735/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to the information described in subparagraphs (A), (B), and (C) of paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1f67d77-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3735/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first report described in such paragraph that is submitted after ","children":[{"tag":"date","attrib":{"date":"2016-12-23"},"text":"December 23, 2016","children":[],"tail":", shall cover the preceding 12-month period before the date of such submission; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f67d78-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3735/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each subsequent report shall cover the semiannual period preceding the date of such submission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67d79-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3735/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The information described in subparagraphs (A), (B), and (C) of paragraph (1) shall be submitted in unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1f67d7a-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tXIII/s1335"},"text":"Pub. L. 113–291, div. A, title XIII, § 1335","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXIII/s1303/a"},"text":"Pub. L. 114–328, div. A, title XIII, § 1303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2567"},"text":"130 Stat. 2567","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tXIII/s1302/b/3"},"text":"Pub. L. 115–91, div. A, title XIII, § 1302(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1705"},"text":"131 Stat. 1705","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1f67d7b-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1f67d7c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1f67d7d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" struck out “or expended” after “obligated”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
