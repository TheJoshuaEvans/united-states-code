{"tag":"section","attrib":{"id":"idd2071f71-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3912"},"text":null,"children":[{"tag":"num","attrib":{"value":"3912"},"text":"§ 3912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction and applicability of chapter","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2071f72-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3912/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This chapter applies to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2071f73-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3912/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2071f74-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3912/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each of the States, including the political subdivisions thereof; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2071f75-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3912/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all territory subject to the jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2071f76-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3912/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability to proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This chapter applies to any judicial or administrative proceeding commenced in any court or agency in any jurisdiction subject to this chapter. This chapter does not apply to criminal proceedings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2071f77-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3912/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Court in which application may be made","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When under this chapter any application is required to be made to a court in which no proceeding has already been commenced with respect to the matter, such application may be made to any court which would otherwise have jurisdiction over the matter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2071f78-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title I, § 102, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s1"},"text":"Pub. L. 108–189, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2837"},"text":"117 Stat. 2837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2071f79-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2071f7a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text