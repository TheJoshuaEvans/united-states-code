{"tag":"section","attrib":{"id":"idd21576f1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4142"},"text":null,"children":[{"tag":"num","attrib":{"value":"4142"},"text":"§ 4142.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to claimants","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each award or denial of a claim by the Commission, whether rendered before or after a hearing, shall include a specific statement of the facts and of the reasoning of the Commission in support of its conclusion.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd21576f2-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-07-03/ch826"},"text":"July 3, 1948, ch. 826","children":[],"tail":", title II, § 212, as added "},{"tag":"ref","attrib":{"href":"/us/pl/87/846/tI/s103"},"text":"Pub. L. 87–846, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-22"},"text":"Oct. 22, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1111"},"text":"76 Stat. 1111","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd21576f3-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd21576f4-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd21576f5-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 2017k of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
