{"tag":"section","attrib":{"id":"idd199690c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3043a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3043a"},"text":"§ 3043a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National intelligence strategy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd199690d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3043a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning in 2017, and once every 4 years thereafter, the Director of National Intelligence shall develop a comprehensive national intelligence strategy to meet national security objectives for the following 4-year period, or a longer period, if appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd199690e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3043a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each national intelligence strategy required by subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd199690f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3043a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" delineate a national intelligence strategy consistent with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1996910-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3043a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the most recent national security strategy report submitted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3043"},"text":"section 3043 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1996911-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3043a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the strategic plans of other relevant departments and agencies of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1996912-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3043a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant national-level plans;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1996913-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3043a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address matters related to national and military intelligence, including counterintelligence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1996914-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3043a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the major national security missions that the intelligence community is currently pursuing and will pursue in the future to meet the anticipated security environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1996915-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3043a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe how the intelligence community will utilize personnel, technology, partnerships, and other capabilities to pursue the major national security missions identified in paragraph (3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1996916-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3043a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess current, emerging, and future threats to the intelligence community, including threats from foreign intelligence and security services and insider threats;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1996917-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3043a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outline the organizational roles and missions of the elements of the intelligence community as part of an integrated enterprise to meet customer demands for intelligence products, services, and support;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1996918-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3043a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify sources of strategic, institutional, programmatic, fiscal, and technological risk; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1996919-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3043a/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyze factors that may affect the intelligence community’s performance in pursuing the major national security missions identified in paragraph (3) during the following 10-year period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd199691a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3043a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence shall submit to the congressional intelligence committees a report on each national intelligence strategy required by subsection (a) not later than 45 days after the date of the completion of such strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd199691b-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title I, § 108A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/293/tIII/s303/a"},"text":"Pub. L. 113–293, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3994"},"text":"128 Stat. 3994","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
