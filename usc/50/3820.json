{"tag":"section","attrib":{"id":"idd2071f27-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3820"},"text":null,"children":[{"tag":"num","attrib":{"value":"3820"},"text":"§ 3820.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedural rights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2071f28-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3820/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is hereby declared to be the purpose of this section to guarantee to each registrant asserting a claim before a local or appeal board, a fair hearing consistent with the informal and expeditious processing which is required by selective service cases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2071f29-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3820/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Pursuant to such rules and regulations as the President may prescribe—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2071f2a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3820/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each registrant shall be afforded the opportunity to appear in person before the local or any appeal board of the Selective Service System to testify and present evidence regarding his status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2071f2b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3820/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to reasonable limitations on the number of witnesses and the total time allotted to each registrant, each registrant shall have the right to present witnesses on his behalf before the local board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2071f2c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3820/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A quorum of any local board or appeal board shall be present during the registrant’s personal appearance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2071f2d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3820/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the event of a decision adverse to the claim of a registrant, the local or appeal board making such decision shall, upon request, furnish to such registrant a brief written statement of the reasons for its decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2071f2e-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-24/ch625"},"text":"June 24, 1948, ch. 625","children":[],"tail":", title I, § 22, as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/129/tI/s101/a/36"},"text":"Pub. L. 92–129, title I, § 101(a)(36)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-09-28"},"text":"Sept. 28, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/353"},"text":"85 Stat. 353","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2071f2f-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2071f30-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd2071f31-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 471a of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
