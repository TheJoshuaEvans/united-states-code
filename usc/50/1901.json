{"tag":"section","attrib":{"id":"idd14f8f57-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1901"},"text":null,"children":[{"tag":"num","attrib":{"value":"1901"},"text":"§ 1901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title, findings, and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd14f8f58-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1901/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This chapter may be cited as the “David L. Boren National Security Education Act of 1991”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd14f8f59-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1901/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd14f8f5a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1901/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The security of the United States is and will continue to depend on the ability of the United States to exercise international leadership.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14f8f5b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1901/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The ability of the United States to exercise international leadership is, and will increasingly continue to be, based on the political and economic strength of the United States, as well as on United States military strength around the world.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14f8f5c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1901/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recent changes in the world pose threats of a new kind to international stability as Cold War tensions continue to decline while economic competition, regional conflicts, terrorist activities, and weapon proliferations have dramatically increased.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14f8f5d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1901/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The future national security and economic well-being of the United States will depend substantially on the ability of its citizens to communicate and compete by knowing the languages and cultures of other countries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14f8f5e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1901/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal Government has an interest in ensuring that the employees of its departments and agencies with national security responsibilities are prepared to meet the challenges of this changing international environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14f8f5f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1901/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal Government also has an interest in taking actions to alleviate the problem of American undergraduate and graduate students being inadequately prepared to meet the challenges posed by increasing global interaction among nations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14f8f60-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1901/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" American colleges and universities must place a new emphasis on improving the teaching of foreign languages, area studies, counterproliferation studies, and other international fields to help meet those challenges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd14f8f61-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1901/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd14f8f62-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1901/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide the necessary resources, accountability, and flexibility to meet the national security education needs of the United States, especially as such needs change over time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14f8f63-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1901/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To increase the quantity, diversity, and quality of the teaching and learning of subjects in the fields of foreign languages, area studies, counterproliferation studies, and other international fields that are critical to the Nation’s interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14f8f64-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1901/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To produce an increased pool of applicants for work in the departments and agencies of the United States Government with national security responsibilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14f8f65-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1901/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To expand, in conjunction with other Federal programs, the international experience, knowledge base, and perspectives on which the United States citizenry, Government employees, and leaders rely.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14f8f66-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1901/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To permit the Federal Government to advocate the cause of international education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd14f8f67-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/183/tVIII/s801"},"text":"Pub. L. 102–183, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-04"},"text":"Dec. 4, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1271"},"text":"105 Stat. 1271","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tIV/s404/a"},"text":"Pub. L. 102–496, title IV, § 404(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3185"},"text":"106 Stat. 3185","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/272/tIII/s305/a/1"},"text":"Pub. L. 105–272, title III, § 305(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-20"},"text":"Oct. 20, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2400"},"text":"112 Stat. 2400","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd14f8f68-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd14f8f69-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd14f8f6a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsecs. (b)(7), (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/272"},"text":"Pub. L. 105–272","children":[],"tail":" inserted “counterproliferation studies,” after “area studies,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/496"},"text":"Pub. L. 102–496","children":[],"tail":" amended subsec. (a) generally, inserting “David L. Boren”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
