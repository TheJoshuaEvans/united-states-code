{"tag":"section","attrib":{"id":"idd0e693d3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s47e"},"text":null,"children":[{"tag":"num","attrib":{"value":"47e"},"text":"§ 47e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of award; approval; payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any awards granted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s47b"},"text":"section 47b of this title","children":[],"tail":" shall be certified by the Attorney General and, together with the approval of the President in those cases where such approval is required, transmitted to the Director of Central Intelligence for payment out of funds appropriated or available for the administration of the National Security Act of 1947, as amended."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd0e693d4-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-15/ch372/s6"},"text":"July 15, 1955, ch. 372, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/366"},"text":"69 Stat. 366","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/377/s1/c"},"text":"Pub. L. 93–377, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-17"},"text":"Aug. 17, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/473"},"text":"88 Stat. 473","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd0e693d5-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd0e693d6-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd0e693d7-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Security Act of 1947, as amended, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"act July 26, 1947, ch. 343","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/495"},"text":"61 Stat. 495","children":[],"tail":", which is classified principally to chapter 44 (§ 3001 et seq.) of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd0e693d8-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/377"},"text":"Pub. L. 93–377","children":[],"tail":" substituted “Attorney General” for “Awards Board”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd0e693d9-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idd0e693da-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to the Director of Central Intelligence or the Director of the Central Intelligence Agency in the Director’s capacity as the head of the intelligence community deemed to be a reference to the Director of National Intelligence. Reference to the Director of Central Intelligence or the Director of the Central Intelligence Agency in the Director’s capacity as the head of the Central Intelligence Agency deemed to be a reference to the Director of the Central Intelligence Agency. See section 1081(a), (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
