{"tag":"section","attrib":{"id":"idd169cdf1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2403"},"text":null,"children":[{"tag":"num","attrib":{"value":"2403"},"text":"§ 2403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal Deputy Administrator for Nuclear Security","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd169cdf2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2403/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd169cdf3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2403/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is in the Administration a Principal Deputy Administrator, who is appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd169cdf4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2403/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Principal Deputy Administrator shall be appointed from among persons who have extensive background in organizational management and are well qualified to manage the nuclear weapons, infrastructure construction and maintenance, nonproliferation, and materials disposition programs of the Administration in a manner that advances and protects the national security of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd169cdf5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2403/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the authority, direction, and control of the Administrator, the Principal Deputy Administrator shall perform such duties and exercise such powers as the Administrator may prescribe, including the coordination of activities among the elements of the Administration. The Principal Deputy Administrator shall act for, and exercise the powers of, the Administrator when the Administrator is disabled or the position of Administrator is vacant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd169cdf6-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dC/tXXXII/s3213"},"text":"Pub. L. 106–65, div. C, title XXXII, § 3213","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dC/tXXXI/s3141/a/2"},"text":"Pub. L. 107–107, div. C, title XXXI, § 3141(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1370"},"text":"115 Stat. 1370","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dC/tXXXI/s3111/a/2"},"text":"Pub. L. 118–159, div. C, title XXXI, § 3111(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2293"},"text":"138 Stat. 2293","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd169cdf7-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd169cdf8-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd169cdf9-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2403, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dC/tXXXII/s3213"},"text":"Pub. L. 106–65, div. C, title XXXII, § 3213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/958"},"text":"113 Stat. 958","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXI/s3157"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXI, § 3157]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–468, which related to status of Administration and contractor personnel within Department of Energy, was renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/s3220"},"text":"section 3220 of Pub. L. 106–65","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dC/tXXXI/s3141/a/1"},"text":"Pub. L. 107–107, div. C, title XXXI, § 3141(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1369"},"text":"115 Stat. 1369","children":[],"tail":", and transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2410"},"text":"section 2410 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd169cdfa-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" inserted “infrastructure construction and maintenance,” after “nuclear weapons,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
