{"tag":"section","attrib":{"id":"idd24c3e9d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4818"},"text":null,"children":[{"tag":"num","attrib":{"value":"4818"},"text":"§ 4818.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review relating to countries subject to comprehensive United States arms embargo","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd24c3e9e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4818/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, the Secretary of Defense, the Secretary of State, the Secretary of Energy, and the heads of other Federal agencies as appropriate, shall conduct a review of license requirements for exports, reexports, or in-country transfers of items to countries subject to a comprehensive United States arms embargo, including, as appropriate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd24c3e9f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4818/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the scope of controls under title 15, Code of Federal Regulations, that apply to exports, reexports, and in-country transfers for military end uses and military end users in countries that are subject to a comprehensive United States arms embargo and countries that are subject to a United Nations arms embargo; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd24c3ea0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4818/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entries on the Commerce Control List maintained under title 15, Code of Federal Regulations, that are not subject to a license requirement for the export, reexport, or in-country transfer of items to countries subject to a comprehensive United States arms embargo.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd24c3ea1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4818/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of results of review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 270 days after ","children":[{"tag":"date","attrib":{"date":"2018-08-13"},"text":"August 13, 2018","children":[],"tail":", the Secretary shall implement the results of the review conducted under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd24c3ea2-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVII/s1759"},"text":"Pub. L. 115–232, div. A, title XVII, § 1759","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2223"},"text":"132 Stat. 2223","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tX/s1081/d/8"},"text":"Pub. L. 116–283, div. A, title X, § 1081(d)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3874"},"text":"134 Stat. 3874","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd24c3ea3-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd24c3ea4-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":n