{"tag":"section","attrib":{"id":"idd1f40c8d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3616"},"text":null,"children":[{"tag":"num","attrib":{"value":"3616"},"text":"§ 3616.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation of remains of certain employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1f40c8e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3616/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may pay the expenses referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5742/b"},"text":"section 5742(b) of title 5","children":[],"tail":" in the case of any employee of the National Security Agency who dies while on a rotational tour of duty within the United States or while in transit to or from such tour of duty."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f40c8f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3616/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this section, the term “rotational tour of duty”, with respect to an employee, means a permanent change of station involving the transfer of the employee from the National Security Agency headquarters to another post of duty for a fixed period established by regulation to be followed at the end of such period by a permanent change of station involving a transfer of the employee back to such headquarters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1f40c90-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/36/s18"},"text":"Pub. L. 86–36, § 18","children":[],"tail":", formerly § 17, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/183/tIV/s405"},"text":"Pub. L. 102–183, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-04"},"text":"Dec. 4, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1267"},"text":"105 Stat. 1267","children":[],"tail":"; renumbered § 18, "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tIII/s304/a"},"text":"Pub. L. 102–496, title III, § 304(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3183"},"text":"106 Stat. 3183","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1f40c91-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1f40c92-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1f40c93-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified in a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s402"},"text":"section 402 of this title","children":[],"tail":" prior to editorial reclassification as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
