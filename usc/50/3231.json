{"tag":"section","attrib":{"id":"idd1c2008d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3231"},"text":null,"children":[{"tag":"num","attrib":{"value":"3231"},"text":"§ 3231.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability to United States intelligence activities of Federal laws implementing international treaties and agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1c2008e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3231/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No Federal law enacted on or after ","children":[{"tag":"date","attrib":{"date":"2000-12-27"},"text":"December 27, 2000","children":[],"tail":", that implements a treaty or other international agreement shall be construed as making unlawful an otherwise lawful and authorized intelligence activity of the United States Government or its employees, or any other person to the extent such other person is carrying out such activity on behalf of, and at the direction of, the United States, unless such Federal law specifically addresses such intelligence activity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c2008f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3231/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized intelligence activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An intelligence activity shall be treated as authorized for purposes of subsection (a) if the intelligence activity is authorized by an appropriate official of the United States Government, acting within the scope of the official duties of that official and in compliance with Federal law and any applicable Presidential directive.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1c20090-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title XI, § 1101, formerly title X, § 1001, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/567/tIII/s308/a"},"text":"Pub. L. 106–567, title III, § 308(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2839"},"text":"114 Stat. 2839","children":[],"tail":"; renumbered title XI, § 1101, "},{"tag":"ref","attrib":{"href":"/us/pl/107/306/tIII/s331/a/1"},"text":"Pub. L. 107–306, title III, § 331(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2394"},"text":"116 Stat. 2394","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1c20091-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1c20092-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1c20093-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s442"},"text":"section 442 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
