{"tag":"section","attrib":{"id":"idd154493f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1912"},"text":null,"children":[{"tag":"num","attrib":{"value":"1912"},"text":"§ 1912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for scholarship program for advanced English language studies by heritage community citizens","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1544940-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1912/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding from Intelligence Community Management Account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts that may be made available to the Secretary under the Fund for a fiscal year, the Director of National Intelligence shall transfer to the Secretary from amounts appropriated for the Intelligence Community Management Account for each of fiscal years 2005 through 2021 $2,000,000 to carry out the scholarship programs for English language studies by certain heritage community citizens under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1902/a/1/E"},"text":"section 1902(a)(1)(E) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1544941-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1912/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal years beginning with fiscal year 2022","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts that may be made available to the Secretary under the Fund for a fiscal year, there is authorized to be appropriated to the Secretary for each fiscal year, beginning with fiscal year 2022, $2,000,000, to carry out the scholarship programs for English language studies by certain heritage community citizens under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1902/a/1/E"},"text":"section 1902(a)(1)(E) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1544942-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1912/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts made available under this section shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1544943-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/183/tVIII/s812"},"text":"Pub. L. 102–183, title VIII, § 812","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/487/tVI/s603/b"},"text":"Pub. L. 108–487, title VI, § 603(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3954"},"text":"118 Stat. 3954","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dW/tVI/s619/c"},"text":"Pub. L. 116–260, div. W, title VI, § 619(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2401"},"text":"134 Stat. 2401","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1544944-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1544945-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1544946-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s619/c/1"},"text":"Pub. L. 116–260, § 619(c)(1)","children":[],"tail":", substituted “for each of fiscal years 2005 through 2021” for “for each fiscal year, beginning with fiscal year 2005,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s619/c/3"},"text":"Pub. L. 116–260, § 619(c)(3)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s619/c/2"},"text":"Pub. L. 116–260, § 619(c)(2)","children":[],"tail":", (4), redesignated subsec. (b) as (c) and substituted “this section” for “subsection (a)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
