{"tag":"section","attrib":{"id":"idd1d9cd08-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355c"},"text":null,"children":[{"tag":"num","attrib":{"value":"3355c"},"text":"§ 3355c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of national security information and other information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1d9cd09-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to limit the authority of the head of an agency to classify information or to continue the classification of information previously classified by that agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d9cd0a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special access programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to limit the authority of the head of an agency to grant or deny access to a special access program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d9cd0b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities of Director of National Intelligence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to limit the authorities of the Director of National Intelligence as the head of the intelligence community, including the Director’s responsibility to protect intelligence sources and methods from unauthorized disclosure as required by 3024(h) ","children":[{"tag":"ref","attrib":{"idref":"fn002097"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002097"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “section”."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d9cd0c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions to release of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to limit any exemption or exception to the release to the public under this subchapter of information that is protected under subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":" (commonly referred to as the “Freedom of Information Act”), or "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":" (commonly referred to as the “Privacy Act”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d9cd0d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding information from Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchaper shall be construed to authorize the withholding of information from Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1d9cd0e-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/567/tVII/s705"},"text":"Pub. L. 106–567, title VII, § 705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2861"},"text":"114 Stat. 2861","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tVI/s602/1"},"text":"Pub. L. 110–53, title VI, § 602(1)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/335"},"text":"121 Stat. 335","children":[],"tail":", 336; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dF/tLXVIII/s6824/d/3"},"text":"Pub. L. 117–263, div. F, title LXVIII, § 6824(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3615"},"text":"136 Stat. 3615","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dF/tLXIV/s6402/c/2/E"},"text":"Pub. L. 119–60, div. F, title LXIV, § 6402(c)(2)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1616"},"text":"139 Stat. 1616","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1d9cd0f-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1d9cd10-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1d9cd11-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out in a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"text":"section 3161 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1d9cd12-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “3024(h)” for “section 3024(i)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3024/i"},"text":"section 3024(i) of this title","children":[],"tail":"” for “section 103(c)(6) of the National Security Act of 1947”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53"},"text":"Pub. L. 110–53","children":[],"tail":" substituted “Director of National Intelligence” for “Director of Central Intelligence” in heading and text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
