{"tag":"section","attrib":{"id":"idd1d51392-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3350"},"text":null,"children":[{"tag":"num","attrib":{"value":"3350"},"text":"§ 3350.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount charged for declassification reviews","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In reviewing and processing a request by a person for the mandatory declassification of information pursuant to Executive Order No. 13526, a successor executive order, or any provision of law, the head of an element of the intelligence community—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d51393-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3350/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not charge the person reproduction fees in excess of the amount of fees that the head would charge the person for reproduction required in the course of processing a request for information under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":" (commonly referred to as the “Freedom of Information Act”); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d51394-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3350/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may waive or reduce any processing fees in the same manner as the head waives or reduces fees under such section 552.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1d51395-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/dN/tIII/s313"},"text":"Pub. L. 115–31, div. N, title III, § 313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/816"},"text":"131 Stat. 816","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1d51396-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1d51397-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1d51398-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order No. 13526, referred to in text, is Ex. Ord. No. 13526, ","children":[{"tag":"date","attrib":{"date":"2009-12-29"},"text":"Dec. 29, 2009","children":[],"tail":", 75 F.R. 707, 1013, which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"text":"section 3161 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1d51399-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd1d5139a-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “intelligence community” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/dN/s2"},"text":"section 2 of div. N of Pub. L. 115–31","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
