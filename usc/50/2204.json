{"tag":"section","attrib":{"id":"idd16031b2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2204"},"text":null,"children":[{"tag":"num","attrib":{"value":"2204"},"text":"§ 2204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16031b3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2204/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “appropriate congressional committees” means the Committee on Foreign Relations of the Senate and the Committee on Foreign Affairs of the House of Representatives, or, where required by law for certain reporting purposes, the Select Committee on Intelligence of the Senate and the Select ","children":[{"tag":"ref","attrib":{"idref":"fn002046"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002046"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “Permanent”."}],"tail":" Committee on Intelligence of the House of Representatives;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16031b4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2204/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “enemy” means any country, government, group, or person that has been engaged in hostilities, whether or not lawfully authorized, with the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd162a1b5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2204/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd162a1b6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2204/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any natural person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd162a1b7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2204/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any corporation, partnership, or other legal entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd162a1b8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2204/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any organization, association, or group; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd162a1b9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2204/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “spoils of war” means enemy movable property lawfully captured, seized, confiscated, or found which has become United States property in accordance with the laws of war.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd162a1ba-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tV/s555"},"text":"Pub. L. 103–236, title V, § 555","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/482"},"text":"108 Stat. 482","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
