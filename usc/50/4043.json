{"tag":"section","attrib":{"id":"idd20e4b59-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4043"},"text":null,"children":[{"tag":"num","attrib":{"value":"4043"},"text":"§ 4043.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of remedies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in section 4041 or 4042 of this title shall be construed to preclude or limit any remedy otherwise available under other law, including consequential and punitive damages.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd20e4b5a-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title VIII, § 803, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/275/tIII/s303/a"},"text":"Pub. L. 111–275, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-13"},"text":"Oct. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2877"},"text":"124 Stat. 2877","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd20e4b5b-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd20e4b5c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd20e4b5d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 597b of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","chil