{"tag":"section","attrib":{"id":"idd143a79d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1826"},"text":null,"children":[{"tag":"num","attrib":{"value":"1826"},"text":"§ 1826.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional oversight","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"On a semiannual basis the Attorney General shall fully inform the Permanent Select Committee on Intelligence and the Committee on the Judiciary of the House of Representatives and the Select Committee on Intelligence and the Committee on the Judiciary of the Senate concerning all physical searches conducted pursuant to this subchapter. On a semiannual basis the Attorney General shall also provide to those committees a report setting forth with respect to the preceding six-month period—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd143a79e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1826/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of applications made for orders approving physical searches under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd143a79f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1826/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of such orders either granted, modified, or denied;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd143a7a0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1826/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of physical searches which involved searches of the residences, offices, or personal property of United States persons, and the number of occasions, if any, where the Attorney General provided notice pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1825/b"},"text":"section 1825(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd143a7a1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1826/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of emergency physical searches authorized by the Attorney General under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1824/e"},"text":"section 1824(e) of this title","children":[],"tail":" and the total number of subsequent orders approving or denying such physical searches."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd143a7a2-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511/tIII/s306"},"text":"Pub. L. 95–511, title III, § 306","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/359/tVIII/s807/a/3"},"text":"Pub. L. 103–359, title VIII, § 807(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-14"},"text":"Oct. 14, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3451"},"text":"108 Stat. 3451","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/tI/s109/a"},"text":"Pub. L. 109–177, title I, § 109(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/204"},"text":"120 Stat. 204","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/23/tVI/s605/b"},"text":"Pub. L. 114–23, title VI, § 605(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-02"},"text":"June 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/298"},"text":"129 Stat. 298","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd143a7a3-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd143a7a4-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd143a7a5-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23"},"text":"Pub. L. 114–23","children":[],"tail":", in introductory provisions, substituted “Permanent Select Committee on Intelligence and the Committee on the Judiciary of the House of Representatives and the Select Committee on Intelligence and the Committee on the Judiciary of the Senate” for “Permanent Select Committee on Intelligence of the House of Representatives and the Select Committee on Intelligence of the Senate, and the Committee on the Judiciary of the Senate,” and struck out “and the Committee on the Judiciary of the House of Representatives” after “those committees”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s109/a/1"},"text":"Pub. L. 109–177, § 109(a)(1)","children":[],"tail":", (2), in introductory provisions, inserted “, and the Committee on the Judiciary of the Senate,” after “Select Committee on Intelligence of the Senate” and substituted “and the Committee on the Judiciary of the House of Representatives” for “and the Committees on the Judiciary of the House of Representatives and the Senate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s109/a/3"},"text":"Pub. L. 109–177, § 109(a)(3)","children":[],"tail":"–(5), added par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd143a7a6-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd143a7a7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1994-10-14"},"text":"Oct. 14, 1994","children":[],"tail":", with exception for certain physical searches approved by the Attorney General to gather foreign intelligence information, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/359/s807/c"},"text":"section 807(c) of Pub. L. 103–359","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1821"},"text":"section 1821 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
