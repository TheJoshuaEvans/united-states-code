{"tag":"section","attrib":{"id":"idd0fe894b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s523"},"text":null,"children":[{"tag":"num","attrib":{"value":"523"},"text":"§ 523.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment of civilian personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Air Force is authorized to employ such civilian personnel as may be necessary to carry out the purposes of this subchapter without regard to the limitation on maximum number of employees imposed by section 14(a) ","children":[{"tag":"ref","attrib":{"idref":"fn002009"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002009"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Federal Employees Pay Act of 1946 ("},{"tag":"ref","attrib":{"href":"/us/usc/t5/s947/g"},"text":"5 U.S.C. 947(g)","children":[],"tail":")."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd0fe894c-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-27/ch766"},"text":"Oct. 27, 1949, ch. 766","children":[],"tail":", title II, § 203, "},{"tag":"ref","attrib":{"href":"/us/stat/63/937"},"text":"63 Stat. 937","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd0fe894d-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd0fe894e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd0fe894f-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"te