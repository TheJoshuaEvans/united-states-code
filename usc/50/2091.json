{"tag":"section","attrib":{"id":"idd15de71a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2091"},"text":null,"children":[{"tag":"num","attrib":{"value":"2091"},"text":"§ 2091.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estimate of appropriations needed","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd15de71b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2091/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estimates of annual appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall prepare the estimates of the annual appropriations required to be made to the fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15de71c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2091/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actuarial valuations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall cause to be made actuarial valuations of the fund at such intervals as the Director determines to be necessary, but not less often than every five years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15de71d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2091/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Changes in law affecting actuarial status of fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any statute which authorizes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15de71e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2091/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new or increased benefits payable from the fund under this subchapter, including annuity increases other than under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2131"},"text":"section 2131 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15de71f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2091/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extension of the coverage of this subchapter to new groups of employees; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15de720-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2091/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increases in pay on which benefits are computed;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is deemed to authorize appropriations to the fund in order to provide funding for the unfunded liability created by that statute, in 30 equal annual installments with interest computed at the rate used in the then most recent valuation of the system and with the first payment thereof due as of the end of the fiscal year in which such new or liberalized benefit, extension of coverage, or increase in pay is effective.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15de721-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2091/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby authorized to be appropriated to the fund for each fiscal year such amounts as may be necessary to meet the amount of normal cost for each year that is not met by contributions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2021/a"},"text":"section 2021(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15de722-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2091/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unfunded liability; credit allowed for military service","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is hereby authorized to be appropriated to the fund for each fiscal year such sums as may be necessary to provide the amount equivalent to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15de723-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2091/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest on the unfunded liability computed for that year at the interest rate used in the then most recent valuation of the system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15de724-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2091/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that portion of disbursement for annuities for that year that the Director estimates is attributable to credit allowed for military service,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"less an amount determined by the Director to be appropriate to reflect the value of the deposits made to the credit of the fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2082/h"},"text":"section 2082(h) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd15de725-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/tII/s261"},"text":"Pub. L. 88–643, title II, § 261","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s802"},"text":"Pub. L. 102–496, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3234"},"text":"106 Stat. 3234","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd15de726-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd15de727-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd15de728-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/s261"},"text":"section 261 of Pub. L. 88–643","children":[],"tail":", title II, "},{"tag":"date","attrib":{"date":"1964-10-13"},"text":"Oct. 13, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1052"},"text":"78 Stat. 1052","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/522/tI/s102"},"text":"Pub. L. 94–522, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-17"},"text":"Oct. 17, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2467"},"text":"90 Stat. 2467","chi