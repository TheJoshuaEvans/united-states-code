{"tag":"section","attrib":{"id":"idd1cb9c6f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3323"},"text":null,"children":[{"tag":"num","attrib":{"value":"3323"},"text":"§ 3323.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for incentive awards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1cb9c70-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3323/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of authority with respect to Federal employees and members of Armed Forces","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of Central Intelligence may exercise the authority granted in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s4503"},"text":"section 4503 of title 5","children":[],"tail":", with respect to Federal employees and members of the Armed Forces detailed or assigned to the Central Intelligence Agency or to the Intelligence Community Staff, in the same manner as such authority may be exercised with respect to the personnel of the Central Intelligence Agency and the Intelligence Community Staff."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cb9c71-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3323/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for exercise of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority granted by subsection (a) of this section may be exercised with respect to Federal employees or members of the Armed Forces detailed or assigned to the Central Intelligence Agency or to the Intelligence Community Staff on or after a date five years before ","children":[{"tag":"date","attrib":{"date":"1983-12-09"},"text":"December 9, 1983","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cb9c72-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3323/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exercise of authority with respect to members of Armed Forces assigned to foreign intelligence duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During fiscal year 1987, the Director of Central Intelligence may exercise the authority granted in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s4503/2"},"text":"section 4503(2) of title 5","children":[],"tail":" with respect to members of the Armed Forces who are assigned to foreign intelligence duties at the time of the conduct which gives rise to the exercise of such authority."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cb9c73-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3323/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment and acceptance of award","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An award made by the Director of Central Intelligence to an employee or member of the Armed Forces under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s4503"},"text":"section 4503 of title 5","children":[],"tail":" or this section may be paid and accepted notwithstanding—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cb9c74-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3323/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5536"},"text":"section 5536 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9c75-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3323/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the death, separation, or retirement of the employee or the member of the Armed Forces whose conduct gave rise to the award, or the assignment of such member to duties other than foreign intelligence duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1cb9c76-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/215/tIV/s402"},"text":"Pub. L. 98–215, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-09"},"text":"Dec. 9, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1477"},"text":"97 Stat. 1477","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/569/tV/s503"},"text":"Pub. L. 99–569, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3198"},"text":"100 Stat. 3198","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1cb9c77-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1cb9c78-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1cb9c79-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s403e–1"},"text":"section 403e–1 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1cb9c7a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/569"},"text":"Pub. L. 99–569","children":[],"tail":" added subsecs. (c) and (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1cb9c7b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idd1cb9c7c-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to the Director of Central Intelligence or the Director of the Central Intelligence Agency in the Director’s capacity as the head of the intelligence community deemed to be a reference to the Director of National Intelligence. Reference to the Director of Central Intelligence or the Director of the Central Intelligence Agency in the Director’s capacity as the head of the Central Intelligence Agency deemed to be a reference to the Director of the Central Intelligence Agency. See section 1081(a), (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
