{"tag":"section","attrib":{"id":"idd1cb9cf5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3333"},"text":null,"children":[{"tag":"num","attrib":{"value":"3333"},"text":"§ 3333.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint facilities certification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1cb9cf6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3333/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cb9cf7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3333/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of National Intelligence set a strategic goal to use joint facilities as a means to save costs by consolidating administrative and support functions across multiple elements of the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9cf8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3333/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The use of joint facilities provides more opportunities for operational collaboration and information sharing among elements of the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cb9cf9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3333/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before an element of the intelligence community purchases, leases, or constructs a new facility that is 20,000 square feet or larger, the head of that element of the intelligence community shall submit to the Director of National Intelligence—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cb9cfa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3333/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a written certification that, to the best of the knowledge of the head of such element, all prospective joint facilities in the vicinity have been considered and the element is unable to identify a joint facility that meets the operational requirements of such element; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9cfb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3333/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a written statement listing the reasons for not participating in the prospective joint facilities considered by the element.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1cb9cfc-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/dN/tVI/s604"},"text":"Pub. L. 115–31, div. N, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/830"},"text":"131 Stat. 830","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1cb9cfd-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1cb9cfe-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd1cb9cff-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “intelligence community” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/dN/s2"},"text":"section 2 of div. N of Pub. L. 115–31","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
