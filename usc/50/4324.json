{"tag":"section","attrib":{"id":"idd223ce8b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4324"},"text":null,"children":[{"tag":"num","attrib":{"value":"4324"},"text":"§ 4324.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return by Custodian, to United States, of payments under licenses, assignments or sales of patents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Alien Property Custodian is authorized and directed to return to the United States any consideration paid to him by the United States under any license, assignment, or sale by the Alien Property Custodian to the United States of any patent (or any right therein or claim thereto, and including an application therefor and any patent issued pursuant to any such application).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd223ce8c-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-10-06/ch106/s27"},"text":"Oct. 6, 1917, ch. 106, § 27","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1928-03-10/ch167/s15"},"text":"Mar. 10, 1928, ch. 167, § 15","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/274"},"text":"45 Stat. 274","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd223ce8d-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd223ce8e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd223ce8f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 27 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idd223ce90-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idd223ce91-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions vested by law in Alien Property Custodian and Office of Alien Property Custodian transferred to Attorney General by Reorg. Plan No. 1 of 1947, § 101, eff. ","children":[{"tag":"date","attrib":{"date":"1947-07-01"},"text":"July 1, 1947","children":[],"tail":", 12 F.R. 4534, "},{"tag":"ref","attrib":{"href":"/us/stat/61/951"},"text":"61 Stat. 951","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
