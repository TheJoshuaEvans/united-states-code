{"tag":"section","attrib":{"id":"idd15b7586-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2056"},"text":null,"children":[{"tag":"num","attrib":{"value":"2056"},"text":"§ 2056.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for annuity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd15b7587-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2056/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" One-out-of-two requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A participant must complete, within the last two years before any separation from service (except a separation because of death or disability) at least one year of creditable civilian service during which the participant is subject to this subchapter and in a pay status before the participant or the participant’s survivors are eligible for an annuity under this subchapter based on that separation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15b7588-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2056/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refund of contributions for time not allowed for credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a participant (other than a participant separated from the service because of death or disability) fails to meet the service and pay status requirement of subsection (a), any amounts deducted from the participant’s pay during the period for which no eligibility is established based on the separation shall be returned to the participant on the separation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15b7589-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2056/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Failure to meet the service and pay status requirement of subsection (a) shall not deprive the participant or the participant’s survivors of any annuity to which they may be entitled under this subchapter based on a previous separation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd15b758a-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/tII/s236"},"text":"Pub. L. 88–643, title II, § 236","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s802"},"text":"Pub. L. 102–496, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3226"},"text":"106 Stat. 3226","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd15b758b-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd15b758c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd15b758d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/s236"},"text":"section 236 of Pub. L. 88–643","children":[],"ta