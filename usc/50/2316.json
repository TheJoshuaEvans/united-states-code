{"tag":"section","attrib":{"id":"idd162a223-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2316"},"text":null,"children":[{"tag":"num","attrib":{"value":"2316"},"text":"§ 2316.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions to increase civilian expertise","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd162a224-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2316/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" to (c) Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd162a225-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2316/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civilian expertise","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall take reasonable measures to reduce the reliance of civilian law enforcement officials on Department of Defense resources to counter the threat posed by the use or potential use of biological and chemical weapons of mass destruction within the United States. The measures shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd162a226-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2316/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions to increase civilian law enforcement expertise to counter such a threat; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd162a227-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2316/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions to improve coordination between civilian law enforcement officials and other civilian sources of expertise, within and outside the Federal Government, to counter such a threat.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd162a228-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2316/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall submit to Congress the following reports:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd162a229-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2316/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1996-09-23"},"text":"September 23, 1996","children":[],"tail":", a report describing the respective policy functions and operational roles of Federal agencies in countering the threat posed by the use or potential use of biological and chemical weapons of mass destruction within the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd162a22a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2316/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than one year after ","children":[{"tag":"date","attrib":{"date":"1996-09-23"},"text":"September 23, 1996","children":[],"tail":", a report describing—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd162a22b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2316/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actions planned to be taken to carry out subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd162a22c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2316/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of such actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd162a22d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2316/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than three years after ","children":[{"tag":"date","attrib":{"date":"1996-09-23"},"text":"September 23, 1996","children":[],"tail":", a report updating the information provided in the reports submitted pursuant to paragraphs (1) and (2), including the measures taken pursuant to subsection (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd162a22e-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXIV/s1416"},"text":"Pub. L. 104–201, div. A, title XIV, § 1416","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2721"},"text":"110 Stat. 2721","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd162a22f-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd162a230-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd162a231-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of subsecs. (d) and (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1416"},"text":"section 1416 of Pub. L. 104–201","children":[],"tail":". Subsecs. (a) to (c) of section 1416 enacted section 382 (now 282) of Title 10, Armed Forces, and sections 175a and 2332d of Title 18, Crimes and Criminal Procedure, and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s372"},"text":"section 372 of Title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
