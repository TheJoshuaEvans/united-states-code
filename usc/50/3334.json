{"tag":"section","attrib":{"id":"idd1cb9d00-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334"},"text":null,"children":[{"tag":"num","attrib":{"value":"3334"},"text":"§ 3334.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intelligence community public-private talent exchange","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1cb9d01-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policies, processes, and procedures required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cb9d02-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 270 days after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", the Director of National Intelligence shall develop policies, processes, and procedures to facilitate the rotation of personnel of the intelligence community to the private sector, and personnel from the private sector to the intelligence community."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9d03-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Focus areas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall ensure that the policies, processes, and procedures developed pursuant to paragraph (1) require exchanges under this section that relate to intelligence or counterintelligence with a focus on rotations described in such paragraph with private-sector organizations in the following fields:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1cb9d04-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Finance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cb9d05-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Acquisition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cb9d06-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Biotechnology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cb9d07-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Computing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cb9d08-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Artificial intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cb9d09-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Business process innovation and entrepreneurship.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cb9d0a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cybersecurity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cb9d0b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Materials and manufacturing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cb9d0c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other technology or research field the Director determines relevant to meet evolving national security threats in technology sectors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cb9d0d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detail authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under policies developed by the Director pursuant to subsection (a), pursuant to a written agreement with a private-sector organization, and with the consent of the employee, a head of an element of the intelligence community may arrange for the temporary detail of an employee of such element to such private-sector organization, or from such private-sector organization to such element under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cb9d0e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cb9d0f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A head of an element of the intelligence community exercising the authority of the head under subsection (a) shall provide for a written agreement among the element of the intelligence community, the private-sector organization, and the employee concerned regarding the terms and conditions of the employee’s detail under this section. The agreement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1cb9d10-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall require that the employee of the element, upon completion of the detail, serve in the element, or elsewhere in the civil service if approved by the head of the element, for a period that is at least equal to the length of the detail;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cb9d11-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide that if the employee of the element fails to carry out the agreement, such employee shall be liable to the United States for payment of all nonsalary and benefit expenses of the detail, unless that failure was for good and sufficient reason, as determined by the head of the element;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cb9d12-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall contain language informing such employee of the prohibition on sharing, using, or otherwise improperly handling classified or unclassified nonpublic information for the benefit or advantage of the private-sector organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cb9d13-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall contain language governing the handling of classified information by such employee during the detail; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cde604-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall contain language requiring the employee to acknowledge the obligations of the employee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1905"},"text":"section 1905 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde605-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An amount for which an employee is liable under paragraph (1) shall be treated as a debt due the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde606-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of an element of the intelligence community may waive, in whole or in part, collection of a debt described in paragraph (2) based on a determination that the collection would be against equity and good conscience and not in the best interests of the United States, after taking into account any indication of fraud, misrepresentation, fault, or lack of good faith on the part of the employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cde607-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A detail under this section may, at any time and for any reason, be terminated by the head of the element of the intelligence community concerned or the private-sector organization concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cde608-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cde609-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A detail under this section shall be for a period of not less than 3 months and not more than 2 years, renewable up to a total of 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde60a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Longer periods","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A detail under this section may be for a period in excess of 2 years, but not more than 5 years, if the head of the element making the detail determines that such detail is necessary to meet critical mission or program requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde60b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No employee of an element of the intelligence community may be detailed under this section for more than a total of 5 years, inclusive of all such details.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cde60c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of Federal employees detailed to private-sector organizations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cde60d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An employee of an element of the intelligence community who is detailed to a private-sector organization under this section shall be considered, during the period of detail, to be on a regular work assignment in the element. The written agreement established under subsection (c)(1) shall address the specific terms and conditions related to the employee’s continued status as a Federal employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde60e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing a temporary detail of an employee of an element of the intelligence community to a private-sector organization, the head of the element shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1cde60f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify that the temporary detail of such employee shall not have an adverse or negative impact on mission attainment or organizational capabilities associated with the detail; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cde610-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an element of the intelligence community in the Department of Defense, ensure that the normal duties and functions of such employees are not, as a result of and during the course of such temporary detail, performed or augmented by contractor personnel in violation of the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2461"},"text":"section 2461 of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cde611-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions for private-sector employees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An employee of a private-sector organization who is detailed to an element of the intelligence community under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cde612-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall continue to receive pay and benefits from the private-sector organization from which such employee is detailed and shall not receive pay or benefits from the element, except as provided in paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde613-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is deemed to be an employee of the element for the purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1cde614-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapters 73 and 81 of title 5;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cde615-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 201, 203, 205, 207, 208, 209, 603, 606, 607, 643, 654, 1905, and 1913 of title 18;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cde616-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 1343, 1344, and 1349(b) of title 31;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cde617-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 171 of title 28 (commonly known as the “Federal Tort Claims Act”) and any other Federal tort liability statute;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cde618-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/g/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Ethics in Government Act of 1978 (5 U.S.C. App.); ","children":[{"tag":"ref","attrib":{"idref":"fn002085"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002085"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cde619-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/g/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 21 of title 41;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde61a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may perform work that is considered inherently governmental in nature only when requested in writing by the head of the element;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde61b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be used to circumvent any limitation or restriction on the size of the workforce of the element;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde61c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be subject to the same requirements applicable to an employee performing the same functions and duties proposed for performance by the private-sector employee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde61d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/g/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an element of the intelligence community in the Department of Defense, may not be used to circumvent the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2461"},"text":"section 2461 of title 10","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde61e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/g/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not have access to any trade secrets or proprietary information which is of commercial value or competitive advantage to the private-sector organization from which such employee is detailed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cde61f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against charging certain costs to the Federal Government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A private-sector organization may not charge an element of the intelligence community or any other agency of the Federal Government, as direct costs under a Federal contract, the costs of pay or benefits paid by the organization to an employee detailed to an element of the intelligence community under this section for the period of the detail and any subsequent renewal periods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cde620-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organizational conflicts of interest","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cde621-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A private-sector organization that temporarily details a member of its workforce to an element of the intelligence community or that accepts the temporary detail of a member of the intelligence community shall not be considered to have an organizational conflict of interest with the element of the intelligence community solely because of participation in the program established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde622-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of conflicts of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the identification of an organizational conflict of interest arises based on the particular facts surrounding an individual’s participation in the program established under this section and the nature of any contract, then the heads of intelligence community elements shall implement a system to avoid, neutralize, or mitigate any such organizational conflicts of interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cde623-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002086"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002086"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. There are two subsecs. (j)."}],"tail":" Additional administrative matters"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Director, pursuant to procedures developed under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cde624-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall, to the degree practicable, ensure that small business concerns are represented with respect to details authorized by this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde625-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, notwithstanding any other provision of law, establish criteria for elements of the intelligence community to use appropriated funds to reimburse small business concerns for the salaries and benefits of its employees during the periods when the small business concern agrees to detail its employees to the intelligence community under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde626-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall take into consideration the question of how details under this section might best be used to help meet the needs of the intelligence community, including with respect to the training of employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde627-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/j/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall take into consideration areas of private-sector expertise that are critical to the intelligence community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde628-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/j/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall establish oversight mechanisms to determine whether the public-private exchange authorized by this section improves the efficiency and effectiveness of the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cde629-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" Definitions"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cde62a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detail","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “detail” means, as appropriate in the context in which such term is used—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1cde62b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/j/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assignment or loan of an employee of an element of the intelligence community to a private-sector organization without a change of position from the intelligence community element that employs the individual; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cde62c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/j/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assignment or loan of an employee of a private-sector organization to an element of the intelligence community without a change of position from the private-sector organization that employs the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde62d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private-sector organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “private-sector organization” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1cde62e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/j/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a for-profit organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cde62f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/j/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a not-for-profit organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde630-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small business concern","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “small business concern” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3703/e/2"},"text":"section 3703(e)(2) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1cde631-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLIII/s5306"},"text":"Pub. L. 116–92, div. E, title LIII, § 5306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2122"},"text":"133 Stat. 2122","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dF/tLXV/s6506/a"},"text":"Pub. L. 118–159, div. F, title LXV, § 6506(a)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2496"},"text":"138 Stat. 2496","children":[],"tail":", 2497.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1cde632-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1cde633-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1cde634-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Ethics in Government Act of 1978, referred to in subsec. (g)(2)(E), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/521"},"text":"Pub. L. 95–521","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-26"},"text":"Oct. 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1824"},"text":"92 Stat. 1824","children":[],"tail":". Titles I, IV, and V of the Act were classified principally to the Appendix to Title 5, Government Organization and Employees, and were substantially repealed and restated in chapter 131 (§ 13101 et seq.) of Title 5 by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":", §§ 3(c), 7, "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4266"},"text":"136 Stat. 4266","children":[],"tail":", 4361. For complete classification of this Act to the Code, see Tables. For disposition of sections of the Act into chapter 131 of Title 5, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s101"},"text":"section 101 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1cde635-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s6506/a"},"text":"Pub. L. 118–159, § 6506(a)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s6506/b"},"text":"Pub. L. 118–159, § 6506(b)","children":[],"tail":", substituted “5 years” for “3 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s6506/c"},"text":"Pub. L. 118–159, § 6506(c)","children":[],"tail":", added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (i), (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s6506/d"},"text":"Pub. L. 118–159, § 6506(d)","children":[],"tail":", added subsec. (i) and redesignated former subsec. (i) as (j) relating to additional administrative matters."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1cde636-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd1cde637-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “intelligence community” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/s5003"},"text":"section 5003 of div. E of Pub. L. 116–92","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
