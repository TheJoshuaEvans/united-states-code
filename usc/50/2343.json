{"tag":"section","attrib":{"id":"idd1651289-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2343"},"text":null,"children":[{"tag":"num","attrib":{"value":"2343"},"text":"§ 2343.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters relating to the international materials protection, control, and accounting program of the Department of Energy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd165128a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2343/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Radiological dispersal device materials protection, control, and accounting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Energy may establish within the International Materials Protection, Control, and Accounting program of the Department of Energy a program on the protection, control, and accounting of materials usable in radiological dispersal devices. In establishing such program, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd165128b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2343/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the sites and radiological materials to be covered by such program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd165128c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2343/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out a risk assessment of such radiological materials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd165128d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2343/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and establish the costs of and schedules for such program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd165128e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2343/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revised focus for materials protection, control, and accounting program of Russian Federation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd165128f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2343/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Energy shall work cooperatively with the Russian Federation to develop, as soon as practicable but not later than ","children":[{"tag":"date","attrib":{"date":"2018-01-01"},"text":"January 1, 2018","children":[],"tail":", a sustainable nuclear materials protection, control, and accounting system for the nuclear materials of the Russian Federation that is supported solely by the Russian Federation."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1651290-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2343/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall work with the Russian Federation to identify various alternatives to provide the United States adequate transparency in the nuclear materials protection, control, and accounting program of the Russian Federation to assure that such program is meeting applicable goals for nuclear materials protection, control, and accounting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1651291-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2343/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount for activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount authorized to be appropriated by section 3101(a)(2) ","children":[{"tag":"ref","attrib":{"idref":"fn002053"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002053"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" for the Department of Energy for the National Nuclear Security Administration for defense nuclear nonproliferation, up to $5,000,000 may be available for carrying out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1651292-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dC/tXXXI/s3156"},"text":"Pub. L. 107–314, div. C, title XXXI, § 3156","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2739"},"text":"116 Stat. 2739","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dC/tXXXI/s3119"},"text":"Pub. L. 111–383, div. C, title XXXI, § 3119","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4514"},"text":"124 Stat. 4514","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1651293-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1651294-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1651295-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 3101(a)(2), referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s3101/a/2"},"text":"section 3101(a)(2) of Pub. L. 107–314","children":[],"tail":", div. C, title XXXI, "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2729"},"text":"116 Stat. 2729","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1651296-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Bob Stump National Defense Authorization Act for Fiscal Year 2003, and not as part of the Defense Against Weapons of Mass Destruction Act of 1996 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1651297-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2018-01-01"},"text":"January 1, 2018","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2013-01-01"},"text":"January 1, 2013","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
