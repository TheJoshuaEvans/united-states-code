{"tag":"section","attrib":{"id":"idd14d1db5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1881e"},"text":"§ 1881e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of information acquired under this subchapter","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd14d1db6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information acquired under section 1881a","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd14d1db7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Information acquired from an acquisition conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1881a"},"text":"section 1881a of this title","children":[],"tail":" shall be deemed to be information acquired from an electronic surveillance pursuant to subchapter I for purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1806"},"text":"section 1806 of this title","children":[],"tail":", except for the purposes of subsection (j) of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14d1db8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States persons","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd14d1db9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881e/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any information concerning a United States person acquired under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1881a"},"text":"section 1881a of this title","children":[],"tail":" shall not be used in evidence against that United States person pursuant to paragraph (1) in any criminal proceeding unless—"}],"tail":null},{"tag":"clause","attrib":{"id":"idd14d1dba-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881e/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Bureau of Investigation obtained an order of the Foreign Intelligence Surveillance Court to access such information pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1881a/f/2"},"text":"section 1881a(f)(2) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd14d1dbb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881e/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Attorney General determines that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idd14d1dbc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881e/a/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the criminal proceeding affects, involves, or is related to the national security of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd14d1dbd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881e/a/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the criminal proceeding involves—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idd14d1dbe-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881e/a/2/A/ii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" death;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idd14d1dbf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881e/a/2/A/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" kidnapping;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idd14d1dc0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881e/a/2/A/ii/II/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serious bodily injury, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1365"},"text":"section 1365 of title 18","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idd14d1dc1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881e/a/2/A/ii/II/dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"dd"},"text":"(dd)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct that constitutes a criminal offense that is a specified offense against a minor, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20911"},"text":"section 20911 of title 34","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idd14d1dc2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881e/a/2/A/ii/II/ee"},"text":null,"children":[{"tag":"num","attrib":{"value":"ee"},"text":"(ee)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incapacitation or destruction of critical infrastructure, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5195c/e"},"text":"section 5195c(e) of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idd14d1dc3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881e/a/2/A/ii/II/ff"},"text":null,"children":[{"tag":"num","attrib":{"value":"ff"},"text":"(ff)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cybersecurity, including conduct described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5195c/e"},"text":"section 5195c(e) of title 42","children":[],"tail":" or section 1029, 1030, or 2511 of title 18;"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idd14d1dc4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881e/a/2/A/ii/II/gg"},"text":null,"children":[{"tag":"num","attrib":{"value":"gg"},"text":"(gg)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transnational crime, including transnational narcotics trafficking and transnational organized crime; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idd14d1dc5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881e/a/2/A/ii/II/hh"},"text":null,"children":[{"tag":"num","attrib":{"value":"hh"},"text":"(hh)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" human trafficking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14d1dc6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881e/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No judicial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A determination by the Attorney General under subparagraph (A)(ii) is not subject to judicial review.","children":[],"tail