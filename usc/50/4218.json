/173"},"text":"56 Stat. 173","children":[],"tail":", which was classified to section 97a of former Title 18, Criminal Code and Criminal Procedure, and was repealed by "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645/s21"},"text":"act of June 25, 1948, ch. 645, § 21","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/868"},"text":"62 Stat. 868","children":[],"tail":" and reenacted as "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1383"},"text":"section 1383 of Title 18","children":[],"tail":", Crimes and Criminal Procedure. "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1383"},"text":"Section 1383 of Title 18","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/94/412/tV/s501/e"},"text":"Pub. L. 94–412, title V, § 501(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-14"},"text":"Sept. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1258"},"text":"90 Stat. 1258","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Commission on Wartime Relocation and Internment of Civilians Act, referred to in par. (6), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/317"},"text":"Pub. L. 96–317","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-07-31"},"text":"July 31, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/964"},"text":"94 Stat. 964","children":[],"tail":", which was classified as a note under section 1981 of the former Appendix to this title and was omitted from the Code due to termination of the Commission not later than 90 days after "},{"tag":"date","attrib":{"date":"1983-06-30"},"text":"June 30, 1983","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd217e7c8-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section wa