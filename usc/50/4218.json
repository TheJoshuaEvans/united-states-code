{"tag":"section","attrib":{"id":"idd217e7b6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4218"},"text":null,"children":[{"tag":"num","attrib":{"value":"4218"},"text":"§ 4218.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd217e7b7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4218/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “evacuation, relocation, and internment period” means that period beginning on ","children":[{"tag":"date","attrib":{"date":"1941-12-07"},"text":"December 7, 1941","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1946-06-30"},"text":"June 30, 1946","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e7b8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4218/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “eligible individual” means any individual of Japanese ancestry, or the spouse or a parent of an individual of Japanese ancestry, who is living on ","children":[{"tag":"date","attrib":{"date":"1988-08-10"},"text":"August 10, 1988","children":[],"tail":", and who, during the evacuation, relocation, and internment period—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd217e7b9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4218/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was a United States citizen or a permanent resident alien; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd217e7ba-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4218/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd217e7bb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4218/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" was confined, held in custody, relocated, or otherwise deprived of liberty or property as a result of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idd217e7bc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4218/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Executive Order Numbered 9066, dated ","children":[{"tag":"date","attrib":{"date":"1942-02-19"},"text":"February 19, 1942","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd217e7bd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4218/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Act entitled “An Act to provide a penalty for violation of restrictions or orders with respect to persons entering, remaining in, leaving, or committing any act in military areas or zones”, approved ","children":[{"tag":"date","attrib":{"date":"1942-03-21"},"text":"March 21, 1942","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/56/173"},"text":"56 Stat. 173","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd217e7be-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4218/2/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other Executive order, Presidential proclamation, law of the United States, directive of the Armed Forces of the United States, or other action taken by or on behalf of the United States or its agents, representatives, officers, or employees, respecting the evacuation, relocation, or internment of individuals solely on the basis of Japanese ancestry; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd217e7bf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4218/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was enrolled on the records of the United States Government during the period beginning on ","children":[{"tag":"date","attrib":{"date":"1941-12-07"},"text":"December 7, 1941","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1946-06-30"},"text":"June 30, 1946","children":[],"tail":", as being in a prohibited military zone;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that the term “eligible individual” does not include any individual who, during the period beginning on ","children":[{"tag":"date","attrib":{"date":"1941-12-07"},"text":"December 7, 1941","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1945-09-02"},"text":"September 2, 1945","children":[],"tail":", relocated to a country while the United States was at war with that country;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e7c0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4218/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “permanent resident alien” means an alien lawfully admitted into the United States for permanent residence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e7c1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4218/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Fund” means the Civil Liberties Public Education Fund established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4214"},"text":"section 4214 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e7c2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4218/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Board” means the Civil Liberties Public Education Fund Board of Directors established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4216"},"text":"section 4216 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e7c3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4218/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Commission” means the Commission on Wartime Relocation and Internment of Civilians, established by the Commission on Wartime Relocation and Internment of Civilians Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/317"},"text":"Public Law 96–317","children":[],"tail":"; 50 U.S.C. App. 1981 note)."},{"tag":"ref","attrib":{"idref":"fn002127"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002127"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd217e7c4-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/383/tI/s108"},"text":"Pub. L. 100–383, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"198