{"tag":"section","attrib":{"id":"idd1d9cd34-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355f"},"text":null,"children":[{"tag":"num","attrib":{"value":"3355f"},"text":"§ 3355f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1d9cd35-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is hereby authorized to be appropriated to carry out the provisions of this subchapter amounts as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d9cd36-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2001, $650,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d9cd37-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each fiscal year after fiscal year 2001, such sums as may be necessary for such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d9cd38-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding requests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall include in the budget submitted to Congress for each fiscal year under ","children":[{"ta