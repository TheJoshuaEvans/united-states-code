{"tag":"section","attrib":{"id":"idd1e8256a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516"},"text":null,"children":[{"tag":"num","attrib":{"value":"3516"},"text":"§ 3516.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health benefits for certain former spouses of Central Intelligence Agency employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1e8256b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons eligible","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (e), any individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1e8256c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" formerly married to an employee or former employee of the Agency, whose marriage was dissolved by divorce or annulment before ","children":[{"tag":"date","attrib":{"date":"1985-05-07"},"text":"May 7, 1985","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1e8256d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, at any time during the eighteen-month period before the divorce or annulment became final, was covered under a health benefits plan as a member of the family of such employee or former employee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1e8256e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who was married to such employee for not less than ten years during periods of service by such employee with the Agency, at least five years of which were spent outside the United States by both the employee and the former spouse,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is eligible for coverage under a health benefits plan in accordance with the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1e8256f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enrollment for health benefits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1e82570-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any individual eligible for coverage under subsection (a) may enroll in a health benefits plan for self alone or for self and family if, before the expiration of the six-month period beginning on ","children":[{"tag":"date","attrib":{"date":"1986-10-01"},"text":"October 1, 1986","children":[],"tail":", and in accordance with such procedures as the Director of the Office of Personnel Management shall by regulation prescribe, such individual—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1e82571-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" files an election for such enrollment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1e82572-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arranges to pay currently into the Employees Health Benefits Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8909"},"text":"section 8909 of title 5","children":[],"tail":" an amount equal to the sum of the employee and agency contributions payable in the case of an employee enrolled under chapter 89 of such title in the same health benefits plan and with the same level of benefits."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1e82573-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director of the Central Intelligence Agency shall, as soon as possible, take all steps practicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1e82574-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine the identity and current address of each former spouse eligible for coverage under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1e82575-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to notify each such former spouse of that individual’s rights under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1e82576-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Personnel Management, upon notification by the Director of the Central Intelligence Agency, shall waive the six-month limitation set forth in paragraph (1) in any case in which the Director of the Central Intelligence Agency determines that the circumstances so warrant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1e82577-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility of former wives or husbands","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1e82578-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding subsections (a) and (b) and except as provided in subsections (d), (e), and (f), an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1e82579-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who was divorced on or before ","children":[{"tag":"date","attrib":{"date":"1991-12-04"},"text":"December 4, 1991","children":[],"tail":", from a participant or retired participant in the Central Intelligence Agency Retirement and Disability System or the Federal Employees Retirement System Special Category;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1e8257a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who was married to such participant for not less than ten years during the participant’s creditable service, at least five years of which were spent by the participant during the participant’s service as an employee of the Agency outside the United States, or otherwise in a position the duties of which qualified the participant for designation by the Director as a participant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2013"},"text":"section 2013 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1e8257b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who was enrolled in a health benefits plan as a family member at any time during the 18-month period before the date of dissolution of the marriage to such participant;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is eligible for coverage under a health benefits plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1e8257c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A former spouse eligible for coverage under paragraph (1) may enroll in a health benefits plan in accordance with subsection (b)(1), except that the election for such enrollment must be submitted within 60 days after the date on which the Director notifies the former spouse of such individual’s eligibility for health insurance coverage under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1e8257d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsections (a), (b), and (c) and except as provided in subsections (e) and (f), an individual divorced on or before ","children":[{"tag":"date","attrib":{"date":"1991-12-04"},"text":"December 4, 1991","children":[],"tail":", from a participant or retired participant in the Central Intelligence Agency Retirement and Disability System or Federal Employees’ Retirement System Special Category who enrolled in a health benefits plan following the dissolution of the marriage to such participant may continue enrollment following the death of such participant notwithstanding the termination of the retirement annuity of such individual."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1e8257e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remarriage before age fifty-five; continued enrollment; restored eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1e8257f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any former spouse who remarries before age fifty-five is not eligible to make an election under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1e82580-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any former spouse enrolled in a health benefits plan pursuant to an election under subsection (b)(1) or to subsection (d) may continue the enrollment under the conditions of eligibility which the Director of the Office of Personnel Management shall by regulation prescribe, except that any former spouse who remarries before age fifty-five shall not be eligible for continued enrollment under this section after the end of the thirty-one-day period beginning on the date of remarriage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1e82581-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1e82582-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A former spouse who is not eligible to enroll or to continue enrollment in a health benefits plan under this section solely because of remarriage before age fifty-five shall be restored to such eligibility on the date such remarriage is dissolved by death, annulment, or divorce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1e82583-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A former spouse whose eligibility is restored under subparagraph (A) may, under regulations which the Director of the Office of Personnel Management shall prescribe, enroll in a health benefits plan if such former spouse—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1e82584-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was an individual referred to in paragraph (1) and was an individual covered under a benefits plan as a family member at any time during the 18-month period before the date of dissolution of the marriage to the Agency employee or annuitant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1e82585-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was an individual referred to in paragraph (2) and was an individual covered under a benefits plan immediately before the remarriage ended the enrollment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1e82586-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enrollment in health benefits plan under other authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No individual may be covered by a health benefits plan under this section during any period in which such individual is enrolled in a health benefits plan under any other authority, nor may any individual be covered under more than one enrollment under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1e82587-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3516/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Health benefits plan” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section the term “health benefits plan” means an approved health benefits plan under chapter 89 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1e82588-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-20/ch227/s16"},"text":"June 20, 1949, ch. 227, § 16","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/569/tIII/s303/a"},"text":"Pub. L. 99–569, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3194"},"text":"100 Stat. 3194","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/88/tIII/s307/c"},"text":"Pub. L. 102–88, title III, § 307(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/433"},"text":"105 Stat. 433","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/178/tII/s203/c"},"text":"Pub. L. 103–178, title II, § 203(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2031"},"text":"107 Stat. 2031","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI/s1071/b/2/B"},"text":"Pub. L. 108–458, title I, § 1071(b)(2)(B)","children":[],"tail":", (b)(3)(B), (C), "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3690"},"text":"118 Stat. 3690","children":[],"tail":", 3691.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1e82589-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1e8258a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1e8258b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s403p"},"text":"section 403p of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1e8258c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1071/b/3/B"},"text":"Pub. L. 108–458, § 1071(b)(3)(B)","children":[],"tail":", substituted “Director of the Central Intelligence Agency” for “Director of Central Intelligence” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1071/b/3/C"},"text":"Pub. L. 108–458, § 1071(b)(3)(C)","children":[],"tail":", substituted “Director of the Central Intelligence Agency” for “Director of Central Intelligence” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1071/b/2/B"},"text":"Pub. L. 108–458, § 1071(b)(2)(B)","children":[],"tail":", struck out “of Central Intelligence” after “Director”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/178/s203/c/2/A"},"text":"Pub. L. 103–178, § 203(c)(2)(A)","children":[],"tail":", substituted “subsection (e)” for “subsection (c)(1)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/178/s203/c/1"},"text":"Pub. L. 103–178, § 203(c)(1)","children":[],"tail":", added subsecs. (c) and (d). Former subsecs. (c) and (d) redesignated (e) and (f), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/178/s203/c/2/B"},"text":"Pub. L. 103–178, § 203(c)(2)(B)","children":[],"tail":", inserted “or to subsection (d)” after “subsection (b)(1)” in par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/178/s203/c/1/A"},"text":"Pub. L. 103–178, § 203(c)(1)(A)","children":[],"tail":", redesignated subsec. (c) as (e). Former subsec. (e) redesignated (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/178/s203/c/1/A"},"text":"Pub. L. 103–178, § 203(c)(1)(A)","children":[],"tail":", redesignated subsecs. (d) and (e) as (f) and (g), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/88"},"text":"Pub. L. 102–88","children":[],"tail":" added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1e8258d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd1e8258e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For Determination by President that amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" take effect on "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", see Memorandum of President of the United States, "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", 70 F.R. 23925, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" effective not later than six months after "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1097/a"},"text":"section 1097(a) of Pub. L. 108–458","children":[],"tail":", set out in an Effective Date of 2004 Amendment; Transition Provisions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd1e8258f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/178/s203/c"},"text":"section 203(c) of Pub. L. 103–178","children":[],"tail":" applicable to individuals on and after "},{"tag":"date","attrib":{"date":"1994-10-01"},"text":"Oct. 1, 1994","children":[],"tail":", with no benefits provided pursuant to section 203(c) payable with respect to any period before "},{"tag":"date","attrib":{"date":"1994-10-01"},"text":"Oct. 1, 1994","children":[],"tail":", except that subsec. (d) of this section applicable to individuals beginning "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/10