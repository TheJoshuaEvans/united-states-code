{"tag":"section","attrib":{"id":"idd0f9a6b3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s213"},"text":null,"children":[{"tag":"num","attrib":{"value":"213"},"text":"§ 213.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of confiscation proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Such prizes and capture shall be condemned in the district court of the United States having jurisdiction of the amount, or in admiralty in any district in which the same may be seized, or into which they may be taken and proceedings first instituted.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd0f9a6b4-47c4-11f1-8bcf-c89722bddd2e"},"text":"(R.S. § 5309; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1877-02-27/ch69/s1"},"text":"Feb. 27, 1877, ch. 69, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/19/253"},"text":"19 Stat. 253","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s291"},"text":"Mar. 3, 1911, ch. 231, § 291","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1167"},"text":"36 Stat. 1167","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd0f9a6b5-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd0f9a6b6-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd0f9a6b7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5309 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1861-08-06/ch60/s2"},"text":"act Aug. 6, 1861, ch. 60, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/12/319"},"text":"12 Stat. 319","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1911-03-03"},"text":"Mar. 3, 1911","children":[],"tail":", conferred the powers and duties of the former circuit courts upon the district courts."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd0f9a6b8-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1877—Act ","children":[{"tag":"date","attrib":{"date":"1877-02-27"},"text":"Feb. 27, 1877","children":[],"tail":", inserted “may” after “any district in which the same”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
