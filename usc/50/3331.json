{"tag":"section","attrib":{"id":"idd1cb9ccb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3331"},"text":null,"children":[{"tag":"num","attrib":{"value":"3331"},"text":"§ 3331.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management of intelligence community personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1cb9ccc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3331/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multi-sector workforce initiative","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cb9ccd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3331/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning on ","children":[{"tag":"date","attrib":{"date":"2018-10-01"},"text":"October 1, 2018","children":[],"tail":", the Director of National Intelligence shall improve management of the workforce of the intelligence community by enabling elements of the intelligence community to build and maintain an appropriate mix between employees of the United States Government and core contractors."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9cce-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3331/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Briefing to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2017-07-01"},"text":"July 1, 2017","children":[],"tail":", and each 120 days thereafter until "},{"tag":"date","attrib":{"date":"2018-07-01"},"text":"July 1, 2018","children":[],"tail":", the Director of National Intelligence shall brief the congressional intelligence committees on the initiative required by paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cb9ccf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3331/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management based on workload requirements and authorized funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cb9cd0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3331/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning on ","children":[{"tag":"date","attrib":{"date":"2018-10-01"},"text":"October 1, 2018","children":[],"tail":", the personnel levels of the intelligence community shall be managed each fiscal year on the basis of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1cb9cd1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3331/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the workload required to carry out the functions and activities of the intelligence community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cb9cd2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3331/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funds made available to the intelligence community in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3094"},"text":"section 3094 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9cd3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3331/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on constraints or limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning on ","children":[{"tag":"date","attrib":{"date":"2018-10-01"},"text":"October 1, 2018","children":[],"tail":", the management of such personnel in the intelligence community in any fiscal year shall not be subject to an externally imposed constraint or limitation expressed in terms of man years, end strength, full-time equivalent positions, or maximum number of employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cb9cd4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3331/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Briefing and report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", the Director of National Intelligence shall issue a written report and provide a briefing to the congressional intelligence committees on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cb9cd5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3331/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methodology used to calculate the number of civilian and contractor full-time equivalent positions in the intelligence community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9cd6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3331/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost analysis tool used to calculate personnel costs in the intelligence community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9cd7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3331/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plans of the Director of National Intelligence and the head of each element of the intelligence community to implement a multi-sector workforce as required by subsections (a) and (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cb9cd8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3331/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 240 days after ","children":[{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", the Inspector General of the Intelligence Community shall submit to the congressional intelligence committees a written report on the accuracy of intelligence community data for the numbers and costs associated with the civilian and contractor workforce in each element of the intelligence community."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1cb9cd9-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/dN/tIII/s306"},"text":"Pub. L. 115–31, div. N, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/812"},"text":"131 Stat. 812","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1cb9cda-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1cb9cdb-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd1cb9cdc-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “intelligence community” and “congressional intelligence committees” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/dN/s2"},"text":"section 2 of div. N of Pub. L. 115–31","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
