{"tag":"section","attrib":{"id":"idd1d9cd56-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3361"},"text":null,"children":[{"tag":"num","attrib":{"value":"3361"},"text":"§ 3361.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Virtual Translation Center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1d9cd57-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3361/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence shall establish in the intelligence community an element with the function of connecting the elements of the intelligence community engaged in the acquisition, storage, translation, or analysis of voice or data in digital form.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d9cd58-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3361/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The element established under subsection (a) shall be known as the National Virtual Translation Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d9cd59-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3361/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Function","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The element established under subsection (a) shall provide for timely and accurate translations of foreign intelligence for all elements of the intelligence community through—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d9cd5a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3361/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the integration of the translation capabilities of the intelligence community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d9cd5b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3361/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of remote-connection capabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d9cd5c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3361/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of such other capabilities as the Director considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d9cd5d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3361/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative matters","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d9cd5e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3361/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall retain direct supervision and control over the element established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d9cd5f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3361/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The element established under subsection (a) shall connect elements of the intelligence community utilizing the most current available information technology that is applicable to the function of the element.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d9cd60-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3361/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Personnel of the element established under subsection (a) may carry out the duties and functions of the element at any location that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d9cd61-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3361/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been certified as a secure facility by a department or agency of the United States Government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d9cd62-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3361/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director has otherwise determined to be appropriate for such duties and functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d9cd63-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3361/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The element required by subsection (a) shall be established as soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2002-11-27"},"text":"November 27, 2002","children":[],"tail":", but not later than 90 days after "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"November 27, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1d9cd64-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/tIII/s313"},"text":"Pub. L. 107–306, title III, § 313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2391"},"text":"116 Stat. 2391","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI/s1071/g/2/A/i"},"text":"Pub. L. 108–458, title I, § 1071(g)(2)(A)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3691"},"text":"118 Stat. 3691","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/487/tIII/s304"},"text":"Pub. L. 108–487, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3944"},"text":"118 Stat. 3944","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tIX/s7901/f/1"},"text":"Pub. L. 118–31, div. G, title IX, § 7901(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1107"},"text":"137 Stat. 1107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1d9cd65-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes",