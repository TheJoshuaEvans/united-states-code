1"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd145f163-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s102/b/1"},"text":"Pub. L. 109–177, § 102(b)(1)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/112/14"},"text":"Pub. L. 112–14","children":[],"tail":", this section was amended, effective "},{"tag":"date","attrib":{"date":"2015-06-01"},"text":"June 1, 2015","children":[],"tail":", to read as it read on "},{"tag":"date","attrib":{"date":"2001-10-25"},"text":"Oct. 25, 2001","children":[],"tail":". The amendments made by "},{"tag":"ref","attrib":{"href":"/us/pl/114/23"},"text":"Pub. L. 114–23","children":[],"tail":", which was enacted "},{"tag":"date","attrib":{"date":"2015-06-02"},"text":"June 2, 2015","children":[],"tail":", were directed to this section as it read prior to such reversion and were executed as if the reversion had not taken place, to reflect the probable intent of Congress and the extension of the provisions of this section to "},{"tag":"date","attrib":{"date":"2019-12-15"},"text":"Dec. 15, 2019","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/114/23/s705/a"},"text":"Pub. L. 114–23, § 705(a)","children":[],"tail":", (c). See 2015 Amendment notes below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd145f164-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1862, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511/tV/s502"},"text":"Pub. L. 95–511, title V, § 502","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/272/tVI/s602"},"text":"Pub. L. 105–272, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-20"},"text":"Oct. 20, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2411"},"text":"112 Stat. 2411","children":[],"tail":", which related to access to certain business records for foreign intelligence and international terrorism investigations, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tII/s215"},"text":"Pub. L. 107–56, title II, § 215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/287"},"text":"115 Stat. 287","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd145f165-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/49/s10/a/4"},"text":"Pub. L. 118–49, § 10(a)(4)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/49/s10/b/4"},"text":"Pub. L. 118–49, § 10(b)(4)","children":[],"tail":", added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/69"},"text":"Pub. L. 116–69","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/s102/b/1"},"text":"Pub. L. 109–177, § 102(b)(1)","children":[],"tail":". See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s705/a"},"text":"Pub. L. 114–23, § 705(a)","children":[],"tail":", (c), amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/s102/b/1"},"text":"