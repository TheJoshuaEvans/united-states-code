{"tag":"section","attrib":{"id":"idd145f14c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1862"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862"},"text":"§ 1862.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to certain business records for foreign intelligence and international terrorism investigations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd145f14d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1862/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Federal Bureau of Investigation or a designee of the Director (whose rank shall be no lower than Assistant Special Agent in Charge) may make an application for an order authorizing a common carrier, public accommodation facility, physical storage facility, or vehicle rental facility to release records in its possession for an investigation to gather foreign intelligence information or an investigation concerning international terrorism which investigation is being conducted by the Federal Bureau of Investigation under such guidelines as the Attorney General approves pursuant to Executive Order No. 12333, or a successor order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd145f14e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1862/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recipient and contents of application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd145f14f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1862/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be made to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd145f150-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1862/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a judge of the court established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1803/a"},"text":"section 1803(a) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd145f151-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1862/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States Magistrate Judge under chapter 43 of title 28 who is publicly designated by the Chief Justice of the United States to have the power to hear applications and grant orders for the release of records under this section on behalf of a judge of that court; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd145f152-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1862/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall specify that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd145f153-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1862/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the records concerned are sought for an investigation described in subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd145f154-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1862/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there are specific and articulable facts giving reason to believe that the person to whom the records pertain is a foreign power or an agent of a foreign power;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd145f155-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1862/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002034"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002034"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No subpar. (C) or (D) has been enacted."}],"tail":" a statement by the applicant that, to the best knowledge of the applicant, the application fairly reflects all information that might reasonably—"}],"tail":null},{"tag":"clause","attrib":{"id":"idd145f156-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1862/b/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" call into question the accuracy of the application or the reasonableness of any assessment in the application conducted by the department or agency on whose behalf the application is made; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd145f157-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1862/b/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise raise doubts with respect to the findings required under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd145f158-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1862/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" non-cumulative information known to the applicant that is potentially exculpatory regarding the requested legal findings or any assessment in the application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd145f159-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1862/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ex parte judicial order of approval","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd145f15a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1862/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon application made pursuant to this section, the judge shall enter an ex parte order as requested, or as modified, approving the release of records if the judge finds that the application satisfies the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd145f15b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1862/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An order under this subsection shall not disclose that it is issued for purposes of an investigation described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd145f15c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1862/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance; nondisclosure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd145f15d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1862/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any common carrier, public accommodation facility, physical storage facility, or vehicle rental facility shall comply with an order under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd145f15e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1862/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No common carrier, public accommodation facility, physical storage facility, or vehicle rental facility, or officer, employee, or agent thereof, shall disclose to any person (other than those officers, agents, or employees of such common carrier, public accommodation facility, physical storage facility, or vehicle rental facility necessary to fulfill the requirement to disclose information to the Federal Bureau of Investigation under this section) that the Federal Bureau of Investigation has sought or obtained records pursuant to an order under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd145f15f-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511/tV/s502"},"text":"Pub. L. 95–511, title V, § 502","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tII/s215"},"text":"Pub. L. 107–56, title II, § 215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/288"},"text":"115 Stat. 288","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/108/tIII/s314/a/7"},"text