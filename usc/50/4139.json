{"tag":"section","attrib":{"id":"idd21576db-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4139"},"text":null,"children":[{"tag":"num","attrib":{"value":"4139"},"text":"§ 4139.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of awards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd21576dc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4139/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall certify to the Secretary of the Treasury, in terms of United States currency, for payment out of the War Claims Fund each award made pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4132"},"text":"section 4132 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd21576dd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4139/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall recertify to the Secretary of the Treasury, in terms of United States currency, for payment out of the War Claims Fund, awards heretofore made with respect to claims against the Government of Hungary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1641b/1"},"text":"section 1641b(1) of title 22","children":[],"tail":". Nothing contained in this subsection shall be construed as authorizing the filing of new claims against Hungary."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd21576de-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-07-03/ch826"},"text":"July 3, 1948, ch. 826","children":[],"tail":", title II, § 209, as added "},{"tag":"ref","attrib":{"href":"/us/pl/87/846/tI/s103"},"text":"Pub. L. 87–846, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-22"},"text":"Oct. 22, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1111"},"text":"76 Stat. 1111","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd21576df-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd21576e0-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd21576e1-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 2017h of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
