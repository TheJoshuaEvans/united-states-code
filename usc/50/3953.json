{"tag":"section","attrib":{"id":"idd20990b6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3953"},"text":null,"children":[{"tag":"num","attrib":{"value":"3953"},"text":"§ 3953.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mortgages and trust deeds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd20990b7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3953/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mortgage as security","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section applies only to an obligation on real or personal property owned by a servicemember that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20990b8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3953/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" originated before the period of the servicemember’s military service and for which the servicemember is still obligated; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20990b9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3953/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is secured by a mortgage, trust deed, or other security in the nature of a mortgage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20990ba-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3953/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stay of proceedings and adjustment of obligation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In an action filed during, or within one year after, a servicemember’s period of military service to enforce an obligation described in subsection (a), the court may after a hearing and on its own motion and shall upon application by a servicemember when the servicemember’s ability to comply with the obligation is materially affected by military service—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20990bb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3953/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stay the proceedings for a period of time as justice and equity require, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20990bc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3953/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adjust the obligation to preserve the interests of all parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20990bd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3953/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale or foreclosure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A sale, foreclosure, or seizure of property for a breach of an obligation described in subsection (a) shall not be valid if made during, or within one year after, the period of the servicemember’s military service except—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20990be-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3953/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon a court order granted before such sale, foreclosure, or seizure with a return made and approved by the court; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20990bf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3953/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if made pursuant to an agreement as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3918"},"text":"section 3918 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20990c0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3953/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Misdemeanor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person who knowingly makes or causes to be made a sale, foreclosure, or seizure of property that is prohibited by subsection (c), or who knowingly attempts to do so, shall be fined as provided in title 18, or imprisoned for not more than one year, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd20990c1-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title III, § 303, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s1"},"text":"Pub. L. 108–189, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2847"},"text":"117 Stat. 2847","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dB/tII/s2203/a"},"text":"Pub. L. 110–289, div. B, title II, § 2203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","chi