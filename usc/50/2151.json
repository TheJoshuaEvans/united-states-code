{"tag":"section","attrib":{"id":"idd16030e7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2151"},"text":null,"children":[{"tag":"num","attrib":{"value":"2151"},"text":"§ 2151.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of Federal Employees’ Retirement System to Agency employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd16030e8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2151/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsections (b) and (c), all employees of the Agency, any of whose service after ","children":[{"tag":"date","attrib":{"date":"1983-12-31"},"text":"December 31, 1983","children":[],"tail":", is employment for the purpose of title II of the Social Security Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s401"},"text":"42 U.S.C. 401","children":[],"tail":" et seq.] and chapter 21 of title 26, shall be subject to chapter 84 of title 5."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16030e9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2151/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for pre-1984 employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Participants in the Central Intelligence Agency Retirement and Disability System who were participants in such system on or before ","children":[{"tag":"date","attrib":{"date":"1983-12-31"},"text":"December 31, 1983","children":[],"tail":", and who have not had a break in service in excess of one year since that date, are not subject to chapter 84 of title 5 without regard to whether they are subject to title II of the Social Security Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s401"},"text":"42 U.S.C. 401","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16030ea-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2151/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability of FERS to certain employees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16030eb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2151/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The provisions of chapter 84 of title 5 shall not apply with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd16030ec-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2151/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual who separates, or who has separated, from Federal Government service after having been an employee of the Agency subject to subchapter II of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16030ed-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2151/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any employee of the Agency having at least 5 years of civilian service which was performed before ","children":[{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":", and is creditable under subchapter II of this chapter (determined without regard to any deposit or redeposit requirement under subchapter III of chapter 83 of title 5, or under subchapter II of this chapter, or any requirement that the individual become subject to such subchapter or to subchapter II of this chapter after performing the service involved)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16030ee-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2151/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) shall not apply with respect to an individual who has elected under regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2157"},"text":"section 2157 of this title","children":[],"tail":" to become subject to chapter 84 of title 5 to the extent provided in such regulations."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16030ef-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2151/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual described in paragraph (1) shall be deemed to be an individual excluded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8402/b/2"},"text":"section 8402(b)(2) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16030f0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2151/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to become subject to FERS","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An employee who is designated as a participant in the Central Intelligence Agency Retirement and Disability System after ","children":[{"tag":"date","attrib":{"date":"1987-12-31"},"text":"December 31, 1987","children":[],"tail":", pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2013"},"text":"section 2013 of this title","children":[],"tail":" may elect to become subject to chapter 84 of title 5. Such election—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16030f1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2151/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be effective unless it is made during the six-month period beginning on the date on which the employee is so designated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16030f2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2151/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall take effect beginning with the first pay period beginning after the date of the election; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16030f3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2151/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be irrevocable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16030f4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2151/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The application of the provisions of chapter 84 of title 5 to an employee referred to in subsection (a) shall be subject to the exceptions and special rules provided in this subchapter. Any provision of that chapter which is inconsistent with a special rule provided in this subchapter shall not apply to such employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd16030f5-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/tIII/s301"},"text":"Pub. L. 88–643, title III, § 301","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s802"},"text":"Pub. L. 102–496, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3243"},"text":"106 Stat. 3243","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd16030f6-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd16030f7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd16030f8-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsecs. (a) and (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Title II of the Act is classified generally to subchapter II (§ 401 et seq.) of chapter 7 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd16030f9-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/s301"},"text":"section 301 of Pub. L. 88–643","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/tV/s506"},"text":"Pub. L. 99–335, title V, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/624"},"text":"100 Stat. 624","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/453/tV/s502"},"text":"Pub. L. 100–453, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1909"},"text":"102 Stat. 1909","children":[],"tail":", related to application of Federal Employees’ Retirement System to Agency employees and was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403"},"text":"section 403 of this title","children":[],"tail":" prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/88/643"},"text":"Pub. L. 88–643","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s802"},"text":"section 802 of Pub. L. 102–496","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd16030fa-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd16030fb-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of fourth month beginning after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s805"},"text":"section 805 of Pub. L. 102–496","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
