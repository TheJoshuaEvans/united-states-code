{"tag":"section","attrib":{"id":"idd156babb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2011"},"text":null,"children":[{"tag":"num","attrib":{"value":"2011"},"text":"§ 2011.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CIARDS system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd156babc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2011/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd156babd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2011/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is a retirement and disability system for certain employees of the Central Intelligence Agency known as the Central Intelligence Agency Retirement and Disability System (hereinafter in this chapter referred to as the “system”), originally established pursuant to title II of the Central Intelligence Agency Retirement Act of 1964 for Certain Employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd156babe-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2011/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" DCI regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall prescribe regulations for the system. The Director shall submit any proposed regulations for the system to the congressional intelligence committees not less than 14 days before they take effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd156babf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2011/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall administer the system in accordance with regulations prescribed under this subchapter and with the principles established by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd156bac0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2011/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finality of decisions of DCI","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the interests of the security of the foreign intelligence activities of the United States and in order further to implement ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3024/h"},"text":"section 3024(h) of this title","children":[],"tail":" that the Director of National Intelligence shall be responsible for protecting intelligence sources and methods from unauthorized disclosure, and notwithstanding the provisions of chapter 7 of title 5 or any other provision of law (except "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2155/b"},"text":"section 2155(b) of this title","children":[],"tail":"), any determination by the Director authorized by this chapter shall be final and conclusive and shall not be subject to review by any court."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd156bac1-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/tII/s201"},"text":"Pub. L. 88–643, title II, § 201","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s802"},"text":"Pub. L. 102–496, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3201"},"text":"106 Stat. 3201","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/178/tII/s202/a/2"},"text":"Pub. L. 103–178, title II, § 202(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2026"},"text":"107 Stat. 2026","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/272/tIV/s403/b"},"text":"Pub. L. 105–272, title IV, § 403(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-20"},"text":"Oct. 20, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2404"},"text":"112 Stat. 2404","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI/s1072/c"},"text":"Pub. L. 108–458, title I, § 1072(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3693"},"text":"118 Stat. 3693","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dF/tLXIV/s6402/c/2/C"},"text":"Pub. L. 119–60, div. F, title LXIV, § 6402(c)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1616"},"text":"139 Stat. 1616","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd156bac2-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd156bac3-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd156bac4-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Central Intelligence Agency Retirement Act of 1964 for Certain Employees, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643"},"text":"Pub. L. 88–643","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-13"},"text":"Oct. 13, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1043"},"text":"78 Stat. 1043","children":[],"tail":", which was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403"},"text":"section 403 of this title","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/88/643"},"text":"Pub. L. 88–643","children":[],"tail":" was revised generally by "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s802"},"text":"Pub. L. 102–496, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3196"},"text":"106 Stat. 3196","children":[],"tail":", and is now known as the Central Intelligence Agency Retirement Act. As so revised, title II of "},{"tag":"ref","attrib":{"href":"/us/pl/88/643"},"text":"Pub. L. 88–643","children":[],"tail":" is classified generally to this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd156bac5-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/6