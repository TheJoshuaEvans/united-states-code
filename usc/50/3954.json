{"tag":"section","attrib":{"id":"idd20990cb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3954"},"text":null,"children":[{"tag":"num","attrib":{"value":"3954"},"text":"§ 3954.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Settlement of stayed cases relating to personal property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd20990cc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3954/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appraisal of property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When a stay is granted pursuant to this chapter in a proceeding to foreclose a mortgage on or to repossess personal property, or to rescind or terminate a contract for the purchase of personal property, the court may appoint three disinterested parties to appraise the property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20990cd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3954/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equity payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Based on the appraisal, and if undue hardship to the servicemember’s dependents will not result, the court may order that the amount of the servicemember’s equity in the property be paid to the servicemember, or the servicemember’s dependents, as a condition of foreclosing the mortgage, repossessing the property, or rescinding or terminating the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd20990ce-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title III, § 304, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s1"},"text":"Pub. L. 108–189, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2848"},"text":"117 Stat. 2848","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd20990cf-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd20990d0-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd20990d1-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 534 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd20990d2-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 304 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"act Oct. 17, 1940, ch. 888","children":[],"tail":", art. III, as added "},{"tag":"ref","attrib":{"href":"/us/act/1942-10-06/ch581/s12"},"text":"Oct. 6, 1942, ch. 581, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/772"},"text":"56 Stat. 772","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/12/s9/9"},"text":"Pub. L. 102–12, § 9(9)","children":[],"tail":", "},{