{"tag":"section","attrib":{"id":"idd21576d5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4138"},"text":null,"children":[{"tag":"num","attrib":{"value":"4138"},"text":"§ 4138.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain awards prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No award shall be made under this subchapter to or for the benefit of (1) any person who has been convicted of a violation of any provision of chapter 115, title 18, or of any other crime involving disloyalty to the United States, or (2) any claimant whose claim under this subchapter is within the scope of title III of the International Claims Settlement Act of 1949, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/stat/69/570"},"text":"69 Stat. 570","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1641"},"text":"22 U.S.C. 1641","children":[],"tail":" et seq.], except any claimant whose award under section 303(1) of title III of the International Claims Settlement Act of 1949, as amended ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1641b/1"},"text":"22 U.S.C. 1641b(1)","children":[],"tail":"], is recertified pursuant to subsection (b) of "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4139"},"text":"section 4139 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd21576d6-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-07-03/ch826"},"text":"July 3, 1948, ch. 826","children":[],"tail":", title II, § 208, as added "},{"tag":"ref","attrib":{"href":"/us/pl/87/846/tI/s103"},"text":"Pub. L. 87–846, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-22"},"text":"Oct. 22, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1110"},"text":"76 Stat. 1110","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd21576d7-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd21576d8-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd21576d9-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The International Claims Settlement Act of 1949, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-10/ch54"},"text":"act Mar. 10, 1950, ch. 54","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/12"},"text":"64 Stat. 12","children":[],"tail":". Title III of the Act is classified generally to subchapter III (§ 1641 et seq.) of chapter 21 of Title 22, Foreign Relations and Intercourse. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1621"},"text":"section 1621 of Title 22","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd21576da-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 2017g of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
