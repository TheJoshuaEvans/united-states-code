{"tag":"section","attrib":{"id":"idd20e4af7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025"},"text":null,"children":[{"tag":"num","attrib":{"value":"4025"},"text":"§ 4025.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guarantee of residency for military personnel and spouses of military personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd20e4af8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of voting for any Federal office (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"section 30101 of title 52","children":[],"tail":") or a State or local office, a person who is absent from a State in compliance with military or naval orders shall not, solely by reason of that absence—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20e4af9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be deemed to have lost a residence or domicile in that State, without regard to whether or not the person intends to return to that State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4afa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be deemed to have acquired a residence or domicile in any other State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4afb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be deemed to have become a resident in or a resident of any other State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4afc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spouses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of voting for any Federal office (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"section 30101 of title 52","children":[],"tail":") or a State or local office—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20e4afd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a person who is absent from a State because the person is accompanying the person’s spouse who is absent from that same State in compliance with military or naval orders shall not, solely by reason of that absence—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd20e4afe-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be deemed to have lost a residence or domicile in that State, without regard to whether or not the person intends to return to that State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd20e4aff-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be deemed to have acquired a residence or domicile in any other State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd20e4b00-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be deemed to have become a resident in or a resident of any other State; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4b01-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4025/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the spouse of a servicemember may elect to use the same residence as the servicemember regardless of the date on which the marriage of the spouse and the servicemember occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd20e4b02-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title VII, § 705, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s1"},"text":"Pub. L. 108–189, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2865"},"text":"117 Stat. 2865","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/97/s2/a"},"text":"Pub. L. 111–97, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-11-11"},"text":"Nov. 11, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/3007"},"text":"123 Stat. 3007","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/407/tIII/s303/a"},"text":"Pub. L. 115–407, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5373"},"text":"132 Stat. 5373","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd20e4b03-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd20e4b04-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd20e4b05-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 595 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd20e4b06-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/407"},"text":"Pub. L. 115–407","children":[],"tail":" substituted “State or local office—” for “State or local office, a person who is absent from a State because the person is accompanying the person’s spouse who is absent from that same State in compliance with military or naval orders shall not, solely by reason of that absence—” in introductory provisions, added pars. (1) and (2), and struck out former pars. (1) to (3) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) be deemed to have lost a residence or domicile in that State, without regard to whether or not the person intends to return to that State;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) be deemed to have acquired a residence or domicile in any other State; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) be deemed to have become a resident in or a resident of any other State.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/97"},"text":"Pub. L. 111–97","children":[],"tail":" inserted “and spouses of military personnel” after “military personnel” in section catchline, designated existing provisions as subsec.(a), inserted heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd20e4b07-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd20e4b08-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/407/tIII/s303/b"},"text":"Pub. L. 115–407, title III, § 303(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5374"},"text":"132 Stat. 5374","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/407/tIII/s303/b"},"text":"“The amendments made by subsection (a) [amending this section] shall take effect on the date that is 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd20e4b09-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/97/s2/c"},"text":"Pub. L. 111–97, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-11-11"},"text":"Nov. 11, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/3007"},"text":"123 Stat. 3007","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/97/s2/c"},"text":"“Subsection (b) of section 705 of such Act [Servicemembers Civil Relief Act] (50 U.S.C. App. 595) [now ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4025"},"text":"50 U.S.C. 4025","children":[],"tail":"], as added by subsection (a) of this section, shall apply with respect to absences from States described in such subsection (b) on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2009-11-11"},"text":"Nov. 11, 2009","children":[],"tail":"], regardless of the date of the military or naval order concerned.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd20e4b0a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any case not final before ","children":[{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s3"},"text":"section 3 of Pub. L. 108–189","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3901"},"text":"section 3901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
