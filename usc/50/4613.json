{"tag":"section","attrib":{"id":"idd24782f1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613"},"text":null,"children":[{"tag":"num","attrib":{"value":"4613"},"text":"§ 4613.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chemical and biological weapons proliferation sanctions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd24782f2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of sanctions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd24782f3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination by the President","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b)(2), the President shall impose both of the sanctions described in subsection (c) if the President determines that a foreign person, on or after ","children":[{"tag":"date","attrib":{"date":"1991-10-28"},"text":"October 28, 1991","children":[],"tail":", has knowingly and materially contributed—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd24782f4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through the export from the United States of any goods or technology that are subject to the jurisdiction of the United States under this chapter, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd24782f5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through the export from any other country of any goods or technology that would be, if they were United States goods or technology, subject to the jurisdiction of the United States under this chapter,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to the efforts by any foreign country, project, or entity described in paragraph (2) to use, develop, produce, stockpile, or otherwise acquire chemical or biological weapons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd24782f6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Countries, projects, or entities receiving assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) applies in the case of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd24782f7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any foreign country that the President determines has, at any time after ","children":[{"tag":"date","attrib":{"date":"1980-01-01"},"text":"January 1, 1980","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{"id":"idd24782f8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used chemical or biological weapons in violation of international law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd24782f9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used lethal chemical or biological weapons against its own nationals; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd24782fa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made substantial preparations to engage in the activities described in clause (i) or (ii);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd24782fb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any foreign country whose government is determined for purposes of section 4605(j) ","children":[{"tag":"ref","attrib":{"idref":"fn002149"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002149"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title to be a government that has repeatedly provided support for acts of international terrorism; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd24782fc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other foreign country, project, or entity designated by the President for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd24782fd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons against which sanctions are to be imposed","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Sanctions shall be imposed pursuant to paragraph (1) on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd24782fe-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the foreign person with respect to which the President makes the determination described in that paragraph;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd24782ff-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any successor entity to that foreign person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2478300-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any foreign person that is a parent or subsidiary of that foreign person if that parent or subsidiary knowingly assisted in the activities which were the basis of that determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2478301-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any foreign person that is an affiliate of that foreign person if that affiliate knowingly assisted in the activities which were the basis of that determination and if that affiliate is controlled in fact by that foreign person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2478302-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations with and actions by foreign government of jurisdiction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2478303-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the President makes the determinations described in subsection (a)(1) with respect to a foreign person, the Congress urges the President to initiate consultations immediately with the government with primary jurisdiction over that foreign person with respect to the imposition of sanctions pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2478304-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions by government of jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to pursue such consultations with that government, the President may delay imposition of sanctions pursuant to this section for a period of up to 90 days. Following these consultations, the President shall impose sanctions unless the President determines and certifies to the Congress that that government has taken specific and effective actions, including appropriate penalties, to terminate the involvement of the foreign person in the activities described in subsection (a)(1). The President may delay imposition of sanctions for an additional period of up to 90 days if the President determines and certifies to the Congress that that government is in the process of taking the actions described in the preceding sentence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2478305-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall report to the Congress, not later than 90 days after making a determination under subsection (a)(1), on the status of consultations with the appropriate government under this subsection, and the basis for any determination under paragraph (2) of this subsection that such government has taken specific corrective actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2478306-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2478307-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of sanctions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The sanctions to be imposed pursuant to subsection (a)(1) are, except as provided in paragraph (2) of this subsection, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2478308-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement sanction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Government shall not procure, or enter into any contract for the procurement of, any goods or services from any person described in subsection (a)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2478309-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Import sanctions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The importation into the United States of products produced by any person described in subsection (a)(3) shall be prohibited.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd247830a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall not be required to apply or maintain sanctions under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd247830b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of procurement of defense articles or defense services—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd247830c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under existing contracts or subcontracts, including the exercise of options for production quantities to satisfy United States operational military requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd247830d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the President determines that the person or other entity to which the sanctions would otherwise be applied is a sole source supplier of the defense articles or services, that the defense articles or services are essential, and that alternative sources are not readily or reasonably available; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd247830e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the President determines that such articles or services are essential to the national security under defense coproduction agreements;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd247830f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to products or services provided under contracts entered into before the date on which the President publishes his intention to impose sanctions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2478310-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd2478311-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" spare parts,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2478312-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" component parts, but not finished products, essential to United States products or production, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2478313-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" routine servicing and maintenance of products, to the extent that alternative sources are not readily or reasonably available;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2478314-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to information and technology essential to United States products or production; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2478315-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to medical or other humanitarian items.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2478316-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of sanctions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The sanctions imposed pursuant to this section shall apply for a period of at least 12 months following the imposition of sanctions and shall cease to apply thereafter only if the President determines and certifies to the Congress that reliable information indicates that the foreign person with respect to which the determination was made under subsection (a)(1) has ceased to aid or abet any foreign government, project, or entity in its efforts to acquire chemical or biological weapons capability as described in that subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2478317-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2478318-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criterion for waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may waive the application of any sanction imposed on any person pursuant to this section, after the end of the 12-month period beginning on the date on which that sanction was imposed on that person, if the President determines and certifies to the Congress that such waiver is important to the national security interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2478319-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of and report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the President decides to exercise the waiver authority provided in paragraph (1), the President shall so notify the Congress not less than 20 days before the waiver takes effect. Such notification shall include a report fully articulating the rationale and circumstances which led the President to exercise the waiver authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd247831a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of foreign person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section, the term “foreign person” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd247831b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who is not a citizen of the United States or an alien admitted for permanent residence to the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd247831c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4613/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation, partnership, or other entity which is created or organized under the laws of a foreign country or which has its principal place of business outside the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd247831d-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/72/s11C"},"text":"Pub. L. 96–72, § 11C","children":[],"tail":", as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/182/tIII"},"text":"Pub. L. 102–182, title III","children":[],"tail":", §§ 305(a), 309(b)(1), "},{"tag":"date","attrib":{"date":"1991-12-04"},"text":"Dec. 4, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1247"},"text":"105 Stat. 1247","children":[],"tail":", 1258.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd247831e-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd247831f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd2478320-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(1), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/72"},"text":"Pub. L. 96–72","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/503"},"text":"93 Stat. 503","children":[],"tail":", known as the Export Administration Act of 1979, which was classified principally to this chapter, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVII/s1766/a"},"text":"Pub. L. 115–232, div. A, title XVII, § 1766(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2232"},"text":"132 Stat. 2232","children":[],"tail":", except for sections 11A, 11B, and 11C thereof ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4611"},"text":"50 U.S.C. 4611","children":[],"tail":", 4612, 4613)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4605/j"},"text":"Section 4605(j) of this title","children":[],"tail":", referred to in subsec. (a)(2)(B), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVII/s1766/a"},"text":"Pub. L. 115–232, div. A, title XVII, § 1766(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2232"},"text":"132 Stat. 2232","children":[],"tail":". For similar provisions, see "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4813/c"},"text":"section 4813(c) of this title","children":[],"tail":", as enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd2478321-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 2410c of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd2478322-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/72/s11C"},"text":"section 11C of Pub. L. 96–72","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/138/tV/s505/a"},"text":"Pub. L. 102–138, title V, § 505(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/724"},"text":"105 Stat. 724","children":[],"tail":", contained provisions substantially identical to those added by "},{"tag":"ref","attrib":{"href":"/us/pl/102/182/s305/a"},"text":"section 305(a) of Pub. L. 102–182","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/182/s309/a"},"text":"Pub. L. 102–182, § 309(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd2478323-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/182/s309/b/1"},"text":"Pub. L. 102–182, § 309(b)(1)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"October 28, 1991","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1991-12-04"},"text":"December 4, 1991","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd2478324-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd2478325-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Department of Defense Review of Export Licenses for Certain Biological Pathogens","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXIII/s1323"},"text":"Pub. L. 104–106, div. A, title XIII, § 1323","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/480"},"text":"110 Stat. 480","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/106/dA/tXIII/s1323"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Department of Defense Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any application to the Secretary of Commerce for a license for the export of a class 2, class 3, or class 4 biological pathogen to a country identified to the Secretary under subsection (c) as a country that is known or suspected to have a biological weapons program shall be referred to the Secretary of Defense for review. The Secretary of Defense shall notify the Secretary of Commerce within 15 days after receipt of an application under the preceding sentence whether the export of such biological pathogen pursuant to the license would be contrary to the national security interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Denial of License if Contrary to National Security Interest","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A license described in subsection (a) shall be denied by the Secretary of Commerce if it is determined that the export of such biological pathogen to that country would be contrary to the national security interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Identification of Countries Known or Suspected To Have a Program To Develop Offensive Biological Weapons","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall determine, for the purposes of this section, those countries that are known or suspected to have a program to develop offensive biological weapons. Upon making such determination, the Secretary shall provide to the Secretary of Commerce a list of those countries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall update the list under paragraph (1) on a regular basis. Whenever a country is added to or deleted from such list, the Secretary shall notify the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Determination under this subsection of countries that are known or suspected to have a program to develop offensive biological weapons shall be made in consultation with the Secretary of State and the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, the term ‘class 2, class 3, or class 4 biological pathogen’ means any biological pathogen that is characterized by the Centers for Disease Control as a class 2, class 3, or class 4 biological pathogen.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idd2478326-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"idd2478327-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under this section delegated to Secretary of State, with certain exceptions, by section 1(a) of Ex. Ord. No. 12851, ","children":[{"tag":"date","attrib":{"date":"1993-06-11"},"text":"June 11, 1993","children":[],"tail":", 58 F.R. 33181, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2797"},"text":"section 2797 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
