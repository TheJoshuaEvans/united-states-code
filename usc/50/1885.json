{"tag":"section","attrib":{"id":"idd14f8f03-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885"},"text":null,"children":[{"tag":"num","attrib":{"value":"1885"},"text":"§ 1885.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd14f8f04-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “assistance” means the provision of, or the provision of access to, information (including communication contents, communications records, or other information relating to a customer or communication), facilities, or another form of assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14f8f05-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “civil action” includes a covered civil action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14f8f06-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional intelligence committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “congressional intelligence committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd14f8f07-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Select Committee on Intelligence of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14f8f08-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Permanent Select Committee on Intelligence of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14f8f09-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “contents” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801/n"},"text":"section 1801(n) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14f8f0a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered civil action","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered civil action” means a civil action filed in a Federal or State court that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd14f8f0b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alleges that an electronic communication service provider furnished assistance to an element of the intelligence community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14f8f0c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seeks monetary or other relief from the electronic communication service provider related to the provision of such assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14f8f0d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic communication service provider","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “electronic communication service provider” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd14f8f0e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a telecommunications carrier, as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s153"},"text":"section 153 of title 47","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14f8f0f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a provider of electronic communication service, as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2510"},"text":"section 2510 of title 18","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14f8f10-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a provider of a remote computing service, as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2711"},"text":"section 2711 of title 18","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14f8f11-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other communication service provider who has access to wire or electronic communications either as such communications are transmitted or as such communications are stored;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14f8f12-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any other service provider who has access to equipment that is being or may be used to transmit or store wire or electronic communications, but not including any entity that serves primarily as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd14f8f13-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/6/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public accommodation facility, as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1861/4"},"text":"section 1861(4) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd14f8f14-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/6/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a dwelling, as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3602"},"text":"section 3602 of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd14f8f15-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/6/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a community facility, as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1592n"},"text":"section 1592n of title 42","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd14f8f16-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/6/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a food service establishment, as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1638"},"text":"section 1638 of title 7","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14f8f17-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a parent, subsidiary, affiliate, successor, or assignee of an entity described in subparagraph (A), (B), (C), or (D);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14f8f18-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/6/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer, employee, custodian, or agent of an entity described in subparagraph (A), (B), (C), (D), (E), or (F).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14f8f19-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intelligence community","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “intelligence community” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003/4"},"text":"section 3003(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14f8f1a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd14f8f1b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an electronic communication service provider; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14f8f1c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a landlord, custodian, or other person who may be authorized or required to furnish assistance pursuant to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd14f8f1d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/8/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an order of the court established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1803/a"},"text":"section 1803(a) of this title","children":[],"tail":" directing such assistance;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd14f8f1e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/8/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification in writing under section 2511(2)(a)(ii)(B) or 2709(b) of title 18; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd14f8f1f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/8/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a directive under section 1802(a)(4), 1805b(e), as added by section 2 of the Protect America Act of 2007 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/55"},"text":"Public Law 110–55","children":[],"tail":"), or 1881a(i) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14f8f20-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means any State, political subdivision of a State, the Commonwealth of Puerto Rico, the District of Columbia, and any territory or possession of the United States, and includes any officer, public utility commission, or other body authorized to regulate an electronic communication service provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd14f8f21-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511/tVIII/s801"},"text":"Pub. L. 95–511, title VIII, § 801","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/261/tII/s201"},"text":"Pub. L. 110–261, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-10"},"text":"July 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2467"},"text":"122 Stat. 2467","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/118/tI/s101/b/2/A"},"text":"Pub. L. 115–118, title I, § 101(b)(2)(A)","children":[],"tail":", title II, § 205(a)(7), "},{"tag":"date","attrib":{"date":"2018-01-19"},"text":"Jan. 19, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/8"},"text":"132 Stat. 8","children":[],"tail":", 21; "},{"tag":"ref","attrib":{"href":"/us/pl/118/49/s25/b"},"text":"Pub. L. 118–49, § 25(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-20"},"text":"Apr. 20, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/893"},"text":"138 Stat. 893","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd14f8f22-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd14f8f23-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd14f8f24-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1805b"