n":[{"tag":"ref","attrib":{"href":"/us/pl/115/118/s101/b/2/A"},"text":"Pub. L. 115–118, § 101(b)(2)(A)","children":[],"tail":", which directed substitution of “"},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1881a/i"},"text":"section 1881a(i) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1881a/h"},"text":"section 1881a(h) of this title","children":[],"tail":"”, was executed by substituting “1881a(i) of this title” for “1881a(h) of this title” to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
