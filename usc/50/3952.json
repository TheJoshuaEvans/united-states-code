{"tag":"section","attrib":{"id":"idd20990a3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3952"},"text":null,"children":[{"tag":"num","attrib":{"value":"3952"},"text":"§ 3952.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection under installment contracts for purchase or lease","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd20990a4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3952/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection upon breach of contract","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20990a5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3952/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection after entering military service","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After a servicemember enters military service, a contract by the servicemember for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd20990a6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3952/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase of real or personal property (including a motor vehicle); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd20990a7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3952/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lease or bailment of such property,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"may not be rescinded or terminated for a breach of terms of the contract occurring before or during that person’s military service, nor may the property be repossessed for such breach without a court order.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20990a8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3952/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section applies only to a contract for which a deposit or installment has been paid by the servicemember before the servicemember enters military service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20990a9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3952/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Misdemeanor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person who knowingly resumes possession of property in violation of subsection (a), or in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3918"},"text":"section 3918 of this title","children":[],"tail":", or who knowingly attempts to do so, shall be fined as provided in title 18, or imprisoned for not more than one year, or both."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20990aa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3952/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of court","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In a hearing based on this section, the court—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20990ab-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3952/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may order repayment to the servicemember of all or part of the prior installments or deposits as a condition of terminating the contract and resuming possession of the property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20990ac-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3952/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, on its own motion, and shall on application by a servicemember when the servicemember’s ability to comply with the contract is materially affected by military service, stay the proceedings for a period of time as, in the opinion of the court, justice and equity require; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20990ad-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3952/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may make other disposition as is equitable to preserve the interests of all parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd20990ae-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title III, § 302, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s1"},"text":"Pub. L. 108–189, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2846"},"text":"117 Stat. 2846","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/275/tIII/s303/b/3"},"text":"Pub. L. 111–275, title III, § 303(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-13"},"text":"Oct. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2878"},"text":"124 Stat. 2878","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd20990af-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd20990b0-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd20990b1-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 532 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd20990b2-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 302 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"act Oct. 17, 1940, ch. 888","children":[],"tail":", art. III, "},{"tag":"ref","attrib":{"href":"/us/stat/54/1182"},"text":"54 Stat. 1182","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1942-10-06/ch581"},"text":"Oct. 6, 1942, ch. 581","children":[],"tail":", §§ 9(b), (c), 10, "},{"tag":"ref","attrib":{"href":"/us/stat/56/771"},"text":"56 Stat. 771","children":[],"tail":", 772; "},{"tag":"ref","attrib":{"href":"/us/act/1952-06-23/ch450"},"text":"June 23, 1952, ch. 450","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/151"},"text":"66 Stat. 151","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/12/s9/9"},"text":"Pub. L. 102–12, § 9(9)","children":[],"tail":", (10), "},{"tag":"date","attrib":{"date":"1991-03-18"},"text":"Mar. 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/40"},"text":"105 Stat. 40","children":[],"tail":", related to mortgages and trust deeds, prior to the general amendment of this Act by "},{"tag":"ref","attrib":{"href":"/us/pl/108/189"},"text":"Pub. L. 108–189","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3953"},"text":"section 3953 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd20990b3-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/275"},"text":"Pub. L. 111–275","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) related to penalties."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd20990b4-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd20990b5-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any case not final before ","children":[{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s3"},"text":"section 3 of Pub. L. 108–189","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3901"},"text":"section 3901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
