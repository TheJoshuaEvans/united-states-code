{"tag":"section","attrib":{"id":"idd143a7b3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1828"},"text":null,"children":[{"tag":"num","attrib":{"value":"1828"},"text":"§ 1828.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil liability","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An aggrieved person, other than a foreign power or an agent of a foreign power, as defined in section 1801(a) or (b)(1)(A), respectively, of this title, whose premises, property, information, or material has been subjected to a physical search within the United States or about whom information obtained by such a physical search has been disclosed or used in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1827"},"text":"section 1827 of this title","children":[],"tail":" shall have a cause of action against any person who committed such violation and shall be entitled to recover—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd143a7b4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1828/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actual damages, but not less than liquidated damages of $1,000 or $100 per day for each day of violation, whichever is greater;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd143a7b5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1828/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" punitive damages; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd143a7b6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1828/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable attorney’s fees and other investigative and litigation costs reasonably incurred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd143a7b7-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511/tIII/s308"},"text":"Pub. L. 95–511, title III, § 308","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/359/tVIII/s807/a/3"},"text":"Pub. L. 103–359, title VIII, § 807(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-14"},"text":"Oct. 14, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3452"},"text":"108 Stat. 3452","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd143a7b8-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd143a7b9-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd143a7ba-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1994-10-14"},"text":"Oct. 14, 1994","children":[],"tail":", with exception for certain physical searches approved by the Attorney General to gather foreign intelligence information, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/359/s807/c"},"text":"section 807(c) of Pub. L. 103–359","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1821"},"text":"section 1821 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
