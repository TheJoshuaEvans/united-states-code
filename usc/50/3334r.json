{"tag":"section","attrib":{"id":"idd1d2a0dd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334r"},"text":null,"children":[{"tag":"num","attrib":{"value":"3334r"},"text":"§ 3334r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of a chief technology officer within certain elements of the intelligence community","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1d2a0de-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334r/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of each covered element of the intelligence community shall designate a senior official to serve as the chief technology officer of such element.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d2a0df-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334r/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the covered elements of the intelligence community are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d2a0e0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334r/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Central Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d2a0e1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334r/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Defense Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d2a0e2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334r/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal Bureau of Investigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d2a0e3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334r/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Geospatial-Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d2a0e4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334r/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Security Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d2a0e5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334r/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Reconnaissance Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d2a0e6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334r/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chief technology officer of each covered element of the intelligence community shall be responsible for assisting the head of such element in the identification and adoption of technology to advance mission needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d2a0e7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334r/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of dual appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any chief technology officer designated pursuant to subsection (a) may not concurrently serve as the chief information officer, the chief data officer, or the principal science officer of any element of the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1d2a0e8-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tV/s7504"},"text":"Pub. L. 118–31, div. G, title V, § 7504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1083"},"text":"137 Stat. 1083","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1d2a0e9-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1d2a0ea-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd1d2a0eb-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “intelligence community” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s7002"},"text":"section 7002 of Pub. L. 118–31","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
