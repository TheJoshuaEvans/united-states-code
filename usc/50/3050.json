{"tag":"section","attrib":{"id":"idd19bdaa7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3050"},"text":null,"children":[{"tag":"num","attrib":{"value":"3050"},"text":"§ 3050.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on hiring and retention of minority employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd19bdaa8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3050/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":" The Director of National Intelligence shall, on an annual basis, submit to Congress a report on the employment of covered persons within each element of the intelligence community for the preceding fiscal year and the preceding 5 fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19bdaa9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3050/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each such report shall include data, disaggregated by category of covered person and by element of the intelligence community, on the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd19bdaaa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3050/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of all individuals employed in the element during the fiscal year involved, the aggregate percentage of such individuals who are covered persons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd19bdaab-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3050/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Of all individuals employed in the element during the fiscal year involved at the levels referred to in subparagraphs (A) and (B), the percentage of covered persons employed at such levels:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd19bdaac-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3050/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Positions at levels 1 through 15 of the General Schedule.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd19bdaad-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3050/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Positions at levels above GS–15.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd19bdaae-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3050/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of all individuals hired by the element involved during the fiscal year involved, the percentage of such individuals who are covered persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19bdaaf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3050/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":" Each such report shall be submitted in unclassified form, but may contain a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19bdab0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3050/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":" Nothing in this section shall be construed as providing for the substitution of any similar report required under another provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19bdab1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3050/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Covered persons” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section the term “covered persons” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd19bdab2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3050/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" racial and ethnic minorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd19bdab3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3050/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" women; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd19bdab4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3050/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd19bdab5-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title I, § 114, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/272/tIII/s307/a"},"text":"Pub. L. 105–272, title III, § 307(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-20"},"text":"Oct. 20, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2401"},"text":"112 Stat. 2401","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/306/tIII"},"text":"Pub. L. 107–306, title III","children":[],"tail":", §§ 324, 353(b)(6), title VIII, §§ 811(b)(1)(D), 821, 822, "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2393"},"text":"116 Stat. 2393","children":[],"tail":", 2402, 2422, 2426, 2427; "},{"tag":"ref","attrib":{"href":"/us/pl/108/177/tIII/s361/c"},"text":"Pub. L. 108–177, title III, § 361(c)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2003-12-13"},"text":"Dec. 13, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2625"},"text":"117 Stat. 2625","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI/s1071/a/1/N"},"text":"Pub. L. 108–458, title I, § 1071(a)(1)(N)","children":[],"tail":", (O), (3)(A), (7), "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3689"},"text":"118 Stat. 3689","children":[],"tail":", 3690; "},{"tag":"ref","attrib":{"href":"/us/pl/112/277/tIII/s310/a/2"},"text":"Pub. L. 112–277, title III, § 310(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-14"},"text":"Jan. 14, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2474"},"text":"126 Stat. 2474","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/126/tIII/s329/a/1"},"text":"Pub. L. 113–126, title III, § 329(a)(1)","children":[],"tail":", (c)(2), "},{"tag":"date","attrib":{"date":"2014-07-07"},"text":"July 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1405"},"text":"128 Stat. 1405","children":[],"tail":", 1406; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLVII/s5704/a"},"text":"Pub. L. 116–92, div. E, title LVII, § 5704(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2162"},"text":"133 Stat. 2162","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd19bdab6-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd19bdab7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd19bdab8-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Schedule, referred to in subsec. (b)(2), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd19bdab9-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s404i"},"text":"section 404i of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section. Some section numbers of this title referenced in amendment notes below reflect the classification of such sections prior to their editorial reclassification."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd19bdaba-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s5704/a/1"},"text":"Pub. L. 116–92, § 5704(a)(1)","children":[],"tail":", inserted “and the preceding 5 fiscal years” after “fiscal year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s5704/a/2"},"text":"Pub. L. 116–92, § 5704(a)(2)","children":[],"tail":", substituted “data, disaggregated by category of covered person and by element of the intelligence community,” for “disaggregated data by category of covered person from each element of the intelligence community” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/126/s329/c/2/A"},"text":"Pub. L. 113–126, § 329(c)(2)(A)","children":[],"tail":", substituted “Annual report on hiring and retention of minority employees” for “Additional annual reports from the Director of National Intelligence” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/126/s329/c/2/B"},"text":"Pub. L. 113–126, § 329(c)(2)(B)","children":[],"tail":", (C), struck out subsec. (a) designation and heading “Annual report on hiring and retention of minority employees” and redesignated par. (1) as subsec. (a). Former pars. (2) to (5) redesignated subsecs. (b) to (e), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/126/s329/c/2/C"},"text":"Pub. L. 113–126, § 329(c)(2)(C)","children":[],"tail":", (D), redesignated subsec. (a)(2) as (b), redesignated subpars. (A) to (C) of former subsec. (a)(2) as pars. (1) to (3), respectively, of subsec. (b), and in par. (2) as redesignated, substituted “subparagraphs (A) and (B)” for “clauses (i) and (ii)” in introductory provisions and redesignated cls. (i) and (ii) as subpars. (A) and (B), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/126/s329/a/1"},"text":"Pub. L. 113–126, § 329(a)(1)","children":[],"tail":", struck out subsec. (b) which related to annual report on threat of attack on the United States using weapons of mass destruction."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/126/s329/c/2/C"},"text":"Pub. L. 113–126, § 329(c)(2)(C)","children":[],"tail":", redesignated subsec. (a)(3) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/126/s329/c/2/C"},"text":"Pub. L. 113–126, § 329(c)(2)(C)","children":[],"tail":", (E), redesignated subsec. (a)(4) as (d) and substituted “section” for “subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/126/s329/c/2/C"},"text":"Pub. L. 113–126, § 329(c)(2)(C)","children":[],"tail":", (F), redesignated subsec. (a)(5) as (e), substituted “section” for “subsection,” in introductory provisions, and redesignated subpars. (A) to (C) of former subsec. (a)(5) as pars. (1) to (3), respectively, of subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/277"},"text":"Pub. L. 112–277","children":[],"tail":" redesignated subsecs. (b) and (c) as (a) and (b), respectively, struck out former subsec. (a) which required annual reports on the safety and security of Russian nuclear facilities and nuclear military forces, and struck out subsec. (d) which defined the term “congressional leadership”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1071/a/7"},"text":"Pub. L. 108–458, § 1071(a)(7)","children":[],"tail":", substituted “Additional annual reports from the Director of National Intelligence” for “Additional annual reports from the Director of Central Intelligence” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1071/a/1/N"},"text":"Pub. L. 108–458, § 1071(a)(1)(N)","children":[],"tail":", substituted “Director of National Intelligence” for “Director of Central Intelligence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1071/a/1/O"},"text":"Pub. L. 108–458, § 1071(a)(1)(O)","children":[],"tail":", substituted “Director of National Intelligence” for “Director of Central Intelligence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1071/a/3/A"},"text":"Pub. L. 108–458, § 1071(a)(3)(A)","children":[],"tail":", substituted “Director of National Intelligence” for “Director”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177/s361/c"},"text":"Pub. L. 108–177, § 361(c)","children":[],"tail":", redesignated subsec. (b) as (a) and struck out former subsec. (a), which related to annual reports on intelligence community cooperation with Federal law enforcement agencies."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177/s361/c/2"},"text":"Pub. L. 108–177, § 361(c)(2)","children":[],"tail":", redesignated subsecs. (c) and (d) as (b) and (c), respectively. Former subsec. (b) redesignated (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177/s361/d"},"text":"Pub. L. 108–177, § 361(d)","children":[],"tail":", redesignated subsec. (e) as (d) and struck out former subsec. (d), which related to annual reports on covert leases of the intelligence community."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177/s361/c/2"},"text":"Pub. L. 108–177, § 361(c)(2)","children":[],"tail":", redesignated subsec. (e) as (d). Former subsec. (d) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177/s361/d/2"},"text":"Pub. L. 108–177, § 361(d)(2)","children":[],"tail":", redesignated subsec. (e) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177/s361/c/2"},"text":"Pub. L. 108–177, § 361(c)(2)","children":[],"tail":", redesignated subsec. (f) as (e). Former subsec. (e) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177/s361/c/2"},"text":"Pub. L. 108–177, § 361(c)(2)","children":[],"tail":", redesignated subsec. (f) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/s811/b/1/D/i/I"},"text":"Pub. L. 107–306, § 811(b)(1)(D)(i)(I)","children":[],"tail":", struck out “the congressional intelligence committees and” before “the congressional leadership”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/s811/b/1/D/i/II"},"text":"Pub. L. 107–306, § 811(b)(1)(D)(i)(II)","children":[],"tail":", (III), added par. (2) and redesignated former pars. (2) and (3) as (3) and (4), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/s811/b/1/D/ii"},"text":"Pub. L. 107–306, § 811(b)(1)(D)(ii)","children":[],"tail":", substituted “submit to the congressional leadership on an annual basis, and to the congressional intelligence committees on the date each year provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s415b"},"text":"section 415b of this title","children":[],"tail":",” for “, on an annual basis, submit to the congressional intelligence committees and the congressional leadership”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/s324/2"},"text":"Pub. L. 107–306, § 324(2)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/s821/2"},"text":"Pub. L. 107–306, § 821(2)","children":[],"tail":", added subsec. (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/s353/b/6"},"text":"Pub. L. 107–306, § 353(b)(6)","children":[],"tail":", added subsec. (d) and struck out heading and text of former subsec. (d). Text read as follows: “In this section:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The term ‘congressional intelligence committees’ means the Permanent Select Committee on Intelligence of the House of Representatives and the Select Committee on Intelligence of the Senate.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The term ‘congressional leadership’ means the Speaker and the minority leader of the House of Representatives and the majority leader and the minority leader of the Senate.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/s324/1"},"text":"Pub. L. 107–306, § 324(1)","children":[],"tail":", redesignated subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/s822/2"},"text":"Pub. L. 107–306, § 822(2)","children":[],"tail":", added subsec. (e). Former subsec. (e) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/s821/1"},"text":"Pub. L. 107–306, § 821(1)","children":[],"tail":", redesignated subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/s822/1"},"text":"Pub. L. 107–306, § 822(1)","children":[],"tail":", redesignated subsec. (e) as (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd19bdabb-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idd19bdabc-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on International Relations of House of Representatives changed to Committee on Foreign Affairs of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd19bdabd-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For Determination by President that amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" take effect on "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", see Memorandum of President of the United States, "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", 70 F.R. 23925, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" effective not later than six months after "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1097/a"},"text":"section 1097(a) of Pub. L. 108–458","children":[],"tail":", set out in an Effective Date of 2004 Amendment; Transition Provisions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd19bdabe-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177"},"text":"Pub. L. 108–177","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2003-12-31"},"text":"Dec. 31, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/177/s361/n"},"text":"section 361(n) of Pub. L. 108–177","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1611"},"text":"section 1611 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd19bdabf-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report and Strategic Plan on Biological Weapons","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/tIII/s335"},"text":"Pub. L. 111–259, title III, § 335","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2688"},"text":"124 Stat. 2688","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/259/tIII/s335"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement for Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":"], the Director of National Intelligence shall submit to the congressional intelligence committees a report on—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the intelligence collection efforts of the United States dedicated to assessing the threat from biological weapons from state, nonstate, or rogue actors, either foreign or domestic; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts to protect the biodefense knowledge and infrastructure of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required by subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the intelligence collection efforts of the United States dedicated to detecting the development or use of biological weapons by state, nonstate, or rogue actors, either foreign or domestic;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on fiscal, human, technical, open-source, and other intelligence collection resources of the United States dedicated for use to detect or protect against the threat of biological weapons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assessment of any problems that may reduce the overall effectiveness of United States intelligence collection and analysis to identify and protect biological weapons targets, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intelligence collection gaps or inefficiencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inadequate information sharing practices; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inadequate cooperation among departments or agencies of the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a strategic plan prepared by the Director of National Intelligence, in coordination with the Attorney General, the Secretary of Defense, and the Secretary of Homeland Security, that provides for actions for the appropriate elements of the intelligence community to close important intelligence gaps related to biological weapons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of appropriate goals, schedules, milestones, or metrics to measure the long-term effectiveness of actions implemented to carry out the plan described in paragraph (4); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any long-term resource and human capital issues related to the collection of intelligence regarding biological weapons, including any recommendations to address shortfalls of experienced and qualified staff possessing relevant scientific, language, and technical skills.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation of Strategic Plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after the date on which the Director of National Intelligence submits the report required by subsection (a), the Director shall begin implementation of the strategic plan referred to in subsection (b)(4).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definitions of terms used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s335"},"text":"section 335 of Pub. L. 111–259","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/s2"},"text":"section 2 of Pub. L. 111–259","children":[],"tail":", set out as a Definitions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd19bdac0-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Date for First Report on Cooperation With Civilian Law Enforcement Agencies","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/272/tIII/s307/c"},"text":"Pub. L. 105–272, title III, § 307(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-20"},"text":"Oct. 20, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2402"},"text":"112 Stat. 2402","children":[],"tail":", provided that the first report under former subsec. (a) of this section was to be submitted not later than "},{"tag":"date","attrib":{"date":"1999-12-31"},"text":"Dec. 31, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
