{"tag":"section","attrib":{"id":"idd170f90f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2484"},"text":null,"children":[{"tag":"num","attrib":{"value":"2484"},"text":"§ 2484.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of preexisting laws and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"With respect to any facility, mission, or function of the Department of Energy that the Secretary of Energy transfers to the Administrator under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2481"},"text":"section 2481 of this title","children":[],"tail":", unless otherwise provided in this chapter, all provisions of law and regulations in effect immediately before the date of the transfer that are applicable to such facility, mission, or function shall continue to apply to the corresponding functions of the Administration."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd170f910-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dC/tXXXII/s3296"},"text":"Pub. L. 106–65, div. C, title XXXII, § 3296","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/971"},"text":"113 Stat. 971","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dC/tXXXI/s3132/b/2"},"text":"Pub. L. 112–239, div. C, title XXXI, § 3132(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2186"},"text":"126 Stat. 2186","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd170f911-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd170f912-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd170f913-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title XXXII of div. C of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/953"},"text":"113 Stat. 953","children":[],"tail":", which is classified principally to this chapter. For effective date of this chapter, see "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/s3299"},"text":"section 3299 of Pub. L. 106–65","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2401"},"text":"section 2401 of this title","children":[],"tail":". For complete classification of title XXXII to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2401"},"text":"section 2401 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd170f914-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “Unless otherwise provided in this chapter, all provisions of law and regulations in effect immediately before the effective date of this chapter that are applicable to functions of the Department of Energy specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2481"},"text":"section 2481 of this title","children":[],"tail":" shall continue to apply to the corresponding functions of the Administration.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd170f915-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd170f916-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2000-03-01"},"text":"Mar. 1, 2000","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/s3299"},"text":"section 3299 of Pub. L. 106–65","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2401"},"text":"section 2401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
