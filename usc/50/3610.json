{"tag":"section","attrib":{"id":"idd1f40c38-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3610"},"text":null,"children":[{"tag":"num","attrib":{"value":"3610"},"text":"§ 3610.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senior Cryptologic Executive Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1f40c39-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3610/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; applicable personnel provisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1f40c3a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3610/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense (or his designee) may by regulation establish a personnel system for senior civilian cryptologic personnel in the National Security Agency to be known as the Senior Cryptologic Executive Service. The regulations establishing the Senior Cryptologic Executive Service shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1f40c3b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3610/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the requirements set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3131"},"text":"section 3131 of title 5","children":[],"tail":" for the Senior Executive Service;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f40c3c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3610/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that positions in the Senior Cryptologic Executive Service meet requirements that are consistent with the provisions of section 3132(a)(2) of such title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f40c3d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3610/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide, without regard to section 2,","children":[{"tag":"ref","attrib":{"idref":"fn002110"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002110"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" rates of pay for the Senior Cryptologic Executive Service that are not in excess of the maximum rate or less than the minimum rate of basic pay established for the Senior Executive Service under section 5382 of such title, and that are adjusted at the same time and to the same extent as rates of basic pay for the Senior Executive Service are adjusted;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f40c3e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3610/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a performance appraisal system for the Senior Cryptologic Executive Service that conforms to the provisions of subchapter II of chapter 43 of such title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f40c3f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3610/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for removal consistent with section 3592 of such title, and removal or suspension consistent with subsections (a), (b), and (c) of section 7543 of such title (except that any hearing or appeal to which a member of the Senior Cryptologic Executive Service is entitled shall be held or decided pursuant to procedures established by regulations of the Secretary of Defense or his designee);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f40c40-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3610/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit the payment of performance awards to members of the Senior Cryptologic Executive Service consistent with the provisions applicable to performance awards under section 5384 of such title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f40c41-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3610/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that members of the Senior Cryptologic Executive Service may be granted sabbatical leaves consistent with the provisions of section 3396(c) of such title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f40c42-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3610/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the recertification of members of the Senior Cryptologic Executive Service consistent with the provisions of section 3393a ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of such title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f40c43-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3610/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as otherwise provided in subsection (a), the Secretary of Defense (or his designee) may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1f40c44-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3610/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make applicable to the Senior Cryptologic Executive Service any of the provisions of title 5 applicable to applicants for or members of the Senior Executive Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f40c45-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3610/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint, promote, and assign individuals to positions established within the Senior Cryptologic Executive Service without regard to the provisions of title 5 governing appointments and other personnel actions in the competitive service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f40c46-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3610/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President, based on the recommendations of the Secretary of Defense, may award ranks to members of the Senior Cryptologic Executive Service in a manner consistent with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s4507"},"text":"section 4507 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f40c47-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3610/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of this section, the Director of the National Security Agency may detail or assign any member of the Senior Cryptologic Executive Service to serve in a position outside the National Security Agency in which the member’s expertise and experience may be of benefit to the National Security Agency or another Government agency. Any such member shall not by reason of such detail or assignment lose any entitlement or status associated with membership in the Senior Cryptologic Executive Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f40c48-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3610/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merit pay system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense (or his designee) may by regulation establish a merit pay system for such employees of the National Security Agency as the Secretary of Defense (or his designee) considers appropriate. The merit pay system shall be designed to carry out purposes consistent with those set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5401/a"},"text":"section 5401(a) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f40c49-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3610/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum pay for fiscal year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to allow the aggregate amount payable to a member of the Senior Cryptologic Executive Service under this section during any fiscal year to exceed the annual rate payable for positions at level I of the Executive Schedule in effect at the end of such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1f40c4a-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/36/s12"},"text":"Pub. L. 86–36, § 12","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/89/tVI/s603"},"text":"Pub. L. 97–89, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-04"},"text":"Dec. 4, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1156"},"text":"95 Stat. 1156","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/194/tV/s506/c/2"},"text":"Pub. L. 101–194, title V, § 506(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-30"},"text":"Nov. 30, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1759"},"text":"103 Stat. 1759","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tX/s1064/b"},"text":"Pub. L. 104–106, div. A, title X, § 1064(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/445"},"text":"110 Stat. 445","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1f40c4b-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1f40c4c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1f40c4d-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tai