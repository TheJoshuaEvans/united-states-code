-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2296"},"text":"116 Stat. 2296","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Level I of the Executive Schedule, referred to in subsec. (c), is set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5312"},"text":"section 5312 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1f40c4e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified in a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s402"},"text":"section 402 of this title","children":[],"tail":" prior to editorial reclassification as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1f40c4f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" struck out par. (5), which required the Director of the National Security Agency to submit to the Permanent Select Committee on Intelligence of the House of Representatives and the Select Committee on Intelligence of the Senate annual reports on executive personnel in the National Security Agency."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/194/s506/c/2/A"},"text":"Pub. L. 101–194, § 506(c)(2)(A)","children":[],"tail":", struck out “and” at end of subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/194/s506/c/2/B"},"text":"Pub. L. 101–194, § 506(c)(2)(B)","children":[],"tail":", which directed amendment by inserting “and” after the semicolon at the end of subpar. (G), was executed by substituting “; and” for the period at the end of subpar. (G), to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/194/s506/c/2/C"},"text":"Pub. L. 101–194, § 506(c)(2)(C)","children":[],"tail":", added subpar. (H)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1f40c50-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd1f40c51-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/194"},"text":"Pub. L. 101–194","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1991-01-01"},"text":"Jan. 1, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/194/s506/d"},"text":"section 506(d) of Pub. L. 101–194","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3151"},"text":"section 3151 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd1f40c52-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","chil