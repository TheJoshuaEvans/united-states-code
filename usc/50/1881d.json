{"tag":"section","attrib":{"id":"idd14d1da8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1881d"},"text":"§ 1881d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint applications and concurrent authorizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd14d1da9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint applications and orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an acquisition targeting a United States person under section 1881b or 1881c of this title is proposed to be conducted both inside and outside the United States, a judge having jurisdiction under section 1881b(a)(1) or 1881c(a)(1) of this title may issue simultaneously, upon the request of the Government in a joint application complying with the requirements of sections 1881b(b) and 1881c(b) of this title, orders under sections 1881b(c) and 1881c(c) of this title, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd14d1daa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concurrent authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an order authorizing electronic surveillance or physical search has been obtained under section 1805 or 1824 of this title, the Attorney General may authorize, for the effective period of that order, without an order under section 1881b or 1881c of this title, the targeting of that United States person for the purpose of acquiring foreign intelligence information while such person is reasonably believed to be located outside the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd14d1dab-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency authorization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd14d1dac-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concurrent authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Attorney General authorized the emergency employment of electronic surveillance or a physical search pursuant to section 1805 or 1824 of this title, the Attorney General may authorize, for the effective period of the emergency authorization and subsequent order pursuant to section 1805 or 1824 of this title, without a separate order under section 1881b or 1881c of this title, the targeting of a United States person subject to such emergency employment for the purpose of acquiring foreign intelligence information while such United States person is reasonably believed to be located outside the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14d1dad-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an application submitted to the Court pursuant to section 1804 or 1823 of this title is denied, or in any other case in which the acquisition pursuant to paragraph (1) is terminated and no order with respect to the target of the acquisition is issued under section 1805 or 1824 of this title, all information obtained or evidence derived from such acquisition shall be handled in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1881c/d/4"},"text":"section 1881c(d)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd14d1dae-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511/tVII/s705"},"text":"Pub. L. 95–511, title VII, § 705","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/261/tI/s101/a/2"},"text":"Pub. L. 110–261, title I, § 101(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-10"},"text":"July 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2457"},"text":"122 Stat. 2457","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/118/tI/s105"},"text":"Pub. L. 115–118, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-01-19"},"text":"Jan. 19, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/13"},"text":"132 Stat. 13","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd14d1daf-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"idd14d1db0-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/261/tIV/s403/b/1"},"text":"Pub. L. 110–261, title IV, § 403(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-10"},"text":"July 10, 2008","children"