{"tag":"section","attrib":{"id":"idd152003c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1910"},"text":null,"children":[{"tag":"num","attrib":{"value":"1910"},"text":"§ 1910.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd152003d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1910/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal years 1993 and 1994","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated to carry out this chapter for fiscal years 1993 and 1994 shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd152003e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1910/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal years 1995 and 1996","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated from, and may be obligated from, the Fund for each of the fiscal years 1995 and 1996 not more than the amount credited to the Fund in interest only for the preceding fiscal year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1904/e"},"text":"section 1904(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd152003f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1910/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding from Intelligence Community Management Account for fiscal years beginning with fiscal year 2005","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts that may be made available to the Secretary under the Fund for a fiscal year, the Director of National Intelligence shall transfer to the Secretary from amounts appropriated for the Intelligence Community Management Account for each of fiscal years 2005 through 2021 $8,000,000 to carry out the scholarship, fellowship, and grant programs under subparagraphs (A), (B), and (C), respectively, of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1902/a/1"},"text":"section 1902(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1520040-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1910/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal years beginning with fiscal year 2022","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts that may be made available to the Secretary under the Fund for a fiscal year, there is authorized to be appropriated to the Secretary for each fiscal year, beginning with fiscal year 2022, $8,000,000, to carry out the scholarship, fellowship, and grant programs under subparagraphs (A), (B), and (C), respectively, of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1902/a/1"},"text":"section 1902(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1520041-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/183/tVIII/s810"},"text":"Pub. L. 102–183, title VIII, § 810","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/178/tIII/s311/c"},"text":"Pub. L. 103–178, title III, § 311(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2037"},"text":"107 Stat. 2037","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/487/tVI/s601/a"},"text":"Pub. L. 108–487, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3951"},"text":"118 Stat. 3951","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dW/tVI/s619/a"},"text":"Pub. L. 116–260, div. W, title VI, § 619(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2401"},"text":"134 Stat. 2401","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1520042-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1520043-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1520044-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s619/a/1"},"text":"Pub. L. 116–260, § 619(a)(1)","children":[],"tail":", substituted “for each of fiscal years 2005 through 2021” for “for each fiscal year, beginning with fiscal year 2005,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s619/a/2"},"text":"Pub. L. 116–260, § 619(a)(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/487"},"text":"Pub. L. 108–487","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
