{"tag":"section","attrib":{"id":"idd1e36aea-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3503"},"text":null,"children":[{"tag":"num","attrib":{"value":"3503"},"text":"§ 3503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1e36aeb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchases and contracts for supplies and services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the performance of its functions the Central Intelligence Agency is authorized to exercise the authorities contained in sections 3201, 3203, 3204, 3206, 3207, 3302 through 3306, 3321 through 3323, 3801 through 3808, 3066, 3134, 3841, and 4752 of title 10.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1e36aec-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Agency head” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the exercise of the authorities granted in subsection (a) of this section, the term “Agency head” shall mean the Director, the Deputy Director, or the Executive of the Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1e36aed-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classes of purchases and contracts; finality of decision; powers delegable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The determinations and decisions provided in subsection (a) of this section to be made by the Agency head may be made with respect to individual purchases and contracts or with respect to classes of purchases or contracts, and shall be final. Except as provided in subsection (d) of this section, the Agency head is authorized to delegate his powers provided in this section, including the making of such determinations and decisions, in his discretion and subject to his direction, to any other officer or officers or officials of the Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1e36aee-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3503/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers not delegable; written findings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The power of the Agency head to make the determinations or decisions specified in sections 3201 through 3204 of title 10 shall not be delegable. Each determination or decision required by sections 3201 through 3204, 3321 through 3323, and 3841 of title 10 shall be based upon written findings made by the official making such determinations, which findings shall be final and shall be available within the Agency for a period of at least six years following the date of the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1e36aef-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-20/ch227/s3"},"text":"June 20, 1949, ch. 227, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/208"},"text":"63 Stat. 208","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/269/tV/s502/a"},"text":"Pub. L. 97–269, title V, § 502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-27"},"text":"Sept. 27, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1145"},"text":"96 Stat. 1145","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dE/tLVI/s5607/f"},"text":"Pub. L. 104–106, div. E, title LVI, § 5607(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/702"},"text":"110 Stat. 702","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tIII/s7332"},"text":"Pub. L. 118–31, div. G, title III, § 7332","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1045"},"text":"137 Stat. 1045","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dF/tLXV/s6505"},"text":"Pub. L. 119–60, div. F, title LXV, § 6505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1629"},"text":"139 Stat. 1629","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1e36af0-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1e36af1-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1e36af2-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s403c"},"text":"section 403c of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1e36af3-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “3066” for “3069”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s7332/1"},"text":"Pub. L. 118–31, § 7332(1)","children":[],"tail":", substituted “sections 3201, 3203, 3204, 3206, 3207, 3302 through 3306, 3321 through 3323, 3801 through 3808, 3069, 3134, 3841, and 4752 of title 10” for “sections 2304(a)(1) to (6), (10), (12), (15), (17), and sections 2305(a) to (c), 2306, 2307, 2308, 2309, 2312, and 2313 of title 10”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s7332/2"},"text":"Pub. L. 118–31, § 7332(2)","children":[],"tail":", which directed substitution of “in sections 3201 through 3204 of title 10 shall not be delegable. Each determination or decision required by sections 3201 through 3204, 3321 through 3323, and 3841 of title 10” for “ ‘in paragraphs’ and all that follows through ‘1947’ ”, was executed by making the substitution for “in paragraphs (12) and (15) of section 2304(a) and "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2307/a"},"text":"section 2307(a) of title 10","children":[],"tail":" shall not be delegable. Each determination or decision required by paragraphs (12) and (15) of section 2304(a), by sections 2306 and 2313, or by "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2307/a"},"text":"section 2307(a) of title 10","children":[],"tail":"”, which had read in the original “in paragraphs (12) and (15) of section 2(c) and section 5(a) of the Armed Services Procurement Act of 1947 shall not be delegable. Each determination or decision required by paragraphs (12) and (15) of section 2(c), by section 4 or by section 5(a) of the Armed Services Procurement Act of 1947”, to reflect the probable intent of Congress. In the original text, “1947” appeared twice, and amendment was executed as if striking out text through “1947” the second time appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" struck out subsec. (e) which read as follows: “Notwithstanding subsection (e) of "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s759"},"text":"section 759 of title 40","children":[],"tail":", the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s759"},"text":"section 759 of title 40","children":[],"tail":" relating to the procurement of automatic data processing equipment or services shall not apply with respect to such procurement by the Central Intelligence Agency.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/269"},"text":"Pub. L. 97–269","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1e36af4-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd1e36af5-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/s5701"},"text":"section 5701 of Pub. L. 104–106","children":[],"tail":", div. E, title LVII, "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/702"},"text":"110 Stat. 702","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd1e36af6-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/269/tVII/s703"},"text":"Pub. L. 97–269, title VII, § 703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-27"},"text":"Sept. 27, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1155"},"text":"96 Stat. 1155","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/269/tVII/s703"},"text":"“The provisions of titles IV and V [enacting former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s202"},"text":"section 202 of Title 10","children":[],"tail":", Armed Forces, and amending this section] and of this title [which, except for enacting this note was not classified to the Code] shall become effective upon the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1982-09-27"},"text":"Sept. 27, 1982","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1e36af7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Procurement of Automatic Data Processing Equipment or Services; Contracts Made Before ","children":[{"tag":"date","attrib":{"date":"1982-09-27"},"text":"September 27, 1982","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/269/tV/s502/b"},"text":"Pub. L. 97–269, title V, § 502(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-27"},"text":"Sept. 27, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1145"},"text":"96 Stat. 1145","children":[],"tail":", provided that former subsec. (e) of this section did not apply to a contract made before "},{"tag":"date","attrib":{"date":"1982-09-27"},"text":"Sept. 27, 1982","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
