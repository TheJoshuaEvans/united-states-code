{"tag":"section","attrib":{"id":"idd0e90473-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98c"},"text":null,"children":[{"tag":"num","attrib":{"value":"98c"},"text":"§ 98c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Materials constituting the National Defense Stockpile","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd0e90474-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The stockpile consists of the following materials:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0e90475-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Materials acquired under this subchapter and contained in the national stockpile on ","children":[{"tag":"date","attrib":{"date":"1979-07-29"},"text":"July 29, 1979","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0e90476-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Materials acquired under this subchapter after ","children":[{"tag":"date","attrib":{"date":"1979-07-29"},"text":"July 29, 1979","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0e90477-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Materials in the supplemental stockpile established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1704/b"},"text":"section 1704(b) of title 7","children":[],"tail":" (as in effect from "},{"tag":"date","attrib":{"date":"1959-09-21"},"text":"September 21, 1959","children":[],"tail":", through "},{"tag":"date","attrib":{"date":"1966-12-31"},"text":"December 31, 1966","children":[],"tail":") on "},{"tag":"date","attrib":{"date":"1979-07-29"},"text":"July 29, 1979","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0e90478-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Materials acquired by the United States under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4533"},"text":"section 4533 of this title","children":[],"tail":" and transferred to the stockpile by the President pursuant to subsection (f) of such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0e90479-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98c/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Materials transferred to the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2423"},"text":"section 2423 of title 22","children":[],"tail":" that have been determined to be strategic and critical materials for the purposes of this subchapter and that are allocated by the President under subsection (b) of such section for stockpiling in the stockpile."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0e9047a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98c/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Materials acquired by the Commodity Credit Corporation and transferred to the stockpile under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s714b/h"},"text":"section 714b(h) of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0e9047b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98c/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Materials acquired by the Commodity Credit Corporation under paragraph (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1743/a"},"text":"section 1743(a) of title 7","children":[],"tail":", and transferred to the stockpile under the third sentence of such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0e9047c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98c/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Materials transferred to the stockpile by the President under paragraph (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1743/a"},"text":"section 1743(a) of title 7","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0e9047d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98c/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Materials transferred to the stockpile under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0e9047e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98c/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Materials transferred to the stockpile under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0e9047f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer and reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, any material that (1) is under the control of any department or agency of the United States, (2) is determined by the head of such department or agency to be excess to its needs and responsibilities, and (3) is suitable for transfer or disposal through the stockpile shall be transferred to the stockpile. Any such transfer shall be made without reimbursement to such department or agency, but all costs required to effect such transfer shall be paid or reimbursed from funds appropriated to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0e90480-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer and disposal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense shall determine whether materials are suitable for transfer to the stockpile under subsection (b), are suitable for disposal through the stockpile, and are uncontaminated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd0e90481-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-06-07/ch190/s4"},"text":"June 7, 1939, ch. 190, § 4","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/41/s2/a"},"text":"Pub. L. 96–41, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-30"},"text":"July 30, 1979","children":[],"tail":", "},{"ta