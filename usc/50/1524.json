{"tag":"section","attrib":{"id":"idd10f29e4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1524"},"text":null,"children":[{"tag":"num","attrib":{"value":"1524"},"text":"§ 1524.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements to provide support to vaccination programs of Department of Health and Human Services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd10f29e5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1524/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense may enter into agreements with the Secretary of Health and Human Services to provide support for vaccination programs of the Secretary of Health and Human Services in the United States through use of the excess peacetime biological weapons defense capability of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd10f29e6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1524/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1994-02-01"},"text":"February 1, 1994","children":[],"tail":", the Secretary of Defense shall submit to the congressional defense committees a report on the feasibility of providing Department of Defense support for vaccination programs under subsection (a) and shall identify resource requirements that are not within the Department’s capability."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd10f29e7-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tXVII/s1705"},"text":"Pub. L. 103–160, div. A, title XVII, § 1705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1856"},"text":"107 Stat. 1856","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd10f29e8-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd10f29e9-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd10f29ea-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Defense Authorization Act for Fiscal Year 1994, and not as part of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/121/tIV/s409"},"text":"Pub. L. 91–121, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-11-19"},"text":"Nov. 19, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/209"},"text":"83 Stat. 209","children":[],"tail":", which comprises this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd10f29eb-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd10f29ec-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Congressional Defense Committees” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Congressional defense committees means the Committees on Armed Services and the Committees on Appropriations of the Senate and House of Representatives, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s3"},"text":"section 3 of Pub. L. 103–160","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1562"},"text":"107 Stat. 1562","children":[],"tail":". See note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
