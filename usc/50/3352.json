loyment, fitness for contractor employees, and eligibility for access to classified national security information), or any successor entity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1d513d7-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLXVI/s6601"},"text":"Pub. L. 116–92, div. E, title LXVI, § 6601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2209"},"text":"133 Stat. 2209","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1d513d8-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1d513d9-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1d513da-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in text, means title LXVI of div. E of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":", which enacted this section and sections 3162a and 3352a to 3352f of this title and amended sections 3033, 3104, 3163, and 3164 of this title. For complete classification of title LXVI to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Executive Order No. 12829, referred to in par. (2), is Ex. Ord. No. 12829, ","children":[{"tag":"date","attrib":{"date":"1993-01-06"},"text":"Jan. 6, 1993","children":[],"tail":", 58 F.R. 3479, which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"tex