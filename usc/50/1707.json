{"tag":"section","attrib":{"id":"idd135507d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1707"},"text":null,"children":[{"tag":"num","attrib":{"value":"1707"},"text":"§ 1707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multinational economic embargoes against governments in armed conflict with the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd135507e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy on the establishment of embargoes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the policy of the United States, that upon the use of the Armed Forces of the United States to engage in hostilities against any foreign country, the President shall, as appropriate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd135507f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1707/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek the establishment of a multinational economic embargo against such country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1355080-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1707/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek the seizure of its foreign financial assets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1355081-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1707/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 20 days after the first day of the engagement of the United States in hostilities described in subsection (a), the President shall, if the armed conflict has continued for 14 days, submit to Congress a report setting forth—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1355082-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1707/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific steps the United States has taken and will continue to take to establish a multinational economic embargo and to initiate financial asset seizure pursuant to subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1355083-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1707/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any foreign sources of trade or revenue that directly or indirectly support the ability of the adversarial government to sustain a military conflict against the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1355084-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tXII/s1231"},"text":"Pub. L. 106–65, div. A, title XII, § 1231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/788"},"text":"113 Stat. 788","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1355085-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1355086-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1355087-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Defense Authorization Act for Fiscal Year 2000, and not as part of the International Emergency Economic Powers Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
