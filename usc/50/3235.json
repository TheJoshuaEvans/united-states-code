{"tag":"section","attrib":{"id":"idd1c47137-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3235"},"text":null,"children":[{"tag":"num","attrib":{"value":"3235"},"text":"§ 3235.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Semiannual reports on investigations of unauthorized disclosures of classified information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1c47138-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3235/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c47139-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3235/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered official","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered official” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c4713a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3235/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the heads of each element of the intelligence community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c4713b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3235/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the inspectors general with oversight responsibility for an element of the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c4713c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3235/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “investigation” means any inquiry, whether formal or informal, into the existence of an unauthorized public disclosure of classified information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c4713d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3235/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unauthorized disclosure of classified information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “unauthorized disclosure of classified information” means any unauthorized disclosure of classified information to any recipient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c4713e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3235/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unauthorized public disclosure of classified information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “unauthorized public disclosure of classified information” means the unauthorized disclosure of classified information to a journalist or media organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c4713f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3235/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intelligence community reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c47140-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3235/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less frequently than once every 6 months, each covered official shall submit to the congressional intelligence committees a report on investigations of unauthorized public disclosures of classified information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c47141-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3235/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted under paragraph (1) shall include, with respect to the preceding 6-month period, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c47142-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3235/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of investigations opened by the covered official regarding an unauthorized public disclosure of classified information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c47143-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3235/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of investigations completed by the covered official regarding an unauthorized public disclosure of classified information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c47144-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3235/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of the number of such completed investigations identified under subparagraph (B), the number referred to the Attorney General for criminal investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c47145-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3235/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Justice reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c47146-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3235/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less frequently than once every 6 months, the Assistant Attorney General for National Security of the Department of Justice, in consultation with the Director of the Federal Bureau of Investigation, shall submit to the congressional intelligence committees, the Committee on the Judiciary of the Senate, and the Committee on the Judiciary of the House of Representatives a report on the status of each referral made to the Department of Justice from any element of the intelligence community regarding an unauthorized disclosure of classified information made during the most recent 365-day period or any referral that has not yet been closed, regardless of the date the referral was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c47147-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3235/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted under paragraph (1) shall include, for each referral covered by the report, at a minimum, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c47148-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3235/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The date the referral was received.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c47149-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3235/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A statement indicating whether the alleged unauthorized disclosure described in the referral was substantiated by the Department of Justice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c4714a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3235/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A statement indicating the highest level of classification of the information that was revealed in the unauthorized disclosure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c4714b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3235/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A statement indicating whether an open criminal investigation related to the referral is active.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c4714c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3235/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A statement indicating whether any criminal charges have been filed related to the referral.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c4714d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3235/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A statement indicating whether the Department of Justice has been able to attribute the unauthorized disclosure to a particular entity or individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c4714e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3235/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report submitted under this section shall be submitted in unclassified form, but may have a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1c4714f-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title XI, § 1105, as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLXVII/s6718/a"},"text":"Pub. L. 116–92, div. E, title LXVII, § 6718(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2228"},"text":"133 Stat. 2228","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
