{"tag":"section","attrib":{"id":"idd1c92b6a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3307"},"text":null,"children":[{"tag":"num","attrib":{"value":"3307"},"text":"§ 3307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Communications with the Committees on Armed Services of the Senate and the House of Representatives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1c92b6b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3307/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests of committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Counterterrorism Center, the Director of a national intelligence center, or the head of any element of the intelligence community shall, not later than 45 days after receiving a written request from the Chair or ranking minority member of the Committee on Armed Services of the Senate or the Committee on Armed Services of the House of Representatives for any existing intelligence assessment, report, estimate, or legal opinion relating to matters within the jurisdiction of such Committee, make available to such committee such assessment, report, estimate, or legal opinion, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c92b6c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3307/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assertion of privilege","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c92b6d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3307/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In response to a request covered by subsection (a), the Director of the National Counterterrorism Center, the Director of a national intelligence center, or the head of any element of the intelligence community shall provide to the Committee making such request the document or information covered by such request unless the President determines that such document or information shall not be provided because the President is asserting a privilege pursuant to the Constitution of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c92b6e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3307/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The White House Counsel shall submit to Congress in writing any assertion by the President under paragraph (1) of a privilege pursuant to the Constitution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c92b6f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3307/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c92b70-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3307/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intelligence community","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “intelligence community” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003/4"},"text":"section 3003(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c92b71-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3307/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intelligence assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “intelligence assessment” means an intelligence-related analytical study of a subject of policy significance and does not include building-block papers, research projects, and reference aids.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c92b72-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3307/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intelligence estimate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “intelligence estimate” means an appraisal of available intelligence relating to a specific situation or condition with a view to determining the courses of action open to an enemy or potential enemy and the probable order of adoption of such courses of action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1c92b73-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tX/s1079"},"text":"Pub. L. 110–181, div. A, title X, § 1079","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/334"},"text":"122 Stat. 334","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1c92b74-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1c92b75-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1c92b76-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s413c"},"text":"section 413c of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
