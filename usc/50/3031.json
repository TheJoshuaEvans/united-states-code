{"tag":"section","attrib":{"id":"idd1923cd8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3031"},"text":null,"children":[{"tag":"num","attrib":{"value":"3031"},"text":"§ 3031.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of the National Counterintelligence and Security Center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1923cd9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3031/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of the National Counterintelligence and Security Center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Counterintelligence and Security Center appointed under section 902 of the Counterintelligence Enhancement Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3382"},"text":"50 U.S.C. 3382","children":[],"tail":") is a component of the Office of the Director of National Intelligence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1923cda-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3031/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Counterintelligence and Security Center shall perform the duties provided in the Counterintelligence Enhancement Act of 2002 and such other duties as may be prescribed by the Director of National Intelligence or specified by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1923cdb-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":