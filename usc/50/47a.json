{"tag":"section","attrib":{"id":"idd0e449c2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s47a"},"text":null,"children":[{"tag":"num","attrib":{"value":"47a"},"text":"§ 47a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information concerning illegal introduction, manufacture, acquisition or export of special nuclear material or atomic weapons or conspiracies relating thereto; reward","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any person who furnishes original information to the United States—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd0e449c3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s47a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leading to the finding or other acquisition by the United States of special nuclear material or an atomic weapon which has been introduced into the United States or manufactured or acquired therein contrary to the laws of the United States, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0e449c4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s47a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the introduction or attempted introduction into the United States or the manufacture or acquisition or attempted manufacture or acquisition of, or a conspiracy to introduce into the United States or to manufacture or acquire, special nuclear material or an atomic weapon contrary to the laws of the United States, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0e449c5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s47a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the export or attempted export, or a conspiracy to export, special nuclear material or an atomic weapon from the United States contrary to the laws of the United States,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be rewarded by the payment of an amount not to exceed $500,000.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd0e449c6-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-15/ch372/s2"},"text":"July 15, 1955, ch. 372, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/365"},"text":"69 Stat. 365","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/377/s1/b"},"text":"Pub. L. 93–377, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-17"},"text":"Aug. 17, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/472"},"text":"88 Stat. 472","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd0e449c7-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd0e449c8-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd0e449c9-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/377"},"text":"Pub. L. 93–377","children":[],"tail":" in par. (a) made minor changes in phraseology, in par. (b) included information relating to the actual introduction, manufacture and acquisition, or conspiring to introduce into the United States or to manufacture or acquire special nuclear material or an atomic weapon as within the information for which a reward would be given, and added par. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd0e693ba-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idd0e693bb-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-15/ch372/s1"},"text":"Act July 15, 1955, ch. 372, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/365"},"text":"69 Stat. 365","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/93/377/s1/a"},"text":"Pub. L. 93–377, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-17"},"text":"Aug. 17, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/472"},"text":"88 Stat. 472","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/93/377/s1/a"},"text":"“That this Act [enacting this chapter] may be cited as the ‘Atomic Weapons and Special Nuclear Materials Rewards Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
