{"tag":"section","attrib":{"id":"idd16c17f3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2443"},"text":null,"children":[{"tag":"num","attrib":{"value":"2443"},"text":"§ 2443.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of employee practices affecting national security","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd16c17f4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2443/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual notification of security clearance revocations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At or about the time that the President’s budget is submitted to Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":", the Administrator shall notify the appropriate congressional committees of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16c17f5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2443/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of covered employees whose security clearance was revoked during the year prior to the year in which the notification is made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16c17f6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2443/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each employee counted under paragraph (1), the length of time such employee has been employed at the Administration, as the case may be, since such revocation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16c17f7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2443/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual notification of terminations and removals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than December 31 of each year, the Administrator shall notify the appropriate congressional committees of each instance in which the Administrator terminated the employment of a covered employee or removed and reassigned a covered employee for cause during that year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16c17f8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2443/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16c17f9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2443/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd16c17fa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2443/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional defense committees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16c17fb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2443/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Commerce of the House of Representatives and the Committee on Energy and Natural Resources of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16c17fc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2443/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered employee” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd16c17fd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2443/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee of the Administration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16c17fe-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2443/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee of an element of the Department of Energy (other than the Administration) involved in nuclear security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd16c17ff-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dC/tXXXII/s3245"},"text":"Pub. L. 106–65, div. C, title XXXII, § 3245","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dC/tXXXI/s3111/a/1"},"text":"Pub. L. 114–92, div. C, title XXXI, § 3111(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1186"},"text":"129 Stat. 1186","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dC/tXXXI/s3131/a"},"text":"Pub. L. 117–81, div. C, title XXXI, § 3131(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2229"},"text":"135 Stat. 2229","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd16c1800-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd16c1801-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd16c1802-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2443, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dC/tXXXII/s3245"},"text":"Pub. L. 106–65, div. C, title XXXII, § 3245","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/377/s1/a/2/tIII/s315"},"text":"Pub. L. 106–377, § 1(a)(2) [title III, § 315]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-27"},"text":"Oct. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1441"},"text":"114 Stat. 1441","children":[],"tail":", 1441A–81, related to prohibition on pay of personnel engaged in concurrent service or duties inside and outside Administration, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dC/tXXXI/s3143"},"text":"Pub. L. 107–107, div. C, title XXXI, § 3143","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1371"},"text":"115 Stat. 1371","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd16c1803-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" added subsecs. (a) and (b) and struck out former subsecs. (a) and (b), which related to annual notification and notification to congressional committees, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
