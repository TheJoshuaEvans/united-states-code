{"tag":"section","attrib":{"id":"idd24057d5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4587"},"text":null,"children":[{"tag":"num","attrib":{"value":"4587"},"text":"§ 4587.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd24057d6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4587/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations issued under section 4581 or 4582 of this title shall provide for the imposition of civil penalties described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd24057d7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4587/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties described","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd24057d8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4587/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful acts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for a person to violate, attempt to violate, conspire to violate, or cause a violation of any order, regulation, notification requirement, or prohibition issued under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd24057d9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4587/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may impose civil penalties on any person who commits an unlawful act described in paragraph (1) in amounts equivalent to amounts provided for under section 206(b) of the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1705/b"},"text":"50 U.S.C. 1705(b)","children":[],"tail":") for violations under that Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd24057da-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4587/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Divestment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may compel the divestment of a covered national security transaction in a prohibited technology determined to be in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4581/a"},"text":"section 4581(a) of this title","children":[],"tail":" or regulations issued thereunder."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd24057db-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4587/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relief","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may direct the Attorney General of the United States to seek appropriate relief, including divestment relief for violations of the prohibition set forth in subsection ","children":[{"tag":"ref","attrib":{"idref":"fn002145"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002145"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" 4581(a) of this title, in the district courts of the United States, in order to implement and enforce this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd24057dc-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-08/ch932"},"text":"Sept. 8, 1950, ch. 932","children":[],"tail":", title VIII, § 807, as added "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXV/s8521"},"text":"Pub. L. 119–60, div. H, title LXXXV, § 8521","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1930"},"text":"139 Stat. 1930","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd24057dd-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd24057de-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd24057df-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The International Emergency Economic Powers Act, referred to in subsec. (b)(2), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/223"},"text":"Pub. L. 95–223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-28"},"text":"Dec. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1626"},"text":"91 Stat. 1626","children":[],"tail":", which is classified generally to chapter 35 (§ 1701 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
