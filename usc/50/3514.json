{"tag":"section","attrib":{"id":"idd1e824c5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3514"},"text":null,"children":[{"tag":"num","attrib":{"value":"3514"},"text":"§ 3514.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retirement equity for spouses of certain employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1e824c6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3514/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner and extent of applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of sections 2002, 2031(b)(1)–(3), 2031(f), 2031(g), 2031(i)(2), 2031(j), 2031(m), 2032, 2033, 2034, 2035, 2052(b), 2071(b), 2071(d), and 2094(b) of this title establishing certain requirements, limitations, rights, entitlements, and benefits relating to retirement annuities, survivor benefits, and lump-sum payments for a spouse or former spouse of an Agency employee who is a participant in the Central Intelligence Agency Retirement and Disability System shall apply in the same manner and to the same extent in the case of an Agency employee who is a participant in the Civil Service Retirement and Disability System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1e824c7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3514/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Office of Personnel Management, in consultation with the Director of the Central Intelligence Agency, shall prescribe such regulations as may be necessary to implement the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1e824c8-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-20/ch227/s14"},"text":"June 20, 1949, ch. 227, § 14","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/269/tVI/s612"},"text":"Pub. L. 97–269, title VI, § 612","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-27"},"text":"Sept. 27, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1154"},"text":"96 Stat. 1154","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/569/tIII/s302/b"},"text":"Pub. L. 99–569, title III, § 302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3194"},"text":"100 Stat. 3194","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/178/tIV"},"text":"Pub. L. 100–178, title IV","children":[],"tail":", §§ 401(b), 402(b)(3), "},{"tag":"date","attrib":{"date":"1987-12-02"},"text":"Dec. 2, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1013"},"text":"101 Stat. 1013","children":[],"tail":", 1014; "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s803/a/1"},"text":"Pub. L. 102–496, title VIII, § 803(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3251"},"text":"106 Stat. 3251","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI/s1071/b/3/A"},"text":"Pub. L. 108–458, title I, § 1071(b)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3690"},"text":"118 Stat. 3690","children":[],"tail":"; "},{"tag":"ref","attrib":