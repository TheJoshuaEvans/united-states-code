{"tag":"section","attrib":{"id":"idd1bf8e7d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3172"},"text":null,"children":[{"tag":"num","attrib":{"value":"3172"},"text":"§ 3172.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of stay","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever the President determines and reports to Congress in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3173"},"text":"section 3173 of this title","children":[],"tail":" that a stay of sanctions or related actions pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3171"},"text":"section 3171 of this title","children":[],"tail":" has not afforded sufficient time to obviate the risk to an ongoing criminal investigation or to an intelligence source or method that gave rise to the stay, he may extend such stay for a period of time specified by the President, which period may not exceed 120 days. The authority of this section may be used to extend the period of a stay pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3171"},"text":"section 3171 of this title","children":[],"tail":" for successive periods of not more than 120 days each."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd1bf8e7e-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title IX, § 902, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/93/tIII/s303/a"},"text":"Pub. L. 104–93, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-01-06"},"text":"Jan. 6, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/964"},"text":"109 Stat. 964","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1bf8e7f-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1bf8e80-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1bf8e81-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s441a"},"text":"section 441a of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
