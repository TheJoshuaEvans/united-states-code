{"tag":"section","attrib":{"id":"idd1e5b484-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3510a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3510a"},"text":"§ 3510a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of appropriations for construction projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"During the current fiscal year and thereafter, funds appropriated for construction projects of the Central Intelligence Agency, which are transferred to another Agency for execution, shall remain available until expended.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd1e5b485-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/139/tVIII/s8104"},"text":"Pub. L. 103–139, title VIII, § 8104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-11"},"text":"Nov. 11, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1463"},"text":"107 Stat. 1463","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1e5b486-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1e5b487-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1e5b488-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s403j"},"text":"section 403j of this title","children":[],"tail":" prior to editorial reclassification as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Department of Defense Appropriations Act, 1994, and not as part of the Central Intelligence Agency Act of 1949 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd1e5b489-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/396/tIX/s9030"},"text":"Pub. L. 102–396, title IX, § 9030","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1907"},"text":"106 Stat. 1907","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/172/tVIII/s8030"},"text":"Pub. L. 102–172, title VIII, § 8030","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-26"},"text":"Nov. 26, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1177"},"text":"105 Stat. 1177","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/511/tVIII/s8031"},"text":"Pub. L. 101–511, title VIII, § 8031","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1881"},"text":"104 Stat. 1881","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/165/tIX/s9042"},"text":"Pub. L. 101–165, title IX, § 9042","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11