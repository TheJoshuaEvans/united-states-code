{"tag":"section","attrib":{"id":"idd15de763-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2095"},"text":null,"children":[{"tag":"num","attrib":{"value":"2095"},"text":"§ 2095.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Recovery of payments under this subchapter may not be made from an individual when, in the judgment of the Director, the individual is without fault and recovery would be against equity and good conscience. Withholding or recovery of money payable pursuant to this subchapter on account of a certification or payment made by a former employee of the Agency in the discharge of the former employee’s official duties may be made if the Director certifies that the certification or payment involved fraud on the part of the former employee.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd15de764-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/tII/s265"},"text":"Pub. L. 88–643, title II, § 265","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s802"},"text":"Pub. L. 102–496, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3237"},"text":"106 Stat. 3237","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/178/tII/s202/a/13"},"text":"Pub. L. 103–178, title II, § 202(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2027"},"text":"107 Stat. 2027","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd15de765-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"ta