{"tag":"section","attrib":{"id":"idd15b7565-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2054"},"text":null,"children":[{"tag":"num","attrib":{"value":"2054"},"text":"§ 2054.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discontinued service benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd15b7566-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2054/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deferred annuity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A participant who separates from the Agency may, upon separation or at any time before the commencement of an annuity under this subchapter, elect—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15b7567-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2054/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to have the participant’s contributions to the fund returned to the participant in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2071/a"},"text":"section 2071(a) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15b7568-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2054/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except in a case in which the Director determines that separation was based in whole or in part on the ground of disloyalty to the United States, to leave the contributions in the fund and receive an annuity, computed as prescribed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2031"},"text":"section 2031 of this title","children":[],"tail":", commencing at age 62."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15b7569-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2054/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refund of contributions if former participant dies before age 62","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a participant who qualifies under subsection (a) to receive a deferred annuity commencing at age 62 dies before reaching age 62, the participant’s contributions to the fund, with interest, shall be paid in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2071"},"text":"section 2071 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd15b756a-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/tII/s234"},"text":"Pub. L. 88–643, title II, § 234","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s802"},"text":"Pub. L. 102–496, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3225"},"text":"106 Stat. 3225","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/178/tII/s202/a/10"},"text":"Pub. L. 103–178, title II, § 202(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2026"},"text":"107 Stat. 2026","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd15b756b-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd15b756c-47c4-11f1-8bcf-c89722bddd2e"},"tex