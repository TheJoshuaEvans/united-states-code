{"tag":"section","attrib":{"id":"idd1e36ad4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3501"},"text":null,"children":[{"tag":"num","attrib":{"value":"3501"},"text":"§ 3501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"When used in this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1e36ad5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Agency” means the Central Intelligence Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1e36ad6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Director” means the Director of the Central Intelligence Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1e36ad7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3501/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Government agency” means any executive department, commission, council, independent establishment, corporation wholly or partly owned by the United States which is an instrumentality of the United States, board, bureau, division, service, office, officer, authority, administration, or other establishment, in the executive branch of the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1e36ad8-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-20/ch227/s1"},"text":"June 20, 1949, ch. 227, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/208"},"text":"63 Stat. 208","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/707/tV/s511/a/3"},"text":"Pub. L. 86–707, title V, § 511(a)(3)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1960-09-06"},"text":"Sept. 6, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/800"},"text":"74 Stat. 800","children":[],"tail":", 801; "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI/s1077"},"text":"Pub. L. 108–458, title I, § 1077","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3695"},"text":"118 Stat. 3695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1e36ad9-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1e36ada-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1e36adb-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s403a"},"text":"section 403a of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1e36adc-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" redesignated subsecs. (a) to (c) as pars. (1) to (3), respectively, and amended par. (2) generally. Prior to amendment, par. (2) read as follows: “ ‘Director’ means the Director of Central Intelligence;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/707/s511/c/1"},"text":"Pub. L. 86–707, § 511(c)(1)","children":[],"tail":", substituted “Government.” for “Government; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/707/s511/a/3"},"text":"Pub. L. 86–707, § 511(a)(3)","children":[],"tail":", repealed subsec. (d) which defined “continental United States”. See "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5921"},"text":"section 5921 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1e36add-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd1e36ade-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For Determination by President that amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" take effect on "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", see Memorandum of President of the United States, "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", 70 F.R. 23925, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" effective not later than six months after "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1097/a"},"text":"section 1097(a) of Pub. L. 108–458","children":[],"tail":", set out in an Effective Date of 2004 Amendment; Transition Provisions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idd1e36adf-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-20/ch227/s10"},"text":"Act June 20, 1949, ch. 227, § 10","children":[],"tail":", formerly § 12, "},{"tag":"ref","attrib":{"href":"/us/stat/63/213"},"text":"63 Stat. 213","children":[],"tail":"; renumbered § 10, "},{"tag":"date","attrib":{"date":"1958-07-07"},"text":"July 7, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/507/s21/b/2"},"text":"Pub. L. 85–507, § 21(b)(2)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/337"},"text":"72 Stat. 337","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/85/507/s21/b/2"},"text":"“This Act [see Tables for classification] may be cited as the ‘Central Intelligence Agency Act of 1949’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"separability","id":"idd1e36ae0-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Separability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-20/ch227/s9"},"text":"Act June 20, 1949, ch. 227, § 9","children":[],"tail":", formerly § 11, "},{"tag":"ref","attrib":{"href":"/us/stat/63/213"},"text":"63 Stat. 213","children":[],"tail":"; renumbered § 9, "},{"tag":"date","attrib":{"date":"1958-07-07"},"text":"July 7, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/507/s21/b/2"},"text":"Pub. L. 85–507, § 21(b)(2)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/337"},"text":"72 Stat. 337","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/85/507/s21/b/2"},"text":"“If any provision of this Act [see Tables for classification], or the application of such provision to any person or circumstances, is held invalid, the remainder of this Act or the application of such provision to persons or circumstances other than those as to which it is held invalid, shall not be affected thereby.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1e36ae1-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Designation of Headquarters Compound of Central Intelligence Agency as the George Bush Center for Intelligence","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/272/tIII/s309"},"text":"Pub. L. 105–272, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-20"},"text":"Oct. 20, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2403"},"text":"112 Stat. 2403","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/272/tIII/s309"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The headquarters compound of the Central Intelligence Agency located in Langley, Virginia, shall be known and designated as the ‘George Bush Center for Intelligence’.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"References","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any reference in a law, map, regulation, document, paper, or other record of the United States to the headquarters compound referred to in subsection (a) shall be deemed to be a reference to the ‘George Bush Center for Intelligence’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
