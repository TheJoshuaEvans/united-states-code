{"tag":"section","attrib":{"id":"idd16030d2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2143"},"text":null,"children":[{"tag":"num","attrib":{"value":"2143"},"text":"§ 2143.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative forms of annuities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd16030d3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2143/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority for alternative form of annuity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall prescribe regulations under which any participant who has a life-threatening affliction or other critical medical condition may, at the time of retiring under this subchapter (other than under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2051"},"text":"section 2051 of this title","children":[],"tail":"), elect annuity benefits under this section instead of any other benefits under this subchapter (including any survivor benefits under this subchapter) based on the service of the participant creditable under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16030d4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2143/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis for alternative forms of annuity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations and alternative forms of annuity shall, to the maximum extent practicable, meet the requirements prescribed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8343a"},"text":"section 8343a of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16030d5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2143/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lump-sum credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any lump-sum credit provided pursuant to an election under subsection (a) shall not preclude an individual from receiving other benefits provided under that subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16030d6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2143/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of regulations to congressional intelligence committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall submit the regulations prescribed under subsection (a) to the congressional intelligence committees before the regulations take effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd16030d7-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/tII/s294"},"text":"Pub. L. 88–643, title II, § 294","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s802"},"text":"Pub. L. 102–496, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3242"},"text":"106 Stat. 3242","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXI/s11002/c"},"text":"Pub. L. 103–66, title XI, § 11002(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-0