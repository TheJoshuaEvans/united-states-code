{"tag":"section","attrib":{"id":"idd0f75d2f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167p"},"text":null,"children":[{"tag":"num","attrib":{"value":"167p"},"text":"§ 167p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Helium-3 separation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd0f75d30-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167p/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency cooperation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall cooperate with the Secretary of Energy, or a designee, on any assessment or research relating to the extraction and refining of the isotope helium-3 from crude helium and other potential sources, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0f75d31-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167p/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gas analysis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f75d32-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167p/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" infrastructure studies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0f75d33-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167p/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feasibility study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Secretary of Energy, or a designee, may carry out a study to assess the feasibility of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0f75d34-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167p/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a facility to separate the isotope helium-3 from crude helium; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f75d35-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167p/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exploring other potential sources of the isotope helium-3.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0f75d36-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167p/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2013-10-02"},"text":"October 2, 2013","children":[],"tail":", the Secretary shall submit to the Committee on Energy and Natural Resources of the Senate and the Committee on Natural Resources of the House of Representatives a report that contains a description of the results of the assessments conducted under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0f75d37-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167p/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $1,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd0f75d38-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1925-03-03/ch426/s18"},"text":"Mar. 3, 1925, ch. 426, § 18","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/40/s6/3"},"text":"Pub. L. 113–40, § 6(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-10-02"},"text":"Oct. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/543"},"text":"127 Stat. 543","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
