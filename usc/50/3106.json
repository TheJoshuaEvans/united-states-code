349/1/B"},"text":"Pub. L. 111–259, § 349(1)(B)","children":[],"tail":", struck out subpars. (C) and (D) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) The annual report on improvements of the financial statements of the intelligence community for auditing purposes required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s404i–1"},"text":"section 404i–1 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) The annual report on counterdrug intelligence matters required by section 826 of the Intelligence Authorization Act for Fiscal Year 2003.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s501/b/3"},"text":"Pub. L. 111–259, § 501(b)(3)","children":[],"tail":", redesignated pars. (4) and (5) as (3) and (4), respectively, and struck out former par. (3) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) The semiannual reports on the activities of the Diplomatic Telecommunications Service Program Office (DTS–PO) required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7302/a/6/D/ii"},"text":"section 7302(a)(6)(D)(ii) of title 22","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s349/2"},"text":"Pub. L. 111–259, § 349(2)","children":[],"tail":", struck out par. (6) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(6) The semiannual report on financial intelligence on terrorist assets required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s404m"},"text":"section 404m of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177/s361"},"text":"Pub. L. 108–177, § 361","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","ch