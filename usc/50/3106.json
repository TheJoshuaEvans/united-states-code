itle","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(K). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177/s361"},"text":"Pub. L. 108–177, § 361","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1)(A)(ii), redesignated subpar. (K) as (H)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(L). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177/s361"},"text":"Pub. L. 108–177, § 361","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1)(A)(i), struck out subpar. (L) which read as follows: “The annual report on exceptions to consumer disclosure requirements for national security investigations under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681b/b/4/E"},"text":"section 1681b(b)(4)(E) of title 15","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(M). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177/s361"},"text":"Pub. L. 108–177, § 361","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1)(A)(ii), redesignated subpar. (M) as (I)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(N). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177/s361"},"text":"Pub. L. 108–177, § 361","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1)(A)(ii), which directed that subpar. (N) be redesignated, could not be executed because there was no corresponding subpar. provided for such redesignation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177/s361"},"text":"Pub. L. 108–177, § 361","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1)(B)(iii), (iv), redesignated subpars. (D) and (G) as (C) and (D), respectively, and struck out subpars. (C), (E), and (F) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) The annual report on covert leases required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s404i/e"},"text":"section 404i(e) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(E) The annual report on activities of personnel of the Federal Bureau of Investigation outside the United States required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s540C/c/2"},"text":"section 540C(c)(2) of title 28","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(F) The annual report on intelligence activities of the People’s Republic of China required by section 308(c) of the Intelligence Authorization Act for Fiscal Year 1998 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/107"},"text":"Public Law 105–107","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s402a"},"text":"50 U.S.C. 402a","children":[],"tail":" note).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177/s361"},"text":"Pub. L. 108–177, § 361","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1)(B)(i), substituted “section 404i(a)” for “section 404i(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177/s361"},"text":"Pub. L. 108–177, § 361","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1)(B)(ii), substituted “section 404i(c)” for “section 404i(d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177/s361"},"text":"Pub. L. 108–177, § 361","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2), redesignated pars. (2), (3), (5), (6), (7), and (8) as (1), (2), (3), (4), (5), and (6), respectively, and struck out former pars. (1) and (4) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The periodic reports on intelligence provided to the United Nations required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s404g/b"},"text":"section 404g(b) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) The semiannual reports on the acquisition of technology relating to weapons of mass destruction and advanced conventional munitions required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2366/b"},"text":"section 2366(b) of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1aa323b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd1aa323c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2026-12-31"},"text":"Dec. 31, 2026","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s6801/a/1/C"},"text":"section 6801(a)(1)(C) of Pub. L. 119–60","children":[],"tail":", set out as an Effective Date of Repeal note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3055"},"text":"section 3055 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd1aa323d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177"},"text":"Pub. L. 108–177","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2003-12-31"},"text":"Dec. 31, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/177/s361/n"},"text":"section 361(n) of Pub. L. 108–177","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1611"},"text":"section 1611 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1aa323e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Preparation and Submittal of Reports, Reviews, Studies, and Plans Relating to Intelligence Activities of Department of Defense or Department of Energy","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/487/tI/s107"},"text":"Pub. L. 108–487, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3943"},"text":"118 Stat. 3943","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/487/tI/s107"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation in Preparation","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of National Intelligence shall ensure that any report, review, study, or plan required to be prepared or conducted by a provision of this Act [see Tables for classification], including a provision of the classified Schedule of Authorizations referred to in section 102(a) [","children":[{"tag":"ref","attrib":{"href":"/us/stat/118/3940"},"text":"118 Stat. 3940","children":[],"tail":"] or the classified annex to this Act, that involves the intelligence or intelligence-related activities of the Department of Defense or the Department of Energy is prepared or conducted in consultation with the Secretary of Defense or the Secretary of Energy, as appropriate."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense or the Secretary of Energy may carry out any consultation required by this subsection through an official of the Department of Defense or the Department of Energy, as the case may be, designated by such Secretary for that purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submittal","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any report, review, study, or plan referred to in subsection (a) shall be submitted, in addition to any other committee of Congress specified for submittal in the provision concerned, to the following committees or subcommittees of Congress, as appropriate:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Armed Services, the Subcommittee on Defense of the Committee on Appropriations, and the Select Committee on Intelligence of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Armed Services, the Subcommittee on Defense of the Committee on Appropriations, and the Permanent Select Committee on Intelligence of the House of Representatives.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177/tI/s107"},"text":"Pub. L. 108–177, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-13"},"text":"Dec. 13, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2604"},"text":"117 Stat. 2604","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/tI/s109"},"text":"Pub. L. 107–306, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2389"},"text":"116 Stat. 2389","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/108/tV/s505"},"text":"Pub. L. 107–108, title V, § 505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1406"},"text":"115 Stat. 1406","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1aa323f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Submittal of Various Overdue Reports","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/tVIII/s801"},"text":"Pub. L. 107–306, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2418"},"text":"116 Stat. 2418","children":[],"tail":", provided that certain overdue reports that the Director of Central Intelligence has sole or primary responsibility to present to Congress must be submitted to Congress no later than 180 days after "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", or amounts available to the Director to carry out the functions and duties of the Director’s Office would be reduced by ⅓."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
