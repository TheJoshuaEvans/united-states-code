{"tag":"section","attrib":{"id":"idd1f40cc3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3711"},"text":null,"children":[{"tag":"num","attrib":{"value":"3711"},"text":"§ 3711.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to carry out Department of Defense Cooperative Threat Reduction Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1f40cc4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3711/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may carry out a program, referred to as the “Department of Defense Cooperative Threat Reduction Program”, with respect to foreign countries to do the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1f40cc5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3711/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Facilitate the elimination and the safe and secure transportation and storage of chemical, biological, or other weapons, weapons components, weapons-related materials, and associated delivery vehicles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f40cc6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3711/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Facilitate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1f40cc7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3711/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the safe and secure transportation and storage of nuclear weapons, nuclear weapons-usable or high-threat radiological materials, nuclear weapons components, and associated delivery vehicles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f40cc8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3711/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the elimination of nuclear weapons, nuclear weapons components, and nuclear weapons delivery vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f40cc9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3711/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prevent the proliferation of nuclear and chemical weapons, weapons components, and weapons-related materials, technology, and expertise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f40cca-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3711/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prevent the proliferation of biological weapons, weapons components, and weapons-related materials, technology, and expertise, which may include activities that facilitate detection and reporting of highly pathogenic diseases or other diseases that are associated with or that could be used as an early warning mechanism for disease outbreaks that could affect the Armed Forces of the United States or allies of the United States, regardless of whether such diseases are caused by biological weapons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f40ccb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3711/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prevent the proliferation of weapons of mass destruction-related materials, including materials, equipment, and technology that could be used for the design, development, production, or use of nuclear, chemical, and biological weapons and the means of delivery of such weapons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f40ccc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3711/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Carry out military-to-military and defense contacts for advancing the mission of the Program, subject to subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f40ccd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3711/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concurrence of Secretary of State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority under subsection (a) to carry out the Program is subject to any concurrence of the Secretary of State or other appropriate agency head required under section 3712 or 3713 of this title (unless such concurrence is otherwise exempted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3751"},"text":"section 3751 of this title","children":[],"tail":" with respect to activities or determinations carried out or made before "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"December 19, 2014","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f40cce-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3711/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority to carry out the Program in subsection (a) includes authority to provide equipment, goods, and services, but does not include authority to provide funds directly for a project or activity carried out under the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f40ccf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3711/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Type of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Program carried out under subsection (a) may involve assistance in planning and in resolving technical problems associated with weapons destruction and proliferation. The Program may also involve the funding of critical short-term requirements relating to weapons destruction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f40cd0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3711/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of other agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense may reimburse heads of other departments and agencies of the Federal Government under this section for costs of the participation of the respective departments and agencies in the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f40cd1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3711/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military-to-military and defense contacts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall ensure that the military-to-military and defense contacts carried out under subsection (a)(6)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1f40cd2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3711/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are focused and expanded to support specific relationship-building opportunities, which could lead to the development of the Program in new geographic areas and achieve other benefits of the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f40cd3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3711/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are directly administered as part of the Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f40cd4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3711/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include cooperation and coordination with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1f40cd5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3711/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the unified combatant commands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f40cd6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3711/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f40cd7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3711/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior notice to Congress of obligation of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1f40cd8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3711/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 15 days before any obligation of any Cooperative Threat Reduction funds, the Secretary of Defense shall submit to the congressional defense committees a report on that proposed obligation of such funds for that fiscal year (or, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3735/b"},"text":"section 3735(b) of this title","children":[],"tail":", the semiannual period covered by the report)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f40cd9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3711/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under paragraph (1) shall specify—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1f40cda-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3711/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities and forms of assistance for which the Secretary plans to obligate funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f40cdb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3711/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the proposed obligation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f40cdc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3711/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the projected involvement (if any) of any other department or agency of the United States and of the private sector of the United States in the activities and forms of assistance for which the Secretary plans to obligate such funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f40cdd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3711/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for notifications previously provided","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except for Cooperative Threat Reduction funds subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3735"},"text":"section 3735 of this title","children":[],"tail":", paragraph (1) shall not apply with respect to a proposed obligation of Cooperative Threat Reduction funds that is covered by a notification previously submitted by the Secretary to the congressional defense committees that includes the matters described in subparagraphs (A) through (C) of paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1f40cde-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tXIII/s1321"},"text":"Pub. L. 113–291, div. A, title XIII, § 1321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3595"},"text":"128 Stat. 3595","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXIII"},"text":"Pub. L. 114–328, div. A, title XIII","children":[],"tail":", §§ 1302(b)(1), 1303(b), "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2566"},"text":"130 Stat. 2566","children":[],"tail":", 2568; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tXIII/s1302/b/1"},"text":"Pub. L. 115–91, div. A, title XIII, § 1302(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1705"},"text":"131 Stat. 1705","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1f40cdf-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1f40ce0-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1f40ce1-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (g)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" substituted “15 days” for “45 days”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (g)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":", §§ 1302(b)(1), 1303(b)(1), in heading substituted “Reports requirement” for “Annual requirement” and in text substituted “45 days” for “15 days” and inserted “(or, in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3735/b"},"text":"section 3735(b) of this title","children":[],"tail":", the semiannual period covered by the report)” after “that fiscal year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1303/b/2"},"text":"Pub. L. 114–328, § 1303(b)(2)","children":[],"tail":", substituted “Except for Cooperative Threat Reduction funds subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3735"},"text":"section 3735 of this title","children":[],"tail":", paragraph (1)” for “Paragraph (1)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
