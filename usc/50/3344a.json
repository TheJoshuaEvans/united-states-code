{"tag":"section","attrib":{"id":"idd1d512e2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3344a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3344a"},"text":"§ 3344a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training to promote sensible classification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1d512e3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3344a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d512e4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3344a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Over-classification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “over-classification” means classification at a level that exceeds the minimum level of classification that is sufficient to protect the national security of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d512e5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3344a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sensible classification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “sensible classification” means classification at a level that is the minimum level of classification that is sufficient to protect the national security of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d512e6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3344a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each head of an agency with classification authority shall conduct training for employees of the agency with classification authority to hold employees accountable for over-classification and to promote sensible classification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1d512e7-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tVI/s7603"},"text":"Pub. L. 118–31, div. G, title VI, § 7603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1097"},"text":"137 Stat. 1097","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
