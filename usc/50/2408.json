{"tag":"section","attrib":{"id":"idd169ce23-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2408"},"text":null,"children":[{"tag":"num","attrib":{"value":"2408"},"text":"§ 2408.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff of Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd169ce24-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2408/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall maintain within the Administration sufficient staff to assist the Administrator in carrying out the duties and responsibilities of the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd169ce25-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2408/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The staff of the Administration shall perform, in accordance with applicable law, such of the functions of the Administrator as the Administrator shall prescribe. The Administrator shall assign to the staff responsibility for the following functions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd169ce26-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2408/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd169ce27-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2408/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Legislative affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd169ce28-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2408/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Public affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd169ce29-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2408/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Liaison with the Department of Energy’s Office of Intelligence and Counterintelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd169ce2a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2408/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Liaison with other elements of the Department of Energy and with other Federal agencies, State, tribal, and local governments, and the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd169ce2b-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dC/tXXXII/s3218"},"text":"Pub. L. 106–65, div. C, title XXXII, § 3218","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/960"},"text":"113 Stat. 960","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dC/tXXXI/s3117/e"},"text":"Pub. L. 109–364, div. C, title XXXI, § 3117(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/12