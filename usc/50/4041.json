{"tag":"section","attrib":{"id":"idd20e4b3c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4041"},"text":null,"children":[{"tag":"num","attrib":{"value":"4041"},"text":"§ 4041.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement by the Attorney General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd20e4b3d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4041/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil action","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General may commence a civil action in any appropriate district court of the United States against any person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20e4b3e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4041/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engages in a pattern or practice of violating this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4b3f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4041/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engages in a violation of this chapter that raises an issue of significant public importance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4b40-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4041/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relief","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In a civil action commenced under subsection (a), the court may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20e4b41-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4041/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant any appropriate equitable or declaratory relief with respect to the violation of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4b42-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4041/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award all other appropriate relief, including monetary damages, to any person aggrieved by the violation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4b43-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4041/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may, to vindicate the public interest, assess a civil penalty—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd20e4b44-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4041/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an amount not exceeding $55,000 for a first violation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd20e4b45-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4041/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an amount not exceeding $110,000 for any subsequent violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4b46-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4041/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intervention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon timely application, a person aggrieved by a violation of this chapter with respect to which the civil action is commenced may intervene in such action, and may obtain such appropriate relief as the person could obtain in a civil action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4042"},"text":"section 4042 of this title","children":[],"tail":" with respect to that violation, along with costs and a reasonable attorney fee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd20e4b47-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title VIII, § 801, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/275/tIII/s303/a"},"text":"Pub. L. 111–275, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-13"},"text":"Oct. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2877"},"text":"124 Stat. 2877","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd20e4b48-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd20e4b49-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd20e4b4a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 597 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
