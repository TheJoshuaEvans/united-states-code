{"tag":"section","attrib":{"id":"idd217e78e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4216"},"text":null,"children":[{"tag":"num","attrib":{"value":"4216"},"text":"§ 4216.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Directors of the Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd217e78f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4216/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the Civil Liberties Public Education Fund Board of Directors, which shall be responsible for making disbursements from the Fund in the manner provided in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd217e790-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4216/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of the Fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board may make disbursements from the Fund only—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd217e791-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4216/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to sponsor research and public educational activities, and to publish and distribute the hearings, findings, and recommendations of the Commission, so that the events surrounding the evacuation, relocation, and internment of United States citizens and permanent resident aliens of Japanese ancestry will be remembered, and so that the causes and circumstances of this and similar events may be illuminated and understood; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e792-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4216/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for reasonable administrative expenses of the Board, including expenses incurred under subsections (c)(3), (d), and (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd217e793-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4216/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd217e794-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4216/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall be composed of 9 members appointed by the President, by and with the advice and consent of the Senate, from individuals who are not officers or employees of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e795-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4216/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd217e796-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4216/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subparagraphs (B) and (C), members shall be appointed for terms of 3 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd217e797-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4216/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Of the members first appointed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd217e798-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4216/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 shall be appointed for terms of 3 years, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd217e799-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4216/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 shall be appointed for terms of 2 years,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"as designated by the President at the time of appointment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd217e79a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4216/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any member appointed to fill a vacancy occurring before the expiration of the term for which such member’s predecessor was appointed shall be appointed only for the remainder of such term. A member may serve after the expiration of such member’s term until such member’s successor has taken office. No individual may be appointed as a member for more than 2 consecutive terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e79b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4216/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Board shall serve without pay, except that members of the Board shall be entitled to reimbursement for travel, subsistence, and other necessary expenses incurred by them in carrying out the functions of the Board, in the same manner as persons employed intermittently in the United States Government are allowed expenses under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e79c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4216/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"5 members of the Board shall constitute a quorum but a lesser number may hold hearings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e79d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4216/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chair","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chair of the Board shall be elected by the members of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd217e79e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4216/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director and staff","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd217e79f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4216/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall have a Director who shall be appointed by the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e7a0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4216/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may appoint and fix the pay of such additional staff as it may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e7a1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4216/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of civil service laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director and the additional staff of the Board may be appointed without regard to section 5311(b) ","children":[{"tag":"ref","attrib":{"idref":"fn002126"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002126"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 5 and without regard to the provisions of such title governing appointments in the competitive service, and may be paid without regard to the provisions of chapter 51 and subchapter III of chapter 53 of such title relating to classification and General Schedule pay rates, except that the compensation of any employee of the Board may not exceed a rate equivalent to the minimum rate of basic pay payable for GS–18 of the General Schedule under section 5332(a) of such title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd217e7a2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4216/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative support services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of General Services shall provide to the Board on a reimbursable basis such administrative support services as the Board may request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd217e7a3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4216/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gifts and donations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may accept, use, and dispose of gifts or donations of services or property for purposes authorized under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd217e7a4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4216/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 12 months after the first meeting of the Board and every 12 months thereafter, the Board shall transmit to the President and to each House of the Congress a report describing the activities of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd217e7a5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4216/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"90 days after the termination of the Fund, the Board shall terminate and all obligations of the Board under this section shall cease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd217e7a6-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/383/tI/s106"},"text":"Pub. L. 100–383, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-10"},"text":"Aug. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/908"},"text":"102 Stat. 908","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd217e7a7-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd217e7a8-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd217e7a9-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5311/b"},"text":"Section 5311(b) of title 5","children":[],"tail":", referred to in subsec. (d)(3), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/101/509/tV/s529/tI/s104/c/1"},"text":"Pub. L. 101–509, title V, § 529 [title I, § 104(c)(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1427"},"text":"104 Stat. 1427","children":[],"tail":", 1447."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd217e7aa-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 1989b–5 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd217e7ab-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd217e7ac-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References in Other Laws to GS–16, 17, or 18 Pay Rates","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References in laws to the rates of pay for GS–16, 17, or 18, or to maximum rates of pay under the General Schedule, to be considered references to rates payable under specified sections of Title 5, Government Organization and Employees, see section 529 [title I, § 101(c)(1)] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
