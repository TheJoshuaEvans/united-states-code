{"tag":"section","attrib":{"id":"idd1a094d2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3061"},"text":null,"children":[{"tag":"num","attrib":{"value":"3061"},"text":"§ 3061.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counterintelligence and national security protections for intelligence community grant funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1a094d3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3061/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure as condition for receipt of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of an element of the intelligence community may not award a grant to a person or entity unless the person or entity has certified to the head of the element that the person or entity has disclosed to the head of the element any material financial or material in-kind support that the person or entity knows, or should have known, derives from the People’s Republic of China, the Russian Federation, the Islamic Republic of Iran, the Democratic People’s Republic of Korea, or the Republic of Cuba, during the 5-year period ending on the date of the person or entity’s application for the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1a094d4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3061/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process for review of grant applicants prior to award","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1a094d5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3061/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of an element of the intelligence community may not award a grant to a person or entity who submitted a certification under subsection (a) until such certification is received by the head of an element of the intelligence community and submitted to the Director of National Intelligence pursuant to the process set forth in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a094d6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3061/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1a094d7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3061/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence, in coordination with such heads of elements of the intelligence community as the Director considers appropriate, shall establish a process to review the awarding of a grant to an applicant who submitted a certification under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a094d8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3061/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The process established under subparagraph (A) shall include the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1a094d9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3061/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The immediate transmission of a copy of each applicant’s certification made under subsection (a) to the Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1a094da-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3061/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The review of the certification and any accompanying disclosures submitted under subsection (a) as soon as practicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1a094db-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3061/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Authorization for the heads of the elements of the intelligence community to take such actions as may be necessary, including denial or revocation of a grant, to ensure a grant does not pose an unacceptable risk of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idd1a094dc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3061/b/2/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" misappropriation of United States intellectual property, research and development, and innovation efforts; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd1a094dd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3061/b/2/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other counterintelligence threats.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1a094de-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title I, § 121, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dF/tLXIII/s6302/a"},"text":"Pub. L. 117–263, div. F, title LXIII, § 6302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3501"},"text":"136 Stat. 3501","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dF/tLXVIII/s6801/a/2"},"text":"Pub. L. 119–60, div. F, title LXVIII, § 6801(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1652"},"text":"139 Stat. 1652","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1a094df-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1a094e0-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1a094e1-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" struck out subsec. (c) which required the Director of National Intelligence to submit an annual report to congressional intelligence committees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1a094e2-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd1a094e3-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dF/tLXIII/s6302/b"},"text":"Pub. L. 117–263, div. F, title LXIII, § 6302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3502"},"text":"136 Stat. 3502","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dF/tLXIII/s6302/b"},"text":"“Subsections (a) and (b) of section 121 of such Act [act ","children":[{"tag":"date","attrib":{"date":"1947-07-26"},"text":"July 26, 1947","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3061"},"text":"50 U.S.C. 3061","children":[],"tail":"], as added by subsection (a), shall apply only with respect to grants awarded by an element of the intelligence community after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “intelligence community” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s6302/b"},"text":"section 6302(b) of Pub. L. 117–263","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s6002"},"text":"section 6002 of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
