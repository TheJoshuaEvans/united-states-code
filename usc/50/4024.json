{"tag":"section","attrib":{"id":"idd20e4ae2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4024"},"text":null,"children":[{"tag":"num","attrib":{"value":"4024"},"text":"§ 4024.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health insurance reinstatement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd20e4ae3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4024/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reinstatement of health insurance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A servicemember who, by reason of military service as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4023/a/1"},"text":"section 4023(a)(1) of this title","children":[],"tail":", is entitled to the rights and protections of this chapter shall also be entitled upon termination or release from such service to reinstatement of any health insurance that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20e4ae4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4024/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was in effect on the day before such service commenced; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4ae5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4024/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was terminated effective on a date during the period of such service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4ae6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4024/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No exclusion or waiting period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The reinstatement of health care insurance coverage for the health or physical condition of a servicemember described in subsection (a), or any other person who is covered by the insurance by reason of the coverage of the servicemember, shall not be subject to an exclusion or a waiting period, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20e4ae7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4024/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the condition arose before or during the period of such service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4ae8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4024/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an exclusion or a waiting period would not have been imposed for the condition during the period of coverage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4ae9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4024/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a case in which the condition relates to the servicemember, the condition has not been determined by the Secretary of Veterans Affairs to be a disability incurred or aggravated in the line of duty (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s105"},"text":"section 105 of title 38","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4aea-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4024/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) does not apply to a servicemember entitled to participate in employer-offered insurance benefits pursuant to the provisions of chapter 43 of title 38.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4aeb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4024/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for applying for reinstatement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application under this section must be filed not later than 120 days after the date of the termination of or release from military service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4aec-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4024/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on premium increases","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20e4aed-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4024/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Premium protection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the premium for health insurance coverage that was terminated by a servicemember and required to be reinstated under subsection (a) may not be increased, for the balance of the period for which coverage would have been continued had the coverage not been terminated, to an amount greater than the amount chargeable for such coverage before the termination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4aee-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4024/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increases of general applicability not precluded","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) does not prevent an increase in premium to the extent of any general increase in the premiums charged by the carrier of the health care insurance for the same health insurance coverage for persons similarly covered by such insurance during the period between the termination and the reinstatement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd20e4aef-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title VII, § 704, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s1"},"text":"Pub. L. 108–189, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2864"},"text":"117 Stat. 2864","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/233/tIII/s302"},"text":"Pub. L. 109–233, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-06-15"},"text":"June 15, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/406"},"text":"120 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd20e4af0-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd20e4af1-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd20e4af2-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 594 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd20e4af3-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 704 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"act Oct. 17, 1940, ch. 888","children":[],"tail":", art. VII, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tXVI/s1603"},"text":"Pub. L. 107–107, div. A, title XVI, § 1603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1276"},"text":"115 Stat. 1276","children":[],"tail":", related to guarantee of residency for military personnel, prior to the general amendment of this Act by "},{"tag":"ref","attrib":{"href":"/us/pl/108/189"},"text":"Pub. L. 108–189","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4025"},"text":"section 4025 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd20e4af4-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233/s302/b"},"text":"Pub. L. 109–233, § 302(b)","children":[],"tail":", substituted “in a case in which the” for “if the”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233/s302/a"},"text":"Pub. L. 109–233, § 302(a)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd20e4af5-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd20e4af6-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any case not final before ","children":[{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s3"},"text":"section 3 of Pub. L. 108–189","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3901"},"text":"section 3901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
