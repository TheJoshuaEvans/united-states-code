{"tag":"section","attrib":{"id":"idd1cde6f5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334f"},"text":null,"children":[{"tag":"num","attrib":{"value":"3334f"},"text":"§ 3334f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional notification of designation of covered intelligence officer as persona non grata","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1cde6f6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered intelligence officer defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered intelligence officer” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cde6f7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States intelligence officer serving in a post in a foreign country; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde6f8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a known or suspected foreign intelligence officer serving in a United States post.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cde6f9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 72 hours after a covered intelligence officer is designated as a persona non grata, the Director of National Intelligence, in consultation with the Secretary of State, shall submit to the congressional intelligence committees, the Committee on Foreign Relations of the Senate, and the Committee on Foreign Affairs of the House of Representatives a notification of that designation. Each such notification shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cde6fa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the designation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde6fb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis for the designation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde6fc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334f/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a justification for the expulsion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1cde6fd-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLXVII/s6719"},"text":"Pub. L. 116–92, div. E, title LXVII, § 6719","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2229"},"text":"133 Stat. 2229","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1cde6fe-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1cde6ff-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd1cde700-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “congressional intelligence committees” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/s5003"},"text":"section 5003 of div. E of Pub. L. 116–92","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
