{"tag":"section","attrib":{"id":"idd0f9a6bc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s215"},"text":null,"children":[{"tag":"num","attrib":{"value":"215"},"text":"§ 215.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution of confiscation proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Attorney General, or the United States attorney for any judicial district in which such property may at the time be, may institute the proceedings of condemnation, and in such case they shall be wholly for the benefit of the United States; or any person may file an information with such attorney, in which case the proceedings shall be for the use of such informer and the United States in equal parts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd0f9a6bd-47c4-11f1-8bcf-c89722bddd2e"},"text":"(R.S. § 5311; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646/s1"},"text":"June 25, 1948, ch. 646, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/909"},"text":"62 Stat. 909","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd0f9a6be-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd0f9a6bf-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd0f9a6c0-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5311 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1861-08-06/ch60/s3"},"text":"act Aug. 6, 1861, ch. 60, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/12/319"},"text":"12 Stat. 319","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd0f9a6c1-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idd0f9a6c2-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", eff. "},{"tag":"date","attrib":{"date":"1948-09-01"},"text":"Sept. 1, 1948","children":[],"tail":", substituted “United States attorney” for “attorney of the United States”. See "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s541"},"text":"section 541 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure, and Historical and Revision Notes thereunder."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
