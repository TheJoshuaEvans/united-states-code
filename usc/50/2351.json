{"tag":"section","attrib":{"id":"idd16512ae-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2351"},"text":null,"children":[{"tag":"num","attrib":{"value":"2351"},"text":"§ 2351.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National coordinator on nonproliferation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd16512af-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2351/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of position","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall designate an individual to serve in the Executive Office of the President as the National Coordinator for Nonproliferation Matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16512b0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2351/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Coordinator, under the direction of the National Security Council, shall advise and assist the President by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16512b1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2351/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advising the President on nonproliferation of weapons of mass destruction, including issues related to terrorism, arms control, and international organized crime;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16512b2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2351/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chairing the Committee on Nonproliferation of the National Security Council; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16512b3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2351/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taking such actions as are necessary to ensure that there is appropriate emphasis in, cooperation on, and coordination of, nonproliferation research efforts of the United States, including activities of Federal agencies as well as activities of contractors funded by the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16512b4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2351/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the total amount authorized to be appropriated under section 301,","children":[{"tag":"ref","attrib":{"idref":"fn002056"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002056"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" $2,000,000 is available to the Department of Defense for carrying out research referred to in subsection (b)(3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd16512b5-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXIV/s1441"},"text":"Pub. L. 104–201, div. A, title XIV, § 1441","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2727"},"text":"110 Stat. 2727","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tX/s1069/c/2"},"text":"Pub. L. 105–261, div. A, title X, § 1069(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2136"},"text":"112 Stat. 2136","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd16512b6-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd16512b7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd16512b8-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 301, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s301"},"text":"section 301 of Pub. L. 104–201","children":[],"tail":", div. A, title III, "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2475"},"text":"110 Stat. 2475","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd16512b9-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261"},"text":"Pub. L. 105–261","children":[],"tail":" substituted “of the National Security Council” for “established under section 1342”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd16512ba-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd16512bb-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Commission To Assess Organization of Federal Government To Combat Proliferation of Weapons of Mass Destruction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/293/tVII"},"text":"Pub. L. 104–293, title VII","children":[],"tail":", subtitle A, "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3470"},"text":"110 Stat. 3470","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tVII/s708"},"text":"Pub. L. 105–277, div. A, § 101(f) [title VII, § 708]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–390, established the Commission to Assess the Organization of the Federal Government to Combat the Proliferation of Weapons of Mass Destruction, directed the Commission to carry out a thorough study of the organization of the Federal Government, including the elements of the intelligence community, with respect to combatting the proliferation of weapons of mass destruction and, not later than 18 months after "},{"tag":"date","attrib":{"date":"1998-01-18"},"text":"Jan. 18, 1998","children":[],"tail":", to submit to Congress a report containing a detailed statement of its findings and conclusions, and provided that the Commission terminate 60 days after the date on which it submitted such report."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
