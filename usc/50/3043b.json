{"tag":"section","attrib":{"id":"idd199691c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3043b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3043b"},"text":"§ 3043b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports on worldwide threats","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd199691d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3043b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd199691e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3043b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional intelligence committees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd199691f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3043b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committees on Armed Services of the House of Representatives and the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1996920-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3043b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the first Monday in February 2021, and each year thereafter, the Director of National Intelligence, in coordination with the heads of the elements of the intelligence community, shall submit to the appropriate congressional committees a report containing an assessment of the intelligence community with respect to worldwide threats to the national security of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1996921-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3043b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report under subsection (b) shall be submitted in unclassified form, but may include a classified annex only for the protection of intelligence sources and methods relating to the matters contained in the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1996922-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3043b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1996923-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3043b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Open hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon request by the appropriate congressional committees, the Director (and any other head of an element of the intelligence community determined appropriate by the committees in consultation with the Director) shall testify before such committees in an open setting regarding a report under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1996924-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3043b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Closed hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any information that may not be disclosed during an open hearing under paragraph (1) in order to protect intelligence sources and methods may instead be discussed in a closed hearing that immediately follows such open hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1996925-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title I, § 108B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dW/tVI/s617/a"},"text":"Pub. L. 116–260, div. W, title VI, § 617(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2400"},"text":"134 Stat. 2400","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
