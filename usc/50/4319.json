{"tag":"section","attrib":{"id":"idd2215e49-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4319"},"text":null,"children":[{"tag":"num","attrib":{"value":"4319"},"text":"§ 4319.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fugitives from justice barred from recovery","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No person shall be entitled to the return of any property or money under any provision of this chapter, or any amendment of this chapter, who is a fugitive from justice of the United States or any State or Territory thereof, or the District of Columbia.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd2215e4a-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-10-06/ch106/s22"},"text":"Oct. 6, 1917, ch. 106, § 22","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1923-03-04/ch285/s2"},"text":"Mar. 4, 1923, ch. 285, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/1516"},"text":"42 Stat. 1516","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1928-03-10/ch167/s16"},"text":"Mar. 10, 1928, ch. 167, § 16","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/275"},"text":"45 Stat. 275","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2215e4b-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2215e4c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd2215e4d-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-10-06/ch106"},"text":"act Oct. 6, 1917, ch. 106","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/411"},"text":"40 Stat. 411","children":[],"tail":", known as the Trading with the enemy Act, also known as the Trading with the Enemy Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4301"},"text":"section 4301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd2215e4e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 22 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd2215e4f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1928—Act ","children":[{"tag":"date","attrib":{"date":"1928-03-10"},"text":"Mar. 10, 1928","children":[],"tail":", inserted “, or any amendment of this chapter,” after “any provision of this chapter”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
