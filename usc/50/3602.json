{"tag":"section","attrib":{"id":"idd1f1c2cb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3602"},"text":null,"children":[{"tag":"num","attrib":{"value":"3602"},"text":"§ 3602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of the Agency and Director of Compliance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1f1c2cc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3602/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1f1c2cd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3602/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is a Director of the National Security Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f1c2ce-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3602/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Security Agency shall be appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f1c2cf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3602/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Security Agency shall be the head of the National Security Agency and shall discharge such functions and duties as are provided by this chapter or otherwise by law or executive order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f1c2d0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3602/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is a Director of Compliance of the National Security Agency, who shall be appointed by the Director of the National Security Agency and who shall be responsible for the programs of compliance over mission activities of the National Security Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1f1c2d1-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/36/s2"},"text":"Pub. L. 86–36, § 2","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/tIV/s433"},"text":"Pub. L. 111–259, title IV, § 433","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2732"},"text":"124 Stat. 2732","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/126/tIV/s401/a"},"text":"Pub. L. 113–126, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-07"},"text":"July 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1407"},"text":"128 Stat. 1407","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1f1c2d2-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1f1c2d3-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1f1c2d4-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified in a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s402"},"text":"section 402 of this title","children":[],"tail":" prior to editorial reclassification as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd1f1c2d5-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/36/s2"},"text":"section 2 of Pub. L. 86–36","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-05-29"},"text":"May 29, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/63"},"text":"73 Stat. 63","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/367/tII/s201"},"text":"Pub. L. 87–367, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-10-04"},"text":"Oct. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/789"},"text":"75 Stat. 789","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-23/ch1024"},"text":"Sept. 23, 1950, ch. 1024","children":[],"tail":", title III, § 306(a), as added "},{"tag":"ref","attrib":{"href":"/us/pl/88/290"},"text":"Pub. L. 88–290","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-03-26"},"text":"Mar. 26, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/170"},"text":"78 Stat. 170","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/426/tIII/s306/h"},"text":"Pub. L. 88–426, title III, § 306(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-14"},"text":"Aug. 14, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/430"},"text":"78 Stat. 430","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/631/s3/d"},"text":"Pub. L. 88–631, § 3(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-06"},"text":"Oct. 6, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1008"},"text":"78 Stat. 1008","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/632/s1/e/1"},"text":"Pub. L. 89–632, § 1(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-08"},"text":"Oct. 8, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/878"},"text":"80 Stat. 878","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tIV/s405"},"text":"Pub. L. 102–496, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3186"},"text":"106 Stat. 3186","children":[],"tail":", related to authority of Secretary of Defense to establish positions and fix compensation, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVI"},"text":"Pub. L. 104–201, div. A, title XVI","children":[],"tail":", §§ 1633(b)(1), 1635, "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2751"},"text":"110 Stat. 2751","children":[],"tail":", 2752, effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1f1c2d6-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/126"},"text":"Pub. L. 113–126","children":[],"tail":" added subsec. (a) and designated existing provisions as subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1f1c2d7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd1f1c2d8-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/126/tIV/s403"},"text":"Pub. L. 113–126, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-07"},"text":"July 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1408"},"text":"128 Stat. 1408","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/11"},"text":"Pub. L. 117–286, § 4(b)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4344"},"text":"136 Stat. 4344","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/286/s4/b/11"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise specifically provided, the amendments made by sections 401 [amending this section] and 402 [amending sections 8G and 12 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/452"},"text":"Pub. L. 95–452","children":[],"tail":", formerly set out in the Appendix to Title 5, Government Organization and Employees] shall take effect on "},{"tag":"date","attrib":{"date":"2014-10-01"},"text":"October 1, 2014","children":[],"tail":", and shall apply upon the earlier of—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of section 401—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the first nomination by the President of an individual to serve as the Director of the National Security Agency that occurs on or after ","children":[{"tag":"date","attrib":{"date":"2014-10-01"},"text":"October 1, 2014","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the cessation of the performance of the duties of the Director of the National Security Agency by the individual performing such duties on ","children":[{"tag":"date","attrib":{"date":"2014-10-01"},"text":"October 1, 2014","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of section 402—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the first nomination by the President of an individual to serve as the Inspector General of the National Security Agency that occurs on or after ","children":[{"tag":"date","attrib":{"date":"2014-10-01"},"text":"October 1, 2014","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the cessation of the performance of the duties of the Inspector General of the National Security Agency by the individual performing such duties on ","children":[{"tag":"date","attrib":{"date":"2014-10-01"},"text":"October 1, 2014","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for Initial Nominations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding paragraph (1)(A) or (2)(A) of subsection (a), an individual serving as the Director of the National Security Agency or the Inspector General of the National Security Agency on the date that the President first nominates an individual for such position on or after ","children":[{"tag":"date","attrib":{"date":"2014-10-01"},"text":"October 1, 2014","children":[],"tail":", may continue to perform in that position after such date of nomination and until the individual appointed to the position, by and with the advice and consent of the Senate, assumes the duties of the position."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incumbent Inspector General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The individual serving as Inspector General of the National Security Agency on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2014-07-07"},"text":"July 7, 2014","children":[],"tail":"] shall be eligible to be appointed by the President to a new term of service under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s403"},"text":"section 403 of title 5","children":[],"tail":", United States Code, by and with the advice and consent of the Senate.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1f1c2d9-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Establishment of Artificial Intelligence Security Center","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dF/tLXV/s6504"},"text":"Pub. L. 118–159, div. F, title LXV, § 6504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2495"},"text":"138 Stat. 2495","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dF/tLXVI/s6601"},"text":"Pub. L. 119–60, div. F, title LXVI, § 6601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1633"},"text":"139 Stat. 1633","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dF/tLXVI/s6601"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Counter-artificial Intelligence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘counter-artificial intelligence’ means techniques or procedures to extract information about the behavior or characteristics of an artificial intelligence system, or to learn how to manipulate an artificial intelligence system, in order to subvert the confidentiality, integrity, or availability of an artificial intelligence system or adjacent system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":"], the Director of the National Security Agency shall establish an Artificial Intelligence Security Center (referred to in this section as the ‘Center’) within the Cybersecurity Collaboration Center of the National Security Agency."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The functions of the Artificial Intelligence Security Center shall be as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing guidance to prevent or mitigate counter-artificial intelligence techniques.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promoting secure artificial intelligence adoption practices for managers of national security systems (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3552"},"text":"section 3552 of title 44","children":[],"tail":", United States Code) and elements of the defense industrial base."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In accordance with subsection (d), developing security guidance to defend artificial intelligence technologies from technology theft by nation-state adversaries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other functions as the Director considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Artificial Intelligence Security Guidance.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the guidance pursuant to subsection (c)(3), the Director of the National Security Agency shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify vulnerabilities in advanced artificial intelligence technologies, with a focus on cybersecurity risks and security challenges unique to protecting such technologies from theft or sabotage by nation-state adversaries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify elements of the artificial intelligence supply chain or development or product lifecycle that, if accessed by nation-state adversaries, would contribute to progress made by nation-state adversaries on advanced artificial intelligence or would provide opportunities to adversaries to compromise the confidentiality, integrity, or availability of artificial intelligence systems or associated supply chains; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify strategies for artificial intelligence technologies to identify, protect, detect, respond, and recover from nation-state adversary cyber threats.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"External collaboration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In developing the guidance pursuant to subsection (c)(3), the Director of the National Security Agency may collaborate, on a voluntary basis, with other departments and agencies of the United States Government, research entities, and private sector entities, as determined appropriate by the Director, on artificial intelligence model safety and security, including through the provision of any computing resources the Director determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Security guidance form","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the National Security Agency shall publish, and may update from time to time, the security guidance developed under subsection (c)(3) to share with departments and agencies of the United States Government, research entities, and private sector entities, as determined appropriate by the Director, at unclassified or classified levels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disestablishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the National Security Agency may disestablish the Center established in subsection (b) not earlier than 3 years after the date of the enactment of this Act provided that the Director of the National Security Agency submits to the congressional intelligence committees [Select Committee on Intelligence of the Senate and Permanent Select Committee on Intelligence of the House of Representatives] a report documenting the rationale for disestablishment of the Center, including resource trades, effectiveness, priority, and any other pertinent considerations not later than 6 months prior to the disestablishment.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1f1c2da-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Position of Importance and Responsibility","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/126/tIV/s401/b"},"text":"Pub. L. 113–126, title IV, § 401(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-07"},"text":"July 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1408"},"text":"128 Stat. 1408","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/126/tIV/s401/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President may designate the Director of the National Security Agency as a position of importance and responsibility under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s601"},"text":"section 601 of title 10","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2014-07-07"},"text":"July 7, 2014","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
