{"tag":"section","attrib":{"id":"idd20bdaaa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3977"},"text":null,"children":[{"tag":"num","attrib":{"value":"3977"},"text":"§ 3977.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Premiums and interest guaranteed by United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd20bdaab-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3977/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guarantee of premiums and interest by the United States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20bdaac-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3977/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guarantee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payment of premiums, and interest on premiums at the rate specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3976"},"text":"section 3976 of this title","children":[],"tail":", which become due on a policy under the protection of this subchapter is guaranteed by the United States. If the amount guaranteed is not paid to the insurer before the period of insurance protection under this subchapter expires, the amount due shall be treated by the insurer as a policy loan on the policy."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20bdaad-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3977/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, at the expiration of insurance protection under this subchapter, the cash surrender value of a policy is less than the amount due to pay premiums and interest on premiums on the policy, the policy shall terminate. Upon such termination, the United States shall pay the insurer the difference between the amount due and the cash surrender value.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20bdaae-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3977/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery from insured of amounts paid by the United States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20bdaaf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3977/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debt payable to the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount paid by the United States to an insurer under this subchapter shall be a debt payable to the United States by the insured on whose policy payment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20bdab0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3977/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such amount may be collected by the United States, either as an offset from any amount due the insured by the United States or as otherwise authorized by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20bdab1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3977/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debt not dischargeable in bankruptcy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such debt payable to the United States is not dischargeable in bankruptcy proceedings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20bdab2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3977/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crediting of amounts recovered","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amounts received by the United States as repayment of debts incurred by an insured under this subchapter shall be credited to the appropriation for the payment of claims under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd20bdab3-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title IV, § 407, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s1"},"text":"Pub. L. 108–189, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2853"},"text":"117 Stat. 2853","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd20bdab4-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd20bdab5-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd20bdab6-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 547 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd20bdab7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 407 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"act Oct. 17, 1940, ch. 888","children":[],"tail":", art. IV, "},{"tag":"ref","attrib":{"href":"/us/stat/54/1185"},"text":"54 Stat. 1185","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1942-10-06/ch581/s13"},"text":"Oct. 6, 1942, ch. 581, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/775"},"text":"56 Stat. 775","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/857/s14/76"},"text":"Pub. L. 85–857, § 14(76)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1272"},"text":"72 Stat. 1272","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/12/s9/17"},"text":"Pub. L. 102–12, § 9(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-03-18"},"text":"Mar. 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/40"},"text":"105 Stat. 40","children":[],"tail":", related to regulations and finality of determinations, prior to the general amendment of this Act by "},{"tag":"ref","attrib":{"href":"/us/pl/108/189"},"text":"Pub. L. 108–189","children":[],"tail":". See sections 3978 and 3979 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd20bdab8-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd20bdab9-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any case not final before ","children":[{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s3"},"text":"section 3 of Pub. L. 108–189","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3901"},"text":"section 3901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
