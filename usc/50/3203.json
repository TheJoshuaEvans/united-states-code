{"tag":"section","attrib":{"id":"idd1c1ffd4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3203"},"text":null,"children":[{"tag":"num","attrib":{"value":"3203"},"text":"§ 3203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1c1ffd5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to accept services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":" and subject to subsection (b), the Foreign Languages Program under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3201"},"text":"section 3201 of this title","children":[],"tail":" shall include authority for the head of a covered element of the intelligence community to accept from any dedicated personnel voluntary services in support of the activities authorized by this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c1ffd6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements and limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c1ffd7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3203/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In accepting voluntary services from an individual under subsection (a), the head of a covered element of the intelligence community shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c1ffd8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3203/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supervise the individual to the same extent as the head of the element would supervise a compensated employee of that element providing similar services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c1ffd9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3203/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the individual is licensed, privileged, has appropriate educational or experiential credentials, or is otherwise qualified under applicable law or regulations to provide such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c1ffda-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3203/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In accepting voluntary services from an individual under subsection (a), the head of a covered element of the intelligence community may not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c1ffdb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3203/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" place the individual in a policymaking position, or other position performing inherently governmental functions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c1ffdc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3203/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compensate the individual for the provision of such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c1ffdd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3203/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to recruit and train individuals providing services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of a covered element of the intelligence community may recruit and train individuals to provide voluntary services under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c1ffde-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3203/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of individuals providing services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c1ffdf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3203/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (2), while providing voluntary services under subsection (a) or receiving training under subsection (c), an individual shall be considered to be an employee of the Federal Government only for purposes of the following provisions of law:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c1ffe0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3203/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"Section 552a of title 5","children":[],"tail":" (relating to maintenance of records on individuals)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c1ffe1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3203/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 11 of title 18 (relating to conflicts of interest).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c1ffe2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3203/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c1ffe3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3203/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to voluntary services under paragraph (1) provided by an individual that are within the scope of the services accepted under that paragraph, the individual shall be deemed to be a volunteer of a governmental entity or nonprofit institution for purposes of the Volunteer Protection Act of 1997 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14501"},"text":"42 U.S.C. 14501","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c1ffe4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3203/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of any claim against such an individual with respect to the provision of such services, section 4(d) of such Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14503/d"},"text":"42 U.S.C. 14503(d)","children":[],"tail":") "},{"tag":"ref","attrib":{"idref":"fn002081"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002081"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall not apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c1ffe5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3203/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Acceptance of voluntary services under this section shall have no bearing on the issuance or renewal of a security clearance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c1ffe6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3203/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of incidental expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c1ffe7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3203/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of a covered element of the intelligence community may reimburse an individual for incidental expenses incurred by the individual in providing voluntary services under subsection (a). The head of a covered element of the intelligence community shall determine which expenses are eligible for reimbursement under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c1ffe8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3203/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reimbursement under paragraph (1) may be made from appropriated or nonappropriated funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c1ffe9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3203/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to install equipment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c1ffea-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3203/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of a covered element of the intelligence community may install telephone lines and any necessary telecommunication equipment in the private residences of individuals who provide voluntary services under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c1ffeb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3203/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of a covered element of the intelligence community may pay the charges incurred for the use of equipment installed under paragraph (1) for authorized purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c1ffec-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3203/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1348"},"text":"section 1348 of title 31","children":[],"tail":", the head of a covered element of the intelligence community may use appropriated funds or nonappropriated funds of the element in carrying out this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1c1ffed-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title X, § 1013, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/487/tVI/s612/a/2"},"text":"Pub. L. 108–487, title VI, § 612(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3957"},"text":"118 Stat. 3957","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1c1ffee-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1c1ffef-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1c1fff0-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Volunteer Protection Act of 1997, referred to in subsec. (d)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/19"},"text":"Pub. L. 105–19","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-18"},"text":"June 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/218"},"text":"111 Stat. 218","children":[],"tail":", which is classified generally to chapter 139 (§ 14501 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s14501"},"text":"section 14501 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4(d) of such Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14503/d"},"text":"42 U.S.C. 14503(d)","children":[],"tail":"), meaning the Volunteer Protection Act of 1997 and referred to in subsec. (d)(2)(B), was redesignated section 4(e) of the Act by "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tV/s584/1"},"text":"Pub. L. 115–254, div. B, title V, § 584(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3399"},"text":"132 Stat. 3399","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1c1fff1-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s441j–2"},"text":"section 441j–2 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
