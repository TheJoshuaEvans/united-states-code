{"tag":"section","attrib":{"id":"idd1f67ce2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3712"},"text":null,"children":[{"tag":"num","attrib":{"value":"3712"},"text":"§ 3712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds for certain emergent threats or opportunities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1f67ce3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3712/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of the Program, the Secretary of Defense may obligate and expend Cooperative Threat Reduction funds for a fiscal year, and any Cooperative Threat Reduction funds for a prior fiscal year that remain available for obligation, for a proliferation threat reduction project or activity if the Secretary, with the concurrence of the Secretary of State, determines each of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1f67ce4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3712/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" That such project or activity will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1f67ce5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3712/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the United States in the resolution of a critical emerging proliferation threat; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f67ce6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3712/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit the United States to take advantage of opportunities to achieve long-standing nonproliferation goals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67ce7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3712/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That such project or activity will be completed in a period not exceeding five years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67ce8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3712/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That the Department of Defense is the entity of the Federal Government that is most capable of carrying out such project or activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f67ce9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3712/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 15 days before the date on which the Secretary obligates funds under subsection (a) for a project or activity, the Secretary of Defense shall notify, in writing, the congressional defense committees and the Secretary of State shall notify, in writing, the Committee on Foreign Affairs of the House of Representatives and the Committee on Foreign Relations of the Senate of the determinations made under such subsection with respect to such project or activity, together with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1f67cea-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3712/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a justification for such determinations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67ceb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3712/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the scope and duration of such project or activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67cec-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3712/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a discussion of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1f67ced-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3712/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether authorities other than the authority under this section are available to the Secretaries to perform such project or activity to meet the threats or goals identified under subsection (a)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f67cee-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3712/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such other authorities exist, why the Secretaries were not able to use such authorities for such project or activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f67cef-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3712/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-defense agency partner-nation contacts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to military-to-military and defense contacts carried out under subsection (a)(6) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3711"},"text":"section 3711 of this title","children":[],"tail":", as further described in subsection (f) of such section, concurrence of the Secretary of State under subsection (a) is required only for participation in such contacts by personnel from non-defense agencies of foreign countries."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f67cf0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3712/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception to requirement for certain determinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirement for a determination under subsection (a) shall not apply to a state of the former Soviet Union.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1f67cf1-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tXIII/s1322"},"text":"Pub. L. 113–291, div. A, title XIII, § 1322","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3597"},"text":"128 Stat. 3597","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXIII/s1302/b/2"},"text":"Pub. L. 114–328, div. A, title XIII, § 1302(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2566"},"text":"130 Stat. 2566","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1f67cf2-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1f67cf3-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1f67cf4-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" substituted “Not later than 15 days before the date on which” for “At the time at which” in introductory provisions and added par. (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
