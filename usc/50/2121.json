{"tag":"section","attrib":{"id":"idd15de78f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2121"},"text":null,"children":[{"tag":"num","attrib":{"value":"2121"},"text":"§ 2121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary contributions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd15de790-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2121/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority for voluntary contributions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15de791-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2121/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under such regulations as may be prescribed by the Director, a participant may voluntarily contribute additional sums in multiples of one percent of the participant’s basic pay, but not in excess of 10 percent of such basic pay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15de792-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2121/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The voluntary contribution account in each case is the sum of unrefunded contributions, plus interest—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd15de793-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2121/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for periods before ","children":[{"tag":"date","attrib":{"date":"1985-01-01"},"text":"January 1, 1985","children":[],"tail":", at 3 percent a year; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd15de794-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2121/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for periods on or after ","children":[{"tag":"date","attrib":{"date":"1985-01-01"},"text":"January 1, 1985","children":[],"tail":", at the rate computed under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8334/e"},"text":"section 8334(e) of title 5","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"compounded annually to the date of election under subsection (b) or the date of payment under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15de795-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2121/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of voluntary contributions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Effective on the date of retirement and at the election of the participant, the participant’s account shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15de796-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2121/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" returned in a lump sum;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15de797-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2121/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used to purchase an additional life annuity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15de798-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2121/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used to purchase an additional life annuity for the participant and to provide for a cash payment on the participant’s death to a beneficiary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15de799-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2121/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used to purchase an additional life annuity for the participant and a life annuity commencing on the participant’s death payable to a beneficiary, with a guaranteed return to the beneficiary or the beneficiary’s legal representative of an amount equal to the cash payment referred to in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In the case of a benefit provided under paragraph (3) or (4), the participant shall notify the Director in writing of the name of the beneficiary of the cash payment or life annuity to be paid upon the participant’s death.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15de79a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2121/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Value of benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The benefits provided by subsection (b)(2), (3), or (4) shall be actuarially equivalent in value to the payment provided for in subsection (b)(1) and shall be calculated upon such tables of mortality as may be from time to time prescribed for this purpose by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15de79b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2121/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lump-sum payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A voluntary contribution account shall be paid in a lump sum at such time as the participant dies or separates from the Agency without entitlement to an annuity. In the case of death, the account shall be paid in the order of precedence specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2071/c"},"text":"section 2071(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15de79c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2121/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits in addition to other benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any benefit payable to a participant or to the participant’s beneficiary with respect to the additional contributions provided under this section shall be in addition to benefits otherwise provided under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd15de79d-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/tII/s281"},"text":"Pub. L. 88–643, title II, § 281","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s802"},"text":"Pub. L. 102–496, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3239"},"text":"106 Stat. 3239","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd15de79e-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd15de79f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd15de7a0-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/s281"},"text":"section 281 of Pub. L. 88–643","children":[],"tail":", title II, "},{"tag":"date","attrib":{"date":"1964-10-13"},"text":"Oct. 13, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1053"},"text":"78 Stat. 1053","children":[],"tail":"; Ex. Ord. No. 12443, § 3, "},{"tag":"date","attrib":{"date":"1983-09-27"},"text":"Sept. 27, 1983","children":[],"tail":", 48 F.R. 44751; "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/tV/s501/2"},"text":"Pub. L. 99–335, title V, § 501(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/622"},"text":"100 Stat. 622","children":[],"tail":", related to voluntary contributions and was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403"},"text":"section 403 of this title","children":[],"tail":" prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/88/643"},"text":"Pub. L. 88–643","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s802"},"text":"section 802 of Pub. L. 102–496","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd15de7a1-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd15de7a2-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of fourth month beginning after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s805"},"text":"section 805 of Pub. L. 102–496","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
