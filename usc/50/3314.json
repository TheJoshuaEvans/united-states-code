{"tag":"section","attrib":{"id":"idd1c92bd1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3314"},"text":null,"children":[{"tag":"num","attrib":{"value":"3314"},"text":"§ 3314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on national security systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1c92bd2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate committees of Congress defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c92bd3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3314/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional intelligence committees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c92bd4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3314/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations and the Committee on Armed Services of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c92bd5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3314/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations and the Committee on Armed Services of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c92bd6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", and annually thereafter, the Director of the National Security Agency, in coordination with the Secretary of Defense and the Chairman of the Joint Chiefs of Staff, shall submit to the appropriate committees of Congress a report on national security systems."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c92bd7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3314/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted under subsection (b) shall include information related to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c92bd8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3314/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national security systems or components thereof that have been decertified and are still in operational use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c92bd9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3314/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extension requests and the current status of any national security systems still in use or components thereof that have been decertified and are still in use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c92bda-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3314/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national security systems known to not be in compliance with the policies, principles, standards, and guidelines issued by the Committee on National Security Systems established pursuant to National Security Directive 42, signed by the President on ","children":[{"tag":"date","attrib":{"date":"1990-07-05"},"text":"July 5, 1990","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c92bdb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3314/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizations which have not provided access or information to the Director of the National Security Agency that is adequate to enable the Director to make a determination as to whether such organizations are in compliance with the policies, principles, standards, and guidelines issued by such Committee on National Security Systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1c92bdc-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/dN/tVI/s603"},"text":"Pub. L. 115–31, div. N, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/829"},"text":"131 Stat. 829","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1c92bdd-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1c92bde-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd1c92bdf-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “congressional intelligence committees” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/dN/s2"},"text":"section 2 of div. N of Pub. L. 115–31","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
