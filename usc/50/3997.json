{"tag":"section","attrib":{"id":"idd20bdb1b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3997"},"text":null,"children":[{"tag":"num","attrib":{"value":"3997"},"text":"§ 3997.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of information concerning benefits of subchapter","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd20bdb1c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3997/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of information by Secretary concerned","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary concerned shall issue to servicemembers information explaining the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20bdb1d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3997/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application forms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary concerned shall provide application forms to servicemembers requesting relief under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20bdb1e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3997/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information from Secretary of the Interior","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall furnish to the Secretary concerned information explaining the provisions of this subchapter (other than sections 3991, 4000, and 4001 of this title) and related application forms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd20bdb1f-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title V, § 507, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s1"},"text":"Pub. L. 108–189, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2857"},"text":"117 Stat. 2857","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd20bdb20-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd20bdb21-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd20bdb22-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 567 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd20bdb23-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 507 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"act Oct. 17, 1940, ch. 888","children":[],"tail":", art. V, "},{"tag":"ref","attrib":{"href":"/us/stat/54/1188"},"te