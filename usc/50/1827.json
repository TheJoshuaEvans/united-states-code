{"tag":"section","attrib":{"id":"idd143a7a8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1827"},"text":null,"children":[{"tag":"num","attrib":{"value":"1827"},"text":"§ 1827.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd143a7a9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1827/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person is guilty of an offense if he intentionally—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd143a7aa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1827/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under color of law for the purpose of obtaining foreign intelligence information, executes a physical search within the United States except as authorized by statute; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd143a7ab-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1827/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discloses or uses information obtained under color of law by physical search within the United States, knowing or having reason to know that the information was obtained through physical search not authorized by statute, for the purpose of obtaining intelligence information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd143a7ac-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1827/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is a defense to a prosecution under subsection (a) that the defendant was a law enforcement or investigative officer engaged in the course of his official duties and the physical search was authorized by and conducted pursuant to a search warrant or court order of a court of competent jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd143a7ad-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1827/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fine or imprisonment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An offense described in this section is punishable by a fine of not more than $10,000 or imprisonment for not more than five years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd143a7ae-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1827/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is Federal jurisdiction over an offense under this section if the person committing the offense was an officer or employee of the United States at the time the offense was committed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd143a7af-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511/tIII/s307"},"text":"Pub. L. 95–511, title III, § 307","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/359/tVIII/s807/a/3"},"text":"Pub. L. 103–359, title VIII, § 807(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-14"},"text":"Oct. 14, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3452"},"text":"108 Stat. 3452","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd143a7b0-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd143a7b1-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd143a7b2-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1994-10-14"},"text":"Oct. 14, 1994","children":[],"tail":", with exception for certain physical searches approved by the Attorney General to gather foreign intelligence information, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/359/s807/c"},"text":"section 807(c) of Pub. L. 103–359","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1821"},"text":"section 1821 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
