{"tag":"section","attrib":{"id":"idd1bf8ec1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3202"},"text":null,"children":[{"tag":"num","attrib":{"value":"3202"},"text":"§ 3202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education partnerships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1bf8ec2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the Foreign Languages Program, the head of a covered element of the intelligence community may enter into one or more education partnership agreements with educational institutions in the United States in order to encourage and enhance the study in such educational institutions of foreign languages that are critical to the capability of the intelligence community to carry out the national security activities of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1bf8ec3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance provided under educational partnership agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under an educational partnership agreement entered into with an educational institution pursuant to this section, the head of a covered element of the intelligence community may provide the following assistance to the educational institution:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1bf8ec4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3202/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The loan of equipment and instructional materials of the element of the intelligence community to the educational institution for any purpose and duration that the head of the element considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1bf8ec5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3202/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any other provision of law relating to the transfer of surplus property, the transfer to the educational institution of any computer equipment, or other equipment, that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1bf8ec6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3202/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commonly used by educational institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1bf8ec7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3202/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" surplus to the needs of the element of the intelligence community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1bf8ec8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3202/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined by the head of the element to be appropriate for support of such agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1bf8ec9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3202/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The provision of dedicated personnel to the educational institution—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1bf8eca-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3202/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to teach courses in foreign languages that are critical to the capability of the intelligence community to carry out the national security activities of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1bf8ecb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3202/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist in the development for the educational institution of courses and materials on such languages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1bf8ecc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3202/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The involvement of faculty and students of the educational institution in research projects of the element of the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1bf8ecd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3202/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cooperation with the educational institution in developing a program under which students receive academic credit at the educational institution for work on research projects of the element of the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c1ffce-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3202/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provision of academic and career advice and assistance to students of the educational institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c1ffcf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3202/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provision of cash awards and other items that the head of the element of the intelligence community considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1c1ffd0-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title X, § 1012, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/487/tVI/s612/a/2"},"text":"Pub. L. 108–487, title VI, § 612(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3956"},"text":"118 Stat. 3956","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1c1ffd1-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1c1ffd2-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1c1ffd3-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s441j–1"},"text":"section 441j–1 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
