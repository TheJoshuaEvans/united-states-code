{"tag":"section","attrib":{"id":"idd1ef5196-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3527"},"text":null,"children":[{"tag":"num","attrib":{"value":"3527"},"text":"§ 3527.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chaplain Corps and Chief of Chaplains","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1ef5197-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3527/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Chaplain Corps","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is in the Agency a Chaplain Corps, which shall provide spiritual and religious pastoral services and care across all components of the Agency for employees of all faiths and non-faiths.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ef5198-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3527/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief of Chaplains","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ef5199-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3527/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of the Chaplain Corps shall be the Chief of Chaplains, who shall be appointed by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ef519a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3527/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":" The Chief of Chaplains shall report directly to the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ef519b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3527/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief of Chaplains shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1ef519c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3527/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oversee the Chaplain Corps; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ef519d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3527/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be the proponent for, and consult with the Director on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1ef519e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3527/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all guidance pertaining to chaplains’ care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef519f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3527/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programming and instruction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef51a0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3527/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any policy or guidance pertaining to religion or religious accommodation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ef51a1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3527/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All appropriate offices of the Agency shall consult with the Chief of Chaplains on best practices to implement guidance or policy pertaining to religion or religious accommodation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ef51a2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3527/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Chaplains of the Chaplain Corps shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ef51a3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3527/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be located at the headquarters building of the Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ef51a4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3527/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" travel as necessary to provide services to personnel of the Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ef51a5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3527/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ef51a6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3527/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum staffing level","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chaplain Corps shall be composed of not less than 6 chaplains, of which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1ef51a7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3527/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 3 shall be full-time staff employees of the Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ef51a8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3527/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 3 shall be government contractors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ef51a9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3527/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall expeditiously fill any vacancies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ef51aa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3527/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusive role","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A chaplain of the Chaplain Corps shall serve exclusively in the chaplain’s role in the Chaplain Corps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ef51ab-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3527/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment; compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may appoint and fix the compensation of such chaplains of the Chaplain Corps as the Director considers appropriate, except that the Director may not provide basic pay to any chaplain of the Chaplain Corps at an annual rate of basic pay in excess of the maximum rate of basic pay for grade GS–15 of the General Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ef51ac-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3527/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ef51ad-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3527/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide security clearances, including one-time read-ins, to chaplains of the Chaplain Corps to ensure that personnel of the Agency can seek unrestricted chaplaincy counseling; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ef51ae-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3527/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnish physical workspace for the Chaplain Corps at the headquarters building of the Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ef51af-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3527/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall implement privacy standards with respect to the physical workspaces of the Chaplain Corps to ensure privacy for individuals visiting such spaces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ef51b0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3527/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of Chaplain Corps","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may not require a chaplain of the Chaplain Corps to perform any rite, ritual, or ceremony that is contrary to the conscience, moral principles, or religious beliefs of the chaplain or of the ecclesiastical organization that ordains the chaplain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ef51b1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3527/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certifications to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less frequently than annually, the Director shall certify to Congress whether implementation of this section meets the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1ef51b2-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-20/ch227/s26"},"text":"June 20, 1949, ch. 227, § 26","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dX/tIV/s411"},"text":"Pub. L. 117–103, div. X, title IV, § 411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/976"},"text":"136 Stat. 976","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dF/tLXV/s6504/a"},"text":"Pub. L. 119–60, div. F, title LXV, § 6504(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1627"},"text":"139 Stat. 1627","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1ef51b3-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1ef51b4-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1ef51b5-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" amended section generally. Prior to amendment, section consisted of subsecs. (a) to (c), relating, respectively, to establishment of Chaplain Corps, Chief of Chaplains, and staff and administration of the Chaplain Corps."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1ef51b6-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1ef51b7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability of Minimum Staffing Requirement","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dF/tLXV/s6504/b"},"text":"Pub. L. 119–60, div. F, title LXV, § 6504(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1629"},"text":"139 Stat. 1629","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dF/tLXV/s6504/b"},"text":"“The minimum staffing level required by subsection (d)(1) of section 26 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3527/d/1"},"text":"50 U.S.C. 3527(d)(1)","children":[],"tail":"] (as amended by subsection (a)) shall apply on and after the date that is 120 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
