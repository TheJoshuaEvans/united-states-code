{"tag":"section","attrib":{"id":"idd1923cad-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3029"},"text":null,"children":[{"tag":"num","attrib":{"value":"3029"},"text":"§ 3029.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil Liberties Protection Officer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1923cae-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3029/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil Liberties Protection Officer","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1923caf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3029/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within the Office of the Director of National Intelligence, there is a Civil Liberties Protection Officer who shall be appointed by the Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1923cb0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3029/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Civil Liberties Protection Officer shall report directly to the Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1923cb1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3029/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Civil Liberties Protection Officer shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1923cb2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3029/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the protection of civil liberties and privacy is appropriately incorporated in the policies and procedures developed for and implemented by the Office of the Director of National Intelligence and the elements of the intelligence community within the National Intelligence Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1923cb3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3029/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oversee compliance by the Office and the Director of National Intelligence with requirements under the Constitution and all laws, regulations, Executive orders, and implementing guidelines relating to civil liberties and privacy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1923cb4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3029/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and assess complaints and other information indicating possible abuses of civil liberties and privacy in the administration of the programs and operations of the Office and the Director of National Intelligence and, as appropriate, investigate any such complaint or information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1923cb5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3029/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the use of technologies sustain, and do not erode, privacy protections relating to the use, collection, and disclosure of personal information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1923cb6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3029/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that personal information contained in a system of records subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":" (popularly referred to as the “Privacy Act”), is handled in full compliance with fair information practices as set out in that section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1923cb7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3029/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct privacy impact assessments when appropriate or as required by law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1923cb8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3029/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other duties as may be prescribed by the Director of National Intelligence or specified by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1923cb9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3029/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of agency Inspectors General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When appropriate, the Civil Liberties Protection Officer may refer complaints to the Office of Inspector General having responsibility for the affected element of the department or agency of the intelligence community to conduct an investigation under paragraph (3) of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1923cba-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title I, § 103D, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI/s1011/a"},"text":"Pub. L. 108–458, title I, § 1011(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3658"},"text":"118 Stat. 3658","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1923cbb-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1923cbc-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1923cbd-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Privacy Act, referred to in subsec. (b)(5), probably means the Privacy Act of 1974, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/579"},"text":"Pub. L. 93–579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-31"},"text":"Dec. 31, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1896"},"text":"88 Stat. 1896","children":[],"tail":", which enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees, and provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1974 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1923cbe-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s403–3d"},"text":"section 403–3d of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1923cbf-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd1923cc0-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For Determination by President that section take effect on ","children":[{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", see Memorandum of President of the United States, "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", 70 F.R. 23925, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section effective not later than six months after ","children":[{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1097/a"},"text":"section 1097(a) of Pub. L. 108–458","children":[],"tail":", set out in an Effective Date of 2004 Amendment; Transition Provisions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
