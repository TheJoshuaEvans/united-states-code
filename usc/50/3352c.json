{"tag":"section","attrib":{"id":"idd1d7831d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352c"},"text":null,"children":[{"tag":"num","attrib":{"value":"3352c"},"text":"§ 3352c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals for promptness of determinations regarding security clearances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1d7831e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall reform the security clearance process with the objective that, by ","children":[{"tag":"date","attrib":{"date":"2021-12-31"},"text":"December 31, 2021","children":[],"tail":", 90 percent of all determinations, other than determinations regarding populations identified under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3352b/b/3/C"},"text":"section 3352b(b)(3)(C) of this title","children":[],"tail":", regarding—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d7831f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" security clearances—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d78320-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the secret level are issued in 30 days or fewer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d78321-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the top secret level are issued in 90 days or fewer; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d78322-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reciprocity of security clearances at the same level are recognized in 2 weeks or fewer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d78323-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain reinvestigations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall reform the security clearance process with the goal that by ","children":[{"tag":"date","attrib":{"date":"2021-12-31"},"text":"December 31, 2021","children":[],"tail":", reinvestigation on a set periodicity is not required for more than 10 percent of the population that holds a security clearance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d78324-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equivalent metrics","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d78325-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Council develops a set of performance metrics that it certifies to the appropriate congressional committees should achieve substantially equivalent outcomes as those outlined in subsections (a) and (b), the Council may use those metrics for purposes of compliance within this provision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d78326-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Council uses the authority provided by paragraph (1) to use metrics as described in such paragraph, the Council shall, not later than 30 days after communicating such metrics to departments and agencies, notify the appropriate congressional committees that it is using such authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d78327-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", the Council shall submit to the appropriate congressional committees and make available to appropriate industry partners a plan to carry out this section. Such plan shall include recommended interim milestones for the goals set forth in subsections (a) and (b) for 2019, 2020, and 2021."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1d78328-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLXVI/s6604"},"text":"Pub. L. 116–92, div. E, title LXVI, § 6604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2213"},"text":"133 Stat. 2213","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dF/tLXVIII/s6824/b/3"},"text":"Pub. L. 117–263, div. F, title LXVIII, § 6824(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3615"},"text":"136 Stat. 3615","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1d78329-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1d7832a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1d7832b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsecs. (c)(1), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “subsections (a) and (b)” for “subsections (b) and (c)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1d7832c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd1d7832d-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Council”, “reciprocity”, “appropriate congressional committees”, and “appropriate industry partners”, referred to in text, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3352"},"text":"section 3352 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
