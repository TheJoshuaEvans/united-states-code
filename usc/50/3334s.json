{"tag":"section","attrib":{"id":"idd1d2a0ec-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334s"},"text":null,"children":[{"tag":"num","attrib":{"value":"3334s"},"text":"§ 3334s.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs for next-generation microelectronics in support of artificial intelligence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1d2a0ed-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334s/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, the Director of National Intelligence, acting through the Director of the Intelligence Advanced Research Projects Activity, shall establish or otherwise oversee a program to advance microelectronics research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d2a0ee-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334s/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research focus","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of National Intelligence shall ensure that the research carried out under the program established under subsection (a) is focused on the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d2a0ef-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334s/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advanced engineering and applied research into next-generation computing models, materials, devices, architectures, and algorithms to enable the advancement of artificial intelligence and machine learning.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d2a0f0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334s/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Efforts to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d2a0f1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334s/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" overcome challenges with engineering and applied research of microelectronics, including with respect to the physical limits on transistors, electrical interconnects, and memory elements; ","children":[{"tag":"ref","attrib":{"idref":"fn002092"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002092"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “and”."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d2a0f2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334s/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" promote long-term advancements in computing technologies, including by fostering a unified and multidisciplinary approach encompassing research and development into—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1d2a0f3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334s/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" next-generation algorithm design;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1d2a0f4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334s/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" next-generation compute capability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1d2a0f5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334s/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" generative and adaptive artificial intelligence for design applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1d2a0f6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334s/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" photonics-based microprocessors, including electrophotonics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1d2a0f7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334s/b/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chemistry and physics of new materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1d2a0f8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334s/b/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" optical communication networks, including electrophotonics; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1d2a0f9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334s/b/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" safety and controls for generative artificial intelligence applications for the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d2a0fa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334s/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other activity the Director determines would promote the development of microelectronics research for future technologies, including optical communications or quantum technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d2a0fb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334s/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration, consultation, and collaboration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program established under subsection (a), the Director of National Intelligence shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d2a0fc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334s/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the national strategy developed pursuant to subsection (a)(3)(A)(i) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4656"},"text":"section 4656 of title 15","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d2a0fd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334s/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the Secretary of Commerce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d2a0fe-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334s/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actively collaborate with relevant Government agencies and programs, including the programs established under subsection ","children":[{"tag":"ref","attrib":{"idref":"fn002093"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002093"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “subsections”."}],"tail":" (c), (d), (e), and (f) of such "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s4656"},"text":"section 4656 of title 15","children":[],"tail":", academic institutions, and private industry to leverage expertise and resources in conducting research."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d2a0ff-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334s/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts authorized to be appropriated for the National Intelligence Program of the Office of the Director of National Intelligence may be made available to carry out the program established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1d2a100-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tV/s7507"},"text":"Pub. L. 118–31, div. G, title V, § 7507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1089"},"text":"137 Stat. 1089","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dF/tLXVIII/s6801/b/1"},"text":"Pub. L. 119–60, div. F, title LXVIII, § 6801(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1653"},"text":"139 Stat. 1653","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1d2a101-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1d2a102-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1d2a103-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" struck out subsec. (e) which related to briefing requirements of the Director of the Intelligence Advanced Research Projects Activity."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1d2a104-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd1d2a105-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “intelligence community” and “congressional intelligence committees” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s7002"},"text":"section 7002 of Pub. L. 118–31","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
