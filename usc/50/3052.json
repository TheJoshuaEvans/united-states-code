{"tag":"section","attrib":{"id":"idd19e4ac7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3052"},"text":null,"children":[{"tag":"num","attrib":{"value":"3052"},"text":"§ 3052.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on establishment or operation of diplomatic intelligence support centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd19e4ac8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3052/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd19e4ac9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3052/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A diplomatic intelligence support center may not be established, operated, or maintained without the prior approval of the Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd19e4aca-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3052/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director may only approve the establishment, operation, or maintenance of a diplomatic intelligence support center if the Director determines that the establishment, operation, or maintenance of such center is required to provide necessary intelligence support in furtherance of the national security interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19e4acb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3052/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of use of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated pursuant to authorizations by law for intelligence and intelligence-related activities may not be obligated or expended for the establishment, operation, or maintenance of a diplomatic intelligence support center that is not approved by the Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19e4acc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3052/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd19e4acd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3052/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “diplomatic intelligence support center” means an entity to which employees of the various elements of the intelligence community (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003/4"},"text":"section 3003(4) of this title","children":[],"tail":") are detailed for the purpose of providing analytical intelligence support that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd19e4ace-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3052/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consists of intelligence analyses on military or political matters and expertise to conduct limited assessments and dynamic taskings for a chief of mission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd19e4acf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3052/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not intelligence support traditionally provided to a chief of mission by the Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd19e4ad0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3052/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “chief of mission” has the meaning given that term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3902/3"},"text":"section 3902(3) of title 22","children":[],"tail":", and includes ambassadors at large and ministers of diplomatic missions of the United States, or persons appointed to lead United States offices abroad designated by the Secretary of State as diplomatic in nature."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19e4ad1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3052/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall cease to be effective on ","children":[{"tag":"date","attrib":{"date":"2000-10-01"},"text":"October 1, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd19e4ad2-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title I, § 115, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/120/tIII/s303/a"},"text":"Pub. L. 106–120, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-03"},"text":"Dec. 3, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1610"},"text":"113 Stat. 1610","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI/s1071/a/1/P"},"text":"Pub. L. 108–458, title I, § 1071(a)(1)(P)","children":[],"tail":"–(R), "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3689"},"text":"118 Stat. 3689","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd19e4ad3-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd19e4ad4-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd19e4ad5-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s404j"},"text":"section 404j of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd19e4ad6-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1071/a/1/P"},"text":"Pub. L. 108–458, § 1071(a)(1)(P)","children":[],"tail":", substituted “Director of National Intelligence” for “Director of Central Intelligence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1071/a/1/Q"},"text":"Pub. L. 108–458, § 1071(a)(1)(Q)","children":[],"tail":", substituted “Director of National Intelligence” for “Director of Central Intelligence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1071/a/1/R"},"text":"Pub. L. 108–458, § 1071(a)(1)(R)","children":[],"tail":", substituted “Director of National Intelligence” for “Director of Central Intelligence”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd19e4ad7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd19e4ad8-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For Determination by President that amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" take effect on "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", see Memorandum of President of the United States, "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", 70 F.R. 23925, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" effective not later than six months after "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1097/a"},"text":"section 1097(a) of Pub. L. 108–458","children":[],"tail":", set out in an Effective Date of 2004 Amendment; Transition Provisions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
