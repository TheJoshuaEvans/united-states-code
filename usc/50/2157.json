{"tag":"section","attrib":{"id":"idd160319b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2157"},"text":null,"children":[{"tag":"num","attrib":{"value":"2157"},"text":"§ 2157.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd160319c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2157/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall prescribe regulations providing for the transition from the Central Intelligence Agency Retirement and Disability System to the Federal Employees’ Retirement System provided in chapter 84 of title 5 in a manner consistent with sections 301 through 304 of the Federal Employees’ Retirement System Act of 1986.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd160319d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2157/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall submit regulations prescribed under subsection (a) to the congressional intelligence committees before they take effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd160319e-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/tIII/s307"},"text":"Pub. L. 88–643, title III, § 307","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s802"},"text":"Pub. L. 102–496, title VIII, § 802","children":[],"tail"