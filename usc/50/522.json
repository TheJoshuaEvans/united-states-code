{"tag":"section","attrib":{"id":"idd0fe8946-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s522"},"text":null,"children":[{"tag":"num","attrib":{"value":"522"},"text":"§ 522.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of lands; advance payments for construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To accomplish the purposes of this subchapter, the Secretary of the Air Force is authorized to acquire lands and rights pertaining thereto, or other interest therein, including the temporary use thereof, by donation, purchase, exchange of Government-owned lands, or otherwise, and construction under this subchapter may be prosecuted without regard to section 3324(a) and (b) of title 31.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd0fe8947-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-27/ch766"},"text":"Oct. 27, 1949, ch. 766","children":[],"tail":", title II, § 202, "},{"tag":"ref","attrib":{"href":"/us/stat/63/937"},"text":"63 Stat. 937","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd0fe8948-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd0fe8949-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd0fe894a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Section 3324(a) and (b) of title 31” substituted in text for “section 3648, Revised Statutes, as amended [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s529"},"text":"31 U.S.C. 529","children":[],"tail":"]” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s4/b"},"text":"Pub. L. 97–258, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1067"},"text":"96 Stat. 1067","children":[],"tail":", the first section of which enacted Title 31, Money and Finance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
