{"tag":"section","attrib":{"id":"idd16512dd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2353"},"text":null,"children":[{"tag":"num","attrib":{"value":"2353"},"text":"§ 2353.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive preparedness program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd16512de-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2353/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, acting through the Committee on Nonproliferation established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2352"},"text":"section 2352 of this title","children":[],"tail":", shall develop a comprehensive program for carrying out this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16512df-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2353/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program set forth in the report shall include specific plans as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16512e0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2353/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Plans for countering proliferation of weapons of mass destruction and related materials and technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16512e1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2353/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Plans for training and equipping Federal, State, and local officials for managing a crisis involving a use or threatened use of a weapon of mass destruction, including the consequences of the use of such a weapon.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16512e2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2353/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Plans for providing for regular sharing of information among intelligence, law enforcement, and customs agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16512e3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2353/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Plans for training and equipping law enforcement units, customs services, and border security personnel to counter the smuggling of weapons of mass destruction and related materials and technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16512e4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2353/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Plans for establishing appropriate centers for analyzing seized nuclear, radiological, biological, and chemical weapons, and related materials and technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16512e5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2353/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Plans for establishing in the United States appropriate legal controls and authorities relating to the exporting of nuclear, radiological, biological, and chemical weapons, and related materials and technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16512e6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2353/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Plans for encouraging and assisting governments of foreign countries to implement and enforce laws that set forth appropriate penalties for offenses regarding the smuggling of weapons of mass destruction and related materials and technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16512e7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2353/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Plans for building the confidence of the United States and Russia in each other’s controls over United States and Russian nuclear weapons and fissile materials, including plans for verifying the dismantlement of nuclear weapons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16512e8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2353/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Plans for reducing United States and Russian stockpiles of excess plutonium, reflecting—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd16512e9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2353/b/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consideration of the desirability and feasibility of a United States-Russian agreement governing fissile material disposition and the specific technologies and approaches to be used for disposition of excess plutonium; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16512ea-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2353/b/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the options for United States cooperation with Russia in the disposition of Russian plutonium.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16512eb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2353/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Plans for studying the merits and costs of establishing a global network of means for detecting and responding to terroristic or other criminal use of biological agents against people or other forms of life in the United States or any foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16512ec-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2353/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16512ed-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2353/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At the same time that the President submits the budget for fiscal year 1998 to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":", the President shall submit to Congress a report that sets forth the comprehensive program developed under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16512ee-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2353/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The report shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd16512ef-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2353/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The specific plans for the program that are required under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16512f0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2353/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Estimates of the funds necessary, by agency or department, for carrying out such plans in fiscal year 1998 and the following five fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16512f1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2353/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The report shall be in an unclassified form. If there is a classified version of the report, the President shall submit the classified version at the same time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd16512f2-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXIV/s1443"},"text":"Pub. L. 104–201, div. A, title XIV, § 1443","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2728"},"text":"110 Stat. 2728","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd16512f3-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd16512f4-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd16512f5-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this title”, meaning title XIV of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2714"},"text":"110 Stat. 2714","children":[],"tail":", which is classified principally to this chapter. For complete classification of title XIV to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2301"},"text":"section 2301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
