{"tag":"section","attrib":{"id":"idd20bda7b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3973"},"text":null,"children":[{"tag":"num","attrib":{"value":"3973"},"text":"§ 3973.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for insurance protection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd20bda7c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3973/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application procedure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application for protection under this subchapter shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20bda7d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3973/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be in writing and signed by the insured, the insured’s legal representative, or the insured’s beneficiary, as the case may be;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20bda7e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3973/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the policy and the insurer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20bda7f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3973/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include an acknowledgement that the insured’s rights under the policy are subject to and modified by the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20bda80-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3973/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Veterans Affairs may require additional information from the applicant, the insured and the insurer to determine if the policy is entitled to protection under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20bda81-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3973/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to the Secretary by the insurer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon receipt of the application of the insured, the insurer shall furnish a report concerning the policy to the Secretary of Veterans Affairs as required by regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20bda82-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3973/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy modification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon application for protection under this subchapter, the insured and the insurer shall have constructively agreed to any policy modification necessary to give this title full force and effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd20bda83-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title IV, § 403, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s1"},"text":"Pub. L. 108–189, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2852"},"text":"117 Stat. 2852","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd20bda84-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd20bda85-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd20bda86-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 543 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd20bda87-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 403 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"act Oct. 17, 1940, ch. 888","children":[],"tail":", art. IV, "},{"tag":"ref","attrib":{"href":"/us/stat/54/1184"},"text":"54 Stat. 1184","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1942-10-06/ch581/s13"},"text":"Oct. 6, 1942, ch. 581, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/775"},"text":"56 Stat. 775","children":[],"tail":"; "},{"tag":"ref","att