{"tag":"section","attrib":{"id":"idd1cb9c91-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3326"},"text":null,"children":[{"tag":"num","attrib":{"value":"3326"},"text":"§ 3326.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation of expenditure of funds appropriated for Department of Defense intelligence programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"During the current fiscal year and hereafter, none of the funds appropriated for intelligence programs to the Department of Defense which are transferred to another Federal agency for execution shall be expended by the Department of Defense in any fiscal year in excess of amounts required for expenditure during such fiscal year by the Federal agency to which such funds are transferred.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd1cb9c92-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/172/tVIII/s8089"},"text":"Pub. L. 102–172, title VIII, § 8089","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-26"},"text":"Nov. 26, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1193"},"text":"105 Stat. 1193","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1cb9c93-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1cb9c94-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1cb9c95-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s414"},"text":"section 414 of this title","children":[],"tail":" prior to editorial reclassification as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
