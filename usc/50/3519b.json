{"tag":"section","attrib":{"id":"idd1ece088-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3519b"},"text":"§ 3519b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for certain individuals injured by reason of war, insurgency, hostile act, terrorist activities, or incidents designated by the Director","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1ece089-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ece08a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered dependent","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered dependent” means a family member (as defined by the Director) of a covered employee who, on or after ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1ece08b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accompanies the covered employee to an assigned duty station in a foreign country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ece08c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" becomes injured by reason of a qualifying injury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ece08d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered employee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered employee” means an officer or employee of the Central Intelligence Agency who, on or after ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":", becomes injured by reason of a qualifying injury."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ece08e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered individual","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered individual” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1ece08f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1ece090-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is detailed to the Central Intelligence Agency from other agencies of the United States Government or from the Armed Forces; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ece091-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is affiliated with the Central Intelligence Agency, as determined by the Director; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ece092-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, on or after ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":", becomes injured by reason of a qualifying injury."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ece093-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying injury","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualifying injury” means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1ece094-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to a covered dependent, an injury incurred—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1ece095-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during a period in which the covered dependent is accompanying the covered employee to an assigned duty station in a foreign country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ece096-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in connection with war, insurgency, hostile act, terrorist activity, or an incident designated for purposes of this section by the Director; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ece097-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/a/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that was not the result of the willful misconduct of the covered dependent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ece098-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to a covered employee or a covered individual—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1ece099-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an injury incurred—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idd1ece09a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/a/4/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during a period of assignment to a duty station in a foreign country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd1ece09b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/a/4/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in connection with war, insurgency, hostile act, or terrorist activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd1ece09c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/a/4/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that was not the result of the willful misconduct of the covered employee or the covered individual; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ece09d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an injury incurred—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idd1ece09e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/a/4/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in connection with an incident designated for purposes of this section by the Director; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd1ece09f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/a/4/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that was not the result of the willful misconduct of the covered employee or the covered individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ece0a0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment of compensation for total disability resulting from certain injuries","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ece0a1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director may increase the amount of monthly compensation paid to a covered employee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8105"},"text":"section 8105 of title 5","children":[],"tail":". Subject to paragraph (2), the Director may determine the amount of each such increase by taking into account—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1ece0a2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the severity of the qualifying injury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ece0a3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the circumstances by which the covered employee became injured; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ece0a4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the seniority of the covered employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ece0a5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding chapter 81 of title 5, the total amount of monthly compensation increased under paragraph (1) may not exceed the monthly pay of the maximum rate of basic pay for GS–15 of the General Schedule under section 5332 of such title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ece0a6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs for treating qualifying injuries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may pay the costs of treating a qualifying injury of a covered employee, a covered individual, or a covered dependent, or may reimburse a covered employee, a covered individual, or a covered dependent for such costs, that are not otherwise covered by chapter 81 of title 5, or other provision of Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ece0a7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to make payments for qualifying injuries to the brain","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ece0a8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1ece0a9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered dependent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered dependent” has the meaning given such term in subsection (a), except that the assigned duty station need not be in a foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ece0aa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying injury","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualifying injury” has the meaning given such term in subsection (a), except that the assigned duty station need not be in a foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ece0ab-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law but subject to paragraph (3), the Director may provide payment to a covered dependent, a covered employee, and a covered individual for a qualifying injury to the brain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ece0ac-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1ece0ad-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Payment under paragraph (2) in a fiscal year may be made using any funds—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1ece0ae-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriated specifically for payments under such paragraph; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ece0af-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reprogrammed in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3094"},"text":"section 3094 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ece0b0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each fiscal year, the Director shall include with the budget justification materials submitted to Congress in support of the budget of the President for that fiscal year pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":" an estimate of the funds required in that fiscal year to make payments under paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ece0b1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1ece0b2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall prescribe regulations to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ece0b3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations prescribed under subparagraph (A) shall include regulations detailing fair and equitable criteria for payment under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ece0b4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on other benefits","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1ece0b5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments made under paragraph (2) are supplemental to any other benefit furnished by the United States Government for which a covered dependent, covered employee, or covered individual is entitled, and the receipt of such payments may not affect the eligibility of such a person to any other benefit furnished by the United States Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ece0b6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3519b/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to certain Federal workers compensation laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Without regard to the requirements in sections (b) and (c), covered employees need not first seek benefits provided under chapter 81 of title 5 to be eligible solely for payment authorized under paragraph (2) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1ece0b7-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-20/ch227/s19A"},"text":"June 20, 1949, ch. 227, § 19A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLXIV/s6412/a"},"text":"Pub. L. 116–92, div. E, title LXIV, § 6412(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2197"},"text":"133 Stat. 2197","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/46/s2/b"},"text":"Pub. L. 117–46, § 2(b)","children":[],"tail":", (f), "},{"tag":"date","attrib":{"date":"2021-10-08"},"text":"Oct. 8, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/391"},"text":"135 Stat. 391","children":[],"tail":", 393; "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dX/tVI/s603/a"},"text":"Pub. L. 117–103, div. X, title VI, § 603(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/995"},"text":"136 Stat. 995","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tVIII"},"text":"Pub. L. 118–31, div. G, title VIII","children":[],"tail":", §§ 7801, 7802(a), "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1102"},"text":"137 Stat. 1102","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1ece0b8-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1ece0b9-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1ece0ba-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s7801"},"text":"Pub. L. 118–31, § 7801","children":[],"tail":", added par. (3) and struck out former par. (3). Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) ","children":[{"tag":"inline","attrib":{},"text":"Appropriations required","children":[],"tail":".—Payment under paragraph (2) in a fiscal year may only be made using amounts appropriated in advance specifically for payments under such paragraph in such fiscal year."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) ","children":[{"tag":"inline","attrib":{},"text":"Matter of payments","children":[],"tail":".—Payments under paragraph (2) using amounts appropriated for such purpose shall be made on a first come, first serve, or pro rata basis."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) ","children":[{"tag":"inline","attrib":{},"text":"Amounts of payments","children":[],"tail":".—The total amount of funding obligated for payments under paragraph (2) may not exceed the amount specifically appropriated for providing payments under such paragraph during its period of availability.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s7802/a"},"text":"Pub. L. 118–31, § 7802(a)","children":[],"tail":", designated existing provisions as subpar. (A), inserted heading, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":" added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/46/s2/f"},"text":"Pub. L. 117–46, § 2(f)","children":[],"tail":", inserted “total disability resulting from” before “certain injuries” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/46/s2/b"},"text":"Pub. L. 117–46, § 2(b)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1ece0bb-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1ece0bc-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/46/s2/c"},"text":"Pub. L. 117–46, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-10-08"},"text":"Oct. 8, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/392"},"text":"135 Stat. 392","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/46/s2/c"},"text":"“Payment under subsection (d) of such section [meaning ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3519b/d"},"text":"50 U.S.C. 3519b(d)","children":[],"tail":"], as added by subsection (b) of this section, may be made available for a qualifying injury to the brain that occurs before, on, or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2021-10-08"},"text":"Oct. 8, 2021","children":[],"tail":"] as the Director of the Central Intelligence Agency considers appropriate.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “qualifying injury” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/46/s2/c"},"text":"section 2(c) of Pub. L. 117–46","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/46/s2/a"},"text":"section 2(a) of Pub. L. 117–46","children":[],"tail":", set out below.]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLXIV/s6412/c"},"text":"Pub. L. 116–92, div. E, title LXIV, § 6412(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2198"},"text":"133 Stat. 2198","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dE/tLXIV/s6412/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Section 19A of the Central Intelligence Agency Act of 1949 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3519b"},"text":"50 U.S.C. 3519b","children":[],"tail":"], as added by subsection (a), shall apply with respect to—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments made to covered employees (as defined in such section) under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8105"},"text":"section 8105 of title 5","children":[],"tail":", United States Code, beginning on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treatment described in subsection (b) of such section 19A occurring on or after the date of the enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1ece0bd-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tVIII/s7802/b"},"text":"Pub. L. 118–31, div. G, title VIII, § 7802(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1103"},"text":"137 Stat. 1103","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dG/tVIII/s7802/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Not later than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":"], the Director of the Central Intelligence Agency shall—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revise applicable regulations to conform with the amendment made by subsection (a) [amending this section]; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the congressional intelligence committees, the Subcommittee on Defense of the Committee on Appropriations of the Senate, and the Subcommittee on Defense of the Committee on Appropriations of the House of Representatives copies of such regulations, as revised pursuant to paragraph (1).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “congressional intelligence committees” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s7802/b"},"text":"section 7802(b) of Pub. L. 118–31","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/s7002"},"text":"section 7002 of Pub. L. 118–31","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":".]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/46/s2/e"},"text":"Pub. L. 117–46, § 2(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-10-08"},"text":"Oct. 8, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/393"},"text":"135 Stat. 393","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/46/s2/e"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-10-08"},"text":"Oct. 8, 2021","children":[],"tail":"], the Director shall prescribe regulations required under section 19A(d)(4)(A) of such Act [meaning act "},{"tag":"date","attrib":{"date":"1949-06-20"},"text":"June 20, 1949","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3519b/d/4/A"},"text":"50 U.S.C. 3519b(d)(4)(A)","children":[],"tail":"], as added by subsection (b) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 210 days after the date of the enactment of this Act, the Director shall submit to the appropriate congressional committees the regulations prescribed in accordance with paragraph (1).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “appropriate congressional committees” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/46/s2/e"},"text":"section 2(e) of Pub. L. 117–46","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/46/s2/a"},"text":"section 2(a) of Pub. L. 117–46","children":[],"tail":", set out below.]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLXIV/s6412/b"},"text":"Pub. L. 116–92, div. E, title LXIV, § 6412(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2198"},"text":"133 Stat. 2198","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dE/tLXIV/s6412/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Not later than 120 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":"], the Director of the Central Intelligence Agency shall—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe regulations ensuring the fair and equitable implementation of section 19A of the Central Intelligence Agency Act of 1949 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3519b"},"text":"50 U.S.C. 3519b","children":[],"tail":"], as added by subsection (a); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the congressional intelligence committees such regulations.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “congressional intelligence committees” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s6412/b"},"text":"section 6412(b) of Pub. L. 116–92","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/s5003"},"text":"section 5003 of div. E of Pub. L. 116–92","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1ece0be-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Intelligence Community Implementation of HAVANA Act of 2021 Authorities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tVIII/s7803"},"text":"Pub. L. 118–31, div. G, title VIII, § 7803","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1103"},"text":"137 Stat. 1103","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dG/tVIII/s7803"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c), not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":"], each head of an element of the intelligence community that has not already done so shall—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue regulations and procedures to implement the authorities provided by section 19A(d) of the Central Intelligence Agency Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3519b/d"},"text":"50 U.S.C. 3519b(d)","children":[],"tail":") and section 901(i) of title IX of division J of the Further Consolidated Appropriations Act, 2020 ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2680b/i"},"text":"22 U.S.C. 2680b(i)","children":[],"tail":") to provide payments under such sections, to the degree that such authorities are applicable to the head of the element; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the congressional intelligence committees, the Committee on Armed Services and the Subcommittee on Defense of the Committee on Appropriations of the Senate, and the Committee on Armed Services and the Subcommittee on Defense of the Committee on Appropriations of the House of Representatives copies of such regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 210 days after the date of the enactment of this Act, each head of an element of the intelligence community shall submit to the congressional intelligence committees, the Committee on Armed Services and the Subcommittee on Defense of the Committee on Appropriations of the Senate, and the Committee on Armed Services and the Subcommittee on Defense of the Committee on Appropriations of the House of Representatives a report on—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated number of individuals associated with their element that may be eligible for payment under the authorities described in subsection (a)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the obligation that the head of the intelligence community element expects to incur in fiscal year 2025 as a result of establishing the regulations pursuant to subsection (a)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any perceived barriers or concerns in implementing such authorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternative Reporting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of the enactment of this Act, each head of an element of the intelligence community (other than the Director of the Central Intelligence Agency) who believes that the authorities described in subsection (a)(1) are not currently relevant for individuals associated with their element, or who are not otherwise in position to issue the regulations and procedures required by subsection (a)(1) shall provide written and detailed justification to the congressional intelligence committees, the Committee on Armed Services and the Subcommittee on Defense of the Committee on Appropriations of the Senate, and the Committee on Armed Services and the Subcommittee on Defense of the Committee on Appropriations of the House of Representatives to explain this position.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definitions of “intelligence community” and “congressional intelligence committees” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s7803"},"text":"section 7803 of Pub. L. 118–31","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/s7002"},"text":"section 7002 of Pub. L. 118–31","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd1ece0bf-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/46/s2/a"},"text":"Pub. L. 117–46, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-10-08"},"text":"Oct. 8, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/391"},"text":"135 Stat. 391","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/46/s2/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section [amending this section and enacting provisions set out as notes above]:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate congressional committees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘appropriate congressional committees’ mean—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional intelligence committees (as that term is defined in section 3 of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"50 U.S.C. 3003","children":[],"tail":"));"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Homeland Security and Governmental Affairs and the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Homeland Security and the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered dependent","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘covered dependent’ has the meaning given such term in subsection (d)(1) of section 19 [probably should be “19A”] of the Central Intelligence Agency Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3519"},"text":"50 U.S.C. 3519","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3519b"},"text":"50 U.S.C. 3519b","children":[],"tail":"], as added by subsection (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered employee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘covered employee’ has the meaning given such term in section 19A(a) of the Central Intelligence Agency Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3519b/a"},"text":"50 U.S.C. 3519b(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered individual","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘covered individual’ has the meaning given such term in section 19A(a) of the Central Intelligence Agency Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3519b/a"},"text":"50 U.S.C. 3519b(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifying injury","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘qualifying injury’ has the meaning given such term in subsection (d)(1) of section 19 [probably should be “19A”] of the Central Intelligence Agency Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3519"},"text":"50 U.S.C. 3519","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3519b"},"text":"50 U.S.C. 3519b","children":[],"tail":"], as added by subsection (b).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
