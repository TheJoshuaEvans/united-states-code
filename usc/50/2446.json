{"tag":"section","attrib":{"id":"idd16e883b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2446"},"text":null,"children":[{"tag":"num","attrib":{"value":"2446"},"text":"§ 2446.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of contractors who engage in improper program management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd16e883c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2446/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided by subsection (b), if the Secretary of Energy or the Administrator determines that a covered contractor engaged in improper program management that resulted in a notification under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2753"},"text":"section 2753 of this title","children":[],"tail":" or significantly and detrimentally affected the cost, scope, or schedule associated with the approval of critical decision 3 in the acquisition process for a project (as defined in Department of Energy Order 413.3B (relating to program management and project management for the acquisition of capital assets)), the Secretary or the Administrator, as the case may be, shall submit to the appropriate congressional committees—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16e883d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2446/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation as to whether termination of the contract is an appropriate remedy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16e883e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2446/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the terms of the contract regarding award fees and performance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16e883f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2446/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the Secretary or the Administrator, as the case may be, plans to exercise options under the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16e8840-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2446/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary or the Administrator, as the case may be, is not able to submit the information described in paragraphs (1) through (3) of subsection (a) by reason of a contract enforcement action, the Secretary or the Administrator, as the case may be, shall submit to the appropriate congressional committees a notification of such contract enforcement action and the date on which the Secretary or the Administrator, as the case may be, plans to submit the information described in such paragraphs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16e8841-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2446/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16e8842-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2446/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd16e8843-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2446/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional defense committees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16e8844-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2446/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Commerce of the House of Representatives and the Committee on Energy and Natural Resources of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16e8845-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2446/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered contractor” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd16e8846-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2446/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contractor of the Administration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16e8847-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2446/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contractor of an element of the Department of Energy (other than the Administration) involved in nuclear security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd16e8848-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dC/tXXXII/s3247"},"text":"Pub. L. 106–65, div. C, title XXXII, § 3247","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dC/tXXXI/s3111/c/1"},"text":"Pub. L. 114–92, div. C, title XXXI, § 3111(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1188"},"text":"129 Stat. 1188","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
