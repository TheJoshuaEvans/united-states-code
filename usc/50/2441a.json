{"tag":"section","attrib":{"id":"idd16c17d7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2441a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2441a"},"text":"§ 2441a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized personnel levels of the Office of the Administrator","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd16c17d8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2441a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of IPA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall ensure that the expertise of the national security laboratories and the nuclear weapons production facilities is made available to the Administration, the Department of Energy, the Department of Defense, other Federal agencies, and Congress through the temporary assignment of personnel from such laboratories and facilities pursuant to the Intergovernmental Personnel Act Mobility Program and other similar programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16c17d9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2441a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of the Administrator employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “Office of the Administrator”, with respect to the employees of the Administration, includes employees whose funding is derived from an account of the Administration titled “Federal Salaries and Expenses”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16c17da-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2441a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual briefing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conjunction with the submission of the budget of the President to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", the Administrator shall provide to the congressional defense committees a briefing containing the following information:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16c17db-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2441a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A projection of the expected number of employees of the Office of the Administrator, as counted under subsection (d), for the fiscal year covered by the budget and the four subsequent fiscal years, broken down by the office in which the employees are projected to be assigned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16c17dc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2441a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to the most recent fiscal year for which data is available—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd16c17dd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2441a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of service support contracts of the Administration and whether such contracts are funded using program or program direction funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16c17de-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2441a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of full-time equivalent contractor employees working under each contract identified under subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16c17df-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2441a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of full-time equivalent contractor employees described in subparagraph (B) that have been employed under such a contract for a period greater than two years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16c17e0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2441a/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to each contract identified under subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd16c17e1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2441a/c/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of each appropriations account that supports the contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd16c17e2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2441a/c/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount obligated under the contract during the fiscal year, listed by each such account; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16c17e3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2441a/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to each appropriations account identified under subparagraph (D)(i), the total amount obligated for contracts identified under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16c17e4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2441a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counting rule","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16c17e5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2441a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A determination of the number of employees in the Office of the Administrator under subsection (c) shall be expressed on a full-time equivalent basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16c17e6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2441a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided by paragraph (3), in determining the total number of employees in the Office of the Administrator under subsection (c), the Administrator shall count each employee of the Office without regard to whether the employee is located at the headquarters of the Administration, a site office of the Administration, a service or support center of the Administration, or any other location.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16c17e7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2441a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following employees may not be counted for purposes of determining the total number of employees in the Office of the Administrator under subsection (c):","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd16c17e8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2441a/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Employees of the Office of Naval Reactors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16c17e9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2441a/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Employees of the Office of Secure Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16c17ea-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2441a/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Armed Forces detailed to the Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16c17eb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2441a/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Personnel supporting the Office of the Administrator pursuant to the mobility program under subchapter VI of chapter 33 of title 5 (commonly referred to as the “Intergovernmental Personnel Act Mobility Program”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd16c17ec-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dC/tXXXII/s3241A"},"text":"Pub. L. 106–65, div. C, title XXXII, § 3241A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dC/tXXXI/s3111/a/1"},"text":"Pub. L. 112–239, div. C, title XXXI, § 3111(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2168"},"text":"126 Stat. 2168","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dC/tXXXI/s3116"},"text":"Pub. L. 113–291, div. C, title XXXI, § 3116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3888"},"text":"128 Stat. 3888","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dC/tXXXI/s3138"},"text":"Pub. L. 114–92, div. C, title XXXI, § 3138","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1215"},"text":"129 Stat. 1215","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dC/tXXXI/s3136/a"},"text":"Pub. L. 114–328, div. C, title XXXI, § 3136(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2771"},"text":"130 Stat. 2771","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dC/tXXXI/s3111/a"},"text":"Pub. L. 116–92, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1949"},"text":"133 Stat. 1949","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dC/tXXXI/s3117"},"text":"Pub. L. 117–263, div. C, title XXXI, § 3117","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3054"},"text":"136 Stat. 3054","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd16c17ed-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd16c17ee-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd16c17ef-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3117/a/1"},"text":"Pub. L. 117–263, § 3117(a)(1)","children":[],"tail":", (2), redesignated subsec. (d) as (a) and struck out former subsec. (a) which limited the number of employees of the Office of the Administrator to 1,890 and required justification for any excess starting with fiscal year 2020."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3117/a/2"},"text":"Pub. L. 117–263, § 3117(a)(2)","children":[],"tail":", redesignated subsec. (e) as (b). Former subsec. (b) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3117/a/2"},"text":"Pub. L. 117–263, § 3117(a)(2)","children":[],"tail":", (b), redesignated subsec. (f) as (c) and amended it generally. Prior to amendment, subsec. related to report to be included in annual budget justification materials. Former subsec. (c) struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3117/a/1"},"text":"Pub. L. 117–263, § 3117(a)(1)","children":[],"tail":", struck out subsec. (c). Text read as follows: “In accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3523"},"text":"section 3523 of title 5","children":[],"tail":", the Administrator may offer voluntary separation or retirement incentives to meet the total number of employees authorized under subsection (a).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3117/a/3"},"text":"Pub. L. 117–263, § 3117(a)(3)","children":[],"tail":", (c), redesignated subsec. (b) as (d) and substituted “under subsection (c)” for “under subsection (a)” wherever appearing. Former subsec. (d) redesignated (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3117/a/2"},"text":"Pub. L. 117–263, § 3117(a)(2)","children":[],"tail":", redesignated subsecs. (e) and (f) as (b) and (c), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s3111/a/1/A"},"text":"Pub. L. 116–92, § 3111(a)(1)(A)","children":[],"tail":", (B)(i), substituted “The” for “By "},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"October 1, 2015","children":[],"tail":", the” and “1,890” for “1,690”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s3111/a/1/A"},"text":"Pub. L. 116–92, § 3111(a)(1)(A)","children":[],"tail":", (B)(ii), substituted “2020” for “2016” and “1,890” for “1,690”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s3111/a/2/A"},"text":"Pub. L. 116–92, § 3111(a)(2)(A)","children":[],"tail":", substituted “for the most recent fiscal year for which data are available” for “as of the date of the report” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s3111/a/2/B"},"text":"Pub. L. 116–92, § 3111(a)(2)(B)","children":[],"tail":", added pars. (5) and (6) and struck out former par. (5) which read as follows: “With respect to each contract identified under paragraph (2)—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the cost of the contract; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) identification of the program or program direction accounts that support the contract.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (f)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3116/a/1"},"text":"Pub. L. 113–291, § 3116(a)(1)","children":[],"tail":", substituted “2015” for “2014” and “1,690” for “1,825”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3116/a/2"},"text":"Pub. L. 113–291, § 3116(a)(2)","children":[],"tail":", substituted “2016” for “2015” and “1,690” for “1,825”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3116/b"},"text":"Pub. L. 113–291, § 3116(b)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
