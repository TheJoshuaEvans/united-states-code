{"tag":"section","attrib":{"id":"idd209906d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3938"},"text":null,"children":[{"tag":"num","attrib":{"value":"3938"},"text":"§ 3938.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child custody protection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd209906e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3938/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of temporary custody order based on certain deployments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a court renders a temporary order for custodial responsibility for a child based solely on a deployment or anticipated deployment of a parent who is a servicemember, the court shall require that the temporary order shall expire not later than the period justified by the deployment of the servicemember.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd209906f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3938/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on consideration of member’s deployment in determination of child’s best interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a motion or a petition is filed seeking a permanent order to modify the custody of the child of a servicemember, no court may consider the absence of the servicemember by reason of deployment, or the possibility of deployment, as the sole factor in determining the best interest of the child.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2099070-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3938/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No Federal jurisdiction or right of action or removal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall create a Federal right of action or otherwise give rise to Federal jurisdiction or create a right of removal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2099071-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3938/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case where State law applicable to a child custody proceeding involving a temporary order as contemplated in this section provides a higher standard of protection to the rights of the parent who is a deploying servicemember than the rights provided under this section with respect to such temporary order, the appropriate court shall apply the higher State standard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2099072-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3938/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deployment defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “deployment” means the movement or mobilization of a servicemember to a location for a period of longer than 60 days and not longer than 540 days pursuant to temporary or permanent official orders—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2099073-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3938/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are designated as unaccompanied;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2099074-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3938/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which dependent travel is not authorized; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2099075-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3938/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that otherwise do not permit the movement of family members to that location.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2099076-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title II, § 208, as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tV/s566/a"},"text":"Pub. L. 113–291, div. A, title V, § 566(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3384"},"text":"128 Stat. 3384","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2099077-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2099078-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd2099079-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 528 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
