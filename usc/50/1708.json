{"tag":"section","attrib":{"id":"idd1355088-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708"},"text":null,"children":[{"tag":"num","attrib":{"value":"1708"},"text":"§ 1708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions to address economic or industrial espionage in cyberspace","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1355089-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd135508a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2014-12-19"},"text":"December 19, 2014","children":[],"tail":", and annually thereafter through 2020, the President shall submit to the appropriate congressional committees a report on foreign economic and industrial espionage in cyberspace during the 12-month period preceding the submission of the report that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd135508b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identifies—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd135508c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign countries that engage in economic or industrial espionage in cyberspace with respect to trade secrets or proprietary information owned by United States persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd135508d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign countries identified under clause (i) that the President determines engage in the most egregious economic or industrial espionage in cyberspace with respect to such trade secrets or proprietary information (to be known as “priority foreign countries”);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd135508e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" categories of technologies or proprietary information developed by United States persons that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idd135508f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/a/1/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are targeted for economic or industrial espionage in cyberspace; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd1355090-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/a/1/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, have been appropriated through such espionage;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1355091-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" articles manufactured or otherwise produced using technologies or proprietary information described in clause (iii)(II); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1355092-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/a/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, services provided using such technologies or proprietary information;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1355093-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the economic or industrial espionage engaged in by the foreign countries identified under clauses (i) and (ii) of subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1355094-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1355095-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions taken by the President to decrease the prevalence of economic or industrial espionage in cyberspace; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1355096-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress made in decreasing the prevalence of such espionage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1355097-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of foreign countries engaging in economic or industrial espionage in cyberspace","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of clauses (i) and (ii) of paragraph (1)(A), the President shall identify a foreign country as a foreign country that engages in economic or industrial espionage in cyberspace with respect to trade secrets or proprietary information owned by United States persons if the government of the foreign country—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1355098-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engages in economic or industrial espionage in cyberspace with respect to trade secrets or proprietary information owned by United States persons; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1355099-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" facilitates, supports, fails to prosecute, or otherwise permits such espionage by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd135509a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who are citizens or residents of the foreign country; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd135509b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entities that are organized under the laws of the foreign country or are otherwise subject to the jurisdiction of the government of the foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd135509c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report required by paragraph (1) shall be submitted in unclassified form but may contain a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd135509d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of sanctions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd135509e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may, pursuant to the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" et seq.), block and prohibit all transactions in all property and interests in property of each person described in paragraph (2), if such property and interests in property are in the United States, come within the United States, or are or come within the possession or control of a United States person."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd135509f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons described","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person described in this paragraph is a foreign person the President determines knowingly requests, engages in, supports, facilitates, or benefits from the significant appropriation, through economic or industrial espionage in cyberspace, of technologies or proprietary information developed by United States persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd13550a0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority to impose sanctions under paragraph (1) shall not include the authority to impose sanctions on the importation of goods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd13550a1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation; penalties","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd13550a2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may exercise all authorities provided under sections 203 and 205 of the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1702"},"text":"50 U.S.C. 1702","children":[],"tail":" and 1704) to carry out this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd13550a3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The penalties provided for in subsections (b) and (c) of section 206 of the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1705"},"text":"50 U.S.C. 1705","children":[],"tail":") shall apply to a person that violates, attempts to violate, or conspires to violate, or causes a violation of, this subsection or a regulation prescribed under this subsection to the same extent that such penalties apply to a person that commits an unlawful act described in section 206(a) of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1705/a"},"text":"50 U.S.C. 1705(a)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd13550a4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to affect the application of any penalty or the exercise of any authority provided for under any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd13550a5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd13550a6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd13550a7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services, the Committee on Banking, Housing, and Urban Affairs, the Committee on Commerce, Science, and Transportation, the Committee on Homeland Security and Governmental Affairs, the Committee on Finance, the Committee on Foreign Relations, and the Select Committee on Intelligence of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd13550a8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services, the Committee on Energy and Commerce, the Committee on Homeland Security, the Committee on Financial Services, the Committee on Foreign Affairs, the Committee on Ways and Means, and the Permanent Select Committee on Intelligence of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd13550a9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cyberspace","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “cyberspace”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd13550aa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means the interdependent network of information technology infrastructures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd13550ab-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the Internet, telecommunications networks, computer systems, and embedded processors and controllers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd13550ac-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Economic or industrial espionage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “economic or industrial espionage” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd13550ad-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stealing a trade secret or proprietary information or appropriating, taking, carrying away, or concealing, or by fraud, artifice, or deception obtaining, a trade secret or proprietary information without the authorization of the owner of the trade secret or proprietary information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd13550ae-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" copying, duplicating, downloading, uploading, destroying, transmitting, delivering, sending, communicating, or conveying a trade secret or proprietary information without the authorization of the owner of the trade secret or proprietary information; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd13550af-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly receiving, buying, or possessing a trade secret or proprietary information that has been stolen or appropriated, obtained, or converted without the authorization of the owner of the trade secret or proprietary information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd13550b0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Knowingly","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “knowingly”, with respect to conduct, a circumstance, or a result, means that a person has actual knowledge, or should have known, of the conduct, the circumstance, or the result.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd13550b1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Own","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “own”, with respect to a trade secret or proprietary information, means to hold rightful legal or equitable title to, or license in, the trade secret or proprietary information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd13550b2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means an individual or entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd13550b3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proprietary information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “proprietary information” means competitive bid preparations, negotiating strategies, executive emails, internal financial data, strategic business plans, technical designs, manufacturing processes, source code, data derived from research and development investments, and other commercially valuable information that a person has developed or obtained if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd13550b4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/d/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person has taken reasonable measures to keep the information confidential; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd13550b5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/d/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information is not generally known or readily ascertainable through proper means by the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd13550b6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technology","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “technology” has the meaning given that term in section 16 ","children":[{"tag":"ref","attrib":{"idref":"fn002021"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002021"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Export Administration Act of 1979 ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4618"},"text":"50 U.S.C. 4618","children":[],"tail":") (as in effect pursuant to the International Emergency Economic Powers Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" et seq.))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd13550b7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trade secret","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “trade secret” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1839"},"text":"section 1839 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd13550b8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “United States person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd13550b9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/d/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who is a citizen or resident of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd13550ba-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/d/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity organized under the laws of the United States or any jurisdiction within the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd13550bb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1708/d/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person located in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd13550bc-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tXVI/s1637"},"text":"Pub. L. 113–291, div. A, title XVI, § 1637","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3644"},"text":"128 Stat. 3644","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd13550bd-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd13550be-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd13550bf-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The International Emergency Economic Powers Act, referred to in subsecs. (b)(1) and (d)(8), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/223"},"text":"Pub. L. 95–223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-28"},"text":"Dec. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1626"},"text":"91 Stat. 1626","children":[],"tail":", which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 16 of the Export Administration Act of 1979 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4618"},"text":"50 U.S.C. 4618","children":[],"tail":"), referred to subsec. (d)(8), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVII/s1766/a"},"text":"Pub. L. 115–232, div. A, title XVII, § 1766(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2232"},"text":"132 Stat. 2232","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd13550c0-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Carl Levin and Howard P. “Buck” McKeon National Defense Authorization Act for Fiscal Year 2015, and not as part of the International Emergency Economic Powers Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
