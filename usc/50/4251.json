{"tag":"section","attrib":{"id":"idd21a3145-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4251"},"text":null,"children":[{"tag":"num","attrib":{"value":"4251"},"text":"§ 4251.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of claims","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law or of this chapter, nothing in this chapter shall be construed as recognition of any claim of Mexico or any other country or any Indian tribe (except as expressly provided in this chapter with respect to the Aleut tribe of Alaska) to any territory or other property of the United States, nor shall this chapter be construed as providing any basis for compensation in connection with any such claim.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd21a3146-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/383/tIII/s301"},"text":"Pub. L. 100–383, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-10"},"text":"Aug. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/916"},"text":"102 Stat. 916","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd21a3147-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd21a3148-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd21a3149-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 1989d of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
