{"tag":"section","attrib":{"id":"idd0edbff9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h"},"text":null,"children":[{"tag":"num","attrib":{"value":"98h"},"text":"§ 98h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Defense Stockpile Transaction Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd0edbffa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a separate fund to be known as the National Defense Stockpile Transaction Fund (hereinafter in this section referred to as the “fund”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0edbffb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund operations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0edbffc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All moneys received from the sale of materials in the stockpile under paragraphs (5) and (6) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s98e/a"},"text":"section 98e(a) of this title","children":[],"tail":" "},{"tag":"ref","attrib":{"idref":"fn002003"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002003"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall be covered into the fund."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0edbffd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s98d/a/1"},"text":"section 98d(a)(1) of this title","children":[],"tail":", moneys covered into the fund under paragraph (1) are hereby made available (subject to such limitations as may be provided in appropriation Acts) for the following purposes:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd0edbffe-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The acquisition, maintenance, and disposal of strategic and critical materials under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s98e/a"},"text":"section 98e(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0edbfff-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation, storage, and other incidental expenses related to such acquisition, maintenance, and disposal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0edc000-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development of current specifications of stockpile materials and the upgrading of existing stockpile materials to meet current specifications (including transportation, when economical, related to such upgrading).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0edc001-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Encouraging the appropriate conservation of strategic and critical materials.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0edc002-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Testing and quality studies of stockpile materials.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0edc003-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Studying future material and mobilization requirements for the stockpile.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0edc004-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Activities authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s98h–6"},"text":"section 98h–6 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0edc005-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Contracting under competitive procedures for materials development and research to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd0edc006-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h/b/2/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the quality and availability of materials stockpiled from time to time in the stockpile; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd0edc007-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h/b/2/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop new materials for the stockpile.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0edc008-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improvement or rehabilitation of facilities, structures, and infrastructure needed to maintain the integrity of stockpile materials.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0edc009-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Disposal of hazardous materials that are stored in the stockpile and authorized for disposal by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0edc00a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h/b/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Performance of environmental remediation, restoration, waste management, or compliance activities at locations of the stockpile that are required under a Federal law or are undertaken by the Government under an administrative decision or negotiated agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0edc00b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h/b/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pay of employees of the National Defense Stockpile program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0edc00c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h/b/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other expenses of the National Defense Stockpile program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0edc00d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Moneys in the fund shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0edc00e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Moneys received from sale of materials being rotated or disposed of","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All moneys received from the sale of materials being rotated under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s98e/a/4"},"text":"section 98e(a)(4) of this title","children":[],"tail":" or disposed of under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s98f/a"},"text":"section 98f(a) of this title","children":[],"tail":" shall be covered into the fund and shall be available only for the acquisition of replacement materials."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0edc00f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of bartering","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, during a fiscal year, the National Defense Stockpile Manager barters materials in the stockpile for the purpose of acquiring, upgrading, refining, or processing other materials (or for services directly related to that purpose), the contract value of the materials so bartered shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0edc010-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be applied toward the total value of materials that are authorized to be disposed of from the stockpile during that fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0edc011-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be treated as an acquisition for purposes of satisfying any requirement imposed on the National Defense Stockpile Manager to enter into obligations during that fiscal year under subsection (b)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0edc012-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not increase or decrease the balance in the fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd0edc013-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-06-07/ch190/s9"},"text":"June 7, 1939, ch. 190, § 9","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/41/s2/a"},"text":"Pub. L. 96–41, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-30"},"text":"July 30, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/323"},"text":"93 Stat. 323","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tII/s203/d"},"text":"Pub. L. 97–35, title II, § 203(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/382"},"text":"95 Stat. 382","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dC/tII/s3203/a"},"text":"Pub. L. 99–661, div. C, title II, § 3203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4067"},"text":"100 Stat. 4067","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/180/dC/tII/s3204"},"text":"Pub. L. 100–180, div. C, title II, § 3204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1247"},"text":"101 Stat. 1247","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dC/tXXXIII/s3312/b"},"text":"Pub. L. 101–189, div. C, title XXXIII, § 3312(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1688"},"text":"103 Stat. 1688","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dC/tXXXIII/s3301/c"},"text":"Pub. L. 101–510, div. C, title XXXIII, § 3301(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1845"},"text":"104 Stat. 1845","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dC/tXXXIII/s3311/a"},"text":"Pub. L. 102–190, div. C, title XXXIII, § 3311(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1584"},"text":"105 Stat. 1584","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dC/tXXXIII/s3313"},"text":"Pub. L. 102–484, div. C, title XXXIII, § 3313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2653"},"text":"106 Stat. 2653","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dC/tXXXIII/s3313"},"text":"Pub. L. 103–160, div. C, title XXXIII, § 3313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1962"},"text":"107 Stat. 1962","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dC/tXXXIII/s3304"},"text":"Pub. L. 105–261, div. C, title XXXIII, § 3304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2264"},"text":"112 Stat. 2264","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tXIV/s1411/b"},"text":"Pub. L. 113–66, div. A, title XIV, § 1411(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/934"},"text":"127 Stat. 934","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd0edc014-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd0edc015-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd0edc016-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Paragraphs (5) and (6) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s98e/a"},"text":"section 98e(a) of this title","children":[],"tail":", referred to in subsec. (b)(1), were redesignated as paragraphs (6) and (7) of "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s98e/a"},"text":"section 98e(a) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tXIV/s1411/a"},"text":"Pub. L. 113–66, div. A, title XIV, § 1411(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/934"},"text":"127 Stat. 934","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd0edc017-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 98h, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-06-07/ch190/s9"},"text":"act June 7, 1939, ch. 190, § 9","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1946-07-23/ch590"},"text":"July 23, 1946, ch. 590","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/600"},"text":"60 Stat. 600","children":[],"tail":", related to disposition of receipts, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/96/41/s2/a"},"text":"section 2(a) of Pub. L. 96–41","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s98h/b/1"},"text":"section 98h(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd0edc018-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (b)(2)(D) to (M). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66"},"text":"Pub. L. 113–66","children":[],"tail":" added subpar. (D) and redesignated former subpars. (D) to (L) as (E) to (M), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(2)(J) to (L). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261"},"text":"Pub. L. 105–261","children":[],"tail":" added subpar. (J) and redesignated former subpars. (J) and (K) as (K) and (L), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b)(2)(J), (K). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s3313/a"},"text":"Pub. L. 103–160, § 3313(a)","children":[],"tail":", added subpars. (J) and (K)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s3313/b"},"text":"Pub. L. 103–160, § 3313(b)","children":[],"tail":", struck out par. (4) which read as follows: “Notwithstanding paragraph (2), moneys in the fund may not be used to pay salaries and expenses of stockpile employees.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/s3313/a/1"},"text":"Pub. L. 102–484, § 3313(a)(1)","children":[],"tail":", inserted “, maintenance, and disposal” after “acquisition” and substituted “section 98e(a)” for “section 98e(a)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/s3313/a/2"},"text":"Pub. L. 102–484, § 3313(a)(2)","children":[],"tail":", substituted “such acquisition, maintenance, and disposal” for “such acquisition”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(H), (I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/s3313/b"},"text":"Pub. L. 102–484, § 3313(b)","children":[],"tail":", added subpars. (H) and (I)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/s3313/c"},"text":"Pub. L. 102–484, § 3313(c)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (b)(2)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" added subpar. (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (b)(2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (b)(2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180"},"text":"Pub. L. 100–180","children":[],"tail":" struck out subpar. (F) which related to other reasonable requirements for management of stockpile."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/s3203/a/1"},"text":"Pub. L. 99–661, § 3203(a)(1)","children":[],"tail":", struck out “Such moneys shall remain in the fund until appropriated.” after “covered into the fund.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/s3203/a/2"},"text":"Pub. L. 99–661, § 3203(a)(2)","children":[],"tail":", added pars. (2) and (3) and struck out former pars. (2) and (3) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Moneys covered into the fund under paragraph (1) shall be available, when appropriated therefor, only for the acquisition of strategic and critical materials under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s98e/a/1"},"text":"section 98e(a)(1) of this title","children":[],"tail":" (and for transportation related to such acquisition)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) Moneys in the fund, when appropriated, shall remain available until expended, unless otherwise provided in appropriation Acts.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" in par. (1) struck out provisions relating to moneys remaining in the fund at the end of the third fiscal year following the fiscal year in which received, and in par. (3) substituted provisions respecting funds remaining available until expended, for provisions relating to funds remaining available for a period of five fiscal years."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd0edc019-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd0edc01a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Use of Funds From National Defense Stockpile Transaction Fund To Meet National Defense Stockpile Goals and Specifications in Effect on ","children":[{"tag":"date","attrib":{"date":"1984-10-01"},"text":"October 1, 1984","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/440/tV/s518"},"text":"Pub. L. 100–440, title V, § 518","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-22"},"text":"Sept. 22, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1748"},"text":"102 Stat. 1748","children":[],"tail":", directed that, no later than "},{"tag":"date","attrib":{"date":"1989-10-01"},"text":"Oct. 1, 1989","children":[],"tail":", Administrator of General Services, or any Federal officer assuming Administrator’s responsibilities with respect to management of the stockpile, to use all funds authorized and appropriated before "},{"tag":"date","attrib":{"date":"1985-01-01"},"text":"Jan. 1, 1985","children":[],"tail":", from National Defense Stockpile Transaction Fund to evaluate, test, relocate, upgrade or purchase stockpile materials to meet National Defense Stockpile goals and specifications in effect on "},{"tag":"date","attrib":{"date":"1984-10-01"},"text":"Oct. 1, 1984","children":[],"tail":". Similar provisions were contained in the following prior appropriation acts:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/m/tV/s519"},"text":"Pub. L. 100–202, § 101(m) [title V, § 519]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-390"},"text":"101 Stat. 1329–390","children":[],"tail":", 1329–417."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/m/tV/s520"},"text":"Pub. L. 99–500, § 101(m) [title V, § 520]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-308"},"text":"100 Stat. 1783–308","children":[],"tail":", 1783–326, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/m/tV/s520"},"text":"Pub. L. 99–591, § 101(m) [title V, § 520]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-308"},"text":"100 Stat. 3341–308","children":[],"tail":", 3341–326."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd0edc01b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deposit of Funds Accruing From Naval Petroleum Reserves","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tIX/s905"},"text":"Pub. L. 98–525, title IX, § 905","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2574"},"text":"98 Stat. 2574","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tXVI/s1611/a"},"text":"Pub. L. 99–145, title XVI, § 1611(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/776"},"text":"99 Stat. 776","children":[],"tail":", authorized the deposit into the National Defense Stockpile Transaction Fund, established under this section, of 30 percent of all money accruing to the United States during fiscal years 1985 and 1986 from lands in the naval petroleum and oil shale reserves."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
