{"tag":"section","attrib":{"id":"idd1d5137a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3349"},"text":null,"children":[{"tag":"num","attrib":{"value":"3349"},"text":"§ 3349.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification regarding the authorized public disclosure of national intelligence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1d5137b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3349/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the event of an authorized disclosure of national intelligence or intelligence related to national security to the persons or entities described in subsection (b), the government official responsible for authorizing the disclosure shall submit to the congressional intelligence committees on a timely basis a notification of the disclosure if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d5137c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3349/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at the time of the disclosure—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d5137d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3349/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such intelligence is classified; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d5137e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3349/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is declassified for the purpose of the disclosure; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d5137f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3349/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disclosure will be made by an officer, employee, or contractor of the Executive branch.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d51380-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3349/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons or entities described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The persons or entities described in this subsection are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d51381-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3349/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Media personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d51382-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3349/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person or entity, if the disclosure described in subsection (a) is made with the intent or knowledge that such information will be made publicly available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d51383-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3349/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each notification required under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d51384-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3349/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the specific title and authority of the individual authorizing the disclosure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d51385-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3349/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if applicable, provide the specific title and authority of the individual who authorized the declassification of the intelligence disclosed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d51386-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3349/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the intelligence disclosed, including the classification of the intelligence prior to its disclosure or declassification and the rationale for making the disclosure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d51387-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3349/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The notification requirement in this section does not apply to a disclosure made—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d51388-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3349/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to any statutory requirement, including to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":" (commonly referred to as the “Freedom of Information Act”);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d51389-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3349/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in connection with a civil, criminal, or administrative proceeding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d5138a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3349/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a result of a declassification review process under Executive Order 13526 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s435"},"text":"50 U.S.C. 435","children":[],"tail":" note) [now "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"text":"50 U.S.C. 3161","children":[],"tail":" note] or any successor order; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d5138b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3349/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any officer, employee, or contractor of the Federal government or member of an advisory committee to an element of the intelligence community who possesses an active security clearance and a need to know the specific national intelligence or intelligence related to national security, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003/5"},"text":"section 3003(5) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1d5138c-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/277/tV/s504"},"text":"Pub. L. 112–277, title V, § 504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-14"},"text":"Jan. 14, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2477"},"text":"126 Stat. 2477","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/126/tIII/s328"},"text":"Pub. L. 113–126, title III, § 328","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-07"},"text":"July 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1405"},"text":"128 Stat. 1405","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1d5138d-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1d5138e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1d5138f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/126"},"text":"Pub. L. 113–126","children":[],"tail":" struck out subsec. (e). Text read as follows: “The notification requirements of this section shall cease to be effective for any disclosure described in subsection (a) that occurs on or after the date that is one year after "},{"tag":"date","attrib":{"date":"2013-01-14"},"text":"January 14, 2013","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1d51390-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd1d51391-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/277/s2"},"text":"Pub. L. 112–277, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-14"},"text":"Jan. 14, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2469"},"text":"126 Stat. 2469","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/277/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this Act [see Tables for classification]:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional intelligence committees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘congressional intelligence committees’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Select Committee on Intelligence of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Permanent Select Committee on Intelligence of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Intelligence community","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘intelligence community’ has the meaning given that term in section 3(4) of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s401a/4"},"text":"50 U.S.C. 401a(4)","children":[],"tail":") [now "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003/4"},"text":"50 U.S.C. 3003(4)","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
