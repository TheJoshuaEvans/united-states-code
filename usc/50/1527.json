{"tag":"section","attrib":{"id":"idd10f2a01-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527"},"text":null,"children":[{"tag":"num","attrib":{"value":"1527"},"text":"§ 1527.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improved biosafety for handling of select agents and toxins","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd10f2a02-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quality control and quality assurance program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense, acting through the executive agent for the biological select agent and toxin biosafety program of the Department of Defense, shall carry out a program to implement certain quality control and quality assurance measures at each covered facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd10f2a03-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quality control and quality assurance measures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (c), the quality control and quality assurance measures implemented at each covered facility under subsection (a) shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd10f2a04-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Designation of an external manager to oversee quality assurance and quality control.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd10f2a05-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Environmental sampling and inspection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd10f2a06-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Production procedures that prohibit operations where live biological select agents and toxins are used in the same laboratory where viability testing is conducted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd10f2a07-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Production procedures that prohibit work on multiple organisms or multiple strains of one organism within the same biosafety cabinet.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd10f2a08-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A video surveillance program that uses video monitoring as a tool to improve laboratory practices in accordance with regulatory requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd10f2a09-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Formal, recurring data reviews of production in an effort to identify data trends and nonconformance issues before such issues affect end products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd10f2a0a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Validated protocols for production processes to ensure that process deviations are adequately vetted prior to implementation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd10f2a0b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Maintenance and calibration procedures and schedules for all tools, equipment, and irradiators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd10f2a0c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the program under subsection (a), the Secretary may waive any of the quality control and quality assurance measures required under subsection (b) in the interest of national defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd10f2a0d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and report required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd10f2a0e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall carry out a study to evaluate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd10f2a0f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the feasibility of consolidating covered facilities within a unified command to minimize risk;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd10f2a10-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunities to partner with industry for the production of biological select agents and toxins and related services in lieu of maintaining such capabilities within the Department of the Army; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd10f2a11-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether operations under the biological select agent and toxin production program should be transferred to another government or commercial laboratory that may be better suited to execute production for non-Department of Defense customers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd10f2a12-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2017-02-01"},"text":"February 1, 2017","children":[],"tail":", the Secretary shall submit to the congressional defense committees a report on the results of the study under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd10f2a13-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comptroller General review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2017-09-01"},"text":"September 1, 2017","children":[],"tail":", the Comptroller General of the United States shall submit to the congressional defense committees a report that includes the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd10f2a14-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A review of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd10f2a15-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actions taken by the Department of Defense to address the findings and recommendations of the report of the Department of the Army titled “Individual and Institutional Accountability for the Shipment of Viable Bacillus Anthracis from Dugway Proving Grounds”, dated ","children":[{"tag":"date","attrib":{"date":"2015-12-15"},"text":"December 15, 2015","children":[],"tail":", including any actions taken to address the culture of complacency in the biological select agent and toxin production program identified in such report; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd10f2a16-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress of the Secretary in carrying out the program under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd10f2a17-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An analysis of the study and report under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd10f2a18-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd10f2a19-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “biological select agent and toxin” means any agent or toxin identified under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd10f2a1a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 331.3 of title 7, Code of Federal Regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd10f2a1b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 121.3 or section 121.4 of title 9, Code of Federal Regulations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd10f2a1c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 73.3 or section 73.4 of title 42, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd10f2a1d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1527/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “covered facility” means any facility of the Department of Defense that produces biological select agents and toxins.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd10f2a1e-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tII/s218"},"text":"Pub. L. 114–328, div. A, title II, § 218","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2052"},"text":"130 Stat. 2052","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd10f2a1f-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd10f2a20-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd10f2a21-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Defense Authorization Act for Fiscal Year 2017, and not as part of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/121/tIV/s409"},"text":"Pub. L. 91–121, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-11-19"},"text":"Nov. 19, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/209"},"text":"83 Stat. 209","children":[],"tail":", which comprises this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd10f2a22-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd10f2a23-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Notification of Safety and Security Concerns at Certain Department of Defense Laboratories","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tX/s1089"},"text":"Pub. L. 118–31, div. A, title X, § 1089","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/420"},"text":"137 Stat. 420","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dA/tX/s1089"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall notify the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives] within 7 days after ceasing operations at any Department of Defense laboratory or facility rated at biosafety level–3 or higher for safety or security reasons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The notification required under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reason why operations have ceased at the laboratory or facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether appropriate notification to other Federal agencies has occurred;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the actions taken to determine the root cause of the cessation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the actions taken to restore operations at the laboratory or facility.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd10f2a24-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Congressional Defense Committees” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Congressional defense committees means the Committees on Armed Services and Appropriations of the Senate and the House of Representatives, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s3"},"text":"section 3 of Pub. L. 114–328","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2025"},"text":"130 Stat. 2025","children":[],"tail":". See note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
