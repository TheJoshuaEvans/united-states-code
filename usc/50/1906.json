{"tag":"section","attrib":{"id":"idd152000c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1906"},"text":null,"children":[{"tag":"num","attrib":{"value":"1906"},"text":"§ 1906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd152000d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd152000e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1906/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall submit to the President and to the congressional intelligence committees an annual report of the conduct of the program required by this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd152000f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1906/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The report submitted to the President shall be submitted each year at the time that the President’s budget for the next fiscal year is submitted to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1520010-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1906/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The report submitted to the congressional intelligence committees shall be submitted on the date provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3106"},"text":"section 3106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1520011-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each such report shall contain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1520012-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1906/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the trends within language, international, area, and counterproliferation studies, along with a survey of such areas as the Secretary determines are receiving inadequate attention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1520013-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1906/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect on those trends of activities under the program required by this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1520014-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1906/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the assistance provided under the program for the previous fiscal year, to include the subject areas being addressed and the nature of the assistance provided;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1520015-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1906/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the performance of the individuals who received assistance under the program during the previous fiscal year, to include the degree to which assistance was terminated under the program and the extent to which individual recipients failed to meet their obligations under the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1520016-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1906/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an analysis of the results of the program for the previous fiscal year, and cumulatively, to include, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1520017-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1906/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of individuals who have received assistance under the program who subsequently became employees of the United States Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1520018-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1906/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of individuals who did not subsequently become employees of the United States Government, an analysis of the reasons why they did not become employees and an explanation as to what use, if any, was made of the assistance by those recipients; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1520019-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1906/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the uses made of grants to educational institutions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd152001a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1906/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current list of agencies and offices of the Federal Government required to be developed by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1902/g"},"text":"section 1902(g) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd152001b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1906/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any legislative changes recommended by the Secretary to facilitate the administration of the program or otherwise to enhance its objectives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd152001c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1906/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of initial report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The first report under this section shall be submitted at the time the budget for fiscal year 1994 is submitted to Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd152001d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1906/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the preparation of each report required by subsection (a), the Secretary shall consult with the members of the Board specified in paragraphs (1) through (7) of section 1903(b) ","children":[{"tag":"ref","attrib":{"idref":"fn002041"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002041"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title. Each such member shall submit to the Secretary an assessment of their hiring needs in the areas of language and area studies and a projection of the deficiencies in such areas. The Secretary shall include all assessments in the report required by subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd152001e-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/183/tVIII/s806"},"text":"Pub. L. 102–183, title VIII, § 806","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-04"},"text":"Dec. 4, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1276"},"text":"105 Stat. 1276","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/178/tIII/s311/b/1"},"text":"Pub. L. 103–178, title III, § 311(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2037"},"text":"107 Stat. 2037","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tX/s1078/f/3"},"text":"Pub. L. 104–201, div. A, title X, § 1078(f)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2667"},"text":"110 Stat. 2667","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/272/tIII/s305/a/4"},"text":"Pub. L. 105–272, title III, § 305(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-20"},"text":"Oct. 20, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2401"},"text":"112 Stat. 2401","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/306/tVIII/s811/b/7/A"},"text":"Pub. L. 107–306, title VIII, § 811(b)(7)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2425"},"text":"116 Stat. 2425","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd152001f-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1520020-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1520021-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1903/b"},"text":"Section 1903(b) of this title","children":[],"tail":", referred to in subsec. (d), was amended and now specifies members of the Board in paragraphs (1) to (9)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1520022-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306"},"text":"Pub. L. 107–306","children":[],"tail":" designated first and second sentences as pars. (1) and (2), respectively, in par. (1), substituted “the congressional intelligence committees” for “the Congress”, in par. (2), inserted “submitted to the President” after “The report”, and added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/272"},"text":"Pub. L. 105–272","children":[],"tail":" substituted “area, and counterproliferation” for “and area”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(5) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" struck out “and” at end of par. (5), added par. (6), and redesignated former par. (6) as (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/178"},"text":"Pub. L. 103–178","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
