{"tag":"section","attrib":{"id":"idd1675c48-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2364"},"text":null,"children":[{"tag":"num","attrib":{"value":"2364"},"text":"§ 2364.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase of low-enriched uranium derived from Russian highly enriched uranium","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1675c49-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2364/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that the allies of the United States and other nations should participate in efforts to ensure that stockpiles of weapons-grade nuclear material are reduced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1675c4a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2364/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions by Secretary of State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Congress urges the Secretary of State to encourage, in consultation with the Secretary of Energy, other countries to purchase low-enriched uranium that is derived from highly enriched uranium extracted from Russian nuclear weapons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1675c4b-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXIV/s1454"},"text":"Pub. L. 104–201, div. A, title XIV, § 1454","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2730"},"text":"110 Stat. 2730","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
