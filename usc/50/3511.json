{"tag":"section","attrib":{"id":"idd1e5b491-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3511"},"text":null,"children":[{"tag":"num","attrib":{"value":"3511"},"text":"§ 3511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits available in event of the death of personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1e5b492-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may pay death benefits substantially similar to those authorized for members of the Foreign Service pursuant to the Foreign Service Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"22 U.S.C. 3901","children":[],"tail":" et seq.) or any other provision of law. The Director may adjust the eligibility for death benefits as necessary to meet the unique requirements of the mission of the Agency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1e5b493-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Regulations issued pursuant to this section shall be submitted to the Select Committee on Intelligence of the Senate and the Permanent Select Committee on Intelligence of the House of Representatives before such regulations take effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1e5b494-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-20/ch227/s11"},"text":"June 20, 1949, ch. 227, § 11","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/450/tIV/s403/a"},"text":"Pub. L. 96–450, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1978"},"text":"94 Stat. 1978","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/31/dN/tIV/s411"},"text":"Pub. L. 115–31, div. N, title IV, § 411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/820"},"text":"131 Stat. 820","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1e5b495-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1e5b496-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1e5b497-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Service Act of 1980, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465"},"text":"Pub. L. 96–465","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2071"},"text":"94 Stat. 2071","children":[],"tail":", which is classified principally to chapter 52 (§ 3901 et seq.) of Title 22, Foreign Relations and Intercourse. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"section 3901 of Title 22","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1e5b498-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s403k"},"text":"section 403k of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1e5b499-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31"},"text":"Pub. L. 115–31","children":[],"tail":" amended section generally. Prior to amendment, section related to Director’s authority to pay death gratuities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
