{"tag":"section","attrib":{"id":"idd2130655-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4111"},"text":null,"children":[{"tag":"num","attrib":{"value":"4111"},"text":"§ 4111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to certain members of religious orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In any case in which any money is payable as a result of the enactment of this subchapter to any person who is prevented from accepting such money by the rules, regulations, or customs of the church or the religious order or organization of which he is a member, such money shall be paid, upon the request of such person, to such church or to such religious order or organization.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd2130656-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-07-03/ch826"},"text":"July 3, 1948, ch. 826","children":[],"tail":", title I, § 14, "},{"tag":"ref","attrib":{"href":"/us/stat/62/1247"},"text":"62 Stat. 1247","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/846/tI/s102"},"text":"Pub. L. 87–846, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-22"},"text":"Oct. 22, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1107"},"text":"76 Stat. 1107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2130657-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2130658-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd2130659-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in text, was in the original “this title”, meaning title I of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-07-03/ch826"},"text":"act July 3, 1948, ch. 826","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/1240"},"text":"62 Stat. 1240","children":[],"tail":", which is classified principally to this subchapter. For complete classification of title I to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd213065a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 2013 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd213065b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/846"},"text":"Pub. L. 87–846","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd213065c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idd213065d-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For provisions transferring Foreign Claims Settlement Commission of the United States to Department of Justice, as a separate agency, see section 1622a et seq. of Title 22, Foreign Relations and Intercourse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idd213065e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idd213065f-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"War Claims Commission, including offices of its members, abolished and functions of Commission and of members, officers, and employees thereof transferred to Foreign Claims Settlement Commission of the United States by Reorg. Plan No. 1 of 1954, §§ 2, 4, eff. ","children":[{"tag":"date","attrib":{"date":"1954-07-01"},"text":"July 1, 1954","children":[],"tail":", 19 F.R. 3985, "},{"tag":"ref","attrib":{"href":"/us/stat/68/1279"},"text":"68 Stat. 1279","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees. See, also, "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4101"},"text":"section 4101 of this title","children":[],"tail":" and notes thereunder."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
