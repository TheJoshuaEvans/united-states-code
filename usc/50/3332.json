{"tag":"section","attrib":{"id":"idd1cb9cdd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3332"},"text":null,"children":[{"tag":"num","attrib":{"value":"3332"},"text":"§ 3332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance and reporting requirement regarding the interactions between the intelligence community and entertainment industry","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1cb9cde-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3332/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cb9cdf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3332/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Engagement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “engagement”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1cb9ce0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3332/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means any significant interaction between an element of the intelligence community and an entertainment industry entity for the purposes of contributing to an entertainment product intended to be heard, read, viewed, or otherwise experienced by the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cb9ce1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3332/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include routine inquiries made by the press or news media to the public affairs office of an intelligence community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9ce2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3332/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entertainment industry entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “entertainment industry entity” means an entity that creates, produces, promotes, or distributes a work of entertainment intended to be heard, read, viewed, or otherwise experienced by an audience, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1cb9ce3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3332/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" theater productions, motion pictures, radio broadcasts, television broadcasts, podcasts, webcasts, other sound or visual recording, music, or dance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cb9ce4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3332/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" books and other published material; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cb9ce5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3332/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other entertainment activity, as determined by the Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cb9ce6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3332/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of National Intelligence guidance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cb9ce7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3332/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", the Director of National Intelligence shall issue, and release to the public, guidance regarding engagements by elements of the intelligence community with entertainment industry entities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9ce8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3332/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The guidance required by paragraph (1) shall permit an element of the intelligence community to conduct engagements, if the head of the element, or a designee of such head, provides prior approval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cb9ce9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3332/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information on prior year engagements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the written request of either of the congressional intelligence committees, the Director of National Intelligence shall submit to such committees information with respect to engagements occurring during the calendar year prior to the year during which such request is made. Such information may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cb9cea-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3332/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the nature and duration of each such engagement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9ceb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3332/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost incurred by the United States Government for each such engagement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9cec-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3332/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the benefits to the United States Government for each such engagement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9ced-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3332/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a determination of whether any information was declassified, and whether any classified information was improperly disclosed, for each such engagement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9cee-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3332/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the work produced through each such engagement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1cb9cef-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/dN/tIII/s308"},"text":"Pub. L. 115–31, div. N, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/813"},"text":"131 Stat. 813","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLVII/s5701/d"},"text":"Pub. L. 116–92, div. E, title LVII, § 5701(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2160"},"text":"133 Stat. 2160","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1cb9cf0-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1cb9cf1-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1cb9cf2-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s5701/d/1"},"text":"Pub. L. 116–92, § 5701(d)(1)","children":[],"tail":", struck out subpar. (A) designation before “permit an element”, substituted “shall” for “shall—” and “approval.” for “approval; and”, and struck out subpar. (B) which read as follows: “require an unclassified annual report to the congressional intelligence committees regarding engagements.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s5701/d/2"},"text":"Pub. L. 116–92, § 5701(d)(2)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c) which related to the annual report to the congressional intelligence committees regarding engagements."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1cb9cf3-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd1cb9cf4-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “intelligence community” and “congressional intelligence committees” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/dN/s2"},"text":"section 2 of div. N of Pub. L. 115–31","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
