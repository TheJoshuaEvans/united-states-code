{"tag":"section","attrib":{"id":"idd1c92b77-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3308"},"text":null,"children":[{"tag":"num","attrib":{"value":"3308"},"text":"§ 3308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information access by the Comptroller General of the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1c92b78-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3308/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" DNI directive governing access","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c92b79-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3308/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for directive","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence, in consultation with the Comptroller General of the United States, shall issue a written directive governing the access of the Comptroller General to information in the possession of an element of the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c92b7a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3308/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment to directive","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence, in consultation with the Comptroller General, may issue an amendment to the directive issued under paragraph (1) at any time the Director determines such an amendment is appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c92b7b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3308/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other laws","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The directive issued under paragraph (1) and any amendment to such directive issued under paragraph (2) shall be consistent with the provisions of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c92b7c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3308/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 7 of title 31; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c92b7d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3308/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s401"},"text":"50 U.S.C. 401","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c92b7e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3308/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality of information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c92b7f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3308/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General of the United States shall ensure that the level of confidentiality of information made available to the Comptroller General pursuant to the directive issued under subsection (a)(1) or an amendment to such directive issued under subsection (a)(2) is not less than the level of confidentiality of such information required of the head of the element of the intelligence community from which such information was obtained.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c92b80-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3308/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties for unauthorized disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An officer or employee of the Government Accountability Office shall be subject to the same statutory penalties for unauthorized disclosure or use of such information as an officer or employee of the element of the intelligence community from which such information was obtained.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c92b81-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3308/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c92b82-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3308/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of directive","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The directive issued under subsection (a)(1) shall be submitted to Congress by the Director of National Intelligence, together with any comments of the Comptroller General of the United States, no later than ","children":[{"tag":"date","attrib":{"date":"2011-05-01"},"text":"May 1, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c92b83-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3308/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of amendment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amendment to such directive issued under subsection (a)(2) shall be submitted to Congress by the Director, together with any comments of the Comptroller General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c92b84-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3308/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The directive issued under subsection (a)(1) and any amendment to such directive issued under subsection (a)(2) shall take effect 60 days after the date such directive or amendment is submitted to Congress under subsection (c), unless the Director determines that for reasons of national security the directive or amendment should take effect sooner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1c92b85-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/tIII/s348"},"text":"Pub. L. 111–259, title III, § 348","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2700"},"text":"124 Stat. 2700","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1c92b86-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1c92b87-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1c92b88-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Security Act of 1947, referred to in subsec. (a)(3)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"act July 26, 1947, ch. 343","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/495"},"text":"61 Stat. 495","children":[],"tail":", which is classified principally to chapter 44 (§ 3001 et seq.) of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1c92b89-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s403–9"},"text":"section 403–9 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1c92b8a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd1c92b8b-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “intelligence community”, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s2"},"text":"section 2 of Pub. L. 111–259","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
