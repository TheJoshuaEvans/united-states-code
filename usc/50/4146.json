{"tag":"section","attrib":{"id":"idd2157715-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4146"},"text":null,"children":[{"tag":"num","attrib":{"value":"4146"},"text":"§ 4146.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of records","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of State is authorized and directed to transfer or otherwise make available to the Commission such records and documents relating to claims authorized by this subchapter as may be required by the Commission in carrying out its functions under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd2157716-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-07-03/ch826"},"text":"July 3, 1948, ch. 826","children":[],"tail":", title II, § 216, as added "},{"tag":"ref","attrib":{"href":"/us/pl/87/846/tI/s103"},"text":"Pub. L. 87–846, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-22"},"text":"Oct. 22, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1113"},"text":"76 Stat. 1113","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2157717-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2157718-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd2157719-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 2017","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of the former Appendix to this title prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
