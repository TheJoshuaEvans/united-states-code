{"tag":"section","attrib":{"id":"idd1deafd5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371"},"text":null,"children":[{"tag":"num","attrib":{"value":"3371"},"text":"§ 3371.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required counterintelligence assessments, briefings, notifications, and reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1deafd6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign counterintelligence and cybersecurity threats to Federal election campaigns","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1deafd7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports required","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1deafd8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As provided in subparagraph (B), with respect to an election for Federal office, the Director of National Intelligence, in coordination with the Under Secretary of Homeland Security for Intelligence and Analysis and the Director of the Federal Bureau of Investigation, shall make publicly available on an internet website an advisory report on foreign counterintelligence and cybersecurity threats to campaigns of candidates for Federal office. Each such report, consistent with the protection of sources and methods, shall include the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1deafd9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of foreign counterintelligence and cybersecurity threats to campaigns of candidates for Federal office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1deafda-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A summary of best practices that campaigns of candidates for Federal office can employ in seeking to counter such threats.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1deafdb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An identification of publicly available resources, including United States Government resources, for countering such threats.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1deafdc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schedule for submittal","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1deafdd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided by clause (ii), with respect to an election for Federal office, a report under this subsection shall be first made available not later than the date that is 1 year before the date of such election, and may be subsequently revised as the Director of National Intelligence determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1deafde-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 2020 elections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to an election for Federal office that occurs during 2020, the report under this subsection shall be first made available not later than the date that is 60 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-20"},"text":"December 20, 2020","children":[],"tail":", and may be subsequently revised as the Director of National Intelligence determines appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1deafdf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to be included","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A report under this subsection shall reflect the most current information available to the Director of National Intelligence regarding foreign counterintelligence and cybersecurity threats.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1deafe0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of campaigns subject to heightened threats","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Director of the Federal Bureau of Investigation and the Under Secretary of Homeland Security for Intelligence and Analysis jointly determine that a campaign of a candidate for Federal office is subject to a heightened foreign counterintelligence or cybersecurity threat, the Director and the Under Secretary, consistent with the protection of sources and methods, may make available additional information to the appropriate representatives of such campaign.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1deafe1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1deafe2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of National Intelligence assessment of foreign interference in Federal elections","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1deafe3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessments required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 45 days after the end of a Federal election cycle, the Director of National Intelligence, in consultation with the heads of such other executive departments and agencies as the Director considers appropriate, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1deafe4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct an assessment of any information indicating that a foreign government, or any person acting as an agent of or on behalf of a foreign government, has acted with the intent or purpose of interfering in elections for Federal office occurring during the Federal election cycle; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1deafe5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" transmit the findings of the Director with respect to the assessment conducted under subparagraph (A), along with such supporting information as the Director considers appropriate, to the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1deafe6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1deafe7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1deafe8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1deafe9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/c/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1deafea-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/c/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1deafeb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/c/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1deafec-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/c/1/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1deafed-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An assessment conducted under paragraph (1)(A), with respect to an act described in such paragraph, shall identify, to the maximum extent ascertainable, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1deafee-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The nature of any foreign interference and any methods employed to execute the act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1deafef-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The persons involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1deaff0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The foreign government or governments that authorized, directed, sponsored, or supported the act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1deaff1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall, not later than 60 days after the end of a Federal election cycle, make available to the public, to the greatest extent possible consistent with the protection of sources and methods, the findings transmitted under paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1deaff2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal election cycle defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “Federal election cycle” means the period which begins on the day after the date of a regularly scheduled general election for Federal office and which ends on the date of the first regularly scheduled general election for Federal office held after such date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1deaff3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3371/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall apply with respect to the Federal election cycle that began during November 2018, and each succeeding Federal election cycle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1deaff4-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLIII/s5304"},"text":"Pub. L. 116–92, div. E, title LIII, § 5304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2119"},"text":"133 Stat. 2119","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1deaff5-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1deaff6-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1deaff7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s5304"},"text":"section 5304 of Pub. L. 116–92","children":[],"tail":". Subsec. (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/s5304"},"text":"section 5304 of Pub. L. 116–92","children":[],"tail":" enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3111"},"text":"section 3111 of this title","children":[],"tail":" and amended the analysis for the National Security Act of 1947 ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"50 U.S.C. 3001","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
