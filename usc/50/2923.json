{"tag":"section","attrib":{"id":"idd175b4fa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2923"},"text":null,"children":[{"tag":"num","attrib":{"value":"2923"},"text":"§ 2923.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations for the Department of Energy programs to prevent weapons of mass destruction proliferation and terrorism","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd175b4fb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2923/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b), there are authorized to be appropriated to Department of Energy National Nuclear Security Administration Defense Nuclear Nonproliferation such sums as may be necessary for fiscal year 2008 to accelerate, expand, and strengthen the following programs to prevent weapons of mass destruction (WMD) proliferation and terrorism:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd175b4fc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2923/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Global Threat Reduction Initiative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd175b4fd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2923/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Nonproliferation and International Security program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd175b4fe-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2923/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The International Materials Protection, Control and Accounting program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd175b4ff-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2923/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Nonproliferation and Verification Research and Development program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd175b500-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2923/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The sums appropriated pursuant to subsection (a) may not exceed the amounts authorized to be appropriated by any national defense authorization Act for fiscal year 2008 (whether enacted before or after ","children":[{"tag":"date","attrib":{"date":"2007-08-03"},"text":"August 3, 2007","children":[],"tail":") to Department of Energy National Nuclear Security Administration Defense Nuclear Nonproliferation for such purposes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd175b501-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXVIII/s1833"},"text":"Pub. L. 110–53, title XVIII, § 1833","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/497"},"text":"121 Stat. 497","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
