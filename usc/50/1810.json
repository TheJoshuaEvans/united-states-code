{"tag":"section","attrib":{"id":"idd13eecbd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1810"},"text":null,"children":[{"tag":"num","attrib":{"value":"1810"},"text":"§ 1810.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil liability","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An aggrieved person, other than a foreign power or an agent of a foreign power, as defined in section 1801(a) or (b)(1)(A) of this title, respectively, who has been subjected to an electronic surveillance or about whom information obtained by electronic surveillance of such person has been disclosed or used in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1809"},"text":"section 1809 of this title","children":[],"tail":" shall have a cause of action against any person who committed such violation and shall be entitled to recover—"}],"tail":null},{"tag":"subsection","attrib":{"id":"idd13eecbe-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1810/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" actual damages, but not less than liquidated damages equal to the greater of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd13eecbf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1810/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the aggrieved person is a United States person, $10,000 or $1,000 per day for each day of violation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd13eecc0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1810/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any other aggrieved person, $1,000 or $100 per day for each day of violation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd13eecc1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1810/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" punitive damages; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd13eecc2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1810/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable attorney’s fees and other investigation and litigation costs reasonably incurred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd13eecc3-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511/tI/s110"},"text":"Pub. L. 95–511, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-25"},"text":"Oct. 25, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1796"},"text":"92 Stat. 1796","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/49/s15/a"},"text":"Pub. L. 118–49, § 15(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-20"},"text":"Apr. 20, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/882"},"text":"138 Stat. 882","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd13eecc4-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd13eecc5-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd13eecc6-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/49"},"text":"Pub. L. 118–49","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “actual damages, but not less than liquidated damages of $1,000 or $100 per day for each day of violation, whichever is greater;”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
