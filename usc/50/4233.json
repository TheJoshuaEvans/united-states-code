{"tag":"section","attrib":{"id":"idd217e7f3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4233"},"text":null,"children":[{"tag":"num","attrib":{"value":"4233"},"text":"§ 4233.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aleutian and Pribilof Islands Restitution Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd217e7f4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4233/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States the Aleutian and Pribilof Islands Restitution Fund, which shall be administered by the Secretary. The Fund shall consist of amounts appropriated to it pursuant to this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd217e7f5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4233/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall report to the Congress, not later than 60 days after the end of each fiscal year, on the financial condition of the Fund, and the results of operations of the Fund, during the preceding fiscal year and on the expected financial condition and operations of the Fund during the current fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd217e7f6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4233/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the Fund shall be invested in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s9702"},"text":"section 9702 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd217e7f7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4233/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall terminate the Fund 3 years after ","children":[{"tag":"date","attrib":{"date":"1988-08-10"},"text":"August 10, 1988","children":[],"tail":", or 1 year following disbursement of all payments from the Fund, as authorized by this subchapter, whichever occurs later. On the date the Fund is terminated, all investments of amounts in the Fund shall be liquidated by the Secretary and receipts thereof deposited in the Fund and all funds remaining in the Fund shall be deposited in the miscellaneous receipts account in the Treasury."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd217e7f8-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/383/tII/s203"},"text":"Pub. L. 100–383, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-10"},"text":"Aug. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/911"},"text":"102 Stat. 911","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd217e7f9-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd217e7fa-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd217e7fb-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 1989c–2 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd217e7fc-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd217e7fd-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reestablishment of Fund; Use of Funds","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions that the Fund, if terminated pursuant to subsec. (d) of this section, is to be reestablished upon appropriation of additional funds, and restricting use of appropriated funds, see section 1(b), (c), of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/402"},"text":"Pub. L. 103–402","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4235"},"text":"section 4235 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
