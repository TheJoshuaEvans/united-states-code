{"tag":"section","attrib":{"id":"idd1c6baaa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3239"},"text":null,"children":[{"tag":"num","attrib":{"value":"3239"},"text":"§ 3239.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to buy certain satellite component from American sources","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1c6baab-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3239/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c6baac-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3239/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered element of the intelligence community","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered element of the intelligence community” means an element of the intelligence community that is not an element of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c6baad-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3239/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National security satellite","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “national security satellite” means a satellite weighing over 400 pounds whose principle purpose is to support the national security or intelligence needs of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c6baae-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3239/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States” means the several States, the District of Columbia, and the territories and possessions of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c6baaf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3239/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning ","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":", except as provided in subsection (c), a covered element of the intelligence community may not award a contract for a national security satellite if the satellite uses a star tracker that is not produced in the United States, including with respect to both the software and the hardware of the star tracker."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c6bab0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3239/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of a covered element of the intelligence community may waive the requirement under subsection (b) if, on a case-by-case basis, the head certifies in writing to the congressional intelligence committees that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c6bab1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3239/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is no available star tracker produced in the United States that meets the mission and design requirements of the national security satellite for which the star tracker will be used;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c6bab2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3239/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of a star tracker produced in the United States is unreasonable, based on a market survey; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c6bab3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3239/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such waiver is necessary for the national security interests of the United States based on an urgent and compelling need.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1c6bab4-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title XI, § 1109, as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dW/tIII/s308/a"},"text":"Pub. L. 116–260, div. W, title III, § 308(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2368"},"text":"134 Stat. 2368","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
