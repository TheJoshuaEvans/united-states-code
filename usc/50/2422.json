{"tag":"section","attrib":{"id":"idd16c1783-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2422"},"text":null,"children":[{"tag":"num","attrib":{"value":"2422"},"text":"§ 2422.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Defense Nuclear Security","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd16c1784-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2422/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is within the Administration an Office of Defense Nuclear Security, headed by a Chief appointed by the Secretary of Energy. The Administrator shall recommend to the Secretary suitable candidates for such position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16c1785-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2422/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief of Defense Nuclear Security","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16c1786-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2422/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of the Office of Defense Nuclear Security is the Chief of Defense Nuclear Security, who shall report to the Administrator and shall implement the security policies directed by the Secretary and Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16c1787-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2422/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief shall have direct access to the Secretary and all other officials of the Department and the contractors of the Department concerning security matters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16c1788-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2422/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief shall be responsible for the development and implementation of security programs for the Administration, including the protection, control and accounting of materials, and for the physical security for all facilities of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd16c1789-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dC/tXXXII/s3232"},"text":"Pub. L. 106–65, div. C, title XXXII, § 3232","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/960"},"text":"113 Stat. 960","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dC/tXXXI/s3117/b/1"},"text":"Pub. L. 109–364, div. C, title XXXI, § 3117(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2507"},"text":"120 Stat. 2507","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dC/tXXXI/s3111/2"},"text":"Pub. L. 118–31, div. C, title XXXI, § 3111(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/788"},"text":"137 Stat. 788","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd16c178a-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd16c178b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd16c178c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" struck out “and cyber” after “physical”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s3117/b/1/A"},"text":"Pub. L. 109–364, § 3117(b)(1)(A)","children":[],"tail":", struck out “Office of Defense Nuclear Counterintelligence and” before “Office of Defense Nuclear Security” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s3117/b/1/B"},"text":"Pub. L. 109–364, § 3117(b)(1)(B)","children":[],"tail":", added subsec. (a) and struck out heading and text of former subsec. (a). Text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) There are within the Administration—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) an Office of Defense Nuclear Counterintelligence; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) an Office of Defense Nuclear Security.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Each office established under paragraph (1) shall be headed by a Chief appointed by the Secretary of Energy. The Administrator shall recommend to the Secretary suitable candidates for each such position.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s3117/b/1/C"},"text":"Pub. L. 109–364, § 3117(b)(1)(C)","children":[],"tail":", (D), redesignated subsec. (c) as (b) and struck out former subsec. (b) which related to the Chief of Defense Nuclear Counterintelligence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd16c178d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd16c178e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2000-03-01"},"text":"Mar. 1, 2000","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/s3299"},"text":"section 3299 of Pub. L. 106–65","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2401"},"text":"section 2401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
