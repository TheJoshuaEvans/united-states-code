{"tag":"section","attrib":{"id":"idd249f525-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4814"},"text":null,"children":[{"tag":"num","attrib":{"value":"4814"},"text":"§ 4814.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of export controls","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd249f526-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4814/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall rely on, including through delegations, as appropriate, the Secretary, the Secretary of Defense, the Secretary of State, the Secretary of Energy, the Director of National Intelligence, and the heads of other Federal agencies as appropriate, to exercise the authority to carry out the purposes set forth in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd249f527-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4814/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this section include to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd249f528-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4814/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" advise the President with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd249f529-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4814/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying specific threats to the national security and foreign policy that the authority of this subchapter may be used to address; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd249f52a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4814/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercising the authority under this subchapter to implement policies, regulations, procedures, and actions that are necessary to effectively counteract those threats;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd249f52b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4814/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" review and approve—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd249f52c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4814/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" criteria for including items on, and removing such an item from, a list of controlled items established under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd249f52d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4814/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an interagency procedure for compiling and amending any list described in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd249f52e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4814/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" criteria for including a person on a list of persons to whom exports, reexports, and in-country transfers of items are prohibited or restricted under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd249f52f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4814/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards for compliance by persons subject to controls under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd249f530-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4814/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policies and procedures for the end-use monitoring of exports, reexports, and in-country transfers of items controlled under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd249f531-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4814/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benefit from the inherent equities, experience, and capabilities of the Federal officials described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd249f532-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4814/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that the administration of export controls under this subchapter should be consistent with the procedures relating to export license applications described in Executive Order 12981 (1995).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd249f533-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVII/s1755"},"text":"Pub. L. 115–232, div. A, title XVII, § 1755","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2216"},"text":"132 Stat. 2216","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd249f534-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd249f535-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd249f536-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsecs. (b)(1), (2) and (c), was in the original “this part”, meaning part I (§§ 1751–1768) of subtitle B of title XVII of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":", known as the Export Controls Act of 2018, which is classified principally to this subchapter. For complete classification of part I to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s1751"},"text":"section 1751 of Pub. L. 115–232","children":[],"tail":", set out as a Short Title note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4801"},"text":"section 4801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Executive Order 12981, referred to in subsec. (c), is Ex. Ord. No. 12981, ","children":[{"tag":"date","attrib":{"date":"1995-12-05"},"text":"Dec. 5, 1995","children":[],"tail":", 60 F.R. 62981, which is set out as a note under former "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4603"},"text":"section 4603 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
