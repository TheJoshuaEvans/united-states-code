{"tag":"section","attrib":{"id":"idd20e4ab6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023"},"text":null,"children":[{"tag":"num","attrib":{"value":"4023"},"text":"§ 4023.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Professional liability protection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd20e4ab7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section applies to a servicemember who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20e4ab8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after ","children":[{"tag":"date","attrib":{"date":"1990-07-31"},"text":"July 31, 1990","children":[],"tail":", is ordered to active duty (other than for training) pursuant to sections 688, 12301(a), 12301(g), 12302, 12304, 12306, or 12307 of title 10 or who is ordered to active duty under section 12301(d) of such title during a period when members are on active duty pursuant to any of the preceding sections; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4ab9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" immediately before receiving the order to active duty—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd20e4aba-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was engaged in the furnishing of health-care or legal services or other services determined by the Secretary of Defense to be professional services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd20e4abb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" had in effect a professional liability insurance policy that does not continue to cover claims filed with respect to the servicemember during the period of the servicemember’s active duty unless the premiums are paid for such coverage for such period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4abc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of coverage","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20e4abd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Coverage of a servicemember referred to in subsection (a) by a professional liability insurance policy shall be suspended by the insurance carrier in accordance with this subsection upon receipt of a written request from the servicemember by the insurance carrier.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4abe-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Premiums for suspended contracts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A professional liability insurance carrier—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd20e4abf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not require that premiums be paid by or on behalf of a servicemember for any professional liability insurance coverage suspended pursuant to paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd20e4ac0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall refund any amount paid for coverage for the period of such suspension or, upon the election of such servicemember, apply such amount for the payment of any premium becoming due upon the reinstatement of such coverage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4ac1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonliability of carrier during suspension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A professional liability insurance carrier shall not be liable with respect to any claim that is based on professional conduct (including any failure to take any action in a professional capacity) of a servicemember that occurs during a period of suspension of that servicemember’s professional liability insurance under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4ac2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain claims considered to arise before suspension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of paragraph (3), a claim based upon the failure of a professional to make adequate provision for a patient, client, or other person to receive professional services or other assistance during the period of the professional’s active duty service shall be considered to be based on an action or failure to take action before the beginning of the period of the suspension of professional liability insurance under this subsection, except in a case in which professional services were provided after the date of the beginning of such period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4ac3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reinstatement of coverage","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20e4ac4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reinstatement required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Professional liability insurance coverage suspended in the case of any servicemember pursuant to subsection (b) shall be reinstated by the insurance carrier on the date on which that servicemember transmits to the insurance carrier a written request for reinstatement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4ac5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time and premium for reinstatement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The request of a servicemember for reinstatement shall be effective only if the servicemember transmits the request to the insurance carrier within 30 days after the date on which the servicemember is released from active duty. The insurance carrier shall notify the servicemember of the due date for payment of the premium of such insurance. Such premium shall be paid by the servicemember within 30 days after receipt of that notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4ac6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of reinstated coverage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The period for which professional liability insurance coverage shall be reinstated for a servicemember under this subsection may not be less than the balance of the period for which coverage would have continued under the insurance policy if the coverage had not been suspended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4ac7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase in premium","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20e4ac8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on premium increases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An insurance carrier may not increase the amount of the premium charged for professional liability insurance coverage of any servicemember for the minimum period of the reinstatement of such coverage required under subsection (c)(3) to an amount greater than the amount chargeable for such coverage for such period before the suspension.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4ac9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) does not prevent an increase in premium to the extent of any general increase in the premiums charged by that carrier for the same professional liability coverage for persons similarly covered by such insurance during the period of the suspension.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4aca-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of coverage of unaffected persons","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20e4acb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require a suspension of professional liability insurance protection for any person who is not a person referred to in subsection (a) and who is covered by the same professional liability insurance as a person referred to in such subsection; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4acc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relieve any person of the obligation to pay premiums for the coverage not required to be suspended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4acd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stay of civil or administrative actions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20e4ace-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stay of actions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A civil or administrative action for damages on the basis of the alleged professional negligence or other professional liability of a servicemember whose professional liability insurance coverage has been suspended under subsection (b) shall be stayed until the end of the period of the suspension if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd20e4acf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the action was commenced during the period of the suspension;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd20e4ad0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the action is based on an act or omission that occurred before the date on which the suspension became effective; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd20e4ad1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the suspended professional liability insurance would, except for the suspension, on its face cover the alleged professional negligence or other professional liability negligence or other professional liability of the servicemember.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4ad2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date of commencement of action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever a civil or administrative action for damages is stayed under paragraph (1) in the case of any servicemember, the action shall have been deemed to have been filed on the date on which the professional liability insurance coverage of the servicemember is reinstated under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4ad3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of suspension upon limitations period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a civil or administrative action for which a stay could have been granted under subsection (f) by reason of the suspension of professional liability insurance coverage of the defendant under this section, the period of the suspension of the coverage shall be excluded from the computation of any statutory period of limitation on the commencement of such action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4ad4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Death during period of suspension","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a servicemember whose professional liability insurance coverage is suspended under subsection (b) dies during the period of the suspension—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20e4ad5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirement for the grant or continuance of a stay in any civil or administrative action against such servicemember under subsection (f)(1) shall terminate on the date of the death of such servicemember; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4ad6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the carrier of the professional liability insurance so suspended shall be liable for any claim for damages for professional negligence or other professional liability of the deceased servicemember in the same manner and to the same extent as such carrier would be liable if the servicemember had died while covered by such insurance but before the claim was filed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4ad7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20e4ad8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Active duty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “active duty” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/d/1"},"text":"section 101(d)(1) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4ad9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Profession","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “profession” includes occupation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4ada-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4023/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Professional","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “professional” includes occupational.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd20e4adb-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title VII, § 703, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s1"},"text":"Pub. L. 108–189, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2862"},"text":"117 Stat. 2862","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd20e4adc-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd20e4add-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd20e4ade-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 593 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd20e4adf-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 703 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"act Oct. 17, 1940, ch. 888","children":[],"tail":", art. VII, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/12/s5/b"},"text":"Pub. L. 102–12, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-03-18"},"text":"Mar. 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/37"},"text":"105 Stat. 37","children":[],"tail":", related to reinstatement of health coverage upon release from service, prior to the general amendment of this Act by "},{"tag":"ref","attrib":{"href":"/us/pl/108/189"},"text":"Pub. L. 108–189","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4024"},"text":"section 4024 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd20e4ae0-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd20e4ae1-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any case not final before ","children":[{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s3"},"text":"section 3 of Pub. L. 108–189","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3901"},"text":"section 3901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
