{"tag":"section","attrib":{"id":"idd1f40c5d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3612"},"text":null,"children":[{"tag":"num","attrib":{"value":"3612"},"text":"§ 3612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Funds appropriated to an entity of the Federal Government other than an element of the Department of Defense that have been specifically appropriated for the purchase of cryptologic equipment, materials, or services with respect to which the National Security Agency has been designated as the central source of procurement for the Government shall remain available for a period of three fiscal years.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd1f40c5e-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/36/s14"},"text":"Pub. L. 86–36, § 14","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/89/tVI/s603"},"text":"Pub. L. 97–89, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-04"},"text":"Dec. 4, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1158"},"text":"95 Stat. 1158","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1f40c5f-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1f40c60-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1f40c61-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":