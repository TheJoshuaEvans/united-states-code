{"tag":"section","attrib":{"id":"idd2215e50-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4320"},"text":null,"children":[{"tag":"num","attrib":{"value":"4320"},"text":"§ 4320.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of income, etc., by Alien Property Custodian","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Alien Property Custodian is directed to pay to the person entitled thereto, from and after ","children":[{"tag":"date","attrib":{"date":"1923-03-04"},"text":"March 4, 1923","children":[],"tail":", the net income (including dividends, interest, annuities, and other earnings), accruing and collected thereafter, in respect of any money or property held in trust for such person by the Alien Property Custodian or by the Treasurer of the United States for the account of the Alien Property Custodian, under such rules and regulations as the President may prescribe."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd2215e51-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-10-06/ch106/s23"},"text":"Oct. 6, 1917, ch. 106, § 23","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1923-03-04/ch285/s2"},"text":"Mar. 4, 1923, ch. 285, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/1516"},"text":"42 Stat. 1516","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1928-03-10/ch167/s17"},"text":"Mar. 10, 1928, ch. 167, § 17","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/275"},"text":"45 Stat. 275","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2215e52-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2215e53-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd2215e54-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 23 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd2215e55-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1928—Act ","children":[{"tag":"date","attrib":{"date":"1928-03-10"},"text":"Mar. 10, 1928","children":[],"tail":", struck out restriction that no person be paid any amount over $10,000 per annum."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idd2215e56-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idd2215e57-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions vested by law in Alien Property Custodian and Office of Alien Property Custodian transferred to Attorney General by Reorg. Plan No. 1 of 1947, § 101, eff. ","children":[{"tag":"date","attrib":{"date":"1947-07-01"},"text":"July 1, 1947","children":[],"tail":", 12 F.R. 4534, "},{"tag":"ref","attrib":{"href":"/us/stat/61/951"},"text":"61 Stat. 951","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
