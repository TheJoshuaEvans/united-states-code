{"tag":"section","attrib":{"id":"idd217e803-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4235"},"text":null,"children":[{"tag":"num","attrib":{"value":"4235"},"text":"§ 4235.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation for community losses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd217e804-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4235/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of funds appropriated to the Fund, the Secretary shall make payments from the Fund, in accordance with this section, as restitution for certain Aleut losses sustained in World War II.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd217e805-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4235/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trust","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd217e806-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4235/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, subject to the availability of funds appropriated for this purpose, establish a trust for the purposes set forth in this section. Such trust shall be established pursuant to the laws of the State of Alaska, and shall be maintained and operated by not more than seven trustees, as designated by the Secretary. Each affected Aleut village may submit to the Administrator a list of three prospective trustees. The Secretary, after consultation with the Administrator, affected Aleut villages, and the Corporation, shall designate not more than seven trustees from such lists as submitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e807-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4235/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of trust","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The trust established under this subsection shall be administered in a manner that is consistent with the laws of the State of Alaska, and as prescribed by the Secretary, after consultation with representatives of eligible Aleuts, the residents of affected Aleut villages, and the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd217e808-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4235/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002129"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002129"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Two subsecs. (c) have been enacted."}],"tail":" Accounts for benefit of Aleuts"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd217e809-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4235/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall deposit in the trust such sums as may be appropriated for the purposes set forth in this subsection. The trustees shall maintain and operate 8 independent and separate accounts in the trust for purposes of this subsection, as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd217e80a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4235/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One account for the independent benefit of the wartime Aleut residents of Attu and their descendants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd217e80b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4235/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Six accounts for the benefit of the 6 surviving affected Aleut villages, one each for the independent benefit of Akutan, Atka, Nikolski, Saint George, Saint Paul, and Unalaska, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd217e80c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4235/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One account for the independent benefit of those Aleuts who, as determined by the Secretary, upon the advice of the trustees, are deserving but will not benefit directly from the accounts established under subparagraphs (A) and (B).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The trustees shall credit to the account described in subparagraph (C) an amount equal to 5 percent of the principal amount deposited by the Secretary in the trust under this subsection. Of the remaining principal amount, an amount shall be credited to each account described in subparagraphs (A) and (B) which bears the same proportion to such remaining principal amount as the Aleut civilian population, as of ","children":[{"tag":"date","attrib":{"date":"1942-06-01"},"text":"June 1, 1942","children":[],"tail":", of the village with respect to which such account is established bears to the total civilian Aleut population on such date of all affected Aleut villages."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e80d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4235/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of accounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The trustees may use the principal, accrued interest, and other earnings of the accounts maintained under paragraph (1) for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd217e80e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4235/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the benefit of elderly, disabled, or seriously ill persons on the basis of special need;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd217e80f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4235/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the benefit of students in need of scholarship assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd217e810-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4235/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preservation of Aleut cultural heritage and historical records;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd217e811-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4235/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the improvement of community centers in affected Aleut villages; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd217e812-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4235/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other purposes to improve the condition of Aleut life, as determined by the trustees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e813-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4235/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $5,000,000 to the Fund to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd217e814-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4235/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation for damaged or destroyed church property","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd217e815-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4235/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inventory and assessment of property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall make an inventory and assessment of real and personal church property of affected Aleut villages which was damaged or destroyed during World War II. In making such inventory and assessment, the Administrator shall consult with the trustees of the trust established under subsection (b), residents of affected Aleut villages, affected church members and leaders, and the clergy of the churches involved. Within 1 year after ","children":[{"tag":"date","attrib":{"date":"1988-08-10"},"text":"August 10, 1988","children":[],"tail":", the Administrator shall submit such inventory and assessment, together with an estimate of the present replacement value of lost or destroyed furnishings and artifacts, to the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e816-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4235/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review by the Secretary; deposit in the trust","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall review the inventory and assessment provided under paragraph (1), and shall deposit in the trust established under subsection (b) an amount reasonably calculated by the Secretary to compensate affected Aleut villages for church property lost, damaged, or destroyed during World War II.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e817-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4235/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The trustees shall distribute the amount deposited in the trust under paragraph (2) for the benefit of the churches referred to in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e818-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4235/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Fund $4,700,000 to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd217e819-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4235/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" Administrative and legal expenses"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd217e81a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4235/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement for expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall reimburse the Administrator, not less often than annually, for reasonable and necessary administrative and legal expenses in carrying out the Administrator’s responsibilities under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e81b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4235/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Fund such sums as are necessary to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd217e81c-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/383/tII/s205"},"text":"Pub. L. 100–383, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-10"},"text":"Aug. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/912"},"text":"102 Stat. 912","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/402/s1/a"},"text":"Pub. L. 103–402, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4174"},"text":"108 Stat. 4174","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd217e81d-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd217e81e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd217e81f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 1989c–4 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd217e820-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/402"},"text":"Pub. L. 103–402","children":[],"tail":" substituted “$4,700,000” for “$1,400,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd217e821-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd217e822-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reestablishment of Fund; Use of Funds","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/402/s1/b"},"text":"Pub. L. 103–402, § 1(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4174"},"text":"108 Stat. 4174","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/402/s1/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Fund referred to in section 205(a) of the Aleutian and Pribilof Islands Restitution Act (50 U.S.C. App. 1989c–4(a)) [now ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4235/a"},"text":"50 U.S.C. 4235(a)","children":[],"tail":"] has been terminated pursuant to section 203(d) of such Act (50 U.S.C. App. 1989c–2(d)) [now "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4233/d"},"text":"50 U.S.C. 4233(d)","children":[],"tail":"], upon the appropriation of additional funds pursuant to this Act [amending this section], the Fund shall be reestablished."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The funds appropriated pursuant to this Act shall be used solely for the renovation, replacement, and restoration of church property lost, damaged, or destroyed during World War II.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
