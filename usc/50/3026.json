{"tag":"section","attrib":{"id":"idd18ff37a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3026"},"text":null,"children":[{"tag":"num","attrib":{"value":"3026"},"text":"§ 3026.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deputy Directors of National Intelligence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd18ff37b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3026/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal Deputy Director of National Intelligence","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd18ff37c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3026/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is a Principal Deputy Director of National Intelligence who shall be appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd18ff37d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3026/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the event of a vacancy in the position of Principal Deputy Director of National Intelligence, the Director of National Intelligence shall recommend to the President an individual for appointment as Principal Deputy Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd18ff37e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3026/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any individual nominated for appointment as Principal Deputy Director of National Intelligence shall have extensive national security experience and management expertise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd18ff37f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3026/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The individual serving as Principal Deputy Director of National Intelligence shall not, while so serving, serve in any capacity in any other element of the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd18ff380-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3026/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Principal Deputy Director of National Intelligence shall assist the Director of National Intelligence in carrying out the duties and responsibilities of the Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd18ff381-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3026/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Principal Deputy Director of National Intelligence shall act for, and exercise the powers of, the Director of National Intelligence during the absence or disability of the Director of National Intelligence or during a vacancy in the position of Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd18ff382-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3026/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deputy Directors of National Intelligence","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd18ff383-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3026/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There may be not more than four Deputy Directors of National Intelligence who shall be appointed by the Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd18ff384-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3026/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each Deputy Director of National Intelligence appointed under this subsection shall have such duties, responsibilities, and authorities as the Director of National Intelligence may assign or are specified by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd18ff385-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3026/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military status of Director of National Intelligence and Principal Deputy Director of National Intelligence","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd18ff386-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3026/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than one of the individuals serving in the positions specified in paragraph (2) may be a commissioned officer of the Armed Forces in active status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd18ff387-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3026/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The positions referred to in this paragraph are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd18ff388-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3026/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd18ff389-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3026/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Principal Deputy Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd18ff38a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3026/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It is the sense of Congress that, under ordinary circumstances, it is desirable that one of the individuals serving in the positions specified in paragraph (2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd18ff38b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3026/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a commissioned officer of the Armed Forces, in active status; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd18ff38c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3026/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have, by training or experience, an appreciation of military intelligence activities and requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd18ff38d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3026/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A commissioned officer of the Armed Forces, while serving in a position specified in paragraph (2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd18ff38e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3026/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be subject to supervision or control by the Secretary of Defense or by any officer or employee of the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd18ff38f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3026/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not exercise, by reason of the officer’s status as a commissioned officer, any supervision or control with respect to any of the military or civilian personnel of the Department of Defense except as otherwise authorized by law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd18ff390-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3026/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be counted against the numbers and percentages of commissioned officers of the rank and grade of such officer authorized for the military department of that officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd18ff391-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3026/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subparagraph (A) or (B) of paragraph (4), the appointment of an officer of the Armed Forces to a position specified in paragraph (2) shall not affect the status, position, rank, or grade of such officer in the Armed Forces, or any emolument, perquisite, right, privilege, or benefit incident to or arising out of such status, position, rank, or grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1923c82-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3026/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A commissioned officer of the Armed Forces on active duty who is appointed to a position specified in paragraph (2), while serving in such position and while remaining on active duty, shall continue to receive military pay and allowances and shall not receive the pay prescribed for such position. Funds from which such pay and allowances are paid shall be reimbursed from funds available to the Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1923c83-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title I, § 103A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI/s1011/a"},"text":"Pub. L. 108–458, title I, § 1011(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3656"},"text":"118 Stat. 3656","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1923c84-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1923c85-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1923c86-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s403–3a"},"text":"section 403–3a of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1923c87-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd1923c88-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For Determination by President that section take effect on ","children":[{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", see Memorandum of President of the United States, "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", 70 F.R. 23925, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section effective not later than six months after ","children":[{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1097/a"},"text":"section 1097(a) of Pub. L. 108–458","children":[],"tail":", set out in an Effective Date of 2004 Amendment; Transition Provisions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
