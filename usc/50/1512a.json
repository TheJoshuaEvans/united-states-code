{"tag":"section","attrib":{"id":"idd10a6fbe-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1512a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1512a"},"text":"§ 1512a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation of chemical munitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd10a6fbf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1512a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of transportation across State lines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense may not transport any chemical munition that constitutes part of the chemical weapons stockpile out of the State in which that munition is located on ","children":[{"tag":"date","attrib":{"date":"1994-10-05"},"text":"October 5, 1994","children":[],"tail":", and, in the case of any such chemical munition not located in a State on "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"October 5, 1994","children":[],"tail":", may not transport any such munition into a State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd10a6fc0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1512a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation of chemical munitions not in chemical weapons stockpile","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any chemical munitions that are discovered or otherwise come within the control of the Department of Defense and that do not constitute part of the chemical weapons stockpile, the Secretary of Defense may transport such munitions to the nearest chemical munitions stockpile storage facility that has necessary permits for receiving and storing such items if the transportation of such munitions to that facility—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd10a6fc1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1512a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is considered by the Secretary of Defense to be necessary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd10a6fc2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1512a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can be accomplished while protecting public health and safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd10a6fc3-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tI/s143"},"text":"Pub. L. 103–337, div. A, title I, § 143","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2689"},"text":"108 Stat. 2689","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd10a6fc4-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd10a6fc5-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd10a6fc6-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Defense Authorization Act for Fiscal Year 1995, and not as part of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/121/tIV/s409"},"text":"Pub. L. 91–121, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-11-19"},"text":"Nov. 19, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/209"},"text":"83 Stat. 209","children":[],"tail":", which comprises this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
