{"tag":"section","attrib":{"id":"idd0f75cca-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167e"},"text":null,"children":[{"tag":"num","attrib":{"value":"167e"},"text":"§ 167e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intragovernmental cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense and the Chairman of the Atomic Energy Commission may each designate representatives to cooperate with the Secretary in carrying out the purposes of this chapter, and shall have complete right of access to plants, data, and accounts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd0f75ccb-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1925-03-03/ch426/s7"},"text":"Mar. 3, 1925, ch. 426, § 7","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/86/777/s2"},"text":"Pub. L. 86–777, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-13"},"text":"Sept. 13, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/921"},"text":"74 Stat. 921","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd0f75ccc-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd0f75ccd-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idd0f75cce-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Atomic Energy Commission abolished and functions transferred by sections 5814 and 5841 of Title 42, The Public Health and Welfare. See also Transfer of Functions notes set out under those sections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
