{"tag":"section","attrib":{"id":"idd1c1fffb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3205"},"text":null,"children":[{"tag":"num","attrib":{"value":"3205"},"text":"§ 3205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c1fffc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3205/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “covered element of the intelligence community” means an agency, office, bureau, or element referred to in subparagraphs (B) through (L) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003/4"},"text":"section 3003(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c1fffd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3205/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “educational institution” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c1fffe-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3205/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local educational agency (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c1ffff-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3205/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002"},"text":"section 1002 of title 20","children":[],"tail":", other than institutions referred to in subsection (a)(1)(C) of such section); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c20000-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3205/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other nonprofit institution that provides instruction of foreign languages in languages that are critical to the capability of the intelligence community to carry out national security activities of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c20001-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3205/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “dedicated personnel” means employees of the intelligence community and private citizens (including former civilian employees of the Federal Government who have been voluntarily separated, and members of the United States Armed Forces who have been honorably discharged, honorably separated, or generally discharged under honorable circumstances and rehired on a voluntary basis specifically to perform the activities authorized under this part).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1c20002-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title X, § 1015, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/487/tVI/s612/a/2"},"text":"Pub. L. 108–487, title VI, § 612(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":",