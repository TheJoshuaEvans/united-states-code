{"tag":"section","attrib":{"id":"idd13eecae-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1809"},"text":null,"children":[{"tag":"num","attrib":{"value":"1809"},"text":"§ 1809.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal sanctions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd13eecaf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1809/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person is guilty of an offense if he—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd13eecb0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1809/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intentionally engages in electronic surveillance under color of law except as authorized by this chapter, chapter 119, 121, or 206 of title 18, or any express statutory authorization that is an additional exclusive means for conducting electronic surveillance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1812"},"text":"section 1812 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd13eecb1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1809/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intentionally discloses or uses information obtained under color of law by electronic surveillance, knowing or having reason to know that the information was obtained through electronic surveillance not authorized by this chapter, chapter 119, 121, or 206 of title 18, or any express statutory authorization that is an additional exclusive means for conducting electronic surveillance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1812"},"text":"section 1812 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd13eecb2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1809/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly and willfully communicates, furnishes, transmits, or otherwise makes available to an unauthorized person, or publishes, or uses in any manner prejudicial to the safety or interest of the United States or for the benefit of any foreign government to the detriment of the United States an application, in whole or in part, for an order for electronic surveillance under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd13eecb3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1809/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is a defense to a prosecution under paragraph (1) or (2) of subsection (a) that the defendant was a law enforcement or investigative officer engaged in the course of his official duties and the electronic surveillance was authorized by and conducted pursuant to a search warrant or court order of a court of competent jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd13eecb4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1809/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person guilty of an offense in this section shall be fined under title 18, imprisoned for not more than 10 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd13eecb5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1809/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is Federal jurisdiction over an offense under this section if the person committing the offense was an officer or employee of the United States at the time the offense was committed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd13eecb6-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511/tI/s109"},"text":"Pub. L. 95–511, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-25"},"text":"Oct. 25, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1796"},"text":"92 Stat. 1796","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/261/tI/s102/b"},"text":"Pub. L. 110–261, title I, § 102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-10"},"text":"July 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2459"},"text":"122 Stat. 2459","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/tVIII/s801/3"},"text":"Pub. L. 111–259, title VIII, § 801(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2746"},"text":"124 Stat. 2746","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/49/s13/a"},"text":"Pub. L. 118–49, § 13(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2024-04-20"},"text":"Apr. 20, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/881"},"text":"138 Stat. 881","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd13eecb7-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd13eecb8-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd13eecb9-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511"},"text":"Pub. L. 95–511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-25"},"text":"Oct. 25, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1783"},"text":"92 Stat. 1783","children":[],"tail":", known as the Foreign Intelligence Surveillance Act of 1978, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801"},"text":"section 1801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd13eecba-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/49/s13/a/1/A"},"text":"Pub. L. 118–49, § 13(a)(1)(A)","children":[],"tail":", struck out “intentionally” after “if he” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/49/s13/a/1/B/ii"},"text":"Pub. L. 118–49, § 13(a)(1)(B)(ii)","children":[],"tail":", which directed the substitution of a semicolon for “; or”, could not be executed because the word “or” did not appear."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/49/s13/a/1/B/i"},"text":"Pub. L. 118–49, § 13(a)(1)(B)(i)","children":[],"tail":", inserted “intentionally” before “engages in”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/49/s13/a/1/C/i"},"text":"Pub. L. 118–49, § 13(a)(1)(C)(i)","children":[],"tail":", which directed the substitution of “intentionally discloses” for “disclose”, was executed by making the substitution for “discloses” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/49/s13/a/1/C/ii"},"text":"Pub. L. 118–49, § 13(a)(1)(C)(ii)","children":[],"tail":", (D), added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/49/s13/a/2"},"text":"Pub. L. 118–49, § 13(a)(2)","children":[],"tail":", substituted “under paragraph (1) or (2) of subsection (a)” for “under subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/49/s13/b"},"text":"Pub. L. 118–49, § 13(b)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, text read as follows: “An offense described in this section is punishable by a fine of not more than $10,000 or imprisonment for not more than five years, or both.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s801/3/A"},"text":"Pub. L. 111–259, § 801(3)(A)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1812"},"text":"section 1812 of this title","children":[],"tail":";” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1812"},"text":"section 1812 of this title","children":[],"tail":".;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s801/3/B"},"text":"Pub. L. 111–259, § 801(3)(B)","children":[],"tail":", substituted “title.” for “title..”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/261"},"text":"Pub. L. 110–261","children":[],"tail":" substituted “authorized by this chapter, chapter 119, 121, or 206 of title 18, or any express statutory authorization that is an additional exclusive means for conducting electronic surveillance under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1812"},"text":"section 1812 of this title","children":[],"tail":".” for “authorized by statute” in pars. (1) and (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd13eecbb-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd13eecbc-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/261"},"text":"Pub. L. 110–261","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-07-10"},"text":"July 10, 2008","children":[],"tail":", except as provided in "},{"tag":"ref","attrib":{"href":"/us/pl/110/261/s404"},"text":"section 404 of Pub. L. 110–261","children":[],"tail":", set out as a Transition Procedures note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801"},"text":"section 1801 of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/261/s402"},"text":"section 402 of Pub. L. 110–261","children":[],"tail":", set out as an Effective Date of 2008 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801"},"text":"section 1801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
