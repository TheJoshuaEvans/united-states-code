{"tag":"section","attrib":{"id":"idd16512bc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2352"},"text":null,"children":[{"tag":"num","attrib":{"value":"2352"},"text":"§ 2352.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Security Council Committee on Nonproliferation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd16512bd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2352/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee on Nonproliferation (in this section referred to as the “Committee”) is established as a committee of the National Security Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16512be-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2352/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16512bf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2352/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Committee shall be composed of representatives of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd16512c0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2352/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16512c1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2352/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16512c2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2352/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of Central Intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16512c3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2352/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16512c4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2352/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16512c5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2352/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Federal Emergency Management Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16512c6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2352/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16512c7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2352/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16512c8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2352/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other members as the President may designate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16512c9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2352/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Coordinator for Nonproliferation Matters shall chair the Committee on Nonproliferation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16512ca-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2352/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee has the following responsibilities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16512cb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2352/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To review and coordinate Federal programs, policies, and directives relating to the proliferation of weapons of mass destruction and related materials and technologies, including matters relating to terrorism and international organized crime.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16512cc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2352/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To make recommendations through the National Security Council to the President regarding the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd16512cd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2352/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Integrated national policies for countering the threats posed by weapons of mass destruction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16512ce-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2352/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Options for integrating Federal agency budgets for countering such threats.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16512cf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2352/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Means to ensure that Federal, State, and local governments have adequate capabilities to manage crises involving nuclear, radiological, biological, or chemical weapons or related materials or technologies, and to manage the consequences of a use of such weapon or related materials or technologies, and that use of those capabilities is coordinated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16512d0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2352/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Means to ensure appropriate cooperation on, and coordination of, the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd16512d1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2352/c/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Preventing the smuggling of weapons of mass destruction and related materials and technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd16512d2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2352/c/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promoting domestic and international law enforcement efforts against proliferation-related efforts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd16512d3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2352/c/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Countering the involvement of organized crime groups in proliferation-related activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd16512d4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2352/c/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Safeguarding weapons of mass destruction materials and related technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd16512d5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2352/c/2/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improving coordination and cooperation among intelligence activities, law enforcement, and the Departments of Defense, State, Commerce, and Energy in support of nonproliferation and counterproliferation efforts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd16512d6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2352/c/2/D/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improving export controls over materials and technologies that can contribute to the acquisition of weapons of mass destruction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd16512d7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2352/c/2/D/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reducing proliferation of weapons of mass destruction and related materials and technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd16512d8-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXIV/s1442"},"text":"Pub. L. 104–201, div. A, title XIV, § 1442","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2727"},"text":"110 Stat. 2727","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd16512d9-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd16512da-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idd16512db-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to the Director of Central Intelligence or the Director of the Central Intelligence Agency in the Director’s capacity as the head of the intelligence community deemed to be a reference to the Director of National Intelligence. Reference to the Director of Central Intelligence or the Director of the Central Intelligence Agency in the Director’s capacity as the head of the Central Intelligence Agency deemed to be a reference to the Director of the Central Intelligence Agency. See section 1081(a), (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idd16512dc-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of all functions, personnel, assets, components, authorities, grant programs, and liabilities of the Federal Emergency Management Agency, including the functions of the Under Secretary for Federal Emergency Management relating thereto, to the Federal Emergency Management Agency, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s315/a/1"},"text":"section 315(a)(1) of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions, personnel, assets, and liabilities of the Federal Emergency Management Agency, including the functions of the Director of the Federal Emergency Management Agency relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see former section 313(1) and sections 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
