{"tag":"section","attrib":{"id":"idd0f75ced-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167m"},"text":null,"children":[{"tag":"num","attrib":{"value":"167m"},"text":"§ 167m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd0f75cee-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transparency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Bureau of Land Management, shall make available on the Internet information relating to the Federal Helium System that includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0f75cef-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167m/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continued publication of an open market and in-kind price;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f75cf0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167m/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aggregated projections of excess refining capacity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f75cf1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167m/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ownership of helium held in the Federal Helium Reserve;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f75cf2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167m/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the volume of helium delivered to persons through the Federal Helium Pipeline;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f75cf3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167m/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pressure constraints of the Federal Helium Pipeline;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f75cf4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167m/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the projected date when 3,000,000,000 standard cubic feet of crude helium will remain in the Federal Helium Reserve and the final phase described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s167d/c"},"text":"section 167d(c) of this title","children":[],"tail":" will begin;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f75cf5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167m/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the fees charged under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s167c"},"text":"section 167c of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f75cf6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167m/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the scheduling of crude helium deliveries through the Federal Helium Pipeline; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f75cf7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167m/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other factors that will increase transparency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0f75cf8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2013-10-02"},"text":"October 2, 2013","children":[],"tail":", to provide the market with appropriate and timely information affecting the helium resource, the Director of the Bureau of Land Management shall establish a timely and public reporting process to provide data that affects the helium industry, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0f75cf9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167m/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" annual maintenance schedules and quarterly updates, that shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd0f75cfa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167m/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date and duration of planned shutdowns of the Federal Helium Pipeline;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0f75cfb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167m/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature of work to be undertaken on the Federal Helium System, whether routine, extended, or extraordinary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0f75cfc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167m/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the anticipated impact of the work on the helium supply;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0f75cfd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167m/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efforts being made to minimize any impact on the supply chain; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0f75cfe-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167m/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any concerns regarding maintenance of the Federal Helium Pipeline, including the pressure of the pipeline or deviation from normal operation of the pipeline;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f75cff-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167m/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each unplanned outage, a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd0f75d00-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167m/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the beginning of the outage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0f75d01-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167m/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expected duration of the outage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0f75d02-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167m/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature of the problem;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0f75d03-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167m/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated impact on helium supply;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0f75d04-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167m/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan to correct problems, including an estimate of the potential timeframe for correction and the likelihood of plan success within the timeframe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0f75d05-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167m/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts to minimize negative impacts on the helium supply chain; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0f75d06-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167m/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" updates on repair status and the anticipated online date;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f75d07-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167m/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monthly summaries of meetings and communications between the Bureau of Land Management and the Cliffside Refiners Limited Partnership, including a list of participants and an indication of any actions taken as a result of the meetings or communications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f75d08-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167m/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" current predictions of the lifespan of the Federal Helium System, including how much longer the crude helium supply will be available based on current and forecasted demand and the projected maximum production capacity of the Federal Helium System for the following fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd0f75d09-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1925-03-03/ch426/s15"},"text":"Mar. 3, 1925, ch. 426, § 15","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/40/s6/3"},"text":"Pub. L. 113–40, § 6(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-10-02"},"text":"Oct. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/541"},"text":"127 Stat. 541","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd0f75d0a-47c4-11f1-8bcf-c89722bd