{"tag":"section","attrib":{"id":"idd10343ef-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s854"},"text":null,"children":[{"tag":"num","attrib":{"value":"854"},"text":"§ 854.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules, regulations, and forms","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Attorney General may at any time, make, prescribe, amend, and rescind such rules, regulations and forms as he deems necessary to carry out the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd10343f0-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch849/s5"},"text":"Aug. 1, 1956, ch. 849, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/900"},"text":"70 Stat. 900","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd10343f1-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd10343f2-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd10343f3-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Internal Security Act of 1950 which comprises subchapters I to III of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
