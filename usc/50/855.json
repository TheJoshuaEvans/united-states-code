{"tag":"section","attrib":{"id":"idd10343f4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s855"},"text":null,"children":[{"tag":"num","attrib":{"value":"855"},"text":"§ 855.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations; penalties; deportation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd10343f5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s855/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever willfully violates any provision of this subchapter or any regulation thereunder, or in any registration statement willfully make ","children":[{"tag":"ref","attrib":{"idref":"fn002011"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002011"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “makes”."}],"tail":" a false statement of a material fact or willfully omits any material fact, shall be fined not more than $10,000 or imprisoned for not more than five years, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd10343f6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s855/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any alien convicted of a violation of this subchapter or any regulation thereunder is subject to deportation in the manner provided by chapter 4 of title II of the Immigration and Nationality Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1221"},"text":"8 U.S.C. 1221","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd10343f7-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch849/s6"},"text":"Aug. 1, 1956, ch. 849, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/900"},"text":"70 Stat. 900","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tIII/s308/g/9/B"},"text":"Pub. L. 104–208, div. C, title III, § 308(g)(9)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-624"},"text":"110 Stat. 3009–624","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd10343f8-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd10343f9-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd10343fa-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Immigration and Nationality Act, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"act June 27, 1952, ch. 477","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/163"},"text":"66 Stat. 163","children":[],"tail":". Chapter 4 of title II of the Act is classified generally to part IV (§ 1221 et seq.) of subchapter II of chapter 12 of Title 8, Aliens and Nationality. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of Title 8","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd10343fb-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Internal Security Act of 1950 which comprises subchapters I to III of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd10343fc-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" substituted “chapter 4 of title II of the Immigration and Nationality Act” for “chapter 5, title II, of the Immigration and Nationality Act ("},{"tag":"ref","attrib":{"href":"/us/stat/66/163"},"text":"66 Stat. 163","children":[],"tail":")”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd10343fd-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd10343fe-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" effective, with certain transitional provisions, on the first day of the first month beginning more than 180 days after "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/s309"},"text":"section 309 of Pub. L. 104–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of Title 8","children":[],"tail":", Aliens and Nationality."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
