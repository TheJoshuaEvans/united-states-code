{"tag":"section","attrib":{"id":"idd13eec9e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1808"},"text":null,"children":[{"tag":"num","attrib":{"value":"1808"},"text":"§ 1808.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report of Attorney General to Congressional committees; limitation on authority or responsibility of information gathering activities of Congressional committees; report of Congressional committees to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd13eec9f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1808/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd13eeca0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1808/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On a semiannual basis the Attorney General shall fully inform the Permanent Select Committee on Intelligence and the Committee on the Judiciary of the House of Representatives and the Select Committee on Intelligence and the Committee on the Judiciary of the Senate concerning all electronic surveillance under this subchapter. Nothing in this subchapter shall be deemed to limit the authority and responsibility of the appropriate committees of each House of Congress to obtain such information as they may need to carry out their respective functions and duties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd13eeca1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1808/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each report under the first sentence of paragraph (1) shall include a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd13eeca2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1808/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of applications made for orders and extensions of orders approving electronic surveillance under this subchapter where the nature and location of each facility or place at which the electronic surveillance will be directed is unknown;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd13eeca3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1808/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each criminal case in which information acquired under this chapter has been authorized for use at trial during the period covered by such report;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd13eeca4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1808/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of emergency employments of electronic surveillance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1805/e"},"text":"section 1805(e) of this title","children":[],"tail":" and the total number of subsequent orders approving or denying such electronic surveillance; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd13eeca5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1808/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of authorizations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1805/f"},"text":"section 1805(f) of this title","children":[],"tail":" and the total number of subsequent emergency employments of electronic surveillance under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1805/e"},"text":"section 1805(e) of this title","children":[],"tail":" or emergency physical searches pursuant to section 301(e)."},{"tag":"ref","attrib":{"idref":"fn002029"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002029"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd13eeca6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1808/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On or before one year after ","children":[{"tag":"date","attrib":{"date":"1978-10-25"},"text":"October 25, 1978","children":[],"tail":", and on the same day each year for four years thereafter, the Permanent Select Committee on Intelligence and the Senate Select Committee on Intelligence shall report respectively to the House of Representatives and the Senate, concerning the implementation of this chapter. Said reports shall include but not be limited to an analysis and recommendations concerning whether this chapter should be (1) amended, (2) repealed, or (3) permitted to continue in effect without amendment."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd13eeca7-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511/tI/s108"},"text":"Pub. L. 95–511, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-25"},"text":"Oct. 25, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1795"},"text":"92 Stat. 1795","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/567/tVI/s604/a"},"text":"Pub. L. 106–567, title VI, § 604(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2853"},"text":"114 Stat. 2853","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/tI/s108/c"},"text":"Pub. L. 109–177, title I, § 108(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/204"},"text":"120 Stat. 204","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/261/tI/s105/b"},"text":"Pub. L. 110–261, title I, § 105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-10"},"text":"July 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2462"},"text":"122 Stat. 2462","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/23/tVI/s605/a"},"text":"Pub. L. 114–23, title VI, § 605(a)","children":[],"tail":", title VII, § 701(c), "},{"tag":"date","attrib":{"date":"2015-06-02"},"text":"June 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/297"},"text":"129 Stat. 297","children":[],"tail":", 299.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd13eeca8-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd13eeca9-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd13eecaa-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 301, referred to in subsec. (a)(2)(D), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511/s301"},"text":"section 301 of Pub. L. 95–511","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1821"},"text":"section 1821 of this title","children":[],"tail":", relates to definitions for terms used in subchapter II of this chapter, and does not contain a subsec. (e). "},{"tag":"ref","attrib":{"href":"/us/pl/95/511/s304/e"},"text":"Section 304(e) of Pub. L. 95–511","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1824/e"},"text":"section 1824(e) of this title","children":[],"tail":", relates to authorizations and orders for emergency physical searches."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511"},"text":"Pub. L. 95–511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-25"},"text":"Oct. 25, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1783"},"text":"92 Stat. 1783","children":[],"tail":", known as the Foreign Intelligence Surveillance Act of 1978, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801"},"text":"section 1801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd13eecab-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s605/a"},"text":"Pub. L. 114–23, § 605(a)","children":[],"tail":", substituted “the Permanent Select Committee on Intelligence and the Committee on the Judiciary of the House of Representatives and the Select Committee on Intelligence and the Committee on the Judiciary of the Senate” for “the House Permanent Select Committee on Intelligence and the Senate Select Committee on Intelligence, and the Committee on the Judiciary of the Senate,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s701/c"},"text":"Pub. L. 114–23, § 701(c)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/261"},"text":"Pub. L. 110–261","children":[],"tail":" substituted “1805(e)” for “1805(f)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s108/c/1"},"text":"Pub. L. 109–177, § 108(c)(1)","children":[],"tail":", inserted “, and the Committee on the Judiciary of the Senate,” after “Senate Select Committee on Intelligence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s108/c/2"},"text":"Pub. L. 109–177, § 108(c)(2)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “Each report under the first sentence of paragraph (1) shall include a description of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) each criminal case in which information acquired under this chapter has been passed for law enforcement purposes during the period covered by such report; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) each criminal case in which information acquired under this chapter has been authorized for use at trial during such reporting period.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/567"},"text":"Pub. L. 106–567","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd13eecac-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd13eecad-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/261"},"text":"Pub. L. 110–261","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-07-10"},"text":"July 10, 2008","children":[],"tail":", except as provided in "},{"tag":"ref","attrib":{"href":"/us/pl/110/261/s404"},"text":"section 404 of Pub. L. 110–261","children":[],"tail":", set out as a Transition Procedures note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801"},"text":"section 1801 of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/261/s402"},"text":"section 402 of Pub. L. 110–261","children":[],"tail":", set out as an Effective Date of 2008 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801"},"text":"section 1801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
