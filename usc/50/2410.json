{"tag":"section","attrib":{"id":"idd169ce33-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2410"},"text":null,"children":[{"tag":"num","attrib":{"value":"2410"},"text":"§ 2410.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of Administration and contractor personnel within Department of Energy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd169ce34-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2410/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of Administration personnel","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each officer or employee of the Administration—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd169ce35-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2410/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be responsible to and subject to the authority, direction, and control of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd169ce36-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2410/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary acting through the Administrator and consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7132/c/3"},"text":"section 7132(c)(3) of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd169ce37-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2410/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd169ce38-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2410/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator’s designee within the Administration; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd169ce39-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2410/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be responsible to, or subject to the authority, direction, or control of, any other officer, employee, or agent of the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd169ce3a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2410/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of contractor personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each officer or employee of a contractor of the Administration shall not be responsible to, or subject to the authority, direction, or control of, any officer, employee, or agent of the Department of Energy who is not an employee of the Administration, except for the Secretary of Energy consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7132/c/3"},"text":"section 7132(c)(3) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd169ce3b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2410/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of section","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsections (a) and (b) may not be interpreted to in any way preclude or interfere with the communication of technical findings derived from, and in accord with, duly authorized activities between—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd169ce3c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2410/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head, or any contractor employee, of a national security laboratory or of a nuclear weapons production facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd169ce3d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2410/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Energy, the President, or Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd169ce3e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2410/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on dual office holding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except in accordance with sections 2402(a)(2) and 2406(a)(1) of this title:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd169ce3f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2410/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An individual may not concurrently hold or carry out the responsibilities of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd169ce40-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2410/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position within the Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd169ce41-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2410/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position within the Department of Energy not within the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd169ce42-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2410/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No funds appropriated or otherwise made available for any fiscal year may be used to pay, to an individual who concurrently holds or carries out the responsibilities of a position specified in paragraph (1)(A) and a position specified in paragraph (1)(B), the basic pay, salary, or other compensation relating to any such position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd169ce43-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2410/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of intelligence and counterintelligence personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the restrictions of subsections (a) and (b), each officer or employee of the Administration, or of a contractor of the Administration, who is carrying out activities related to intelligence or counterintelligence shall, in carrying out those activities, be subject to the authority, direction, and control of the Secretary of Energy or the Secretary’s delegate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd169ce44-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dC/tXXXII/s3220"},"text":"Pub. L. 106–65, div. C, title XXXII, § 3220","children":[],"tail":", formerly § 3213, "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/958"},"text":"113 Stat. 958","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXI/s3157"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXI, § 3157]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–468; renumbered § 3220, "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dC/tXXXI/s3141/a/1"},"text":"Pub. L. 107–107, div. C, title XXXI, § 3141(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1370"},"text":"115 Stat. 1370","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dC/tXXXI/s3117/a/2/B"},"text":"Pub. L. 109–364, div. C, title XXXI, § 3117(a)(2)(B)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2507"},"text":"120 Stat. 2507","children":[],"tail":", 2508; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dC/tXXXI/s3121"},"text":"Pub. L. 111–84, div. C, title XXXI, § 3121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2710"},"text":"123 Stat. 2710","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dC/tXXXI/s3145/b"},"text":"Pub. L. 113–66, div. C, title XXXI, § 3145(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/1071"},"text":"127 Stat. 1071","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dC/tXXXI/s3143/a"},"text":"Pub. L. 113–291, div. C, title XXXI, § 3143(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3902"},"text":"128 Stat. 3902","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd169ce45-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd169ce46-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd169ce47-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2403"},"text":"section 2403 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd169ce48-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" substituted “activities between—” for “activities between” before par. (1) designation and “; and” for “, and” at end of par. (1) and realigned margins of pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsecs. (a)(1)(A), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66"},"text":"Pub. L. 113–66","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7132/c/3"},"text":"section 7132(c)(3) of title 42","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/s3117/a"},"text":"Pub. L. 109–364, § 3117(a)","children":[],"tail":". See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s3117/a"},"text":"Pub. L. 109–364, § 3117(a)","children":[],"tail":", which, in par. (2), directed repeal of subsec. (e) effective "},{"tag":"date","attrib":{"date":"2010-09-30"},"text":"Sept. 30, 2010","children":[],"tail":", was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":", and as so amended, no longer contains a par. (2) or amends this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s3117/d"},"text":"Pub. L. 109–364, § 3117(d)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXI/s3157/1"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXI, § 3157(1)]","children":[],"tail":", struck out “Administration, in carrying out any function of the” after “employee of the” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXI/s3157/2"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXI, § 3157(2)]","children":[],"tail":", struck out “, in carrying out any function of the Administration,” after “contractor of the Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXI/s3157/3"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXI, § 3157(3)]","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd16c1739-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd16c173a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2000-03-01"},"text":"Mar. 1, 2000","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/s3299"},"text":"section 3299 of Pub. L. 106–65","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2401"},"text":"section 2401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
