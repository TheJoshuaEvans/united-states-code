{"tag":"section","attrib":{"id":"idd20bdaea-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3993"},"text":null,"children":[{"tag":"num","attrib":{"value":"3993"},"text":"§ 3993.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Desert-land entries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd20bdaeb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3993/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Desert-land rights not forfeited","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A desert-land entry made or held under the desert-land laws before the entrance of the entryman or the entryman’s successor in interest into military service shall not be subject to contest or cancellation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20bdaec-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3993/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for failure to expend any required amount per acre per year in improvements upon the claim;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20bdaed-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3993/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for failure to effect the reclamation of the claim during the period the entryman or the entryman’s successor in interest is in the military service, or for 180 days after termination of or release from military service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20bdaee-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3993/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during any period of hospitalization or rehabilitation due to an injury or disability incurred in the line of duty.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The time within which the entryman or claimant is required to make such expenditures and effect reclamation of the land shall be exclusive of the time periods described in paragraphs (2) and (3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20bdaef-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3993/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service-related disability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an entryman or claimant is honorably discharged and is unable to accomplish reclamation of, and payment for, desert land due to a disability incurred in the line of duty, the entryman or claimant may make proof without further reclamation or payments, under regulations prescribed by the Secretary of the Interior, and receive a patent for the land entered or claimed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20bdaf0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3993/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to obtain the protection of this section, the entryman or claimant shall, within 180 days after entry into military service, cause to be filed in the land office of the district where the claim is situated a notice communicating the fact of military service and the desire to hold the claim under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd20bdaf1-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title V, § 503, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s1"},"text":"Pub. L. 108–189, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2856"},"text":"117 Stat. 2856","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd20bdaf2-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd20bdaf3-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd20bdaf4-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 563 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd20bdaf5-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 503 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"act Oct. 17, 1940, ch. 888","children":[],"tail":", art. V, "},{"tag":"ref","attrib":{"href":"/us/stat/54/1187"},"text":"54 Stat. 1187","children":[],"tail":", related to death or incapacity during or resulting from service as affecting rights and perfection of rights, prior to the general amendment of this Act by "},{"tag":"ref","attrib":{"href":"/us/pl/108/189"},"text":"Pub. L. 108–189","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3996"},"text":"section 3996 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd20bdaf6-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd20bdaf7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any case not final before ","children":[{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s3"},"text":"section 3 of Pub. L. 108–189","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3901"},"text":"section 3901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
