{"tag":"section","attrib":{"id":"idd1deb04a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3372"},"text":null,"children":[{"tag":"num","attrib":{"value":"3372"},"text":"§ 3372.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring mineral investments under Belt and Road Initiative of People’s Republic of China","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1deb04b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3372/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Director of National Intelligence (referred to in this section as the “Director”), in consultation with the Secretary of the Interior, the Secretary of Energy, the Secretary of Commerce, the Secretary of State, the Secretary of Defense, and the United States Trade Representative, shall submit to the appropriate congressional committees a report on investments in minerals under the Belt and Road Initiative of the People’s Republic of China that includes an assessment of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1deb04c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3372/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notable past mineral investments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1deb04d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3372/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether and how such investments have increased the extent of control of minerals by the People’s Republic of China;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1deb04e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3372/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any efforts by the People’s Republic of China to counter or interfere with the goals of the Energy Resource Governance Initiative of the Department of State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1deb04f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3372/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the strategy of the People’s Republic of China with respect to mineral investments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1deb050-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3372/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring mechanism","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conjunction with each report required by subsection (a), the Director shall submit to the appropriate congressional committees a list of any minerals with respect to which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1deb051-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3372/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the People’s Republic of China, directly or through the Belt and Road Initiative—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1deb052-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3372/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is increasing its concentration of extraction and processing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1deb053-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3372/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is acquiring significant mining and processing facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1deb054-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3372/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is maintaining or increasing export restrictions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1deb055-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3372/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has achieved substantial control of the supply of minerals used within an industry or related minerals;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1deb056-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3372/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a significant difference between domestic prices in the People’s Republic of China as compared to prices on international markets; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1deb057-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3372/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a significant increase or volatility in price as a result of the Belt and Road Initiative of the People’s Republic of China.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1deb058-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3372/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Critical mineral evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For any mineral included on the list required by subsection (b) that is not already designated as critical by the Secretary of the Interior pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1606/c"},"text":"section 1606(c) of title 30","children":[],"tail":", the Director shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1deb059-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3372/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine, in consultation with the Secretary of the Interior, the Secretary of Energy, the Secretary of Commerce, the Secretary of State, the Secretary of Defense, and the United States Trade Representative, whether the mineral is strategic and critical to the defense or national security of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1deb05a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3372/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a recommendation to the Secretary of the Interior regarding the designation of the mineral under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1606/c"},"text":"section 1606(c) of title 30","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1deb05b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3372/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall update the report required by subsection (a) and list required by subsection (b) not less frequently than annually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1deb05c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3372/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report or list required by this section shall be submitted in unclassified form but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1deb05d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3372/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1deb05e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3372/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Natural Resources, the Committee on Foreign Relations, the Committee on Armed Services, the Committee on Finance, the Committee on Homeland Security and Governmental Affairs, the Committee on Commerce, Science, and Transportation, and the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1deb05f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3372/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Commerce, the Committee on Foreign Affairs, the Committee on Armed Services, the Committee on Ways and Means, the Committee on Homeland Security, and the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1deb060-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tVII/s7003"},"text":"Pub. L. 116–260, div. Z, title VII, § 7003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2577"},"text":"134 Stat. 2577","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
