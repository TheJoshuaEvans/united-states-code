{"tag":"section","attrib":{"id":"idd15b7572-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2055"},"text":null,"children":[{"tag":"num","attrib":{"value":"2055"},"text":"§ 2055.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory retirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd15b7573-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2055/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Involuntary retirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15b7574-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2055/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director may, in the Director’s discretion, place in a retired status any participant in the system described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15b7575-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2055/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) applies with respect to any participant who has not less than 10 years of service with the Agency and who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd15b7576-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2055/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed at least 25 years of service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd15b7577-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2055/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is at least 50 years of age and has completed at least 20 years of service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15b7578-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2055/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory retirement for age","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15b7579-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2055/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A participant in the system shall be automatically retired from the Agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd15b757a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2055/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon reaching age 65, in the case of a participant in the system who is at the Senior Intelligence Service rank of level 4 or above; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd15b757b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2055/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon reaching age 60, in the case of any other participant in the system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15b757c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2055/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of retirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Retirement under paragraph (1) shall be effective on the last day of the month in which the participant reaches the age applicable to that participant under that paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15b757d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2055/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority for extension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which the Director determines it to be in the public interest, the Director may extend the mandatory retirement date for a participant under this subsection by a period of not to exceed 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15b757e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2055/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retirement benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A participant retired under this section shall receive retirement benefits in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2031"},"text":"section 2031 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd15b757f-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/tII/s235"},"text":"Pub. L. 88–643, t