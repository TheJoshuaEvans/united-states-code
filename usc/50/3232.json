{"tag":"section","attrib":{"id":"idd1c20094-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3232"},"text":null,"children":[{"tag":"num","attrib":{"value":"3232"},"text":"§ 3232.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counterintelligence initiatives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1c20095-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3232/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to protect intelligence sources and methods from unauthorized disclosure, the Director of National Intelligence shall establish and implement an inspection process for all agencies and departments of the United States that handle classified information relating to the national security of the United States intended to assure that those agencies and departments maintain effective operational security practices and programs directed against counterintelligence activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c20096-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3232/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual review of dissemination lists","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence shall establish and implement a process for all elements of the intelligence community to review, on an annual basis, individuals included on distribution lists for access to classified information. Such process shall ensure that only individuals who have a particularized “need to know” (as determined by the Director) are continued on such distribution lists.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c20097-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3232/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Completion of financial disclosure statements required for access to certain classified information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence shall establish and implement a process by which each head of an element of the intelligence community directs that all employees of that element, in order to be granted access to classified information referred to in subsection (a) of section 1.3 of Executive Order No. 12968 (","children":[{"tag":"date","attrib":{"date":"1995-08-02"},"text":"August 2, 1995","children":[],"tail":"; 60 Fed. Reg. 40245; [former] "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s435"},"text":"50 U.S.C. 435","children":[],"tail":" note [now "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"text":"50 U.S.C. 3161","children":[],"tail":" note]), submit financial disclosure forms as required under subsection (b) of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c20098-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3232/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arrangements to handle sensitive information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence shall establish, for all elements of the intelligence community, programs and procedures by which sensitive classified information relating to human intelligence is safeguarded against unauthorized disclosure by employees of those elements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1c20099-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title XI, § 1102, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/177/tIII/s341/a/1"},"text":"Pub. L. 108–177, title III, § 341(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-13"},"text":"Dec. 13, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2615"},"text":"117 Stat. 2615","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI/s1071/a/1/NN"},"text":"Pub. L. 108–458, title I, § 1071(a)(1)(NN)","children":[],"tail":"–(QQ), "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3689"},"text":"118 Stat. 3689","children":[],"tail":", 3690; "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/tIII/s347/e"},"text":"Pub. L. 111–259, title III, § 347(e)","children":[],"tail":", title IV, § 409, "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2699"},"text":"124 Stat. 2699","children":[],"tail":", 2724.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1c2009a-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1c2009b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1c2009c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s442a"},"text":"section 442a of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1c2009d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s409/1"},"text":"Pub. L. 111–259, § 409(1)","children":[],"tail":", struck out par. (1) designation before “In” and par. (2) which read as follows: “The Director shall carry out the process through the Office of the National Counterintelligence Executive.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s347/e"},"text":"Pub. L. 111–259, § 347(e)","children":[],"tail":", struck out par. (1) designation before “The Director” and par. (2) which read as follows: “Not later than October 15 of each year, the Director shall certify to the congressional intelligence committees that the review required under paragraph (1) has been conducted in all elements of the intelligence community during the preceding fiscal year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s409/2"},"text":"Pub. L. 111–259, § 409(2)","children":[],"tail":", struck out par. (1) designation before “The Director” and par. (2) which read as follows: “The Director shall carry out paragraph (1) through the Office of the National Counterintelligence Executive.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1071/a/1/NN"},"text":"Pub. L. 108–458, § 1071(a)(1)(NN)","children":[],"tail":", substituted “Director of National Intelligence” for “Director of Central Intelligence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1071/a/1/OO"},"text":"Pub. L. 108–458, § 1071(a)(1)(OO)","children":[],"tail":", substituted “Director of National Intelligence” for “Director of Central Intelligence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1071/a/1/PP"},"text":"Pub. L. 108–458, § 1071(a)(1)(PP)","children":[],"tail":", substituted “Director of National Intelligence” for “Director of Central Intelligence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1071/a/1/QQ"},"text":"Pub. L. 108–458, § 1071(a)(1)(QQ)","children":[],"tail":", substituted “Director of National Intelligence” for “Director of Central Intelligence”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1c2009e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd1c2009f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For Determination by President that amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" take effect on "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", see Memorandum of President of the United States, "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", 70 F.R. 23925, set out as