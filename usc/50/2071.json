{"tag":"section","attrib":{"id":"idd15b7591-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071"},"text":null,"children":[{"tag":"num","attrib":{"value":"2071"},"text":"§ 2071.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lump-sum payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd15b7592-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entitlement to lump-sum credit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2082/d"},"text":"section 2082(d) of this title","children":[],"tail":" and subsection (b) of this section, a participant who—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15b7593-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is separated from the Agency for at least 31 consecutive days and is not transferred to employment covered by another retirement system for Government employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15b7594-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" files an application with the Director for payment of the lump-sum credit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15b7595-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not reemployed in a position in which the participant is subject to this subchapter at the time the participant files the application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15b7596-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not become eligible to receive an annuity under this subchapter within 31 days after filing the application,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is entitled to be paid the lump-sum credit. Receipt of the payment of the lump-sum credit by the former participant voids all annuity rights under this subchapter based on the service on which the lump-sum credit is based, until the former participant is reemployed in service subject to this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15b7597-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions for payment of lump-sum credit","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15b7598-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever a former participant becomes entitled to receive payment of the lump-sum credit under subsection (a), such lump-sum credit shall be paid to the former participant and to any former spouse or former wife or husband of the former participant in accordance with paragraphs (2) through (4). The former participant’s lump-sum credit shall be reduced by the amount of the lump-sum credit payable to any former spouse or former wife or husband.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15b7599-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pro rata share for former spouse","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Unless otherwise expressly provided by any spousal agreement or court order under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2094/b"},"text":"section 2094(b) of this title","children":[],"tail":", a former spouse of the former participant shall be entitled to receive a share of such participant’s lump-sum credit—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd15b759a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if married to the participant throughout the period of creditable service of the participant, equal to 50 percent of such lump-sum credit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd15b759b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if not married to the participant throughout such creditable service, equal to a proportion of 50 percent of such lump-sum credit which is the proportion that the number of days of the marriage of the former spouse to the participant during periods of creditable service of such participant bears to the total number of days of such creditable service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15b759c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Share for former wife or husband","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Payment of the former participant’s lump-sum credit shall be subject to the terms of a court order under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2094/c"},"text":"section 2094(c) of this title","children":[],"tail":" concerning any former wife or husband of the former participant if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd15b759d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the court order expressly relates to any portion of such lump-sum credit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd15b759e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of the lump-sum credit would extinguish entitlement of such former wife or husband to a survivor annuity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2036"},"text":"section 2036 of this title","children":[],"tail":" or to any portion of the participant’s annuity under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2094/c"},"text":"section 2094(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15b759f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A lump-sum credit may be paid to or for the benefit of a former participant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd15b75a0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only upon written notification to (i) the current spouse, if any, (ii) any former spouse, and (iii) any former wife or husband who has a court order covered by paragraph (3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd15b75a1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only if the express written concurrence of the current spouse has been received by the Director.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"This paragraph may be waived under circumstances described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2031/b/1/D"},"text":"section 2031(b)(1)(D) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15b75a2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Order of precedence of payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A lump-sum payment authorized by subsection (d) or (e) of this section 2121(d) ","children":[{"tag":"ref","attrib":{"idref":"fn002043"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002043"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The words “of this section 2121(d)” probably should be “of this section or by section 2121(d)”."}],"tail":" of this title and a payment of any accrued and unpaid annuity authorized by subsection (f) of this section shall be paid in the following order of precedence to individuals surviving the participant and alive on the date entitlement to the payment arises, upon establishment of a valid claim therefor, and such payment bars recovery by any other individual:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15b75a3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the beneficiary or beneficiaries designated by such participant in a signed and witnessed writing received by the Director before the participant’s death. For this purpose, a designation, change, or cancellation of beneficiary in a will or other document not so executed and filed with the Director shall have no force or effect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15b75a4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If there is no designated beneficiary, to the surviving wife or husband of such participant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15b75a5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If none of the above, to the child or children of such participant and descendent of deceased children by representation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15b75a6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If none of the above, to the parents of such participant or the survivor of them.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15b75a7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If none of the above, to the duly appointed executor or administrator of the estate of such participant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15b75a8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If none of the above, to such other next of kin of such participant as the Director determines to be legally entitled to such payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15b75a9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Death of former participant before retirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15b75aa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), if a former participant eligible for a deferred annuity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2054"},"text":"section 2054 of this title","children":[],"tail":" dies before reaching age 62, such former participant’s lump-sum credit shall be paid in accordance with subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15b75ab-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case where there is a surviving former spouse or surviving former wife or husband of such participant who is entitled to a share of such participant’s lump-sum credit under paragraphs (2) and (3) of subsection (b), the lump-sum credit payable under paragraph (1) shall be reduced by the lump-sum credit payable to such former spouse or former wife or husband.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15b75ac-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of all annuity rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If all annuity rights under this subchapter based on the service of a deceased participant or annuitant terminate before the total annuity paid equals the lump-sum credit, the difference shall be paid in accordance with subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15b75ad-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of accrued and unpaid annuity when retired participant dies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a retired participant dies, any annuity accrued and unpaid shall be paid in accordance with subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15b75ae-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of survivor annuity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An annuity accrued and unpaid on the termination, except by death, of the annuity of a survivor annuitant shall be paid to that individual. An annuity accrued and unpaid on the death of a survivor annuitant shall be paid in the following order of precedence, and the payment bars recovery by any other individual:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15b75af-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the duly appointed executor or administrator of the estate of the survivor annuitant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15b75b0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2071/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If there is no executor or administrator, to such next of kin of the survivor annuitant as the Director determines to be legally entitled to such payment, except that no payment shall be made under this paragraph until after the expiration of 30 days from the date of death of the survivor annuitant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd15b75b1-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/tII/s241"},"text":"Pub. L. 88–643, title II, § 241","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s802"},"text":"Pub. L. 102–496, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3226"},"text":"106 Stat. 3226","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/178/tII/s202/a/11"},"text":"Pub. L. 103–178, title II, § 202(a)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2026"},"text":"107 Stat. 2026","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd15b75b2-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd15b75b3-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd15b75b4-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/s241"},"text":"section 241 of Pub. L. 88–643","children":[],"tail":", title II, "},{"tag":"date","attrib":{"date":"1964-10-13"},"text":"Oct. 13, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1049"},"text":"78 Stat. 1049","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/522/tII/s209"},"text":"Pub. L. 94–522, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-17"},"text":"Oct. 17, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2471"},"text":"90 Stat. 2471","children":[],"tail":"; Ex. Ord. No. 12443, § 5, "},{"tag":"date","attrib":{"date":"1983-09-27"},"text":"Sept. 27, 1983","children":[],"tail":", 48 F.R. 44752; "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/tV/s501/2"},"text":"Pub. L. 99–335, title V, § 501(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/622"},"text":"100 Stat. 622","children":[],"tail":", related to disposition of contributions and interest in excess of benefits received and was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403"},"text":"section 403 of this title","children":[],"tail":" prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/88/643"},"text":"Pub. L. 88–643","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s802"},"text":"section 802 of Pub. L. 102–496","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd15b75b5-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/178/s202/a/11/A"},"text":"Pub. L. 103–178, § 202(a)(11)(A)","children":[],"tail":", substituted “A lump-sum payment authorized by subsection (d) or (e) of this "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2121/d"},"text":"section 2121(d) of this title","children":[],"tail":" and a payment of any accrued and unpaid annuity authorized by subsection (f) of this section” for “A lump-sum benefit that would have been payable to a participant, former participant, or annuitant, or to a survivor annuitant, authorized by subsection (d) or (e) of this section or by section 2054(b) or 2121(d) of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/178/s202/a/11/B"},"text":"Pub. L. 103–178, § 202(a)(11)(B)","children":[],"tail":", added subsec. (f) and redesignated former subsec. (f) as (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd15b75b6-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd15b75b7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/178"},"text":"Pub. L. 103–178","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-02-01"},"text":"Feb. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/178/s202/b"},"text":"section 202(b) of Pub. L. 103–178","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd15b75b8-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of fourth month beginning after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s805"},"text":"section 805 of Pub. L. 102–496","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
