{"tag":"section","attrib":{"id":"idd1ef51f9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3530"},"text":null,"children":[{"tag":"num","attrib":{"value":"3530"},"text":"§ 3530.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of wellness and workforce support","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1ef51fa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3530/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall establish within the Agency an office (in this section referred to as the “Office”) to provide support for the physical health, mental health, and wellbeing of eligible individuals under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ef51fb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3530/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief Wellbeing Officer; assigned staff","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ef51fc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3530/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief Wellbeing Officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of the Office is the Chief Wellbeing Officer, who shall provide to the Director regular updates on the operations of the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ef51fd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3530/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assigned staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To assist in performing the functions under subsection (c), the Director shall assign to the Office a sufficient number of individuals, who shall have no official duties other than duties related to the Office while so assigned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ef51fe-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3530/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Office","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ef51ff-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3530/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall establish the functions and role of the Office, which shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1ef5200-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3530/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Providing to eligible individuals under subsection (d) advice and assistance on health and wellbeing, including with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1ef5201-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3530/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical health and access to physical health care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef5202-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3530/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mental health and access to mental health care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef5203-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3530/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other related programs and benefits for which the individual may be eligible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ef5204-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3530/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In providing advice and assistance to individuals under subparagraph (A), assisting such individuals who are applying for, and navigating the process to obtain, benefits furnished by the United States Government for which the individual is eligible, including, at a minimum—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1ef5205-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3530/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health care and benefits described in such subparagraph; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef5206-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3530/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benefits furnished pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3519b"},"text":"section 3519b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ef5207-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3530/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Maintaining, and making available to eligible individuals under subsection (d), the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1ef5208-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3530/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A list of physicians and mental health care providers (including from the private sector, as applicable), who have experience with the physical and mental health care needs of the Agency workforce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef5209-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3530/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A list of chaplains and religious counselors who have experience with the needs of the Agency workforce, including information regarding access to the Chaplain Corps established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3527"},"text":"section 3527 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef520a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3530/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information regarding how to select and retain private attorneys who have experience with the legal needs of the Agency workforce, including detailed information on the process for the appropriate sharing of information with retained private attorneys.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ef520b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3530/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other functions the Director determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ef520c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3530/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The inclusion of any person on a list maintained or made available pursuant to paragraph (1)(C) shall not be construed as an endorsement of such person (or any service furnished by such person), and the Director shall not be liable, as a result of such inclusion, for any portion of compensable injury, loss, or damage attributable to such person or service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ef520d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3530/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1ef520e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3530/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall ensure that, to the extent permitted by law, the advice and assistance provided by the Office to eligible individuals under subsection (d) is provided in a confidential manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ef520f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3530/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may prescribe regulations regarding the requirement for confidentiality under this paragraph. The Director shall submit to the congressional intelligence committees (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":"), the Subcommittee on Defense of the Committee on Appropriations of the Senate, and the Subcommittee on Defense of the Committee on Appropriations of the House of Representatives any such regulations not later than 30 days after prescribing such regulations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ef5210-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3530/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ef5211-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3530/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual described in paragraph (2) may receive a service under the Office at the election of the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ef5212-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3530/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individuals described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual described in this paragraph is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1ef5213-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3530/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a current or former officer or employee of the Agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ef5214-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3530/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual affiliated with the Agency, as determined by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1ef5215-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-20/ch227/s29"},"text":"June 20, 1949, ch. 227, § 29","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dF/tLXIV/s6416/a"},"text":"Pub. L. 117–263, div. F, title LXIV, § 6416(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3528"},"text":"136 Stat. 3528","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1ef5216-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1ef5217-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1ef5218-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Establishment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dF/tLXIV/s6416/b"},"text":"Pub. L. 117–263, div. F, title LXIV, § 6416(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3530"},"text":"136 Stat. 3530","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dF/tLXIV/s6416/b"},"text":"“The Director of the Central Intelligence Agency shall establish the Office under section 29 of the Central Intelligence Agency Act of 1949 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3530"},"text":"50 U.S.C. 3530","children":[],"tail":"] (as added by subsection (a)) (in this section referred to as the ‘Office’) by not later than 120 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
