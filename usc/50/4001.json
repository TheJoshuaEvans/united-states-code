{"tag":"section","attrib":{"id":"idd20bdb47-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4001"},"text":null,"children":[{"tag":"num","attrib":{"value":"4001"},"text":"§ 4001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Residence for tax purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd20bdb48-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4001/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Residence or domicile","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20bdb49-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4001/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A servicemember shall neither lose nor acquire a residence or domicile for purposes of taxation with respect to the person, personal property, or income of the servicemember by reason of being absent or present in any tax jurisdiction of the United States solely in compliance with military orders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20bdb4a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4001/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spouses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A spouse of a servicemember shall neither lose nor acquire a residence or domicile for purposes of taxation with respect to the person, personal property, or income of the spouse by reason of being absent or present in any tax jurisdiction of the United States solely to be with the servicemember in compliance with the servicemember’s military orders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20bdb4b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4001/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For any taxable year of the marriage, a servicemember and the spouse of such servicemember may elect to use for purposes of taxation, regardless of the date on which the marriage of the servicemember and the spouse occurred, any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd20bdb4c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4001/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The residence or domicile of the servicemember.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd20bdb4d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4001/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The residence or domicile of the spouse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd20bdb4e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4001/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The permanent duty station of the servicemember.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4a4f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4001/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military service compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Compensation of a servicemember for military service shall not be deemed to be income for services performed or from sources within a tax jurisdiction of the United States if the servicemember is not a resident or domiciliary of the jurisdiction in which the servicemember is serving in compliance with military orders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4a50-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4001/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income of a military spouse","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Income for services performed by the spouse of a servicemember shall not be deemed to be income for services performed or from sources within a tax jurisdiction of the United States if the spouse is not a resident or domiciliary of the jurisdiction in which the income is earned because the spouse is in the jurisdiction solely to be with the servicemember serving in compliance with military orders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4a51-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4001/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal property","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20e4a52-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4001/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relief from personal property taxes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The personal property of a servicemember or the spouse of a servicemember shall not be deemed to be located or present in, or to have a situs for taxation in, the tax jurisdiction in which the servicemember is serving in compliance with military orders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4a53-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4001/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for property within member’s domicile or residence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection applies to personal property or its use within any tax jurisdiction other than the servicemember’s or the spouse’s domicile or residence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4a54-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4001/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for property used in trade or business","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section does not prevent taxation by a tax jurisdiction with respect to personal property used in or arising from a trade or business, if it has jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4a55-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4001/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to law of State of domicile","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Eligibility for relief from personal property taxes under this subsection is not contingent on whether or not such taxes are paid to the State of domicile.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4a56-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4001/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase of tax liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A tax jurisdiction may not use the military compensation of a nonresident servicemember to increase the tax liability imposed on other income earned by the nonresident servicemember or spouse subject to tax by the jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4a57-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4001/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Indian reservations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An Indian servicemember whose legal residence or domicile is a Federal Indian reservation shall be taxed by the laws applicable to Federal Indian reservations and not the State where the reservation is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4a58-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4001/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20e4a59-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4001/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “personal property” means intangible and tangible property (including motor vehicles).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4a5a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4001/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “taxation” includes licenses, fees, or excises imposed with respect to motor vehicles and their use, if the license, fee, or excise is paid by the servicemember in the servicemember’s State of domicile or residence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4a5b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4001/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “tax jurisdiction” means a State or a political subdivision of a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd20e4a5c-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title V, § 511, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s1"},"text":"Pub. L. 108–189, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2858"},"text":"117 Stat. 2858","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/97/s3/a"},"text":"Pub. L. 111–97, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-11-11"},"text":"Nov. 11, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/3008"},"text":"123 Stat. 3008","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/407/tIII/s302/a"},"text":"Pub. L. 115–407, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5373"},"text":"132 Stat. 5373","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/333/s18"},"text":"Pub. L. 117–333, § 18","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6137"},"text":"136 Stat. 6137","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd20e4a5d-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd20e4a5e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd20e4a5f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 571 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd20e4a60-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 511 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"act Oct. 17, 1940, ch. 888","children":[],"tail":", art. V, "},{"tag":"ref","attrib":{"href":"/us/stat/54/1189"},"text":"54 Stat. 1189","children":[],"tail":", related to land rights of persons under 21. See "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3998"},"text":"section 3998 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 512 to 514 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"act Oct. 17, 1940, ch. 888","children":[],"tail":", were omitted in the general amendment of this Act by "},{"tag":"ref","attrib":{"href":"/us/pl/108/189"},"text":"Pub. L. 108–189","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 512, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"act Oct. 17, 1940, ch. 888","children":[],"tail":", art. V, "},{"tag":"ref","attrib":{"href":"/us/stat/54/1190"},"text":"54 Stat. 1190","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1942-10-06/ch581/s16"},"text":"Oct. 6, 1942, ch. 581, § 16","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/776"},"text":"56 Stat. 776","children":[],"tail":", related to extension of benefits to persons serving with war allies of the United States. See "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3914"},"text":"section 3914 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 513, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"act Oct. 17, 1940, ch. 888","children":[],"tail":", art. V, "},{"tag":"ref","attrib":{"href":"/us/stat/54/1190"},"text":"54 Stat. 1190","children":[],"tail":", related to deferral of income tax collection and the statute of limitations. See "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4000"},"text":"section 4000 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 514, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"act Oct. 17, 1940, ch. 888","children":[],"tail":", art. V, as added "},{"tag":"ref","attrib":{"href":"/us/act/1942-10-06/ch581/s17"},"text":"Oct. 6, 1942, ch. 581, § 17","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/777"},"text":"56 Stat. 777","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1944-07-03/ch397/s1"},"text":"July 3, 1944, ch. 397, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/722"},"text":"58 Stat. 722","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/771"},"text":"Pub. L. 87–771","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-09"},"text":"Oct. 9, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/768"},"text":"76 Stat. 768","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/12/s9/24"},"text":"Pub. L. 102–12, § 9(24)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-03-18"},"text":"Mar. 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/41"},"text":"105 Stat. 41","children":[],"tail":", related to residence for tax purposes. See "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4001"},"text":"section 4001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd20e4a61-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/333"},"text":"Pub. L. 117–333","children":[],"tail":" added pars. (2) and (3) and struck out former par. (2) which related to residence of spouses of servicemembers for tax purposes."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/407"},"text":"Pub. L. 115–407","children":[],"tail":" designated existing provisions as subpar. (A), inserted heading, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/97/s3/a/1"},"text":"Pub. L. 111–97, § 3(a)(1)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/97/s3/a/3"},"text":"Pub. L. 111–97, § 3(a)(3)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/97/s3/a/2"},"text":"Pub. L. 111–97, § 3(a)(2)","children":[],"tail":", redesignated subsec. (c) as (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/97/s3/a/4/A"},"text":"Pub. L. 111–97, § 3(a)(4)(A)","children":[],"tail":", inserted “or the spouse of a servicemember” after “The personal property of a servicemember”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/97/s3/a/4/B"},"text":"Pub. L. 111–97, § 3(a)(4)(B)","children":[],"tail":", inserted “or the spouse’s” after “servicemember’s”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/97/s3/a/2"},"text":"Pub. L. 111–97, § 3(a)(2)","children":[],"tail":", redesignated subsecs. (d) to (f) as (e) to (g), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd20e4a62-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd20e4a63-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/407/tIII/s302/b"},"text":"Pub. L. 115–407, title III, § 302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5373"},"text":"132 Stat. 5373","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/407/tIII/s302/b"},"text":"“The amendments made by subsection (a) [amending this section] shall apply with respect to any return of State or local income tax filed for any taxable year beginning with the taxable year that includes the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd20e4a64-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/97/s3/b"},"text":"Pub. L. 111–97, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-11-11"},"text":"Nov. 11, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/3008"},"text":"123 Stat. 3008","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/97/s3/b"},"text":"“Subsections (a)(2) and (c) of section 511 of such Act [Servicemembers Civil Relief Act] (50 U.S.C. App. 571) [now ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4001"},"text":"50 U.S.C. 4001","children":[],"tail":"], as added by subsection (a) of this section, and the amendments made to such section 511 by subsection (a)(4) of this section [amending this section], shall apply with respect to any return of State or local income tax filed for any taxable year beginning with the taxable year that includes the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2009-11-11"},"text":"Nov. 11, 2009","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd20e4a65-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any case not final before ","children":[{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s3"},"text":"section 3 of Pub. L. 108–189","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3901"},"text":"section 3901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
