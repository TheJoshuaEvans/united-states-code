],"tail":", title II, "},{"tag":"date","attrib":{"date":"1964-10-13"},"text":"Oct. 13, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1045"},"text":"78 Stat. 1045","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/185/s1"},"text":"Pub. L. 91–185, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/847"},"text":"83 Stat. 847","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/269/tVI/s611"},"text":"Pub. L. 97–269, title VI, § 611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-27"},"text":"Sept. 27, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1153"},"text":"96 Stat. 1153","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/tV"},"text":"Pub. L. 99–335, title V","children":[],"tail":", §§ 501(2), 502, "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/622"},"text":"100 Stat. 622","children":[],"tail":", 623; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", related to compulsory contributions to the fund and was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403"},"text":"section 403 of this title","children":[],"tail":" prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/88/643"},"text":"Pub. L. 88–643","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s802"},"text":"section 802 of Pub. L. 102–496","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd156bb12