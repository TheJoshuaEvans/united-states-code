{"tag":"section","attrib":{"id":"idd156baee-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021"},"text":null,"children":[{"tag":"num","attrib":{"value":"2021"},"text":"§ 2021.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions to fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd156baef-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd156baf0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “revised annuity participant” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd156baf1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" on ","children":[{"tag":"date","attrib":{"date":"2012-12-31"},"text":"December 31, 2012","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{"id":"idd156baf2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not a participant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd156baf3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not performing qualifying service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd156baf4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has less than 5 years of qualifying service; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd156baf5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after ","children":[{"tag":"date","attrib":{"date":"2012-12-31"},"text":"December 31, 2012","children":[],"tail":", becomes a participant performing qualifying service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd156baf6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd156baf7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (d), 7 percent of the basic pay received by a participant other than a revised annuity participant for any pay period shall be deducted and withheld from the pay of that participant and contributed to the fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd156baf8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revised annuity participants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (d), 9.3 percent of the basic pay received by a revised annuity participant for any pay period shall be deducted and withheld from the pay of that revised annuity participant and contributed to the fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd156baf9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency contributions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd156bafa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An amount equal to 7 percent of the basic pay received by a participant other than a revised annuity participant shall be contributed to the fund for a pay period for the participant from the appropriation or fund which is used for payment of the participant’s basic pay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd156bafb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revised annuity participants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An amount equal to 4.7 percent of the basic pay received by a revised annuity participant shall be contributed to the fund for a pay period for the revised annuity participant from the appropriation or fund which is used for payment of the revised annuity participant’s basic pay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd156bafc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits to the fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amounts deducted and withheld from basic pay, together with the amounts so contributed from the appropriation or fund, shall be deposited by the Director to the credit of the fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd156bafd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consent of participant to deductions from pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each participant shall be deemed to consent and agree to such deductions from basic pay, and payment less such deductions shall be a full and complete discharge and acquittance of all claims and demands whatsoever for all regular services during the period covered by such payment, except the right to the benefits to which the participant is entitled under this subchapter, notwithstanding any law, rule, or regulation affecting the individual’s pay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd156bafe-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of contributions after 35 years of service","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd156baff-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accrual of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts deducted and withheld from the basic pay of a participant under this section for pay periods after the first day of the first pay period beginning after the day on which the participant completes 35 years of creditable service computed under sections 2081 and 2082 of this title (excluding service credit for unused sick leave under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2031/a/2"},"text":"section 2031(a)(2) of this title","children":[],"tail":") shall accrue interest. Such interest shall accrue at the rate of 3 percent a year through "},{"tag":"date","attrib":{"date":"1984-12-31"},"text":"December 31, 1984","children":[],"tail":", and thereafter at the rate computed under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8334/e"},"text":"section 8334(e) of title 5","children":[],"tail":", and shall be compounded annually from the date on which the amount is so deducted and withheld until the date of the participant’s retirement or death."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd156bb00-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of amounts withheld after 35 years of service","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd156bb01-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use for deposits due under section 2082(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts described in paragraph (1), including interest accrued on such amounts, shall be applied upon the participant’s retirement or death toward any deposit due under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2082/b"},"text":"section 2082(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd156bb02-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lump-sum payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any balance of such amounts not so required for such a deposit shall be refunded to the participant in a lump sum after the participant’s separation (or, in the event of a death in service, to a beneficiary in order of precedence specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2071/c"},"text":"section 2071(c) of this title","children":[],"tail":"), subject to prior notification of a current spouse, if any, unless the participant establishes to the satisfaction of the Director, in accordance with regulations which the Director may prescribe, that the participant does not know, and has taken all reasonable steps to determine, the whereabouts of the current spouse."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd156bb03-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchases of additional elective benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In lieu of such a lump-sum payment, the participant may use such amounts—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd156bb04-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to purchase an additional annuity in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2121"},"text":"section 2121 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd156bb05-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide any additional survivor benefit for a current or former spouse or spouses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd156bb06-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offset for social security taxes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd156bb07-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons covered","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a participant who was a participant subject to this subchapter before ","children":[{"tag":"date","attrib":{"date":"1984-01-01"},"text":"January 1, 1984","children":[],"tail":", and whose service—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd156bb08-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is employment for the purposes of title II of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s401"},"text":"42 U.S.C. 401","children":[],"tail":" et seq.] and chapter 21 of title 26, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd156bb09-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not creditable service for any purpose under subchapter III of this chapter or chapter 84 of title 5,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"there shall be deducted and withheld from the basic pay of the participant under this section during any pay period only the amount computed under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd156bb0a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction in contribution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount deducted and withheld from the basic pay of a participant during any pay period pursuant to paragraph (1) shall be the excess of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd156bb0b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount determined by multiplying the percent applicable to the participant under subsection (a) by the basic pay payable to the participant for that pay period, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd156bb0c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2021/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the taxes deducted and withheld from such basic pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s3101/a"},"text":"section 3101(a) of title 26","children":[],"tail":" (relating to old-age, survivors, and disability insurance) for that pay period."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd156bb0d-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/tII/s211"},"text":"Pub. L. 88–643, title II, § 211","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s802"},"text":"Pub. L. 102–496, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3202"},"text":"106 Stat. 3202","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/178/tII/s202/a/3"},"text":"Pub. L. 103–178, title II, § 202(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2026"},"text":"107 Stat. 2026","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/96/tV/s5003"},"text":"Pub. L. 112–96, title V, § 5003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/200"},"text":"126 Stat. 200","children":[],"tail":"; "},{