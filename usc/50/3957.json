{"tag":"section","attrib":{"id":"idd20bda35-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3957"},"text":null,"children":[{"tag":"num","attrib":{"value":"3957"},"text":"§ 3957.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of life insurance policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd20bda36-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3957/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment of policy protected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a life insurance policy on the life of a servicemember is assigned before military service to secure the payment of an obligation, the assignee of the policy (except the insurer in connection with a policy loan) may not exercise, during a period of military service of the servicemember or within one year thereafter, any right or option obtained under the assignment without a court order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20bda37-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3957/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The prohibition in subsection (a) shall not apply—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20bda38-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3957/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the assignee has the written consent of the insured made during the period described in subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20bda39-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3957/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when the premiums on the policy are due and unpaid; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20bda3a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3957/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon the death of the insured.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20bda3b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3957/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Order refused because of material affect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A court which receives an application for an order required under subsection (a) may refuse to grant such order if the court determines the ability of the servicemember to comply with the terms of the obligation is materially affected by military service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20bda3c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3957/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of guaranteed premiums","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, premiums guaranteed under the provisions of subchapter IV of this chapter shall not be considered due and unpaid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20bda3d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3957/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Misdemeanor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person who knowingly takes an action contrary to this section, or attempts to do so, shall be fined as provided in title 18, or imprisoned for not more than one year, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd20bda3e-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title III, § 306, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s1"},"text":"Pub. L. 108–189, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2850"},"text":"117 Stat. 2850","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/275/tIII/s303/b/6"},"text":"Pub. L. 111–275, title III, § 303(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-13"},"text":"Oct. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2878"},"text":"124 Stat. 2878","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd20bda3f-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd20bda40-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd20bda41-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"chil