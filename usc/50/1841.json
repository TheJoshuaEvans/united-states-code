{"tag":"section","attrib":{"id":"idd143a7c1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1841"},"text":null,"children":[{"tag":"num","attrib":{"value":"1841"},"text":"§ 1841.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd143a7c2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1841/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “foreign power”, “agent of a foreign power”, “international terrorism”, “foreign intelligence information”, “Attorney General”, “United States person”, “United States”, “person”, and “State” shall have the same meanings as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801"},"text":"section 1801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd143a7c3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1841/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “pen register” and “trap and trace device” have the meanings given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3127"},"text":"section 3127 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd143a7c4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1841/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “aggrieved person” means any person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd143a7c5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1841/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose telephone line was subject to the installation or use of a pen register or trap and trace device authorized by this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd143a7c6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1841/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose communication instrument or device was subject to the use of a pen register or trap and trace device authorized by this subchapter to capture incoming electronic or other communications impulses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd143a7c7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1841/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd143a7c8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1841/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “specific selection term”—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd143a7c9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1841/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a term that specifically identifies a person, account, address, or personal device, or any other specific identifier; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd143a7ca-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1841/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is used to limit, to the greatest extent reasonably practicable, the scope of information sought, consistent with the purpose for seeking the use of the pen register or trap and trace device.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd143a7cb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1841/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A specific selection term under subparagraph (A) does not include an identifier that does not limit, to the greatest extent reasonably practicable, the scope of information sought, consistent with the purpose for seeking the use of the pen register or trap and trace device, such as an identifier that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd143a7cc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1841/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies an electronic communication service provider (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1881"},"text":"section 1881 of this title","children":[],"tail":") or a provider of remote computing service (as that term is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2711"},"text":"section 2711 of title 18","children":[],"tail":"), when not used as part of a specific identifier as described in subparagraph (A), unless the provider is itself a subject of an authorized investigation for which the specific selection term is used as the basis for the use; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd143a7cd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1841/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies a broad geographic region, including the United States, a city, a county, a State, a zip code, or an area code, when not used as part of a specific identifier as described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd143a7ce-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1841/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of subparagraph (A), the term “address” means a physical address or electronic address, such as an electronic mail address or temporarily assigned network address (including an Internet protocol address).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd143a7cf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1841/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this paragraph shall be construed to preclude the use of multiple terms or identifiers to meet the requirements of subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd143a7d0-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511/tIV/s401"},"text":"Pub. L. 95–511, title IV, § 401","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/272/tVI/s601/2"},"text":"Pub. L. 105–272, title VI, § 601(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-20"},"text":"Oct. 20, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2404"},"text":"112 Stat. 2404","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/23/tII/s201/b"},"text":"Pub. L. 114–23, title II, § 201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-02"},"text":"June 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/277"},"text":"129 Stat. 277","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd143a7d1-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd143a7d2-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd143a7d3-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511/s401"},"text":"section 401 of Pub. L. 95–511","children":[],"tail":" was renumbered section 701 and was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801"},"text":"section 1801 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/110/261"},"text":"Pub. L. 110–261","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd143a7d4-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23"},"text":"Pub. L. 114–23","children":[],"tail":" added par. (4)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
