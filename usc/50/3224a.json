{"tag":"section","attrib":{"id":"idd1c20060-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3224a"},"text":"§ 3224a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of support by Director of National Intelligence for certain workforce activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1c20061-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may, with or without reimbursement, obligate or expend amounts authorized to be appropriated or otherwise made available for the Office of the Director of National Intelligence for covered workforce activities for the purpose of supporting a covered workforce activity of an element of the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c20062-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the date on which the Director exercises the authority in subsection (a), the Director shall submit to the congressional intelligence committees and the Committees on Appropriations of the House of Representatives and the Senate written notification of such exercise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c20063-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered workforce activity defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered workforce activity” means an activity relating to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c20064-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruitment or retention of the intelligence community workforce; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c20065-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" diversity, equality, inclusion, or accessibility, with respect to such workforce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1c20066-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title X, § 1025, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dX/tIII/s304"},"text":"Pub. L. 117–103, div. X, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/965"},"text":"136 Stat. 965","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
