{"tag":"section","attrib":{"id":"idd1996926-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3044"},"text":null,"children":[{"tag":"num","attrib":{"value":"3044"},"text":"§ 3044.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Software licensing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1996927-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3044/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for inventories of software licenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The chief information officer of each element of the intelligence community, in consultation with the Chief Information Officer of the Intelligence Community, shall biennially—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1996928-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3044/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct an inventory of all existing software licenses of such element, including utilized and unutilized licenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1996929-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3044/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assess the actions that could be carried out by such element to achieve the greatest possible economies of scale and associated cost savings in software procurement and usage, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd199692a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3044/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the centralization of the management of software licenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd199692b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3044/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the regular tracking and maintaining of comprehensive inventories of software licenses using automated discovery and inventory tools and metrics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd199692c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3044/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyzing software license data to inform investment decisions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd199692d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3044/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing appropriate personnel with sufficient software licenses management training; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd199692e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3044/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Chief Information Officer of the Intelligence Community each inventory required by paragraph (1) and each assessment required by paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd199692f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3044/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inventories by the Chief Information Officer of the Intelligence Community","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief Information Officer of the Intelligence Community, based on the inventories and assessments required by subsection (a), shall biennially—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1996930-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3044/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compile an inventory of all existing software licenses of the intelligence community, including utilized and unutilized licenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1996931-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3044/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assess the actions that could be carried out by the intelligence community to achieve the greatest possible economies of scale and associated cost savings in software procurement and usage, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1996932-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3044/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the centralization of the management of software licenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1996933-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3044/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the regular tracking and maintaining of comprehensive inventories of software licenses using automated discovery and inventory tools and metrics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1996934-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3044/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyzing software license data to inform investment decisions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1996935-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3044/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing appropriate personnel with sufficient software licenses management training; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1996936-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3044/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" based on the assessment required under paragraph (2), make such recommendations with respect to software procurement and usage to the Director of National Intelligence as the Chief Information Officer considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19bda37-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3044/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Information Officer of the Intelligence Community shall submit to the congressional intelligence committees a copy of each inventory compiled under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19bda38-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3044/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after the date on which the Director of National Intelligence receives recommendations from the Chief Information Officer of the Intelligence Community in accordance with subsection (b)(3), the Director of National Intelligence shall, to the extent practicable, issue guidelines for the intelligence community on software procurement and usage based on such recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd19bda39-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title I, § 109, as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/126/tIII/s307/a"},"text":"Pub. L. 113–126, title III, § 307(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-07"},"text":"July 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1396"},"text":"128 Stat. 1396","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/293/tIII/s304"},"text":"Pub. L. 113–293, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3995"},"text":"128 Stat. 3995","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd19bda3a-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd19bda3b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd19bda3c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3044, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343/tI/s109"},"text":"act July 26, 1947, ch. 343, title I, § 109","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/178/tIII/s304/a"},"text":"Pub. L. 103–178, title III, § 304(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2034"},"text":"107 Stat. 2034","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/293/tVIII/s803/a"},"text":"Pub. L. 104–293, title VIII, § 803(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3475"},"text":"110 Stat. 3475","children":[],"tail":", 3476; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1067/16"},"text":"Pub. L. 106–65, div. A, title X, § 1067(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/775"},"text":"113 Stat. 775","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/306/tVIII/s811/b/1/B"},"text":"Pub. L. 107–306, title VIII, § 811(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2422"},"text":"116 Stat. 2422","children":[],"tail":", related to annual report on intelligence, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/tIII/s347/a"},"text":"Pub. L. 111–259, title III, § 347(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2698"},"text":"124 Stat. 2698","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd19bda3d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/293/s304/1"},"text":"Pub. L. 113–293, § 304(1)","children":[],"tail":", substituted “usage, including—” for “usage; and” in introductory provisions and added subpars. (A) to (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/293/s304/2/B"},"text":"Pub. L. 113–293, § 304(2)(B)","children":[],"tail":", substituted “usage, including—” for “usage.” in introductory provisions and added subpars. (A) to (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/293/s304/2/A"},"text":"Pub. L. 113–293, § 304(2)(A)","children":[],"tail":", (C), added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/293/s304/3"},"text":"Pub. L. 113–293, § 304(3)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd19bda3e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd19bda3f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Initial Inventory","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/126/tIII/s307/b"},"text":"Pub. L. 113–126, title III, § 307(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-07"},"text":"July 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1397"},"text":"128 Stat. 1397","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/126/tIII/s307/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Intelligence community elements.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 120 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2014-07-07"},"text":"July 7, 2014","children":[],"tail":"], the chief information officer of each element of the intelligence community shall complete the initial inventory, assessment, and submission required under section 109(a) of the National Security Act of 1947 ["},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3044/a"},"text":"50 U.S.C. 3044(a)","children":[],"tail":"], as added by subsection (a) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Basis","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The initial inventory conducted for each element of the intelligence community under section 109(a)(1) of the National Security Act of 1947 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3044/a/1"},"text":"50 U.S.C. 3044(a)(1)","children":[],"tail":"], as added by subsection (a) of this section, shall be based on the inventory of software licenses conducted pursuant to section 305 of the Intelligence Authorization Act for Fiscal Year 2013 ("},{"tag":"ref","attrib":{"href":"/us/pl/112/277"},"text":"Public Law 112–277","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/126/2472"},"text":"126 Stat. 2472","children":[],"tail":") for such element."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chief information officer of the intelligence community","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2014-07-07"},"text":"July 7, 2014","children":[],"tail":"], the Chief Information Officer of the Intelligence Community shall complete the initial compilation and assessment required under section 109(b) of the National Security Act of 1947 ["},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3044/b"},"text":"50 U.S.C. 3044(b)","children":[],"tail":"], as added by subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “intelligence community” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/126/s307/b"},"text":"section 307(b) of Pub. L. 113–126","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/113/126/s2"},"text":"section 2 of Pub. L. 113–126","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
