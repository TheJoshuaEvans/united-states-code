{"tag":"section","attrib":{"id":"idd1f1c2f6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3607"},"text":null,"children":[{"tag":"num","attrib":{"value":"3607"},"text":"§ 3607.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support for activities and personnel outside the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1f1c2f7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3607/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leasing of real property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/act/1932-06-30/s322"},"text":"section 322 of the Act of June 30, 1932","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5536"},"text":"section 5536 of title 5","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2675"},"text":"section 2675 of title 10","children":[],"tail":", the Director of the National Security Agency, on behalf of the Secretary of Defense, may lease real property outside the United States, for periods not exceeding ten years, for the use of the National Security Agency for special cryptologic activities and for housing for personnel assigned to such activities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f1c2f8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3607/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowances and benefits, housing, and retirement accrual","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the National Security Agency, on behalf of the Secretary of Defense, may provide to certain civilian and military personnel of the Department of Defense who are assigned to special cryptologic activities outside the United States and who are designated by the Secretary of Defense for the purposes of this subsection—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1f1c2f9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3607/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" allowances and benefits—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1f1c2fa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3607/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comparable to those provided by the Secretary of State to members of the Foreign Service under chapter 9 of title I of the Foreign Service Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4081"},"text":"22 U.S.C. 4081","children":[],"tail":" et seq.) or any other provision of law; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f1c2fb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3607/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of selected personnel serving in circumstances similar to those in which personnel of the Central Intelligence Agency serve, comparable to those provided by the Director of Central Intelligence to personnel of the Central Intelligence Agency;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f1c2fc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3607/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" housing (including heat, light, and household equipment) without cost to such personnel, if the Director of the National Security Agency, on behalf of the Secretary of Defense determines that it would be in the public interest to provide such housing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f1c2fd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3607/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special retirement accrual in the same manner provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2153"},"text":"section 2153 of this title","children":[],"tail":" and in "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3518"},"text":"section 3518 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f1c2fe-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3607/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority subject to availability of appropriated funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of the Director of the National Security Agency, on behalf of the Secretary of Defense, to make payments under subsections (a) and (b), and under contracts for leases entered into under subsection (a), is effective for any fiscal year only to the extent that appropriated funds are available for such purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f1c2ff-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3607/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members of Armed Forces","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Armed Forces may not receive benefits under both subsection (b)(1) and title 37 for the same purpose. The Secretary of Defense shall prescribe such regulations as may be necessary to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f1c300-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3607/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Regulations issued pursuant to subsection (b)(1) shall be submitted to the Permanent Select Committee on Intelligence of the House of Representatives and the Select Committee on Intelligence of the Senate before such regulations take effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1f1c301-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/36/s9"},"text":"Pub. L. 86–36, § 9","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/450/tIV/s402/a/1"},"text":"Pub. L. 96–450, title IV, § 402(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1977"},"text":"94 Stat. 1977","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/89/tVI/s601"},"text":"Pub. L. 97–89, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-04"},"text":"Dec. 4, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1154"},"text":"95 Stat. 1154","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/tV/s507/a"},"text":"Pub. L. 99–335, title V, § 507(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/628"},"text":"100 Stat. 628","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/193/tV/s505/b"},"text":"Pub. L. 101–193, title V, § 505(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-30"},"text":"Nov. 30, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1709"},"text":"103 Stat. 1709","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s803/b"},"text":"Pub. L. 102–496, title VIII, § 803(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3253"},"text":"106 Stat. 3253","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1f1c302-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1f1c303-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1f1c304-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1932-06-30/s322"},"text":"Section 322 of the Act of June 30, 1932","children":[],"tail":", referred to in subsec. (a), is section 322 of "},{"tag":"ref","attrib":{"href":"/us/act/1932-06-30/ch314/tIII"},"text":"act June 30, 1932, ch. 314, title III","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/412"},"text":"47 Stat. 412","children":[],"tail":", which was classified to section 278a of former Title 40, Public Buildings, Property, and Works, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/678/s7"},"text":"Pub. L. 100–678, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-17"},"text":"Nov. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4052"},"text":"102 Stat. 4052","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Foreign Service Act of 1980, referred to in subsec. (b)(1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465"},"text":"Pub. L. 96–465","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2071"},"text":"94 Stat. 2071","children":[],"tail":". Chapter 9 of title I of the Act is classified generally to subchapter IX (§ 4081 et seq.) of chapter 52 of Title 22, Foreign Relations and Intercourse. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"section 3901 of Title 22","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1f1c305-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified in a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s402"},"text":"section 402 of this title","children":[],"tail":" prior to editorial reclassification as this section. Some section numbers of this title referenced in amendment notes below reflect the classification of such sections prior to their editorial reclassification."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1f1c306-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/496"},"text":"Pub. L. 102–496","children":[],"tail":" substituted “the Central Intelligence Agency Retirement Act” for “the Central Intelligence Agency Retirement Act of 1964 for Certain Employees”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/193"},"text":"Pub. L. 101–193","children":[],"tail":" substituted a semicolon for “(including special retirement accrual in the same manner provided in section 303 of the Central Intelligence Agency Retirement Act of 1964 for Certain Employees ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403"},"text":"50 U.S.C. 403","children":[],"tail":" note)); and” at end of subpar. (B) of par. (1) and added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335"},"text":"Pub. L. 99–335","children":[],"tail":" inserted “(including special retirement accrual in the same manner provided in section 303 of the Central Intelligence Agency Retirement Act of 1964 for Certain Employees ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403"},"text":"50 U.S.C. 403","children":[],"tail":" note))” before semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/89/s601/a"},"text":"Pub. L. 97–89, § 601(a)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “allowances and benefits comparable to those provided by the Secretary of State to officers and employees of the Foreign Service under paragraphs (1), (2), (7), (9), (10), and (11) of section 1136, and under sections 1137, 1138a, 1148, 1156, 1157, and 1160, of title 22; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/89/s601/b"},"text":"Pub. L. 97–89, § 601(b)","children":[],"tail":", added subsecs. (d) and (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1f1c307-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idd1f1c308-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to the Director of Central Intelligence or the Director of the Central Intelligence Agency in the Director’s capacity as the head of the intelligence community deemed to be a reference to the Director of National Intelligence, and reference to the Director of Central Intelligence or the Director of the Central Intelligence Agency in the Director’s capacity as the head of the Central Intelligence Agency deemed to be a reference to the Director of the Central Intelligence Agency, see section 1081(a), (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd1f1c309-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/496"},"text":"Pub. L. 102–496","children":[],"tail":" effective on the first day of the fourth month beginning after "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s805"},"text":"section 805 of Pub. L. 102–496","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd1f1c30a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335"},"text":"Pub. L. 99–335","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1987-01-01"},"text":"Jan. 1, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/s702/a"},"text":"section 702(a) of Pub. L. 99–335","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8401"},"text":"section 8401 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd1f1c30b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/89"},"text":"Pub. L. 97–89","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/89/s806"},"text":"section 806 of Pub. L. 97–89","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1621"},"text":"section 1621 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
