{"tag":"section","attrib":{"id":"idd20e4a8a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4021"},"text":null,"children":[{"tag":"num","attrib":{"value":"4021"},"text":"§ 4021.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Anticipatory relief","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd20e4a8b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4021/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for relief","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A servicemember may, during military service or within 180 days of termination of or release from military service, apply to a court for relief—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20e4a8c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4021/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from any obligation or liability incurred by the servicemember before the servicemember’s military service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4a8d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4021/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from a tax or assessment falling due before or during the servicemember’s military service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4a8e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4021/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax liability or assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In a case covered by subsection (a), the court may, if the ability of the servicemember to comply with the terms of such obligation or liability or pay such tax or assessment has been materially affected by reason of military service, after appropriate notice and hearing, grant the following relief:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20e4a8f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4021/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stay of enforcement of real estate contracts","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd20e4a90-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4021/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of an obligation payable in installments under a contract for the purchase of real estate, or secured by a mortgage or other instrument in the nature of a mortgage upon real estate, the court may grant a stay of the enforcement of the obligation—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd20e4a91-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4021/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the servicemember’s period of military service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd20e4a92-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4021/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the date of termination of or release from military service, or from the date of application if made after termination of or release from military service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd20e4a93-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4021/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any stay under this paragraph shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd20e4a94-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4021/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a period equal to the remaining life of the installment contract or other instrument, plus a period of time equal to the period of military service of the servicemember, or any part of such combined period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd20e4a95-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4021/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to payment of the balance of the principal and accumulated interest due and unpaid at the date of termination or release from the applicant’s military service or from the date of application in equal installments during the combined period at the rate of interest on the unpaid balance prescribed in the contract or other instrument evidencing the obligation, and subject to other terms as may be equitable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4a96-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4021/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stay of enforcement of other contracts","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd20e4a97-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4021/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of any other obligation, liability, tax, or assessment, the court may grant a stay of enforcement—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd20e4a98-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4021/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the servicemember’s military service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd20e4a99-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4021/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the date of termination of or release from military service, or from the date of application if made after termination or release from military service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd20e4a9a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4021/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any stay under this paragraph shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd20e4a9b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4021/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a period of time equal to the period of the servicemember’s military service or any part of such period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd20e4a9c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4021/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to payment of the balance of principal and accumulated interest due and unpaid at the date of termination or release from military service, or the date of application, in equal periodic installments during this extended period at the rate of interest as may be prescribed for this obligation, liability, tax, or assessment, if paid when due, and subject to other terms as may be equitable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4a9d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4021/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affect ","children":[{"tag":"ref","attrib":{"idref":"fn002119"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002119"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Effect”."}],"tail":" of stay on fine or penalty"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When a court grants a stay under this section, a fine or penalty shall not accrue on the obligation, liability, tax, or assessment for the period of compliance with the terms and conditions of the stay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd20e4a9e-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title VII, § 701, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s1"},"text":"Pub. L. 108–189, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2860"},"text":"117 Stat. 2860","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd20e4a9f-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd20e4aa0-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd20e4aa1-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 591 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd20e4aa2-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 701 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"act Oct. 17, 1940, ch. 888","children":[],"tail":", art. VII, as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/540/tV/s504/2"},"text":"Pub. L. 92–540, title V, § 504(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1098"},"text":"86 Stat. 1098","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/12/s3"},"text":"Pub. L. 102–12, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-03-18"},"text":"Mar. 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/34"},"text":"105 Stat. 34","children":[],"tail":", related to power of attorney, prior to the general amendment of this Act by "},{"tag":"ref","attrib":{"href":"/us/pl/108/189"},"text":"Pub. L. 108–189","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4022"},"text":"section 4022 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in section 700 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"act Oct. 17, 1940, ch. 888","children":[],"tail":", art. VII, as added "},{"tag":"ref","attrib":{"href":"/us/act/1942-10-06/ch581/s18"},"text":"Oct. 6, 1942, ch. 581, § 18","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/777"},"text":"56 Stat. 777","children":[],"tail":", prior to the general amendment of this Act by "},{"tag":"ref","attrib":{"href":"/us/pl/108/189"},"text":"Pub. L. 108–189","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd20e4aa3-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd20e4aa4-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any case not final before ","children":[{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s3"},"text":"section 3 of Pub. L. 108–189","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3901"},"text":"section 3901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
