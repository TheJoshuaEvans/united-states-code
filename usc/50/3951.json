{"tag":"section","attrib":{"id":"idd2099084-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3951"},"text":null,"children":[{"tag":"num","attrib":{"value":"3951"},"text":"§ 3951.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evictions and distress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2099085-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3951/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Court-ordered eviction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2099086-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3951/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except by court order, a landlord (or another person with paramount title) may not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2099087-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3951/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" evict a servicemember, or the dependents of a servicemember, during a period of military service of the servicemember, from premises—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd2099088-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3951/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are occupied or intended to be occupied primarily as a residence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2099089-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3951/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the monthly rent does not exceed $2,400, as adjusted under paragraph (2) for years after 2003; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd209908a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3951/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject such premises to a distress during the period of military service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd209908b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3951/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Housing price inflation adjustment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd209908c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3951/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For calendar years beginning with 2004, the amount in effect under paragraph (1)(A)(ii) shall be increased by the housing price inflation adjustment for the calendar year involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd209908d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3951/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this paragraph—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd209908e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3951/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The housing price inflation adjustment for any calendar year is the percentage change (if any) by which—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idd209908f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3951/a/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the CPI housing component for November of the preceding calendar year, exceeds","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd2099090-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3951/a/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the CPI housing component for November of 1984.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2099091-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3951/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “CPI housing component” means the index published by the Bureau of Labor Statistics of the Department of Labor known as the Consumer Price Index, All Urban Consumers, Rent of Primary Residence, U.S. City Average.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2099092-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3951/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of housing price inflation adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense shall cause to be published in the Federal Register each year the amount in effect under paragraph (1)(A)(ii) for that year following the housing price inflation adjustment for that year pursuant to paragraph (2). Such publication shall be made for a year not later than 60 days after such adjustment is made for that year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2099093-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3951/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stay of execution","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2099094-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3951/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Court authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon an application for eviction or distress with respect to premises covered by this section, the court may on its own motion and shall, if a request is made by or on behalf of a servicemember whose ability to pay the agreed rent is materially affected by military service—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2099095-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3951/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stay the proceedings for a period of 90 days, unless in the opinion of the court, justice and equity require a longer or shorter period of time; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2099096-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3951/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adjust the obligation under the lease to preserve the interests of all parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2099097-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3951/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relief to landlord","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a stay is granted under paragraph (1), the court may grant to the landlord (or other person with paramount title) such relief as equity may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2099098-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3951/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Misdemeanor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (a), a person who knowingly takes part in an eviction or distress described in subsection (a), or who knowingly attempts to do so, shall be fined as provided in title 18, or imprisoned for not more than one year, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2099099-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3951/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rent allotment from pay of servicemember","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent required by a court order related to property which is the subject of a court action under this section, the Secretary concerned shall make an allotment from the pay of a servicemember to satisfy the terms of such order, except that any such allotment shall be subject to regulations prescribed by the Secretary concerned establishing the maximum amount of pay of servicemembers that may be allotted under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd209909a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3951/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation of applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3932"},"text":"Section 3932 of this title","children":[],"tail":" is not applicable to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd209909b-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title III, § 301, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s1"},"text":"Pub. L. 108–189, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2845"},"text":"117 Stat. 2845","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/275/tIII/s303/b/2"},"text":"Pub. L. 111–275, title III, § 303(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-13"},"text":"Oct. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2877"},"text":"124 Stat. 2877","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd209909c-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd209909d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd209909e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 531 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd209909f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 301 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"act Oct. 17, 1940, ch. 888","children":[],"tail":", art. III, "},{"tag":"ref","attrib":{"href":"/us/stat/54/1182"},"text":"54 Stat. 1182","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1942-10-06/ch581/s9/a"},"text":"Oct. 6, 1942, ch. 581, § 9(a)","children":[],"tail":", (c), (d), "},{"tag":"ref","attrib":{"href":"/us/stat/56/771"},"text":"56 Stat. 771","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/12/s9/9"},"text":"Pub. L. 102–12, § 9(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-03-18"},"text":"Mar. 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/40"},"text":"105 Stat. 40","children":[],"tail":", related to installment contracts for purchase of property, prior to the general amendment of this Act by "},{"tag":"ref","attrib":{"href":"/us/pl/108/189"},"text":"Pub. L. 108–189","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3952"},"text":"section 3952 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in section 300 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"act Oct. 17, 1940, ch. 888","children":[],"tail":", art. III, "},{"tag":"ref","attrib":{"href":"/us/stat/54/1181"},"text":"54 Stat. 1181","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1942-10-06/ch581/s8"},"text":"Oct. 6, 1942, ch. 581, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/771"},"text":"56 Stat. 771","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/358/s10"},"text":"Pub. L. 89–358, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-03"},"text":"Mar. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/28"},"text":"80 Stat. 28","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/12"},"text":"Pub. L. 102–12","children":[],"tail":", §§ 2(a), (b), 9(8), "},{"tag":"date","attrib":{"date":"1991-03-18"},"text":"Mar. 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/34"},"text":"105 Stat. 34","children":[],"tail":", 39, prior to the general amendment of this Act by "},{"tag":"ref","attrib":{"href":"/us/pl/108/189"},"text":"Pub. L. 108–189","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd20990a0-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/275"},"text":"Pub. L. 111–275","children":[],"tail":" amended subsec. (c) generally. Prior to amendment, subsec. (c) related to penalties."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd20990a1-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd20990a2-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any case not final before ","children":[{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s3"},"text":"section 3 of Pub. L. 108–189","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3901"},"text":"section 3901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
