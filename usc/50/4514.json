{"tag":"section","attrib":{"id":"idd22afae9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4514"},"text":null,"children":[{"tag":"num","attrib":{"value":"4514"},"text":"§ 4514.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on actions without congressional authorization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd22afaea-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4514/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wage or price controls","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No provision of this chapter shall be interpreted as providing for the imposition of wage or price controls without the prior authorization of such action by a joint resolution of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd22afaeb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4514/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chemical or biological weapons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No provision of this subchapter shall be exercised or interpreted to require action or compliance by any private person to assist in any way in the production of or other involvement in chemical or biological warfare capabilities, unless authorized by the President (or the President’s designee who is serving in a position at level I of the Executive Schedule in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5312"},"text":"section 5312 of title 5","children":[],"tail":") without further redelegation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd22afaec-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-08/ch932"},"text":"Sept. 8, 1950, ch. 932","children":[],"tail":", title I, § 104, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/558/tI/s112"},"text":"Pub. L. 102–558, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4202"},"text":"106 Stat. 4202","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd22afaed-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd22afaee-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd22afaef-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-08/ch932"},"text":"act Sept. 8, 1950, ch. 932","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/798"},"text":"64 Stat. 798","children":[],"tail":", known as the Defense Production Act of 1950, which is classified principally to this chapter. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4501"},"text":"section 4501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd22afaf0-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{}