{"tag":"section","attrib":{"id":"idd13eecce-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1811"},"text":null,"children":[{"tag":"num","attrib":{"value":"1811"},"text":"§ 1811.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization during time of war","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other law, the President, through the Attorney General, may authorize electronic surveillance without a court order under this subchapter to acquire foreign intelligence information for a period not to exceed fifteen calendar days following a declaration of war by the Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd13eeccf-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511/tI/s111"},"text":"Pub. L. 95–511, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-25"},"text":"Oct. 25, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1796"},"text":"92 Stat. 1796","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
