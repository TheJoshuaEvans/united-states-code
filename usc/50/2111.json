{"tag":"section","attrib":{"id":"idd15de76c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2111"},"text":null,"children":[{"tag":"num","attrib":{"value":"2111"},"text":"§ 2111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recall","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd15de76d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to recall","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may, with the consent of a retired participant, recall that participant to service in the Agency whenever the Director determines that such recall is in the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15de76e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay of retired participant while serving","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A retired participant recalled to duty in the Agency under subsection (a) or reinstated or reappointed in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2051/c"},"text":"section 2051(c) of this title","children":[],"tail":" shall, while so serving, be entitled, in lieu of the retired participant’s annuity, to the full basic pay of the grade in which the retired participant is serving. During such service, the retired participant shall make contributions to the fund in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2021"},"text":"section 2021 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15de76f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2111/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recomputation of annuity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When the retired participant reverts to retired status, the annuity of the retired participant shall be redetermined in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2031"},"text":"section 2031 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd15de770-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/tII/s271"},"text":"Pub. L. 88–643, title II, § 271","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s802"},"text":"Pub. L. 102–496, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3238"},"text":"106 Stat. 3238","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tIX/s7901/d/3"},"text":"Pub. L. 118–31, div. G, title IX, § 7901(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1106"},"text":"137 Stat. 1106","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd15de771-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd15de772-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":