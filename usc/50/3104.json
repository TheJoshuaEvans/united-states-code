{"tag":"section","attrib":{"id":"idd1aa31d5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104"},"text":null,"children":[{"tag":"num","attrib":{"value":"3104"},"text":"§ 3104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports on security clearances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1aa31d6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on security clearance determinations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1aa31d7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than February 1 of each year, the President shall submit to Congress a report on the security clearance process. Such report shall include, for each security clearance level—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1aa31d8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the number of employees of the United States Government who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1aa31d9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" held a security clearance at such level as of October 1 of the preceding year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1aa31da-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were approved for a security clearance at such level during the preceding fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1aa31db-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the number of contractors to the United States Government who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1aa31dc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" held a security clearance at such level as of October 1 of the preceding year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1aa31dd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were approved for a security clearance at such level during the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1aa31de-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of paragraph (1), the President may consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1aa31df-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security clearances at the level of confidential and secret as one security clearance level; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1aa31e0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security clearances at the level of top secret or higher as one security clearance level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1aa31e1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intelligence community reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1aa31e2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1aa31e3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than March 1 of each year, the Director of National Intelligence shall submit a report to the congressional intelligence committees, the Committee on Homeland Security and Governmental Affairs of the Senate, the Committee on Homeland Security of the House of Representatives, and the Committee on Oversight and Reform of the House of Representatives regarding the security clearances processed by each element of the intelligence community during the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1aa31e4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall submit to the Committee on Armed Services of the Senate and the Committee on Armed Services of the House of Representatives such portions of the report submitted under subparagraph (A) as the Director determines address elements of the intelligence community that are within the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1aa31e5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each report submitted under this paragraph shall separately identify security clearances processed for Federal employees and contractor employees sponsored by each such element.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1aa31e6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each report submitted under paragraph (1)(A) shall include, for each element of the intelligence community for the fiscal year covered by the report, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1aa31e7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total number of initial security clearance background investigations sponsored for new applicants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1aa31e8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total number of security clearance periodic reinvestigations sponsored for existing employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1aa31e9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The total number of initial security clearance background investigations for new applicants that were adjudicated with notice of a determination provided to the prospective applicant, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1aa31ea-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of such adjudications that were adjudicated favorably and granted access to classified information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1aa31eb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of such adjudications that were adjudicated unfavorably and resulted in a denial or revocation of a security clearance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1aa31ec-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The total number of security clearance periodic background investigations that were adjudicated with notice of a determination provided to the existing employee, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1aa31ed-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of such adjudications that were adjudicated favorably; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1aa31ee-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of such adjudications that were adjudicated unfavorably and resulted in a denial or revocation of a security clearance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1aa31ef-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The total number of pending security clearance background investigations, including initial applicant investigations and periodic reinvestigations, that were not adjudicated as of the last day of such year and that remained pending, categorized as follows:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1aa31f0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/b/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For 180 days or shorter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1aa31f1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/b/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For longer than 180 days, but shorter than 12 months.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1aa31f2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/b/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For 12 months or longer, but shorter than 18 months.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1aa31f3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/b/2/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For 18 months or longer, but shorter than 24 months.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1aa31f4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/b/2/E/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For 24 months or longer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1aa31f5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For any security clearance determinations completed or pending during the year preceding the year for which the report is submitted that have taken longer than 12 months to complete—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1aa31f6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/b/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of the causes for the delays incurred during the period covered by the report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1aa31f7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/b/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of such delays involving a polygraph requirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1aa31f8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The percentage of security clearance investigations, including initial and periodic reinvestigations, that resulted in a denial or revocation of a security clearance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1aa31f9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The percentage of security clearance investigations that resulted in incomplete information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1aa31fa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The percentage of security clearance investigations that did not result in enough information to make a decision on potentially adverse information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1aa31fb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The report required under this subsection shall be submitted in unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1aa31fc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The reports required under subsections (a)(1) and (b) shall be submitted in unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1aa31fd-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title V, § 506H, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/tIII/s367/a/1/A"},"text":"Pub. L. 111–259, title III, § 367(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2703"},"text":"124 Stat. 2703","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dM/tVII/s701/a"},"text":"Pub. L. 114–113, div. M, title VII, § 701(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2929"},"text":"129 Stat. 2929","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLXVI/s6609/b"},"text":"Pub. L. 116–92, div. E, title LXVI, § 6609(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2217"},"text":"133 Stat. 2217","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1aa31fe-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1aa31ff-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1aa3200-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s415a–10"},"text":"section 415a–10 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1aa3201-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s6609/b/1"},"text":"Pub. L. 116–92, § 6609(b)(1)","children":[],"tail":", struck out subpar. (C) which related to security clearance investigations and determinations for each element of the intelligence community."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s6609/b/3"},"text":"Pub. L. 116–92, § 6609(b)(3)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). Pub L. 116–92, § 6609(b)(2), (4), redesignated subsec. (b) as (c) and substituted “subsections (a)(1) and (b)” for “subsection (a)(1)”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s701/a/1"},"text":"Pub. L. 114–113, § 701(a)(1)","children":[],"tail":", (2), redesignated subsec. (b) as (a) and struck out former subsec. (a) which related to quadrennial audit of position requirements."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s701/a/2"},"text":"Pub. L. 114–113, § 701(a)(2)","children":[],"tail":", (3), redesignated subsec. (c) as (b) and substituted “The reports required under subsection (a)(1)” for “The results required under subsection (a)(2) and the reports required under subsection (b)(1)”. Former subsec. (b) redesignated (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1aa3202-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idd1aa3203-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1aa3204-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Initial Audit","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/tIII/s367/a/1/B"},"text":"Pub. L. 111–259, title III, § 367(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2704"},"text":"124 Stat. 2704","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/259/tIII/s367/a/1/B"},"text":"“The first audit required to be conducted under section 506H(a)(1) of the National Security Act of 1947 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3104/a/1"},"text":"50 U.S.C. 3104(a)(1)","children":[],"tail":"], as added by subparagraph (A) of this paragraph, shall be completed not later than "},{"tag":"date","attrib":{"date":"2011-02-01"},"text":"February 1, 2011","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
