{"tag":"section","attrib":{"id":"idd0f03090-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"98h–6"},"text":"§ 98h–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development and conservation of reliable sources","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd0f03091-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (d), the National Defense Stockpile Manager shall encourage the development and appropriate conservation of reliable sources of strategic and critical materials—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0f03092-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–6/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by purchasing, or making a commitment to purchase, strategic and critical materials from reliable sources when such materials are needed for the stockpile;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f03093-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–6/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by contracting with facilities located in and owned and controlled by reliable sources, or making a commitment to contract with such facilities, for the processing or refining of strategic and critical materials in the stockpile when processing or refining is necessary to convert such materials into a form more suitable for storage or disposition or meeting stockpile requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f03094-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–6/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by qualifying facilities located in and owned and controlled by reliable sources, or qualifying strategic and critical materials produced by such facilities, to meet stockpile requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f03095-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–6/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by contracting with facilities located in and owned and controlled by reliable sources to recycle strategic and critical materials to meet stockpile requirements or increase the balance of the National Defense Stockpile Transaction Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s98h"},"text":"section 98h of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f03096-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–6/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" by entering into an agreement to co-fund a bankable feasibility study for a project for the development of strategic and critical materials located in and owned and controlled by a reliable source, if the agreement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd0f03097-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–6/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limits the liability of the stockpile to not more than the total funding provided by the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0f03098-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–6/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limits the funding contribution of the Federal Government to not more than 50 percent of the cost of the bankable feasibility study; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0f03099-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–6/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not obligate the Federal Government to purchase strategic and critical materials from the reliable source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0f0309a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional authorities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0f27a8b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–6/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extended contracting authority","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd0f27a8c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–6/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of a contract or commitment made under subsection (a) may not exceed ten years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0f27a8d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–6/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preexisting contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A contract entered into before ","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"December 22, 2023","children":[],"tail":", for a term of more than ten years may be extended, on or after "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"December 22, 2023","children":[],"tail":", for a total of not more than an additional ten years pursuant to any option or options set forth in the contract."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f27a8e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–6/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters relating to co-funding of bankable feasibility studies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent authorized by Congress pursuant to the Defense Production Act of 1950 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4501"},"text":"50 U.S.C. 4501","children":[],"tail":" et seq.) and determined to be required by the President pursuant to that Act, the National Defense Stockpile Manager may provide for loans or procure debt issued by other entities to carry out a project for the development of strategic and critical materials with respect to which a study was carried out under subsection (a)(5)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0f27a8f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposed transactions included in annual materials plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Descriptions of proposed transactions under subsection (a) shall be included in the Annual Materials and Operations Plan. Changes to any such transaction, or the addition of a transaction not included in such plan, shall be made in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s98d/a/2"},"text":"section 98d(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0f27a90-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–6/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of the National Defense Stockpile Manager to enter into obligations under this section is effective for any fiscal year only to the extent that funds in the National Defense Stockpile Transaction Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s98h"},"text":"section 98h of this title","children":[],"tail":" are adequate to meet such obligations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0f27a91-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–6/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bankable feasibility study defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “bankable feasibility study” means a comprehensive technical and economic study—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0f27a92-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–6/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the selected option for a strategic and critical materials development project that includes appropriately detailed assessments of realistically assumed extraction, processing, metallurgical, economic, marketing, legal, environmental, social, and governmental considerations and any other relevant operational factors and detailed financial analysis, that are necessary to demonstrate at the time of reporting that production is reasonably justified; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f27a93-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–6/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that may reasonably serve as the basis for a final decision by a proponent of a project or financial institution to proceed with, or finance, the development of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd0f27a94-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-06-07/ch190/s15"},"text":"June 7, 1939, ch. 190, § 15","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dC/tXXXIII/s3312/a"},"text":"Pub. L. 101–189, div. C, title XXXIII, § 3312(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1687"},"text":"103 Stat. 1687","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tXIV/s1411/c"},"text":"Pub. L. 113–66, div. A, title XIV, § 1411(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/934"},"text":"127 Stat. 934","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXIV/s1412/b"},"text":"Pub. L. 114–328, div. A, title XIV, § 1412(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2570"},"text":"130 Stat. 2570","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXIV/s1411/3"},"text":"Pub. L. 117–81, div. A, title XIV, § 1411(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2018"},"text":"135 Stat. 2018","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tXIV/s1411/d/1/B"},"text":"Pub. L. 117–263, div. A, title XIV, § 1411(d)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2871"},"text":"136 Stat. 2871","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXIV/s1411/e/1"},"text":"Pub. L. 118–31, div. A, title XIV, § 1411(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/526"},"text":"137 Stat. 526","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd0f27a95-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd0f27a96-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd0f27a97-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Defense Production Act of 1950, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-08/ch932"},"text":"act Sept. 8, 1950, ch. 932","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/798"},"text":"64 Stat. 798","children":[],"tail":", which is classified principally to chapter 55 (§ 4501 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4501"},"text":"section 4501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd0f27a98-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" amended section generally. Prior to amendment, section related to development of domestic sources for materials."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s1411/d/1/B/i"},"text":"Pub. L. 117–263, § 1411(d)(1)(B)(i)","children":[],"tail":", substituted “Annual Materials and Operations Plan” for “annual materials plan”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s1411/d/1/B/ii"},"text":"Pub. L. 117–263, § 1411(d)(1)(B)(ii)","children":[],"tail":", inserted “, acting through the National Defense Stockpile Manager,” after “The President” and substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t50/s98h–2/b/1"},"text":"section 98h–2(b)(1) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t50/s98h–2/a"},"text":"section 98h–2(a) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" added pars. (3) and (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66"},"text":"Pub. L. 113–66","children":[],"tail":" inserted “and appropriate conservation” after “development” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
