{"tag":"section","attrib":{"id":"idd0edc01c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"98h–1"},"text":"§ 98h–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategic and Critical Materials Board of Directors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd0edc01d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a Strategic and Critical Materials Board of Directors (in this subchapter referred to as the “Board”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0edc01e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall be composed, at a minimum, of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0edc01f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary of Defense for Industrial Base Policy, who shall serve as chairman of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0edc020-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One designee of each of the Secretary of Commerce, the Secretary of State, the Secretary of Energy, and the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0edc021-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One designee of each of the Chairman and Ranking Member of the Readiness Subcommittee of the House Committee on Armed Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0edc022-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One designee of each of the Chairman and Ranking Member of the Readiness Subcommittee of the Senate Committee on Armed Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0edc023-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–1/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Four designees of the chairman of the Board, who shall have expertise relating to military affairs, defense procurement, production of strategic and critical materials, finance, or any other disciplines deemed necessary by the chairman to conduct the business of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0edc024-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of the Board","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to other matters assigned to it by the chairman, the Board shall conduct the following, without power of delegation:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0edc025-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Adopt by-laws that ensure sufficient oversight, governance, and effectiveness of the National Defense Stockpile program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0edc026-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Elect or remove Board members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0edc027-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advise the National Defense Stockpile Manager.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0edc028-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–1/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establish performance metrics and conduct an annual performance review of the management and operations of the National Defense Stockpile program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0edc029-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–1/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Review and approve the annual budget of the National Defense Stockpile program and conduct appropriate reviews of annual financial statements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0edc02a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–1/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Re-allocate budget resources within the annual budget of the National Defense Stockpile program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0edc02b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–1/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Review and approve the Annual Materials and Operations Plan required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s98h–2/a"},"text":"section 98h–2(a) of this title","children":[],"tail":". The report required by "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s98h–2/b/2"},"text":"section 98h–2(b)(2) of this title","children":[],"tail":" shall include the views and recommendations of the Board on the projected domestic and foreign economic effects of all acquisition of materials for and disposals of materials from the stockpile."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0edc02c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–1/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Complete and submit the annual Board Report, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s98h–2/b/2"},"text":"section 98h–2(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0edc02d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–1/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Recommend to the Secretary of Defense—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd0edc02e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–1/c/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a strategy to ensure a secure supply of materials designated as critical to national security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0f0302f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–1/c/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other strategies as the Board considers appropriate to strengthen the industrial base with respect to materials critical to national security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0f03030-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall meet as determined necessary by the chairman but not less frequently than once every year to fulfill the duties described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0f03031-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of provisions relating to Federal advisory committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013/a"},"text":"Section 1013(a) of title 5","children":[],"tail":" shall not apply to the Board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0f03032-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0f03033-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–1/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Materials critical to national security","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “materials critical to national security” means materials—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd0f03034-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–1/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon which the production or sustainment of military equipment is dependent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0f03035-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–1/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the supply of which could be restricted by actions or events outside the control of the Government of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f03036-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–1/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military equipment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “military equipment” means equipment used directly by the Armed Forces to carry out military operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f03037-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–1/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secure supply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “secure supply”, with respect to a material, means the availability of a source or sources for the material, including the full supply chain for the material and components containing the material.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd0f03038-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-06-07/ch190/s10"},"text":"June 7, 1939, ch. 190, § 10","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/41/s2/a"},"text":"Pub. L. 96–41, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-30"},"text":"July 30, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/323"},"text":"93 Stat. 323","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dC/tXXXIII/s3314"},"text":"Pub. L. 102–484, div. C, title XXXIII, § 3314","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2654"},"text":"106 Stat. 2654","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tXIV/s1411/b"},"text":"Pub. L. 117–263, div. A, title XIV, § 1411(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2869"},"text":"136 Stat. 2869","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXIV/s1411/c"},"text":"Pub. L. 118–31, div. A, title XIV, § 1411(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/524"},"text":"137 Stat. 524","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd0f03039-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd0f0303a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd0f0303b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 10 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-06-07/ch190/s10"},"text":"act June 7, 1939, ch. 190, § 10","children":[],"tail":", was renumbered section 13 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s98h–4"},"text":"section 98h–4 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s187"},"text":"section 187 of Title 10","children":[],"tail":", Armed Forces, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s1411/a"},"text":"Pub. L. 117–263, § 1411(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd0f0303c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1411/c/1/A"},"text":"Pub. L. 118–31, § 1411(c)(1)(A)","children":[],"tail":", substituted “of the management and operations of the National Defense Stockpile program” for “of the National Defense Stockpile Manager”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1411/c/1/B"},"text":"Pub. L. 118–31, § 1411(c)(1)(B)","children":[],"tail":", redesignated pars. (6) and (7) as (5) and (6), respectively, and struck out former par. (5) which read as follows: “Set compensation for the National Defense Stockpile Manager.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1411/c/1/B"},"text":"Pub. L. 118–31, § 1411(c)(1)(B)","children":[],"tail":", (C), redesignated par. (8) as (7) and substituted “required by "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s98h–2/a"},"text":"section 98h–2(a) of this title","children":[],"tail":". The report required by "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s98h–2/b/2"},"text":"section 98h–2(b)(2) of this title","children":[],"tail":" shall include the views and recommendations of the Board on” for “required by "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s98h–2/a/2"},"text":"section 98h–2(a)(2) of this title","children":[],"tail":", including a review of” and “all acquisition of materials for and disposals of materials from the stockpile” for “proposed actions to be taken under the Annual Materials and Operations Plan”. Former par. (7) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(8) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1411/c/1/B"},"text":"Pub. L. 118–31, § 1411(c)(1)(B)","children":[],"tail":", redesignated pars. (9) and (10) as (8) and (9), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1411/c/2"},"text":"Pub. L. 118–31, § 1411(c)(2)","children":[],"tail":", amended subsec. (e) generally. Prior to amendment, text read as follows: “Section 14 of the Federal Advisory Committee Act (5 U.S.C. App.) shall not apply to the Board.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" amended section generally. Prior to amendment, section related to appointment of advisory committees and a Market Impact Committee."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd0f0303d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd0f0303e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Advisory Committee Regarding Operation and Modernization of Stockpile","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dC/tXXXIII/s3306"},"text":"Pub. L. 102–484, div. C, title XXXIII, § 3306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2652"},"text":"106 Stat. 2652","children":[],"tail":", required the President to appoint, no later than "},{"tag":"date","attrib":{"date":"1993-03-15"},"text":"Mar. 15, 1993","children":[],"tail":", an advisory committee to make recommendations concerning the operation and modernization of the National Defense Stockpile."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
