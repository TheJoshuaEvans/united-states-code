{"tag":"section","attrib":{"id":"idd10a7007-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1520a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1520a"},"text":"§ 1520a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on use of human subjects for testing of chemical or biological agents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd10a7008-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1520a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may not conduct (directly or by contract)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd10a7009-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1520a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any test or experiment involving the use of a chemical agent or biological agent on a civilian population; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd10a700a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1520a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other testing of a chemical agent or biological agent on human subjects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd10a700b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1520a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsections (c), (d), and (e), the prohibition in subsection (a) does not apply to a test or experiment carried out for any of the following purposes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd10a700c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1520a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any peaceful purpose that is related to a medical, therapeutic, pharmaceutical, agricultural, industrial, or research activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd10a700d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1520a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any purpose that is directly related to protection against toxic chemicals or biological weapons and agents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd10a700e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1520a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any law enforcement purpose, including any purpose related to riot control.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd10a700f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1520a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Informed consent required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense may conduct a test or experiment described in subsection (b) only if informed consent to the testing was obtained from each human subject in advance of the testing on that subject.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd10a7010-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1520a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior notice to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the date of final approval within the Department of Defense of plans for any experiment or study to be conducted by the Department of Defense (whether directly or under contract) involving the use of human subjects for the testing of a chemical agent or a biological agent, the Secretary of Defense shall submit to the Committee on Armed Services of the Senate and the Committee on Armed Services of the House of Representatives a report setting forth a full accounting of those plans, and the experiment or study may then be conducted only after the end of the 30-day period beginning on the date such report is received by those committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd10a7011-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1520a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Biological agent” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “biological agent” means any micro-organism (including bacteria, viruses, fungi, rickettsiac, or protozoa), pathogen, or infectious substance, and any naturally occurring, bioengineered, or synthesized component of any such micro-organism, pathogen, or infectious substance, whatever its origin or method of production, that is capable of causing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd10a7012-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1520a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" death, disease, or other biological malfunction in a human, an animal, a plant, or another living organism;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd10a7013-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1520a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deterioration of food, water, equipment, supplies, or materials of any kind; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd10a7014-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1520a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deleterious alteration of the environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd10a7015-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1078"},"text":"Pub. L. 105–85, div. A, title X, § 1078","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1915"},"text":"111 Stat. 1915","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1067/4"},"text":"Pub. L. 106–65, div. A, title X, § 1067(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/774"},"text":"113 Stat. 774","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd10a7016-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd10a7017-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd10a7018-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s1078"},"text":"section 1078 of Pub. L. 105–85","children":[],"tail":". Subsec. (f) of "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/s1078"},"text":"section 1078 of Pub. L. 105–85","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1523/b"},"text":"section 1523(b) of this title","children":[],"tail":". Subsec. (g) of "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/s1078"},"text":"section 1078 of Pub. L. 105–85","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1520"},"text":"section 1520 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Defense Authorization Act for Fiscal Year 1998, and not as part of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/121/tIV/s409"},"text":"Pub. L. 91–121, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-11-19"},"text":"Nov. 19, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/209"},"text":"83 Stat. 209","children":[],"tail":", which comprises this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd10a7019-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “and the Committee on Armed Services” for “and the Committee on National Security”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
