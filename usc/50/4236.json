{"tag":"section","attrib":{"id":"idd217e823-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4236"},"text":null,"children":[{"tag":"num","attrib":{"value":"4236"},"text":"§ 4236.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individual compensation of eligible Aleuts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd217e824-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4236/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to eligible Aleuts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to payments made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4235"},"text":"section 4235 of this title","children":[],"tail":", the Secretary shall, in accordance with this section, make per capita payments out of the Fund to eligible Aleuts. The Secretary shall pay, subject to the availability of funds appropriated to the Fund for such payments, to each eligible Aleut the sum of $12,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd217e825-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4236/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance of Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may request the Attorney General to provide reasonable assistance in locating eligible Aleuts residing outside the affected Aleut villages, and upon such request, the Attorney General shall provide such assistance. In so doing, the Attorney General may use available facilities and resources of the International Committee of the Red Cross and other organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd217e826-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4236/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance of Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may request the assistance of the Administrator in identifying and locating eligible Aleuts for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd217e827-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4236/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification of treatment of payments under other laws","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts paid to an eligible Aleut under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd217e828-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4236/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be treated for purposes of the internal revenue laws of the United States as damages for human suffering, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e829-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4236/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be included as income or resources for purposes of determining eligibility to receive benefits described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3803/c/2/C"},"text":"section 3803(c)(2)(C) of title 31","children":[],"tail":" or the amount of such benefits."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd217e82a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4236/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment in full settlement of claims against United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The payment to an eligible Aleut under this section shall be in full satisfaction of all claims against the United States arising out of the relocation described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4232/5"},"text":"section 4232(5) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd217e82b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4236/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Fund such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd217e82c-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/383/tII/s206"},"text":"Pub. L. 100–383, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-10"},"text":"Aug. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/914"},"text":"102 Stat. 914","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd217e82d-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd217e82e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd217e82f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 1989c–5 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
