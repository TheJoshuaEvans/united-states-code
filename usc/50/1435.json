{"tag":"section","attrib":{"id":"idd107fe8c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1435"},"text":null,"children":[{"tag":"num","attrib":{"value":"1435"},"text":"§ 1435.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective period","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This chapter shall be effective only during a national emergency declared by Congress or the President and for six months after the termination thereof or until such earlier time as Congress, by concurrent resolution, may designate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd107fe8d-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/804/s4"},"text":"Pub. L. 85–804, § 4","children":[],"tail":", formerly § 5, "},{"tag":"date","attrib":{"date":"1958-08-28"},"text":"Aug. 28, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/973"},"text":"72 Stat. 973","children":[],"tail":"; renumbered § 4, "},{"tag":"ref","attrib":{"href":"/us/pl/105/362/tIX/s901/r/1/B"},"text":"Pub. L. 105–362, title IX, § 901(r)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-10"},"text":"Nov. 10, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3291"},"text":"112 Stat. 3291","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd107fe8e-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd107fe8f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd107fe90-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},