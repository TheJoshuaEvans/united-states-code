{"tag":"section","attrib":{"id":"idd16031a7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2201"},"text":null,"children":[{"tag":"num","attrib":{"value":"2201"},"text":"§ 2201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers of spoils of war","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd16031a8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2201/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for transfer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Spoils of war in the possession, custody, or control of the United States may be transferred to any other party, including any government, group, or person, by sale, grant, loan or in any other manner, only to the extent and in the same manner that property of the same type, if otherwise owned by the United States, may be so transferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16031a9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2201/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any transfer pursuant to subsection (a) shall be subject to all of the terms, conditions, and requirements applicable to the transfer of property of the same type otherwise owned by the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd16031aa-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tV/s552"},"text":"Pub. L. 103–236, title V, § 552","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/482"},"text":"108 Stat. 482","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd16031ab-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd16031ac-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idd16031ad-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tV/s551"},"text":"Pub. L. 103–236, title V, § 551","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/482"},"text":"108 Stat. 482","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/236/tV/s551"},"text":"“This part [part B (§§ 551–556) of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":", enacting this chapter] may be cited as the ‘Spoils of War Act of 1994’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
