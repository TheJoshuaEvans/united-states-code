{"tag":"section","attrib":{"id":"idd162a1bb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2205"},"text":null,"children":[{"tag":"num","attrib":{"value":"2205"},"text":"§ 2205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter shall apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd162a1bc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2205/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the abandonment or failure to take possession of spoils of war by troops in the field for valid military reasons related to the conduct of the immediate conflict, including the burden of transporting such property or a decision to allow allied forces to take immediate possession of certain property solely for use during an ongoing conflict;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd162a1bd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2205/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the abandonment or return of any property obtained, borrowed, or requisitioned for temporary use during military operations without intent to retain possession of such property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd162a1be-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2205/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the destruction of spoils of war by troops in the field;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd162a1bf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2205/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the return of spoils of war to previous owners from whom such property had been seized by enemy forces; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd162a1c0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2205/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minor articles of personal property which have lawfully become the property of individual members of the armed forces as war trophies pursuant to public written authorization from the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd162a1c1-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tV/s556"},"text":"Pub. L. 103–236, title V, § 556","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/483"},"text":"108 Stat. 483","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
