{"tag":"section","attrib":{"id":"idd1a09493-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060"},"text":null,"children":[{"tag":"num","attrib":{"value":"3060"},"text":"§ 3060.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Climate Security Advisory Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1a09494-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of National Intelligence shall establish a Climate Security Advisory Council for the purpose of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1a09495-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting intelligence analysts of various elements of the intelligence community with respect to analysis of climate security and its impact on the areas of focus of such analysts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a09496-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating coordination between the elements of the intelligence community and elements of the Federal Government that are not elements of the intelligence community in collecting data on, and conducting analysis of, climate change and climate security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a09497-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that the intelligence community is adequately prioritizing climate change in carrying out its activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1a09498-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition of Council","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1a09499-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall be composed of the following individuals appointed by the Director of National Intelligence:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1a0949a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An appropriate official from the National Intelligence Council, who shall chair the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a0949b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The lead official with respect to climate and environmental security analysis from—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1a0949c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Central Intelligence Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1a0949d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Intelligence and Research of the Department of State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1a0949e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Geospatial-Intelligence Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1a0949f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Intelligence and Counterintelligence of the Department of Energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1a094a0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/b/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the Under Secretary of Defense for Intelligence and Security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1a094a1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/b/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Defense Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a094a2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Three appropriate officials from elements of the Federal Government that are not elements of the intelligence community that are responsible for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1a094a3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing decision makers with a predictive understanding of the climate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1a094a4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making observations of our Earth system that can be used by the public, policymakers, and to support strategic decisions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1a094a5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/b/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating Federal research and investments in understanding the forces shaping the global environment, both human and natural, and their impacts on society.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a094a6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other officials as the Director of National Intelligence or the chair of the Council may determine appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a094a7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of chair","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The chair of the Council shall have responsibility for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1a094a8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying agencies to supply individuals from elements of the Federal Government that are not elements of the intelligence community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a094a9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" securing the permission of the relevant agency heads for the participation of such individuals on the Council; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a094aa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other duties that the Director of National Intelligence may direct.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1a094ab-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties and responsibilities of Council","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall carry out the following duties and responsibilities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1a094ac-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To meet at least quarterly to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1a094ad-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exchange appropriate data between elements of the intelligence community and elements of the Federal Government that are not elements of the intelligence community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a094ae-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discuss processes for the routine exchange of such data and implementation of such processes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a094af-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare summaries of the business conducted at each meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a094b0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To assess and determine best practices with respect to the analysis of climate security, including identifying publicly available information and intelligence acquired through clandestine means that enables such analysis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a094b1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To assess and identify best practices with respect to prior efforts of the intelligence community to analyze climate security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a094b2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To assess and describe best practices for identifying and disseminating climate intelligence indications and warnings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a094b3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To recommend methods of incorporating analysis of climate security and the best practices identified under paragraphs (2) through (4) into existing analytic training programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a094b4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To consult, as appropriate, with other elements of the intelligence community that conduct analysis of climate change or climate security and elements of the Federal Government that are not elements of the intelligence community that conduct analysis of climate change or climate security, for the purpose of sharing information about ongoing efforts and avoiding duplication of existing efforts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a094b5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To work with elements of the intelligence community that conduct analysis of climate change or climate security and elements of the Federal Government that are not elements of the intelligence community that conduct analysis of climate change or climate security—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1a094b6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to exchange appropriate data between such elements, establish processes, procedures and practices for the routine exchange of such data, discuss the implementation of such processes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a094b7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enable and facilitate the sharing of findings and analysis between such elements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a094b8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To assess whether the elements of the intelligence community that conduct analysis of climate change or climate security may inform the research direction of academic work and the sponsored work of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a094b9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At the discretion of the chair of the Council, to convene conferences of analysts and nonintelligence community personnel working on climate change or climate security on subjects that the chair shall direct.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1a094ba-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1a094bb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2021-01-31"},"text":"January 31, 2021","children":[],"tail":", and not less frequently than annually thereafter, the chair of the Council shall submit, on behalf of the Council, to the congressional intelligence committees a report describing the activities of the Council as described in subsection (c) during the year preceding the year during which the report is submitted."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a094bc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under paragraph (1) shall include a description of any obstacles or gaps relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1a094bd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Council fulfilling its duties and responsibilities under subsection (c); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a094be-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the responsiveness of the intelligence community to the climate security needs and priorities of the policymaking elements of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1a094bf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall terminate on ","children":[{"tag":"date","attrib":{"date":"2024-12-31"},"text":"December 31, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1a094c0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1a094c1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Climate security","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “climate security” means the effects of climate change on the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1a094c2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The national security of the United States, including national security infrastructure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a094c3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subnational, national, and regional political stability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a094c4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The security of allies and partners of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a094c5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ongoing or potential political violence, including unrest, rioting, guerrilla warfare, insurgency, terrorism, rebellion, revolution, civil war, and interstate war.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a094c6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Climate intelligence indications and warnings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “climate intelligence indications and warnings” means developments relating to climate security with the potential to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1a094c7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imminently and substantially alter the political stability or degree of human security in a country or region; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a094c8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" imminently and substantially threaten—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1a094c9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national security of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1a094ca-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the military, political, or economic interests of allies and partners of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1a094cb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3060/f/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" citizens of the United States abroad.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1a094cc-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title I, § 120, as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLIII/s5321/a"},"text":"Pub. L. 116–92, div. E, title LIII, § 5321(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2126"},"text":"133 Stat. 2126","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dW/tIV/s405/b"},"text":"Pub. L. 116–260, div. W, title IV, § 405(b)","children":[],"tail":", title VI, § 618, "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2380"},"text":"134 Stat. 2380","children":[],"tail":", 2400; "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dX/tIV/s404"},"text":"Pub. L. 117–103, div. X, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/975"},"text":"136 Stat. 975","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tIII/s7319"},"text":"Pub. L. 118–31, div. G, title III, § 7319","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1036"},"text":"137 Stat.