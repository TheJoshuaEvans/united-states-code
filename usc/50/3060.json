edContent","attrib":{"origin":"/us/pl/116/92/dE/tLIII/s5321/c"},"text":"“Not later than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":"], the Director of National Intelligence shall appoint the members of the Council under section 120 of the National Security Act of 1947 ["},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3060"},"text":"50 U.S.C. 3060","children":[],"tail":"], as added by subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
