{"tag":"section","attrib":{"id":"idd15904ed-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2035"},"text":null,"children":[{"tag":"num","attrib":{"value":"2035"},"text":"§ 2035.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retirement annuity for certain former spouses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd15904ee-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2035/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retirement annuity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual who was a former spouse of a participant, former participant, or retired participant on ","children":[{"tag":"date","attrib":{"date":"1982-11-15"},"text":"November 15, 1982","children":[],"tail":", and any former spouse divorced after "},{"tag":"date","attrib":{"date":"1982-11-15"},"text":"November 15, 1982","children":[],"tail":", from a participant or former participant who retired before "},{"tag":"date","attrib":{"date":"1982-11-15"},"text":"November 15, 1982","children":[],"tail":", shall be entitled, except to the extent such former spouse is disqualified under subsection (b), to an annuity—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15904ef-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2035/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if married to the participant throughout the creditable service of the participant, equal to 50 percent of the annuity of the participant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15904f0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2035/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if not married to the participant throughout such creditable service, equal to that former spouse’s pro rata share of 50 percent of such annuity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15904f1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2035/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A former spouse is not entitled to an annuity under this section if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15904f2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2035/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the former spouse remarries before age 55, except that the entitlement of the former spouse to an annuity under this section shall be restored on the date such remarriage is dissolved by death, annulment, or divorce; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15904f3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2035/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the former spouse is less than 50 years of age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15904f4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2035/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement and termination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15904f5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2035/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retirement annuities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The entitlement of a former spouse to an annuity under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd15904f6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2035/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall commence on the later of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd15904f7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2035/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the day the participant upon whose service the right to the annuity is based becomes entitled to an annuity under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd15904f8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2035/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first day of the month in which the divorce or annulment involved becomes final; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd15904f9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2035/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such former spouse’s 50th birthday; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd15904fa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2035/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall terminate on the earlier of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd15904fb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2035/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the last day of the month before the former spouse dies or remarries before 55 years of age, except that the entitlement of the former spouse to an annuity under this section shall be restored on the date such remarriage is dissolved by death, annulment, or divorce; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd15904fc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2035/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the annuity of the participant terminates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15904fd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2035/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disability annuities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraph (1)(A)(i), in the case of a former spouse of a disability annuitant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd15904fe-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2035/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the annuity of the former spouse shall commence on the date on which the participant would qualify on the basis of the participant’s creditable service for an annuity under this subchapter (other than disability annuity) or the date the disability annuity begins, whichever is later; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd15904ff-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2035/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the annuity of the former spouse shall be calculated on the basis of the annuity for which the participant would otherwise so qualify.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1590500-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2035/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election of benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A former spouse of a participant or retired participant shall not become entitled under this section to an annuity or to the restoration of an annuity payable from the fund unless the former spouse elects to receive it instead of any survivor annuity to which the former spouse may be entitled under this or any other retirement system for Government employees on the basis of a marriage to someone other than the participant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1590501-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2035/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1590502-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2035/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time limit; waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An annuity under this section shall not be payable unless appropriate written application is provided to the Director, complete with any supporting documentation which the Director may by regulation require, not later than ","children":[{"tag":"date","attrib":{"date":"1990-06-02"},"text":"June 2, 1990","children":[],"tail":". The Director may waive the application deadline under the preceding sentence in any case in which the Director determines that the circumstances warrant such a waiver."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1590503-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2035/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retroactive benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon approval of an application under subparagraph (A), the appropriate annuity shall be payable to the former spouse with respect to all periods before such approval during which the former spouse was entitled to an annuity under this section, but in no event shall an annuity be payable under this section with respect to any period before ","children":[{"tag":"date","attrib":{"date":"1987-12-02"},"text":"December 2, 1987","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1590504-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2035/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restoration of annuities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (c)(4)(A), the deadline by which an application for a retirement annuity must be submitted shall not apply in cases in which a former spouse’s entitlement to such annuity is restored under subsection (b)(1) or (c)(1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1590505-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2035/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to impair, reduce, or otherwise affect the annuity or the entitlement to an annuity of a participant or former participant under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1590506-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/tII/s225"},"text":"Pub. L. 88–643, title II, § 225","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s802"},"text":"Pub. L. 102–496, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3218"},"text":"106 Stat. 3218","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/178/tII/s202/a/7"},"text":"Pub. L. 103–178, title II, § 202(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2026"},"text":"107 Stat. 2026","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1590507-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1590508-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd1590509-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/s225"},"text":"section 225 of Pub. L. 88–643","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/178/tIV/s401/a"},"text":"Pub. L. 100–178, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-02"},"text":"Dec. 2, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1012"},"text":"101 Stat. 1012","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/453/tIII/s302/c/1"},"text":"Pub. L. 100–453, title III, § 302(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1907"},"text":"102 Stat. 1907","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/88/tIII/s307/b"},"text":"Pub. L. 102–88, title III, § 307(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/433"},"text":"105 Stat. 433","children":[],"tail":", related to retirement benefits for certain other former spouses and was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403"},"text":"section 403 of this title","children":[],"tail":" prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/88/643"},"text":"Pub. L. 88–643","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s802"},"text":"section 802 of Pub. L. 102–496","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd159050a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/178/s202/a/7/A"},"text":"Pub. L. 103–178, § 202(a)(7)(A)","children":[],"tail":", substituted “any survivor annuity” for “any other annuity”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/178/s202/a/7/B"},"text":"Pub. L. 103–178, § 202(a)(7)(B)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1990-06-02"},"text":"June 2, 1990","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1991-06-02"},"text":"June 2, 1991","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd159050b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd159050c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/178"},"text":"Pub. L. 103–178","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-02-01"},"text":"Feb. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/178/s202/b"},"text":"section 202(b) of Pub. L. 103–178","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd159050d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of fourth month beginning after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s805"},"text":"section 805 of Pub. L. 102–496","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
