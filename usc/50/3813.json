{"tag":"section","attrib":{"id":"idd204d4d0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3813"},"text":null,"children":[{"tag":"num","attrib":{"value":"3813"},"text":"§ 3813.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of requirements of this chapter; voluntary enlistments unaffected","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd204d4d1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3813/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deeming of notice upon publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every person shall be deemed to have notice of the requirements of this chapter upon publication by the President of a proclamation or other public notice fixing a time for any registration under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3802"},"text":"section 3802 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd204d4d2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3813/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duty to inform local board of current address and changes in status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be the duty of every registrant to keep his local board informed as to his current address and changes in status as required by such rules and regulations as may be prescribed by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd204d4d3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3813/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separability of provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any provision of this chapter, or the application thereof to any person or circumstance, is held invalid, the remainder of the chapter, and the application of such provision to other persons or circumstances, shall not be affected thereby.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd204d4d4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3813/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary enlistments or reenlistments; absence of affect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3803/c"},"text":"section 3803(c) of this title","children":[],"tail":", nothing contained in this chapter shall be construed to repeal, amend, or suspend the laws now in force authorizing voluntary enlistment or reenlistment in the Armed Forces of the United States, including the reserve components thereof, except that no person shall be accepted for enlistment after he has been issued an order to report for induction unless authorized by the Director and the Secretary of Defense and except that, whenever the Congress or the President has declared that the national interest is imperiled, voluntary enlistment or reenlistment in such forces, and their reserve components, may be suspended by the President to such extent as he may deem necessary in the interest of national defense."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd204d4d5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3813/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Furnishing of names and addresses to Secretary of Defense or Secretary of Homeland Security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to assist the Armed Forces in recruiting individuals for voluntary service in the Armed Forces, the Director shall, upon the request of the Secretary of Defense or the Secretary of Homeland Security, furnish to the Secretary the full names, email addresses (if available), dates of birth, phone numbers (if available), and mailing addresses of individuals registered under this Act. Full names, email addresses, dates of birth, phone numbers, and mailing addresses furnished pursuant to the preceding sentence may be used by the Secretary of Defense or Secretary of Homeland Security only for recruiting purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd204d4d6-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-24/ch625"},"text":"June 24, 1948, ch. 625","children":[],"tail":", title I, § 15, "},{"tag":"ref","attrib":{"href":"/us/stat/62/624"},"text":"62 Stat. 624","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/129/tI/s101/a/33"},"text":"Pub. L. 92–129, title I, § 101(a)(33)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-09-28"},"text":"Sept. 28, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/353"},"text":"85 Stat. 353","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/86/tIX/s916/c"},"text":"Pub. L. 97–86, title IX, § 916(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-01"},"text":"Dec. 1, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1129"},"text":"95 Stat. 1129","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/e/11/E"},"text":"Pub. L. 107–296, title XVII, § 1704(e)(11)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2316"},"text":"116 Stat. 2316","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s532/a"},"text":"Pub. L. 118–159, div. A, title V, § 532(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1886"},"text":"138 Stat. 1886","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tV/s535/b/5"},"text":"Pub. L. 119–60, div. A, title V, § 535(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/872"},"text":"139 Stat. 872","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd204d4d7-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"idd204d4d8-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendment of Subsection (a)","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tV/s535/b/5"},"text":"Pub. L. 119–60, div. A, title V, § 535(b)(5)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/872"},"text":"139 Stat. 872","children":[],"tail":", provided that, effective one year after "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", subsection (a) of this section is amended by striking “upon publication by the President of a proclamation or other public notice fixing a time for any registration under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3802"},"text":"section 3802 of this title","children":[],"tail":"”. See 2025 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd204d4d9-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd204d4da-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a), (c), and (d), was in the original “this title”, meaning title I of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-24/ch625"},"text":"act June 24, 1948, ch. 625","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/604"},"text":"62 Stat. 604","children":[],"tail":", which is classified principally to this chapter. For complete classification of title I to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (e), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-24/ch625"},"text":"act June 24, 1948, ch. 625","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/604"},"text":"62 Stat. 604","children":[],"tail":", known as the Military Selective Service Act. For complete classification of this Act to the Code, see References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3801"},"text":"section 3801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd204d4db-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 465 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd204d4dc-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" struck out “upon publication by the President of a proclamation or other public notice fixing a time for any registration under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3802"},"text":"section 3802 of this title","children":[],"tail":"” after “this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2024—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" substituted “the full names, email addresses (if available), dates of birth, phone numbers (if available), and mailing addresses” for “the names and addresses” and “Full names, email addresses, dates of birth, phone numbers, and mailing addresses furnished” for “Names and addresses furnished”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “of Homeland Security” for “of Transportation” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/86"},"text":"Pub. L. 97–86","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1971—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/129"},"text":"Pub. L. 92–129","children":[],"tail":" inserted provision empowering the Director and the Secretary of Defense to authorize voluntary enlistments and reenlistments in the Armed Forces after a person has been issued an order to report for induction and struck out reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3803/g"},"text":"section 3803(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd204d4dd-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd204d4de-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" effective one year after "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s535/c"},"text":"section 535(c) of Pub. L. 119–60","children":[],"tail":", set out as an Effective Date of Repeal note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3802"},"text":"section 3802 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd204d4df-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2024 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s532/b"},"text":"Pub. L. 118–159, div. A, title V, § 532(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1887"},"text":"138 Stat. 1887","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dA/tV/s532/b"},"text":"“The amendments made by this section [amending this section] shall take effect 120 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd204d4e0-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective on the date of transfer of the Coast Guard to the Department of Homeland Security, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1704/g"},"text":"section 1704(g) of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
