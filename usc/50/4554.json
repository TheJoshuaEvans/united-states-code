,"tail":"; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(4) with respect to addressing the national energy emergency declared under Ex. Ord. No. 14156, ","children":[{"tag":"date","attrib":{"date":"2025-01-20"},"text":"Jan. 20, 2025","children":[],"tail":", 90 F.R. 8433, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1621"},"text":"section 1621 of this title","children":[],"tail":", delegated to the Chief Executive Officer of the United States International Development Finance Corporation, see section 6(d) of Ex. Ord. No. 14241, "},{"tag":"date","attrib":{"date":"2025-03-20"},"text":"Mar. 20, 2025","children":[],"tail":", 90 F.R. 13673, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1601"},"text":"section 1601 of Title 30","children":[],"tail":", Mineral Lands and Mining."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under this chapter relating to production, conservation, use, control, distribution, and allocation of energy, delegated to Secretary of Energy, see section 4 of Ex. Ord. No. 11790, eff. ","children":[{"tag":"date","attrib":{"date":"1974-06-25"},"text":"June 25, 1974","children":[],"tail":", 39 F.R. 23185, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s761"},"text":"section 761 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
