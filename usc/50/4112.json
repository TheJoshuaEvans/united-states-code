{"tag":"section","attrib":{"id":"idd2130660-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4112"},"text":null,"children":[{"tag":"num","attrib":{"value":"4112"},"text":"§ 4112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States citizens serving in allied forces","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2130661-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission is authorized to receive and to determine, according to law, the amount and validity, and provide for the payment of any claim for compensation filed by or on behalf of any individual who, being then an American citizen, served in the military or naval forces of any government allied with the United States during World War II who was held as a prisoner of war for any period of time subsequent to ","children":[{"tag":"date","attrib":{"date":"1941-12-07"},"text":"December 7, 1941","children":[],"tail":", by any government of any nation with which such allied government has been at war subsequent to such date. Compensation shall be payable under this section in accordance with the standards established by, and at the rates prescribed in, subsection (b) of "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4105"},"text":"section 4105 of this title","children":[],"tail":", and paragraphs (2) and (3) of subsection (d) of such section 4105."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2130662-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deductions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount payable under this section shall be reduced by such sum as the individual entitled to compensation under this section has received or is entitled to receive from any government by reason of the same detention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2130663-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4112/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments on death","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event of death of the individual entitled to compensation under this section, payment may be made to the persons specified in paragraph (4) of subsection (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4105"},"text":"section 4105 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2130664-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4112/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing date for claims","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Claims for benefits under this section must be filed within one year after ","children":[{"tag":"date","attrib":{"date":"1954-08-31"},"text":"August 31, 1954","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2130665-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4112/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of claim for payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any claim allowed under the provisions of this section shall be certified to the Secretary of the Treasury for payment out of the War Claims Fund established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4110"},"text":"section 4110 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2130666-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-07-03/ch826"},"text":"July 3, 1948, ch. 826","children":[],"tail":", title I, § 15, as added "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-31/ch1162"},"text":"Aug. 31, 1954, ch. 1162","children":[],"tail":", title I, § 103, "},{"tag":"ref","attrib":{"href":"/us/stat/68/1034"},"text":"68 Stat. 1034","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/87/846/tI/s102"},"text":"Pub. L. 87–846, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-22"},"text":"Oct. 22, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1107"},"text":"76 Stat. 1107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2130667-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2130668-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd2130669-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 2014 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd213066a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/846"},"text":"Pub. L. 87–846","children":[],"tail":" made technical amendment to reference in original act which appears in text of subsecs. (a) and (c) as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4105"},"text":"section 4105 of this title","children":[],"tail":" and in subsec. (e) as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4110"},"text":"section 4110 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd213066b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idd213066c-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For provisions transferring Foreign Claims Settlement Commission of the United States to Department of Justice, as a separate agency, see section 1622a et seq. of Title 22, Foreign Relations and Intercourse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
