{"tag":"section","attrib":{"id":"idd1c2006d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3227a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3227a"},"text":"§ 3227a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Degree-granting authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1c2006e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3227a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning on the transfer date, under regulations prescribed by the Director of National Intelligence, the President of the National Intelligence University may, upon the recommendation of the faculty of the University, confer appropriate degrees upon graduates who meet the degree requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c2006f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3227a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A degree may not be conferred under this section unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c20070-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3227a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Education has recommended approval of the degree in accordance with the Federal Policy Governing Granting of Academic Degrees by Federal Agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c20071-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3227a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the University is accredited by the appropriate academic accrediting agency or organization to award the degree, as determined by the Secretary of Education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1c20072-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title X, § 1032, as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dW/tIII/s305/a"},"text":"Pub. L. 116–260, div. W, title III, § 305(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2366"},"text":"134 Stat. 2366","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tIII/s7327/c"},"text":"Pub. L. 118–31, div. G, title III, § 7327(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1045"},"text":"137 Stat. 1045","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1c20073-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1c20074-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1c20075-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" struck out subsec. (c) which related to congressional notification requirements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
