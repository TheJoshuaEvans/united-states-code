{"tag":"section","attrib":{"id":"idd16c178f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2423"},"text":null,"children":[{"tag":"num","attrib":{"value":"2423"},"text":"§ 2423.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counterintelligence programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd16c1790-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2423/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National security laboratories and nuclear weapons production facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy shall, at each national security laboratory and nuclear weapons production facility, establish and maintain a counterintelligence program adequate to protect national security information at that laboratory or production facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16c1791-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2423/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy shall, at each Department facility not described in subsection (a) at which Restricted Data is located, assign an employee of the Office of Intelligence and Counterintelligence of the Department of Energy who shall be responsible for and assess counterintelligence matters at that facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd16c1792-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dC/tXXXII/s3233"},"text":"Pub. L. 106–65, div. C, title XXXII, § 3233","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/961"},"text":"113 Stat. 961","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dC/tXXXI/s3117/a/2/C"},"text":"Pub. L. 109–364, div. C, title XXXI, § 3117(a)(2)(C)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2507"},"text":"120 Stat. 2507","children":[],"tail":", 2508; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dC/tXXXI/s3121"},"text":"Pub. L. 111–84, div. C, title XXXI, § 3121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2710"},"text":"123 Stat. 2710","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLXVII/s6744/a"},"text":"Pub. L. 116–92, div. E, title LXVII, § 6744(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2241"},"text":"133 Stat. 2241","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd16c1793-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd16c1794-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd16c1795-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “Department facility” for “Administration facility” and inserted “Intelligence and” after “the Office of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/s3117/a"},"text":"Pub. L. 109–364, § 3117(a)","children":[],"tail":", see 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s3117/a"},"text":"Pub. L. 109–364, § 3117(a)","children":[],"tail":", which, in par. (2), directed amendment of this section by substituting “Administrator” for “Secretary of Energy” in subsecs. (a) and (b) and “Administration” for “Office of Counterintelligence of the Department of Energy” in subsec. (b), effective "},{"tag":"date","attrib":{"date":"2010-09-30"},"text":"Sept. 30, 2010","children":[],"tail":", was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":", and as so amended, no longer contains a par. (2) or amends this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s3117/c"},"text":"Pub. L. 109–364, § 3117(c)","children":[],"tail":", substituted “Secretary of Energy” for “Administrator” in subsecs. (a) and (b) and “Office of Counterintelligence of the Department of Energy” for “Office of Defense Nuclear Counterintelligence” in subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd16c1796-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":