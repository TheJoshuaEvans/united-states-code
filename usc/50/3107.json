{"tag":"section","attrib":{"id":"idd1aa3240-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3107"},"text":null,"children":[{"tag":"num","attrib":{"value":"3107"},"text":"§ 3107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of compliance with oversight requirements","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The head of each element of the intelligence community shall annually submit to the congressional intelligence committees—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1aa3241-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3107/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a certification that, to the best of the knowledge of the head of such element—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1aa3242-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3107/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of such element is in full compliance with the requirements of this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1aa3243-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3107/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any information required to be submitted by the head of such element under this chapter before the date of the submission of such certification has been properly submitted; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1aa3244-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3107/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the head of such element is unable to submit a certification under paragraph (1), a statement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1aa3245-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3107/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the reasons the head of such element is unable to submit such a certification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1aa3246-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3107/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing any information required to be submitted by the head of such element under this chapter before the date of the submission of such statement that has not been properly submitted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1aa3247-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3107/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the head of such element will submit such information as soon as possible after the submission of such statement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1aa3248-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title V, § 508, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/tIII/s332/a"},"text":"Pub. L. 111–259, title III, § 332(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2686"},"text":"124 Stat. 2686","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1aa3249-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1aa324a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1aa324b-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in pars. (1)(B) and (2)(B), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"act July 26, 1947, ch. 343","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/495"},"text":"61 Stat. 495","children":[],"tail":", known as the National Security Act of 1947, which is classified principally to this chapter. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1aa324c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s415d"},"text":"section 415d of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1aa324d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1aa324e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/tIII/s332/b"},"text":"Pub. L. 111–259, title III, § 332(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2687"},"text":"124 Stat. 2687","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/259/tIII/s332/b"},"text":"“The first certification or statement required to be submitted by the head of each element of the intelligence community under section 508 of the National Security Act of 1947 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3107"},"text":"50 U.S.C. 3107","children":[],"tail":"], as added by subsection (a), shall be submitted not later than 90 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “intelligence community” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s332/b"},"text":"section 332(b) of Pub. L. 111–259","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/s2"},"text":"section 2 of Pub. L. 111–259","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
