{"tag":"section","attrib":{"id":"idd1603192-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2156"},"text":null,"children":[{"tag":"num","attrib":{"value":"2156"},"text":"§ 2156.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1603193-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2156/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall prescribe in regulations appropriate procedures to carry out this subchapter. Such regulations shall be prescribed in consultation with the Director of the Office of Personnel Management and the Executive Director of the Federal Retirement Thrift Investment Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1603194-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2156/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall submit regulations prescribed under subsection (a) to the congressional intelligence committees before they take effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1603195-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/tIII/s306"},"text":"Pub. L. 88–643, title III, § 306","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s802"},"text":"Pub. L. 102–496, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"te