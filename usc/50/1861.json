{"tag":"section","attrib":{"id":"idd145f13c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1861"},"text":null,"children":[{"tag":"num","attrib":{"value":"1861"},"text":"§ 1861.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd145f13d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1861/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “foreign power”, “agent of a foreign power”, “foreign intelligence information”, “international terrorism”, and “Attorney General” shall have the same meanings as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801"},"text":"section 1801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd145f13e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1861/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “common carrier” means any person or entity transporting people or property by land, rail, water, or air for compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd145f13f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1861/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “physical storage facility” means any business or entity that provides space for the storage of goods or materials, or services related to the storage of goods or materials, to the public or any segment thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd145f140-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1861/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “public accommodation facility” means any inn, hotel, motel, or other establishment that provides lodging to transient guests.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd145f141-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1861/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “vehicle rental facility” means any person or entity that provides vehicles for rent, lease, loan, or other similar use to the public or any segment thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd145f142-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511/tV/s501"},"text":"Pub. L. 95–511, title V, § 501","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tII/s215"},"text":"Pub. L. 107–56, title II, § 215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/287"},"text":"115 Stat. 287","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/108/tIII/s314/a/6"},"text":"Pub. L. 107–108, title III, § 314(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1402"},"text":"115 Stat. 1402","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/tI"},"text":"Pub. L. 109–177, title I","children":[],"tail":", §§ 102(b)(1), 106(a)–(e), (f)(2), (g), "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/195-198"},"text":"120 Stat. 195