 directed to this section as it read prior to such reversion and were executed as if the reversion had not taken place, to reflect the probable intent of Congress and the extension of the provisions of this section to "},{"tag":"date","attrib":{"date":"2019-12-15"},"text":"Dec. 15, 2019","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/114/23/s705/a"},"text":"Pub. L. 114–23, § 705(a)","children":[],"tail":", (c). See 2015 Amendment notes below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd145f146-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1861, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511/tV/s501"},"text":"Pub. L. 95–511, title V, § 501","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/272/tVI/s602"},"text":"Pub. L. 105–272, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-20"},"text":"Oct. 20, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2410"},"text":"112 Stat. 2410","children":[],"tail":", defined terms used in this subchapter, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tII/s215"},"text":"Pub. L. 107–56, title II, § 215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/287"},"text":"115 Stat. 287","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd145f147-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/69"},"text":"Pub. L. 116–69","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/s102/b/1"},"text":"Pub. L. 109–177, § 102(b)(1)","children":[],"tail":". See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/118"},"text":"Pub. L. 115–118","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s705/a"},"text":"Pub. L. 114–23, § 705(a)","children":[],"tail":", (c), amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/s102/b/1"},"text":"Pub. L. 109–177, § 102(b)(1)","children":[],"tail":". See Codification note above and 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s103/a"},"text":"Pub. L. 114–23, § 103(a)","children":[],"tail":", added subpar. (A). Former subpar. (A) redesignated (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s101/a/1/A"},"text":"Pub. L. 114–23, § 101(a)(1)(A)","children":[],"tail":", substituted “in the case of an application other than an application described in subparagraph (C) (including an application for the production of call detail records other than in the manner described in subparagraph (C)), a statement” for “a statement” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s101/a/1/B"},"text":"Pub. L. 114–23, § 101(a)(1)(B)","children":[],"tail":", struck out “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s101/a/2"},"text":"Pub. L. 114–23, § 101(a)(2)","children":[],"tail":", redesignated subpar. (A) as (B). Former subpar. (B) redesignated (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s101/a/3"},"text":"Pub. L. 114–23, § 101(a)(3)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s101/a/2"},"text":"Pub. L. 114–23, § 101(a)(2)","children":[],"tail":", redesignated subpar. (B) as (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s104/a/1"},"text":"Pub. L. 114–23, § 104(a)(1)","children":[],"tail":", inserted “and that the minimization procedures submitted in accordance with subsection (b)(2)(D) meet the definition of minimization procedures under subsection (g)” after “subsections (a) and (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s103/b/1"},"text":"Pub. L. 114–23, § 103(b)(1)","children":[],"tail":", inserted before semicolon at end “, including each specific selection term to be used as the basis for the production”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s101/b"},"text":"Pub. L. 114–23, § 101(b)","children":[],"tail":", added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s103/b/2"},"text":"Pub. L. 114–23, § 103(b)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s102/b/1/A"},"text":"Pub. L. 114–23, § 102(b)(1)(A)","children":[],"tail":", substituted “pursuant to an order issued or an emergency production required” for “pursuant to an order” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s102/b/1/B"},"text":"Pub. L. 114–23, § 102(b)(1)(B)","children":[],"tail":", substituted “such order or such emergency production” for “such order”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s102/b/1/C"},"text":"Pub. L. 114–23, § 102(b)(1)(C)","children":[],"tail":", substituted “the order or the emergency production” for “the order”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s102/b/2/A"},"text":"Pub. L. 114–23, § 102(b)(2)(A)","children":[],"tail":", substituted “an order or emergency production” for “an order”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s102/b/2/B"},"text":"Pub. L. 114–23, § 102(b)(2)(B)","children":[],"tail":", substituted “an order or emergency production” for “an order”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s105"},"text":"Pub. L. 114–23, § 105","children":[],"tail":", amended subsec. (e) generally. Prior to amendment, text read as follows: “A person who, in good faith, produces tangible things under an order pursuant to this section shall not be liable to any other person for such production. Such production shall not be deemed to constitute a waiver of any privilege in any other proceeding or context.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s104/b/1"},"text":"Pub. L. 114–23, § 104(b)(1)","children":[],"tail":", substituted “the production order or any nondisclosure order imposed in connection with the production order” for “that order” and struck out at end “Not less than 1 year after the date of the issuance of the production order, the recipient of a production order may challenge the nondisclosure order imposed in connection with such production order by filing a petition to modify or set aside such nondisclosure order, consistent with the requirements of subparagraph (C), with the pool established by "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1803/e/1"},"text":"section 1803(e)(1) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2)(C)(ii), (iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s104/b/2"},"text":"Pub. L. 114–23, § 104(b)(2)","children":[],"tail":", redesignated cl. (iii) as (ii) and struck out former cl. (ii) which read as follows: “If, upon filing of such a petition, the Attorney General, Deputy Attorney General, an Assistant Attorney General, or the Director of the Federal Bureau of Investigation certifies that disclosure may endanger the national security of the United States or interfere with diplomatic relations, such certification shall be treated as conclusive, unless the judge finds that the certification was made in bad faith.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s104/a/3"},"text":"Pub. L. 114–23, § 104(a)(3)","children":[],"tail":", substituted “The” for “Not later than 180 days after "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"March 9, 2006","children":[],"tail":", the” and inserted “, and update as appropriate,” after “adopt”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s104/a/2"},"text":"Pub. L. 114–23, § 104(a)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s102/a"},"text":"Pub. L. 114–23, § 102(a)","children":[],"tail":", which directed adding subsec. (i) at the end of this section, effective after the addition of subsecs. (j) and (k), was executed by adding subsec. (i) after subsec. (h) to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s106"},"text":"Pub. L. 114–23, § 106","children":[],"tail":", added subsec. (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s107"},"text":"Pub. L. 114–23, § 107","children":[],"tail":", added subsec. (k)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/14"},"text":"Pub. L. 112–14","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/s102/b/1"},"text":"Pub. L. 109–177, § 102(b)(1)","children":[],"tail":". See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/3"},"text":"Pub. L. 112–3","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/s102/b/1"},"text":"Pub. L. 109–177, § 102(b)(1)","children":[],"tail":". See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/141"},"text":"Pub. L. 111–141","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/s102/b/1"},"text":"Pub. L. 109–177, § 102(b)(1)","children":[],"tail":". See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/118"},"text":"Pub. L. 111–118","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/s102/b/1"},"text":"Pub. L. 109–177, § 102(b)(1)","children":[],"tail":". See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s102/b/1"},"text":"Pub. L. 109–177, § 102(b)(1)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/118"},"text":"Pub. L. 111–118","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/111/141"},"text":"Pub. L. 111–141","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/112/3"},"text":"Pub. L. 112–3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/112/14"},"text":"Pub. L. 112–14","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/114/23/s705/a"},"text":"Pub. L. 114–23, § 705(a)","children":[],"tail":", (c), and "},{"tag":"ref","attrib":{"href":"/us/pl/116/69"},"text":"Pub. L. 116–69","children":[],"tail":", amended section effective "},{"tag":"date","attrib":{"date":"2020-03-15"},"text":"Mar. 15, 2020","children":[],"tail":", so as to read as it read on "},{"tag":"date","attrib":{"date":"2001-10-25"},"text":"Oct. 25, 2001","children":[],"tail":". Prior to amendment, section related to access to certain business records for foreign intelligence and international terrorism investigations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s106/a/1"},"text":"Pub. L. 109–177, § 106(a)(1)","children":[],"tail":", substituted “Subject to paragraph (3), the Director” for “The Director”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s106/a/2"},"text":"Pub. L. 109–177, § 106(a)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s106/b"},"text":"Pub. L. 109–177, § 106(b)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “shall specify that the records concerned are sought for an authorized investigation conducted in accordance with subsection (a)(2) to obtain foreign intelligence information not concerning a United States person or to protect against international terrorism or clandestine intelligence activities.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s106/c"},"text":"Pub. L. 109–177, § 106(c)","children":[],"tail":", (d), amended subsec. (c) generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Upon an application made pursuant to this section, the judge shall enter an ex parte order as requested, or as modified, approving the release of records if the judge finds that the application meets the requirements of this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) An order under this subsection shall not disclose that it is issued for purposes of an investigation described in subsection (a).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s106/e"},"text":"Pub. L. 109–177, § 106(e)","children":[],"tail":", amended subsec. (d) generally. Prior to amendment, text read as follows: “No person shall disclose to any other person (other than those persons necessary to produce the tangible things under this section) that the Federal Bureau of Investigation has sought or obtained tangible things under this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/178/s4/a"},"text":"Pub. L. 109–178, § 4(a)","children":[],"tail":", amended subpar. (C) generally. Prior to amendment, subpar. (C) read as follows: “At the request of the Director of the Federal Bureau of Investigation or the designee of the Director, any person making or intending to make a disclosure under this section shall identify to the Director or such designee the person to whom such disclosure will be made or to whom such disclosure was made prior to the request, but in no circumstance shall a person be required to inform the Director or such designee that the person intends to consult an attorney to obtain legal advice or legal assistance.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/178/s3"},"text":"Pub. L. 109–178, § 3","children":[],"tail":", amended subsec. (f) generally. Prior to amendment, subsec. (f) provided for judicial proceedings relating to challenging an order to produce tangible things."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s106/f/2"},"text":"Pub. L. 109–177, § 106(f)(2)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s106/g"},"text":"Pub. L. 109–177, § 106(g)","children":[],"tail":", added subsecs. (g) and (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/108"},"text":"Pub. L. 107–108","children":[],"tail":" inserted “to obtain foreign intelligence information not concerning a United States person or” after “an investigation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd145f148-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd145f149-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/tI/s109/a"},"text":"Pub. L. 114–23, title I, § 109(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-02"},"text":"June 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/276"},"text":"129 Stat. 276","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/23/tI/s109/a"},"text":"“The amendments made by sections 101 through 103 [amending this section] shall take effect on the date that is 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-06-02"},"text":"June 2, 2015","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd145f14a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s102/b/1"},"text":"section 102(b)(1) of Pub. L. 109–177","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2020-03-15"},"text":"Mar. 15, 2020","children":[],"tail":", except that former provisions to continue in effect with respect to any particular foreign intelligence investigation that began before "},{"tag":"date","attrib":{"date":"2020-03-15"},"text":"Mar. 15, 2020","children":[],"tail":", or with respect to any particular offense or potential offense that began or occurred before "},{"tag":"date","attrib":{"date":"2020-03-15"},"text":"Mar. 15, 2020","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/s102/b"},"text":"section 102(b) of Pub. L. 109–177","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1805"},"text":"section 1805 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd145f14b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23"},"text":"Pub. L. 114–23","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/tI/s109/b"},"text":"Pub. L. 114–23, title I, § 109(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-02"},"text":"June 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/276"},"text":"129 Stat. 276","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/23/tI/s109/b"},"text":"“Nothing in this Act [see Tables for classification] shall be construed to alter or eliminate the authority of the Government to obtain an order under title V of the Foreign Intelligence Surveillance Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1861"},"text":"50 U.S.C. 1861","children":[],"tail":" et seq.) as in effect prior to the effective date described in subsection (a) [see Effective Date of 2015 Amendment note above] during the period ending on such effective date.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/tI/s110"},"text":"Pub. L. 114–23, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-02"},"text":"June 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/276"},"text":"129 Stat. 276","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/23/tI/s110"},"text":"“Nothing in this Act [see Tables for classification] shall be construed to authorize the production of the contents (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2510/8"},"text":"section 2510(8) of title 18","children":[],"tail":", United States Code) of any electronic communication from an electronic communication service provider (as such term is defined in section 701(b)(4) of the Foreign Intelligence Surveillance Act of 1978 ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1881/b/4"},"text":"50 U.S.C. 1881(b)(4)","children":[],"tail":")) under title V of the Foreign Intelligence Surveillance Act of 1978 ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1861"},"text":"50 U.S.C. 1861","children":[],"tail":" et seq.).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
