{"tag":"section","attrib":{"id":"idd22d44d4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4535"},"text":null,"children":[{"tag":"num","attrib":{"value":"4535"},"text":"§ 4535.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports on exercise of authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd22d44d5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4535/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President, or the head of an agency to which the President has delegated authorities under this subchapter, shall submit a report and provide a briefing to the appropriate congressional committees with respect to any action taken pursuant to such authorities—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd22d44d6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4535/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided by paragraph (2), not later than 30 days after taking the action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd22d44d7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4535/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an action that involves a business concern in the United Kingdom or Australia, not later than 30 days before taking the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd22d44d8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4535/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd22d44d9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4535/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report and briefing required by subsection (a) with respect to an action described in that subsection shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd22d44da-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4535/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a justification of the necessity of the use of authorities under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd22d44db-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4535/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the financial terms of any related financial transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd22d44dc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4535/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional elements relating to business concerns in the United Kingdom or Australia","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report and briefing required by subsection (a) with respect to an action described in paragraph (2) of that subsection shall include, in addition to the elements under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd22d44dd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4535/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that business concerns in the United States or Canada were not available with respect to the action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd22d44de-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4535/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of why such business concerns were not available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd22d44df-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4535/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd22d44e0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4535/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Banking, Housing, and Urban Affairs of the Senate and the Committee on Financial Services of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd22d44e1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4535/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an action described in subsection (a) involving materials critical to national security (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4552/7/B/ii/II/bb"},"text":"section 4552(7)(B)(ii)(II)(bb) of this title","children":[],"tail":"), the Committee on Energy and Natural Resources of the Senate and the Committee on Natural Resources of the House of Representatives."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd22d44e2-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-08/ch932"},"text":"Sept. 8, 1950, ch. 932","children":[],"tail":", title III, § 305, as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tX/s1080/b"},"text":"Pub. L. 118–31, div. A, title X, § 1080(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/416"},"text":"137 Stat. 416","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd22d44e3-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd22d44e4-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd22d44e5-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 305 to 310 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-08/ch932"},"text":"act Sept. 8, 1950, ch. 932","children":[],"tail":", were omitted in the general amendment of title III of the Act by "},{"tag":"ref","attrib":{"href":"/us/pl/111/67"},"text":"Pub. L. 111–67","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 305, ","children":[{"tag":"ref","attrib":{"href":"/us/act/