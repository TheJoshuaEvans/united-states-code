{"tag":"section","attrib":{"id":"idd19e4af3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3055"},"text":null,"children":[{"tag":"num","attrib":{"value":"3055"},"text":"§ 3055.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on financial intelligence on terrorist assets","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd19e4af4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3055/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On an annual basis, the Secretary of the Treasury (acting through the head of the Office of Intelligence Support) shall submit a report to the appropriate congressional committees that fully informs the committees concerning operations against terrorist financial networks. Each such report shall include with respect to the preceding one-year period—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd19e4af5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3055/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of asset seizures, designations, and other actions against individuals or entities found to have engaged in financial support of terrorism;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd19e4af6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3055/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of physical searches of offices, residences, or financial records of individuals or entities suspected of having engaged in financial support for terrorist activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd19e4af7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3055/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the financial intelligence information seized in these cases has been shared on a full and timely basis with the all departments, agencies, and other entities of the United States Government involved in intelligence activities participating in the Foreign Terrorist Asset Tracking Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19e4af8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3055/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immediate notification for emergency designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a designation of an individual or entity, or the assets of an individual or entity, as having been found to have engaged in terrorist activities, the Secretary of the Treasury shall report such designation within 24 hours of such a designation to the appropriate congressional committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19e4af9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3055/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submittal date of reports to congressional intelligence committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of the reports required to be submitted under subsection (a) to the congressional intelligence committees, the submittal dates for such reports shall be as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3106"},"text":"section 3106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19e4afa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3055/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate congressional committees” means the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd19e4afb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3055/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Permanent Select Committee on Intelligence, the Committee on Appropriations, the Committee on Armed Services, and the Committee on Financial Services of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd19e4afc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3055/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Select Committee on Intelligence, the Committee on Appropriations, the Committee on Armed Services, and the Committee on Banking, Housing, and Urban Affairs of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd19e4afd-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title I, § 118, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/306/tIII/s342/a/1"},"text":"Pub. L. 107–306, title III, § 342(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2398"},"text":"116 Stat. 2398","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/tIII/s347/d"},"text":"Pub. L. 111–259, title III, § 347(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2698"},"text":"124 Stat. 2698","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dF/tLXVIII/s6824/a/3"},"text":"Pub. L. 117–263, div. F, title LXVIII, § 6824(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3615"},"text":"136 Stat. 3615","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd19e4afe-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"idd19e4aff-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For repeal of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s6801/a/1/A"},"text":"section 6801(a)(1)(A) of Pub. L. 119–60","children":[],"tail":", see Effective Date of Repeal note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd19e4b00-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd19e4b01-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s404m"},"text":"section 404m of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd19e4b02-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “an annual” for “a annual” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s347/d/1"},"text":"Pub. L. 111–259, § 347(d)(1)","children":[],"tail":", substituted “Annual” for “Semiannual” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s347/d/2/A"},"text":"Pub. L. 111–259, § 347(d)(2)(A)","children":[],"tail":", (B), in heading, substituted “Annual” for “Semiannual” and, in introductory provisions, substituted “annual basis” for “semiannual basis” and “preceding one-year period” for “preceding six-month period”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s347/d/2/C"},"text":"Pub. L. 111–259, § 347(d)(2)(C)","children":[],"tail":", (D), redesignated pars. (3) and (4) as (2) and (3), respectively, and struck out former par. (2) which read as follows: “the total number of applications for asset seizure and designations of individuals or entities suspected of having engaged in financial support of terrorist activities that were granted, modified, or denied;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s347/d/3"},"text":"Pub. L. 111–259, § 347(d)(3)","children":[],"tail":", inserted “the Committee on Armed Services,” after “the Committee on Appropriations,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd19e4b03-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd19e4b04-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of Repeal","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dF/tLXVIII/s6801/a/1/C"},"text":"Pub. L. 119–60, div. F, title LXVIII, § 6801(a)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1652"},"text":"139 Stat. 1652","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dF/tLXVIII/s6801/a/1/C"},"text":"“The amendments made by subparagraphs (A) and (B) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3106"},"text":"section 3106 of this title","children":[],"tail":" and repealing this section] shall take effect on "},{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
