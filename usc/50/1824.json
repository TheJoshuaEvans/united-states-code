{"tag":"section","attrib":{"id":"idd141374d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824"},"text":null,"children":[{"tag":"num","attrib":{"value":"1824"},"text":"§ 1824.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of order","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd141374e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Necessary findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon an application made pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1823"},"text":"section 1823 of this title","children":[],"tail":", the judge shall enter an ex parte order as requested or as modified approving the physical search if the judge finds that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd141374f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application has been made by a Federal officer and approved by the Attorney General;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1413750-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" on the basis of the facts submitted by the applicant there is probable cause to believe that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1413751-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the target of the physical search is a foreign power or an agent of a foreign power, except that no United States person may be considered an agent of a foreign power solely upon the basis of activities protected by the first amendment to the Constitution of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1413752-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the premises or property to be searched is or is about to be owned, used, possessed by, or is in transit to or from an agent of a foreign power or a foreign power;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1413753-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed minimization procedures meet the definition of minimization contained in this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1413754-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application which has been filed contains all statements and certifications required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1823"},"text":"section 1823 of this title","children":[],"tail":", and, if the target is a United States person, the certification or certifications are not clearly erroneous on the basis of the statement made under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1823/a/6/E"},"text":"section 1823(a)(6)(E) of this title","children":[],"tail":" and any other information furnished under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1823/c"},"text":"section 1823(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1413755-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of probable cause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining whether or not probable cause exists for purposes of an order under subsection (a)(2), a judge may consider past activities of the target, as well as facts and circumstances relating to current or future activities of the target.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1413756-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specifications and directions of orders","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An order approving a physical search under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1413757-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" specify—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1413758-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity, if known, or a description of the target of the physical search;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1413759-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature and location of each of the premises or property to be searched;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd141375a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of information, material, or property to be seized, altered, or reproduced;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd141375b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the manner in which the physical search is to be conducted and, whenever more than one physical search is authorized under the order, the authorized scope of each search and what minimization procedures shall apply to the information acquired by each search; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd141375c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period of time during which physical searches are approved; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd141375d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" direct—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd141375e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the minimization procedures be followed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd141375f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that, upon the request of the applicant, a specified landlord, custodian, or other specified person furnish the applicant forthwith all information, facilities, or assistance necessary to accomplish the physical search in such a manner as will protect its secrecy and produce a minimum of interference with the services that such landlord, custodian, or other person is providing the target of the physical search;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1413760-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that such landlord, custodian, or other person maintain under security procedures approved by the Attorney General and the Director of National Intelligence any records concerning the search or the aid furnished that such person wishes to retain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1413761-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the applicant compensate, at the prevailing rate, such landlord, custodian, or other person for furnishing such aid; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1413762-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the Federal officer conducting the physical search promptly report to the court the circumstances and results of the physical search.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1413763-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of order; assessment of compliance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1413764-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An order issued under this section may approve a physical search for the period necessary to achieve its purpose, or for 90 days, whichever is less, except that (A) an order under this section shall approve a physical search targeted against a foreign power for the period specified in the application or for one year, whichever is less, and (B) an order under this section for a physical search targeted against an agent of a foreign power who is not a United States person may be for the period specified in the application or for one year, whichever is less.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1413765-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At or before the end of the period of time for which a physical search is approved by an order or an extension, or at any time after a physical search is carried out, the judge may assess compliance with the minimization procedures by reviewing the circumstances under which information concerning United States persons was acquired, retained, or disseminated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1413766-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency orders","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1413767-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any other provision of this subchapter, the Attorney General may authorize the emergency employment of a physical search if the Attorney General—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1413768-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonably determines that an emergency situation exists with respect to the employment of a physical search to obtain foreign intelligence information before an order authorizing such physical search can with due diligence be obtained;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1413769-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonably determines that the factual basis for issuance of an order under this subchapter to approve such physical search exists;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd141376a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" informs, either personally or through a designee, a judge of the Foreign Intelligence Surveillance Court at the time of such authorization that the decision has been made to employ an emergency physical search; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd141376b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes an application in accordance with this subchapter to a judge of the Foreign Intelligence Surveillance Court as soon as practicable, but not more than 7 days after the Attorney General authorizes such physical search.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd141376c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Attorney General authorizes the emergency employment of a physical search under paragraph (1), the Attorney General shall require that the minimization procedures required by this subchapter for the issuance of a judicial order be followed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd141376d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the absence of a judicial order approving such physical search, the physical search shall terminate when the information sought is obtained, when the application for the order is denied, or after the expiration of 7 days from the time of authorization by the Attorney General, whichever is earliest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd141376e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A denial of the application made under this subsection may be reviewed as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1803"},"text":"section 1803 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd141376f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the event that such application for approval is denied, or in any other case where the physical search is terminated and no order is issued approving the physical search, no information obtained or evidence derived from such physical search shall be received in evidence or otherwise disclosed in any trial, hearing, or other proceeding in or before any court, grand jury, department, office, agency, regulatory body, legislative committee, or other authority of the United States, a State, or political subdivision thereof, and no information concerning any United States person acquired from such physical search shall subsequently be used or disclosed in any other manner by Federal officers or employees without the consent of such person, except with the approval of the Attorney General if the information indicates a threat of death or serious bodily harm to any person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1413770-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General shall assess compliance with the requirements of paragraph (5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1413771-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1824/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention of applications and orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Applications made and orders granted under this subchapter shall be retained for a period of at least 10 years from the date of the application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1413772-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511/tIII/s304"},"text":"Pub. L. 95–511, title III, § 304","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/359/tVIII/s807/a/3"},"text":"Pub. L. 103–359, title VIII, § 807(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-14"},"text":"Oct. 14, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3447"},"text":"108 Stat. 3447","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/567/tVI/s603/b"},"text":"Pub. L. 106–567, title VI, § 603(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2853"},"text":"114 Stat. 2853","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tII/s207/a/2"},"text":"Pub. L. 107–56, title II, § 207(a)(2)","children":[],"tail":", (b)(2), "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/282"},"text":"115 Stat. 282","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/108/tIII/s314/a/4"},"text":"Pub. L. 107–108, title III, § 314(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1402"},"text":"115 Stat. 1402","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI/s1071/e"},"text":"Pub. L. 108–458, title I, § 1071(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3691"},"text":"118 Stat. 3691","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/tI/s105/b"},"text":"Pub. L. 109–177, title I, § 105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/195"},"text":"120 Stat. 195","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/261/tI"},"text":"Pub. L. 110–261, title I","children":[],"tail":", §§ 107(b), (c)(1), 110(c)(3), "},{"tag":"date","attrib":{"date":"2008-07-10"},"text":"July 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2463"},"text":"122 Stat. 2463","children":[],"tail":", 2464, 2467; "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/tVIII"},"text":"Pub. L. 111–259, title VIII","children":[],"tail":", §§ 801(5), 806(a)(2), "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2746"},"text":"124 Stat. 2746","children":[],"tail":", 2748; "},{"tag":"ref","attrib":{"href":"/us/pl/118/49/s6/g/2"},"text":"Pub. L. 118–49, § 6(g)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-20"},"text":"Apr. 20, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/873"},"text":"138 Stat. 873","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1413773-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1413774-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1413775-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/49/s6/g/2/A/i"},"text":"Pub. L. 118–49, § 6(g)(2)(A)(i)","children":[],"tail":", substituted “against a foreign power” for “against a foreign power, as defined in paragraph (1), (2), or (3) of "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801/a"},"text":"section 1801(a) of this title","children":[],"tail":",”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/49/s6/g/2/A/ii"},"text":"Pub. L. 118–49, § 6(g)(2)(A)(ii)","children":[],"tail":", substituted “one year” for “120 days”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/49/s6/g/2/B"},"text":"Pub. L. 118–49, § 6(g)(2)(B)","children":[],"tail":", (C), redesignated par. (3) as (2) and struck out former par. (2) which read as follows: “Extensions of an order issued under this subchapter may be granted on the same basis as the original order upon an application for an extension and new findings made in the same manner as required for the original order, except that an extension of an order under this chapter for a physical search targeted against a foreign power, as defined in paragraph (5), (6), or (7) of "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801/a"},"text":"section 1801(a) of this title","children":[],"tail":", or against a foreign power, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801/a/4"},"text":"section 1801(a)(4) of this title","children":[],"tail":", that is not a United States person, or against an agent of a foreign power who is not a United States person, may be for a period not to exceed one year if the judge finds probable cause to believe that no property of any individual United States person will be acquired during the period.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s801/5"},"text":"Pub. L. 111–259, § 801(5)","children":[],"tail":", substituted “subsection (a)(2)” for “subsection (a)(3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s806/a/2"},"text":"Pub. L. 111–259, § 806(a)(2)","children":[],"tail":", made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":". See 2004 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/261/s107/b/1"},"text":"Pub. L. 110–261, § 107(b)(1)","children":[],"tail":", (c)(1), redesignated pars. (2) to (5) as (1) to (4), respectively, inserted “or is about to be” before “owned” in par. (2)(B), substituted “1823(a)(6)(E)” for “1823(a)(7)(E)” in par. (4), and struck out former par. (1) which read as follows: “the President has authorized the Attorney General to approve applications for physical searches for foreign intelligence purposes;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/261/s110/c/3"},"text":"Pub. L. 110–261, § 110(c)(3)","children":[],"tail":", substituted “paragraph (5), (6), or (7) of section 1801(a)” for “section 1801(a)(5) or (6)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/261/s107/b/2"},"text":"Pub. L. 110–261, § 107(b)(2)","children":[],"tail":", amended subsec. (e) generally. Prior to amendment, subsec. (e) related to the power of the Attorney General to authorize the emergency employment of a physical search and required an application be made to a judge within 72 hours after the authorization."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (d)(1)(B), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177"},"text":"Pub. L. 109–177","children":[],"tail":" substituted “who is not a United States person” for “as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801/b/1/A"},"text":"section 1801(b)(1)(A) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/s806/a/2"},"text":"Pub. L. 111–259, § 806(a)(2)","children":[],"tail":", substituted “Director of National Intelligence” for “Director of Central Intelligence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s207/a/2"},"text":"Pub. L. 107–56, § 207(a)(2)","children":[],"tail":", substituted “90 days,” for “forty-five days,” and inserted “(A)” after “except that” and “, and (B) an order under this section for a physical search targeted against an agent of a foreign power as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801/b/1/A"},"text":"section 1801(b)(1)(A) of this title","children":[],"tail":" may be for the period specified in the application or for 120 days, whichever is less” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s207/b/2"},"text":"Pub. L. 107–56, § 207(b)(2)","children":[],"tail":", inserted “or against an agent of a foreign power as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801/b/1/A"},"text":"section 1801(b)(1)(A) of this title","children":[],"tail":",” after “not a United States person,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(A)(ii), (3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/108"},"text":"Pub. L. 107–108","children":[],"tail":" substituted “72 hours” for “24 hours”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsecs. (b) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/567"},"text":"Pub. L. 106–567","children":[],"tail":" added subsec. (b) and redesignated former subsecs. (b) to (e) as (c) to (f), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1413776-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd1413777-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/261"},"text":"Pub. L. 110–261","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-07-10"},"text":"July 10, 2008","children":[],"tail":", except as provided in "},{"tag":"ref","attrib":{"href":"/us/pl/110/261/s404"},"text":"section 404 of Pub. L. 110–261","children":[],"tail":", set out as a Transition Procedures note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801"},"text":"section 1801 of this title","children":[],"tail":", see "},{"tag"