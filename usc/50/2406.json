{"tag":"section","attrib":{"id":"idd169ce11-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2406"},"text":null,"children":[{"tag":"num","attrib":{"value":"2406"},"text":"§ 2406.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deputy Administrator for Naval Reactors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd169ce12-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2406/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd169ce13-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2406/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is in the Administration a Deputy Administrator for Naval Reactors. The director of the Naval Nuclear Propulsion Program provided for under the Naval Nuclear Propulsion Executive Order shall serve as the Deputy Administrator for Naval Reactors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd169ce14-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2406/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within the Department of Energy, the Deputy Administrator shall report to the Secretary of Energy through the Administrator and shall have direct access to the Secretary and other senior officials in the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd169ce15-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2406/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Deputy Administrator shall be assigned the responsibilities, authorities, and accountability for all functions of the Office of Naval Reactors under the Naval Nuclear Propulsion Executive Order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd169ce16-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2406/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on Executive Order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise specified in this section and notwithstanding any other provision of this chapter, the provisions of the Naval Nuclear Propulsion Executive Order remain in full force and effect until changed by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd169ce17-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2406/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Naval Nuclear Propulsion Executive Order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the Naval Nuclear Propulsion Executive Order is Executive Order No. 12344, dated ","children":[{"tag":"date","attrib":{"date":"1982-02-01"},"text":"February 1, 1982","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7158"},"text":"42 U.S.C. 7158","children":[],"tail":" note) "},{"tag":"ref","attrib":{"idref":"fn002059"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002059"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" (as in force pursuant to section 1634 