{"tag":"section","attrib":{"id":"idd137c110-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1710"},"text":null,"children":[{"tag":"num","attrib":{"value":"1710"},"text":"§ 1710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confronting asymmetric and malicious cyber activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd137c111-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1710/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On and after the date that is 180 days after ","children":[{"tag":"date","attrib":{"date":"2024-04-24"},"text":"April 24, 2024","children":[],"tail":", the President may impose the sanctions described in subsection (b) with respect to any foreign person that the Secretary of the Treasury, in consultation with the Attorney General and the Secretary of State determine, on or after "},{"tag":"date","attrib":{"date":"2024-04-24"},"text":"April 24, 2024","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd137c112-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1710/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is responsible for or complicit in, or has engaged knowingly in, significant cyber-enabled activities originating from, or directed by persons located, in whole or in substantial part, outside the United States that are reasonably likely to result in, or have materially contributed to, a significant threat to the national security, foreign policy, or economic health or financial stability of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd137c113-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1710/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" materially assisted, sponsored, or provided financial, material, or technological support for, or goods or services to or in support of, any activity described in this subsection or any person whose property and interests in property are blocked pursuant to this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd137c114-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1710/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is owned or controlled by, or has acted or purported to act for or on behalf of, directly or indirectly, any person whose property and interests in property are blocked pursuant to this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd137c115-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1710/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has attempted to engage in any of the activities described in paragraph (1), (2), or (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd137c116-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1710/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The sanctions described in this subsection are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd137c117-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1710/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inadmissibility to United States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an alien—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd137c118-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1710/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ineligibility to receive a visa to enter the United States or to be admitted to the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd137c119-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1710/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the individual has been issued a visa or other documentation, revocation, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1201/i"},"text":"section 1201(i) of title 8","children":[],"tail":", of the visa or other documentation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd137c11a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1710/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Blocking of property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The blocking, in accordance with the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" et seq.), of all transactions in all property and interests in property of a foreign person if such property and interests in property are in the United States, come within the United States, or are or come within the possession or control of a United States person."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd137c11b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1710/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests by appropriate congressional committees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd137c11c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1710/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after receiving a request that meets the requirements of paragraph (2) with respect to whether a foreign person has engaged in an activity described in subsection (a), the Secretary of the Treasury, in consultation with the Attorney General and the Secretary of State shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd137c11d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1710/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine if that person has engaged in such an activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd137c11e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1710/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit a classified or unclassified report to the chairperson and ranking member of the committee or committees that submitted the request with respect to that determination that includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd137c11f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1710/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of whether or not the Secretary of the Treasury, in consultation with the Attorney General and the Secretary of State imposed or intends to impose sanctions with respect to the person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd137c120-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1710/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the President imposed or intends to impose sanctions, a description of those sanctions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd137c121-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1710/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the President does not intend to impose sanctions, a description of actions that meet the threshold for the President to impose sanctions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd137c122-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1710/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A request under paragraph (1) with respect to whether a foreign person has engaged in an activity described in subsection (a) shall be submitted to the President in writing jointly by the chairperson and ranking member of one of the appropriate congressional committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd137c123-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1710/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd137c124-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1710/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs, the Committee on Financial Services, and the Committee on the Judiciary of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd137c125-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1710/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations, the Committee on the Judiciary, and the Committee on Banking, Housing, and Urban Affairs of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd137c126-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/50/dO/s5"},"text":"Pub. L. 118–50, div. O, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-24"},"text":"Apr. 24, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/990"},"text":"138 Stat. 990","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd137c127-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd137c128-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd137c129-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The International Emergency Economic Powers Act, referred to in subsec. (b)(2), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/223"},"text":"Pub. L. 95–223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-28"},"text":"Dec. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1626"},"text":"91 Stat. 1626","children":[],"tail":", which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd137c12a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Strengthening Tools to Counter the Use of Human Shields Act, and not as part of the International Emergency Economic Powers Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idd137c12b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd137c12c-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, § 6(a), ","children":[{"tag":"date","attrib":{"date":"2024-09-13"},"text":"Sept. 13, 2024","children":[],"tail":", 89 F.R. 77758, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"I hereby delegate to the Secretary of the Treasury, in consultation with the Secretary of State and the Attorney General, the functions and authorities vested in the President by section 5(a) of the Strengthening Tools to Counter the Use of Human Shields Act (Division O of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/50"},"text":"Public Law 118–50","children":[],"tail":") (the “Countering Use of Human Shields Act”) ["},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1710/a"},"text":"50 U.S.C. 1710(a)","children":[],"tail":"]."}],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"J.R. Biden, Jr.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
