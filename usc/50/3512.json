{"tag":"section","attrib":{"id":"idd1e5b49a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512"},"text":null,"children":[{"tag":"num","attrib":{"value":"3512"},"text":"§ 3512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gifts, devises, and bequests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1e5b49b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use for operational purposes prohibited","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1e5b49c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the provisions of this section, the Director may accept, hold, administer, and use gifts of money, securities, or other property whenever the Director determines it would be in the interest of the United States to do so.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1e5b49d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any gift accepted by the Director as a gift to the Agency under this subsection (and any income produced by any such gift)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1e5b49e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may be used only for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1e5b49f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" artistic display;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1e5b4a0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purposes relating to the general welfare, education, or recreation of employees or dependents of employees of the Agency or for similar purposes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1e5b4a1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purposes relating to the welfare, education, or recreation of an individual described in paragraph (3); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1e5b4a2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under no circumstances may such a gift (or any income produced by any such gift) be used for operational purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1e5b4a3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An individual described in this paragraph is an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1e5b4a4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is an employee or a former employee of the Agency who suffered injury or illness while employed by the Agency that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1e5b4a5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resulted from hostile or terrorist activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1e5b4a6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" occurred in connection with an intelligence activity having a significant element of risk; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1e5b4a7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512/a/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" occurred under other circumstances determined by the Director to be analogous to the circumstances described in clause (i) or (ii);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1e5b4a8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a family member of such an employee or former employee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1e5b4a9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a surviving family member of an employee of the Agency who died in circumstances described in clause (i), (ii), or (iii) of subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1e5b4aa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director may not accept any gift under this section that is expressly conditioned upon any expenditure not to be met from the gift itself or from income produced by the gift unless such expenditure has been authorized by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1e5b4ab-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director may, in the Director’s discretion, determine that an individual described in subparagraph (A) or (B) of paragraph (3) may accept a gift for the purposes described in paragraph (2)(A)(iii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1e5b4ac-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale, exchange and investment of gifts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless otherwise restricted by the terms of the gift, the Director may sell or exchange, or invest or reinvest, any property which is accepted under subsection (a), but any such investment may only be in interest-bearing obligations of the United States or in obligations guaranteed as to both principal and interest by the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1e5b4ad-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of gifts into special fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby created on the books of the Treasury of the United States a fund into which gifts of money, securities, and other intangible property accepted under the authority of subsection (a), and the earnings and proceeds thereof, shall be deposited. The assets of such fund shall be disbursed upon the order of the Director for the purposes specified in subsection (a) or (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1e5b4ae-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxation of gifts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of Federal income, estate, and gift taxes, gifts accepted by the Director under subsection (a) shall be considered to be to or for the use of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1e5b4af-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Gift” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this section, the term “gift” includes a bequest or devise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1e5b4b0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fundraising","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1e5b4b1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director may engage in fundraising in an official capacity for the benefit of nonprofit organizations that provide support to surviving family members of deceased Agency employees or that otherwise provide support for the welfare, education, or recreation of Agency employees, former Agency employees, or their family members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1e5b4b2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this subsection, the term “fundraising” means the raising of funds through the active participation in the promotion, production, or presentation of an event designed to raise funds and does not include the direct solicitation of money by any other means.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1e5b4b3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than the date that is 7 days after the date the Director engages in fundraising authorized by this subsection or at the time the decision is made to participate in such fundraising, the Director shall notify the Select Committee on Intelligence of the Senate and the Permanent Select Committee on Intelligence of the House of Representatives of the fundraising.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1e5b4b4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director, in consultation with the Director of the Office of Government Ethics, shall issue regulations to carry out the authority provided in this section. Such regulations shall ensure that such authority is exercised consistent with all relevant ethical constraints and principles, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1e5b4b5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the avoidance of any prohibited conflict of interest or appearance of impropriety; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1e5b4b6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3512/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a prohibition against the acceptance of a gift from a foreign government or an agent of a foreign government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1e5b4b7-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-20/ch227/s12"},"text":"June 20, 1949, ch. 227, § 12","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/450/tIV/s404"},"text":"Pub. L. 96–450, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1979"},"text":"94 Stat. 1979","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/87/tIV/s411"},"text":"Pub. L. 112–87, title IV, § 411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-01-03"},"text":"Jan. 3, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1889"},"text":"125 Stat. 1889","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/126/tIV/s421"},"text":"Pub. L. 113–126, title IV, § 421","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-07"},"text":"July 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1410"},"text":"128 Stat. 1410","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/31/dN/tIII/s303/b"},"text":"Pub. L. 115–31, div. N, title III, § 303(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/810"},"text":"131 Stat. 810","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tIX/s7901/g/3"},"text":"Pub. L. 118–31, div. G, title IX, § 7901(g)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1107"},"text":"137 Stat. 1107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1e5b4b8-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1e5b4b9-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1e5b4ba-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 403","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1e5b4bb-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" struck out closing quotation marks after “used only for—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31"},"text":"Pub. L. 115–31","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/126/s421/1"},"text":"Pub. L. 113–126, § 421(1)","children":[],"tail":", substituted “Gifts, devises, and bequests” for “Authority to accept gifts, devises, and bequests” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/126/s421/2"},"text":"Pub. L. 113–126, § 421(2)","children":[],"tail":", in introductory provisions, inserted “by the Director as a gift to the Agency” after “accepted” and substituted “this subsection” for “this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/126/s421/3"},"text":"Pub. L. 113–126, § 421(3)","children":[],"tail":", (4), substituted “subsection (a),” for “this section,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/126/s421/5"},"text":"Pub. L. 113–126, § 421(5)","children":[],"tail":", substituted “subsection (a)” for “this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/126/s421/6"},"text":"Pub. L. 113–126, § 421(6)","children":[],"tail":", (7), added subsec. (f) and redesignated former subsec. (f) as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/87/s411/1"},"text":"Pub. L. 112–87, § 411(1)","children":[],"tail":", designated existing provisions as par. (1), struck out “Any gift accepted under this section (and any income produced by any such gift) may be used only for artistic display or for purposes relating to the general welfare, education, or recreation of employees or dependents of employees of the Agency or for similar purposes, and under no circumstances may such a gift (or any income produced by any such gift) be used for operational purposes. The Director may not accept any gift under this section which is expressly conditioned upon any expenditure not to be met from the gift itself or from income produced by the gift unless such expenditure has been authorized by law.” at end, and added pars. (2) to (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/87/s411/2"},"text":"Pub. L. 112–87, § 411(2)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
