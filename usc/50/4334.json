{"tag":"section","attrib":{"id":"idd22618f0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4334"},"text":null,"children":[{"tag":"num","attrib":{"value":"4334"},"text":"§ 4334.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insurance of property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Alien Property Custodian may procure insurance in such amounts, and from such insurers, as he believes will adequately protect him against loss in connection with property or interest or proceeds held by him.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd22618f1-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-10-06/ch106/s37"},"text":"Oct. 6, 1917, ch. 106, § 37","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1941-12-18/ch593"},"text":"Dec. 18, 1941, ch. 593","children":[],"tail":", title III, § 305, as added "},{"tag":"ref","attrib":{"href":"/us/act/1946-08-08/ch878/s1"},"text":"Aug. 8, 1946, ch. 878, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/930"},"text":"60 Stat. 930","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd22618f2-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd22618f3-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd22618f4-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 37 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior to classification as section 37, section was formerly classified to section 620 of the former Appendix to this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idd22618f5-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idd22618f6-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions vested by law in Alien Property Custodian and Office of Alien Property Custodian transferred to Attorney General by Reorg. Plan No. 1 of 1947, § 101, eff. ","children":[{"tag":"date","attrib":{"date":"1947-07-01"},"text":"July 1, 1947","children":[],"tail":", 12 F.R. 4534, "},{"tag":"ref","attrib":{"href":"/us/stat/61/951"},"text":"61 Stat. 951","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
