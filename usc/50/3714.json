{"tag":"section","attrib":{"id":"idd1f67d10-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3714"},"text":null,"children":[{"tag":"num","attrib":{"value":"3714"},"text":"§ 3714.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds for unspecified purposes or for increased amounts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1f67d11-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3714/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to Congress of intent to use funds for unspecified purposes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1f67d12-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3714/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For any fiscal year for which Cooperative Threat Reduction funds are specifically authorized in an Act other than an appropriations Act for specific purposes within the Program, the Secretary of Defense may obligate or expend such funds, or other funds otherwise made available for the Program for that fiscal year, for purposes other than such specified purposes if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1f67d13-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3714/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that such obligation or expenditure is necessary in the national interests of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f67d14-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3714/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary submits to the congressional defense committees—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1f67d15-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3714/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notification of the intent of the Secretary to make such an obligation or expenditure of funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1f67d16-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3714/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a complete discussion of the purpose and justification for such obligation or expenditure, including the amount of funds to be obligated or expended; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f67d17-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3714/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of 15 days has elapsed following the date on which the Secretary submits the notification and discussion under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67d18-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3714/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction with other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) may not be construed to authorize the obligation or expenditure of Cooperative Threat Reduction Program funds for a purpose for which the obligation or expenditure of such funds is specifically prohibited under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3731"},"text":"section 3731 of this title","children":[],"tail":" or any other provision of law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f67d19-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3714/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited authority to vary individual amounts provided for any fiscal year for specified purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For any fiscal year for which Cooperative Threat Reduction funds are specifically authorized in an Act other than an appropriations Act for specific purposes within the Program, the Secretary may obligate or expend such funds, or other funds otherwise made available for the Program for that fiscal year, in excess of the specific amount so authorized for that purpose if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1f67d1a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3714/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that such obligation or expenditure is necessary in the national interests of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67d1b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3714/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary submits to the congressional defense committees—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1f67d1c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3714/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notification of the intent of the Secretary to make such an obligation or expenditure of funds in excess of such authorized amount; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f67d1d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3714/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a complete discussion of the justification for exceeding such specified amounts, including the amount by which the Secretary will exceed such specified amounts; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67d1e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3714/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of 15 days has elapsed following the date on which the Secretary submits the notification and discussion under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1f67d1f-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tXIII/s1324"},"text":"Pub. L. 113–291, div. A, title XIII, § 1324","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3599"},"text":"128 Stat. 3599","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXIII/s1302/b/4"},"text":"Pub. L. 114–328, div. A, title XIII, § 1302(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2566"},"text":"130 Stat. 2566","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tXIII/s1302/b/2"},"text":"Pub. L. 115–91, div. A, title XIII, § 1302(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1705"},"text":"131 Stat. 1705","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1f67d20-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1f67d21-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1f67d22-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsecs. (a)(1)(C), (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" substituted “15 days” for “45 days”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsecs. (a)(1)(C), (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" substituted “45 days” for “15 days”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
