{"tag":"section","attrib":{"id":"idd100d365-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s797"},"text":null,"children":[{"tag":"num","attrib":{"value":"797"},"text":"§ 797.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for violation of security regulations and orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd100d366-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s797/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Misdemeanor violation of defense property security regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd100d367-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s797/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Misdemeanor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whoever willfully violates any defense property security regulation shall be fined under title 18 or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd100d368-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s797/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defense property security regulation described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), a defense property security regulation is a property security regulation that, pursuant to lawful authority—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd100d369-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s797/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be or has been promulgated or approved by the Secretary of Defense (or by a military commander designated by the Secretary of Defense or by a military officer, or a civilian officer or employee of the Department of Defense, holding a senior Department of Defense director position designated by the Secretary of Defense) for the protection or security of Department of Defense property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd100d36a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s797/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be or has been promulgated or approved by the Administrator of the National Aeronautics and Space Administration for the protection or security of NASA property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd100d36b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s797/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property security regulation described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (2), a property security regulation, with respect to any property, is a regulation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd100d36c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s797/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relating to fire hazards, fire protection, lighting, machinery, guard service, disrepair, disuse, or other unsatisfactory conditions on such property, or the ingress thereto or egress or removal of persons therefrom; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd100d36d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s797/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise providing for safeguarding such property against destruction, loss, or injury by accident or by enemy action, sabotage, or other subversive actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd100d36e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s797/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd100d36f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s797/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Defense property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Department of Defense property” means covered property subject to the jurisdiction, administration, or in the custody of the Department of Defense, any Department or agency of which that Department consists, or any officer or employee of that Department or agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd100d370-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s797/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NASA property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “NASA property” means covered property subject to the jurisdiction, administration, or in the custody of the National Aeronautics and Space Administration or any officer or employee thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd100d371-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s797/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered property” means aircraft, airports, airport facilities, vessels, harbors, ports, piers, water-front facilities, bases, forts, posts, laboratories, stations, vehicles, equipment, explosives, or other property or places.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd100d372-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s797/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulation as including order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “regulation” includes an order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd100d373-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s797/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Posting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any regulation or order covered by subsection (a) shall be posted in conspicuous and appropriate places.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd100d374-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-23/ch1024"},"text":"Sept. 23, 1950, ch. 1024","children":[],"tail":", title I, § 21, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1005"},"text":"64 Stat. 1005","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1053"},"text":"Pub. L. 109–163, div. A, title X, § 1053","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3435"},"text":"119 Stat. 3435","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd100d375-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd100d376-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd100d377-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" amended section generally. Prior to amendment, section related to security regulations and orders and penalties for violations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
