{"tag":"section","attrib":{"id":"idd1675c27-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2357f"},"text":null,"children":[{"tag":"num","attrib":{"value":"2357f"},"text":"§ 2357f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statutory construction","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Nothing in this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1675c28-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2357f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applies to the data-gathering, regulatory, or enforcement authority of any existing United States department or agency over nonproliferation efforts in the independent states of the former Soviet Union, and the review of those efforts undertaken by the coordination mechanism established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2357b"},"text":"section 2357b of this title","children":[],"tail":" shall not in any way supersede or prejudice any other process provided by law; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1675c29-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2357f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applies to any activity that is reportable pursuant to title V of the National Security Act of 1947 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3091"},"text":"50 U.S.C. 3091","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1675c2a-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228/dB/tXIII/s1338"},"text":"Pub. L. 107–228, div. B, title XIII, § 1338","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1451"},"text":"116 Stat. 1451","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1675c2b-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1675c2c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1675c2d-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Security Act of 1947, referred to in par. (2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"act July 26, 1947, ch. 343","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/495"},"text":"61 Stat. 495","children":[],"tail":", which was formerly classified principally to chapter 15 (§ 401 et seq.) of this title, prior to editorial reclassification in chapter 44 (§ 3001 et seq.) of this title. Title V of the Act is now classified generally to subchapter III (§ 3091 et seq.) of chapter 44 of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
