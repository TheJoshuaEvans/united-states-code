{"tag":"section","attrib":{"id":"idd1ef517a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3526"},"text":null,"children":[{"tag":"num","attrib":{"value":"3526"},"text":"§ 3526.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improvement of education in science, technology, engineering, arts, and mathematics","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1ef517b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3526/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ef517c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3526/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible entity” includes a department or agency of the Federal Government, a State, a political subdivision of a State, an individual, and a not-for-profit or other organization in the private sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ef517d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3526/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “educational institution” includes any public or private elementary school or secondary school, institution of higher education, college, university, or any other profit or nonprofit institution that is dedicated to improving science, technology, engineering, the arts, mathematics, business, law, medicine, or other fields that promote development and education relating to science, technology, engineering, the arts, or mathematics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ef517e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3526/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States, the District of Columbia, the Commonwealth of Puerto Rico, the Commonwealth of the Northern Mariana Islands, and any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ef517f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3526/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall, on a continuing basis—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ef5180-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3526/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify actions that the Director may take to improve education in the scientific, technology, engineering, arts, and mathematics (known as “STEAM”) skills necessary to meet the long-term national security needs of the United States for personnel proficient in such skills; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ef5181-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3526/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and conduct programs to carry out such actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ef5182-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3526/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ef5183-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3526/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director, in support of educational programs in science, technology, engineering, the arts, and mathematics, may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1ef5184-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3526/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award grants to eligible entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ef5185-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3526/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide cash awards and other items to eligible entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ef5186-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3526/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept voluntary services from eligible entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ef5187-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3526/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support national competition judging, other educational event activities, and associated award ceremonies in connection with such educational programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ef5188-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3526/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into one or more education partnership agreements with educational institutions in the United States for the purpose of encouraging and enhancing study in science, technology, engineering, the arts, and mathematics disciplines at all levels of education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ef5189-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3526/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education partnership agreements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1ef518a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3526/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nature of assistance provided","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under an education partnership agreement entered into with an educational institution under paragraph (1)(E), the Director may provide assistance to the educational institution by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1ef518b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3526/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" loaning equipment to the educational institution for any purpose and duration in support of such agreement that the Director considers appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef518c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3526/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making personnel available to teach science courses or to assist in the development of science courses and materials for the educational institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef518d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3526/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing sabbatical opportunities for faculty and internship opportunities for students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef518e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3526/c/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involving faculty and students of the educational institution in Agency projects, including research and technology transfer or transition projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef518f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3526/c/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperating with the educational institution in developing a program under which students may be given academic credit for work on Agency projects, including research and technology transfer for transition projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef5190-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3526/c/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing academic and career advice and assistance to students of the educational institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ef5191-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3526/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In entering into education partnership agreements under paragraph (1)(E), the Director shall prioritize entering into education partnership agreements with the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1ef5192-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3526/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Historically Black colleges and universities and other minority-serving institutions, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1067q/a"},"text":"section 1067q(a) of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef5193-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3526/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Educational institutions serving women, members of minority groups, and other groups of individuals who traditionally are involved in the science, technology, engineering, arts, and mathematics professions in disproportionately low numbers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ef5194-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3526/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of advisor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall designate one or more individuals within the Agency to advise and assist the Director regarding matters relating to science, technology, engineering, the arts, and mathematics education and training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1ef5195-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-20/ch227/s25"},"text":"June 20, 1949, ch. 227, § 25","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dW/tV/s501"},"text":"Pub. L. 116–260, div. W, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2380"},"text":"134 Stat. 2380","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
