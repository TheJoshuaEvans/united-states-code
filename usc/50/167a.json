{"tag":"section","attrib":{"id":"idd0f4eb3f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167a"},"text":null,"children":[{"tag":"num","attrib":{"value":"167a"},"text":"§ 167a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd0f4eb40-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extraction and disposal of helium on Federal lands","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0f4eb41-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into agreements with private parties for the recovery and disposal of helium on Federal lands upon such terms and conditions as the Secretary deems fair, reasonable, and necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f4eb42-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leasehold rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may grant leasehold rights to any such helium.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f4eb43-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not enter into any agreement by which the Secretary sells such helium other than to a private party with whom the Secretary has an agreement for recovery and disposal of helium.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f4eb44-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Agreements under paragraph (1) may be subject to such regulations as may be prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f4eb45-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An agreement under paragraph (1) shall be subject to any rights of any affected Federal oil and gas lessee that may be in existence prior to the date of the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f4eb46-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An agreement under paragraph (1) (and any extension or renewal of an agreement) shall contain such terms and conditions as the Secretary may consider appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f4eb47-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167a/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall not in any manner affect or diminish the rights and obligations of the Secretary and private parties under agreements to dispose of helium produced from Federal lands in existence on ","children":[{"tag":"date","attrib":{"date":"1996-10-09"},"text":"October 9, 1996","children":[],"tail":", except to the extent that such agreements are renewed or extended after "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"October 9, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0f4eb48-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Storage, transportation, and sale","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may store, transport, and sell helium only in accordance with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0f4eb49-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extraction of helium from deposits on Federal land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All amounts received by the Secretary from the sale or disposition of helium on Federal land shall be credited to the Helium Production Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s167d/e"},"text":"section 167d(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd0f4eb4a-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1925-03-03/ch426/s3"},"text":"Mar. 3, 1925, ch. 426, § 3","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/86/777/s2"},"text":"Pub. L. 86–777, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-13"},"text":"Sept. 13, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/918"},"text":"74 Stat. 918","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/273/s3"},"text":"Pub. L. 104–273, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3315"},"text":"110 Stat. 3315","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/40/s3"},"text":"Pub. L. 113–40, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-10-02"},"text":"Oct. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/535"},"text":"127 Stat. 535","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd0f4eb4b-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd0f4eb4c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd0f4eb4d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3 of act ","children":[{"tag":"date","attrib":{"date":"1925-03-03"},"text":"Mar. 3, 1925","children":[],"tail":", related to disposal of helium by sale, use of funds so obtained, and reports to Congress on such uses and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s164"},"text":"section 164 of this title","children":[],"tail":", prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/86/777"},"text":"Pub. L. 86–777","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd0f4eb4e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/40"},"text":"Pub. L. 113–40","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/273"},"text":"Pub. L. 104–273","children":[],"tail":" amended section generally. Prior to amendment, section enumerated various aspects of Secretary’s authority, including provisions in subsec. (a) relating to conserving, producing, buying, and selling helium, in subsec. (b) relating to helium on public domain, and in subsec. (c) relating to contract price for helium."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
