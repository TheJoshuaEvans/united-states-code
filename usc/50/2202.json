{"tag":"section","attrib":{"id":"idd16031ae-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2202"},"text":null,"children":[{"tag":"num","attrib":{"value":"2202"},"text":"§ 2202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on transfers to countries which support terrorism","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Spoils of war in the possession, custody, or control of the United States may not be transferred to any country determined by the Secretary of State, for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2780"},"text":"section 2780 of title 22","children":[],"tail":", to be a nation whose government has repeatedly provided support for acts of international terrorism."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd16031af-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tV/s553"},"text":"Pub. L. 103–236, title V, § 553","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/482"},"text":"108 Stat. 482","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
