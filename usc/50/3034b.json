{"tag":"section","attrib":{"id":"idd1971eec-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3034b"},"text":"§ 3034b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intelligence Community Chief Data Officer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1971eed-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intelligence Community Chief Data Officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is an Intelligence Community Chief Data Officer within the Office of the Director of National Intelligence who shall be appointed by the Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1971eee-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement relating to appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual appointed as the Intelligence Community Chief Data Officer shall have a professional background and experience appropriate for the duties of the Intelligence Community Chief Data Officer. In making such appointment, the Director of National Intelligence may give preference to an individual with experience outside of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1971eef-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Intelligence Community Chief Data Officer shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1971ef0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" act as the chief representative of the Director of National Intelligence for data issues within the intelligence community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1971ef1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate, to the extent practicable and advisable, with the Chief Data Officer of the Department of Defense to ensure consistent data policies, standards, and procedures between the intelligence community and the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1971ef2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the Director of National Intelligence regarding data elements of the budget of the Office of the Director of National Intelligence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1971ef3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform other such duties relating to data as may be prescribed by the Director of National Intelligence or specified in law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1971ef4-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title I, § 103K, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dF/tLXVII/s6704"},"text":"Pub. L. 117–263, div. F, title LXVII, § 6704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3562"},"text":"136 Stat. 3562","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tIII/s7310/b/1"},"text":"Pub. L. 118–31, div. G, title III, § 7310(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1028"},"text":"137 Stat. 1028","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1971ef5-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1971ef6-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1971ef7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" inserted “relating to data” after “duties”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1971ef8-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1971ef9-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Removal of Unrelated Duties and Functions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tIII/s7310/b/2"},"text":"Pub. L. 118–31, div. G, title III, § 7310(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1028"},"text":"137 Stat. 1028","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dG/tIII/s7310/b/2"},"text":"“Not later than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":"], consistent with section 103K(c) of the National Security Act of 1947 ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3034b/c"},"text":"50 U.S.C. 3034b(c)","children":[],"tail":"), as amended by paragraph (1), the Director of National Intelligence shall complete such internal reorganization of the Office of the Director of National Intelligence as the Director determines necessary to ensure that the duties of the Intelligence Community Chief Data Officer appointed under such section do not include any other duty that does not relate to an issue involving data.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
