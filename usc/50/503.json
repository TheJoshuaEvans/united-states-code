{"tag":"section","attrib":{"id":"idd0fe8919-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s503"},"text":null,"children":[{"tag":"num","attrib":{"value":"503"},"text":"§ 503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated, out of any money in the Treasury not otherwise appropriated, not to exceed $75,000,000 to carry out the purposes of sections 501 and 502 of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd0fe891a-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-05-11/ch98/s3"},"text":"May 11, 1949, ch. 98, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/66"},"text":"63 Stat. 66","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
