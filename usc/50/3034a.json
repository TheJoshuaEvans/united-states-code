{"tag":"section","attrib":{"id":"idd194aee5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3034a"},"text":"§ 3034a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functional Managers for the intelligence community","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd194aee6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functional Managers authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence may establish within the intelligence community one or more positions of manager of an intelligence function. Any position so established may be known as the “Functional Manager” of the intelligence function concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd194aee7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall designate individuals to serve as manager of intelligence functions established under subsection (a) from among officers and employees of elements of the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd194aee8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each manager of an intelligence function established under subsection (a) shall have the duties as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd194aee9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To act as principal advisor to the Director on the intelligence function.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1971eea-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To carry out such other responsibilities with respect to the intelligence function as the Director may specify for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1971eeb-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title I, § 103J, as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/126/tIII/s305/a"},"text":"Pub. L. 113–126, title III, § 305(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-07"},"text":"July 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1395"},"text":"128 Stat. 1395","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
