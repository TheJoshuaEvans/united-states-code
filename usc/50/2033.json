en":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s805"},"text":"section 805 of Pub. L. 102–496","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
