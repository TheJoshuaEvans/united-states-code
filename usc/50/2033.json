{"tag":"section","attrib":{"id":"idd15904bc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2033"},"text":null,"children":[{"tag":"num","attrib":{"value":"2033"},"text":"§ 2033.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election of survivor benefits for certain former spouses divorced as of ","children":[{"tag":"date","attrib":{"date":"1982-11-15"},"text":"November 15, 1982","children":[],"tail":null}],"tail":null},{"tag":"subsection","attrib":{"id":"idd15904bd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2033/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Former spouses as of ","children":[{"tag":"date","attrib":{"date":"1982-11-15"},"text":"November 15, 1982","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A participant, former participant, or retired participant in the system who on ","children":[{"tag":"date","attrib":{"date":"1982-11-15"},"text":"November 15, 1982","children":[],"tail":", had a former spouse may, by a spousal agreement, elect to receive a reduced annuity and provide a survivor annuity for such former spouse under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2032/b"},"text":"section 2032(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15904be-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2033/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for making election","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15904bf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2033/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the participant or former participant has not retired under such system on or before ","children":[{"tag":"date","attrib":{"date":"1982-11-15"},"text":"November 15, 1982","children":[],"tail":", an election under this section may be made at any time before retirement."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15904c0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2033/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the participant or former participant has retired under such system on or before ","children":[{"tag":"date","attrib":{"date":"1982-11-15"},"text":"November 15, 1982","children":[],"tail":", an election under this section may be made within such period after "},{"tag":"date","attrib":{"date":"1982-11-15"},"text":"November 15, 1982","children":[],"tail":", as the Director may prescribe."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15904c1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2033/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of applying this subchapter, any such election shall be treated in the same manner as if it were a spousal agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2094/b"},"text":"section 2094(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15904c2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2033/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Base for annuity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under this section may provide for a survivor annuity based on all or any portion of that part of the annuity of the participant which is not designated or committed as a base for a survivor annuity for a spouse or any other former spouse of the participant. The participant and the participant’s spouse may make an election under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2031/b/1/B"},"text":"section 2031(b)(1)(B) of this title","children":[],"tail":" before the time of retirement for the purpose of allowing an election to be made under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15904c3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2033/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction in participant’s annuity","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15904c4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2033/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the reduction in the participant’s annuity shall be determined in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2031/b/2"},"text":"section 2031(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15904c5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2033/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of reduction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such reduction shall be effective as of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd15904c6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2033/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the commencing date of the participant’s annuity, in the case of an election under subsection (b)(1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd15904c7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2033/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"1982-11-15"},"text":"November 15, 1982","children":[],"tail":", in the case of an election under subsection (b)(2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd15904c8-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/tII/s223"},"text":"Pub. L. 88–643, title II, § 223","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s802"},"text":"Pub. L. 102–496, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3216"},"text":"106 Stat. 3216","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd15904c9-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd15904ca-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd15904cb-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"te