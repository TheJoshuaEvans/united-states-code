{"tag":"section","attrib":{"id":"idd1675c2e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2357g"},"text":null,"children":[{"tag":"num","attrib":{"value":"2357g"},"text":"§ 2357g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting and consultation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1675c2f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2357g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after each inauguration of a President, the President shall submit a report to the Congress on his general and specific nonproliferation and threat reduction objectives and how the efforts of executive branch agencies will be coordinated most effectively, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2357b"},"text":"section 2357b of this title","children":[],"tail":", to achieve those objectives."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1675c30-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2357g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President should consult with and brief, from time to time, the appropriate committees of Congress regarding the efficacy of the coordination mechanism established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2357b"},"text":"section 2357b of this title","children":[],"tail":" in achieving its stated objectives."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1675c31-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228/dB/tXIII/s1339"},"text":"Pub. L. 107–228, div. B, title XIII, § 1339","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1451"},"text":"116 Stat. 1451","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
