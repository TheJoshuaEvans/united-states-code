{"tag":"section","attrib":{"id":"idd14f8ef9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881h"},"text":null,"children":[{"tag":"num","attrib":{"value":"1881h"},"text":"§ 1881h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties for unauthorized disclosure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd14f8efa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person is guilty of an offense under this section if that person knowingly and willfully communicates, furnishes, transmits, or otherwise makes available to an unauthorized person, or publishes, or uses in any manner prejudicial to the safety or interest of the United States or for the benefit of any foreign government to the detriment of the United States any classified information that contains the contents of any communication acquired under this subchapter to which a known United States person is a party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd14f8efb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person guilty of an offense in this section shall be fined under title 18, imprisoned for not more than 8 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd14f8efc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is Federal jurisdiction over an offense under this section if the person committing the offense was an officer or employee of the United States at the time the offense was committed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd14f8efd-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511/tVII/s709"},"text":"Pub. L. 95–511, title VII, § 709","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/49/s13/c"},"text":"Pub. L. 118–49, § 13(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-20"},"text":"Apr. 20, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/882"},"text":"138 Stat. 882","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd14f8efe-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"idd14f8eff-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/261/tIV/s403/b/1"},"text":"Pub. L. 110–261, title IV, § 403(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-10"},"text":"July 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2474"},"text":"122 Stat. 2474","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/112/238/s2/a/1"},"text":"Pub. L. 112–238, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-30"},"text":"Dec. 30, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1631"},"text":"126 Stat. 1631",