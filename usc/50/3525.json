{"tag":"section","attrib":{"id":"idd1ef5160-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3525"},"text":null,"children":[{"tag":"num","attrib":{"value":"3525"},"text":"§ 3525.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of the Ombudsman for Analytic Objectivity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1ef5161-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3525/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ef5162-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3525/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Agency an Office of the Ombudsman for Analytic Objectivity (in this section referred to as the “Office”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ef5163-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3525/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of Ombudsman","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office shall be headed by an Ombudsman, who shall be appointed by the Director from among current or former senior staff officers of the Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ef5164-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3525/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties and responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Ombudsman shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ef5165-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3525/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on an annual basis, conduct a survey of analytic objectivity among officers and employees of the Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ef5166-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3525/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement a procedure by which any officer or employee of the Agency may submit to the Office a complaint alleging politicization, bias, lack of objectivity, or other issues relating to a failure of tradecraft in analysis conducted by the Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ef5167-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3525/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" except as provided in paragraph (4), upon receiving a complaint submitted pursuant to paragraph (2), take reasonable action to investigate the complaint, make a determination as to whether the incident described in the complaint involved politicization, bias, or lack of objectivity, and prepare a report that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1ef5168-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3525/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" summarizes the facts relevant to the complaint;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ef5169-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3525/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documents the determination of the Ombudsman with respect to the complaint; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ef516a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3525/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains a recommendation for remedial action;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ef516b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3525/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a complaint submitted pursuant to paragraph (2) alleges politicization, bias, or lack of objectivity in the collection of intelligence information, refer the complaint to the official responsible for supervising collection operations of the Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ef516c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3525/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuously monitor changes in areas of analysis that the Ombudsman determines involve a heightened risk of politicization, bias, or lack of objectivity, to ensure that any change in the analytic line arises from proper application of analytic tradecraft and not as a result of politicization, bias, or lack of objectivity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ef516d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3525/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ef516e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3525/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On an annual basis, the Ombudsman shall submit to the intelligence committees a report on the results of the survey conducted pursuant to subsection (b)(1) with respect to the most recent fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ef516f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3525/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" On an annual basis, the Ombudsman shall submit to the intelligence committees a report that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1ef5170-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3525/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of complaints of submitted pursuant to subsection (b)(2) during the most recent fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ef5171-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3525/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the nature of such complaints, the actions taken by the Office or any other relevant element or component of the Agency with respect to such complaints, and the resolution of such complaints.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ef5172-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3525/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" On a quarterly basis, the Ombudsman shall submit to the intelligence committees a report that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1ef5173-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3525/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of the areas of analysis monitored during the most recent calendar quarter pursuant to subsection (b)(5); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ef5174-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3525/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a brief description of the methods by which the Office has conducted such monitoring.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ef5175-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3525/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intelligence committees defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “intelligence committees” means the Permanent Select Committee on Intelligence of the House of Representatives and the Select Committee on Intelligence of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1ef5176-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-20/ch227/s24"},"text":"June 20, 1949, ch. 227, § 24","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dW/tIV/s401/a"},"text":"Pub. L. 116–260, div. W, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2376"},"text":"134 Stat. 2376","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1ef5177-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1ef5178-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idd1ef5179-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dW/tIV/s401/b"},"text":"Pub. L. 116–260, div. W, title IV, § 401(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2377"},"text":"134 Stat. 2377","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dW/tIV/s401/b"},"text":"“Any reference in any law, regulation, map, document, paper, or other record of the United States to the Ombudsman for Analytic and Collection Objectivity of the Central Intelligence Agency shall be deemed to be a reference to the Office of the Ombudsman for Analytic Objectivity of the Central Intelligence Agency established by section 24(a) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3525/a"},"text":"50 U.S.C. 3525(a)","children":[],"tail":"] of the Central Intelligence Agency Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3501"},"text":"50 U.S.C. 3501","children":[],"tail":" et seq.), as added by subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
