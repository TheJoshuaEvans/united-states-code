{"tag":"section","attrib":{"id":"idd1971efa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c"},"text":null,"children":[{"tag":"num","attrib":{"value":"3034c"},"text":"§ 3034c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intelligence Community Innovation Unit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1971efb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1971efc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emerging technology","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"the term “emerging technology” has the meaning given that term in section 6701 of the Intelligence Authorization Act for Fiscal Year 2023 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Public Law 117–263","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3024"},"text":"50 U.S.C. 3024","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1971efd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Unit” means the Intelligence Community Innovation Unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1971efe-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan for implementation of Intelligence Community Innovation Unit","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1971eff-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"December 22, 2023","children":[],"tail":", the Director of National Intelligence shall develop a plan for how to implement the Intelligence Community Innovation Unit within the intelligence community."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1971f00-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters covered","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan developed pursuant to paragraph (1) shall cover how the Unit will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1971f01-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benefit heads of the elements of the intelligence community in identifying commercial emerging technologies and associated capabilities to address critical mission needs of elements of the intelligence community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1971f02-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the heads of the elements of the intelligence community seeking to field commercial emerging technologies technical expertise with respect to such technologies.","children":[{"tag":"ref","attrib":{"idref":"fn002072"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002072"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should be a semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1971f03-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the transition of potential prototypes and solutions to critical mission needs of the intelligence community from research and prototype projects to production; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1971f04-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as a liaison between the intelligence community and the private sector, in which capacity such liaison shall focus on small- and medium-sized companies and other organizations that do not have significant experience engaging with the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1971f05-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan developed pursuant to paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1971f06-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plan for not more than 50 full-time equivalent personnel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1971f07-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include an assessment as to how the establishment of the Unit would benefit the identification and evaluation of commercial emerging technologies for prototyping and potential adoption by the intelligence community to fulfill critical mission needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1971f08-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon completing development of the plan pursuant to paragraph (1), the Director shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1971f09-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the congressional intelligence committees, the Subcommittee on Defense of the Committee on Appropriations of the Senate, and the Subcommittee on Defense of the Committee on Appropriations of the House of Representatives a copy of the plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1971f0a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide such committees and subcommittees a briefing on the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1971f0b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent and in such amounts as specifically provided in advance in appropriations Acts for the purposes detailed in this section, not later than 180 days after the date on which the Director of National Intelligence submits the plan pursuant to subsection (b)(4)(A), the Director of National Intelligence shall establish the Unit within the Office of the Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1971f0c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Unit shall not abrogate or otherwise constrain any element of the intelligence community from conducting authorized activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1971f0d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of the Intelligence Community Innovation Unit","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1971f0e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment; reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of the Unit is the Director of the Intelligence Community Innovation Unit, who shall be appointed by the Director of National Intelligence and shall report directly to the Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1971f0f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting an individual for appointment as the Director of the Intelligence Community Innovation Unit, the Director of National Intelligence shall give preference to individuals who the Director of National Intelligence determines have—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1971f10-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significant relevant experience involving commercial emerging technology within the private sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1971f11-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a demonstrated history of fostering the adoption of commercial emerging technologies by the United States Government or the private sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1971f12-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1971f13-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the Director of the Intelligence Community Innovation Unit, the Unit shall be composed of not more than 50 full-time equivalent positions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1971f14-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff with certain expertise","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of National Intelligence shall ensure that there is a sufficient number of staff of the Unit, as determined by the Director, with expertise in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1971f15-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other transaction authorities and nontraditional and rapid acquisition pathways for emerging technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1971f16-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaging and evaluating small- and medium-sized emerging technology companies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1971f17-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the mission needs of the intelligence community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1971f18-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other skills or experiences as the Director determines necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1971f19-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority relating to detailees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon request of the Unit, each head of an element of the intelligence community may detail to the Unit any of the personnel of that element to assist in carrying out the duties under subsection (b) on a reimbursable or a nonreimbursable basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1971f1a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ensuring transition from prototyping to production","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Intelligence Community Innovation Unit shall transition research and prototype projects to products in a production stage upon identifying a demonstrated critical mission need of one or more elements of the intelligence community and a potential mission partner likely to field and further fund upon maturation, including by designating projects as Emerging Technology Transition Projects under the pilot program required by section 6713 of the Intelligence Authorization Act for Fiscal Year 2023 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Public Law 117–263","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3024"},"text":"50 U.S.C. 3024","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1971f1b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encouragement of use by elements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence shall take such steps as may be necessary to encourage the use of the Unit by the heads of the other elements of the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1971f1c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of construction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1971f1d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No preferential treatment for private sector","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to require any element of the intelligence community to provide preferential treatment for any private sector entity with regard to procurement of technology construed as restricting or preempting any activities of the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1971f1e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No additional authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Unit established pursuant to subsection (c) will be limited to the existing authorities possessed by the Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1971f1f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3034c/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authorities and requirements of this section shall terminate on the date that is 5 years after the date of the establishment of the Unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1971f20-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title I, § 103L, as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tV/s7502"},"text":"Pub. L. 118–31, div. G, title V, § 7502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1079"},"text":"137 Stat. 1079","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
