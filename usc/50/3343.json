{"tag":"section","attrib":{"id":"idd1d2a1a3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343"},"text":null,"children":[{"tag":"num","attrib":{"value":"3343"},"text":"§ 3343.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security clearances; limitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1d2a1a4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d2a1a5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controlled substance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “controlled substance” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"section 802 of title 21","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d2a1a6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d2a1a7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer or employee of a Federal agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d2a1a8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the Army, Navy, Air Force, or Marine Corps who is on active duty or is in an active status; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d2a1a9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer or employee of a contractor of a Federal agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d2a1aa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restricted Data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Restricted Data” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2014"},"text":"section 2014 of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d2a1ab-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special access program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “special access program” has the meaning given that term in section 4.1 of Executive Order No. 12958 (60 Fed. Reg. 19825).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d2a1ac-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After ","children":[{"tag":"date","attrib":{"date":"2008-01-01"},"text":"January 1, 2008","children":[],"tail":", the head of a Federal agency may not grant or renew a security clearance for a covered person who is an unlawful user of a controlled substance or an addict (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s802/1"},"text":"section 802(1) of title 21","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d2a1ad-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disqualification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d2a1ae-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After ","children":[{"tag":"date","attrib":{"date":"2008-01-01"},"text":"January 1, 2008","children":[],"tail":", absent an express written waiver granted in accordance with paragraph (2), the head of a Federal agency may not grant or renew a security clearance described in paragraph (3) for a covered person who—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d2a1af-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been convicted in any court of the United States of a crime, was sentenced to imprisonment for a term exceeding 1 year, and was incarcerated as a result of that sentence for not less than 1 year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d2a1b0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been discharged or dismissed from the Armed Forces under dishonorable conditions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d2a1b1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is mentally incompetent, as determined by an adjudicating authority, based on an evaluation by a duly qualified mental health professional employed by, or acceptable to and approved by, the United States Government and in accordance with the adjudicative guidelines required by subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d2a1b2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In a meritorious case, an exception to the disqualification in this subsection may be authorized if there are mitigating factors. Any such waiver may be authorized only in accordance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d2a1b3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards and procedures prescribed by, or under the authority of, an Executive order or other guidance issued by the President; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d2a1b4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adjudicative guidelines required by subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d2a1b5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered security clearances","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection applies to security clearances that provide for access to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d2a1b6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special access programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d2a1b7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Restricted Data; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d2a1b8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information commonly referred to as “sensitive compartmented information”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d2a1b9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d2a1ba-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than February 1 of each year, the head of a Federal agency shall submit a report to the appropriate committees of Congress if such agency employs or employed a person for whom a waiver was granted in accordance with paragraph (2) during the preceding year. Such annual report shall not reveal the identity of such person, but shall include for each waiver issued the disqualifying factor under paragraph (1) and the reasons for the waiver of the disqualifying factor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d2a1bb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this paragraph:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1d2a1bc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate committees of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate committees of Congress” means, with respect to a report submitted under subparagraph (A) by the head of a Federal agency—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idd1d2a1bd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/c/4/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional defense committees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd1d512be-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/c/4/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional intelligence committees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd1d512bf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/c/4/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Homeland Security and Governmental Affairs of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd1d512c0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/c/4/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Oversight and Government Reform of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd1d512c1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/c/4/B/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each Committee of the Senate or the House of Representatives with oversight authority over such Federal agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1d512c2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional defense committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “congressional defense committees” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a/16"},"text":"section 101(a)(16) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1d512c3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/c/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional intelligence committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “congressional intelligence committees” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d512c4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjudicative guidelines","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d512c5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to establish","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall establish adjudicative guidelines for determining eligibility for access to classified information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d512c6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements related to mental health","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The guidelines required by paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d512c7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include procedures and standards under which a covered person is determined to be mentally incompetent and provide a means to appeal such a determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d512c8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3343/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that no negative inference concerning the standards in the guidelines may be raised solely on the basis of seeking mental health counseling.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1d512c9-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/tIII/s3002"},"text":"Pub. L. 108–458, title III, § 3002","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tX/s1072/a"},"text":"Pub. L. 110–181, div. A, title X, § 1072(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/328"},"text":"122 Stat. 328","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1d512ca-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1d512cb-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1d512cc-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order 12958, referred to in subsec. (a)(4), which was formerly set out as a note under section 435 (now section 3161) of this title, was revoked by Ex. Ord. No. 13526, § 6.2(g), ","children":[{"tag":"date","attrib":{"date":"2009-12-29"},"text":"Dec. 29, 2009","children":[],"tail":", 75 F.R. 731."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1d512cd-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s435c"},"text":"section 435c of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1d512ce-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idd1d512cf-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Oversight and Government Reform of House of Representatives changed to Committee on Oversight and Reform of House of Representatives by House Resolution No. 6, One Hundred Sixteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":". Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, "},{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
