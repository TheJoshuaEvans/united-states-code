{"tag":"section","attrib":{"id":"idd14862fd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874"},"text":null,"children":[{"tag":"num","attrib":{"value":"1874"},"text":"§ 1874.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public reporting by persons subject to orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd14862fe-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person subject to a nondisclosure requirement accompanying an order or directive under this chapter or a national security letter may, with respect to such order, directive, or national security letter, publicly report the following information using one of the following structures:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd14862ff-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A semiannual report that aggregates the number of orders, directives, or national security letters with which the person was required to comply into separate categories of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1486300-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of national security letters received, reported in bands of 1000 starting with 0–999;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1486301-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of customer selectors targeted by national security letters, reported in bands of 1000 starting with 0–999;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1486302-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of orders or directives received, combined, under this chapter for contents, reported in bands of 1000 starting with 0–999;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1486303-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of customer selectors targeted under orders or directives received, combined, under this chapter for contents, reported in bands of 1000 starting with 0–999;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1486304-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of orders received under this chapter for noncontents, reported in bands of 1000 starting with 0–999; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1486305-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the number of customer selectors targeted under orders under this chapter for noncontents, reported in bands of 1000 starting with 0–999, pursuant to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1486306-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/a/1/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subchapter III;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1486307-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/a/1/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subchapter IV with respect to applications described in section 1861(b)(2)(B) ","children":[{"tag":"ref","attrib":{"idref":"fn002039"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002039"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1486308-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/a/1/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subchapter IV with respect to applications described in section 1861(b)(2)(C) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1486309-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A semiannual report that aggregates the number of orders, directives, or national security letters with which the person was required to comply into separate categories of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd148630a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of national security letters received, reported in bands of 500 starting with 0–499;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd148630b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of customer selectors targeted by national security letters, reported in bands of 500 starting with 0–499;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd148630c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of orders or directives received, combined, under this chapter for contents, reported in bands of 500 starting with 0–499;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd148630d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of customer selectors targeted under orders or directives received, combined, under this chapter for contents, reported in bands of 500 starting with 0–499;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd148630e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of orders received under this chapter for noncontents, reported in bands of 500 starting with 0–499; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd148630f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of customer selectors targeted under orders received under this chapter for noncontents, reported in bands of 500 starting with 0–499.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1486310-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A semiannual report that aggregates the number of orders, directives, or national security letters with which the person was required to comply into separate categories of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1486311-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of all national security process received, including all national security letters, and orders or directives under this chapter, combined, reported in bands of 250 starting with 0–249; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1486312-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of customer selectors targeted under all national security process received, including all national security letters, and orders or directives under this chapter, combined, reported in bands of 250 starting with 0–249.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1486313-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An annual report that aggregates the number of orders, directives, and national security letters the person was required to comply with into separate categories of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1486314-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of all national security process received, including all national security letters, and orders or directives under this chapter, combined, reported in bands of 100 starting with 0–99; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1486315-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of customer selectors targeted under all national security process received, including all national security letters, and orders or directives under this chapter, combined, reported in bands of 100 starting with 0–99.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1486316-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of time covered by reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1486317-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A report described in paragraph (1) or (2) of subsection (a) shall include only information—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1486318-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relating to national security letters for the previous 180 days; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1486319-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relating to authorities under this chapter for the 180-day period of time ending on the date that is not less than 180 days prior to the date of the publication of such report, except that with respect to a platform, product, or service for which a person did not previously receive an order or directive (not including an enhancement to or iteration of an existing publicly available platform, product, or service) such report shall not include any information relating to such new order or directive until 540 days after the date on which such new order or directive is received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd148631a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A report described in paragraph (3) of subsection (a) shall include only information relating to the previous 180 days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd148631b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A report described in paragraph (4) of subsection (a) shall include only information for the 1-year period of time ending on the date that is not less than 1 year prior to the date of the publication of such report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd148631c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other forms of agreed to publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section prohibits the Government and any person from jointly agreeing to the publication of information referred to in this subsection in a time, form, or manner other than as described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd148631d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd148631e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “contents” has the meaning given that term under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2510"},"text":"section 2510 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd148631f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1874/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National security letter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “national security letter” has the meaning given that term under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1873"},"text":"section 1873 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1486320-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511/tVI/s604"},"text":"Pub. L. 95–511, title VI, § 604","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/23/tVI/s603/a"},"text":"Pub. L. 114–23, title VI, § 603(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-02"},"text":"June 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/295"},"text":"129 Stat. 295","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/118/tII/s205/a/4"},"text":"Pub. L. 115–118, title II, § 205(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-01-19"},"text":"Jan. 19, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/21"},"text":"132 Stat. 21","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1486321-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1486322-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1486323-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (b)(1)(B), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511"},"text":"Pub. L. 95–511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-25"},"text":"Oct. 25, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1783"},"text":"92 Stat. 1783","children":[],"tail":", known as the Foreign Intelligence Surveillance Act of 1978, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801"},"text":"section 1801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1861(b)(2)(B), (C) of this title, referred to in subsec. (a)(1)(F)(ii), (iii), means section 1861(b)(2)(B), (C) of this title prior to the amendment of section 1861 by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/tI/s102/b"},"text":"Pub. L. 109–177, title I, § 102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/195"},"text":"120 Stat. 195","children":[],"tail":", set out as an Effective Date of 2006 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1805"},"text":"section 1805 of this title","children":[],"tail":", which amended "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1861"},"text":"section 1861 of this title","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2020-03-15"},"text":"Mar. 15, 2020","children":[],"tail":", so that such section read as it read on "},{"tag":"date","attrib":{"date":"2001-10-25"},"text":"Oct. 25, 2001","children":[],"tail":", with certain exceptions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1486324-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/118/s205/a/4/A"},"text":"Pub. L. 115–118, § 205(a)(4)(A)","children":[],"tail":", substituted “contents,” for “contents”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/118/s205/a/4/B"},"text":"Pub. L. 115–118, § 205(a)(4)(B)","children":[],"tail":", substituted “comply into” for “comply in the into” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
