{"tag":"section","attrib":{"id":"idd21576e2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4140"},"text":null,"children":[{"tag":"num","attrib":{"value":"4140"},"text":"§ 4140.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claim filing period","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Within sixty days after the enactment of this subchapter or of legislation making appropriations to the Commission for payment of administrative expenses incurred in carrying out its functions under this subchapter, whichever date is later, the Commission shall give public notice by publication in the Federal Register of the time when, and the limit of time within which claims may be filed, which limit shall not be more than eighteen months after such publication.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd21576e3-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-07-03/ch826"},"text":"July 3, 1948, ch. 826","children":[],"tail":", title II, § 210, as added "},{"tag":"ref","attrib":{"href":"/us/pl/87/846/tI/s103"},"text":"Pub. L. 87–846, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-22"},"text":"Oct. 22, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1111"},"text":"76 Stat. 1111","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd21576e4-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd21576e5-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd21576e6-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The enactment of this subchapter, referred to in text, probably means the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/846"},"text":"Pub. L. 87–846","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1962-10-22"},"text":"Oct. 22, 1962","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd21576e7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 2017i of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd21576e8-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd21576e9-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Protests Relating to Awards by Commission; Notice by Publication in Federal Register","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Notwithstanding the provisions of this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4141"},"text":"section 4141 of this title","children":[],"tail":", receipt and consideration of filed and published protests relating to awards made by the Foreign Claims Settlement Commission which result in modification of such awards shall be certified and paid by the Secretary of the Treasury out of the War Claims Fund in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4143"},"text":"section 4143 of this title","children":[],"tail":". See section 615 of "},{"tag":"ref","attrib":{"href":"/us/act/1950-03-10/ch54"},"text":"act Mar. 10, 1950, ch. 54","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/94/542"},"text":"Pub. L. 94–542","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-18"},"text":"Oct. 18, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2512"},"text":"90 Stat. 2512","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1623"},"text":"section 1623 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
