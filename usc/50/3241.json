{"tag":"section","attrib":{"id":"idd1c6bac4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3241"},"text":null,"children":[{"tag":"num","attrib":{"value":"3241"},"text":"§ 3241.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biennial reports on foreign biological threats","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1c6bac5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3241/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On a biennial basis until the date that is 10 years after ","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"March 15, 2022","children":[],"tail":", the Director of National Intelligence shall submit to the congressional intelligence committees a comprehensive report on the activities, prioritization, and responsibilities of the intelligence community with respect to foreign biological threats emanating from the territory of, or sponsored by, a covered country."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c6bac6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3241/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under subsection (a) shall include, with respect to foreign biological threats emanating from the territory of, or sponsored by, a covered country, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c6bac7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3241/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A detailed description of all activities relating to such threats undertaken by each element of the intelligence community, and an assessment of any gaps in such activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c6bac8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3241/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A detailed description of all duties and responsibilities relating to such threats explicitly authorized or otherwise assigned, exclusively or jointly, to each element of the intelligence community, and an assessment of any identified gaps in such duties or responsibilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c6bac9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3241/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the coordination among the relevant elements of the intelligence community with respect to the activities specified in paragraph (1) and the duties and responsibilities specified in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c6baca-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3241/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An inventory of the strategies, plans, policies, and interagency agreements of the intelligence community relating to the collection, monitoring, analysis, mitigation, and attribution of such threats, and an assessment of any identified gaps therein.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c6bacb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3241/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the coordination and interactions among the relevant elements of the intelligence community and non-intelligence community partners.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c6bacc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3241/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of foreign malign influence efforts relating to such threats, including any foreign academics engaged in such efforts, and a description of how the intelligence community contributes to efforts by non-intelligence community partners to counter such foreign malign influence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c6bacd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3241/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report submitted under subsection (a) may be submitted in classified form, but if so submitted shall include an unclassified executive summary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c6bace-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3241/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c6bacf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3241/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered country","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered country” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c6bad0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3241/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" China;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c6bad1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3241/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Iran;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c6bad2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3241/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" North Korea;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c6bad3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3241/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Russia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c6bad4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3241/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any other foreign country—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1c6bad5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3241/d/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from which the Director of National Intelligence determines a biological threat emanates; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1c6bad6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3241/d/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the Director determines has a known history of, or has been assessed as having conditions present for, infectious disease outbreaks or epidemics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c6bad7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3241/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign biological threat","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “foreign biological threat” means biological warfare, bioterrorism, naturally occurring infectious diseases, or accidental exposures to biological materials, without regard to whether the threat originates from a state actor, a non-state actor, natural conditions, or an undetermined source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c6bad8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3241/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign malign influence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “foreign malign influence” has the meaning given such term in section 3059(e) ","children":[{"tag":"ref","attrib":{"idref":"fn002083"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002083"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c6bad9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3241/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-intelligence community partner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “non-intelligence community partner” means a Federal department or agency that is not an element of the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1c6bada-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title XI, § 1111, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dX/tVIII/s821/a"},"text":"Pub. L. 117–103, div. X, title VIII, § 821(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1019"},"text":"136 Stat. 1019","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1c6badb-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1c6badc-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1c6badd-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3059/e"},"text":"Section 3059(e) of this title","children":[],"tail":", referred to in subsec. (d)(3), was redesignated as "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3059/f"},"text":"section 3059(f) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dF/tLXIII"},"text":"Pub. L. 117–263, div. F, title LXIII","children":[],"tail":", §6307(b)(1), "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3505"},"text":"136 Stat. 3505","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1c6bade-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1c6badf-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"First Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dX/tVIII/s821/b"},"text":"Pub. L. 117–103, div. X, title VIII, § 821(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1020"},"text":"136 Stat. 1020","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/103/dX/tVIII/s821/b"},"text":"“Not later than 120 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":"], the Director of National Intelligence shall submit to the congressional intelligence committees the first report required under section 1111 of the National Security Act of 1947 ["},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3241"},"text":"50 U.S.C. 3241","children":[],"tail":"], as added by subsection (a).”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “congressional intelligence committees” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dX/s821/b"},"text":"section 821(b) of div. X of Pub. L. 117–103","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dX/s2"},"text":"section 2 of div. X of Pub. L. 117–103","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
