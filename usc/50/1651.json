{"tag":"section","attrib":{"id":"idd11655f7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1651"},"text":null,"children":[{"tag":"num","attrib":{"value":"1651"},"text":"§ 1651.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other laws, powers and authorities conferred thereby, and actions taken thereunder; Congressional studies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd11655f8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1651/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The provisions of this chapter shall not apply to the following provisions of law, the powers and authorities conferred thereby, and actions taken thereunder:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd11655f9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1651/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapters 1 to 11 of title 40 and division C (except sections 3302, 3307(e), 3501(b), 3509, 3906, 4710, and 4711) of subtitle I of title 41.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd11655fa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1651/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 3727(a)–(e)(1) of title 31.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd11655fb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1651/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6305"},"text":"Section 6305 of title 41","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"par