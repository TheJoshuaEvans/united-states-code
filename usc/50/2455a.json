{"tag":"section","attrib":{"id":"idd16e8896-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2455a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2455a"},"text":"§ 2455a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Nuclear Security Administration authority for urgent nonproliferation activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd16e8897-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2455a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the notification requirement under subsection (b), not more than 10 percent of the total amounts appropriated or otherwise made available in any fiscal year for the nonproliferation programs of the Department of Energy National Nuclear Security Administration may be expended, notwithstanding any other law, for activities described under subsection (b)(1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16e8898-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2455a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination and notice","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16e8899-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2455a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Energy, with the concurrence of the Secretary of State and the Secretary of Defense, may make a written determination that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd16e889a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2455a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" threats arising from the proliferation of nuclear or radiological weapons or weapons-related materials, technologies, and expertise must be addressed urgently;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16e889b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2455a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certain provisions of law would unnecessarily impede the Secretary’s ability to carry out nonproliferation activities of the National Nuclear Security Administration to address such threats; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16e889c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2455a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is necessary to expend amounts described in subsection (a) to carry out such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16e889d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2455a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 15 days before obligating or expending funds under the authority provided in subsection (a), the Secretary of Energy shall notify the appropriate congressional committees of the determination made under paragraph (1). The notice shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd16e889e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2455a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the determination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16e889f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2455a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities to be undertaken by the nonproliferation programs of the National Nuclear Security Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16e88a0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2455a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expected time frame for such activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16e88a1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2455a/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expected costs of such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16e88a2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2455a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16e88a3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2455a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs, the Committee on Armed Services, and the Committee on Appropriations of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16e88a4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2455a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations, the Committee on Armed Services, and the Committee on Appropriations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd16e88a5-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dC/tXXXI/s3120"},"text":"Pub. L. 111–84, div. C, title XXXI, § 3120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2710"},"text":"123 Stat. 2710","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd16e88a6-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd16e88a7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd16e88a8-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Defense Authorization Act for Fiscal Year 2010, and not as part of the National Nuclear Security Administration Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
