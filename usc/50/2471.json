{"tag":"section","attrib":{"id":"idd170f8d7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2471"},"text":null,"children":[{"tag":"num","attrib":{"value":"2471"},"text":"§ 2471.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd170f8d8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2471/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “national security laboratory” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd170f8d9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2471/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Los Alamos National Laboratory, Los Alamos, New Mexico.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd170f8da-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2471/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sandia National Laboratories, Albuquerque, New Mexico, and Livermore, California.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd170f8db-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2471/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lawrence Livermore National Laboratory, Livermore, California.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd170f8dc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2471/2"},"text":null,"children":[{"tag":"num","attrib":{"value"