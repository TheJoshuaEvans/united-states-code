ifier":"/us/usc/t50/s2471/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any facility of the Department of Energy that the Secretary of Energy, in consultation with the Administrator and Congress, determines to be consistent with the mission of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd170f8e3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2471/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “classified information” means any information that has been determined pursuant to Executive Order No. 12333 of ","children":[{"tag":"date","attrib":{"date":"1981-12-04"},"text":"December 4, 1981","children":[],"tail":" ([former] "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s401"},"text":"50 U.S.C. 401","children":[],"tail":" note) [now "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"50 U.S.C. 3001","children":[],"tail":" note], Executive Order No. 12958 of "},{"tag":"date","attrib":{"date":"1995-04-17"},"text":"April 17, 1995","children":[],"tail":" ([former] "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s435"},"text":"50 U.S.C. 435","children":[],"tail":" note), or successor orders, to require protection against unauthorized disclosure and that is so designated."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd170f8e4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2471/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Restricted Data” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2014/y"},"text":"section 2014(y) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":