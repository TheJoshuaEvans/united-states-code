{"tag":"section","attrib":{"id":"idd16512a5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2345"},"text":null,"children":[{"tag":"num","attrib":{"value":"2345"},"text":"§ 2345.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Export control programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd16512a6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2345/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to pursue options for strengthening export control programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy, in coordination with the Secretary of State, may pursue in the region of the former Soviet Union and other regions of concern options for accelerating programs that assist the countries in such regions in improving their domestic export control programs for materials, technologies, and expertise relevant to the construction or use of a nuclear or radiological dispersal device.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16512a7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2345/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount for activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount authorized to be appropriated by section 3101(a)(2) ","children":[{"tag":"ref","attrib":{"idref":"fn002055"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002055"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" for the Department of Energy for the National Nuclear Security Administration for defense nuclear nonproliferation, up to $5,000,000 may be available for carrying out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd16512a8-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dC/tXXXI/s3159"},"text":"Pub. L. 107–314, div. C, title XXXI, § 3159","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2741"},"text":"116 Stat. 2741","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd16512a9-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd16512aa-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd16512ab-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 3101(a)(2), referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s3101/a/2"},"text":"section 3101(a)(2) of Pub. L. 107–314","children":[],"tail":", div. C, title XXXI, "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2729"},"text":"116 Stat. 2729","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd16512ac-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Bob Stump National Defense Authorization Act for Fiscal Year 2003, and not as part of the Defense Against Weapons of Mass Destruction Act of 1996 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
