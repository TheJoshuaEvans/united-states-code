{"tag":"section","attrib":{"id":"idd16c17a3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426"},"text":null,"children":[{"tag":"num","attrib":{"value":"2426"},"text":"§ 2426.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional oversight of special access programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd16c17a4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on special access programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16c17a5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than February 1 of each year, the Administrator shall submit to the congressional defense committees a report on special access programs of the Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16c17a6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each such report shall set forth—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd16c17a7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount requested for such programs in the President’s budget for the next fiscal year submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16c17a8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each such program in that budget, the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd16c17a9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A brief description of the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd16c17aa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A brief discussion of the major milestones established for the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd16c17ab-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The actual cost of the program for each fiscal year during which the program has been conducted before the fiscal year during which that budget is submitted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd16c17ac-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The estimated total cost of the program and the estimated cost of the program for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idd16c17ad-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/a/2/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd16c17ae-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/a/2/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fiscal year for which the budget is submitted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd16c17af-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/a/2/B/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each of the four succeeding fiscal years during which the program is expected to be conducted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16c17b0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on new special access programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16c17b1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than February 1 of each year, the Administrator shall submit to the congressional defense committees a report that, with respect to each new special access program, provides—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd16c17b2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notice of the designation of the program as a special access program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16c17b3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" justification for such designation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16c17b4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A report under paragraph (1) with respect to a program shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd16c17b5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current estimate of the total program cost for the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16c17b6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of existing programs or technologies that are similar to the technology, or that have a mission similar to the mission, of the program that is the subject of the notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16c17b7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this subsection, the term “new special access program” means a special access program that has not previously been covered in a notice and justification under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16c17b8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports on changes in classification of special access programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16c17b9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever a change in the classification of a special access program of the Administration is planned to be made or whenever classified information concerning a special access program of the Administration is to be declassified and made public, the Administrator shall submit to the congressional defense committees a report containing a description of the proposed change, the reasons for the proposed change, and notice of any public announcement planned to be made with respect to the proposed change.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16c17ba-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (3), any report referred to in paragraph (1) shall be submitted not less than 14 days before the date on which the proposed change or public announcement is to occur.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16c17bb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Administrator determines that because of exceptional circumstances the requirement of paragraph (2) cannot be met with respect to a proposed change or public announcement concerning a special access program of the Administration, the Administrator may submit the report required by paragraph (1) regarding the proposed change or public announcement at any time before the proposed change or public announcement is made and shall include in the report an explanation of the exceptional circumstances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16c17bc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of change in SAP designation criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever there is a modification or termination of the policy and criteria used for designating a program of the Administration as a special access program, the Administrator shall promptly notify the congressional defense committees of such modification or termination. Any such notification shall contain the reasons for the modification or termination and, in the case of a modification, the provisions of the policy as modified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16c17bd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16c17be-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator may waive any requirement under subsection (a), (b), or (c) that certain information be included in a report under that subsection if the Administrator determines that inclusion of that information in the report would adversely affect the national security. The Administrator may waive the report-and-wait requirement in subsection (f) if the Administrator determines that compliance with such requirement would adversely affect the national security. Any waiver under this paragraph shall be made on a case-by-case basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16c17bf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Administrator exercises the authority provided under paragraph (1), the Administrator shall provide the information described in that subsection with respect to the special access program concerned, and the justification for the waiver, jointly to the chairman and ranking minority member of each of the congressional defense committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16c17c0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report and wait for initiating new programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A special access program may not be initiated until—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16c17c1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional defense committees are notified of the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16c17c2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2426/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of 30 days elapses after such notification is received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd16c17c3-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dC/tXXXII/s3236"},"text":"Pub. L. 106–65, div. C, title XXXII, § 3236","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/962"},"text":"113 Stat. 962","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dC/tXXXI/s3143/b"},"text":"Pub. L. 113–291, div. C, title XXXI, § 3143(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3902"},"text":"128 Stat. 3902","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd16c17c4-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd16c17c5-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd16c17c6-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2122a"},"text":"section 2122a of Title 42","children":[],"tail":", The Public Health and Welfare, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/s3294/e/1/A"},"text":"Pub. L. 106–65, § 3294(e)(1)(A)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd16c17c7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(2)(B)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" substituted “program for—” for “program for” before subcl. (I) designation, “year;” for “year,” at end of subcl. (I), and “; and” for “, and” at end of subcl. (II) and realigned margins of subcls. (I) to (III)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd16c17c8-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd16c17c9-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2000-03-01"},"text":"Mar. 1, 2000","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/s3299"},"text":"section 3299 of Pub. L. 106–65","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2401"},"text":"section 2401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
