{"tag":"section","attrib":{"id":"idd20bdacb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3991"},"text":null,"children":[{"tag":"num","attrib":{"value":"3991"},"text":"§ 3991.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxes respecting personal property, money, credits, and real property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd20bdacc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3991/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section applies in any case in which a tax or assessment, whether general or special (other than a tax on personal income), falls due and remains unpaid before or during a period of military service with respect to a servicemember’s—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20bdacd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3991/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personal property (including motor vehicles); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20bdace-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3991/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" real property occupied for dwelling, professional, business, or agricultural purposes by a servicemember or the servicemember’s dependents or employees—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd20bdacf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3991/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before the servicemember’s entry into military service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd20bdad0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3991/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the time the tax or assessment remains unpaid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20bdad1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3991/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of property","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20bdad2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3991/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on sale of property to enforce tax assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Property described in subsection (a) may not be sold to enforce the collection of such tax or assessment except by court order and upon the determination by the court that military service does not materially affect the servicemember’s ability to pay the unpaid tax or assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20bdad3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3991/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stay of court proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A court may stay a proceeding to enforce the collection of such tax or assessment, or sale of such property, during a period of military service of the servicemember and for a period not more than 180 days after the termination of, or release of the servicemember from, military service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20bdad4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3991/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When property described in subsection (a) is sold or forfeited to enforce the collection of a tax or assessment, a servicemember shall have the right to redeem or commence an action to redeem the servicemember’s property during the period of military service or within 180 days after termination of or release from military service. This subsection may not be construed to shorten any period provided by the law of a State (including any political subdivision of a State) for redemption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20bdad5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3991/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest on tax or assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever a servicemember does not pay a tax or assessment on property described in subsection (a) when due, the amount of the tax or assessment due and unpaid shall bear interest until paid at the rate of 6 percent per year. An additional penalty or interest shall not be incurred by reason of nonpayment. A lien for such unpaid tax or assessment may include interest under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20bdad6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3991/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint ownership application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section applies to all forms of property described in subsection (a) owned individually by a servicemember or jointly by a servicemember and a dependent or dependents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd20bdad7-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title V, § 501, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s1"},"text":"Pub. L. 108–189, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2854"},"text":"117 Stat. 2854","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd20bdad8-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd20bdad9-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd20bdada-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 561 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd20bdadb-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 501 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"act Oct. 17, 1940, ch. 888","children":[],"tail":", art. V, "},{"tag":"ref","attrib":{"href":"/us/stat/54/1187"},"text":"54 Stat. 1187","children":[],"tail":", related to rights in public lands and grazing lands, prior to the general amendment of this Act by "},{"tag":"ref","attrib":{"href":"/us/pl/108/189"},"text":"Pub. L. 108–189","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3992"},"text":"section 3992 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in section 500 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"act Oct. 17, 1940, ch. 888","children":[],"tail":", art. V, "},{"tag":"ref","attrib":{"href":"/us/stat/54/1186"},"text":"54 Stat. 1186","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1942-10-06/ch581/s14"},"text":"Oct. 6, 1942, ch. 581, § 14","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/776"},"text":"56 Stat. 776","children":[],"tail":", prior to the general amendment of this Act by "},{"tag":"ref","attrib":{"href":"/us/pl/108/189"},"text":"Pub. L. 108–189","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd20bdadc-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd20bdadd-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any case not final before ","children":[{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s3"},"text":"section 3 of Pub. L. 108–189","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3901"},"text":"section 3901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
