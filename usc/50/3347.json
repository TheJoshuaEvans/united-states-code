{"tag":"section","attrib":{"id":"idd1d51311-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3347"},"text":null,"children":[{"tag":"num","attrib":{"value":"3347"},"text":"§ 3347.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secrecy agreements used in intelligence activities","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law not specifically referencing this section, a nondisclosure policy form or agreement that is to be executed by a person connected with the conduct of an intelligence or intelligence-related activity, other than an employee or officer of the United States Government, may contain provisions appropriate to the particular activity for which such document is to be used. Such form or agreement shall, at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d51312-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3347/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that the person will not disclose any classified information received in the course of such activity unless specifically authorized to do so by the United States Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d51313-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3347/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide that the form or agreement does not bar—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d51314-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3347/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disclosures to Congress; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d51315-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3347/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disclosures to an authorized official of an executive agency that are deemed essential to reporting a violation of United States law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1d51316-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/93/tIII/s306"},"text":"Pub. L. 104–93, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-01-06"},"text":"Jan. 6, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/966"},"text":"109 Stat. 966","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1d51317-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1d51318-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1d51319-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s435"},"text":"section 435 of this title","children":[],"tail":" prior to editorial reclassification as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
