{"tag":"section","attrib":{"id":"idd2347112-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4563"},"text":null,"children":[{"tag":"num","attrib":{"value":"4563"},"text":"§ 4563.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any provision of this chapter or the application of such provision to any person or circumstances shall be held invalid, the remainder of the chapter, and the application of such provision to persons or circumstances other than those as to which it is held invalid, shall not be affected thereby.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd2347113-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-08/ch932"},"text":"Sept. 8, 1950, ch. 932","children":[],"tail":", title VII, § 715, formerly § 714, "},{"tag":"ref","attrib":{"href":"/us/stat/64/821"},"text":"64 Stat. 821","children":[],"tail":"; renumbered § 715, "},{"tag":"ref","attrib":{"href":"/us/act/1951-07-31/ch275"},"text":"July 31, 1951, ch. 275","children":[],"tail":", title I, § 110(b), "},{"tag":"ref","attrib":{"href":"/us/stat/65/144"},"text":"65 Stat. 144","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2347114-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"idd2347115-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4564/a"},"text":"section 4564(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2347116-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd2347117-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter and the chapter, referred to in text, were in the original “this Act” and “the Act”, respectively, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-08/ch932"},"text":"act Sept. 8, 1950, ch. 932","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/798"},"text":"64 Stat. 798","children":[],"tail":", known as the Defense Production Act of 1950, which is classified principally to this chapter. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4501"},"text":"section 4501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd2347118-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 2164 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
