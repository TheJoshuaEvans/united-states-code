{"tag":"section","attrib":{"id":"idd1cde638-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3334a"},"text":"§ 3334a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of National Intelligence University to the Office of the Director of National Intelligence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1cde639-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the submission of the joint certifications under subsection (b)(1), the Secretary of Defense and the Director of National Intelligence shall take such actions that the Director determines necessary to transfer the National Intelligence University from the Defense Intelligence Agency to the Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cde63a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint certifications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cde63b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided by paragraph (2), as soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", but not later than 18 months after "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", the Secretary of Defense and the Director of National Intelligence shall jointly submit to the appropriate congressional committees written certifications of each of the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1cde63c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Middle States Commission on Higher Education has provided regional academic accreditation for the National Intelligence University before the date of the certification, or will provide such academic accreditation as of the date on which the University is transferred under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cde63d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Armed Forces attending the University will be eligible to receive credit for Phase I joint professional military education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cde63e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Education has informed the Director of National Intelligence that the Secretary has recommended approval of the degrees to be conferred pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3227a/b"},"text":"section 3227a(b) of this title","children":[],"tail":" or will provide such recommended approval as of the date on which the University is transferred under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cde63f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of National Intelligence, in collaboration with the Secretary of Defense, has established an appropriate governance model for the University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cde640-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall use the University to provide personnel of the Department of Defense with advanced intelligence education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde641-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to certify","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1cde642-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary of Defense and the Director of National Intelligence fail to submit the certifications under paragraph (1) by the date specified in such paragraph, the Secretary and the Director shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1cde643-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" jointly submit to the appropriate congressional committees a report on such failure by not later than 21 months after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1cde644-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" jointly submit such certifications as soon as practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cde645-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report under subparagraph (A)(i) shall contain the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1cde646-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the progress made toward fulfilling the conditions described in such paragraph as of the date of the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1cde647-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of any obstacles preventing the fulfillment of such conditions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1cde648-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The estimated dates of completion for the fulfillment of such conditions and the submission of the certifications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cde649-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Briefing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", the Director of National Intelligence, the Director of the Defense Intelligence Agency, and the President of the National Intelligence University shall jointly provide to the appropriate congressional committees a briefing on the plan to carry out the transfer under subsection (a), including with respect to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cde64a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring the provision of services to all elements of the intelligence community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde64b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employing a military cadre at the University; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde64c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addressing the current accreditation status of the National Intelligence University with the Middle States Commission on Higher Education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cde64d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost estimates of transfer","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cde64e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", the Secretary of Defense and the Director of National Intelligence shall jointly submit to the appropriate congressional committees an estimate of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1cde64f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the annual costs of operating the National Intelligence University; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cde650-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs to the Federal Government of transferring the National Intelligence University to the Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde651-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of indirect costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The estimate submitted under paragraph (1) shall include all indirect costs, including with respect to human resources, security, facilities, and information technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cde652-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conforming repeal","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cde653-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde654-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amendments made by paragraph (1) shall take effect on the date on which the Secretary of Defense and the Director of National Intelligence jointly submit the joint certifications under subsection (b)(1). The Secretary and the Director shall jointly notify the Law Revision Counsel of the House of Representatives of the submission of the certifications so that the Law Revision Counsel may execute the amendments made by paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cde655-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cde656-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1cde657-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional intelligence committees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cde658-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committees on Armed Services of the Senate and House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde659-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Phase I joint professional military education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Phase I joint professional military education” has the meaning given that term pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2154"},"text":"section 2154 of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1cde65a-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLIII/s5324"},"text":"Pub. L. 116–92, div. E, title LIII, § 5324","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2134"},"text":"133 Stat. 2134","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dW/tIII/s305/c"},"text":"Pub. L. 116–260, div. W, title III, § 305(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2367"},"text":"134 Stat. 2367","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1cde65b-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1cde65c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1cde65d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s5324"},"text":"section 5324 of Pub. L. 116–92","children":[],"tail":". Subsec. (e)(1) of "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/s5324"},"text":"section 5324 of Pub. L. 116–92","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2161"},"text":"section 2161 of Title 10","children":[],"tail":", Armed Forces, and amended the analysis preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2161"},"text":"section 2161 of Title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1cde65e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s305/c/1"},"text":"Pub. L. 116–260, § 305(c)(1)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3227a/b"},"text":"section 3227a(b) of this title","children":[],"tail":"” for “subsection (e)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s305/c/2"},"text":"Pub. L. 116–260, § 305(c)(2)","children":[],"tail":", (3), redesignated subsecs. (g) and (h) as (e) and (f), respectively, and struck out former subsecs. (e) and (f) which related to degree-granting authority and congressional notification requirements, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1cde65f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd1cde660-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “intelligence community” and “congressional intelligence committees” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/s5003"},"text":"section 5003 of div. E of Pub. L. 116–92","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
