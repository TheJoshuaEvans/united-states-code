{"tag":"section","attrib":{"id":"idd204d527-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3818"},"text":null,"children":[{"tag":"num","attrib":{"value":"3818"},"text":"§ 3818.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This chapter shall become effective immediately; except that unless the President, or the Congress by concurrent resolution, declares a national emergency after ","children":[{"tag":"date","attrib":{"date":"1948-06-24"},"text":"June 24, 1948","children":[],"tail":", no person shall be inducted or ordered into active service without his consent under this chapter within ninety days after "},{"tag":"date","attrib":{"date":"1948-06-24"},"text":"June 24, 1948","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd204d528-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-24/ch625"},"text":"June 24, 1948, ch. 625","children":[],"tail":", title I, § 20, "},{"tag":"ref","attrib":{"href":"/us/stat/62/627"},"text":"62 Stat. 627","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-27/ch1059/s1/14"},"text":"Sept. 27, 1950, ch. 1059, § 1(14)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/1074"},"text":"64 Stat. 1074","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041/s53"},"text":"Aug. 10, 1956, ch. 1041, § 53","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/641"},"text":"70A Stat. 641","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd204d529-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd204d52a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd204d52b-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title I of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-24/ch625"},"text":"act June 24, 1948, ch. 625","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/604"},"text":"62 Stat. 604","children":[],"tail":", which is classified principally to this chapter. For complete classification of title I to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd204d52c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 470 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd204d52d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1956—Act ","children":[{"tag":"date","attrib":{"date":"1956-08-10"},"text":"Aug. 10, 1956","children":[],"tail":", repealed provisions requiring the Secretaries of the Army, Navy, and the Treasury to initiate and carry forward intensified voluntary enlistment campaigns for the Army, Air Force, Navy, Marine Corps, and the Coast Guard."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1950—Act ","children":[{"tag":"date","attrib":{"date":"1950-09-27"},"text":"Sept. 27, 1950","children":[],"tail":", struck out “and” after “Air Force” and inserted “and the Secretary of the Treasury, for the Coast Guard” after “Marine Corps”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
