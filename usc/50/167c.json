{"tag":"section","attrib":{"id":"idd0f4eb61-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167c"},"text":null,"children":[{"tag":"num","attrib":{"value":"167c"},"text":"§ 167c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Storage, withdrawal and transportation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd0f4eb62-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary provides helium storage, withdrawal, or transportation services to any person, the Secretary shall impose a fee on the person that accurately reflects the economic value of those services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0f4eb63-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The fees charged under subsection (a) shall be not less than the amount required to reimburse the Secretary for the full costs of providing storage, withdrawal, or transportation services, including capital investments in upgrades and maintenance at the Federal Helium System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0f4eb64-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schedule of fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to sale or auction under subsection (a), (b), or (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s167d"},"text":"section 167d of this title","children":[],"tail":", the Secretary shall annually publish a standardized schedule of fees that the Secretary will charge under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0f4eb65-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All fees received by the Secretary under this section shall be credited to the Helium Production Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s167d/e"},"text":"section 167d(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0f4eb66-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Storage and delivery","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with this section, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0f4eb67-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow any person or qualified bidder to which crude helium is sold or auctioned under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s167d"},"text":"section 167d of this title","children":[],"tail":" to store helium in the Federal Helium Reserve; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f4eb68-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish a schedule for the transportation and delivery of helium using the Federal Helium System that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd0f4eb69-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167c/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures timely delivery of helium auctioned pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s167d/b/2"},"text":"section 167d(b)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0f4eb6a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167c/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures timely delivery of helium acquired from the Secretary from the Federal Helium Reserve by means other than an auction under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s167d/b/2"},"text":"section 167d(b)(2) of this title","children":[],"tail":", including nonallocated sales; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0f4eb6b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167c/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides priority access to the Federal Helium Pipeline for in-kind sales for Federal users.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0f4eb6c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s167c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New Pipeline access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consider any applications for access to the Federal Helium Pipeline in a manner consistent with the schedule for phasing out commercial sales and disposition of assets pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s167d"},"text":"section 167d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd0f4eb6d-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1925-03-03/ch426/s5"},"text":"Mar. 3, 1925, ch. 426, § 5","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/86/777/s2"},"text":"Pub. L. 86–777, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-13"},"text":"Sept. 13, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/920"},"text":"74 Stat. 920","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/273/s3"},"text":"Pub. L. 104–273, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3317"},"text":"110 Stat. 3317","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/40/s4"},"text":"Pub. L. 113–40, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-10-02"},"text":"Oct. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/535"},"text":"127 Stat. 535","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd0f4eb6e-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd0f4eb6f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd0f4eb70-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5 of act ","children":[{"tag":"date","attrib":{"date":"1925-03-03"},"text":"Mar. 3, 1925","children":[],"tail":", authorized governmental cooperation with Department of the Interior to effectuate the purposes of this chapter and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s166"},"text":"section 166 of this title","children":[],"tail":", prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/86/777"},"text":"Pub. L. 86–777","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd0f4eb71-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/40"},"text":"Pub. L. 113–40","children":[],"tail":" amended section generally. Prior to amendment, section related to fees for storage, transportation, and withdrawal."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/273"},"text":"Pub. L. 104–273","children":[],"tail":" amended section generally. Prior to amendment, section related to licensing for extraction, transportation, and sale of helium under Federal helium refining program, including provisions in subsec. (a) relating to rules and regulations, in subsec. (b) relating to terms, assignments, and revocations of licenses, in subsec. (c) relating to purpose of licenses, and in subsec. (d) relating to suspension of licenses and reacquisition of helium supplies in times of war or national emergency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
