{"tag":"section","attrib":{"id":"idd1f67d44-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3732"},"text":null,"children":[{"tag":"num","attrib":{"value":"3732"},"text":"§ 3732.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for on-site managers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1f67d45-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3732/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" On-site manager requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before obligating any Cooperative Threat Reduction funds for a project described in subsection (b), the Secretary of Defense shall appoint one on-site manager for that project. The manager shall be appointed from among employees of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f67d46-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3732/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects covered","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) applies to a project—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1f67d47-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3732/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be located in a state of the former Soviet Union;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67d48-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3732/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which involves dismantlement, destruction, or storage facilities, or construction of a facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67d49-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3732/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which the total contribution by the Department of Defense is expected to exceed $50,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f67d4a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3732/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of on-site manager","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The on-site manager appointed under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1f67d4b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3732/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop, in cooperation with representatives from governments of states participating in the project, a list of those steps or activities critical to achieving the disarmament or nonproliferation goals of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67d4c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3732/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a schedule for completing those steps or activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67d4d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3732/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet with all participants to seek assurances that those steps or activities are being completed on schedule; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67d4e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3732/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspend the participation of the United States in a project when a participant other than the United States fails to complete a scheduled step or activity on time, unless the Secretary of Defense directs the on-site manager to resume the participation of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f67d4f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3732/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to manage more than one project","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1f67d50-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3732/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), an employee of the Federal Government may serve as on-site manager for more than one project, including projects at different locations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67d51-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3732/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If such an employee serves as on-site manager for more than one project in a fiscal year, the total cost of the projects for that fiscal year may not exceed $150,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f67d52-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3732/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Steps or activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Steps or activities referred to in subsection (c)(1) are those steps or activities that, if not completed, will prevent a project from achieving its disarmament or nonproliferation goals, including, at a minimum, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1f67d53-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3732/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identification and acquisition of permits (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3733"},"text":"section 3733 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67d54-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3732/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Verification that the items, substances, or capabilities to be dismantled, secured, or otherwise modified are available for dismantlement, securing, or modification.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67d55-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3732/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Timely provision of financial, personnel, management, transportation, and other resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f67d56-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3732/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which the Secretary directs an on-site manager to resume the participation of the United States in a project under subsection (c)(4), the Secretary shall notify the congressional defense committees of such direction by not later than 30 days after the date of such direction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1f67d57-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tXIII/s1332"},"text":"Pub. L. 113–291, div. A, title XIII, § 1332","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3601"},"text":"128 Stat. 3601","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
