{"tag":"section","attrib":{"id":"idd20bda95-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3975"},"text":null,"children":[{"tag":"num","attrib":{"value":"3975"},"text":"§ 3975.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy restrictions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd20bda96-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3975/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dividends","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"While a policy is protected under this subchapter, a dividend or other monetary benefit under a policy may not be paid to an insured or used to purchase dividend additions without the approval of the Secretary of Veterans Affairs. If such approval is not obtained, the dividends or benefits shall be added to the value of the policy to be used as a credit when final settlement is made with the insurer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20bda97-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3975/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific restrictions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"While a policy is protected under this subchapter, cash value, loan value, withdrawal of dividend accumulation, unearned premiums, or other value of similar character may not be available to the insured without the approval of the Secretary. The right of the insured to change a beneficiary designation or select an optional settlement for a beneficiary shall not be affected by the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"source