{"tag":"section","attrib":{"id":"idd13eecd9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1813"},"text":null,"children":[{"tag":"num","attrib":{"value":"1813"},"text":"§ 1813.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures for the retention of incidentally acquired communications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd13eecda-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1813/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd13eecdb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1813/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered communication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered communication” means any nonpublic telephone or electronic communication acquired without the consent of a person who is a party to the communication, including communications in electronic storage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd13eecdc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1813/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Head of an element of the intelligence community","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “head of an element of the intelligence community” means, as appropriate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd13eecdd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1813/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of an element of the intelligence community; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd13eecde-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1813/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of the department or agency containing such element.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd13eecdf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1813/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States person” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801"},"text":"section 1801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd13eece0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1813/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures for covered communications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd13eece1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1813/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to adopt","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2014-12-19"},"text":"December 19, 2014","children":[],"tail":", each head of an element of the intelligence community shall adopt procedures approved by the Attorney General for such element that ensure compliance with the requirements of paragraph (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd13eece2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1813/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination and approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The procedures required by paragraph (1) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd13eece3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1813/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepared in coordination with the Director of National Intelligence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd13eece4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1813/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approved by the Attorney General prior to issuance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd13eece5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1813/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd13eece6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1813/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The procedures required by paragraph (1) shall apply to any intelligence collection activity not otherwise authorized by court order (including an order or certification issued by a court established under subsection (a) or (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1803"},"text":"section 1803 of this title","children":[],"tail":"), subpoena, or similar legal process that is reasonably anticipated to result in the acquisition of a covered communication to or from a United States person and shall permit the acquisition, retention, and dissemination of covered communications subject to the limitation in subparagraph (B)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd13eece7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1813/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on retention","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A covered communication shall not be retained in excess of 5 years, unless—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd13eece8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1813/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the communication has been affirmatively determined, in whole or in part, to constitute foreign intelligence or counterintelligence or is necessary to understand or assess foreign intelligence or counterintelligence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd13eece9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1813/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the communication is reasonably believed to constitute evidence of a crime and is retained by a law enforcement agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd13eecea-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1813/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the communication is enciphered or reasonably believed to have a secret meaning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd13eeceb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1813/b/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all parties to the communication are reasonably believed to be non-United States persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd13eecec-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1813/b/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retention is necessary to protect against an imminent threat to human life, in which case both the nature of the threat and the information to be retained shall be reported to the congressional intelligence committees not later than 30 days after the date such retention is extended under this clause;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd13eeced-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1813/b/3/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retention is necessary for technical assurance or compliance purposes, including a court order or discovery obligation, in which case access to information retained for technical assurance or compliance purposes shall be reported to the congressional intelligence committees on an annual basis; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd13eecee-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1813/b/3/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" retention for a period in excess of 5 years is approved by the head of the element of the intelligence community responsible for such retention, based on a determination that retention is necessary to protect the national security of the United States, in which case the head of such element shall provide to the congressional intelligence committees a written certification describing—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idd13eecef-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1813/b/3/B/vii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasons extended retention is necessary to protect the national security of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd13eecf0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1813/b/3/B/vii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the duration for which the head of the element is authorizing retention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd13eecf1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1813/b/3/B/vii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the particular information to be retained; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd13eecf2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1813/b/3/B/vii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the measures the element of the intelligence community is taking to protect the privacy interests of United States persons or persons located inside the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd13eecf3-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/293/tIII/s309"},"text":"Pub. L. 113–293, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3998"},"text":"128 Stat. 3998","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd13eecf4-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd13eecf5-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd13eecf6-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Intelligence Authorization Act for Fiscal Year 2015, and not as part of the Foreign Intelligence Surveillance Act of 1978 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd13eecf7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd13eecf8-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “congressional intelligence committees” and “intelligence community” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/293/s2"},"text":"section 2 of Pub. L. 113–293","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
