{"tag":"section","attrib":{"id":"idd1ac7b7c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3113"},"text":null,"children":[{"tag":"num","attrib":{"value":"3113"},"text":"§ 3113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unfunded priorities of the intelligence community: annual report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1ac7b7d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 10 days after the date on which the budget of the President for a fiscal year is submitted to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", the head of each element of the intelligence community shall prepare and submit to the Director of National Intelligence, the congressional intelligence committees, the Subcommittee on Defense of the Committee on Appropriations of the Senate, and the Subcommittee on Defense of the Committee on Appropriations of the House of Representatives a report on the unfunded priorities of the programs under the jurisdiction of such head."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ac7b7e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ac7b7f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3113/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under subsection (a) shall specify, for each unfunded priority covered by such report, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1ac7b80-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3113/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A summary description of such priority, including the objectives to be achieved if such priority is funded (whether in whole or in part).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ac7b81-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3113/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether such priority will satisfy a covert action or support collection against requirements identified in the National Intelligence Priorities Framework of the Office of the Director of National Intelligence (or any successor mechanism established for the prioritization of programs and activities), including a description of such requirements and the related prioritization level.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ac7b82-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3113/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The additional amount of funds recommended in connection with the objectives under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ac7b83-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3113/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Budget information with respect to the unfunded priority, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1ac7b84-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3113/b/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriation account;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ac7b85-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3113/b/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expenditure center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ac7b86-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3113/b/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project and, if applicable, subproject.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ac7b87-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3113/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization of priorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report shall present the unfunded priorities covered by such report in overall order of urgency of priority among unfunded priorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ac7b88-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3113/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unfunded priority defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “unfunded priority”, in the case of a fiscal year, means a program, activity, or mission requirement of an element of the intelligence community that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ac7b89-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3113/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not funded in the budget of the President for the fiscal year as submitted to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ac7b8a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3113/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is necessary to fulfill a covert action or to satisfy an information requirement associated with the collection, analysis, or dissemination of intelligence that has been documented within the National Intelligence Priorities Framework; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ac7b8b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3113/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" would have been recommended for funding by the head of the element of the intelligence community if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1ac7b8c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3113/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional resources had been available for the budget to fund the program, activity, or mission requirement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ac7b8d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3113/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program, activity, or mission requirement has emerged since the budget was formulated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1ac7b8e-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title V, § 514, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dF/tLXIII/s6315"},"text":"Pub. L. 117–263, div. F, title LXIII, § 6315","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3512"},"text":"136 Stat. 3512","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tIII/s7312"},"text":"Pub. L. 118–31, div. G, title III, § 7312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1030"},"text":"137 Stat. 1030","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1ac7b8f-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1ac7b90-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1ac7b91-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" inserted “prepare and” after “each element of the intelligence community shall”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
