{"tag":"section","attrib":{"id":"idd1a305d3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3091"},"text":null,"children":[{"tag":"num","attrib":{"value":"3091"},"text":"§ 3091.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General congressional oversight provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1a305d4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3091/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to congressional committees of intelligence activities and anticipated activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1a305d5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3091/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall ensure that the congressional intelligence committees are kept fully and currently informed of the intelligence activities of the United States, including any significant anticipated intelligence activity as required by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a305d6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3091/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this subchapter shall be construed as requiring the approval of the congressional intelligence committees as a condition precedent to the initiation of any significant anticipated intelligence activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1a305d7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3091/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports concerning illegal intelligence activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall ensure that any illegal intelligence activity is reported promptly to the congressional intelligence committees, as well as any corrective action that has been taken or is planned in connection with such illegal activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1a305d8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3091/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures for reporting information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President and the congressional intelligence committees shall each establish such written procedures as may be necessary to carry out the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1a305d9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3091/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures to protect from unauthorized disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The House of Representatives and the Senate shall each establish, by rule or resolution of such House, procedures to protect from unauthorized disclosure all classified information, and all information relating to intelligence sources and methods, that is furnished to the congressional intelligence committees or to Members of Congress under this subchapter. Such procedures shall be established in consultation with the Director of National Intelligence. In accordance with such procedures, each of the congressional intelligence committees shall promptly call to the attention of its respective House, or to any appropriate committee or committees of its respective House, any matter relating to intelligence activities requiring the attention of such House or such committee or committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1a305da-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3091/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of authority conferred","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed as authority to withhold information from the congressional intelligence committees on the grounds that providing the information to the congressional intelligence committees would constitute the unauthorized disclosure of classified information or information relating to intelligence sources and methods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1a305db-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3091/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Intelligence activities” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the term “intelligence activities” includes covert actions as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3093/e"},"text":"section 3093(e) of this title","children":[],"tail":", and includes financial intelligence activities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1a305dc-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title V, § 501, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/88/tVI/s602/a/2"},"text":"Pub. L. 102–88, title VI, § 602(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/441"},"text":"105 Stat. 441","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/306/tIII"},"text":"Pub. L. 107–306, title III","children":[],"tail":", §§ 342(b), 353(b)(3)(A), (7), "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2399"},"text":"116 Stat. 2399","children":[],"tail":", 2402; "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI/s1071/a/1/V"},"text":"Pub. L. 108–458, title I, § 1071(a)(1)(V)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3689"},"text":"118 Stat. 3689","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/tIII/s331/a"},"text":"Pub. L. 111–259, title III, § 331(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2685"},"text":"124 Stat. 2685","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1a305dd-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1a305de-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1a305df-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (e), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"act July 26, 1947, ch. 343","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/495"},"text":"61 Stat. 495","children":[],"tail":", known as the National Security Act of 1947, which is classified principally to this chapter. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1a305e0-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s413"},"text":"section 413 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd1a305e1-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 501 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343/tV"},"text":"act July 26, 1947, ch. 343, title V","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/450/tIV/s407/b/1"},"text":"Pub. L. 96–450, title IV, § 407(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1981"},"text":"94 Stat. 1981","children":[],"tail":", related to congressional oversight of intelligence activities, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/88/s602/a/2"},"text":"Pub. L. 102–88, § 602(a)(2)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1a305e2-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259"},"text":"Pub. L. 111–259","children":[],"tail":" substituted “such written procedures” for “such procedures”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" substituted “Director of National Intelligence” for “Director of Central Intelligence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/s353/b/3/A"},"text":"Pub. L. 107–306, § 353(b)(3)(A)","children":[],"tail":", substituted “congressional intelligence committees” for “intelligence committees” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/s353/b/7"},"text":"Pub. L. 107–306, § 353(b)(7)","children":[],"tail":", redesignated par. (3) as (2) and struck out former par. (2) which read as follows: “As used in this subchapter, the term ‘congressional intelligence committees’ means the Select Committee on Intelligence of the Senate and the Permanent Select Committee on Intelligence of the House of Representatives.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/s353/b/3/A"},"text":"Pub. L. 107–306, § 353(b)(3)(A)","children":[],"tail":", substituted “congressional intelligence committees” for “intelligence committees” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/s342/b"},"text":"Pub. L. 107–306, § 342(b)","children":[],"tail":", inserted “, and includes financial intelligence activities” before period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1a305e3-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd1a305e4-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For Determination by President that amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" take effect on "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", see Memorandum of President of the United States, "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", 70 F.R. 23925, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" effective not later than six months after "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1097/a"},"text":"section 1097(a) of Pub. L. 108–458","children":[],"tail":", set out in an Effective Date of 2004 Amendment; Transition Provisions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
