{"tag":"section","attrib":{"id":"idd1a09521-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3072"},"text":null,"children":[{"tag":"num","attrib":{"value":"3072"},"text":"§ 3072.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Federal Bureau of Investigation to award personal services contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1a09522-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3072/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Federal Bureau of Investigation may enter into personal services contracts if the personal services to be provided under such contracts directly support the intelligence or counterintelligence missions of the Federal Bureau of Investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1a09523-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3072/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability of certain requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Contracts under subsection (a) shall not be subject to the annuity offset requirements of sections 8344 and 8468 of title 5, the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":", or any law or regulation requiring competitive contracting."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1a09524-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3072/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract to be appropriate means of securing services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Contracting Officer of the Federal Bureau of Investigation shall ensure that each personal services contract entered into by the Director under this section is the appropriate means of securing the services to be provided under such contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1a09525-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title III, § 302, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/177/tIII/s311/a/1"},"text":"Pub. L. 108–177, title III, § 311(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-13"},"text":"Dec. 13, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2605"},"text":"117 Stat. 2605","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1a09526-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1a09527-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1a09528-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s409b"},"text":"section 409b of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd1a09529-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 302 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343/tIII"},"text":"act July 26, 1947, ch. 343, title III","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/507"},"text":"61 Stat. 507","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-08-10/ch412/s10/b"},"text":"Aug. 10, 1949, ch. 412, § 10(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/585"},"text":"63 Stat. 585","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041/s21"},"text":"Aug. 10, 1956, ch. 1041, § 21","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/629"},"text":"70A Stat. 629","children":[],"tail":", was classified to section 171c–2 of former Title 5, Executive Departments and Government Officers and Employees, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/87/651/tIII/s307A"},"text":"Pub. L. 87–651, title III, § 307A","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/526"},"text":"76 Stat. 526","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
