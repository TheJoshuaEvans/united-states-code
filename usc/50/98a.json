{"tag":"section","attrib":{"id":"idd0e90458-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98a"},"text":null,"children":[{"tag":"num","attrib":{"value":"98a"},"text":"§ 98a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings and declaration of purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd0e90459-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Congress finds that the natural resources of the United States in certain strategic and critical materials are deficient or insufficiently developed to supply the military, industrial, and essential civilian needs of the United States for national defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0e9045a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is the purpose of this subchapter to provide for the acquisition and retention of stocks of certain strategic and critical materials and to encourage the conservation and development of sources of such materials within the United States and thereby to decrease and to preclude, when possible, a dangerous and costly depend­ence by the United States upon foreign sources or a single point of failure for supplies of such materials in times of national emergency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0e9045b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The purpose of the National Defense Stockpile is to serve the interest of national defense only. The National Defense Stockpile is not to be used for economic or budgetary purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0e9045c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the maximum extent practicable and to reduce the reliance of the National Defense Stockpile program on appropriated funds, the National Defense Stockpile Manager shall seek to achieve positive cash flows from the recovery of strategic and critical materials pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s98e/a/5"},"text":"section 98e(a)(5) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd0e9045d-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-06-07/ch190/s2"},"text":"June 7, 1939, ch. 190, § 2","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/41/s2/a"},"text":"Pub. L. 96–41, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-30"},"text":"July 30, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/319"},"text":"93 Stat. 319","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/180/dC/tII/s3202/b"},"text":"Pub. L. 100–180, div. C, title II, § 3202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1245"},"text":"101 Stat. 1245","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dC/tXXXIII/s3311"},"text":"Pub. L. 103–160, div. C, title XXXIII, § 3311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1961"},"text":"107 Stat. 1961","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dC/tXXXIII/s3311/b"},"text":"Pub. L. 104–201, div. C, title XXXIII, § 3311(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2857"},"text":"110 Stat. 2857","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tXIV/s1412"},"text":"Pub. L. 112–239, div. A, title XIV, § 1412","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2048"},"text":"126 Stat. 2048","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXIV/s1411/a"},"text":"Pub. L. 118–31, div. A, title XIV, § 1411(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/523"},"text":"137 Stat. 523","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd0e9045e-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd0e9045f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd0e90460-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 98a, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-06-07/ch190/s2"},"text":"June 7, 1939, ch. 190, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/811"},"text":"53 Stat. 811","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-07-23/ch590"},"text":"July 23, 1946, ch. 590","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/596"},"text":"60 Stat. 596","children":[],"tail":"; 1953 Reorg. Plan No. 3, § 2(b), eff. "},{"tag":"date","attrib":{"date":"1953-06-12"},"text":"June 12, 1953","children":[],"tail":", 18 F.R. 3375, "},{"tag":"ref","attrib":{"href":"/us/stat/67/634"},"text":"67 Stat. 634","children":[],"tail":"; 1958 Reorg. Plan No. 1, § 2, eff. "},{"tag":"date","attrib":{"date":"1958-07-01"},"text":"July 1, 1958","children":[],"tail":", 23 F.R. 4991, "},{"tag":"ref","attrib":{"href":"/us/stat/72/1799"},"text":"72 Stat. 1799","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1968-10-21"},"text":"Oct. 21, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/90/608/s402"},"text":"Pub. L. 90–608, § 402","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1194"},"text":"82 Stat. 1194","children":[],"tail":"; Ex. Ord. No. 11725, § 3, eff. "},{"tag":"date","attrib":{"date":"1973-06-29"},"text":"June 29, 1973","children":[],"tail":", 38 F.R. 17175, related to determination of strategic and critical materials, the quantity and quality to be purchased, formation and functions of industry advisory committees, and the subsistence and traveling expenses of members of those committees, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/96/41/s2/a"},"text":"section 2(a) of Pub. L. 96–41","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s98"},"text":"section 98 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/96/41"},"text":"Pub. L. 96–41","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd0e90461-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" inserted “or a single point of failure” after “foreign sources”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" added subsec. (c) and struck out former subsec. (c) which read as follows: “In providing for the National Defense Stockpile under this subchapter, Congress establishes the following principles:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The purpose of the National Defense Stockpile is to serve the interest of national defense only. The National Defense Stockpile is not to be used for economic or budgetary purposes.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Before ","children":[{"tag":"date","attrib":{"date":"1994-10-01"},"text":"October 1, 1994","children":[],"tail":", the quantities of materials stockpiled under this subchapter should be sufficient to sustain the United States for a period of not less than three years during a national emergency situation that would necessitate total mobilization of the economy of the United States for a sustained conventional global war of indefinite duration."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) On and after ","children":[{"tag":"date","attrib":{"date":"1994-10-01"},"text":"October 1, 1994","children":[],"tail":", the quantities of materials stockpiled under this subchapter should be sufficient to meet the needs of the United States during a period of a national emergency that would necessitate an expansion of the Armed Forces together with a significant mobilization of the economy of the United States under planning guidance issued by the Secretary of Defense.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s3311/1"},"text":"Pub. L. 103–160, § 3311(1)","children":[],"tail":", substituted “Before "},{"tag":"date","attrib":{"date":"1994-10-01"},"text":"October 1, 1994","children":[],"tail":", the quantities” for “The quantities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s3311/2"},"text":"Pub. L. 103–160, § 3311(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180"},"text":"Pub. L. 100–180","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd0e90462-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd0e90463-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dC/tXXXIII/s3311/c"},"text":"Pub. L. 104–201, div. C, title XXXIII, § 3311(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2857"},"text":"110 Stat. 2857","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/201/dC/tXXXIII/s3311/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s98h–5"},"text":"section 98h–5 of this title","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"October 1, 1996","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
