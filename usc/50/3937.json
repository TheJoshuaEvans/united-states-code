{"tag":"section","attrib":{"id":"idd209904e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3937"},"text":null,"children":[{"tag":"num","attrib":{"value":"3937"},"text":"§ 3937.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum rate of interest on debts incurred before military service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd209904f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3937/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest rate limitation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2099050-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3937/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation to 6 percent","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An obligation or liability bearing interest at a rate in excess of 6 percent per year that is incurred by a servicemember, or the servicemember and the servicemember’s spouse jointly, before the servicemember enters military service shall not bear interest at a rate in excess of 6 percent—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2099051-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3937/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the period of military service and one year thereafter, in the case of an obligation or liability consisting of a mortgage, trust deed, or other security in the nature of a mortgage; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2099052-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3937/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the period of military service, in the case of any other obligation or liability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2099053-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3937/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forgiveness of interest in excess of 6 percent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Interest at a rate in excess of 6 percent per year that would otherwise be incurred but for the prohibition in paragraph (1) is forgiven.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2099054-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3937/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevention of acceleration of principal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of any periodic payment due from a servicemember under the terms of the instrument that created an obligation or liability covered by this section shall be reduced by the amount of the interest forgiven under paragraph (2) that is allocable to the period for which such payment is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2099055-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3937/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of limitation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2099056-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3937/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proof of military service","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2099057-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3937/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date of a servicemember’s termination or release from military service, in order for an obligation or liability of the servicemember to be subject to the interest rate limitation in subsection (a), the servicemember shall provide to the creditor written notice and a copy of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd2099058-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3937/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the military orders calling the servicemember to military service and any orders further extending military service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2099059-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3937/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other appropriate indicator of military service, including a certified letter from a commanding officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd209905a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3937/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent verification by creditor","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd209905b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3937/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A creditor may use, in lieu of notice and documentation under subparagraph (A), information retrieved from the Defense Manpower Data Center through the creditor’s normal business reviews of such Center for purposes of obtaining information indicating that the servicemember is on active duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd209905c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3937/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safe harbor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A creditor that uses the information retrieved from the Defense Manpower Data Center under clause (i) with respect to a servicemember has not failed to treat the debt of the servicemember in accordance with subsection (a) if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idd209905d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3937/b/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such information indicates that, on the date the creditor retrieves such information, the servicemember is not on active duty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd209905e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3937/b/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the creditor has not, by the end of the 180-day period under subparagraph (A), received the written notice and documentation required under that subparagraph with respect to the servicemember.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd209905f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3937/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation effective as of date of order to active duty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon receipt of written notice and a copy of orders calling a servicemember to military service, the creditor shall treat the debt in accordance with subsection (a), effective as of the date on which the servicemember is called to military service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2099060-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3937/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creditor protection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A court may grant a creditor relief from the limitations of this section if, in the opinion of the court, the ability of the servicemember to pay interest upon the obligation or liability at a rate in excess of 6 percent per year is not materially affected by reason of the servicemember’s military service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2099061-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3937/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2099062-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3937/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “interest” includes service charges, renewal charges, fees, or any other charges (except bona fide insurance) with respect to an obligation or liability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2099063-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3937/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligation or liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “obligation or liability” includes an obligation or liability consisting of a mortgage, trust deed, or other security in the nature of a mortgage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2099064-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3937/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whoever knowingly violates subsection (a) shall be fined as provided in title 18, imprisoned for not more than one year, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2099065-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title II, § 207, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s1"},"text":"Pub. L. 108–189, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2844"},"text":"117 Stat. 2844","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dB/tII/s2203/b"},"text":"Pub. L. 110–289, div. B, title II, § 2203(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2849"},"text":"122 Stat. 2849","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/389/tVIII/s807"},"text":"Pub. L. 110–389, title VIII, § 807","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4189"},"text":"122 Stat. 4189","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/275/tIII/s303/b/1"},"text":"Pub. L. 111–275, title III, § 303(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-13"},"text":"Oct. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2877"},"text":"124 Stat. 2877","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tV/s600"},"text":"Pub. L. 115–232, div. A, title V, § 600","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1793"},"text":"132 Stat. 1793","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2099066-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2099067-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd2099068-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 527 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd2099069-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 207 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"act Oct. 17, 1940, ch. 888","children":[],"tail":", art. II, as added "},{"tag":"ref","attrib":{"href":"/us/act/1942-10-21/ch619"},"text":"Oct. 21, 1942, ch. 619","children":[],"tail":", title V, § 507(b)(2)(B), "},{"tag":"ref","attrib":{"href":"/us/stat/56/964"},"text":"56 Stat. 964","children":[],"tail":", related to limitations prescribed by internal revenue laws as affected by period of service, prior to the general amendment of this Act by "},{"tag":"ref","attrib":{"href":"/us/pl/108/189"},"text":"Pub. L. 108–189","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3936"},"text":"section 3936 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd209906a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" amended par. (1) generally. Prior to amendment, text read as follows: “In order for an obligation or liability of a servicemember to be subject to the interest rate limitation in subsection (a), the servicemember shall provide to the creditor written notice and a copy of the military orders calling the servicemember to military service and any orders further extending military service, not later than 180 days after the date of the servicemember’s termination or release from military service.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/275"},"text":"Pub. L. 111–275","children":[],"tail":" struck out subsec. (f). Text read as follows: “The penalties provided under subsection (e) are in addition to and do not preclude any other remedy available under law to a person claiming relief under this section, including any award for consequential or punitive damages.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s2203/b/1"},"text":"Pub. L. 110–289, § 2203(b)(1)","children":[],"tail":", substituted “in excess of 6 percent—” for “in excess of 6 percent per year during the period of military service.” and added subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s2203/b/2"},"text":"Pub. L. 110–289, § 2203(b)(2)","children":[],"tail":", added subsec. (d) and struck out former subsec. (d). Prior to amendment, text read as follows: “As used in this section, the term ‘interest’ includes service charges, renewal charges, fees, or any other charges (except bona fide insurance) with respect to an obligation or liability.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389"},"text":"Pub. L. 110–389","children":[],"tail":" added subsecs. (e) and (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd209906b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd209906c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any case not final before ","children":[{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s3"},"text":"section 3 of Pub. L. 108–189","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3901"},"text":"section 3901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
