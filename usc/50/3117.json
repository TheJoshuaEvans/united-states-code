{"tag":"section","attrib":{"id":"idd1ac7ba6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3117"},"text":null,"children":[{"tag":"num","attrib":{"value":"3117"},"text":"§ 3117.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of counterintelligence assessments and investigations of Federal candidates or officeholders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1ac7ba7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3117/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ac7ba8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3117/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (3), the Director of the Federal Bureau of Investigation shall notify the chairmen and ranking minority members of the appropriate congressional committees, the Speaker and minority leader of the House of Representatives, and the majority and minority leaders of the Senate of each counterintelligence assessment or investigation of an individual who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1ac7ba9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3117/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a candidate for Federal office; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ac7baa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3117/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a holder of Federal office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ac7bab-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3117/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The notice required under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1ac7bac-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3117/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the relevant facts associated with the counterintelligence assessment or investigation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ac7bad-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3117/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity of such individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ac7bae-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3117/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may refrain from providing a notice under paragraph (1) to an individual who is otherwise a recipient of notices under such paragraph if that individual is a target of the counterintelligence assessment or investigation covered by the notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ac7baf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3117/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall provide each notice under subsection (a) not later than 15 days after the date of the commencement of the counterintelligence assessment or investigation that is the subject of such notice. With respect to counterintelligence assessments or investigations that commenced before ","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"December 18, 2025","children":[],"tail":" and are ongoing as of "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"December 18, 2025","children":[],"tail":", the Director shall provide each notice under subsection (a) not later than 15 days after "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"December 18, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ac7bb0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3117/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ac7bb1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3117/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1ac7bb2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3117/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional intelligence committees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ac7bb3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3117/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committees on the Judiciary of the House of Representatives and the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ac7bb4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3117/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “candidate” and “Federal office” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"section 30101 of title 52","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1ac7bb5-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title V, § 518, as added "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dF/tLXV/s6521"},"text":"Pub. L. 119–60, div. F, title LXV, § 6521","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1630"},"text":"139 Stat. 1630","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
