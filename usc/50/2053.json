{"tag":"section","attrib":{"id":"idd15b755b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2053"},"text":null,"children":[{"tag":"num","attrib":{"value":"2053"},"text":"§ 2053.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary retirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd15b755c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2053/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A participant who is at least 50 years of age and has completed 20 years of service may, on the participant’s application and with the consent of the Director, be retired from the Agency and receive benefits in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2031"},"text":"section 2031 of this title","children":[],"tail":" if the participant has not less than 10 years of service with the Agency."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15b755d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2053/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A participant who has at least 25 years of service, ten years of which are with the Agency, may retire, with the consent of the Director, at any age and receive benefits in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2031"},"text":"section 2031 of this title","children":[],"tail":" if the Office of Personnel Management has authorized separation from service voluntarily for Agency employees under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8336/d/2"},"text":"section 8336(d)(2) of title 5","children":[],"tail":" with respect to the Civil Service Retirement System or section 8414(b)(1)(B) of such title with respect to the Federal Employees’ Retirement System."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd15b755e-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/tII/s233"},"text":"Pub. L. 88–643, title II, § 233","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s802"},"text":"Pub. L. 102–496, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3225"},"text":"106 Stat. 3225","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/36/s3"},"text":"Pub. L. 103–36, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-08"},"text":"June 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/106"},"text":"107 Stat. 106","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd15b755f-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd15b7560-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd15b7561-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/s233"},"text":"section 233 of Pub. L. 88–643","children":[],"tail":", title II, "},{"tag":"date","attrib":{"date":"1964-10-13"},"text":"Oct. 13, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1048"},"text":"78 Stat. 1048","children":[],"tail":", related to voluntary retirement and was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403"},"text":"section 403 of this title","children":[],"tail":" prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/88/643"},"text":"Pub. L. 88–643","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s802"},"text":"section 802 of Pub. L. 102–496","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd15b7562-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/36"},"text":"Pub. L. 103–36","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd15b7563-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd15b7564-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of fourth month beginning after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s805"},"text":"section 805 of Pub. L. 102–496","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
