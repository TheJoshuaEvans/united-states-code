{"tag":"section","attrib":{"id":"idd1c92bb4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3311"},"text":null,"children":[{"tag":"num","attrib":{"value":"3311"},"text":"§ 3311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submittal to Congress by heads of elements of intelligence community of plans for orderly shutdown in event of absence of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1c92bb5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3311/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever the head of an applicable agency submits a plan to the Director of the Office of Management and Budget in accordance with section 124 of Office of Management and Budget Circular A–11, pertaining to agency operations in the absence of appropriations, or any successor circular of the Office that requires the head of an applicable agency to submit to the Director a plan for an orderly shutdown in the event of the absence of appropriations, such head shall submit a copy of such plan to the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c92bb6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3311/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The congressional intelligence committees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c92bb7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3311/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Subcommittee on Defense of the Committee on Appropriations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c92bb8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3311/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Subcommittee on Defense of the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c92bb9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3311/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of a plan for an element of the intelligence community that is within the Department of Defense, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c92bba-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3311/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c92bbb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3311/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c92bbc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3311/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Head of an applicable agency defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “head of an applicable agency” includes the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c92bbd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3311/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c92bbe-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3311/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Central Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c92bbf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3311/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each head of each element of the intelligence community that is within the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1c92bc0-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/126/tIII/s323"},"text":"Pub. L. 113–126, title III, § 323","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-07"},"text":"July 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1401"},"text":"128 Stat. 1401","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1c92bc1-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1c92bc2-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd1c92bc3-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “congressional intelligence committees” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/126/s2"},"text":"section 2 of Pub. L. 113–126","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
