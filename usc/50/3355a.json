,"attrib":{"href":"/us/stat/137/1097"},"text":"137 Stat. 1097","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1d9cce3-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1d9cce4-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1d9cce5-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order 13526, referred to in subsec. (a)(2), is set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"text":"section 3161 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Records Act of 1950, referred to in subsec. (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), was title V of "},{"tag":"ref","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"act June 30, 1949, ch. 288","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-05/ch849/s6/d"},"text":"Sept. 5, 1950, ch. 849, § 6(d)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/583"},"text":"64 Stat. 583","children":[],"tail":", which was classified generally to sections 392 to 396 and 397 to 401 of former Title 44, Public Printing and Documents. Section 6(d) of act "},{"tag":"date","attrib":{"date":"1950-09-05"},"text":"Sept. 5, 1950","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1238"},"text":"82 Stat. 1238","children":[],"tail":", the first section of which enacted Title 44, Public Printing and Documents. For disposition of sections of former Title 44, see Table at the beginning of Title 44. Title V of act "},{"tag":"date","attrib":{"date":"1949-06-30"},"text":"June 30, 1949","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s4"},"text":"Pub. L. 107–217, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1d9cce6-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out in a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"text":"section 3161 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1d9cce7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (c)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s7604/1"},"text":"Pub. L. 118–31, § 7604(1)","children":[],"tail":", added pars. (5) and (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s7604/2"},"text":"Pub. L. 118–31, § 7604(2)","children":[],"tail":", designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “Executive Order 13526” for “Executive Order 12958”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5” for “the Federal Advisory Committee Act (5 U.S.C. App.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “funds, but shall meet in person not less frequently than on a quarterly basis.” for “funds.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (c)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/235/s2/a"},"text":"Pub. L. 112–235, § 2(a)","children":[],"tail":", substituted “from the date of the appointment.” for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/235/s2/b"},"text":"Pub. L. 112–235, § 2(b)","children":[],"tail":", struck out at end “A member of the Board appointed to fill a vacancy before the expiration of a term shall serve for the remainder of the term.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259"},"text":"Pub. L. 111–259","children":[],"tail":" substituted “jurisdiction or by a member of the committee of jurisdiction,” for “jurisdiction,” and inserted “, to evaluate the proper classification of certain records,” after “certain records”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1102/a"},"text":"Pub. L. 108–458, § 1102(a)","children":[],"tail":", designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1102/b"},"text":"Pub. L. 108–458, § 1102(b)","children":[],"tail":", added par. (5)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
