{"tag":"section","attrib":{"id":"idd1d783b3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3355a"},"text":"§ 3355a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public Interest Declassification Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1d783b4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d783b5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established within the executive branch of the United States a board to be known as the “Public Interest Declassification Board” (in this subchapter referred to as the “Board”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d783b6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board shall report directly to the President or, upon designation by the President, the Vice President, the Attorney General, or other designee of the President. The other designee of the President under this paragraph may not be an agency head or official authorized to classify information under Executive Order 13526, or any successor order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d783b7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Board are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d783b8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To advise the President, the Assistant to the President for National Security Affairs, the Director of the Office of Management and Budget, and such other executive branch officials as the Board considers appropriate on the systematic, thorough, coordinated, and comprehensive identification, collection, review for declassification, and release to Congress, interested agencies, and the public of declassified records and materials (including donated historical materials) that are of archival value, including records and materials of extraordinary public interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d783b9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To promote the fullest possible public access to a thorough, accurate, and reliable documentary record of significant United States national security decisions and significant United States national security activities in order to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d783ba-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the oversight and legislative functions of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d783bb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the policymaking role of the executive branch;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d783bc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" respond to the interest of the public in national security matters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d783bd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote reliable historical analysis and new avenues of historical study in national security matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d783be-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide recommendations to the President for the identification, collection, and review for declassification of information of extraordinary public interest that does not undermine the national security of the United States, to be undertaken in accordance with a declassification program that has been established or may be established by the President by Executive order.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d783bf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To advise the President, the Assistant to the President for National Security Affairs, the Director of the Office of Management and Budget, and such other executive branch officials as the Board considers appropriate on policies deriving from the issuance by the President of Executive orders regarding the classification and declassification of national security information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d783c0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To review and make recommendations to the President in a timely manner with respect to any congressional request, made by the committee of jurisdiction or by a member of the committee of jurisdiction, to declassify certain records, to evaluate the proper classification of certain records, or to reconsider a declination to declassify specific records.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d783c1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d783c2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Board shall be composed of nine individuals appointed from among citizens of the United States who are preeminent in the fields of history, national security, foreign policy, intelligence policy, social science, law, or archives, including individuals who have served in Congress or otherwise in the Federal Government or have otherwise engaged in research, scholarship, or publication in such fields on matters relating to the national security of the United States, of whom—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d783c3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" five shall be appointed by the President;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d783c4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be appointed by the Speaker of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d783c5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be appointed by the majority leader of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d783c6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be appointed by the minority leader of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d783c7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be appointed by the minority leader of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d783c8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d783c9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Of the members initially appointed to the Board by the President—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1d783ca-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three shall be appointed for a term of 4 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1d783cb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be appointed for a term of 3 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1d783cc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be appointed for a term of 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d783cd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The members initially appointed to the Board by the Speaker of the House of Representatives or by the majority leader of the Senate shall be appointed for a term of 3 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d783ce-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The members initially appointed to the Board by the minority leader of the House of Representatives or the Senate shall be appointed for a term of 2 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d783cf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any subsequent appointment to the Board shall be for a term of 3 years from the date of the appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d783d0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A vacancy in the Board shall be filled in the same manner as the original appointment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d783d1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Board may be appointed to a new term on the Board upon the expiration of the member’s term on the Board, except that no member may serve more than three full terms on the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d783d2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member of the Board whose term has expired may continue to serve until the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d783d3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that a successor is appointed and sworn in; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d783d4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that is 1 year after the date of the expiration of the term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d783d5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 30 days after the date on which the term of a member of the Board ends, the appointing authority of the member shall submit to Congress a plan to appoint a successor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d783d6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson; Executive Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d783d7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d783d8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall designate one of the members of the Board as the Chairperson of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d783d9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term of service as Chairperson of the Board shall be 2 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d783da-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member serving as Chairperson of the Board may be redesignated as Chairperson of the Board upon the expiration of the member’s term as Chairperson of the Board, except that no member shall serve as Chairperson of the Board for more than 6 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d783db-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Information Security Oversight Office shall serve as the Executive Secretary of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d783dc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall meet as needed to accomplish its mission, consistent with the availability of funds, but shall meet in person not less frequently than on a quarterly basis. A majority of the members of the Board shall constitute a quorum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d783dd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d783de-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any employee of the Federal Government may be detailed to the Board, with the agreement of and without reimbursement to the detailing agency, and such detail shall be without interruption or loss of civil, military, or foreign service status or privilege.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d783df-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to any employees detailed to the Board under paragraph (1), the Board may, subject to the availability of funds, hire not more than 12 staff members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d783e0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d783e1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The members and staff of the Board shall, as a condition of appointment to or employment with the Board, hold appropriate security clearances for access to the classified records and materials to be reviewed by the Board or its staff, and shall follow the guidance and practices on security under applicable Executive orders and Presidential or agency directives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d783e2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The head of an agency shall, as a condition of granting access to a member of the Board, the Executive Secretary of the Board, or a member of the staff of the Board to classified records or materials of the agency under this subchapter, require the member, the Executive Secretary, or the member of the staff, as the case may be, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d783e3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" execute an agreement regarding the security of such records or materials that is approved by the head of the agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d783e4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold an appropriate security clearance granted or recognized under the standard procedures and eligibility criteria of the agency, including any special access approval required for access to such records or materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d9ccd5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The members of the Board, the Executive Secretary of the Board, and the members of the staff of the Board may not use any information acquired in the course of their official activities on the Board for nonofficial purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d9ccd6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of any law or regulation governing access to classified information that pertains to the national security of the United States, and subject to any limitations on access arising under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3355d/b"},"text":"section 3355d(b) of this title","children":[],"tail":", and to facilitate the advisory functions of the Board under this subchapter, a member of the Board seeking access to a record or material under this subchapter shall be deemed for purposes of this subsection to have a need to know the contents of the record or material."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d9ccd7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d9ccd8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each member of the Board shall receive compensation at a rate not to exceed the daily equivalent of the annual rate of basic pay payable for positions at ES–1 of the Senior Executive Service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5382"},"text":"section 5382 of title 5","children":[],"tail":" for each day such member is engaged in the actual performance of duties of the Board."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d9ccd9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Board shall be allowed travel expenses, including per diem in lieu of subsistence at rates authorized for employees of agencies under subchapter I of chapter 57 of title 5, while away from their homes or regular places of business in the performance of the duties of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d9ccda-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance; annual budget","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d9ccdb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On behalf of the President, the Assistant to the President for National Security Affairs shall provide guidance on policy to the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d9ccdc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Executive Secretary of the Board, under the direction of the Chairperson of the Board and the Board, and acting in consultation with the Archivist of the United States, the Assistant to the President for National Security Affairs, and the Director of the Office of Management and Budget, shall prepare the annual budget of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d9ccdd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Information Security Oversight Office may support the activities of the Board under this subchapter. Such support shall be provided on a reimbursable basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d9ccde-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability of records and reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d9ccdf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board shall make available for public inspection records of its proceedings and reports prepared in the course of its activities under this subchapter to the extent such records and reports are not classified and would not be exempt from release under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d9cce0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In making records and reports available under paragraph (1), the Board shall coordinate the release of such records and reports with appropriate officials from agencies with expertise in classified information in order to ensure that such records and reports do not inadvertently contain classified information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d9cce1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355a/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of certain administrative laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of chapter 10 of title 5 shall not apply to the activities of the Board under this subchapter. However, the records of the Board shall be governed by the provisions of the Federal Records Act of 1950.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1d9cce2-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/567/tVII/s703"},"text":"Pub. L. 106–567, title VII, § 703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2856"},"text":"114 Stat. 2856","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI/s1102/a"},"text":"Pub. L. 108–458, title I, § 1102(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"t