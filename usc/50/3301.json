{"tag":"section","attrib":{"id":"idd1c6bb19-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3301"},"text":null,"children":[{"tag":"num","attrib":{"value":"3301"},"text":"§ 3301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiyear national intelligence program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1c6bb1a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual submission of multiyear national intelligence program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence shall submit to the congressional committees specified in subsection (d) each year a multiyear national intelligence program plan reflecting the estimated expenditures and proposed appropriations required to support that program. Any such multiyear national intelligence program plan shall cover the fiscal year with respect to which the budget is submitted and at least four succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c6bb1b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time of submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence shall submit the report required by subsection (a) each year at or about the same time that the budget is submitted to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c6bb1c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency with budget estimates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence and the Secretary of Defense shall ensure that the estimates referred to in subsection (a) are consistent with the budget estimates submitted to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":" for the fiscal year concerned and with the estimated expenditures and proposed appropriations for the future-years defense program submitted pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s221"},"text":"section 221 of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c92b1d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3301/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The congressional committees referred to in subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c92b1e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3301/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Armed Services, the Committee on Appropriations, and the Select Committee on Intelligence of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c92b1f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3301/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Armed Services, the Committee on Appropriations, and the Permanent Select Committee on Intelligence of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1c92b20-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXIV/s1403"},"text":"Pub. L. 101–510, div. A, title XIV, § 1403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1675"},"text":"104 Stat. 1675","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1502/c/4/B"},"text":"Pub. L. 104–106, div. A, title XV, § 1502(c)(4)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/507"},"text":"110 Stat. 507","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1067/10"},"text":"Pub. L. 106–65, div. A, title X, § 1067(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/774"},"text":"113 Stat. 774","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/tVIII/s805/a"},"text":"Pub. L. 111–259, title VIII, § 805(a)","children":[],"tail":"–(d)(1), "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2748"},"text":"124 Stat. 2748","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1c92b21-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1c92b22-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1c92b23-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s404b"},"text":"section 404b of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1c92b24-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s805/d/1"},"text":"Pub. L. 111–259, § 805(d)(1)","children":[],"tail":", struck out “foreign” after “national” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s805/a"},"text":"Pub. L. 111–259, § 805(a)","children":[],"tail":", (b)(1), struck out “foreign” after “national” wherever appearing in heading and text and substituted “Director of National Intelligence” for “Director of Central Intelligence” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s805/b/2"},"text":"Pub. L. 111–259, § 805(b)(2)","children":[],"tail":", inserted “of National Intelligence” after “Director”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s805/b/1"},"text":"Pub. L. 111–259, § 805(b)(1)","children":[],"tail":", (c), substituted “Director of National Intelligence” for “Director of Central Intelligence” and “future-years defense program submitted pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s221"},"text":"section 221 of title 10","children":[],"tail":"” for “multiyear defense program submitted pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s114a"},"text":"section 114a of title 10","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “Committee on Armed Services” for “Committee on National Security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s1502/c/4/B/i"},"text":"Pub. L. 104–106, § 1502(c)(4)(B)(i)","children":[],"tail":", substituted “the congressional committees specified in subsection (d) each year” for “the Committees on Armed Services and Appropriations of the Senate and the House of Representatives and the Select Committee on Intelligence of the Senate and the Permanent Select Committee on Intelligence of the House of Representatives each year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s1502/c/4/B/ii"},"text":"Pub. L. 104–106, § 1502(c)(4)(B)(ii)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1c92b25-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idd1c92b26-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2023 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tVI/s7601"},"text":"Pub. L. 118–31, div. G, title VI, § 7601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1096"},"text":"137 Stat. 1096","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dG/tVI/s7601"},"text":"“This title [enacting sections 3344a and 3350a of this title, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3355a"},"text":"section 3355a of this title","children":[],"tail":", and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3501"},"text":"section 3501 of Title 44","children":[],"tail":", Public Printing and Documents] may be cited as the ‘Sensible Classification Act of 2023’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idd1c92b27-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/tIX/s901/a"},"text":"Pub. L. 107–306, title IX, § 901(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2432"},"text":"116 Stat. 2432","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/306/tIX/s901/a"},"text":"“This title [see Tables for classification] may be cited as the ‘Counterintelligence Enhancement Act of 2002’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idd1c92b28-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/567/tVII/s701"},"text":"Pub. L. 106–567, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2856"},"text":"114 Stat. 2856","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/567/tVII/s701"},"text":"“This title [enacting subchapter III–A of this chapter] may be cited as the ‘Public Interest Declassification Act of 2000’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
