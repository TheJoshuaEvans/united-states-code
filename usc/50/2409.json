{"tag":"section","attrib":{"id":"idd169ce31-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2409"},"text":null,"children":[{"tag":"num","attrib":{"value":"2409"},"text":"§ 2409.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of authority of Secretary of Energy to modify organization of Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding the authority granted by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7253"},"text":"section 7253 of title 42","children":[],"tail":" or any other provision of law, the Secretary of Energy may not establish, abolish, alter, consolidate, or discontinue any organizational unit or component, or transfer any function, of the Administration, except as authorized by subsection (b) or (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2481"},"text":"section 2481 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd169ce32-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dC/tXXXII/s3219"},"text":"Pub. L. 106–65, div. C, title XXXII, § 3219","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/377/s1/a/2/tIII/s314/a"},"text":"Pub. L. 106–377, § 1(a)(2) [title III, § 314(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-27"},"text":"Oct. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1441"},"text":"114 Stat. 1441","children":[],"tail":", 1441A–81.)"}],"tail":"\n"}],"tail":null}
