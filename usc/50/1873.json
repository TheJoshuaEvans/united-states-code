{"tag":"section","attrib":{"id":"idd145f1b2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873"},"text":null,"children":[{"tag":"num","attrib":{"value":"1873"},"text":"§ 1873.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd145f1b3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report by Director of the Administrative Office of the United States Courts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd145f1b4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Administrative Office of the United States Courts shall annually submit to the Permanent Select Committee on Intelligence and the Committee on the Judiciary of the House of Representatives and the Select Committee on Intelligence and the Committee on the Judiciary of the Senate, subject to a declassification review by the Attorney General and the Director of National Intelligence, a report that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd145f1b5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of applications or certifications for orders submitted under each of sections 1805, 1824, 1842, 1861,","children":[{"tag":"ref","attrib":{"idref":"fn002037"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002037"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" 1881a, 1881b, and 1881c of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd145f1b6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of such orders granted under each of those sections;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd145f1b7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of orders modified under each of those sections;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd145f1b8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of applications or certifications denied under each of those sections;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd145f1b9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of appointments of an individual to serve as amicus curiae under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1803"},"text":"section 1803 of this title","children":[],"tail":", including the name of each individual appointed to serve as amicus curiae;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd145f1ba-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of findings issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1803/i"},"text":"section 1803(i) of this title","children":[],"tail":" that such appointment is not appropriate and the text of any such findings; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd145f1bb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of times the Foreign Intelligence Surveillance Court and the Foreign Intelligence Surveillance Court of Review exercised authority under chapter 21 of title 18 and a description of each use of such authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd145f1bc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall make the report required under paragraph (1) publicly available on an Internet Web site, except that the Director shall not make publicly available on an Internet Web site the findings described in subparagraph (F) of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd14862bd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory reporting by Director of National Intelligence","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (d), the Director of National Intelligence shall annually make publicly available on an Internet Web site a report that identifies, for the preceding 12-month period—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd14862be-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the total number of orders issued pursuant to subchapters I and II and sections 1881b and 1881c of this title and a good faith estimate of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd14862bf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of targets of such orders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14862c0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of targets of such orders who are known to not be United States persons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14862c1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of targets of such orders who are known to be United States persons;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14862c2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the total number of orders issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1881a"},"text":"section 1881a of this title","children":[],"tail":", including pursuant to subsection (f)(2) of such section, and a good faith estimate of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd14862c3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of targets of such orders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14862c4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of search terms concerning a known United States person used to retrieve the unminimized contents (or combined unminimized contents and noncontents information) of electronic communications or wire communications obtained through acquisitions authorized under such section, excluding the number of search terms used to prevent the return of information concerning a United States person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14862c5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of queries concerning a known United States person of unminimized noncontents information relating to electronic communications or wire communications obtained through acquisitions authorized under such section, excluding the number of queries containing information used to prevent the return of information concerning a United States person; ","children":[{"tag":"ref","attrib":{"idref":"fn002038"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002038"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be followed by “and”."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14862c6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of instances in which the Federal Bureau of Investigation opened, under the Criminal Investigative Division or any successor division, an investigation of a United States person (who is not considered a threat to national security) based wholly or in part on an acquisition authorized under such section;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14862c7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the total number of orders issued pursuant to subchapter III and a good faith estimate of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd14862c8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the number of targets of such orders, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd14862c9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of targets of such orders who are known to not be United States persons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd14862ca-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of targets of such orders who are known to be United States persons; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14862cb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of unique identifiers used to communicate information collected pursuant to such orders;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14862cc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of criminal proceedings in which the United States or a State or political subdivision thereof provided notice pursuant to subsection (c) or (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1806"},"text":"section 1806 of this title","children":[],"tail":" (including with respect to information acquired from an acquisition conducted under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1881a"},"text":"section 1881a of this title","children":[],"tail":") or subsection (d) or (e) of "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1825"},"text":"section 1825 of this title","children":[],"tail":" of the intent of the government to enter into evidence or otherwise use or disclose any information obtained or derived from electronic surveillance, physical search, or an acquisition conducted pursuant to this chapter;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14862cd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the total number of orders issued pursuant to applications made under section 1861(b)(2)(B) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title and a good faith estimate of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd14862ce-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of targets of such orders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14862cf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of unique identifiers used to communicate information collected pursuant to such orders;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14862d0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the total number of orders issued pursuant to applications made under section 1861(b)(2)(C) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title and a good faith estimate of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd14862d1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of targets of such orders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14862d2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of unique identifiers used to communicate information collected pursuant to such orders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14862d3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of search terms that included information concerning a United States person that were used to query any database of call detail records obtained through the use of such orders; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14862d4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of national security letters issued and the number of requests for information contained within such national security letters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd14862d5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The annual reports required by subsections (a) and (b) shall be made publicly available during April of each year and include information relating to the previous calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd14862d6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd14862d7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of numerical range","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a good faith estimate required to be reported under subparagraph (B) of any of paragraphs (3), (5), or (6) of subsection (b) is fewer than 500, it shall be expressed as a numerical range of “fewer than 500” and shall not be expressed as an individual number.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14862d8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability to electronic mail address and telephone numbers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (3)(B) of subsection (b) shall not apply to orders resulting in the acquisition of information by the Federal Bureau of Investigation that does not include electronic mail addresses or telephone numbers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14862d9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd14862da-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Director of National Intelligence concludes that a good faith estimate required to be reported under subsection (b)(2)(C) cannot be determined accurately because some but not all of the relevant elements of the intelligence community are able to provide such good faith estimate, the Director shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd14862db-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify that conclusion in writing to the Select Committee on Intelligence and the Committee on the Judiciary of the Senate and the Permanent Select Committee on Intelligence and the Committee on the Judiciary of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd14862dc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report the good faith estimate for those relevant elements able to provide such good faith estimate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd14862dd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/d/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explain when it is reasonably anticipated that such an estimate will be able to be determined fully and accurately; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd14862de-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/d/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make such certification publicly available on an Internet Web site.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14862df-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A certification described in subparagraph (A) shall be prepared in unclassified form, but may contain a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14862e0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Director of National Intelligence continues to conclude that the good faith estimates described in this paragraph cannot be determined accurately, the Director shall annually submit a certification in accordance with this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd14862e1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory reporting by Director of Federal Bureau of Investigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Federal Bureau of Investigation shall annually submit to the Permanent Select Committee on Intelligence and the Committee on Judiciary of the House of Representatives and the Select Committee on Intelligence and the Committee on the Judiciary of the Senate, a report describing the accountability actions taken by the Federal Bureau of Investigation in the preceding 12-month period for noncompliant querying of information acquired under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1881a"},"text":"section 1881a of this title","children":[],"tail":" and any such actions taken pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1803/m"},"text":"section 1803(m) of this title","children":[],"tail":", to include the number of ongoing personnel investigations, the outcome of any completed personnel investigations and any related adverse personnel actions taken."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd14862e2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory reporting on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1881a"},"text":"section 1881a of this title","children":[],"tail":" by Director of Federal Bureau of Investigation"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd14862e3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Federal Bureau of Investigation shall annually submit to the Permanent Select Committee on Intelligence and the Committee on the Judiciary of the House of Representatives and the Select Committee on Intelligence and the Committee on the Judiciary of the Senate a report that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd14862e4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of United States person queries by the Federal Bureau of Investigation of unminimized contents or noncontents acquired pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1881a/a"},"text":"section 1881a(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14862e5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of approved queries using the Federal Bureau of Investigation’s batch job technology, or successor tool;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14862e6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of queries using the Federal Bureau of Investigation’s batch job technology, or successor tool, conducted by the Federal Bureau of Investigation against information acquired pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1881a/a"},"text":"section 1881a(a) of this title","children":[],"tail":" for which pre-approval was not obtained due to emergency circumstances;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14862e7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of United States person queries conducted by the Federal Bureau of Investigation of unminimized contents or noncontents acquired pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1881a/a"},"text":"section 1881a(a) of this title","children":[],"tail":" solely to retrieve evidence of a crime;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14862e8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/f/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a good faith estimate of the number of United States person query terms used by the Federal Bureau of Investigation to conduct queries of unminimized contents or noncontents acquired pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1881a/a"},"text":"section 1881a(a) of this title","children":[],"tail":" primarily to protect the United States person who is the subject of the query; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14862e9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/f/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a good faith estimate of the number of United States person query terms used by the Federal Bureau of Investigation to conduct queries of unminimized contents or noncontents acquired pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1881a/a"},"text":"section 1881a(a) of this title","children":[],"tail":" where the United States person who is the subject of the query is a target or subject of an investigation by the Federal Bureau of Investigation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14862ea-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to declassification review by the Attorney General and the Director of National Intelligence, each annual report submitted pursuant to paragraph (1) shall be available to the public during the first April following the calendar year covered by the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14862eb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarterly report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning on the date that is not later than 1 year after the effective date of this paragraph, the Director of the Federal Bureau of Investigation shall submit a quarterly report to the congressional intelligence committees and to the Committees on the Judiciary of the House of Representatives and of the Senate that includes the number of U.S. person queries conducted during that quarter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd14862ec-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd14862ed-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “contents” has the meaning given that term under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2510"},"text":"section 2510 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14862ee-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic communication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “electronic communication” has the meaning given that term under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2510"},"text":"section 2510 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14862ef-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National security letter","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “national security letter” means a request for a report, records, or other information under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd14862f0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2709"},"text":"section 2709 of title 18","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14862f1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3414/a/5/A"},"text":"section 3414(a)(5)(A) of title 12","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14862f2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/g/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (a) or (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681u"},"text":"section 1681u of title 15","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd14862f3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/g/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681v/a"},"text":"section 1681v(a) of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14862f4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States person” means a citizen of the United States or an alien lawfully admitted for permanent residence (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a"},"text":"section 1101(a) of title 8","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14862f5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1873/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wire communication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “wire communication” has the meaning given that term under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2510"},"text":"section 2510 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd14862f6-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511/tVI/s603"},"text":"Pub. L. 95–511, title VI, § 603","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/23/tVI/s602/a"},"text":"Pub. L. 114–23, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-02"},"text":"June 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/292"},"text":"129 Stat. 292","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/118/tI/s102/b"},"text":"Pub. L. 115–118, title I, § 102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-01-19"},"text":"Jan. 19, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/9"},"text":"132 Stat. 9","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/49"},"text":"Pub. L. 118–49","children":[],"tail":", §§ 11(a)(1), 12(a), 14(b), "},{"tag":"date","attrib":{"date":"2024-04-20"},"text":"Apr. 20, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/878"},"text":"138 Stat. 878","children":[],"tail":", 879, 882.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd14862f7-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd14862f8-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd14862f9-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1861"},"text":"Section 1861 of this title","children":[],"tail":", referred to in subsecs. (a)(1)(A) and (b)(5), (6), means "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1861"},"text":"section 1861 of this title","children":[],"tail":" prior to the amendment of section 1861 by "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/tI/s102/b"},"text":"Pub. L. 109–177, title I, § 102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/195"},"text":"120 Stat. 195","children":[],"tail":", set out as an Effective Date of 2006 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1805"},"text":"section 1805 of this title","children":[],"tail":", which amended "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1861"},"text":"section 1861 of this title","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2020-03-15"},"text":"Mar. 15, 2020","children":[],"tail":", so that such section read as it read on "},{"tag":"date","attrib":{"date":"2001-10-25"},"text":"Oct. 25, 2001","children":[],"tail":", with certain exceptions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b)(4), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511"},"text":"Pub. L. 95–511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-25"},"text":"Oct. 25, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1783"},"text":"92 Stat. 1783","children":[],"tail":", known as the Foreign Intelligence Surveillance Act of 1978, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801"},"text":"section 1801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For the effective date of this paragraph, referred to in subsec. (f)(3), see Effective Date of 2024 Amendment note below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd14862fa-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(1)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/49/s14/b"},"text":"Pub. L. 118–49, § 14(b)","children":[],"tail":", added subpar. (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/49/s11/a/1/A"},"text":"Pub. L. 118–49, § 11(a)(1)(A)","children":[],"tail":", inserted “(or combined unminimized contents and noncontents information)” after “unminimized contents”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/49/s11/a/1/B"},"text":"Pub. L. 118–49, § 11(a)(1)(B)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) related to nonapplicability to certain information, consisting of subpar. (A) relating to certain information held by or queries conducted by the Federal Bureau of Investigation and subpar. (B) relating to electronic mail address and telephone numbers."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/49/s12/a/2"},"text":"Pub. L. 118–49, § 12(a)(2)","children":[],"tail":", added subsec. (e). Former subsec. (e) redesignated (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/49/s11/a/1/C"},"text":"Pub. L. 118–49, § 11(a)(1)(C)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/49/s12/a/1"},"text":"Pub. L. 118–49, § 12(a)(1)","children":[],"tail":", redesignated subsec. (e) as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/118/s102/b/1/A"},"text":"Pub. L. 115–118, § 102(b)(1)(A)","children":[],"tail":", substituted “good faith estimate of—” for “good faith estimate of the number of targets of such orders;” and added subpars. (A) to (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/118/s102/b/1/B"},"text":"Pub. L. 115–118, § 102(b)(1)(B)","children":[],"tail":", inserted “, including pursuant to subsection (f)(2) of such section,” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1881a"},"text":"section 1881a of this title","children":[],"tail":"” in introductory provisions, added subpars. (A) and (D), and redesignated former subpars. (A) and (B) as (B) and (C), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/118/s102/b/1/C"},"text":"Pub. L. 115–118, § 102(b)(1)(C)","children":[],"tail":", substituted “orders, including—” for “orders; and” and added cls. (i) and (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/118/s102/b/1/D"},"text":"Pub. L. 115–118, § 102(b)(1)(D)","children":[],"tail":", (E), added par. (4) and redesignated former pars. (4) to (6) as (5) to (7), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/118/s102/b/2/A"},"text":"Pub. L. 115–118, § 102(b)(2)(A)","children":[],"tail":", substi