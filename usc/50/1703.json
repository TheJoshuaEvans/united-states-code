{"tag":"section","attrib":{"id":"idd135504d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1703"},"text":null,"children":[{"tag":"num","attrib":{"value":"1703"},"text":"§ 1703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation and reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd135504e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, in every possible instance, shall consult with the Congress before exercising any of the authorities granted by this chapter and shall consult regularly with the Congress so long as such authorities are exercised.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd135504f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress upon exercise of Presidential authorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever the President exercises any of the authorities granted by this chapter, he shall immediately transmit to the Congress a report specifying—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1355050-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1703/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the circumstances which necessitate such exercise of authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1355051-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1703/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" why the President believes those circumstances constitute an unusual and extraordinary threat, which has its source in whole or substantial part outside the United States, to the national security, foreign policy, or economy of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1355052-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1703/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authorities to be exercised and the actions to be taken in the exercise of those authorities to deal with those circumstances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1355053-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1703/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" why the President believes such actions are necessary to deal with those circumstances; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1355054-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1703/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any foreign countries with respect to which such actions are to be taken and why such actions are to be taken with respect to those countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1355055-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic follow-up reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At least once during each succeeding six-month period after transmitting a report pursuant to subsection (b) with respect to an exercise of authorities under this chapter, the President shall report to the Congress with respect to the actions taken, since the last such report, in the exercise of such authorities, and with respect to any changes which have occurred concerning any information previously furnished pursuant to paragraphs (1) through (5) of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1355056-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1703/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of this section are supplemental to those contained in title IV of the National Emergencies Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1641"},"text":"50 U.S.C. 1641","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1355057-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/223/tII/s204"},"text":"Pub. L. 95–223, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-28"},"text":"Dec. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1627"},"text":"91 Stat. 1627","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1355058-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1355059-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd135505a-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Emergencies Act, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/412"},"text":"Pub. L. 94–412","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-14"},"text":"Sept. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1255"},"text":"90 Stat. 1255","children":[],"tail":". Title IV of the National Emergencies Act enacted subchapter IV (§ 1641) of chapter 34 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1601"},"text":"section 1601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
