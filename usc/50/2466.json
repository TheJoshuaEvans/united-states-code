{"tag":"section","attrib":{"id":"idd16e88cf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2466"},"text":null,"children":[{"tag":"num","attrib":{"value":"2466"},"text":"§ 2466.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds for the purchase of options to purchase real property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd16e88d0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2466/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the limitation in subsection (b), funds authorized to be appropriated for the Administration for the purchase of real property may be expended to purchase options for the purchase of real property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16e88d1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2466/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on price of options","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The price of any option purchased pursuant to subsection (a) may not exceed the minor construction threshold (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2741"},"text":"section 2741 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16e88d2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2466/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 14 days after the date an option is purchased pursuant to subsection (a), the Administrator shall submit to the congressional defense committees—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16e88d3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2466/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a notification of such purchase; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd170f8d4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2466/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the rationale for such purchase.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd170f8d5-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dC/tXXXII/s3265"},"text":"Pub. L. 106–65, div. C, title XXXII, § 3265","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dC/tXXXI/s3119"},"text":"Pub. L. 117–263, div. C, title XXXI, § 3119","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3055"},"text":"136 Stat. 3055","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
