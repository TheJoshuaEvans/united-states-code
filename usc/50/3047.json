{"tag":"section","attrib":{"id":"idd19bda53-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3047"},"text":null,"children":[{"tag":"num","attrib":{"value":"3047"},"text":"§ 3047.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on intelligence sharing with United Nations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd19bda54-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3047/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of intelligence information to United Nations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd19bda55-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3047/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No United States intelligence information may be provided to the United Nations or any organization affiliated with the United Nations, or to any officials or employees thereof, unless the President certifies to the appropriate committees of Congress that the Director of National Intelligence, in consultation with the Secretary of State and the Secretary of Defense, has established and implemented procedures, and has worked with the United Nations to ensure implementation of procedures, for protecting from unauthorized disclosure United States intelligence sources and methods connected to such information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd19bda56-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3047/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) may be waived upon written certification by the President to the appropriate committees of Congress that providing such information to the United Nations or an organization affiliated with the United Nations, or to any officials or employees thereof, is in the national security interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19bda57-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3047/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation of duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may not delegate or assign the duties of the President under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19bda58-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3047/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to existing law","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd19bda59-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3047/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impair or otherwise affect the authority of the Director of National Intelligence to protect intelligence sources and methods from unauthorized disclosure pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3024/h"},"text":"section 3024(h) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd19bda5a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3047/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supersede or otherwise affect the provisions of subchapter III of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19bda5b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3047/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Appropriate committees of Congress” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the term “appropriate committees of Congress” means the Committee on Foreign Relations and the Select Committee on Intelligence of the Senate and the Committee on Foreign Relations and the Permanent Select Committee on Intelligence of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd19bda5c-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title I, § 112, formerly § 110, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/293/tIII/s308/a"},"text":"Pub. L. 104–293, title III, § 308(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3466"},"text":"110 Stat. 3466","children":[],"tail":"; renumbered § 112, "},{"tag":"ref","attrib":{"href":"/us/pl/105/107/tIII/s303/b"},"text":"Pub. L. 105–107, title III, § 303(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-20"},"text":"Nov. 20, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2252"},"text":"111 Stat. 2252","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/306/tVIII/s811/b/1/C"},"text":"Pub. L. 107–306, title VIII, § 811(b)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2422"},"text":"116 Stat. 2422","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/177/tIII"},"text":"Pub. L. 108–177, title III","children":[],"tail":", §§ 361(b), 377(a), "},{"tag":"date","attrib":{"date":"2003-12-13"},"text":"Dec. 13, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2625"},"text":"117 Stat. 2625","children":[],"tail":", 2630; "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI"},"text":"Pub. L. 108–458, title I","children":[],"tail":", §§ 1071(a)(1)(K), (L), 1072(a)(4), "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3689"},"text":"118 Stat. 3689","children":[],"tail":", 3692; "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/tIII/s347/b"},"text":"Pub. L. 111–259, title III, § 347(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2698"},"text":"124 Stat. 2698","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLXVII/s6742/b/5"},"text":"Pub. L. 116–92, div. E, title LXVII, § 6742(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2240"},"text":"133 Stat. 2240","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dF/tLXIV/s6402/c/2/A/ii"},"text":"Pub. L. 119–60, div. F, title LXIV, § 6402(c)(2)(A)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1616"},"text":"139 Stat. 1616","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd19bda5d-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd19bda5e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd19bda5f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s404g"},"text":"section 404g of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section, and to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s404d–1"},"text":"section 404d–1 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/105/107"},"text":"Pub. L. 105–107","children":[],"tail":". Some section numbers of this title referenced in amendment notes below reflect the classification of such sections prior to their editorial reclassification."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd19bda60-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “section 3024(h)” for “section 3024(i)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “section 3024(i)” for “section 3025(c)(7)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsecs. (b) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259"},"text":"Pub. L. 111–259","children":[],"tail":" redesignated subsecs. (c) to (e) as (b) to (d), respectively, and struck out former subsec. (b). Prior to amendment, text of subsec. (b) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The President shall report annually to the appropriate committees of Congress on the types and volume of intelligence provided to the United Nations and the purposes for which it was provided during the period covered by the report. The President shall also report to the appropriate committees of Congress within 15 days after it has become known to the United States Government that there has been an unauthorized disclosure of intelligence provided by the United States to the United Nations.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The requirement for periodic reports under the first sentence of paragraph (1) shall not apply to the provision of intelligence that is provided only to, and for the use of, appropriately cleared United States Government personnel serving with the United Nations.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) In the case of the annual reports required to be submitted under the first sentence of paragraph (1) to the congressional intelligence committees, the submittal dates for such reports shall be as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s415b"},"text":"section 415b of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1071/a/1/K"},"text":"Pub. L. 108–458, § 1071(a)(1)(K)","children":[],"tail":", substituted “Director of National Intelligence” for “Director of Central Intelligence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1072/a/4"},"text":"Pub. L. 108–458, § 1072(a)(4)","children":[],"tail":", which directed amendment of par. (1) by substituting “section 403–1(i)” for “section 403–3(c)(6)”, could not be executed because the words “section 403–3(c)(6)” did not appear after the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/108/177/s377/a"},"text":"Pub. L. 108–177, § 377(a)","children":[],"tail":". See 2003 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1071/a/1/L"},"text":"Pub. L. 108–458, § 1071(a)(1)(L)","children":[],"tail":", substituted “Director of National Intelligence” for “Director of Central Intelligence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177/s361/b/1"},"text":"Pub. L. 108–177, § 361(b)(1)","children":[],"tail":", substituted “Annual” for “Periodic” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177/s361/b/2"},"text":"Pub. L. 108–177, § 361(b)(2)","children":[],"tail":", substituted “annually” for “semiannually”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177/s361/b/3"},"text":"Pub. L. 108–177, § 361(b)(3)","children":[],"tail":", substituted “the annual” for “periodic”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177/s377/a"},"text":"Pub. L. 108–177, § 377(a)","children":[],"tail":", substituted “section 403–3(c)(7)” for “section 403–3(c)(6)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306"},"text":"Pub. L. 107–306","children":[],"tail":" added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd19bda61-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd19bda62-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For Determination by President that amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" take effect on "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", see Memorandum of President of the United States, "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", 70 F.R. 23925, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" effective not later than six months after "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1097/a"},"text":"section 1097(a) of Pub. L. 108–458","children":[],"tail":", set out in an Effective Date of 2004 Amendment; Transition Provisions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd19bda63-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177/s361/b"},"text":"section 361(b) of Pub. L. 