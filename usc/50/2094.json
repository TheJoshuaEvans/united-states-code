{"tag":"section","attrib":{"id":"idd15de750-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2094"},"text":null,"children":[{"tag":"num","attrib":{"value":"2094"},"text":"§ 2094.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attachment of moneys","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd15de751-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2094/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from legal process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsections (b), (c), and (e), none of the moneys mentioned in this subchapter shall be assignable either in law or equity, or be subject to execution, levy, attachment, garnishment, or other legal process, except as otherwise may be provided by Federal laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15de752-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2094/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment to former spouses under court order or spousal agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any participant, former participant, or retired participant who has a former spouse who is covered by a court order or who is a party to a spousal agreement—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15de753-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2094/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any right of the former spouse to any annuity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2032/a"},"text":"section 2032(a) of this title","children":[],"tail":" in connection with any retirement or disability annuity of the participant, and the amount of any such annuity;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15de754-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2094/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any right of the former spouse of a participant or retired participant to a survivor annuity under section 2032(b) or 2032(c) of this title, and the amount of any such annuity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15de755-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2094/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any right of the former spouse of a former participant to any payment of a lump-sum credit under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2071/b"},"text":"section 2071(b) of this title","children":[],"tail":", and the amount of any such payment;"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be determined in accordance with that spousal agreement or court order, if and to the extent expressly provided for in the terms of the spousal agreement or court order that are not inconsistent with the requirements of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15de756-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2094/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other payments under court orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments under this subchapter that would otherwise be made to a participant, former participant, or retired participant based upon that participant’s service shall be paid, in whole or in part, by the Director to another individual if and to the extent expressly provided for in the terms of any court decree of divorce, annulment, or legal separation, or the terms of any court order or court-approved property settlement agreement incident to any court decree of divorce, annulment, or legal separation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15de757-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2094/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prospective payments; bar to recovery","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15de758-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2094/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsections (b) and (c) apply only to payments made under this subchapter for periods beginning after the date of receipt by the Director of written notice of such decree, order, or agreement and such additional information and documentation as the Director may require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15de759-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2094/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any payment under subsection (b) or (c) to an individual bars recovery by any other individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15de75a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2094/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual entitled to an annuity from the fund may make allotments or assignments of amounts from such annuity for such purposes as the Director considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd15de75b-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/tII/s264"},"text":"Pub. L. 88–643, title II, § 264","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s802"},"text":"Pub. L. 102–496, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3237"},"text":"106 Stat. 3237","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/178/tII/s202/a/12"},"text":"Pub. L. 103–178, title II, § 202(a)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2027"},"text":"107 Stat. 2027","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd15de75c-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd15de75d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd15de75e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/s264"},"text":"section 264 of Pub. L. 88–643","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/522/tII/s212"},"text":"Pub. L. 94–522, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-17"},"text":"Oct. 17, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2471"},"text":"90 Stat. 2471","children":[],"tail":", related to recovery of payments and was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403"},"text":"section 403 of this title","children":[],"tail":" prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/88/643"},"text":"Pub. L. 88–643","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s802"},"text":"section 802 of Pub. L. 102–496","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2095"},"text":"section 2095 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd15de75f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/178/s202/a/12/A"},"text":"Pub. L. 103–178, § 202(a)(12)(A)","children":[],"tail":", inserted “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/178/s202/a/12/B"},"text":"Pub. L. 103–178, § 202(a)(12)(B)","children":[],"tail":", substituted “, and the amount of any such payment;” for “and to any payment of a return of contributions under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2054/a"},"text":"section 2054(a) of this title","children":[],"tail":"; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/178/s202/a/12/C"},"text":"Pub. L. 103–178, § 202(a)(12)(C)","children":[],"tail":", struck out par. (4) which read as follows: “any right of the former spouse of a participant or former participant to a lump-sum payment or additional annuity payable from a voluntary contribution account under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2121"},"text":"section 2121 of this title","children":[],"tail":";”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd15de760-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd15de761-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/178"},"text":"Pub. L. 103–178","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-02-01"},"text":"Feb. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/178/s202/b"},"text":"section 202(b) of Pub. L. 103–178","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd15de762-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of fourth month beginning after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s805"},"text":"section 805 of Pub. L. 102–496","children"