{"tag":"section","attrib":{"id":"idd1ece0ff-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523"},"text":null,"children":[{"tag":"num","attrib":{"value":"3523"},"text":"§ 3523.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intelligence operations and cover enhancement authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1ece100-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ece101-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “designated employee” means an employee designated by the Director of the Central Intelligence Agency under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ece102-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Federal retirement system” includes the Central Intelligence Agency Retirement and Disability System, and the Federal Employees’ Retirement System (including the Thrift Savings Plan).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ece103-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ece104-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the Director of the Central Intelligence Agency may exercise the authorities under this section in order to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1ece105-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" protect from unauthorized disclosure—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1ece106-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intelligence operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ece107-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identities of undercover intelligence officers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ece108-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intelligence sources and methods; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ece109-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intelligence cover mechanisms; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ece10a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the special requirements of work related to collection of foreign intelligence or other authorized activities of the Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ece10b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Central Intelligence Agency may designate any employee of the Agency who is under nonofficial cover to be an employee to whom this section applies. Such designation may be made with respect to any or all authorities exercised under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ece10c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Central Intelligence Agency may pay a designated employee salary, allowances, and other benefits in an amount and in a manner consistent with the nonofficial cover of that employee, without regard to any limitation that is otherwise applicable to a Federal employee. A designated employee may accept, utilize, and, to the extent authorized by regulations prescribed under subsection (i), retain any salary, allowances, and other benefits provided under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ef510d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retirement benefits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ef510e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Central Intelligence Agency may establish and administer a nonofficial cover employee retirement system for designated employees (and the spouse, former spouses, and survivors of such designated employees). A designated employee may not participate in the retirement system established under this paragraph and another Federal retirement system at the same time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ef510f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversion to other Federal retirement system","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1ef5110-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A designated employee participating in the retirement system established under paragraph (1) may convert to coverage under the Federal retirement system which would otherwise apply to that employee at any appropriate time determined by the Director of the Central Intelligence Agency (including at the time of separation of service by reason of retirement), if the Director of the Central Intelligence Agency determines that the employee’s participation in the retirement system established under this subsection is no longer necessary to protect from unauthorized disclosure—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1ef5111-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intelligence operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef5112-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identities of undercover intelligence officers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef5113-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intelligence sources and methods; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef5114-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/d/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intelligence cover mechanisms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ef5115-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversion treatment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon a conversion under this paragraph—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1ef5116-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all periods of service under the retirement system established under this subsection shall be deemed periods of creditable service under the applicable Federal retirement system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef5117-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Director of the Central Intelligence Agency shall transmit an amount for deposit in any applicable fund of that Federal retirement system that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idd1ef5118-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/d/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is necessary to cover all employee and agency contributions including—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idd1ef5119-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/d/2/B/ii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest as determined by the head of the agency administering the Federal retirement system into which the employee is converting; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idd1ef511a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/d/2/B/ii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an employee converting into the Federal Employees’ Retirement System, interest as determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8334/e"},"text":"section 8334(e) of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd1ef511b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/d/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures that such conversion does not result in any unfunded liability to that fund; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef511c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a designated employee who participated in an employee investment retirement system established under paragraph (1) and is converted to coverage under subchapter III of chapter 84 of title 5, the Director of the Central Intelligence Agency may transmit any or all amounts of that designated employee in that employee investment retirement system (or similar part of that retirement system) to the Thrift Savings Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ef511d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmitted amounts","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1ef511e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts described under subparagraph (B)(ii) shall be paid from the fund or appropriation used to pay the designated employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef511f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Central Intelligence Agency may use amounts contributed by the designated employee to a retirement system established under paragraph (1) to offset amounts paid under clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ef5120-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Central Intelligence Agency shall transmit all necessary records relating to a designated employee who converts to a Federal retirement system under this paragraph (including records relating to periods of service which are deemed to be periods of creditable service under subparagraph (B)) to the head of the agency administering that Federal retirement system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ef5121-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health insurance benefits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ef5122-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Central Intelligence Agency may establish and administer a nonofficial cover employee health insurance program for designated employees (and the family of such designated employees). A designated employee may not participate in the health insurance program established under this paragraph and the program under chapter 89 of title 5 at the same time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ef5123-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversion to Federal employees health benefits program","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1ef5124-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A designated employee participating in the health insurance program established under paragraph (1) may convert to coverage under the program under chapter 89 of title 5 at any appropriate time determined by the Director of the Central Intelligence Agency (including at the time of separation of service by reason of retirement), if the Director of the Central Intelligence Agency determines that the employee’s participation in the health insurance program established under this subsection is no longer necessary to protect from unauthorized disclosure—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1ef5125-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intelligence operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef5126-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identities of undercover intelligence officers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef5127-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/e/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intelligence sources and methods; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef5128-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/e/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intelligence cover mechanisms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ef5129-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversion treatment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon a conversion under this paragraph—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1ef512a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee (and family, if applicable) shall be entitled to immediate enrollment and coverage under chapter 89 of title 5;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef512b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any requirement of prior enrollment in a health benefits plan under chapter 89 of that title for continuation of coverage purposes shall not apply;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef512c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/e/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee shall be deemed to have had coverage under chapter 89 of that title from the first opportunity to enroll for purposes of continuing coverage as an annuitant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef512d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/e/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Central Intelligence Agency shall transmit an amount for deposit in the Employees’ Health Benefits Fund that is necessary to cover any costs of such conversion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ef512e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmitted amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount described under subparagraph (B)(iv) shall be paid from the fund or appropriation used to pay the designated employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ef512f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Life insurance benefits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ef5130-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Central Intelligence Agency may establish and administer a nonofficial cover employee life insurance program for designated employees (and the family of such designated employees). A designated employee may not participate in the life insurance program established under this paragraph and the program under chapter 87 of title 5 at the same time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ef5131-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversion to Federal employees group life insurance program","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1ef5132-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A designated employee participating in the life insurance program established under paragraph (1) may convert to coverage under the program under chapter 87 of title 5 at any appropriate time determined by the Director of the Central Intelligence Agency (including at the time of separation of service by reason of retirement), if the Director of the Central Intelligence Agency determines that the employee’s participation in the life insurance program established under this subsection is no longer necessary to protect from unauthorized disclosure—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1ef5133-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intelligence operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef5134-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identities of undercover intelligence officers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef5135-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/f/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intelligence sources and methods; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef5136-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/f/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intelligence cover mechanisms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ef5137-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversion treatment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon a conversion under this paragraph—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1ef5138-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee (and family, if applicable) shall be entitled to immediate coverage under chapter 87 of title 5;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef5139-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any requirement of prior enrollment in a life insurance program under chapter 87 of that title for continuation of coverage purposes shall not apply;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef513a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/f/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee shall be deemed to have had coverage under chapter 87 of that title for the full period of service during which the employee would have been entitled to be insured for purposes of continuing coverage as an annuitant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef513b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/f/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Central Intelligence Agency shall transmit an amount for deposit in the Employees’ Life Insurance Fund that is necessary to cover any costs of such conversion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ef513c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmitted amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount described under subparagraph (B)(iv) shall be paid from the fund or appropriation used to pay the designated employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ef513d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from certain requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Central Intelligence Agency may exempt a designated employee from mandatory compliance with any Federal regulation, rule, standardized administrative policy, process, or procedure that the Director of the Central Intelligence Agency determines—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ef513e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would be inconsistent with the nonofficial cover of that employee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ef513f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" could expose that employee to detection as a Federal employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ef5140-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxation and social security","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ef5141-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, a designated employee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1ef5142-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall file a Federal or State tax return as if that employee is not a Federal employee and may claim and receive the benefit of any exclusion, deduction, tax credit, or other tax treatment that would otherwise apply if that employee was not a Federal employee, if the Director of the Central Intelligence Agency determines that taking any action under this paragraph is necessary to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1ef5143-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/h/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" protect from unauthorized disclosure—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idd1ef5144-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/h/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intelligence operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd1ef5145-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/h/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identities of undercover intelligence officers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd1ef5146-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/h/1/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intelligence sources and methods; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd1ef5147-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/h/1/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intelligence cover mechanisms; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1ef5148-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/h/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the special requirements of work related to collection of foreign intelligence or other authorized activities of the Agency; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1ef5149-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall receive social security benefits based on the social security contributions made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ef514a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internal Revenue Service review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Central Intelligence Agency shall establish procedures to carry out this subsection. The procedures shall be subject to periodic review by the Internal Revenue Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ef514b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Central Intelligence Agency shall prescribe regulations to carry out this section. The regulations shall ensure that the combination of salary, allowances, and benefits that an employee designated under this section may retain does not significantly exceed, except to the extent determined by the Director of the Central Intelligence Agency to be necessary to exercise the authority in subsection (b), the combination of salary, allowances, and benefits otherwise received by Federal employees not designated under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ef514c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finality of decisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any determinations authorized by this section to be made by the Director of the Central Intelligence Agency or the Director’s designee shall be final and conclusive and shall not be subject to review by any court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ef514d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3523/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequently enacted laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No law enacted after the effective date of this section shall affect the authorities and provisions of this section unless such law specifically refers to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1ef514e-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-20/ch227/s23"},"text":"June 20, 1949, ch. 227, § 23","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/487/tIV/s402"},"text":"Pub. L. 108–487, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3946"},"text":"118 Stat. 3946","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1ef514f-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1ef5150-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1ef5151-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The effective date of this section, referred to in subsec. (k), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/487"},"text":"Pub. L. 108–487","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"December 23, 2004","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/pl/108/487/s801"},"text":"section 801 of Pub. L. 108–487","children":[],"tail":", set out as an Effective Date of 2004 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2656f"},"text":"section 2656f of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1ef5152-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s403w"},"text":"section 403w of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
