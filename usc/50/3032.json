{"tag":"section","attrib":{"id":"idd1923ce3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3032"},"text":null,"children":[{"tag":"num","attrib":{"value":"3032"},"text":"§ 3032.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief Information Officer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1923ce4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3032/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief Information Officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To assist the Director of National Intelligence in carrying out the responsibilities of the Director under this chapter and other applicable provisions of law, there shall be within the Office of the Director of National Intelligence a Chief Information Officer of the Intelligence Community who shall be appointed by the Director. The Chief Information Officer shall report directly to the Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1923ce5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3032/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties and responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the direction of the Director of National Intelligence, the Chief Information Officer of the Intelligence Community shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1923ce6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3032/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manage activities relating to the information technology infrastructure and enterprise architecture requirements of the intelligence community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1923ce7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3032/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have procurement approval authority over all information technology items related to the enterprise architectures of all intelligence community components;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1923ce8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3032/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct and manage all information technology-related procurement for the intelligence community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1923ce9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3032/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that all expenditures for information technology and research and development activities are consistent with the intelligence community enterprise architecture and the strategy of the Director for such architecture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1923cea-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3032/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on simultaneous service as other chief information officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual serving in the position of Chief Information Officer of the Intelligence Community may not, while so serving, serve as the chief information officer of any other department or agency, or component thereof, of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1923ceb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3032/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on simultaneous service as Chief Data Officer and Chief Information Officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual serving in the position of Chief Information Officer of the Intelligence Community or chief information officer of any other element of the intelligence community shall not concurrently serve as the Intelligence Community Chief Data Officer under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3034b"},"text":"section 3034b of this title","children":[],"tail":" and as the chief data officer of any other element of the intelligence community."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1923cec-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title I, § 103G, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/487/tIII/s303/a/1"},"text":"Pub. L. 108–487, title III, § 303(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3944"},"text":"118 Stat. 3944","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/tIV/s404"},"text":"Pub. L. 111–259, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2709"},"text":"124 Stat. 2709","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLXIII/s6304"},"text":"Pub. L. 116–92, div. E, title LXIII, § 6304","children":[],"tail":", title LXIV, § 6405, "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2188"},"text":"133 Stat. 2188","children":[],"tail":", 2196; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tIII/s7310/a"},"text":"Pub. L. 118–31, div. G, title III, § 7310(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1028"},"text":"137 Stat. 1028","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1923ced-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1923cee-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1923cef-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"act July 26, 1947, ch. 343","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/495"},"text":"61 Stat. 495","children":[],"tail":", known as the National Security Act of 1947, which is classified principally to this chapter. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1923cf0-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s403–3g"},"text":"section 403–3g of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1923cf1-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s6405"},"text":"Pub. L. 116–92, § 6405","children":[],"tail":", inserted at end “The Chief Information Officer shall report directly to the Director of National Intelligence.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s6304"},"text":"Pub. L. 116–92, § 6304","children":[],"tail":", substituted “by the Director” for “by the President”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s404/1"},"text":"Pub. L. 111–259, § 404(1)","children":[],"tail":", inserted “of the Intelligence Community” after “Chief Information Officer” and substituted “President.” for “President, by and with the advice and consent of the Senate.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s404/2"},"text":"Pub. L. 111–259, § 404(2)","children":[],"tail":"–(4), redesignated subsecs. (c) and (d) as (b) and (c), respectively, inserted “of the Intelligence Community” after “Chief Information Officer” in two places, and struck out former subsec. (b). Text of former subsec. (b) read as follows: “The Chief Information Officer shall serve as the chief information officer of the intelligence community.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1923cf2-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd1923cf3-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/487/tIII/s303/b"},"text":"Pub. L. 108–487, title III, § 303(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3944"},"text":"118 Stat. 3944","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/487/tIII/s303/b"},"text":"“The amendments made by this section [enacting this section] shall take effect on the effective date of the National Security Intelligence Reform Act of 2004 [see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1097"},"text":"section 1097 of Pub. L. 108–458","children":[],"tail":", set out in an Effective Date of 2004 Amendment; Transfer, Termination, and Transition Provisions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"], as provided in section 801 of this Act [set out in an Effective Date of 2004 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2656f"},"text":"section 2656f of Title 22","children":[],"tail":", Foreign Relations and Intercourse].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
