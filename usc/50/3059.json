{"tag":"section","attrib":{"id":"idd19e4b7a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059"},"text":null,"children":[{"tag":"num","attrib":{"value":"3059"},"text":"§ 3059.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign Malign Influence Center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd19e4b7b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is within the Office of the Director of National Intelligence a Foreign Malign Influence Center (in this section referred to as the “Center”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19e4b7c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions and composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Center shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd19e4b7d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be comprised of analysts from all elements of the intelligence community, including elements with diplomatic and law enforcement functions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd19e4b7e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have access to all intelligence and other reporting possessed or acquired by the United States Government pertaining to foreign malign influence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd19e4b7f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the primary organization in the United States Government for analyzing and integrating all intelligence possessed or acquired by the United States Government pertaining to foreign malign influence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd19e4b80-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to employees and officers of the Federal Government in policy-making positions and Congress comprehensive assessments, and indications and warnings, of foreign malign influence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19e4b81-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd19e4b82-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is a Director of the Center, who shall be the head of the Center, and who shall be appointed by the Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd19e4b83-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Role","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Center shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd19e4b84-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report directly to the Director of National Intelligence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd19e4b85-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out the functions under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd19e4b86-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the request of the President or the Director of National Intelligence, develop and provide recommendations for potential responses by the United States to foreign malign influence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19e4b87-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd19e4b88-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the matters submitted pursuant to subsection (b)(4), at the direction of the Director of National Intelligence, but not less than once each year, the Director of the Center shall submit to the congressional intelligence committees, the Committee on Foreign Affairs of the House of Representatives, and the Committee on Foreign Relations of the Senate a report on foreign malign influence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd19e4b89-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under paragraph (1) shall include, with respect to the period covered by the report, a discussion of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd19e4b8a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The most significant activities of the Center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd19e4b8b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any recommendations the Director determines necessary for legislative or other actions to improve the ability of the Center to carry out its functions, including recommendations regarding the protection of privacy and civil liberties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19e4b8c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After ","children":[{"tag":"date","attrib":{"date":"2028-12-31"},"text":"December 31, 2028","children":[],"tail":", the Director of National Intelligence may terminate the Center, but only if the Director of National Intelligence submits to the congressional intelligence committees, the Subcommittee on Defense of the Committee on Appropriations of the Senate, and the Subcommittee on Defense of the Committee on Appropriations of the House of Representatives a determination that the termination of the Center is appropriate, which includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd19e4b8d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a detailed description that other offices or entities within the intelligence community—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1a0947e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the capabilities to perform the functions of the Center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a0947f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will exercise the functions of the Center upon the termination of the Center; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a09480-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a detailed description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1a09481-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actions the Director of National Intelligence will take to conduct an orderly wind-down of the activities of the Center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a09482-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed timeline for such actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1a09483-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1a09484-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered foreign country","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered foreign country” means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1a09485-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Russian Federation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a09486-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Islamic Republic of Iran.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a09487-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Democratic People’s Republic of Korea.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a09488-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The People’s Republic of China.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a09489-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/f/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other foreign country that the Director of the Center determines appropriate for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a0948a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign malign influence","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “foreign malign influence” means any hostile effort undertaken by, at the direction of, or on behalf of or with the substantial support of, the government of a covered foreign country with the objective of influencing, through overt or covert means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1a0948b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the political, military, economic, or other policies or activities of the United States Government or State or local governments, including any election within the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a0948c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3059/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public opinion within the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1a0948d-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title I, § 119C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLIII/s5322/a"},"text":"Pub. L. 116–92, div. E, title LIII, § 5322(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2129"},"text":"133 Stat. 2129","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dF/tLXIII/s6307/a/1"},"text":"Pub. L. 117–263, div. F, title LXIII, § 6307(a)(1)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3504"},"text":"136 Stat. 3504","children":[],"tail":", 3505.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1a0948e-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1a0948f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1a09490-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s6307/a/1/A"},"text":"Pub. L. 117–263, § 6307(a)(1)(A)","children":[],"tail":", struck out “Response” after “Influence” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s6307/a/1/B"},"text":"Pub. L. 117–263, § 6307(a)(1)(B)","children":[],"tail":", struck out “Response” after “Influence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s6307/b"},"text":"Pub. L. 117–263, § 6307(b)","children":[],"tail":", added subsec. (e) and redesignated former subsec. (e) as (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1a09491-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1a09492-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reference to Foreign Malign Influence Response Center","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dF/tLXIII/s6307/a/4"},"text":"Pub. L. 117–263, div. F, title LXIII, § 6307(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3505"},"text":"136 Stat. 3505","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dF/tLXIII/s6307/a/4"},"text":"“Any reference in law, regulation, map, document, paper, or other record of the United States to the ‘Foreign Malign Influence Response Center’ shall be deemed to be a reference to the Foreign Malign Influence Center.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
