{"tag":"section","attrib":{"id":"idd143a7bb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1829"},"text":null,"children":[{"tag":"num","attrib":{"value":"1829"},"text":"§ 1829.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization during time of war","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the President, through the Attorney General, may authorize physical searches without a court order under this subchapter to acquire foreign intelligence information for a period not to exceed 15 calendar days following a declaration of war by the Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd143a7bc-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511/tIII/s309"},"text":"Pub. L. 95–511, title III, § 309","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/359/tVIII/s807/a/3"},"text":"Pub. L. 103–359, title VIII, § 807(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-14"},"text":"Oct. 14, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3452"},"text":"108 Stat. 3452","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd143a7bd-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd143a7be-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd143a7bf-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1994-10-14"},"text":"Oct. 14, 1994","children":[],"tail":", with exception for certain physical searches approved by the Attorney General to gather foreign intelligence information, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/359/s807/c"},"text":"section 807(c) of Pub. L. 103–359","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1821"},"text":"section 1821 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
