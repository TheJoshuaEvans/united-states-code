{"tag":"section","attrib":{"id":"idd1cb9c26-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c"},"text":null,"children":[{"tag":"num","attrib":{"value":"3316c"},"text":"§ 3316c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of definitions for certain terms relating to intelligence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1cb9c27-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2023-09-30"},"text":"September 30, 2023","children":[],"tail":", the Director of National Intelligence and the Under Secretary of Defense for Intelligence and Security, in consultation with the heads of the elements of the intelligence community, shall jointly develop and publish definitions for the following terms:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cb9c28-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Acoustic intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9c29-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All-source intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9c2a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Communications intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9c2b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Critical intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9c2c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cyber-threat intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9c2d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Electronic intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9c2e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Explosive ordnance intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9c2f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" General military intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9c30-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Imagery intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9c31-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Geospatial intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9c32-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Instrumentation signals intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9c33-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Intelligence-related activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9c34-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Joint intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9c35-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Measurement and signature intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9c36-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/a/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Medical intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9c37-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/a/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Open-source intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9c38-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/a/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operational intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9c39-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/a/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Scientific and technical intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9c3a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/a/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Signals intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9c3b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/a/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Strategic intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9c3c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/a/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tactical intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9c3d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/a/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Target intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9c3e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/a/23"},"text":null,"children":[{"tag":"num","attrib":{"value":"23"},"text":"(23)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Technical intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9c3f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/a/24"},"text":null,"children":[{"tag":"num","attrib":{"value":"24"},"text":"(24)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such others terms as may be jointly determined necessary by the Director of National Intelligence and the Under Secretary of Defense for Intelligence and Security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cb9c40-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to activities of intelligence community","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence shall ensure that the definitions developed under subsection (a) are used uniformly across activities of the intelligence community with respect to the corresponding terms specified in such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cb9c41-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of modifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence and the Under Secretary of Defense for Intelligence shall submit to the appropriate congressional committees notification of any modification by the Director and Under Secretary to a definition of a term specified in subsection (a) following the initial publication of the definition under such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cb9c42-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cb9c43-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional intelligence committees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9c44-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3316c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committees on Armed Services of the House of Representatives and the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1cb9c45-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dX/tIII/s309"},"text":"Pub. L. 117–103, div. X, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/971"},"text":"136 Stat. 971","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1cb9c46-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1cb9c47-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1cb9c48-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Requirement to Develop Lexicon for Terms Relating to Gray Zone Activities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dX/tVIII/s825/b/5"},"text":"Pub. L. 117–103, div. X, title VIII, § 825(b)(5)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1028"},"text":"136 Stat. 1028","children":[],"tail":", 1029, provided that:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[“(b) ","children":[{"tag":"inline","attrib":{},"text":"National Intelligence Estimate.—]","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—In this subsection [pars. (1) to (4) not classified to the Code]:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) ","children":[{"tag":"inline","attrib":{},"text":"Gray zone activity","children":[],"tail":".—The term ‘gray zone activity’ means an activity to advance the national interests of a State that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) falls between ordinary statecraft and open warfare;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) is carried out with an intent to maximize the advancement of interests of the state without provoking a kinetic military response by the United States; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iii) falls on a spectrum that ranges from covert adversary operations, to detectible covert adversary operations, to unattributable adversary operations, to deniable adversary operations, to open adversary operations.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) ","children":[{"tag":"inline","attrib":{},"text":"Covert adversary operation","children":[],"tail":".—The term ‘covert adversary operation’ means an operation by an adversary that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) the adversary intends to remain below the threshold at which the United States detects the operation; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) does stay below such threshold.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) ","children":[{"tag":"inline","attrib":{},"text":"Detectible covert adversary operation","children":[],"tail":".—The term ‘detectible covert adversary operation’ means an operation by an adversary that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) the adversary intends to remain below the threshold at which the United States detects the operation; but","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) is ultimately detected by the United States at a level below the level at which the United States will publicly attribute the operation to the adversary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) ","children":[{"tag":"inline","attrib":{},"text":"Unattributable adversary operation","children":[],"tail":".—The term ‘unattributable adversary operation’ means an operation by an adversary that the adversary intends to be detected by the United States, but remains below the threshold at which the United States will publicly attribute the operation to the adversary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(E) ","children":[{"tag":"inline","attrib":{},"text":"Deniable adversary operation","children":[],"tail":".—The term ‘deniable adversary operation’ means an operation by an adversary that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) the adversary intends to be detected and publicly or privately attributed by the United States; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) the adversary intends to deny, to limit the response by the United States, and any allies of the United States.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(F) ","children":[{"tag":"inline","attrib":{},"text":"Open adversary operation","children":[],"tail":".—The term ‘open adversary operation’ means an operation by an adversary that the adversary openly acknowledges as attributable to the adversary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) ","children":[{"tag":"inline","attrib":{},"text":"Requirement to Develop Lexicon.—","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—The Director of National Intelligence, acting through the National Intelligence Council, shall develop a lexicon of common terms (and corresponding definitions for such terms) for concepts associated with gray zone activities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—In developing the lexicon under paragraph (1), the National Intelligence Council shall include in the lexicon each term (and the corresponding definition for each term) specified in subsection (b)(5), unless the National Intelligence Council determines that an alternative term (or alternative definition)—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) more accurately describes a concept associated with gray zone activities; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) is preferable for any other reason.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) ","children":[{"tag":"inline","attrib":{},"text":"Report.—","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) ","children":[{"tag":"inline","attrib":{},"text":"Publication","children":[],"tail":".—The Director of National Intelligence shall publish a report containing the lexicon developed under paragraph (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) ","children":[{"tag":"inline","attrib":{},"text":"Form","children":[],"tail":".—The report under subparagraph (A) shall be published in unclassified form.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd1cb9c49-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “congressional intelligence committees” and “intelligence community” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dX/s2"},"text":"section 2 of div. X of Pub. L. 117–103","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
