{"tag":"section","attrib":{"id":"idd249f4d0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4812"},"text":null,"children":[{"tag":"num","attrib":{"value":"4812"},"text":"§ 4812.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of the President","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd249f4d1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4812/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to carry out the policy set forth in paragraphs (1) through (10) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4811"},"text":"section 4811 of this title","children":[],"tail":", the President shall control—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd249f4d2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4812/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the export, reexport, and in-country transfer of items subject to the jurisdiction of the United States, whether by United States persons or by foreign persons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd249f4d3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4812/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the activities of United States persons, wherever located, relating to specific—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd249f4d4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4812/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nuclear explosive devices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd249f4d5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4812/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" missiles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd249f4d6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4812/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chemical or biological weapons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd249f4d7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4812/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whole plants for chemical weapons precursors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd249f4d8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4812/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign maritime nuclear projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd249f4d9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4812/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign military, security, or intelligence services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd249f4da-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4812/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In exercising authority under this subchapter to carry out the policy set forth in paragraphs (1) through (10) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4811"},"text":"section 4811 of this title","children":[],"tail":", the President shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd249f4db-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4812/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulate the export, reexport, and in-country transfer of items described in subsection (a)(1) of United States persons or foreign persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd249f4dc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4812/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulate the activities described in subsection (a)(2) of United States persons, wherever located;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd249f4dd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4812/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to secure the cooperation of other governments and multilateral organizations to impose control systems that are consistent, to the extent possible, with the controls imposed under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd249f4de-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4812/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain the leadership of the United States in science, engineering, technology research and development, manufacturing, and foundational technology that is essential to innovation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd249f4df-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4812/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect United States technological advances by prohibiting unauthorized technology transfers to foreign persons in the United States or outside the United States, particularly with respect to countries that may pose a significant threat to the national security of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd249f4e0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4812/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthen the United States industrial base, both with respect to current and future defense requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd249f4e1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4812/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforce the controls through means such as regulations, requirements for compliance, lists of controlled items, lists of foreign persons who threaten the national security or foreign policy of the United States, and guidance in a form that facilitates compliance by United States persons and foreign persons, in particular academic institutions, scientific and research establishments, and small- and medium-sized businesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd249f4e2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4812/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of controls","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall impose controls over the export, reexport, or in-country transfer of items for purposes of the objectives described in subsections (b)(1) or (b)(2) without regard to the nature of the underlying transaction or any circumstances pertaining to the activity, including whether such export, reexport, or in-country transfer occurs pursuant to a purchase order or other contract requirement, voluntary decision, inter-company arrangement, marketing effort, or during a joint venture, joint development agreement, or similar collaborative agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd249f4e3-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVII/s1753"},"text":"Pub. L. 115–232, div. A, title XVII, § 1753","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2211"},"text":"132 Stat. 2211","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLV/s5589/b"},"text":"Pub. L. 117–263, div. E, title LV, § 5589(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3380"},"text":"136 Stat. 3380","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd249f4e4-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd249f4e5-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd249f4e6-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (b), was in the original “this part”, meaning part I (§§ 1751–1768) of subtitle B of title XVII of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":", known as the Export Controls Act of 2018, which is classified principally to this subchapter. For complete classification of part I to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s1751"},"text":"section 1751 of Pub. L. 115–232","children":[],"tail":", set out as a Short Title note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4801"},"text":"section 4801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd249f4e7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" inserted “, security, or” before “intelligence”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
