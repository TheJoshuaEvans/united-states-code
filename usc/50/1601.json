{"tag":"section","attrib":{"id":"idd113e4b6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1601"},"text":null,"children":[{"tag":"num","attrib":{"value":"1601"},"text":"§ 1601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of existing declared emergencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd113e4b7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1601/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" All powers and authorities possessed by the President, any other officer or employee of the Federal Government, or any executive agency, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of title 5","children":[],"tail":", as a result of the existence of any declaration of national emergency in effect on "},{"tag":"date","attrib":{"date":"1976-09-14"},"text":"September 14, 1976","children":[],"tail":", are terminated two years from "},{"tag":"date","attrib":{"date":"1976-09-14"},"text":"September 14, 1976","children":[],"tail":". Such termination shall not affect—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd113e4b8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1601/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any action taken or proceeding pending not finally concluded or determined on such date;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd113e4b9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1601/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any action or proceeding based on any act committed prior to such date; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd113e4ba-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1601/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any rights or duties that matured or penalties that were incurred prior to such date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd113e4bb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1601/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of this section, the words “any national emergency in effect” means a general declaration of emergency made by the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd113e4bc-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/412/tI/s101"},"text":"Pub. L. 94–412, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-14"},"text":"Sept. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1255"},"text":"90 Stat. 1255","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd113e4bd-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd113e4be-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idd113e4bf-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/412/s1"},"text":"Pub. L. 94–412, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-14"},"text":"Sept. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1255"},"text":"90 Stat. 1255","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/412/s1"},"text":"“That this Act [enacting this chapter, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1481"},"text":"section 1481 of Title 8","children":[],"tail":", Aliens and Nationality, and "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2667"},"text":"section 2667 of Title 10","children":[],"tail":", Armed Forces, repealing "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s249"},"text":"section 249 of Title 12","children":[],"tail":", Banks and Banking, "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s831d"},"text":"section 831d of Title 16","children":[],"tail":", Conservation, "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1383"},"text":"section 1383 of Title 18","children":[],"tail":", Crimes and Criminal Procedure, "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s211b"},"text":"section 211b of Title 42","children":[],"tail":", The Public Health and Welfare, and section 1742 of the former Appendix to this title, and enacting provisions set out below] may be cited as the ‘National Emergencies Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idd113e4c0-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/412/tV/s501/h"},"text":"Pub. L. 94–412, title V, § 501(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-14"},"text":"Sept. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1258"},"text":"90 Stat. 1258","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/412/tV/s501/h"},"text":"\n"