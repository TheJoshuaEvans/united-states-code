{"tag":"section","attrib":{"id":"idd24eaf9b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4851"},"text":null,"children":[{"tag":"num","attrib":{"value":"4851"},"text":"§ 4851.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Under Secretary of Commerce for Industry and Security","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd24eaf9c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4851/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Under Secretary of Commerce for Industry and Security","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall appoint, by and with the advice and consent of the Senate, an Under Secretary of Commerce for Industry and Security, who shall carry out—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd24eaf9d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4851/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all functions of the Secretary under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd24eaf9e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4851/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all functions delegated to the Under Secretary of Commerce for Export Administration on the day before the date of the enactment of this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd24eaf9f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4851/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"2018-08-13"},"text":"August 13, 2018","children":[],"tail":", any reference in any law or regulation to the Under Secretary of Commerce for Export Administration shall be deemed to be a reference to the Under Secretary of Commerce for Industry and Security."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd24eafa0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4851/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd24eafa1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4851/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation in office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The individual serving as Under Secretary of Commerce for Export Administration on the day before ","children":[{"tag":"date","attrib":{"date":"2018-08-13"},"text":"August 13, 2018","children":[],"tail":", may serve as the Under Secretary of Commerce for Industry and Security on and after that date without the need for renomination or reappointment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd24eafa2-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVII/s1781"},"text":"Pub. L. 115–232, div. A, title XVII, § 1781","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2238"},"text":"132 Stat. 2238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/6/dH/tII/s205/a"},"text":"Pub. L. 116–6, div. H, title II, § 205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-02-15"},"text":"Feb. 15, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/476"},"text":"133 Stat. 476","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd24eafa3-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd24eafa4-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd24eafa5-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(1), was in the original “this subtitle”, meaning subtitle B (§§ 1741–1781) of title XVII of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2208"},"text":"132 Stat. 2208","children":[],"tail":", known as the Export Control Reform Act of 2018, which is classified principally to this chapter. For complete classification of subtitle B to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s1741"},"text":"section 1741 of Pub. L. 115–232","children":[],"tail":", set out as a Short Title note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4801"},"text":"section 4801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of the enactment of this Act, referred to in subsec. (a)(2), probably means the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":", which enacted this section and was approved "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd24eafa6-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s1781"},"text":"section 1781 of Pub. L. 115–232","children":[],"tail":". Subsec. (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s1781"},"text":"section 1781 of Pub. L. 115–232","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd24eafa7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/6/s205/a/3"},"text":"Pub. L. 116–6, § 205(a)(3)","children":[],"tail":", added subsec. (a). Former subsec. (a) redesignated (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/6/s205/a/1"},"text":"Pub. L. 116–6, § 205(a)(1)","children":[],"tail":", (2), redesignated subsec. (a) as (b) and substituted “Reference” for “In general” in heading. Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/6/s205/a/1"},"text":"Pub. L. 116–6, § 205(a)(1)","children":[],"tail":", redesignated subsecs. (b) and (c) as (c) and (d), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd24eafa8-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd24eafa9-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/6/dH/tII/s205/d"},"text":"Pub. L. 116–6, div. H, title II, § 205(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-02-15"},"text":"Feb. 15, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/477"},"text":"133 Stat. 477","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/6/dH/tII/s205/d"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of Title 5","children":[],"tail":", Government Organization and Employees] shall take effect as if included in the John S. McCain National Defense Authorization Act for Fiscal Year 2019 ("},{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Public Law 115–232","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
