{"tag":"section","attrib":{"id":"idd1f67cf5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3713"},"text":null,"children":[{"tag":"num","attrib":{"value":"3713"},"text":"§ 3713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority for urgent threat reduction activities under Department of Defense Cooperative Threat Reduction Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1f67cf6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3713/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of funds for urgent threat reduction activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsections (b) and (c), not more than 15 percent of the total amount of Cooperative Threat Reduction funds for any fiscal year may be obligated or expended, notwithstanding any other provision of law, for covered activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f67cf7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3713/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of Defense determination and notice for urgent threat reduction activities in governed areas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to an area not covered by subsection (c), the Secretary of Defense may obligate or expend funds pursuant to subsection (a) for covered activities if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1f67cf8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3713/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary determines, in writing, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1f67cf9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3713/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a threat arising in such area from the proliferation of chemical, nuclear, or biological weapons or weapons-related materials, technologies, or expertise must be addressed urgently;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f67cfa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3713/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certain provisions of law would unnecessarily impede the ability of the Secretary to carry out such covered activities to address such threat; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f67cfb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3713/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is necessary to obligate or expend such funds to carry out such covered activities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67cfc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3713/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of State and the Secretary of Energy concur with such determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67cfd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3713/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than seven days before the date on which the Secretary of Defense first obligates such funds, the Secretary of Defense, in consultation with the Secretary of State, submits to the congressional defense committees, the Committee on Foreign Affairs of the House of Representatives, and the Committee on Foreign Relations of the Senate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1f67cfe-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3713/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the determination under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f67cff-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3713/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the covered activities to be carried out using such funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f67d00-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3713/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expected time frame for such activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f67d01-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3713/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expected cost of such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f67d02-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3713/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential determination and notice for urgent threat reduction activities in ungoverned areas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to an ungoverned area or an area that is not controlled by an effective governmental authority, as determined by the Secretary of State, the President may obligate or expend funds pursuant to subsection (a) for covered activities if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1f67d03-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3713/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the President determines, in writing, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1f67d04-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3713/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a threat arising in such an area from the proliferation of chemical, nuclear, or biological weapons or weapons-related materials, technologies, or expertise must be addressed urgently; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f67d05-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3713/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is necessary to obligate or expend such funds to carry out such covered activities to address such threat; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67d06-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3713/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at the time at which the President first obligates such funds, the Secretary of Defense, in consultation with the Secretary of State, submits to the congressional defense committees, the Committee on Foreign Affairs of the House of Representatives, and the Committee on Foreign Relations of the Senate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1f67d07-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3713/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the determination under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f67d08-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3713/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the covered activities to be carried out using such funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f67d09-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3713/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expected time frame for such activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f67d0a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3713/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expected cost of such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f67d0b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3713/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered activity defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “covered activity” means an activity under the Program to address a threat arising from the proliferation of chemical, nuclear, or biological weapons or weapons-related materials, technologies, or expertise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1f67d0c-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tXIII/s1323"},"text":"Pub. L. 113–291, div. A, title XIII, § 1323","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3598"},"text":"128 Stat. 3598","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXIII/s1302/b/3"},"text":"Pub. L. 114–328, div. A, title XIII, § 1302(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2566"},"text":"130 Stat. 2566","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1f67d0d-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1f67d0e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1f67d0f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" substituted “not later than seven days before the date on which” for “at the time at which” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
