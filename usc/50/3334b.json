{"tag":"section","attrib":{"id":"idd1cde661-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3334b"},"text":"§ 3334b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection, analysis, and dissemination of workforce data","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1cde662-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cde663-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cde664-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", the Director of National Intelligence shall make available to the public, the appropriate congressional committees, and the workforce of the intelligence community a report which includes aggregate demographic data and other information regarding the diversity and inclusion efforts of the workforce of the intelligence community."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde665-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A report made available under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1cde666-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include unclassified reports and barrier analyses relating to diversity and inclusion efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cde667-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall include aggregate demographic data—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1cde668-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by segment of the workforce of the intelligence community and grade or rank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1cde669-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relating to attrition and promotion rates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1cde66a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that addresses the compliance of the intelligence community with validated inclusion metrics, such as the New Inclusion Quotient index score; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1cde66b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that provides demographic comparisons to the relevant nongovernmental labor force and the relevant civilian labor force;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cde66c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include an analysis of applicant flow data, including the percentage and level of positions for which data are collected, and a discussion of any resulting policy changes or recommendations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cde66d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include demographic data relating to participants in professional development programs of the intelligence community and the rate of placement into senior positions for participants in such programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cde66e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include any voluntarily collected demographic data relating to the membership of any external advisory committee or board to which individuals in senior positions in the intelligence community appoint members; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cde66f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include data in proportions or percentages to account for concerns relating to the protection of classified information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cde670-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than March 31 of each year, the Director of National Intelligence shall provide a report (which may be provided as part of an annual report required under another provision of law) to the workforce of the intelligence community (including senior leadership), the public, and the appropriate congressional committees that includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cde671-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" demographic data and information on the status of diversity and inclusion efforts of the intelligence community, including demographic data relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1cde672-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average years of service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cde673-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average number of years of service for each level in the General Schedule, Senior Executive Service, Senior Intelligence Service, or equivalent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cde674-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" career categories;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde675-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of applicant flow data, including the percentage and level of positions for which data are collected, and a discussion of any resulting policy changes or recommendations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde676-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demographic data relating to participants in professional development programs of the intelligence community and the rate of placement into senior positions for participants in such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cde677-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expand the collection and analysis of voluntary applicant flow data","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cde678-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence shall develop a system to collect and analyze applicant flow data for as many positions within the intelligence community as practicable, in order to identify areas for improvement in attracting diverse talent, with particular attention to senior and management positions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde679-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Phased implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The collection of applicant flow data may be implemented by the Director of National Intelligence in a phased approach commensurate with the resources available to the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cde67a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identify additional categories for voluntary data collection of current employees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cde67b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence may submit to the Office of Management and Budget and to the appropriate congressional committees a recommendation regarding whether the intelligence community should voluntarily collect more detailed data on demographic categories in addition to the race and ethnicity categories specified in the statistical policy directive issued by the Office of Management and Budget entitled “Standards for Maintaining, Collecting, and Presenting Federal Data on Race and Ethnicity”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde67c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making a recommendation under paragraph (1), the Director of National Intelligence shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1cde67d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage in close consultation with internal stakeholders, such as employee resource or affinity groups;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cde67e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that there is clear communication with the workforce of the intelligence community—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1cde67f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to explain the purpose of the potential collection of such data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1cde680-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regarding legal protections relating to any anticipated use of such data; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cde681-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure adherence to relevant standards and guidance issued by the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cde682-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cde683-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicant flow data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “applicant flow data” means data that tracks the rate of applications for job positions among demographic categories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde684-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1cde685-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations, the Committee on Armed Services, the Committee on Homeland Security and Governmental Affairs, the Select Committee on Intelligence, and the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1cde686-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs, the Committee on Armed Services, the Committee on Homeland Security, the Permanent Select Committee on Intelligence, and the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cde687-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334b/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diversity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “diversity” means diversity of persons based on gender, race, ethnicity, disability status, veteran status, sexual orientation, gender identity, national origin, and other demographic categories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1cde688-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLVII/s5704"},"text":"Pub. L. 116–92, div. E, title LVII, § 5704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2162"},"text":"133 Stat. 2162","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dX/tVIII/s802"},"text":"Pub. L. 117–103, div. X, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1011"},"text":"136 Stat. 1011","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dF/tLXVIII/s6824/b/1"},"text":"Pub. L. 117–263, div. F, title LXVIII, § 6824(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3615"},"text":"136 Stat. 3615","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1cde689-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1cde68a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1cde68b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s5704"},"text":"section 5704 of Pub. L. 116–92","children":[],"tail":". Subsec. (a) of "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/s5704"},"text":"section 5704 of Pub. L. 116–92","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3050"},"text":"section 3050 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1cde68c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" struck out “, and subject to paragraph (3)” after “Not later than 180 days after "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s802/1"},"text":"Pub. L. 117–103, § 802(1)","children":[],"tail":", substituted “Not later than March 31 of each year, the Director of National Intelligence shall provide a report” for “After making available a report under subsection (b), the Director of National Intelligence shall annually provide a report” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s802/2"},"text":"Pub. L. 117–103, § 802(2)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “demographic data and information on the status of diversity and inclusion efforts of the intelligence community;”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1cde68d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1cde68e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Expansion of Intelligence Community Recruitment Efforts","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLXIII/s6316"},"text":"Pub. L. 116–92, div. E, title LXIII, § 6316","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2195"},"text":"133 Stat. 2195","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dF/tLXVIII/s6824/b/2"},"text":"Pub. L. 117–263, div. F, title LXVIII, § 6824(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3615"},"text":"136 Stat. 3615","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dF/tLXVIII/s6824/b/2"},"text":"“In order to further increase the diversity of the intelligence community workforce, not later than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":"], the Director of National Intelligence, in consultation with heads of elements of the Intelligence Community, shall create, implement, and submit to the congressional intelligence committees a written plan to ensure that rural and underrepresented regions are more fully and consistently represented in such elements’ employment recruitment efforts. Upon receipt of the plan, the congressional intelligence committees shall have 60 days to submit comments to the Director of National Intelligence before such plan shall be implemented.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definitions of “intelligence community” and “congressional intelligence committees” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s6316"},"text":"section 6316 of Pub. L. 116–92","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/s5003"},"text":"section 5003 of div. E of Pub. L. 116–92","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd1cde68f-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “intelligence community” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/s5003"},"text":"section 5003 of div. E of Pub. L. 116–92","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
