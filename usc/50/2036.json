{"tag":"section","attrib":{"id":"idd15b750e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2036"},"text":null,"children":[{"tag":"num","attrib":{"value":"2036"},"text":"§ 2036.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survivor annuities for previous spouses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director shall prescribe regulations under which a previous spouse who is divorced after ","children":[{"tag":"date","attrib":{"date":"1988-09-29"},"text":"September 29, 1988","children":[],"tail":", from a participant, former participant, or retired participant shall be eligible for a survivor annuity to the same extent and, to the greatest extent practicable, under the same conditions (including reductions to be made in the annuity of the participant) applicable to former spouses (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8331/23"},"text":"section 8331(23) of title 5","children":[],"tail":") of participants in the Civil Service Retirement and Disability System (CSRS) as prescribed by the Civil Service Retirement Spouse Equity Act of 1984."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd15b750f-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/tII/s226"},"text":"Pub. L. 88–643, title II, § 226","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s802"},"text":"Pub. L. 102–496, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3220"},"text":"106 Stat. 3220","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd15b7510-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd15b7511-47c4-11f1-8bcf-c