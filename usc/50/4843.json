{"tag":"section","attrib":{"id":"idd24eaf89-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4843"},"text":null,"children":[{"tag":"num","attrib":{"value":"4843"},"text":"§ 4843.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd24eaf8a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4843/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person who willfully commits, willfully attempts to commit, or willfully conspires to commit, or aids or abets in the commission of, an unlawful act under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4842"},"text":"section 4842 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd24eaf8b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4843/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall, upon conviction, be fined not more than $1,000,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd24eaf8c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4843/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a natural person, may be imprisoned for not more than 20 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd24eaf8d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4843/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may impose the following civil penalties on a person who violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4842"},"text":"section 4842 of this title","children":[],"tail":" or any regulation issued under this subchapter:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd24eaf8e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4843/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A fine of not more than $300,000 or an amount that is twice the value of the transaction that is the basis of the violation with respect to which the penalty is imposed, whichever is greater.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd24eaf8f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4843/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Revocation of a license issued under subchapter I to the person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd24eaf90-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4843/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A prohibition on the person’s ability to export, reexport, or in-country transfer any items controlled under subchapter I.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd24eaf91-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4843/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any civil penalty or administrative sanction (including any suspension or revocation of authority to export) under this section may be imposed only after notice and opportunity for an agency hearing on the record in accordance with sections 554 through 557 of title 5 and shall be subject to judicial review in accordance with chapter 7 of such title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd24eaf92-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4843/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards for levels of civil penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may by regulation provide standards for establishing levels of civil penalty under this section based upon factors such as the seriousness of the violation, the culpability of the violator, and the violator’s record of cooperation with the Government in disclosing the violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd24eaf93-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVII/s1774"},"text":"Pub. L. 115–232, div. A, title XVII, § 1774","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2237"},"text":"132 Stat. 2237","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tX/s1081/d/11"},"text":"Pub. L. 116–283, div. A, title X, § 1081(d)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3874"},"text":"134 Stat. 3874","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd24eaf94-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd24eaf95-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd24eaf96-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapter I, referred to in subsec. (b)(2), (3), was in the original “part I”, meaning part I (§§ 1751–1768) of subtitle B of title XVII of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":", known as the Export Controls Act of 2018, which is classified principally to subchapter I of this chapter. For complete classification of part I to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s1751"},"text":"section 1751 of Pub. L. 115–232","children":[],"tail":", set out as a Short Title note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4801"},"text":"section 4801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd24eaf97-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" inserted “under” before “"},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4842"},"text":"section 4842 of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd24eaf98-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd24eaf99-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tX/s1081/d"},"text":"Pub. L. 116–283, div. A, title X, § 1081(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3873"},"text":"134 Stat. 3873","children":[],"tail":", provided that the amendment made by section 1081(d)(11) is effective as of "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
