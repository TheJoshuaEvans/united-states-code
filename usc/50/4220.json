{"tag":"section","attrib":{"id":"idd217e7d0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4220"},"text":null,"children":[{"tag":"num","attrib":{"value":"4220"},"text":"§ 4220.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entitlements to eligible individuals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd217e7d1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4220/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to sections 4214(e) and 4215(g) of this title and except as provided in subsection (b), beginning on ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"October 1, 1990","children":[],"tail":", the payments to be made to any eligible individual under the provisions of this subchapter shall be an entitlement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd217e7d2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4220/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments from discretionary appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd217e7d3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4220/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any such payment made to an individual who is not of Japanese ancestry and who is an eligible individual on the basis of the amendment made by section 3 of the Civil Liberties Act Amendments of 1992 shall not be an entitlement and shall be made from discretionary appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e7d4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4220/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for fiscal year 1993 and each subsequent fiscal year such sums as may be necessary for the payments from discretionary appropriations described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd217e7d5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4220/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd217e7d6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4220/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “discretionary appropriations” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s900/c/7"},"text":"section 900(c)(7) of title 2","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e7d7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4220/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “entitlement” means “spending authority” as defined in section 651(c)(2)(C) ","children":[{"tag":"ref","attrib":{"idref":"fn002128"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002128"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 2."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd217e7d8-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/383/tI/s110"},"text":"Pub. L. 100–383, title I, § 110","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/162/tII/s209/a"},"text":"Pub. L. 101–162, title II, § 209(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-21"},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1005"},"text":"103 Stat. 1005","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/371/s7"},"text":"Pub. L. 102–371, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-09-27"},"text":"Sept. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1168"},"text":"106 Stat. 1168","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd217e7d9-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd217e7da-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd217e7db-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 3 of the Civil Liberties Act Amendments of 1992, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/371/s3"},"text":"section 3 of Pub. L. 102–371","children":[],"tail":", which amended paragraph (2) of "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4218"},"text":"section 4218 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s651/c/2/C"},"text":"Section 651(c)(2)(C) of title 2","children":[],"tail":", referred to in subsec. (c)(2), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tX/s10116/a/3"},"text":"Pub. L. 105–33, title X, § 10116(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/691"},"text":"111 Stat. 691","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd217e7dc-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 1989b–9 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd217e7dd-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/371"},"text":"Pub. L. 102–371","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, inserted “and except as provided in subsection (b)” after “4215(g) of this title”, struck out “As used in this section, the term ‘entitlement’ means ‘spending authority’ as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s651/c/2/C"},"text":"section 651(c)(2)(C) of title 2","children":[],"tail":".” after “shall be an entitlement.”, and added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
