{"tag":"section","attrib":{"id":"idd20e4b4b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4042"},"text":null,"children":[{"tag":"num","attrib":{"value":"4042"},"text":"§ 4042.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private right of action","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd20e4b4c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4042/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person aggrieved by a violation of this chapter may in a civil action—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20e4b4d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4042/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain any appropriate equitable or declaratory relief with respect to the violation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4b4e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4042/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recover all other appropriate relief, including monetary damages; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4b4f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4042/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a representative party on behalf of members of a class or be a member of a class, in accordance with the Federal Rules of Civil Procedure, notwithstanding any previous agreement to the contrary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4b50-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4042/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs and attorney fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The court may award to a person aggrieved by a violation of this chapter who prevails in an action brought under subsection (a) the costs of the action, including a reasonable attorney fee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd20e4b51-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title VIII, § 802, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/275/tIII/s303/a"},"text":"Pub. L. 111–275, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-13"},"text":"Oct. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2877"},"text":"124 Stat. 2877","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tV/s547/a"},"text":"Pub. L. 116–92, div. A, title V, § 547(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1378"},"text":"133 Stat. 1378","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd20e4b52-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd20e4b53-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd20e4b54-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Civil Procedure, referred to in subsec. (a)(3), are set out in the Appendix to Title 28, Judiciary and Judicial Procedure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd20e4b55-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 597a of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd20e4b56-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd20e4b57-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd20e4b58-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tV/s547/b"},"text":"Pub. L. 116–92, div. A, title V, § 547(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1378"},"text":"133 Stat. 1378","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dA/tV/s547/b"},"text":"“The amendments made by subsection (a) [amending this section] shall not be construed to imply that a person aggrieved by a violation of such Act [the Servicemembers Civil Relief Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3901"},"text":"50 U.S.C. 3901","children":[],"tail":" et seq.)] did not have a right to bring a civil action as a representative party on behalf of members of a class or be a member of a class in a civil action before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
