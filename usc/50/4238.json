{"tag":"section","attrib":{"id":"idd217e846-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4238"},"text":null,"children":[{"tag":"num","attrib":{"value":"4238"},"text":"§ 4238.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with Budget Act","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"No authority under this subchapter to enter into contracts or to make payments shall be effective in any fiscal year except to such extent and in such amounts as are provided in advance in appropriations Acts. In any fiscal year, the Secretary, with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd217e847-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4238/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4233"},"text":"section 4233 of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e848-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4238/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trust established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4235/b"},"text":"section 4235(b) of this title","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e849-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4238/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of sections 4236 and 4237 of this title,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall limit the total benefits conferred to an amount not in excess of the appropriations for such fiscal year. Any provision of this subchapter which, directly or indirectly, authorizes the enactment of new budget authority shall be effective only for fiscal year 1989 and thereafter.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd217e84a-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/383/tII/s208"},"text":"Pub. L. 100–383, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-10"},"text":"Aug. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/916"},"text":"102 Stat. 916","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd217e84b-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd217e84c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd217e84d-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Budget Act, referred to in section catchline, probably means the Congressional Budget Act of 1974, titles I through IX of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344"},"text":"Pub. L. 93–344","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-07-12"},"text":"July 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/297"},"text":"88 Stat. 297","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s621"},"text":"section 621 of Title 2","children":[],"tail":", The Congress, and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd217e84e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 1989c–7 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
