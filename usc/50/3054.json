{"tag":"section","attrib":{"id":"idd19e4ae5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3054"},"text":null,"children":[{"tag":"num","attrib":{"value":"3054"},"text":"§ 3054.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" POW/MIA analytic capability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd19e4ae6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3054/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd19e4ae7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3054/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of National Intelligence shall, in consultation with the Secretary of Defense, establish and maintain in the intelligence community an analytic capability with responsibility for intelligence in support of the activities of the United States relating to individuals who, after ","children":[{"tag":"date","attrib":{"date":"1990-12-31"},"text":"December 31, 1990","children":[],"tail":", are unaccounted for United States personnel."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd19e4ae8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3054/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The analytic capability maintained under paragraph (1) shall be known as the “POW/MIA analytic capability of the intelligence community”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19e4ae9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3054/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unaccounted for United States personnel","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “unaccounted for United States personnel” means the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd19e4aea-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3054/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any missing person (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1513/1"},"text":"section 1513(1) of title 10","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd19e4aeb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3054/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any United States national who was killed while engaged in activities on behalf of the United States and whose remains have not been repatriated to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd19e4aec-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title I, § 117, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/567/tIII/s307/a"},"text":"Pub. L. 106–567, title III, § 307(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2839"},"text":"114 Stat. 2839","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI/s1071/a/1/T"},"text":"Pub. L. 108–458, title I, § 1071(a)(1)(T)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"re