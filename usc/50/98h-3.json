{"tag":"section","attrib":{"id":"idd0f0305a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"98h–3"},"text":"§ 98h–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0f0305b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–3/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “strategic and critical materials” means materials that (A) would be needed to supply the military, industrial, and essential civilian needs of the United States during a national emergency, and (B) are not found or produced in the United States in sufficient quantities to meet such need.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f0305c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–3/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “national emergency” means a general declaration of emergency with respect to the national defense made by the President or by the Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0f0305d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–3/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “reliable source” mean a citizen or business entity organized under the laws of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd0f0305e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–3/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States or any territory or possession of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0f0305f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–3/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a country of the national technology and industrial base, as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4801"},"text":"section 4801 of title 10","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd0f03060-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98h–3/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a qualifying country, as defined in section 225.003 of the Defense Federal Acquisition Regulation Supplement or any successor document.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd0f03061-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-06-07/ch190/s12"},"text":"June 7, 1939, ch. 190, § 12","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/41/s2/a"},"text":"Pub. L. 96–41, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-30"},"text":"July 30, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/324"},"text":"93 Stat. 324","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXIV/s1411/2"},"text":"Pub. L. 117–81, div. A, title XIV, § 1411(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2018"},"text":"135 Stat. 2018","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXIV/s1411/e/2/C"},"text":"Pub. L. 118–31, div. A, title XIV, § 1411(e)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/528"},"text":"137 Stat. 528","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd0f03062-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd0f03063-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd0f03064-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" added par. (3) and struck out former par. (3) which read as follows: “The term ‘national technology and industrial base’ has the meaning given such term in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2500"},"text":"section 2500 of title 10","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" added par. (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
