{"tag":"section","attrib":{"id":"idd1cb9c4b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3321"},"text":null,"children":[{"tag":"num","attrib":{"value":"3321"},"text":"§ 3321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Intelligence Reserve Corps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1cb9c4c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3321/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence may provide for the establishment and training of a National Intelligence Reserve Corps (in this section referred to as “National Intelligence Reserve Corps”) for the temporary reemployment on a voluntary basis of former employees of elements of the intelligence community during periods of emergency, as determined by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cb9c4d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3321/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible individuals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual may participate in the National Intelligence Reserve Corps only if the individual previously served as a full time employee of an element of the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cb9c4e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3321/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence shall prescribe the terms and conditions under which eligible individuals may participate in the National Intelligence Reserve Corps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cb9c4f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3321/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence may provide members of the National Intelligence Reserve Corps transportation and per diem in lieu of subsistence for purposes of participating in any training that relates to service as a member of the Reserve Corps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cb9c50-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3321/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of annuitants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1cb9c51-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3321/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an annuitant receiving an annuity from the Civil Service Retirement and Disability Fund becomes temporarily reemployed pursuant to this section, such annuity shall not be discontinued thereby.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1cb9c52-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3321/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An annuitant so reemployed shall not be considered an employee for the purposes of chapter 83 or 84 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1cb9c53-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3321/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment under Office of Director of National Intelligence personnel ceiling","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the National Intelligence Reserve Corps who is reemployed on a temporary basis pursuant to this section shall not count against any personnel ceiling applicable to the Office of the Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1cb9c54-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI/s1053"},"text":"Pub. L. 108–458, title I, § 1053","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3683"},"text":"118 Stat. 3683","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1cb9c55-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1cb9c56-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1cb9c57-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s403–1c"},"text":"section 403–1c of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1cb9c58-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd1cb9c59-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For Determination by President that section take effect on ","children":[{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", see Memorandum of President of the United States, "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", 70 F.R. 23925, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section effective not later than six months after ","children":[{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1097/a"},"text":"section 1097(a) of Pub. L. 108–458","children":[],"tail":", set out in an Effective Date of 2004 Amendment; Transition Provisions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
