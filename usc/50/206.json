{"tag":"section","attrib":{"id":"idd0f9a692-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s206"},"text":null,"children":[{"tag":"num","attrib":{"value":"206"},"text":"§ 206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of commercial intercourse with part of State in insurrection","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever any part of a State not declared to be in insurrection is under the control of insurgents, or is in dangerous proximity to places under their control, all commercial intercourse therein and therewith shall be subject to the prohibitions and conditions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s205"},"text":"section 205 of this title","children":[],"tail":" for such time and to such extent as shall become necessary to protect the public interests, and be directed by the Secretary of the Treasury, with the approval of the President."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd0f9a693-47c4-11f1-8bcf-c89722bddd2e"},"text":"(R.S. § 5302.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd0f9a694-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd0f9a695-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd0f9a696-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5302 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1864-07-02/ch225/s5"},"text":"act July 2, 1864, ch. 225, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/13/376"},"text":"13 Stat. 376","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
