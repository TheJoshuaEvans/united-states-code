{"tag":"section","attrib":{"id":"idd15b75ba-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2081"},"text":null,"children":[{"tag":"num","attrib":{"value":"2081"},"text":"§ 2081.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of length of service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd15b75bb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2081/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15b75bc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2081/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crediting service as participant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this subchapter, the period of service of a participant shall be computed from the date on which the participant becomes a participant under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15b75bd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2081/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of certain periods","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In computing the period of service of a participant, all periods of separation from the Agency and so much of any leave of absence without pay as may exceed six months in the aggregate in any calendar year shall be excluded, except leaves of absence while receiving benefits under chapter 81 of title 5 and leaves of absence granted participants while performing active and honorable service in the Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15b75be-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2081/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crediting certain periods of separation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A participant or former participant who returns to Government duty after a period of separation shall have included in the participant or former participant’s period of service that part of the period of separation in which the participant or former participant was receiving benefits under chapter 81 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15b75bf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2081/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extra credit for periods served at unhealthful posts overseas","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15b75c0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2081/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classification of certain posts as unhealthful","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may from time to time establish a list of places outside the United States that, by reason of climatic or other extreme conditions, are to be classed as unhealthful posts. Such list shall be established in consultation with the Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15b75c1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2081/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extra credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each year of duty at a post on the list established under paragraph (1), inclusive of regular leaves of absence, shall be counted as one and a half years in computing the length of service of a participant under this subchapter for the purpose of retirement. In computing such service, any fractional month shall be treated as a full month.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15b75c2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2081/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with benefits under title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Extra credit for service at an unhealthful post may not be credited to a participant who is paid a differential under section 5925 or 5928 of title 5 for the same service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd15b75c3-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/tII/s251"},"text":"Pub. L. 88–643, title II, § 251","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s802"},"text":"Pub. L. 102–496, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3228"},"text":"106 Stat. 3228","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd15b75c4-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd15b75c5-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd15b75c6-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/s251"},"text":"section 251 of Pub. L. 88–643","children":[],"tail":", title II, "},{"tag":"date","attrib":{"date":"1964-10-13"},"text":"Oct. 13, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1050"},"text":"78 Stat. 1050","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/522/tII/s210"},"text":"Pub. L. 94–522, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-17"},"text":"Oct. 17, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2471"},"text":"90 Stat. 2471","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/169/tVII/s702"},"text":"Pub. L. 99–169, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-04"},"text":"Dec. 4, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1008"},"text":"99 Stat. 1008","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/tV/s501/2"},"text":"Pub. L. 99–335, title V, § 501(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/622"},"text":"100 Stat. 622","children":[],"tail":", related to computation of length of service and was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403"},"text":"section 403 of this title","children":[],"tail":" prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/88/643"},"text":"Pub. L. 88–643","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s802"},"text":"section 802 of Pub. L. 102–496","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd15b75c7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd15b75c8-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of fourth month beginning after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s805"},"text":"section 805 of Pub. L. 102–496","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
