{"tag":"section","attrib":{"id":"idd14f8f44-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1885b"},"text":"§ 1885b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd14f8f45-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No State shall have authority to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd14f8f46-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct an investigation into an electronic communication service provider’s alleged assistance to an element of the intelligence community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14f8f47-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require through regulation or any other means the disclosure of information about an electronic communication service provider’s alleged assistance to an element of the intelligence community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14f8f48-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impose any administrative sanction on an electronic communication service provider for assistance to an element of the intelligence community; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd14f8f49-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commence or maintain a civil action or other proceeding to enforce a requirement that an electronic communication service provider disclose information concerning alleged assistance to an element of the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd14f8f4a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suits by the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States may bring suit to enforce the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd14f8f4b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The district courts of the United States shall have jurisdiction over any civil action brought by the United States to enforce the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd14f8f4c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1885b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to any investigation, action, or proceeding that is pending on or commenced after ","children":[{"tag":"date","attrib":{"date":"2008-07-10"},"text":"July 10, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd14f8f4d-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511/tVIII/s803"},"text":"Pub. L. 95–511, title VIII, § 803","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/261/tII/s201"},"text":"Pub. L. 110–261, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-10"},"text":"July 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2470"},"text":"122 Stat. 2470","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
