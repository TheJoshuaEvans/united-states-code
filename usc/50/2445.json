{"tag":"section","attrib":{"id":"idd16e882a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2445"},"text":null,"children":[{"tag":"num","attrib":{"value":"2445"},"text":"§ 2445.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on bonuses for employees who engage in improper program management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd16e882b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2445/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16e882c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2445/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy or the Administrator may not pay to a covered employee a bonus during the one-year period beginning on the date on which the Secretary or the Administrator, as the case may be, determines that the covered employee engaged in improper program management that resulted in a notification under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2753"},"text":"section 2753 of this title","children":[],"tail":" or significantly and detrimentally affected the cost, scope, or schedule associated with the approval of critical decision 3 in the acquisition process for a project (as defined in Department of Energy Order 413.3B (relating to program management and project management for the acquisition of capital assets))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16e882d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2445/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2015-11-25"},"text":"November 25, 2015","children":[],"tail":", the Secretary shall issue guidance for the implementation of paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16e882e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2445/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance prohibiting bonuses for additional employees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2015-11-25"},"text":"November 25, 2015","children":[],"tail":", the Secretary and the Administrator shall each issue guidance prohibiting the payment of a bonus to a covered employee during the one-year period beginning on the date on which the Secretary or the Administrator, as the case may be, determines that the covered employee engaged in improper program management—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16e882f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2445/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that jeopardized the health, safety, or security of employees or facilities of the Administration or another element of the Department of Energy involved in nuclear security; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16e8830-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2445/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in carrying out defense nuclear nonproliferation activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16e8831-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2445/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary or the Administrator, as the case may be, may waive the limitation on the payment of a bonus under subsection (a) or (b) on a case-by-case basis if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16e8832-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2445/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary or the Administrator, as the case may be, notifies the appropriate congressional committees of such waiver; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16e8833-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2445/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of 60 days elapses following such notification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16e8834-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2445/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16e8835-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2445/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd16e8836-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2445/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional defense committees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd16e8837-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2445/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Commerce of the House of Representatives and the Committee on Energy and Natural Resources of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16e8838-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2445/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “bonus” means a bonus or award paid under title 5, including under chapters 45 or 53 of such title, or any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16e8839-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2445/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “covered employee” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2443"},"text":"section 2443 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd16e883a-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dC/tXXXII/s3246"},"text":"Pub. L. 106–65, div. C, title XXXII, § 3246","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dC/tXXXI/s3111/b/1"},"text":"Pub. L. 114–92, div. C, title XXXI, § 3111(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1187"},"text":"129 Stat. 1187","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
