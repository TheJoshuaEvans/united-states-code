{"tag":"section","attrib":{"id":"idd1a305ae-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3075"},"text":null,"children":[{"tag":"num","attrib":{"value":"3075"},"text":"§ 3075.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Function” and “Department of Defense” defined","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1a305af-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3075/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As used in sections 3002, 3021, 3023, 3025, and 3073 of this title, the term “function” includes functions, powers, and duties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1a305b0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3075/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As used in this Act, the term “Department of Defense” shall be deemed to include the military departments of the Army, the Navy, and the Air Force, and all agencies created under title II of this Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1a305b1-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title III, § 308, "},{"tag":"ref","attrib":{"href":"/us/stat/61/509"},"text":"61 Stat. 509","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-08-10/ch412/s12/e"},"text":"Aug. 10, 1949, ch. 412, § 12(e)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/591"},"text":"63 Stat. 591","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLXVII/s6742/b/10"},"text":"Pub. L. 116–92, div. E, title LXVII, § 6742(b)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-