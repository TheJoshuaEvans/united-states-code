{"tag":"section","attrib":{"id":"idd143a825-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1844"},"text":null,"children":[{"tag":"num","attrib":{"value":"1844"},"text":"§ 1844.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization during time of war","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the President, through the Attorney General, may authorize the use of a pen register or trap and trace device without a court order under this subchapter to acquire foreign intelligence information for a period not to exceed 15 calendar days following a declaration of war by Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd143a826-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511/tIV/s404"},"text":"Pub. L. 95–511, title IV, § 404","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/272/tVI/s601/2"},"text":"Pub. L. 105–272, title VI, § 601(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-20"},"text":"Oct. 20, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2408"},"text":"112 Stat. 2408","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
