{"tag":"section","attrib":{"id":"idd1a0952a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3072a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3072a"},"text":"§ 3072a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports on exercise of authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1a0952b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3072a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2003-12-13"},"text":"December 13, 2003","children":[],"tail":", and annually thereafter, the Director of the Federal Bureau of Investigation shall submit to the appropriate committees of Congress a report on the exercise of the authority in "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3072"},"text":"section 3072 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a0952c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3072a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each report under this section shall include, for the one-year period ending on the date of such report, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1a0952d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3072a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of contracts entered into during the period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a0952e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3072a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The cost of each such contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a0952f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3072a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The length of each such contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a09530-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3072a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The types of services to be provided under each such contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a09531-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3072a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The availability, if any, of United States Government personnel to perform functions similar to the services to be provided under each such contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a09532-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3072a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The efforts of the Federal Bureau of Investigation to fill available personnel vacancies, or request additional personnel positions, in areas relating to the intelligence or counterintelligence mission of the Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a09533-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3072a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each report under this section shall be submitted in unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a09534-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3072a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1a09535-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3072a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for purposes of the submittal of the classified annex to any report under this section, the term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1a09536-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3072a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Select Committee on Intelligence of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1a09537-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3072a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Permanent Select Committee on Intelligence of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1a09538-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3072a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for purposes of the submittal of the unclassified portion of any report under this section, the term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1a09539-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3072a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the committees specified in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1a0953a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3072a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committees on Appropriations, Governmental Affairs, and the Judiciary of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1a0953b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3072a/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committees on Appropriations, Government Reform and Oversight, and the Judiciary of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1a0953c-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177/tIII/s311/b"},"text":"Pub. L. 108–177, title III, § 311(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-13"},"text":"Dec. 13, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2605"},"text":"117 Stat. 2605","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1a0953d-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1a0953e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1a0953f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s409b–1"},"text":"section 409b–1 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Intelligence Authorization Act for Fiscal Year 2004, and not as part of the National Security Act of 1947 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1a09540-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idd1a09541-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Government Reform and Oversight of House of Representatives changed to Committee on Government Reform of House of Representatives by House Resolution No. 5, One Hundred Sixth Congress, ","children":[{"tag":"date","attrib":{"date":"1999-01-06"},"text":"Jan. 6, 1999","children":[],"tail":". Committee on Government Reform of House of Representatives changed to Committee on Oversight and Government Reform of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, "},{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":". Committee on Oversight and Government Reform of House of Representatives changed to Committee on Oversight and Reform of House of Representatives by House Resolution No. 6, One Hundred Sixteenth Congress, "},{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":". Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, "},{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
