{"tag":"section","attrib":{"id":"idd1ea964c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3518"},"text":null,"children":[{"tag":"num","attrib":{"value":"3518"},"text":"§ 3518.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special annuity computation rules for certain employees’ service abroad","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1ea964d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3518/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers and employees to whom rules apply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any provision of chapter 83 of title 5, the annuity under subchapter III of such chapter of an officer or employee of the Central Intelligence Agency who retires on or after ","children":[{"tag":"date","attrib":{"date":"1989-10-01"},"text":"October 1, 1989","children":[],"tail":", is not designated under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2013"},"text":"section 2013 of this title","children":[],"tail":", and has served abroad as an officer or employee of the Agency on or after "},{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":", shall be computed as provided in subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ea964e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3518/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ea964f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3518/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The portion of the annuity relating to such service abroad that is actually performed at any time during the officer’s or employee’s first ten years of total service shall be computed at the rate and using the percent of average pay specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8339/a/3"},"text":"section 8339(a)(3) of title 5","children":[],"tail":" that is normally applicable only to so much of an employee’s total service as exceeds ten years."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ea9650-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3518/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The portion of the annuity relating to service abroad as described in subsection (a) but that is actually performed at any time after the officer’s or employee’s first ten years of total service shall be computed as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8339/a/3"},"text":"section 8339(a)(3) of title 5","children":[],"tail":"; but, in addition, the officer or employee shall be deemed for annuity computation purposes to have actually performed an equivalent period of service abroad during his or her first ten years of total service, and in calculating the portion of the officer’s or employee’s annuity for his or her first ten years of total service, the computation rate and percent of average pay specified in paragraph (1) shall also be applied to the period of such deemed or equivalent service abroad."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ea9651-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3518/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The portion of the annuity relating to other service by an officer or employee as described in subsection (a) shall be computed as provided in the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8339/a"},"text":"section 8339(a) of title 5","children":[],"tail":" that would otherwise be applicable to such service."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ea9652-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3518/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this subsection, the term “total service” has the meaning given such term under chapter 83 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ea9653-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3518/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annuities deemed annuities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8339"},"text":"section 8339 of title 5","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsections (f) through (m) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8339"},"text":"section 8339 of title 5","children":[],"tail":", an annuity computed under this section shall be deemed to be an annuity computed under subsections (a) and ("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":") "},{"tag":"ref","attrib":{"idref":"fn002106"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002106"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8339"},"text":"section 8339 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ea9654-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3518/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers and employees entitled to greater annuities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8339"},"text":"section 8339 of title 5","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of subsection (a) of this section shall not apply to an officer or employee of the Central Intelligence Agency who would otherwise be entitled to a greater annuity computed under an otherwise applicable subsection of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8339"},"text":"section 8339 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1ea9655-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-20/ch227/s18"},"text":"June 20, 1949, ch. 227, § 18","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/193/tIII/s305"},"text":"Pub. L. 101–193, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-30"},"text":"Nov. 30, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1704"},"text":"103 Stat. 1704","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s803/a/2"},"text":"Pub. L. 102–496, title VIII, § 803(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3252"},"text":"106 Stat. 3252","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1ea9656-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1ea9657-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1ea9658-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsection (","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8339"},"text":"section 8339 of title 5","children":[],"tail":", referred to in subsec. (c), was redesignated subsec. (p) of that section by "},{"tag":"ref","attrib":{"href":"/us/pl/102/378/s2/62"},"text":"Pub. L. 102–378, § 2(62)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1354"},"text":"106 Stat. 1354","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1ea9659-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s403r"},"text":"section 403r of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section. Some section numbers of this title referenced in amendment notes below reflect the classification of such sections prior to their editorial reclassification."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1ece04a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/496"},"text":"Pub. L. 102–496","children":[],"tail":" substituted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2013"},"text":"section 2013 of this title","children":[],"tail":" for reference in original to section 203 of the Central Intelligence Agency Retirement Act of 1964 for Certain Employees which was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403"},"text":"section 403 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1ece04b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd1ece04c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/496"},"text":"Pub. L. 102–496","children":[],"tail":" effective on first day of fourth month beginning after "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s805"},"text":"section 805 of Pub. L. 102–496","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
