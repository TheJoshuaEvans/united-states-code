{"tag":"section","attrib":{"id":"idd1675c39-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2362"},"text":null,"children":[{"tag":"num","attrib":{"value":"2362"},"text":"§ 2362.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers of allocations among cooperative threat reduction programs","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1675c3a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2362/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the various Cooperative Threat Reduction programs are being carried out at different rates in the various countries covered by such programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1675c3b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2362/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is necessary to authorize transfers of funding allocations among the various programs in order to maximize the effectiveness of United States efforts under such programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1675c3c-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXIV/s1452"},"text":"Pub. L. 104–201, div. A, title XIV, § 1452","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2730"},"text":"110 Stat. 2730","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1675c3d-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1675c3e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1675c3f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Specification of Cooperative Threat Reduction Programs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXV/s1501"},"text":"Pub. L. 104–201, div. A, title XV, § 1501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2731"},"text":"110 Stat. 2731","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tXIII/s1301/a/2"},"text":"Pub. L. 105–261, div. A, title XIII, § 1301(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2161"},"text":"112 Stat. 2161","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tXIII/s1303"},"text":"Pub. L. 110–181, div. A, title XIII, § 1303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/412"},"text":"122 Stat. 412","children":[],"tail":", specified Cooperative Threat Reduction programs for purposes of "},{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tXIII/s1351/5"},"text":"Pub. L. 113–291, div. A, title XIII, § 1351(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib"