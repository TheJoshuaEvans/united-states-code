{"tag":"section","attrib":{"id":"idd151ffcc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903"},"text":null,"children":[{"tag":"num","attrib":{"value":"1903"},"text":"§ 1903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Security Education Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd151ffcd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense shall establish a National Security Education Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd151ffce-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall be composed of the following individuals or the representatives of such individuals:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd151ffcf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense, who shall serve as the chairman of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd151ffd0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd151ffd1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd151ffd2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd151ffd3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd151ffd4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd151ffd5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd151ffd6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairperson of the National Endowment for the Humanities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd151ffd7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Six individuals appointed by the President, who shall be experts in the fields of international, language, area, and counterproliferation studies education and who may not be officers or employees of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd151ffd8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of appointees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each individual appointed to the Board pursuant to subsection (b)(7) shall be appointed for a period specified by the President at the time of the appointment, but not to exceed four years. Such individuals shall receive no compensation for service on the Board but may receive reimbursement for travel and other necessary expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd151ffd9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall perform the following functions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd151ffda-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Develop criteria for awarding scholarships, fellowships, and grants under this chapter, including an order of priority in such awards that favors individuals expressing an interest in national security issues or pursuing a career in a national security position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd151ffdb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provide for wide dissemination of information regarding the activities assisted under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd151ffdc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establish qualifications for students desiring scholarships or fellowships, and institutions of higher education desiring grants, under this chapter, including, in the case of students desiring a scholarship or fellowship, a requirement that the student have a demonstrated commitment to the study of the discipline for which the scholarship or fellowship is to be awarded.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd151ffdd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" After taking into account the annual analyses of trends in language, international, area, and counterproliferation studies under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1906/b/1"},"text":"section 1906(b)(1) of this title","children":[],"tail":", make recommendations to the Secretary regarding—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd151ffde-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which countries are not emphasized in other United States study abroad programs, such as countries in which few United States students are studying and countries which are of importance to the national security interests of the United States, and are, therefore, critical countries for the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1902/a/1/A"},"text":"section 1902(a)(1)(A) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd151ffdf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which areas within the disciplines described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1902/a/1/B"},"text":"section 1902(a)(1)(B) of this title","children":[],"tail":" relating to the national security interests of the United States are areas of study in which United States students are deficient in learning and are, therefore, critical areas within those disciplines for the purposes of that section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd151ffe0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which areas within the disciplines described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1902/a/1/C"},"text":"section 1902(a)(1)(C) of this title","children":[],"tail":" are areas in which United States students, educators, and Government employees are deficient in learning and in which insubstantial numbers of United States institutions of higher education provide training and are, therefore, critical areas within those disciplines for the purposes of that section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd151ffe1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/d/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how students desiring scholarships or fellowships can be encouraged to work for an agency or office of the Federal Government involved in national security affairs or national security policy upon completion of their education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd151ffe2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/d/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which foreign languages are critical to the national security interests of the United States for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1902/a/1/D"},"text":"section 1902(a)(1)(D) of this title","children":[],"tail":" (relating to grants for the National Flagship Language Initiative) and "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1902/a/1/E"},"text":"section 1902(a)(1)(E) of this title","children":[],"tail":" (relating to the scholarship program for advanced English language studies by heritage community citizens)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd151ffe3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Encourage applications for fellowships under this chapter from graduate students having an educational background in any academic discipline, particularly in the areas of science or technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd151ffe4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provide the Secretary biennially with a list of scholarship recipients and fellowship recipients, including an assessment of their foreign area and language skills, who are available to work in a national security position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd151ffe5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 30 days after a scholarship or fellowship recipient completes the study or education for which assistance was provided under the program, provide the Secretary with a report fully describing the foreign area and language skills obtained by the recipient as a result of the assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd151ffe6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Review the administration of the program required under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd151ffe7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To the extent provided by the Secretary of Defense, oversee and coordinate the activities of the National Language Service Corps under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1913"},"text":"section 1913 of this title","children":[],"tail":", including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd151ffe8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/d/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing on a periodic basis whether the Corps is addressing the needs identified by the heads of departments and agencies of the Federal Government for personnel with skills in various foreign languages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd151ffe9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/d/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommending plans for the Corps to address foreign language shortfalls and requirements of the departments and agencies of the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd151ffea-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/d/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommending effective ways to increase public awareness of the need for foreign languages skills and career paths in the Federal Government that use those skills; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd151ffeb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1903/d/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" overseeing the Corps efforts to work with Executive agencies and State and local governments to respond to interagency plans and agreements to address overall foreign language shortfalls and to utilize personnel to address the various types of crises that warrant foreign language skills.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd151ffec-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/183/tVIII/s803"},"text":"Pub. L. 102–183, title VIII, § 803","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-04"},"text":"Dec. 4, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1273"},"text":"105 Stat. 1273","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tIV/s404/d"},"text":"Pub. L. 102–496, title IV, § 404(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3186"},"text":"106 Stat. 3186","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tX/s1078/e"},"text":"Pub. L. 104–201, div. A, title X, § 1078(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2666"},"text":"110 Stat. 2666","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/272/tIII/s305/a/3"},"text":"Pub. L. 105–272, title III, § 305(a)(3)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1998-10-20"},"text":"Oct. 20, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2401"},"text":"112 Stat. 2401","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG/tXIII/s1335/g"},"text":"Pub. L. 105–277, div. G, title XIII, § 1335(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-788"},"text":"112 Stat. 2681–788","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/306/tIII/s333/a/4"},"text":"Pub. L. 107–306, title III, § 333(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2396"},"text":"116 Stat. 2396","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/487/tVI/s603/a/3"},"text":"Pub. L. 108–487, title VI, § 603(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3954"},"text":"118 Stat. 3954","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tX/s1087"},"text":"Pub. L. 112–81, div. A, title X, § 1087","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1603"},"text":"125 Stat. 1603","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/166/s2/c/2"},"text":"Pub. L. 112–166, § 2(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1284"},"text":"126 Stat. 1284","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tIX/s954/b"},"text":"Pub. L. 112–239, div. A, title IX, § 954(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1896"},"text":"126 Stat. 1896","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tIX/s7901/c/2"},"text":"Pub. L. 118–31, div. G, title IX, § 7901(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1106"},"text":"137 Stat. 1106","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd151ffed-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd151ffee-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd151ffef-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (d)(9)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" substituted “local governments” for “Local governments”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (b)(5) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s954/b/1"},"text":"Pub. L. 112–239, § 954(b)(1)","children":[],"tail":", added pars. (5) to (7), redesignated former pars. (6) and (7) as (8) and (9), respectively, and struck out former par. (5) which read as follows: “The Director of Central Intelligence.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s954/b/2"},"text":"Pub. L. 112–239, § 954(b)(2)","children":[],"tail":", added par. (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/166"},"text":"Pub. L. 112–166","children":[],"tail":", which directed striking the phrase “by and with the advice and consent of the Senate,”, could not be executed because the phrase did not appear after execution of amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/s1087/a"},"text":"Pub. L. 112–81, § 1087(a)","children":[],"tail":". See 2011 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s1087/a"},"text":"Pub. L. 112–81, § 1087(a)","children":[],"tail":", struck out “by and with the advice and consent of the Senate,” after “President,”."}],"tail":"\n"},{"tag":"p","