{"tag":"section","attrib":{"id":"idd107fe6e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1432"},"text":null,"children":[{"tag":"num","attrib":{"value":"1432"},"text":"§ 1432.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter shall be construed to constitute authorization hereunder for—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd107fe6f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1432/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of the cost-plus-a-percentage-of-cost system of contracting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd107fe70-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1432/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any contract in violation of existing law relating to limitation of profits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd107fe71-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1432/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the negotiation of purchases of or contracts for property or services required by law to be procured by formal advertising and competitive bidding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd107fe72-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1432/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the waiver of any bid, payment, performance, or other bond required by law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd107fe73-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1432/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amendment of a contract negotiated under section 2304(a)(15) ","children":[{"tag":"ref","attrib":{"idref":"fn002012"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002012"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 10 or under section 252(c)(13) "},{"tag":"ref","attrib":{"idref":"fn002012"},"text":"1","children":[],"tail":" of title 41, to increase the contract price to an amount higher than the lowest rejected bid of any responsible bidder; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd107fe74-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1432/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the formalization of an informal commitment, unless it is found that at the time the commitment was made it was impracticable to use normal procurement procedures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd107fe75-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/804/s2"},"text":"Pub. L. 85–804, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-28"},"text":"Aug. 28, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/972"},"text":"72 Stat. 972","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd107fe76-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd107fe77-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","at