{"tag":"section","attrib":{"id":"idd1a094ea-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3063"},"text":null,"children":[{"tag":"num","attrib":{"value":"3063"},"text":"§ 3063.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of senior officials for biotechnology","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1a094eb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3063/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of each element of the intelligence community specified in subsection (b) shall designate a senior official of such element to serve as the official responsible for coordinating the activities of such element relating to biotechnology, as those activities are determined and directed by the head of such element.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1a094ec-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3063/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The elements of the intelligence community specified in this subsection are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1a094ed-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3063/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of the Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a094ee-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3063/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Central Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a094ef-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3063/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Security Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a094f0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3063/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Defense Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a094f1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3063/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The intelligence elements of the Federal Bureau of Investigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a094f2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3063/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Intelligence and Counterintelligence of the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1a094f3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3063/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 15 days after designating a senior official under this section, the head of the element of the intelligence community designating such official shall submit notice of the designation to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1a094f4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3063/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional intelligence committees and the Committees on Appropriations of the Senate and the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a094f5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3063/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a designation relating to the Federal Bureau of Investigation, the Committees on the Judiciary of the Senate and the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1a094f6-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title I, § 123, as added "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dF/tLXVI/s6611/a"},"text":"Pub. L. 119–60, div. F, title LXVI, § 6611(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1636"},"text":"139 Stat. 1636","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1a094f7-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1a094f8-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1a094f9-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Initial Designation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dF/tLXVI/s6611/b"},"text":"Pub. L. 119–60, div. F, title LXVI, § 6611(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1637"},"text":"139 Stat. 1637","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dF/tLXVI/s6611/b"},"text":"“The head of each element of the intelligence community required to designate a senior official of such element under section 123 of the National Security Act of 1947 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3063"},"text":"50 U.S.C. 3063","children":[],"tail":"], as added by subsection (a) of this section, shall designate such senior official not later than 90 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “intelligence community” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s6611/b"},"text":"section 6611(b) of Pub. L. 119–60","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s6002"},"text":"section 6002 of Pub. L. 119–60","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
