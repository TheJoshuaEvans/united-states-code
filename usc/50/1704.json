{"tag":"section","attrib":{"id":"idd135505b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1704"},"text":null,"children":[{"tag":"num","attrib":{"value":"1704"},"text":"§ 1704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to issue regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President may issue such regulations, including regulations prescribing definitions, as may be necessary for the exercise of the authorities granted by this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd135505c-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/223/tII/s205"},"text":"Pub. L. 95–223, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-28"},"text":"Dec. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1628"},"text":"91 Stat. 1628","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
