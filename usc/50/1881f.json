{"tag":"section","attrib":{"id":"idd14d1dcf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1881f"},"text":"§ 1881f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional oversight","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd14d1dd0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Semiannual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less frequently than once every 6 months, the Attorney General shall fully inform, in a manner consistent with national security, the congressional intelligence committees and the Committees on the Judiciary of the Senate and the House of Representatives, consistent with the Rules of the House of Representatives, the Standing Rules of the Senate, and Senate Resolution 400 of the 94th Congress or any successor Senate resolution, concerning the implementation of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd14d1dd1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd14d1dd2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1881a"},"text":"section 1881a of this title"