{"tag":"section","attrib":{"id":"idd175b4a9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2901"},"text":null,"children":[{"tag":"num","attrib":{"value":"2901"},"text":"§ 2901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The 9/11 Commission has made the following recommendations:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd175b4aa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2901/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strengthen “counter-proliferation” efforts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States should work with the international community to develop laws and an international legal regime with universal jurisdiction to enable any state in the world to capture, interdict, and prosecute smugglers of nuclear material.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd175b4ab-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2901/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expand the Proliferation Security Initiative","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the Proliferation Security Initiative, the United States should—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd175b4ac-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2901/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use intelligence and planning resources of the North Atlantic Treaty Organization (NATO) alliance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd175b4ad-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2901/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make participation open to non-NATO countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd175b4ae-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2901/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage Russia and the People’s Republic of China to participate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd175b4af-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2901/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support the Cooperative Threat Reduction program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States should expand, improve, increase resources for, and otherwise fully support the Cooperative Threat Reduction program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd175b4b0-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXVIII/s1801"},"text":"Pub. L. 110–53, title XVIII, § 1801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/491"},"text":"121 Stat. 491","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
