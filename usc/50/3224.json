{"tag":"section","attrib":{"id":"idd1c20038-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224"},"text":null,"children":[{"tag":"num","attrib":{"value":"3224"},"text":"§ 3224.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intelligence officer training program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1c20039-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c2003a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of National Intelligence may carry out grant programs in accordance with subsections (b) and (c) to enhance the recruitment and retention of an ethnically and culturally diverse intelligence community workforce with capabilities critical to the national security interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c2003b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out paragraph (1), the Director shall identify the skills necessary to meet current or emergent needs of the intelligence community and the educational disciplines that will provide individuals with such skills.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c2003c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institutional grant program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c2003d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director may provide grants to institutions of higher education to support the establishment or continued development of programs of study in educational disciplines identified under subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c2003e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A grant provided under paragraph (1) may, with respect to the educational disciplines identified under subsection (a)(2), be used for the following purposes:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c2003f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Curriculum or program development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c20040-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Faculty development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c20041-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Laboratory equipment or improvements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c20042-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Faculty research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c20043-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program for certain minority-serving colleges and universities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c20044-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director may provide grants to historically black colleges and universities, Predominantly Black Institutions, Hispanic-serving institutions, and Asian American and Native American Pacific Islander-serving institutions to provide programs of study in educational disciplines identified under subsection (a)(2) or described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c20045-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A grant provided under paragraph (1) may be used to provide programs of study in the following educational disciplines:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c20046-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Intermediate and advanced foreign languages deemed in the immediate interest of the intelligence community, including Farsi, Pashto, Middle Eastern, African, and South Asian dialects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c20047-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Study abroad programs and cultural immersion programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c20048-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An institution of higher education seeking a grant under this section shall submit an application describing the proposed use of the grant at such time and in such manner as the Director may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c20049-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An institution of higher education that receives a grant under this section shall submit to the Director regular reports regarding the use of such grant, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c2004a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the benefits to students who participate in the course of study funded by such grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c2004b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the results and accomplishments related to such course of study; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c2004c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information that the Director may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c2004d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall prescribe such regulations as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c2004e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c2004f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Director” means the Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c20050-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Historically black college and university","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “historically black college and university” has the meaning given the term “part B institution” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1061"},"text":"section 1061 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c20051-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “institution of higher education” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c20052-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Predominantly black institution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Predominantly Black Institution” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059e"},"text":"section 1059e of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c20053-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hispanic-serving institution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Hispanic-serving institution” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1101a/a/5"},"text":"section 1101a(a)(5) of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c20054-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/g/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Asian american and native american pacific islander-serving institution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Asian American and Native American Pacific Islander-serving institution” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059g/b/2"},"text":"section 1059g(b)(2) of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c20055-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/g/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Study abroad program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “study abroad program” means a program of study that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c20056-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/g/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" takes place outside the geographical boundaries of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c20057-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/g/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" focuses on areas of the world that are critical to the national security interests of the United States and are generally underrepresented in study abroad programs at institutions of higher education, including Africa, Asia, Central and Eastern Europe, Eurasia, Latin America, and the Middle East; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c20058-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3224/g/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a credit or noncredit program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1c20059-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title X, § 1024, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/tIII/s313/a"},"text":"Pub. L. 111–259, title III, § 313(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2665"},"text":"124 Stat. 2665","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/18/tIII/s304"},"text":"Pub. L. 112–18, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-06-08"},"text":"June 8, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/226"},"text":"125 Stat. 226","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/293/tIII/s306"},"text":"Pub. L. 113–293, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3997"},"text":"128 Stat. 3997","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dM/tVII/s712"},"text":"Pub. L. 114–113, div. M, title VII, § 712","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2934"},"text":"129 Stat. 2934","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dF/tLXVIII/s6824/a/7"},"text":"Pub. L. 117–263, div. F, title LXVIII, § 6824(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3615"},"text":"136 Stat. 3615","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1c2005a-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1c2005b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1c2005c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s441p"},"text":"section 441p of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1c2005d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (g)(7)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “place” for “places”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s712/1/B"},"text":"Pub. L. 114–113, § 712(1)(B)","children":[],"tail":", substituted “certain minority-serving” for “historically black” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s712/1/A"},"text":"Pub. L. 114–113, § 712(1)(A)","children":[],"tail":", substituted “historically black colleges and universities, Predominantly Black Institutions, Hispanic-serving institutions, and Asian American and Native American Pacific Islander-serving institutions” for “historically black colleges and universities and Predominantly Black Institutions”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(5) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s712/2"},"text":"Pub. L. 114–113, § 712(2)","children":[],"tail":", added pars. (5) and (6) and redesignated former par. (5) as (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/293/s306/1"},"text":"Pub. L. 113–293, § 306(1)","children":[],"tail":", inserted “and Predominantly Black Institutions” after “universities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/293/s306/2"},"text":"Pub. L. 113–293, § 306(2)","children":[],"tail":", added par. (4) and redesignated former par. (4) as (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/18/s304/1"},"text":"Pub. L. 112–18, § 304(1)","children":[],"tail":", substituted “subsections (b) and (c)” for “subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/18/s304/2"},"text":"Pub. L. 112–18, § 304(2)","children":[],"tail":", (3), added subsec. (c) and redesignated former subsecs. (c) to (e) as (d) to (f), respectively. Former subsec. (f) redesignated (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/18/s304/2"},"text":"Pub. L. 112–18, § 304(2)","children":[],"tail":", redesignated subsec. (f) as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/18/s304/4"},"text":"Pub. L. 112–18, § 304(4)","children":[],"tail":", added pars. (2) and (4) and redesignated former par. (2) as (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1c2005e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1c2005f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings Regarding Improvement of Equality of Employment Opportunities in the Intelligence Community","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177/tIII/s319"},"text":"Pub. L. 108–177, title III, § 319","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-13"},"text":"Dec. 13, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2614"},"text":"117 Stat. 2614","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI/s1071/g/3/A/iv"},"text":"Pub. L. 108–458, title I, § 1071(g)(3)(A)(iv)","children":[],"tail":", (B), "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3692"},"text":"118 Stat. 3692","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/tIII/s313/b/1/A"},"text":"Pub. L. 111–259, title III, § 313(b)(1)(A)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2666"},"text":"124 Stat. 2666","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/259/tIII/s313/b/1/A"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress makes the following findings:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is the recommendation of the Joint Inquiry of the Senate Select Committee on Intelligence and the House Permanent Select Committee on Intelligence into Intelligence Community Activities Before and After the Terrorist Attacks of ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":", that the Intelligence Community should enhance recruitment of a more ethnically and culturally diverse workforce and devise a strategy to capitalize upon the unique cultural and linguistic capabilities of first generation Americans."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Intelligence Community could greatly benefit from an increased number of employees who are proficient in foreign languages and knowledgeable of world cultures, especially in foreign languages that are critical to the national security interests of the United States. Particular emphasis should be given to the recruitment of United States citizens whose linguistic capabilities are acutely required for the improvement of the overall intelligence collection and analysis effort of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Intelligence Community has a significantly lower percentage of women and minorities than the total workforce of the Federal government and the total civilian labor force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Women and minorities continue to be under-represented in senior grade levels, and in core mission areas, of the intelligence community.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
