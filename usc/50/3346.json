{"tag":"section","attrib":{"id":"idd1d51305-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3346"},"text":null,"children":[{"tag":"num","attrib":{"value":"3346"},"text":"§ 3346.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compilation and organization of previously declassified records","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1d51306-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3346/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":", (b) Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d51307-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3346/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compilation and organization of records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Department of Defense may not be required, when conducting a special search, to compile or organize records that have already been declassified and placed into the public domain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d51308-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3346/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special searches","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of this section, the term “special search” means the response of the Department of Defense to any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d51309-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3346/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A statutory requirement to conduct a declassification review on a specified set of agency records.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d5130a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3346/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Executive order to conduct a declassification review on a specified set of agency records.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d5130b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3346/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An order from the President or an official with delegated authority from the President to conduct a declassification review on a specified set of agency records.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1d5130c-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1075], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–280.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1d5130d-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1d5130e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"top