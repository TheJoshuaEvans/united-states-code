{"tag":"section","attrib":{"id":"idd1d783a8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355"},"text":null,"children":[{"tag":"num","attrib":{"value":"3355"},"text":"§ 3355.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d783a9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is in the national interest to establish an effective, coordinated, and cost-effective means by which records on specific subjects of extraordinary public interest that do not undermine the national security interests of the United States may be collected, retained, reviewed, and disseminated to Congress, policymakers in the executive branch, and the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d783aa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3355/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ensuring, through such measures, public access to information that does not require continued protection to maintain the national security interests of the United States is a key to striking the balance between secrecy essential to national security and the openness that is central to the proper functioning of the political institutions of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1d783ab-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/567/tVII/s702"},"text":"Pub. L. 106–567, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2856"},"text":"114 Stat. 2856","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1d783ac-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1d783ad-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1d783ae-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out in a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"text":"section 3161 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1d783af-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd1d783b0-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/567/tVII/s710"},"text":"Pub. L. 106–567, title VII, § 710","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2864"},"text":"114 Stat. 2864","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI/s1102/f"},"text":"Pub. L. 108–458, title I, § 1102(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3700"},"text":"118 Stat. 3700","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tVI/s602/4"},"text":"Pub. L. 110–53, title VI, § 602(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/336"},"text":"121 Stat. 336","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/235/s2/c"},"text":"Pub. L. 112–235, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-28"},"text":"Dec. 28, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1626"},"text":"126 Stat. 1626","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/126/tIII/s311"},"text":"Pub. L. 113–126, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-07"},"text":"July 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1399"},"text":"128 Stat. 1399","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLXVII/s6741/b"},"text":"Pub. L. 116–92, div. E, title LXVII, § 6741(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2239"},"text":"133 Stat. 2239","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dE/tLXVII/s6741/b"},"text":"“This title [enacting this subchapter] shall take effect on the date that is 120 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idd1d783b1-47c4-11f1-8bcf-c89722bddd2e"},"text":nu