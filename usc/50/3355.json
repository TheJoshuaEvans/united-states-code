":null},{"tag":"content","attrib":{},"text":" the Public Interest Declassification Board shall be deemed to not have terminated for purposes of the appointment of members to the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 703(h) of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3355a/h"},"text":"50 U.S.C. 3355a(h)","children":[],"tail":"] shall not apply with respect to the period beginning on "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":", and ending on the day before the date of the enactment of this Act; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the length of the terms of the members serving on the Board as of ","children":[{"tag":"date","attrib":{"date":"2018-12-30"},"text":"December 30, 2018","children":[],"tail":", shall be calculated by not counting the period specified in paragraph (2).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[Prior to being struck out by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLXVII/s6741/b/1"},"text":"Pub. L. 116–92, div. E, title LXVII, § 6741(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2239"},"text":"133 Stat. 2239","children":[],"tail":", section 710(b) of the Public Interest Declassification Act of 2000 ("},{"tag":"ref","attrib":{"href":"/us/pl/106/567/tVII"},"text":"Pub. L. 106–567, title VII","children":[],"tail":"), referred to in the introductory provisions of "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/s6741/c"},"text":