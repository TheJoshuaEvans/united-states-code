{"tag":"section","attrib":{"id":"idd1ac7b73-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3112"},"text":null,"children":[{"tag":"num","attrib":{"value":"3112"},"text":"§ 3112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports on the domestic activities of the intelligence community","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1ac7b74-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than January 31 of each year, the Director of National Intelligence shall submit to the congressional intelligence committees a report—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ac7b75-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3112/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying all domestic activities undertaken by each element of the intelligence community during the prior fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ac7b76-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3112/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each activity identified under paragraph (1), a statement of the legal authority authorizing such activity to be undertaken.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ac7b77-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report under subsection (a) shall be submitted in unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1ac7b78-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title V, § 513, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dX/tV/s505/b"},"text":"Pub. L. 117–103, div. X, title V, § 505(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/989"},"text":"136 Stat. 989","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1ac7b79-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1ac7b7a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1ac7b7b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"First Report; Appropriate Congressional Committees Defined","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dX/tV/s505/c"},"text":"Pub. L. 117–103, div. X, title V, § 505(c)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/989"},"text":"136 Stat. 989","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/103/dX/tV/s505/c"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"First Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":"], the Director of National Intelligence shall submit to the appropriate congressional committees the first report required under section 513 of the National Security Act of 1947 ["},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3112"},"text":"50 U.S.C. 3112","children":[],"tail":"], as added by subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate Congressional Committees Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term ‘appropriate congressional committees’ means—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional intelligence committees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Subcommittees on Commerce, Justice, Science, and Related Agencies and the Subcommittees on Homeland Security of the Committees on Appropriations of the House of Representatives and the Senate.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “congressional intelligence committees” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dX/s505/d"},"text":"section 505(d) of div. X of Pub. L. 117–103","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dX/s2"},"text":"section 2 of div. X of Pub. L. 117–103","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
