{"tag":"section","attrib":{"id":"idd162a1f6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2311"},"text":null,"children":[{"tag":"num","attrib":{"value":"2311"},"text":"§ 2311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Response to threats of terrorist use of weapons of mass destruction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd162a1f7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2311/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced response capability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In light of the potential for terrorist use of weapons of mass destruction against the United States, the President shall take immediate action—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd162a1f8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2311/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance the capability of the Federal Government to prevent and respond to terrorist incidents involving weapons of mass destruction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd162a1f9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2311/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide enhanced support to improve the capabilities of State and local emergency response agencies to prevent and respond to such incidents at both the national and the local level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd162a1fa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2311/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1997-01-31"},"text":"January 31, 1997","children":[],"tail":", the President shall transmit to Congress a report containing—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd162a1fb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2311/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the capabilities of the Federal Government to prevent and respond to terrorist incidents involving weapons of mass destruction and to support State and local prevention and response efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd162a1fc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2311/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements for improvements in those capabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd162a1fd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2311/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the measures that should be taken to achieve such improvements, including additional resources and legislative authorities that would be required.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd162a1fe-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXIV/s1411"},"text":"Pub. L. 104–201, div. A, title XIV, § 1411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2717"},"text":"110 Stat. 2717","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
