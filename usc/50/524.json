{"tag":"section","attrib":{"id":"idd0fe8950-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s524"},"text":null,"children":[{"tag":"num","attrib":{"value":"524"},"text":"§ 524.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated, out of any moneys in the Treasury not otherwise appropriated, to remain available until expended when so specified in the appropriation act concerned, (a) not to exceed $157,500,000 for the establishment and for initial construction, installation, and equipment of the Air Engineering Development Center authorized in this subchapter, including expenses for necessary surveys and acquisition of land, and (b) such sums as may be necessary to carry out the other purposes of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd0fe8951-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-27/ch766"},"text":"Oct. 27, 1949, ch. 766","children":[],"tail":", title II, § 204, "},{"tag":"ref","attrib":{"href":"/us/stat/63/937"},"text":"63 Stat. 937","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-21/ch969"},"text":"Sept. 21, 1950, ch. 969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/895"},"text":"64 Stat. 895","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd0fe8952-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd0fe8953-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd0fe8954-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1950—Act ","children":[{"tag":"date","attrib":{"date":"1950-09-21"},"text":"Sept. 21, 1950","children":[],"tail":", substituted “$157,500,000” for “$100,000,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
