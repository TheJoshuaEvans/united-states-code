{"tag":"section","attrib":{"id":"idd145f174-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1864"},"text":null,"children":[{"tag":"num","attrib":{"value":"1864"},"text":"§ 1864.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of changes to retention of call detail record policies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd145f175-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1864/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to retain","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd145f176-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1864/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 15 days after learning that an electronic communication service provider that generates call detail records in the ordinary course of business has changed the policy of the provider on the retention of such call detail records to result in a retention period of less than 18 months, the Director of National Intelligence shall notify, in writing, the congressional intelligence committees of such change.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd145f177-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1864/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"2015-12-18"},"text":"December 18, 2015","children":[],"tail":", the Director shall submit to the congressional intelligence committees a report identifying each electronic communication service provider that has, as of the date of the report, a policy to retain call detail records for a period of 18 months or less."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd145f178-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1864/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd145f179-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1864/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Call detail record","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “call detail record” has the meaning given that term in section 1861(k) ","children":[{"tag":"ref","attrib":{"idref":"fn002035"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002035"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd145f17a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1864/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic communication service provider","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “electronic communication service provider” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1881/b/4"},"text":"section 1881(b)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd145f17b-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dM/tIII/s307"},"text":"Pub. L. 114–113, div. M, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2916"},"text":"129 Stat. 2916","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd145f17c-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd145f17d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd145f17e-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1861/k"},"text":"Section 1861(k) of this title","children":[],"tail":", referred to in subsec. (b)(1), means "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1861/k"},"text":"section 1861(k) of this title","children":[],"tail":" prior to the amendment of section 1861 by "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/tI/s102/b"},"text":"Pub. L. 109–177, title I, § 102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/195"},"text":"120 Stat. 195","children":[],"tail":", set out as an Effective Date of 2006 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1805"},"text":"section 1805 of this title","children":[],"tail":", which amended "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1861"},"text":"section 1861 of this title","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2020-03-15"},"text":"Mar. 15, 2020","children":[],"tail":", so that such section read as it read on "},{"tag":"date","attrib":{"date":"2001-10-25"},"text":"Oct. 25, 2001","children":[],"tail":", with certain exceptions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd145f17f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Intelligence Authorization Act for Fiscal Year 2016, and also as part of the Consolidated Appropriations Act, 2016, and not as part of the Foreign Intelligence Surveillance Act of 1978 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd145f180-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd145f181-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “congressional intelligence committees” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dM/s2"},"text":"section 2 of div. M of Pub. L. 114–113","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
