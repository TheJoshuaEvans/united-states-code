{"tag":"section","attrib":{"id":"idd24057ea-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589"},"text":null,"children":[{"tag":"num","attrib":{"value":"4589"},"text":"§ 4589.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd24057eb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4584/d"},"text":"section 4584(d) of this title","children":[],"tail":", the term “appropriate congressional committees” means—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd24057ec-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Financial Services, the Committee on Foreign Affairs, and the Committee on Appropriations of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd24057ed-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Banking, Housing, and Urban Affairs and the Committee on Appropriations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd24057ee-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Country of concern","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “country of concern” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd24057ef-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the People’s Republic of China, including the Hong Kong and Macau Special Administrative Regions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd24057f0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Republic of Cuba;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd24057f1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Islamic Republic of Iran;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd24057f2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Democratic People’s Republic of Korea;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd24057f3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Russian Federation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd24057f4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bolivarian Republic of Venezuela under the regime of Nicolas Maduro Moros.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd24057f5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered foreign person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to regulations prescribed in accordance with this subchapter, the term “covered foreign person” means a foreign person that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd24057f6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is incorporated in, has a principal place of business in, or is organized under the laws of a country of concern;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd24057f7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a member of the Central Committee of the Chinese Communist Party or is a member of the political leadership of a country of concern;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd24057f8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is subject to the direction or control of a country of concern, as defined by regulation, an entity described in subparagraph (A) or (B), or the state or the government of a country of concern (including any political subdivision, agency, or instrumentality thereof); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd24057f9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is owned in the aggregate, directly or indirectly, 50 percent or more by a country of concern, an entity described in subparagraph (A) or (B), or the state or the government of a country of concern (including any political subdivision, agency, or instrumentality thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd24057fa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered national security transaction","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd24057fb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to such regulations as may be issued in accordance with this subchapter, the term “covered national security transaction” means a United States person’s direct or indirect—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd24057fc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquisition of an equity interest or contingent equity interest in a covered foreign person that the United States person knows at the time of the acquisition is a covered foreign person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd24057fd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provision of a loan or similar debt financing arrangement to a covered foreign person that the United States person knows at the time of the provision is a covered foreign person, where such debt financing affords or will afford the United States person an interest in profits of the covered foreign person, the right to appoint members of the board of directors (or equivalent) of the covered foreign person, or other comparable financial or governance rights characteristic of an equity investment but not typical of a loan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd24057fe-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entrance by such United States person into a joint venture, wherever located, that is formed with a person of a country of concern, and that the subject United States person knows at the time of entrance into the joint venture that the joint venture will engage, or plans to engage, in a prohibited technology or notifiable technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd24057ff-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conversion of a contingent equity interest (or interest equivalent to a contingent equity interest) or conversion of debt to an equity interest in a covered foreign person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2405800-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" acquisition, leasing, or other development of operations, land, property, or other assets in a country of concern that the United States person knows at the time of such acquisition, leasing, or other development will result in, or that the United States person plans to result in—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idd2405801-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/A/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of a covered foreign person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd2405802-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/A/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the engagement of a person of a country of concern in a prohibited technology or notifiable technology;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2405803-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly directing prohibited transactions or notifiable transactions by foreign persons that the United States person has knowledge at the time of the transaction would constitute an activity described in clause (i), (ii), (iii), (iv), or (v), if engaged in by a United States person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2405804-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquisition of a limited partner or equivalent interest in a venture capital fund, private equity fund, fund of funds, or other pooled investment fund (in each case where the fund is not a United States person) that the United States person has knowledge at the time of the acquisition likely will invest in a person of a country of concern that is in one of the notifiable technology or prohibited technology sectors, and such fund undertakes a transaction that would be a covered national security transaction if undertaken by a United States person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2405805-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other transaction identified by the Secretary, in consultation with the appropriate congressional committees and subject to public notice and comment in accordance with subchapter II of chapter 5 and chapter 7 of title 5, and not subject to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4559"},"text":"section 4559 of this title","children":[],"tail":", that is contributing to the military, intelligence, surveillance, or cyber-enabled capabilities of a country of concern."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2405806-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions and clarifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to regulations prescribed in accordance with this subchapter, the term “covered national security transaction” does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd2405807-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any transaction the value of which the Secretary determines is de minimis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2405808-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any category of transactions that the Secretary determines is in the national interest of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2405809-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an investment—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idd240580a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a security (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a"},"text":"section 78c(a) of title 15","children":[],"tail":") that is traded on an exchange or the over-the-counter market in any jurisdiction;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd240580b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a security issued by an investment company (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–3"},"text":"section 80a–3 of title 15","children":[],"tail":") that is registered with the Securities and Exchange Commission, or, if the Secretary chooses to include it as an exception from a covered national security transaction, in a security issued by a non-United States investment company that is registered with a foreign regulator with comparable oversight standards and regulatory jurisdiction to the Securities and Exchange Commission as determined by the Secretary of Treasury;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd240580c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/B/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" made as a limited partner or equivalent in a venture capital fund, private equity fund, fund of funds, or other pooled investment fund (other than as described in subclause (II)) where—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idd240580d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/B/iii/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the limited partner or equivalent’s committed capital is not more than a de minimis amount, as determined by the Secretary, aggregated across any investment and co-investment vehicles of the fund; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idd240580e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/B/iii/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the limited partner or equivalent has secured a binding contractual assurance that its capital in the fund will not be used to engage in a transaction that would be a covered national security transaction if engaged in by a United States person; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd240580f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/B/iii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a derivative of a security described under subclause (I), (II), or (III);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2405810-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any ancillary transaction undertaken by a financial institution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5312"},"text":"section 5312 of title 31","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2405811-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition by a United States person of the equity or other interest owned or held by a covered foreign person in an entity or assets located outside of a country of concern in which the United States person is acquiring the totality of the interest in the entity held by the covered foreign person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2405812-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an intracompany transfer of funds, as defined in regulations prescribed in accordance with this subchapter, from a United States parent company to a subsidiary located in a country of concern or a transaction that, but for this clause, would be a covered national security transaction between a United States person and its controlled foreign person that supports operations that are not covered national security transactions or that maintains covered national security transactions that the controlled foreign person was engaged in prior to the effective date of the regulations implementing this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2405813-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a transaction secondary to a covered national security transaction, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idd2405814-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/B/vii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contractual arrangements (not including contractual arrangements for technology transfer or technical knowledge transfer) or the procurement of material inputs for any covered national security transaction (such as raw materials);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd2405815-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/B/vii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bank lending;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd2405816-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/B/vii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the processing, clearing, or sending of payments by a bank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd2405817-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/B/vii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" underwriting services including, but not limited to, the temporary acquisition of an equity interest for the sole purpose of facilitating underwriting services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd2405818-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/B/vii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" debt rating services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd2405819-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/B/vii/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prime brokerage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd240581a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/B/vii/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" global custody;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd240581b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/B/vii/VIII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VIII"},"text":"(VIII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equity research or analysis; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd240581c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/B/vii/IX"},"text":null,"children":[{"tag":"num","attrib":{"value":"IX"},"text":"(IX)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other similar services;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd240581d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any ordinary or administrative business transaction as may be defined in such regulations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd240581e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any transaction completed before ","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"December 18, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd240581f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ancillary transaction defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this paragraph, the term “ancillary transaction” means, subject to regulations prescribed by the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd2405820-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the processing, settling, clearing, or sending of payments and cash transactions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2405821-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" underwriting services, including the temporary acquisition of an equity interest for the sole purpose of facilitating underwriting services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2405822-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" credit rating services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2405823-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/4/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other services ordinarily incident to and part of the provision of financial services, such as opening deposit accounts, direct custody services, foreign exchange services, remittances services, and safe deposit services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2405824-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “foreign person” has the meaning given that term in regulations prescribed in accordance with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2405825-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Knowledge; know","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The terms “knowledge” or “know” mean—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2405826-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actual knowledge that a fact or circumstance exists or is substantially certain to occur;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2405827-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an awareness of a high probability of a fact or circumstance’s existence or future occurrence; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2405828-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reason to know of a fact or circumstance’s existence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2405829-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notifiable technology","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd240582a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the regulations prescribed in accordance with this subchapter, the term “notifiable technology” means a technology within the following areas not already captured by the technical thresholds specified by any regulations issued in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4581"},"text":"section 4581 of this title","children":[],"tail":":"}],"tail":null},{"tag":"clause","attrib":{"id":"idd240582b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Semiconductor technology and microelectronics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd240582c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Artificial intelligence systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd240582d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/7/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Quantum information technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd240582e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/7/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" High-performance computing and supercomputing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd240582f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/7/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hypersonic systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2405830-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the appropriate congressional committees and subject to notice and comment in accordance with subchapter II of chapter 5 and chapter 7 of title 5, and not subject to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4559"},"text":"section 4559 of this title","children":[],"tail":", may prescribe regulations in accordance with this subchapter to—"}],"tail":null},{"tag":"clause","attrib":{"id":"idd2405831-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" define the technical parameters of technologies described in subparagraph (A), as reasonably needed for national security purposes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2405832-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to add and define categories to the list in subparagraph (A) that enable the military, intelligence, surveillance, or cyber-enabled capabilities of a country of concern.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2405833-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Party","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “party”, with respect to a covered national security transaction, has the meaning given that term in regulations prescribed in accordance with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2405834-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” includes an individual, corporation, partnership, association, or any other organized group of persons, or legal successor or representative thereof, or any State or local government or agency thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2405835-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited technology","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2405836-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the regulations prescribed in accordance with this subchapter, the term “prohibited technology” means a technology within the following areas, as specified by the regulations:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd2405837-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/10/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advanced semiconductor technology and microelectronics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2405838-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/10/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Artificial intelligence systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2405839-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/10/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Quantum information technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd240583a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/10/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" High-performance computing and supercomputing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd240583b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/10/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hypersonic systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd240583c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the appropriate congressional committees and subject to notice and comment in accordance with subchapter II of chapter 5 and chapter 7 of title 5, and not subject to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4559"},"text":"section 4559 of this title","children":[],"tail":", may prescribe regulations in accordance with this subchapter to—"}],"tail":null},{"tag":"clause","attrib":{"id":"idd240583d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/10/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" define the technical parameters of technologies described in subparagraph (A), as reasonably needed for national security purposes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd240583e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/10/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to add and define categories to the list in subparagraph (A) that enable the military, intelligence, surveillance, or cyber-enabled capabilities of a country of concern.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd240583f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided, the term “Secretary” means the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2405840-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4589/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term