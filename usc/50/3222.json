{"tag":"section","attrib":{"id":"idd1c20015-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3222"},"text":null,"children":[{"tag":"num","attrib":{"value":"3222"},"text":"§ 3222.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program on recruitment and training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1c20016-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3222/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c20017-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3222/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of National Intelligence, in consultation with the heads of the elements of the intelligence community, shall carry out a program to ensure that selected individuals are provided funds for academic training (including with respect to both undergraduate and postgraduate education), or to reimburse for academic training previously obtained—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c20018-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3222/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in capabilities, missions, or skillsets, especially in the fields of science, technology, math, and engineering, to address workforce requirements in which the intelligence community is deficient or likely to be deficient in the future; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c20019-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3222/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for such individuals who have backgrounds or experiences that the Director has identified as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1c2001a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3222/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contributing to capabilities, missions, or skillsets in which the intelligence community is deficient or likely to be deficient in future; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1c2001b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3222/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" being underrepresented in the intelligence community or likely to be underrepresented in the future.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c2001c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3222/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commitment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual selected for participation in the program shall commit to employment with an element of the intelligence community for a period that the Director determines is commensurate with the amount of funding provided to the individual under the program and under such terms and conditions as the Director considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c2001d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3222/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program shall be known as the Pat Roberts Intelligence Scholars Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c2001e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3222/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director, in consultation with the heads of the elements of the intelligence community, shall maintain a publicly available internet website on the program that describes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1c2001f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3222/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the intent of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c20020-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3222/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conditions and requirements for selection and participation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c20021-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3222/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" application instructions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c20022-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3222/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the areas covered by the program pursuant to the review conducted under subsection (b)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1c20023-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3222/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other details the Director determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c20024-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3222/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program under subsection (a), the Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c20025-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3222/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish such requirements relating to the academic training of participants as the Director considers appropriate to ensure that participants are prepared for employment as intelligence professionals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c20026-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3222/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on an annual basis, review the areas that will contribute to the capabilities, missions, and skillsets in which the intelligence community is deficient or is likely to be deficient in the future.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c20027-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3222/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds made available for the program under subsection (a) shall be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c20028-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3222/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide a monthly stipend for each month that a participant is pursuing a course of study;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c20029-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3222/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay the partial or full tuition of a participant for the completion of such course of study;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c2002a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3222/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reimburse a participant for tuition paid by the participant before becoming an employee of an element of the intelligence community, including with respect to providing payments for student loans used for such tuition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c2002b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3222/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay for books and materials that the participant requires or required to complete such course of study;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c2002c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3222/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay the expenses of the participant for travel requested by an element of the intelligence community in relation to such program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c2002d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3222/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for such other purposes the Director considers reasonably appropriate to carry out such program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1c2002e-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title X, § 1022, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/tIII/s311/a"},"text":"Pub. L. 111–259, title III, § 311(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2662"},"text":"124 Stat. 2662","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dF/tLXIII/s6317"},"text":"Pub. L. 117–263, div. F, title LXIII, § 6317","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3513"},"text":"136 Stat. 3513","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1c2002f-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1c20030-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1c20031-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s441n"},"text":"section 441n of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1c20032-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" amended section generally. Prior to amendment, section related to a program on recruitment and training for areas of specialization in which current or future capabilities of the intelligence community are deficient or likely to be deficient."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
