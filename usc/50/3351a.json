{"tag":"section","attrib":{"id":"idd1d513b3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3351a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3351a"},"text":"§ 3351a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Making certain policies and execution plans relating to personnel clearances available to industry partners","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1d513b4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3351a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d513b5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3351a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security executive agent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Security Executive Agent” means the officer serving as the Security Executive Agent pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3162a"},"text":"section 3162a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d513b6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3351a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate industry partner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “appropriate industry partner” means a contractor, licensee, or grantee (as defined in section 101(a) of Executive Order 12829 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"text":"50 U.S.C. 3161","children":[],"tail":" note; relating to National Industrial Security Program), as in effect on the day before "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":") that is participating in the National Industrial Security Program established by such Executive Order."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d513b7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3351a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sharing of policies and plans required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each head of a Federal agency shall share policies and plans relating to security clearances with appropriate industry partners directly affected by such policies and plans in a manner consistent with the protection of national security as well as the goals and objectives of the National Industrial Security Program administered pursuant to Executive Order 12829 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"text":"50 U.S.C. 3161","children":[],"tail":" note; relating to the National Industrial Security Program)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d513b8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3351a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of policies and procedures required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", the Security Executive Agent and the Director of the National Industrial Security Program shall jointly develop policies and procedures by which appropriate industry partners with proper security clearances and a need to know can have appropriate access to the policies and plans shared pursuant to subsection (b) that directly affect those industry partners."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1d513b9-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLIV/s5402"},"text":"Pub. L. 116–92, div. E, title LIV, § 5402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2143"},"text":"133 Stat. 2143","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1d513ba-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1d513bb-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1d513bc-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order 12829, referred to in subsecs. (a)(2) and (b), is Ex. Ord. No. 12829, ","children":[{"tag":"date","attrib":{"date":"1993-01-06"},"text":"Jan. 6, 1993","children":[],"tail":", 58 F.R. 3479, which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"text":"section 3161 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
