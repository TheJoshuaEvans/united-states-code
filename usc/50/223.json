{"tag":"section","attrib":{"id":"idd0f9a6eb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s223"},"text":null,"children":[{"tag":"num","attrib":{"value":"223"},"text":"§ 223.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeiture of vessels owned by citizens of insurrectionary States","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"From and after fifteen days after the issuing of the proclamation, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s205"},"text":"section 205 of this title","children":[],"tail":", any vessel belonging in whole or in part to any citizen or inhabitant of such State or part of a State whose inhabitants are so declared in a state of insurrection, found at sea, or in any port of the rest of the United States, shall be forfeited."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd0f9a6ec-47c4-11f1-8bcf-c89722bddd2e"},"text":"(R.S. § 5319.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd0f9a6ed-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd0f9a6ee-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd0f9a6ef-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5319 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1861-07-12/ch3/s7"},"text":"act July 12, 1861, ch. 3, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/12/257"},"text":"12 Stat. 257","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
