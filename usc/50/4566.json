{"tag":"section","attrib":{"id":"idd23e0d1c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4566"},"text":null,"children":[{"tag":"num","attrib":{"value":"4566"},"text":"§ 4566.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on purchase of United States defense contractors by entities controlled by foreign governments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd23e0d1d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4566/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No entity controlled by a foreign government may merge with, acquire, or take over a company engaged in interstate commerce in the United States that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd23e0d1e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4566/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is performing a Department of Defense contract, or a Department of Energy contract under a national security program, that cannot be performed satisfactorily unless that company is given access to information in a proscribed category of information; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd23e0d1f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4566/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" during the previous fiscal year, was awarded—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd23e0d20-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4566/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of Defense prime contracts in an aggregate amount in excess of $500,000,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd23e0d21-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4566/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of Energy prime contracts under national security programs in an aggregate amount in excess of $500,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd23e0d22-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4566/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability to certain cases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The limitation in subsection (a) shall not apply if a merger, acquisition, or takeover is not suspended or prohibited pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4565"},"text":"section 4565 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd23e0d23-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4566/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd23e0d24-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4566/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “entity controlled by a foreign government” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd23e0d25-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4566/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any domestic or foreign organization or corporation that is effectively owned or controlled by a foreign government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd23e0d26-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4566/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual acting on behalf of a foreign government,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"as determined by the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd23e0d27-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4566/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “proscribed category of information” means a category of information that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd23e0d28-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4566/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to Department of Defense contracts—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd23e0d29-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4566/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes special access information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd23e0d2a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4566/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is determined by the Secretary of Defense to include information the disclosure of which to an entity controlled by a foreign government is not in the national security interests of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd23e0d2b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4566/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is defined in regulations prescribed by the Secretary of Defense for the purposes of this section; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd23e0d2c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4566/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to Department of Energy contracts—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd23e0d2d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4566/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is determined by the Secretary of Energy to include information described in subparagraph (A)(ii); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd23e0d2e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4566/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is defined in regulations prescribed by the Secretary of Energy for the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd23e0d2f-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tVIII/s835"},"text":"Pub. L. 102–484, div. A, title VIII, § 835","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2461"},"text":"106 Stat. 2461","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd23e0d30-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd23e0d31-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd23e0d32-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 2170a of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Defense Authorization Act for Fiscal Year 1993, and not as part of the Defense Production Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
