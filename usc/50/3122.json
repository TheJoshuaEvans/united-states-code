{"tag":"section","attrib":{"id":"idd1ac7bc1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3122"},"text":null,"children":[{"tag":"num","attrib":{"value":"3122"},"text":"§ 3122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defenses and exceptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1ac7bc2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure by United States of identity of covert agent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is a defense to a prosecution under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3121"},"text":"section 3121 of this title","children":[],"tail":" that before the commission of the offense with which the defendant is charged, the United States had publicly acknowledged or revealed the intelligence relationship to the United States of the individual the disclosure of whose intelligence relationship to the United States is the basis for the prosecution."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ac7bc3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conspiracy, misprision of felony, aiding and abetting, etc.","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1ac7bc4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3122/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), no person other than a person committing an offense under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3121"},"text":"section 3121 of this title","children":[],"tail":" shall be subject to prosecution under such section by virtue of section 2 or 4 of title 18 or shall be subject to prosecution for conspiracy to commit an offense under such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1ac7bc5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3122/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) shall not apply (A) in the case of a person who acted in the course of a pattern of activities intended to identify and expose covert agents and with reason to believe that such activities would impair or impede the foreign intelligence activities of the United States, or (B) in the case of a person who has authorized access to classified information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ac7bc6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3122/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure to select congressional committees on intelligence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall not be an offense under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3121"},"text":"section 3121 of this title","children":[],"tail":" to transmit information described in such section directly to either congressional intelligence committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1ac7bc7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3122/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure by agent of own identity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall not be an offense under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3121"},"text":"section 3121 of this title","children":[],"tail":" for an individual to disclose information that solely identifies himself as a covert agent."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1ac7bc8-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title VI, § 602, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/200/s2/a"},"text":"Pub. L. 97–200, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-06-23"},"text":"June 23, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/122"},"text":"96 Stat. 122","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/306/tIII/s353/b/9"},"text":"Pub. L. 107–306, title III, § 353(b)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2402"},"text":"116 Stat. 2402","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1ac7bc9-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1ac7bca-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1ac7bcb-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s422"},"text":"section 422 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1ac7bcc-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306"},"text":"Pub. L. 107–306","children":[],"tail":" substituted “either congressional intelligence committee” for “the Select Committee on Intelligence of the Senate or to the Permanent Select Committee on Intelligence of the House of Representatives”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
