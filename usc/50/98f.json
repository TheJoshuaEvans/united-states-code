{"tag":"section","attrib":{"id":"idd0edbfdb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98f"},"text":null,"children":[{"tag":"num","attrib":{"value":"98f"},"text":"§ 98f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special Presidential disposal authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd0edbfdc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Materials in the stockpile may be released for use, sale, or other disposition—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd0edbfdd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the order of the President, at any time the President determines the release of such materials is required for purposes of the national defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0edbfde-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in time of war declared by the Congress or during a national emergency, on the order of any officer or employee of the United States designated by the President to have authority to issue disposal orders under this subsection, if such officer or employee determines that the release of such materials is required for purposes of the national defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd0edbfdf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the order of the Under Secretary of Defense for Acquisition and Sustainment, if the President has designated the Under Secretary to have authority to issue release orders under this subsection and, in the case of any such order, if the Under Secretary determines that the release of such materials is required for use, manufacture, or production for purposes of national defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0edbfe0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s98f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any order issued under subsection (a) shall be promptly reported by the President, or by the officer or employee issuing such order, in writing, to the Committee on Armed Services of the Senate and the Committee on Armed Services of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd0edbfe1-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-06-07/ch190/s7"},"text":"June 7, 1939, ch. 190, § 7","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/41/s2/a"},"text":"Pub. L. 96–41, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-30"},"text":"July 30, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/322"},"text":"93 Stat. 322","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1502/e/2"},"text":"Pub. L. 104–106, div. A, title XV, § 1502(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/509"},"text":"110 Stat. 509","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1067/13"},"text":"Pub. L. 106–65, div. A, title X, § 1067(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/775"},"text":"113 Stat. 775","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tXIV/s1413/a"},"text":"Pub. L. 112–239, div. A, title XIV, § 1413(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2048"},"text":"126 Stat. 2048","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s902/90"},"text":"Pub. L. 116–92, div. A, title IX, § 902(90)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1554"},"text":"133 Stat. 1554","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd0edbfe2-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd0edbfe3-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd0edbfe4-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 98f, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-06-07/ch190/s7"},"text":"June 7, 1939, ch. 190, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/812"},"text":"53 Stat. 812","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-07-23/ch590"},"text":"July 23, 1946, ch. 590","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/599"},"te