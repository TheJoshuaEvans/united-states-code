{"tag":"section","attrib":{"id":"idd1d2a106-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334t"},"text":null,"children":[{"tag":"num","attrib":{"value":"3334t"},"text":"§ 3334t.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program for beyond 5G","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1d2a107-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334t/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence, acting through the Director of the Intelligence Advanced Research Projects Activity, may initiate or otherwise carry out a program dedicated to research and development efforts relevant to 6G technology and any successor technologies, but only if such efforts are specific to potential applications of 6G technology (or any successor technologies) for the intelligence community or for other national security purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d2a108-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334t/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation and coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out any program under subsection (a), the Director shall consult and coordinate with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d2a109-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334t/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" relevant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d2a10a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334t/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" heads of Federal departments and agencies, including the Administrator of the National Telecommunications and Information Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d2a10b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334t/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interagency bodies, such as the Committee for the Assessment of Foreign Participation in the United States Telecommunications Sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d2a10c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334t/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private sector entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d2a10d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334t/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher learning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d2a10e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334t/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" federally funded research and development centers; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d2a10f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334t/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other individuals and entities as the Director determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d2a110-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334t/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 6G technology defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “6G technology” means hardware, software, or other technologies relating to sixth-generation wireless networks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1d2a111-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tV/s7508"},"text":"Pub. L. 118–31, div. G, title V, § 7508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1090"},"text":"137 Stat. 1090","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1d2a112-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1d2a113-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd1d2a114-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “intelligence community” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s7002"},"text":"section 7002 of Pub. L. 118–31","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
