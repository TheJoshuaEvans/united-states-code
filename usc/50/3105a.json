{"tag":"section","attrib":{"id":"idd1aa3211-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3105a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3105a"},"text":"§ 3105a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classified intelligence budget justification materials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1aa3212-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3105a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1aa3213-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3105a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “budget” has the meaning given the term “budget of the President” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3097"},"text":"section 3097 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1aa3214-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3105a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classified intelligence budget justification materials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “classified intelligence budget justification materials” means, with respect to a fiscal year, the materials submitted to Congress by the Director of National Intelligence in support of the budget for that fiscal year that are classified or otherwise protected from public disclosure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1aa3215-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3105a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timely submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 5 days after the date on which the President submits to Congress the budget for each fiscal year pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":", the Director of National Intelligence shall submit to the congressional intelligence committees and the Committees on Appropriations of the Senate and the House of Representatives the classified intelligence budget justification materials for the element for that budget."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1aa3216-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title V, § 506J, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dF/tLXIII/s6305"},"text":"Pub. L. 117–263, div. F, title LXIII, § 6305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3504"},"text":"136 Stat. 3504","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dF/tLXVIII/s6804/a"},"text":"Pub. L. 119–60, div. F, title LXVIII, § 6804(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1655"},"text":"139 Stat. 1655","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1aa3217-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1aa3218-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd1aa3219-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3105a, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343/tV/s506J"},"text":"act July 26, 1947, ch. 343, title V, § 506J","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/126/tIII/s306/a"},"text":"Pub. L. 113–126, title III, § 306(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-07"},"text":"July 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1395"},"text":"128 Stat. 1395","children":[],"tail":", required annual assessments of intelligence community performance by function, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLVII/s5701/c"},"text":"Pub. L. 116–92, div. E, title LVII, § 5701(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2160"},"text":"133 Stat. 2160","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1aa321a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" inserted “and the Committees on Appropriations of the Senate and the House of Representatives” after “congressional intelligence committees”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
