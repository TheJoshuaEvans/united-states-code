{"tag":"section","attrib":{"id":"idd217e7e4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4232"},"text":null,"children":[{"tag":"num","attrib":{"value":"4232"},"text":"§ 4232.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd217e7e5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4232/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Administrator” means the person appointed by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4234"},"text":"section 4234 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e7e6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4232/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “affected Aleut villages” means the surviving Aleut villages of Akutan, Atka, Nikolski, Saint George, Saint Paul, and Unalaska, and the Aleut village of Attu, Alaska;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e7e7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4232/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Association” means the Aleutian/Pribilof Islands Association, Inc., a nonprofit regional corporation established for the benefit of the Aleut people and organized under the laws of the State of Alaska;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e7e8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4232/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Corporation” means the Aleut Corporation, a for-profit regional corporation for the Aleut region organized under the laws of the State of Alaska and established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1606"},"text":"section 1606 of title 43","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e7e9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4232/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “eligible Aleut” means any Aleut living on ","children":[{"tag":"date","attrib":{"date":"1988-08-10"},"text":"August 10, 1988","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd217e7ea-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4232/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, as a civilian, was relocated by authority of the United States from his or her home village on the Pribilof Islands or the Aleutian Islands west of Unimak Island to an internment camp, or other temporary facility or location, during World War II; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd217e7eb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4232/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who was born while his or her natural mother was subject to such relocation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e7ec-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4232/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of the Interior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e7ed-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4232/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Fund” means the Aleutian and Pribilof Islands Restitution Fund established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4233"},"text":"section 4233 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd217e7ee-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4232/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “World War II” means the period beginning on ","children":[{"tag":"date","attrib":{"date":"1941-12-07"},"text":"December 7, 1941","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1945-09-02"},"text":"September 2, 1945","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd217e7ef-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/383/tII/s202"},"text":"Pub. L. 100–383, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-10"},"text":"Aug. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/911"},"text":"102 Stat. 911","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd217e7f0-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd217e7f1-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"ta