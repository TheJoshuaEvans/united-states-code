{"tag":"section","attrib":{"id":"idd169ce06-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2405"},"text":null,"children":[{"tag":"num","attrib":{"value":"2405"},"text":"§ 2405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deputy Administrator for Defense Nuclear Nonproliferation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd169ce07-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2405/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is in the Administration a Deputy Administrator for Defense Nuclear Nonproliferation, who is appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd169ce08-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2405/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the authority, direction, and control of the Administrator, the Deputy Administrator for Defense Nuclear Nonproliferation shall perform such duties and exercise such powers as the Administrator may prescribe, including the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd169ce09-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2405/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Preventing the spread of materials, technology, and expertise relating to weapons of mass destruction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd169ce0a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2405/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Detecting the proliferation of weapons of mass destruction worldwide.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd169ce0b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2405/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Eliminating inventories of surplus fissile materials usable for nuclear weapons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd169ce0c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2405/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing for international nuclear safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd169ce0d-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dC/tXXXII/s3215"},"text":"Pub. L. 106–65, div. C, title XXXII, § 3215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/959"},"text":"113 Stat. 959","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd169ce0e-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd169ce0f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd169ce10-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2000-03-01"},"text":"Mar. 1, 2000","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/s3299"},"text":"section 3299 of Pub. L. 106–65","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2401"},"text":"section 2401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
