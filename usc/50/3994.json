{"tag":"section","attrib":{"id":"idd20bdaf8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3994"},"text":null,"children":[{"tag":"num","attrib":{"value":"3994"},"text":"§ 3994.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mining claims","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd20bdaf9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3994/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements suspended","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s28"},"text":"section 28 of title 30","children":[],"tail":" specified in subsection (b) shall not apply to a servicemember’s claims or interests in claims, regularly located and recorded, during a period of military service and 180 days thereafter, or during any period of hospitalization or rehabilitation due to injuries or disabilities incurred in the line of duty."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20bdafa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3994/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s28"},"text":"section 28 of title 30","children":[],"tail":" that shall not apply under subsection (a) are those which require that on each mining claim located after "},{"tag":"date","attrib":{"date":"1872-05-10"},"text":"May 10, 1872","children":[],"tail":", and until a patent has been issued for such claim, not less than $100 worth of labor shall be performed or improvements made during each year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20bdafb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3994/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of protection from forfeiture","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A mining claim or an interest in a claim owned by a servicemember that has been regularly located and recorded shall not be subject to forfeiture for nonperformance of annual assessments during the period of military service and for 180 days thereafter, or for any period of hospitalization or rehabilitation described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20bdafc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3994/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to obtain the protections of this section, the claimant of a mining location shall, before the end of the assessment year in which military service is begun or within 60 days after the end of such assessment year, cause to be filed in the office where the location notice or certificate is recorded a notice communicating the fact of military service and the desire to hold the mining claim under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd20bdafd-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title V, § 504, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s1"},"text":"Pub. L. 108–189, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2856"},"text":"117 Stat. 2856","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd20bdafe-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd20bdaff-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd20bdb00-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 564 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd20bdb01-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 504 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"act Oct. 17, 1940, ch. 888","children":[],"tail":", art. V, "},{"tag":"ref","attrib":{"href":"/us/stat/54/1187"},"text":"54 Stat. 1187","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/12/s9/19"},"text":"Pub. L. 102–12, § 9(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-03-18"},"text":"Mar. 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/40"},"text":"105 Stat. 40","children":[],"tail":", related to desert-land entries and the suspension of requirements, prior to the general amendment of this Act by "},{"tag":"ref","attrib":{"href":"/us/pl/108/189"},"text":"Pub. L. 108–189","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3993"},"text":"section 3993 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd20bdb02-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd20bdb03-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any case not final before ","children":[{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s3"},"text":"section 3 of Pub. L. 108–189","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3901"},"text":"section 3901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
