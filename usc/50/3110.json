{"tag":"section","attrib":{"id":"idd1aa325d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3110"},"text":null,"children":[{"tag":"num","attrib":{"value":"3110"},"text":"§ 3110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on violations of law or executive order","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1aa325e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3110/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence shall annually submit to the congressional intelligence committees a report on violations of law or executive order relating to intelligence activities by personnel of an element of the intelligence community that were identified during the previous calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1aa325f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3110/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted under subsection (a) shall, consistent with the need to preserve ongoing criminal investigations, include a description of, and any action taken in response to, any violation of law or executive order (including Executive Order No. 12333 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"50 U.S.C. 3001","children":[],"tail":" note)) relating to intelligence activities committed by personnel of an element of the intelligence community in the course of the employment of such personnel that, during the previous calendar year, was—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1aa3260-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3110/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined by the director, head, or general counsel of any element of the intelligence community to have occurred;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1aa3261-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3110/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referred to the Department of Justice for possible criminal prosecution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1aa3262-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3110/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantiated by the inspector general of any element of the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1aa3263-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title V, § 511, as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/293/tIII/s323/a"},"text":"Pub. L. 113–293, title III, § 323(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4003"},"text":"128 Stat. 4003","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1aa3264-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1aa3265-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1aa3266-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/293/tIII/s323/e"},"text":"Pub. L. 113–293, title III, § 323(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4004"},"text":"128 Stat. 4004","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/293/tIII/s323/e"},"text":"“Nothing in this section [enacting this section and provisions set out as notes under this section] or the amendments made by this section shall be construed to alter any requirement existing on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":"] to submit a report under any provision of law.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1aa3267-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Initial Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/293/tIII/s323/b"},"text":"Pub. L. 113–293, title III, § 323(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4004"},"text":"128 Stat. 4004","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/293/tIII/s323/b"},"text":"“The first report required under section 511 of the National Security Act of 1947 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3110"},"text":"50 U.S.C. 3110","children":[],"tail":"], as added by subsection (a), shall be submitted not later than one year after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1aa3268-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Guidelines","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/293/tIII/s323/c"},"text":"Pub. L. 113–293, title III, § 323(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4004"},"text":"128 Stat. 4004","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/293/tIII/s323/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":"], the Director of National Intelligence, in consultation with the head of each element of the intelligence community, shall—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue guidelines to carry out section 511 of the National Security Act of 1947 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3110"},"text":"50 U.S.C. 3110","children":[],"tail":"], as added by subsection (a); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit such guidelines to the congressional intelligence committees.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definitions of terms used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/293/s323/c"},"text":"section 323(c) of Pub. L. 113–293","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/113/293/s2"},"text":"section 2 of Pub. L. 113–293","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
