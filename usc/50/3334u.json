{"tag":"section","attrib":{"id":"idd1d2a115-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3334u"},"text":null,"children":[{"tag":"num","attrib":{"value":"3334u"},"text":"§ 3334u.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of referral to Department of Justice","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If a referral is made to the Department of Justice from any element of the intelligence community regarding an allegation of misconduct against a civilian employee of the intelligence community, the head of the element of the intelligence community that employs the covered employee shall notify the congressional intelligence committees of the referral not later than 10 days after the date on which such referral is made.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd1d2a116-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dF/tLXVI/s6614/c"},"text":"Pub. L. 118–159, div. F, title LXVI, § 6614(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2506"},"text":"138 Stat. 2506","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1d2a117-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1d2a118-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd1d2a119-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “intelligence community” and “congressional intelligence committees” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dF/s6002"},"text":"section 6002 of div. F of Pub. L. 118–159","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
