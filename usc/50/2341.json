{"tag":"section","attrib":{"id":"idd1651268-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2341"},"text":null,"children":[{"tag":"num","attrib":{"value":"2341"},"text":"§ 2341.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elimination of plutonium production","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1651269-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2341/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Replacement program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy, in consultation with the Secretary of Defense, shall develop a cooperative program with the Government of Russia to eliminate the production of weapons grade plutonium by modifying or replacing the reactor cores at Tomsk–7 and Krasnoyarsk–26 with reactor cores that are less suitable for the production of weapons-grade plutonium.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd165126a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2341/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd165126b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2341/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program shall be designed to achieve completion of the modifications or replacements of the reactor cores within three years after the modification or replacement activities under the program are begun.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd165126c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2341/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The plan for the program shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd165126d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2341/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" specify—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd165126e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2341/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" successive steps for the modification or replacement of the reactor cores; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd165126f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2341/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clearly defined milestones to be achieved; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1651270-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2341/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include estimates of the costs of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1651271-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2341/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of program plan to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1996-09-23"},"text":"September 23, 1996","children":[],"tail":", the Secretary of Defense shall submit to Congress—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1651272-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2341/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for the program under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1651273-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2341/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the United States funding that is necessary for carrying out the activities under the program for each fiscal year covered by the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1651274-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2341/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comparison of the benefits of the program with the benefits of other nonproliferation programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1651275-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXIV/s1432"},"text":"Pub. L. 104–201, div. A, title XIV, § 1432","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2726"},"text":"110 Stat. 2726","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
