{"tag":"section","attrib":{"id":"idd1544951-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1914"},"text":null,"children":[{"tag":"num","attrib":{"value":"1914"},"text":"§ 1914.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Defense program to protect United States students against foreign agents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1544952-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1914/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense shall develop and implement a program to prepare United States students studying abroad through Department of Defense National Security Education Programs to recognize and protect themselves against recruitment efforts by intelligence agents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1544953-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1914/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Briefing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2017-12-12"},"text":"December 12, 2017","children":[],"tail":", the Secretary of Defense shall provide to the Committees on Armed Services of the Senate and the House of Representatives a briefing on the program required under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1544954-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tXII/s1277"},"text":"Pub. L. 115–91, div. A, title XII, § 1277","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1700"},"text":"131 Stat. 1700","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1544955-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1544956-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1544957-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Defense Authorization Act for Fiscal Year 2018, and not as part of the David L. Boren National Security Education Act of 1991 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
