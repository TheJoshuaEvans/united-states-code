{"tag":"section","attrib":{"id":"idd24eaf1e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4821"},"text":null,"children":[{"tag":"num","attrib":{"value":"4821"},"text":"§ 4821.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative procedure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd24eaf1f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4821/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in section 4819(c)(2) or 4843(c) of this title, the functions exercised under this subchapter shall not be subject to sections 551, 553 through 559, and 701 through 706 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd24eaf20-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4821/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative law judges","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd24eaf21-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4821/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd24eaf22-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4821/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint administrative law judges, consistent with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3105"},"text":"section 3105 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd24eaf23-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4821/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate properly appointed administrative law judges from other Federal agencies who are provided to the Department of Commerce pursuant to a legally authorized interagency agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd24eaf24-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4821/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An administrative law judge appointed or designated by the Secretary under paragraph (1) may preside only over proceedings of the Department of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd24eaf25-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4821/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments to regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall notify in advance the Committee on Banking, Housing, and Urban Affairs of the Senate and the Committee on Foreign Affairs of the House of Representatives of any proposed amendments to the Export Administration Regulations with an explanation of the intent and rationale of such amendments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd24eaf26-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVII/s1762"},"text":"Pub. L. 115–232, div. A, title XVII, § 1762","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2231"},"text":"132 Stat. 2231","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd24eaf27-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd24eaf28-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd24eaf29-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (a), was in the original “this part”, meaning part I (§§ 1751–1768) of subtitle B of title XVII of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":", known as the Export Controls Act of 2018, which is classified principally to this subchapter. For complete classification of part I to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s1751"},"text":"section 1751 of Pub. L. 115–232","children":[],"tail":", set out as a Short Title note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4801"},"text":"section 4801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
