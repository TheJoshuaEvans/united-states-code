{"tag":"section","attrib":{"id":"idd135505d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1705"},"text":null,"children":[{"tag":"num","attrib":{"value":"1705"},"text":"§ 1705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd135505e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful acts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for a person to violate, attempt to violate, conspire to violate, or cause a violation of any license, order, regulation, or prohibition issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd135505f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A civil penalty may be imposed on any person who commits an unlawful act described in subsection (a) in an amount not to exceed the greater of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1355060-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1705/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $250,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1355061-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1705/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount that is twice the amount of the transaction that is the basis of the violation with respect to which the penalty is imposed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1355062-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1705/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person who willfully commits, willfully attempts to commit, or willfully conspires to commit, or aids or abets in the commission of, an unlawful act described in subsection (a) shall, upon conviction, be fined not more than $1,000,000, or if a natural person, may be imprisoned for not more than 20 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1355063-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1705/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statute of limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1355064-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1705/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for commencing proceedings","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1355065-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1705/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An action, suit, or proceeding for the enforcement of any civil fine, penalty, or forfeiture, pecuniary or otherwise, under this section shall not be entertained unless commenced within 10 years after the latest date of the violation upon which the civil fine, penalty, or forfeiture is based.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1355066-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1705/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, the commencement of an action, suit, or proceeding includes the issuance of a pre-penalty notice or finding of violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1355067-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1705/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for indictment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person shall be prosecuted, tried, or punished for any offense under subsection (c) unless the indictment is found or the information is instituted within 10 years after the latest date of the violation upon which the indictment or information is based.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1355068-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/223/tII/s206"},"text":"Pub. L. 95–223, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-28"},"text":"Dec. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1628"},"text":"91 Stat. 1628","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/393/tVI/s629"},"text":"Pub. L. 102–393, title VI, § 629","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1773"},"text":"106 Stat. 1773","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/396/tIX/s9155"},"text":"Pub. L. 102–396, title IX, § 9155","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1943"},"text":"106 Stat. 1943","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXIV/s1422"},"text":"Pub. L. 104–201, div. A, title XIV, § 1422","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2725"},"text":"110 Stat. 2725","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/tIV/s402"},"text":"Pub. L. 109–177, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/243"},"text":"120 Stat. 243","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/96/s2/a"},"text":"Pub. L. 110–96, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-10-16"},"text":"Oct. 16, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1011"},"text":"121 Stat. 1011","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/50/dE/tI/s3111/a"},"text":"Pub. L. 118–50, div. E, title I, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-24"},"text":"Apr. 24, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/938"},"text":"138 Stat. 938","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1355069-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd135506a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd135506b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/50"},"text":"Pub. L. 118–50","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/96"},"text":"Pub. L. 110–96","children":[],"tail":" amended section generally. Prior to amendment, text of section read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) A civil penalty of not to exceed $50,000 may be imposed on any person who violates, or attempts to violate, any license, order, or regulation issued under this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) Whoever willfully violates, or willfully attempts to violate, any license, order, or regulation issued under this chapter shall, upon conviction, be fined not more than $50,000, or, if a natural person, may be imprisoned for not more than twenty years, or both; and any officer, director, or agent of any corporation who knowingly participates in such violation may be punished by a like fine, imprisonment, or both.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s402/1"},"text":"Pub. L. 109–177, § 402(1)","children":[],"tail":", substituted “$50,000” for “$10,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s402/2"},"text":"Pub. L. 109–177, § 402(2)","children":[],"tail":", substituted “twenty years” for “ten years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1422/1"},"text":"Pub. L. 104–201, § 1422(1)","children":[],"tail":", inserted “, or attempts to violate,” after “violates”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1422/2"},"text":"Pub. L. 104–201, § 1422(2)","children":[],"tail":", inserted “, or willfully attempts to violate,” after “violates”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/396"},"text":"Pub. L. 102–396","children":[],"tail":" substituted “$10,000” for “$50,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/393"},"text":"Pub. L. 102–393","children":[],"tail":" substituted “$50,000” for “$10,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd135506c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd135506d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/96/s2/b"},"text":"Pub. L. 110–96, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-10-16"},"text":"Oct. 16, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1011"},"text":"121 Stat. 1011","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/96/s2/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil penalties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section 206(b) of the International Emergency Economic Powers Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1705/b"},"text":"50 U.S.C. 1705(b)","children":[],"tail":"], as amended by subsection (a), shall apply to violations described in section 206(a) of such Act with respect to which enforcement action is pending or commenced on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2007-10-16"},"text":"Oct. 16, 2007","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criminal penalties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section 206(c) of the International Emergency Economic Powers Act, as amended by subsection (a), shall apply to violations described in section 206(a) of such Act with respect to which enforcement action is commenced on or after the date of the enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
