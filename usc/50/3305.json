{"tag":"section","attrib":{"id":"idd1c92b4f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3305"},"text":null,"children":[{"tag":"num","attrib":{"value":"3305"},"text":"§ 3305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exhibits for inclusion with budget justification books","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Beginning with the fiscal year 2010 budget request, the Director of National Intelligence shall include the budget exhibits identified in paragraphs (1) and (2) as described in the Department of Defense Financial Management Regulation with the congressional budget justification books.","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c92b50-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3305/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For procurement programs requesting more than $20,000,000 in any fiscal year, the P–1, Procurement Program; P–5, Cost Analysis; P–5a, Procurement History and Planning; P–21, Production Schedule; and P–40 ","children":[{"tag":"ref","attrib":{"idref":"fn002084"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002084"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" Budget Item Justification."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c92b51-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3305/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For research, development, test and evaluation projects requesting more than $10,000,000 in any fiscal year, the R–1, RDT&E Program; R–2, RDT&E Budget Item Justification; R–3, RDT&E Project Cost Analysis; and R–4, RDT&E Program Schedule Profile.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1c92b52-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/329/dC/tVIII/s8107"},"text":"Pub. L. 110–329, div. C, title VIII, § 8107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-09-30"},"text":"Sept. 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3644"},"text":"122 Stat. 3644","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1c92b53-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1c92b54-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1c92b55-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s415a–2"},"text":"section 415a–2 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1c92b56-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"similarProvisions","id":"idd1c92b57-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Similar Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section 