{"tag":"section","attrib":{"id":"idd175b4f1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2922"},"text":null,"children":[{"tag":"num","attrib":{"value":"2922"},"text":"§ 2922.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations for the Department of Defense Cooperative Threat Reduction Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd175b4f2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2922/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal year 2008","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd175b4f3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2922/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), there are authorized to be appropriated to the Department of Defense Cooperative Threat Reduction Program such sums as may be necessary for fiscal year 2008 for the following purposes:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd175b4f4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2922/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chemical weapons destruction at Shchuch’ye, Russia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd175b4f5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2922/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Biological weapons proliferation prevention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd175b4f6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2922/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Acceleration, expansion, and strengthening of Cooperative Threat Reduction Program activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd175b4f7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2922/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The sums appropriated pursuant to paragraph (1) may not exceed the amounts authorized to be appropriated by any national defense authorization Act for fiscal year 2008 (whether enacted before or after ","children":[{"tag":"date","attrib":{"date":"2007-08-03"},"text":"August 3, 2007","children":[],"tail":") to the Department of Defense Cooperative Threat Reduction Program for such purposes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd175b4f8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2922/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Future years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that in fiscal year 2008 and future fiscal years, the President should accelerate and expand funding for Cooperative Threat Reduction programs administered by the Department of Defense and such efforts should include, beginning upon ","children":[{"tag":"date","attrib":{"date":"2007-08-03"},"text":"August 3, 2007","children":[],"tail":", encouraging additional commitments by the Russian Federation and other partner nations, as recommended by the 9/11 Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd175b4f9-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXVIII/s1832"},"text":"Pub. L. 110–53, title XVIII, § 1832","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/497"},"text":"121 Stat. 497","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
