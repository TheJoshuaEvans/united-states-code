{"tag":"section","attrib":{"id":"idd1d9cd76-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3363"},"text":null,"children":[{"tag":"num","attrib":{"value":"3363"},"text":"§ 3363.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terrorist Identification Classification System","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1d9cd77-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3363/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d9cd78-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3363/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director of National Intelligence shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d9cd79-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3363/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and maintain a list of individuals who are known or suspected international terrorists, and of organizations that are known or suspected international terrorist organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d9cd7a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3363/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that pertinent information on the list is shared with the departments, agencies, and organizations described by subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d9cd7b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3363/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The list under paragraph (1), and the mechanisms for sharing information on the list, shall be known as the “Terrorist Identification Classification System”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d9cd7c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3363/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d9cd7d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3363/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall prescribe requirements for the inclusion of an individual or organization on the list required by subsection (a), and for the deletion or omission from the list of an individual or organization currently on the list.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d9cd7e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3363/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall ensure that the information utilized to determine the inclusion, or deletion or omission, of an individual or organization on or from the list is derived from all-source intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d9cd7f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3363/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall ensure that the list is maintained in accordance with existing law and regulations governing the collection, storage, and dissemination of intelligence concerning United States persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d9cd80-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3363/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3024/h"},"text":"section 3024(h) of this title","children":[],"tail":", relating to the protection of intelligence sources and methods, the Director shall provide for the sharing of the list, and information on the list, with such departments and agencies of the Federal Government, State and local government agencies, and entities of foreign governments and international organizations as the Director considers appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d9cd81-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3363/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on criteria for information sharing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d9cd82-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3363/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"2003-03-01"},"text":"March 1, 2003","children":[],"tail":", the Director shall submit to the congressional intelligence committees a report describing the criteria used to determine which types of information on the list required by subsection (a) are to be shared, and which types of information are not to be shared, with various departments and agencies of the Federal Government, State and local government agencies, and entities of foreign governments and international organizations."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d9cd83-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3363/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The report shall include a description of the circumstances in which the Director has determined that sharing information on the list with the departments and agencies of the Federal Government, and of State and local governments, described by subsection (c) would be inappropriate due to the concerns addressed by section 403–3(c)(7) ","children":[{"tag":"ref","attrib":{"idref":"fn002098"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002098"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, relating to the protection of sources and methods, and any instance in which the sharing of information on the list has been inappropriate in light of such concerns."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d9cd84-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3363/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" System administration requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d9cd85-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3363/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall, to the maximum extent practicable, ensure the interoperability of the Terrorist Identification Classification System with relevant information systems of the departments and agencies of the Federal Government, and of State and local governments, described by subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d9cd86-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3363/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall ensure that the System utilizes technologies that are effective in aiding the identification of individuals in the field.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d9cd87-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3363/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on status of System","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d9cd88-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3363/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2002-11-27"},"text":"November 27, 2002","children":[],"tail":", the Director shall, in consultation with the Director of Homeland Security, submit to the congressional intelligence committees a report on the status of the Terrorist Identification Classification System. The report shall contain a certification on the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d9cd89-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3363/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the System contains the intelligence information necessary to facilitate the contribution of the System to the domestic security of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d9cd8a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3363/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the departments and agencies having access to the System have access in a manner that permits such departments and agencies to carry out appropriately their domestic security responsibilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d9cd8b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3363/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the System is operating in a manner that maximizes its contribution to the domestic security of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d9cd8c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3363/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a certification under subparagraph (A), (B), or (C) is in the negative, the modifications or enhancements of the System necessary to ensure a future certification in the positive.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d9cd8d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3363/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The report shall be submitted in unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d9cd8e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3363/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional intelligence committees defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “congressional intelligence committees” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d9cd8f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3363/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Select Committee on Intelligence of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d9cd90-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3363/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Permanent Select Committee on Intelligence of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1d9cd91-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/tIII/s343"},"text":"Pub. L. 107–306, title III, § 343","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2399"},"text":"116 Stat. 2399","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/177/tIII/s377/d"},"text":"Pub. L. 108–177, title III, § 377(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-13"},"text":"Dec. 13, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2631"},"text":"117 Stat. 2631","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI"},"text":"Pub. L. 108–458, title I","children":[],"tail":", §§ 1071(g)(2)(A)(ii), 1072(d)(1)(A), "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3691"},"text":"118 Stat. 3691","children":[],"tail":", 3693; "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/tIII/s347/f"},"text":"Pub. L. 111–259, title III, § 347(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2699"},"text":"124 Stat. 2699","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tIX/s7901/f/2"},"text":"Pub. L. 118–31, div. G, title IX, § 7901(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1107"},"text":"137 Stat. 1107","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dF/tLXIV/s6402/c/2/G"},"text":"Pub. L. 119–60, div. F, title LXIV, § 6402(c)(2)(G)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1616"},"text":"139 Stat. 1616","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1d9cd92-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1d9cd93-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1d9cd94-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s403–3"},"text":"Section 403–3 of this title","children":[],"tail":", referred to in subsec. (d)(2), was repealed and a new section 403–3 enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI/s1011/a"},"text":"Pub. L. 108–458, title I, § 1011(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3643"},"text":"118 Stat. 3643","children":[],"tail":", without corresponding amendment to this section. "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403–3"},"text":"Section 403–3 of this title","children":[],"tail":" was subsequently editorially reclassified as "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3025"},"text":"section 3025 of this title","children":[],"tail":". The new section 3025 contains a subsec. (c) relating to the composition of the Office of the Director of National Intelligence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1d9cd95-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s404n–2"},"text":"section 404n–2 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section. Some section numbers of this title referenced in amendment notes below reflect the classification of such sections prior to their editorial reclassification."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1d9cd96-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “Subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3024/h"},"text":"section 3024(h) of this title","children":[],"tail":", relating” for “Subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3024/i"},"text":"section 3024(i) of this title","children":[],"tail":", relating”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" substituted “Not later than” for “Not later then”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsecs. (d) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259"},"text":"Pub. L. 111–259","children":[],"tail":" redesignated subsecs. (e) to (h) as (d) to (g), respectively, and struck out former subsec. (d). Prior to amendment, text of subsec. (d) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The Director shall review on an annual basis the information provided by various departments and agencies for purposes of the list under subsection (a) in order to determine whether or not the information so provided is derived from the widest possible range of intelligence available to such departments and agencies.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The Director shall, as a result of each review under paragraph (1), certify whether or not the elements of the intelligence community responsible for the collection of intelligence related to the list have provided information for purposes of the list that is derived from the widest possible range of intelligence available to such department and agencies.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1071/g/2/A/ii"},"text":"Pub. L. 108–458, § 1071(g)(2)(A)(ii)","children":[],"tail":", which directed amendment of par. (1) by substituting “Director of National Intelligence” for “Director of Central Intelligence, acting as the head of the intelligence community,”, was executed by making the substitution for “Director of Central Intelligence, acting as head of the Intelligence Community,” in introductory provisions to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1072/d/1/A"},"text":"Pub. L. 108–458, § 1072(d)(1)(A)","children":[],"tail":", which directed amendment of subsec. (c) by substituting “section 403–1(i)” for “section 403–3(c)(6)”, was executed by making the substitution for “section 403–3(c)(7)” to reflect the probable intent of Congress and the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/108/177"},"text":"Pub. L. 108–177","children":[],"tail":". See 2003 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsecs. (c), (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177/s377/d"},"text":"Pub. L. 108–177, § 377(d)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403–3/c/7"},"text":"section 403–3(c)(7) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403–3/c/6"},"text":"section 403–3(c)(6) of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1d9cd97-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd1d9cd98-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For Determination by President that amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" take effect on "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", see Memorandum of President of the United States, "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", 70 F.R. 23925, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" effective not later than six months after "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1097/a"},"text":"section 1097(a) of Pub. L. 108–458","children":[],"tail":", set out in an Effective Date of 2004 Amendment; Transition Provisions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
