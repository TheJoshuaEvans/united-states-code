{"tag":"section","attrib":{"id":"idd20e4aa5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4022"},"text":null,"children":[{"tag":"num","attrib":{"value":"4022"},"text":"§ 4022.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Power of attorney","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd20e4aa6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4022/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Automatic extension","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A power of attorney of a servicemember shall be automatically extended for the period the servicemember is in a missing status (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s551/2"},"text":"section 551(2) of title 37","children":[],"tail":") if the power of attorney—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd20e4aa7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4022/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" was duly executed by the servicemember—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd20e4aa8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4022/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while in military service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd20e4aa9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4022/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" before entry into military service but after the servicemember—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd20e4aaa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4022/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" received a call or order to report for military service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd20e4aab-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4022/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was notified by an official of the Department of Defense that the person could receive a call or order to report for military service;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4aac-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4022/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designates the servicemember’s spouse, parent, or other named relative as the servicemember’s attorney in fact for certain, specified, or all purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd20e4aad-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4022/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expires by its terms after the servicemember entered a missing status.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20e4aae-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4022/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on power of attorney extension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A power of attorney executed by a servicemember may not be extended under subsection (a) if the document by its terms clearly indicates that the power granted expires on the date specified even though the servicemember, after the date of execution of the document, enters a missing status.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd20e4aaf-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title VII, § 702, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s1"},"text":"Pub. L. 108–189, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2861"},"text":"117 Stat. 2861","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd20e4ab0-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd20e4ab1-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd20e4ab2-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 592 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd20e4ab3-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 702 of ","children":[{"