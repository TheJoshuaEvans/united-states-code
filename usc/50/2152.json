{"tag":"section","attrib":{"id":"idd16030fc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2152"},"text":null,"children":[{"tag":"num","attrib":{"value":"2152"},"text":"§ 2152.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules relating to section 2013 criteria employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd16030fd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2152/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this section, in the application of chapter 84 of title 5 to an employee of the Agency who is subject to such chapter and is designated by the Director under the criteria prescribed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2013"},"text":"section 2013 of this title","children":[],"tail":", such employee shall be treated for purposes of determining such employee’s retirement benefits and obligations under such chapter as if the employee were a law enforcement officer (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8401/17"},"text":"section 8401(17) of title 5","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16030fe-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2152/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary and mandatory retirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of sections 2053 and 2055 of this title shall apply to employees referred to in subsection (a), except that the retirement benefits shall be determined under chapter 84 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16030ff-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2152/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recall","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1603100-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2152/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2111"},"text":"section 2111 of this title","children":[],"tail":" shall apply to an employee referred to in subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1603101-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2152/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Contributions during recall service shall be made as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8422"},"text":"section 8422 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1603102-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2152/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When an employee recalled under this subsection reverts to a retired status, the annuity of such employee shall be redetermined under the provisions of chapter 84 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1603103-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2152/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees disabled on duty","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1603104-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2152/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1603105-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2152/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “affected employee” means an employee of the Agency covered under subchapter II of chapter 84 of title 5 who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1603106-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2152/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is performing service in a position designated under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1603107-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2152/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while on duty in the position designated under subsection (a), becomes ill or is injured as a direct result of the performance of such duties before the date on which the employee becomes entitled to an annuity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2053"},"text":"section 2053 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8412/d/1"},"text":"section 8412(d)(1) of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1603108-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2152/d/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because of the illness or injury described in clause (ii), is permanently unable to render useful and efficient service in the employee’s covered position, as determined by the Director; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1603109-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2152/d/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is appointed to a position in the civil service that is not a covered position but is within the Agency; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd160310a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2152/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “covered position” means a position as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd160310b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2152/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a law enforcement officer described in section 8331(20) or 8401(17) of title 5;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd160310c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2152/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a customs and border protection officer described in section 8331(31) or 8401(36) of title 5;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd160310d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2152/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a firefighter described in section 8331(21) or 8401(14) of title 5;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd160310e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2152/d/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an air traffic controller described in section 8331(30) or 8401(35) of title 5;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd160310f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2152/d/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nuclear materials courier described in section 8331(27) or 8401(33) of title 5;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1603110-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2152/d/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the United States Capitol Police;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1603111-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2152/d/1/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the Supreme Court Police;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1603112-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2152/d/1/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an affected employee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1603113-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2152/d/1/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a special agent described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4044/15"},"text":"section 4044(15) of title 22","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1603114-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2152/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of service after disability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless an affected employee files an election described in paragraph (3), creditable service by the affected employee in a position described in paragraph (1)(A)(iv) shall be treated as creditable service in a covered position for purposes of this chapter and chapter 84 of title 5, including eligibility for an annuity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2053"},"text":"section 2053 of this title","children":[],"tail":" or 8412(d)(1) of title 5 and determining the amount to be deducted and withheld from the pay of the affected employee under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8422"},"text":"section 8422 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1603115-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2152/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Break in service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (2) shall only apply if the affected employee transitions to a position described in paragraph (1)(A)(iv) without a break in service exceeding 3 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1603116-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2152/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on treatment of service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The service of an affected employee shall no longer be eligible for treatment under paragraph (2) if such service occurs after the employee is transferred to a supervisory or administrative position related to the activities of the former covered position of the employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1603117-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2152/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opt out","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An affected employee may file an election to have any creditable service performed by the affected employee treated in accordance with chapter 84 of title 5 without regard to paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1603118-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/tIII/s302"},"text":"Pub. L. 88–643, title III, § 302","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s802"},"text":"Pub. L. 102–496, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3244"},"text":"106 Stat. 3244","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/225/s3/c"},"text":"Pub. L. 117–225, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-09"},"text":"Dec. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2296"},"text":"136 Stat. 2296","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1603119-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd160311a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd160311b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/s302"},"text":"section 302 of Pub. L. 88–643","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/tV/s506"},"text":"Pub. L. 99–335, title V, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/625"},"text":"100 Stat. 625","children":[],"tail":", related to special rules relating to employees designated under criteria of former "},{"tag":"ref","attrib":{"href":"/us/pl/88/643/s203"},"text":"section 203 of Pub. L. 88–643","children":[],"tail":" and was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403"},"text":"section 403 of this title","children":[],"tail":" prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/88/643"},"text":"Pub. L. 88–643","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s802"},"text":"section 802 of Pub. L. 102–496","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd160311c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/225"},"text":"Pub. L. 117–225","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd160311d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd160311e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/225"},"text":"Pub. L. 117–225","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-12-09"},"text":"Dec. 9, 2022","children":[],"tail":", and applicable to an individual who suffers an illness or injury described in certain Code provisions on or after the date that is 2 years after "},{"tag":"date","attrib":{"date":"2022-12-09"},"text":"Dec. 9, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/225/s3/f"},"text":"section 3(f) of Pub. L. 117–225","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8336"},"text":"section 8336 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd160311f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of fourth month beginning after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s805"},"text":"section 805 of Pub. L. 102–496","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1603120-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to promulgation of regulations to carry out the amendments made by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/225"},"text":"Pub. L. 117–225","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/225/s3/e"},"text":"section 3(e) of Pub. L. 117–225","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8336"},"text":"section 8336 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
