{"tag":"section","attrib":{"id":"idd1a305cb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3079"},"text":null,"children":[{"tag":"num","attrib":{"value":"3079"},"text":"§ 3079.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insider threat policy compliance and reporting","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The head of each element of the intelligence community shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1a305cc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3079/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement the policy established in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3024/e/8"},"text":"section 3024(e)(8) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a305cd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3079/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" concurrent with the submission to Congress of budget justification materials in support of the budget of the President for a fiscal year that is submitted to Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":", submit to Congress a certification as to whether the element is in compliance with such policy."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1a305ce-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title III, § 313, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dF/tLXIII/s6314/b"},"text":"Pub. L. 117–263, div. F, title LXIII, § 6314(b)","children":[],"tail":", "},{"ta