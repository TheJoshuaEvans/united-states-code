{"tag":"section","attrib":{"id":"idd1dc3dc3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3366"},"text":null,"children":[{"tag":"num","attrib":{"value":"3366"},"text":"§ 3366.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities of heads of other departments and agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the head of any department or agency of the United States is authorized to receive and utilize funds made available to the department or agency by the Director of National Intelligence pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3024/d/2"},"text":"section 3024(d)(2) of this title","children":[],"tail":", as amended by subsection (a), and receive and utilize any system referred to in such section that is made available to such department or agency."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd1dc3dc4-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/tIV/s402/b"},"text":"Pub. L. 111–259, title IV, § 402(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2709"},"text":"124 Stat. 2709","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1dc3dc5-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1dc3dc6-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1dc3dc7-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsection (a), referred to in text, is subsec. (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s402"},"text":"section 402 of Pub. L. 111–259","children":[],"tail":", title IV, "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2708"},"text":"124 Stat. 2708","children":[],"tail":", which amended "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403–1"},"text":"section 403–1 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3024"},"text":"section 3024 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1dc3dc8-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s403–1"},"text":"section 403–1 of this title","children":[],"tail":" prior to editorial reclassification as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
