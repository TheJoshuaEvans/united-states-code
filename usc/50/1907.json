{"tag":"section","attrib":{"id":"idd1520023-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1907"},"text":null,"children":[{"tag":"num","attrib":{"value":"1907"},"text":"§ 1907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government Accountability Office audits","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The conduct of the program required by this chapter may be audited by the Government Accountability Office under such rules and regulations as may be prescribed by the Comptroller General of the United States. Representatives of the Government Accountability Office shall have access to all books, accounts, records, reports, and files and all other papers, things, or property of the Department of Defense pertaining to such activities and necessary to facilitate the audit.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd1520024-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/183/tVIII/s807"},"text":"Pub. L. 102–183, title VIII, § 807","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-04"},"text":"Dec. 4, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1276"},"text":"105 Stat. 1276","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1520025-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1520026-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1520027-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office” in section catchline and in two places in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
