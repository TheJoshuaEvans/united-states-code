{"tag":"section","attrib":{"id":"idd2157725-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4201"},"text":null,"children":[{"tag":"num","attrib":{"value":"4201"},"text":"§ 4201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2157726-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4201/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acknowledge the fundamental injustice of the evacuation, relocation, and internment of United States citizens and permanent resident aliens of Japanese ancestry during World War II;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2157727-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4201/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apologize on behalf of the people of the United States for the evacuation, relocation, and internment of such citizens and permanent resident aliens;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2157728-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4201/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for a public education fund to finance efforts to inform the public about the internment of such individuals so as to prevent the recurrence of any similar event;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2157729-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4201/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make restitution to those individuals of Japanese ancestry who were interned;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd215772a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4201/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make restitution to Aleut residents of the Pribilof Islands and the Aleutian Islands west of Unimak Island, in settlement of United States obligations in equity and at law, for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd215772b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4201/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" injustices suffered and unreasonable hardships endured while those Aleut residents were under United States control during World War II;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd215772c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4201/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personal property taken or destroyed by United States forces during World War II;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd215772d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4201/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community property, including community church property, taken or destroyed by United States forces during World War II; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd215772e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4201/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" traditional village lands on Attu Island not rehabilitated after World War II for Aleut occupation or other productive use;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd215772f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4201/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discourage the occurrence of similar injustices and violations of civil liberties in the future; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2157730-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4201/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make more credible and sincere any declaration of concern by the United States over violations of human rights committed by other nations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2157731-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/383/s1"},"text":"Pub. L. 100–383, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-10"},"text":"Aug. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/903"},"text":"102 Stat. 903","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2157732-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2157733-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd2157734-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 1989 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
