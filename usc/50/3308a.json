{"tag":"section","attrib":{"id":"idd1c92b8c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3308a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3308a"},"text":"§ 3308a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of certain information to Government Accountability Office by National Reconnaissance Office","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1c92b8d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3308a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Reconnaissance Office shall provide to the Comptroller General of the United States, in a timely manner, access to the cost, schedule, and performance information the Comptroller General requires to conduct assessments, as required by any of the appropriate congressional committees, of programs of the National Reconnaissance Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1c92b8e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3308a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1c92b8f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3308a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional defense committees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1c92b90-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3308a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Select Committee on Intelligence of the Senate and the Permanent Select Committee on Intelligence of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1c92b91-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXVI/s1620"},"text":"Pub. L. 114–328, div. A, title XVI, § 1620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2596"},"text":"130 Stat. 2596","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1c92b92-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1c92b93-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1c92b94-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Congressional Defense Committees” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Congressional defense committees means the Committees on Armed Services and Appropriations of the Senate and the House of Representatives, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s3"},"text":"section 3 of Pub. L. 114–328","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2025"},"text":"130 Stat. 2025","children":[],"tail":". See note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
