{"tag":"section","attrib":{"id":"idd16031b0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2203"},"text":null,"children":[{"tag":"num","attrib":{"value":"2203"},"text":"§ 2203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on previous transfers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1994-04-30"},"text":"April 30, 1994","children":[],"tail":", the President shall submit to the appropriate congressional committees a report describing any spoils of war obtained subsequent to "},{"tag":"date","attrib":{"date":"1990-08-02"},"text":"August 2, 1990","children":[],"tail":" that were transferred to any party, including any government, group, or person, before "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"April 30, 1994","children":[],"tail":". Such report shall be submitted in unclassified form to the extent possible."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd16031b1-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tV/s554"},"text":"Pub. L. 103–236, title V, § 554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/482"},"text":"108 Stat. 482","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
