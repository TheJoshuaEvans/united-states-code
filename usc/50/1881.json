b":{"id":"idd148632a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Select Committee on Intelligence of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd148632b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Permanent Select Committee on Intelligence of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd148632c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign Intelligence Surveillance Court; Court","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “Foreign Intelligence Surveillance Court” and “Court” mean the court established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1803/a"},"text":"section 1803(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd148632d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign Intelligence Surveillance Court of Review; Court of Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “Foreign Intelligence Surveillance Court of Review” and “Court of Review” mean the court established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1803/b"},"text":"section 1803(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd148632e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic communication service provider","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “electronic communication service provider” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd148632f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a telecommunications carrier, as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s153"},"text":"section 153 of title 47","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1486330-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a provider of electronic communication service, as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2510"},"text":"section 2510 of title 18","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1486331-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1881/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a provider of a remote computing service, as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2711"},"text":"section 2711 of title 18","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"