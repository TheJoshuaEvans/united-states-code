{"tag":"section","attrib":{"id":"idd1d5134c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3348a"},"text":"§ 3348a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional oversight of sensitive programs not covered by other provisions of law","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1d5134d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d5134e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than February 1 of each year, the head of each covered element shall submit to congressional leadership a report on each covered program carried out by that covered element.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d5134f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each such report shall set forth—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d51350-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount requested by the covered element for covered programs within the budget submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":" for the fiscal year following the fiscal year in which the report is submitted; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d51351-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each program in such budget that is a covered program—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1d51352-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a brief description of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1d51353-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a procurement program, a brief discussion of the major milestones established for the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1d51354-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual cost of the program for each fiscal year during which the program has been conducted before the fiscal year during which that budget is submitted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1d51355-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the estimated total cost of the program and the estimated cost of the program for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idd1d51356-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/a/2/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd1d51357-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/a/2/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fiscal year for which the budget is submitted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd1d51358-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/a/2/B/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each of the four succeeding fiscal years during which the program is expected to be conducted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d51359-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Newly designated programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d5135a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than February 1 of each year, the head of each covered element shall submit to congressional leadership a report that, with respect to each new covered program of that covered element, provides—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d5135b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notice of the designation of the program as a special access program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d5135c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" justification for such designation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d5135d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A report under paragraph (1) with respect to a program shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d5135e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current estimate of the total program cost for the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d5135f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification, as applicable, of existing programs or technologies that are similar to the technology, or that have a mission similar to the technology, or that have a mission similar to the mission, of the program that is the subject of the notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d51360-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New covered program defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “new covered program” means a covered program that has not previously been covered in a notice and justification under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d51361-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision in classification of programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d51362-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever a change in the classification of a covered program of a covered element is planned to be made or whenever classified information concerning a covered program of a covered element is to be declassified and made public, the head of the covered element shall submit to congressional leadership a report containing a description of the proposed change or the information to be declassified, the reasons for the proposed change or declassification, and notice of any public announcement planned to be made with respect to the proposed change or declassification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d51363-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period for submittal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (3), a report referred to in paragraph (1) shall be submitted not less than 14 days before the date on which the proposed change, declassification, or public announcement is to occur.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d51364-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the head of the covered element determines that because of exceptional circumstances the requirement of paragraph (2) cannot be met with respect to a proposed change, declassification, or public announcement concerning a covered program of the covered element, the head of the department or agency may submit the report required by paragraph (1) regarding the proposed change, declassification, or public announcement at any time before the proposed change, declassification, or public announcement is made and shall include in the report an explanation of the exceptional circumstances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d51365-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision of criteria for designating programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever there is a modification or termination of the policy and criteria used for designating a program of a covered element as a covered program, the head of the covered element shall promptly notify congressional leadership of such modification or termination. Any such notification shall contain the reasons for the modification or termination and, in the case of a modification, the provisions of the policy as modified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d51366-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initiation of programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A covered program may not be initiated by a covered element until—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d51367-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" congressional leadership is notified of the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d51368-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of 30 days elapses after such notification is received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d51369-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No funds may be obligated or expended by any covered element to carry out a covered program until the head of the covered element has briefed congressional leadership on the covered program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d5136a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d5136b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered element","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered element” means any element or portion of the Federal Government that is not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d5136c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a covered department or agency as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3348/g"},"text":"section 3348(g) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d5136d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Defense (which is required to submit reports on special access programs under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s119"},"text":"section 119 of title 10","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d5136e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Nuclear Security Administration (which is required to submit reports on special access programs under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2426"},"text":"section 2426 of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d5136f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/g/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an element of the intelligence community (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d51370-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional leadership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “congressional leadership” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d51371-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the majority leader of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d51372-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the minority leader of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d51373-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Speaker of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d51374-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the minority leader of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d51375-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3348a/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered program” means any special access program or similarly protected program established under the authority of Executive Order 12356 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"text":"50 U.S.C. 3161","children":[],"tail":" note; relating to prescribing a uniform system for classifying, declassifying, and safeguarding national security information), or any successor Executive order, or any similar sensitive program established anywhere in the Federal Government, including one established at the direction of the President."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1d51376-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dHH/tV/s501"},"text":"Pub. L. 117–103, div. HH, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1114"},"text":"136 Stat. 1114","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1d51377-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1d51378-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1d51379-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order 12356, referred to in subsec. (g)(3), is Ex. Ord. No. 12356, ","children":[{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", 47 F.R. 14874, 15557, which was revoked by Ex. Ord. No. 12958, "},{"tag":"date","attrib":{"date":"1995-04-17"},"text":"Apr. 17, 1995","children":[],"tail":", 60 F.R. 19825, which was subsequently revoked by Ex. Ord. No. 13526, § 6.2(g), "},{"tag":"date","attrib":{"date":"2009-12-29"},"text":"Dec. 29, 2009","children":[],"tail":", 75 F.R. 731. Ex. Ord. No. 13526, which prescribes a uniform system for classifying, safeguarding, and declassifying national security information, is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"text":"section 3161 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
