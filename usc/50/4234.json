{"tag":"section","attrib":{"id":"idd217e7fe-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4234"},"text":null,"children":[{"tag":"num","attrib":{"value":"4234"},"text":"§ 4234.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"1988-08-10"},"text":"August 10, 1988","children":[],"tail":", the Secretary shall offer to undertake negotiations with the Association, leading to the execution of an agreement with the Association to serve as Administrator under this subchapter. The Secretary may appoint the Association as Administrator if such agreement is reached within 90 days after "},{"tag":"date","attrib":{"date":"1988-08-10"},"text":"August 10, 1988","children":[],"tail":". If no such agreement is reached within such period, the Secretary shall appoint another person as Administrator under this subchapter, after consultation with leaders of affected Aleut villages and the Corporation."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd217e7ff-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/383/tII/s204"},"text":"Pub. L. 100–383, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-10"},"text":"Aug. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/912"},"text":"102 Stat. 912","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd217e800-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd217e801-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd217e802-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 1989c–3 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
