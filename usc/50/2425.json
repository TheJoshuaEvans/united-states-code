{"tag":"section","attrib":{"id":"idd16c179a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2425"},"text":null,"children":[{"tag":"num","attrib":{"value":"2425"},"text":"§ 2425.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government access to information on Administration computers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd16c179b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2425/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall establish procedures to govern access to information on Administration computers. Those procedures shall, at a minimum, provide that any individual who has access to information on an Administration computer shall be required as a condition of such access to provide to the Administrator written consent which permits access by an authorized investigative agency to any Administration computer used in the performance of the duties of such employee during the period of that individual’s access to information on an Administration computer and for a period of three years thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16c179c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2425/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expectation of privacy in Administration computers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law (including any provision of law enacted by the Electronic Communications Privacy Act of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/508"},"text":"Public Law 99–508","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/100/1848"},"text":"100 Stat. 1848","children":[],"tail":")), no user of an Administration computer shall have any expectation of privacy in the use of that computer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16c179d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2425/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “authorized investigative agency” means an agency authorized by law or regulation to conduct a counterintelligence investigation or investigations of persons who are proposed for access to classified information to ascertain whether such persons satisfy the criteria for obtaining and retaining access to such information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd16c179e-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dC/tXXXII/s3235"},"text":"Pub. L. 106–65, div. C, title XXXII, § 3235","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/961"},"text":"113 Stat. 961","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dC/tXXXI/s3145/c"},"text":"Pub. L. 113–66, div. C, title XXXI, § 3145(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/1071"},"text":"127 Stat. 1071","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd16c179f-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd16c17a0-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd16c17a1-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Electronic Communications Privacy Act of 1986, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/508"},"text":"Pub. L. 99–508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1848"},"text":"100 Stat. 1848","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1986 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2510"},"text":"section 2510 of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd16c17a2-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66"},"text":"Pub. L. 113–66","children":[],"tail":" inserted “("},{"tag":"ref","attrib":{"href":"/us/pl/99/508"},"text":"Public Law 99–508","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/100/1848"},"text":"100 Stat. 1848","children":[],"tail":")” after “of 1986”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
