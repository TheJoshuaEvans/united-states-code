{"tag":"section","attrib":{"id":"idd204d4f8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3815"},"text":null,"children":[{"tag":"num","attrib":{"value":"3815"},"text":"§ 3815.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repeals; appropriations; termination date","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd204d4f9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3815/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in this chapter all laws or any parts of laws in conflict with the provisions of the chapter are repealed to the extent of such conflict.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd204d4fa-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3815/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated, out of any money in the Treasury not otherwise appropriated, such sums as may be necessary to carry out the provisions of this chapter. All funds appropriated for the administrative expenses of the National Security Training Commission shall be appropriated directly to the Commission and all funds appropriated to pay the expenses of training carried out by the military departments designated by the Commission shall be appropriated directly to the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd204d4fb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3815/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provisions of this chapter, no person shall be inducted for training and service in the Armed Forces after ","children":[{"tag":"date","attrib":{"date":"1973-07-01"},"text":"July 1, 1973","children":[],"tail":", except persons now or hereafter deferred under section 3806 of this chapter after the basis for such deferment ceases to exist."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd204d4fc-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-24/ch625"},"text":"June 24, 1948, ch. 625","children":[],"tail":", title I, § 17, "},{"tag":"ref","attrib":{"href":"/us/stat/62/625"},"text":"62 Stat. 625","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1950-06-23/ch351"},"text":"June 23, 1950, ch. 351","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/254"},"text":"64 Stat. 254","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1950-06-30/ch445/s1"},"text":"June 30, 1950, ch. 445, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/318"},"text":"64 Stat. 318","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1951-06-19/ch144"},"text":"June 19, 1951, ch. 144","children":[],"tail":", title I, § 1(w), "},{"tag":"ref","attrib":{"href":"/us/stat/65/87"},"text":"65 Stat. 87","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1955-06-30/ch250"},"text":"June 30, 1955, ch. 250","children":[],"tail":", title I, § 102, "},{"tag":"ref","attrib":{"href":"/us/stat/69/224"},"text":"69 Stat. 224","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/4/s1"},"text":"Pub. L. 86–4, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-03-23"},"text":"Mar. 23, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/13"},"text":"73 Stat. 13","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/2/s1"},"text":"Pub. L. 88–2, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-03-28"},"text":"Mar. 28, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/4"},"text":"