{"tag":"section","attrib":{"id":"idd145f186-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1871"},"text":null,"children":[{"tag":"num","attrib":{"value":"1871"},"text":"§ 1871.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Semiannual report of the Attorney General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd145f187-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1871/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On a semiannual basis, the Attorney General shall submit to the Permanent Select Committee on Intelligence of the House of Representatives, the Select Committee on Intelligence of the Senate, and the Committees on the Judiciary of the House of Representatives and the Senate, in a manner consistent with the protection of the national security, a report setting forth with respect to the preceding 6-month period—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd145f188-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1871/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the aggregate number of persons targeted for orders issued under this chapter, including a breakdown of those targeted for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd145f189-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1871/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electronic surveillance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1805"},"text":"section 1805 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd145f18a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1871/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical searches under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1824"},"text":"section 1824 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd145f18b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1871/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pen registers under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1842"},"text":"section 1842 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd145f18c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1871/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to records under section 1861 ","children":[{"tag":"ref","attrib":{"idref":"fn002036"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002036"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd145f18d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1871/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquisitions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1881b"},"text":"section 1881b of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd145f18e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1871/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquisitions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1881c"},"text":"section 1881c of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd145f18f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1871/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of individuals covered by an order issued pursuant to section 1801(b)(1)(C) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd145f190-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1871/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of times that the Attorney General has authorized that information obtained under this chapter may be used in a criminal proceeding or any information derived therefrom may be used in a criminal proceeding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd145f191-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1871/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of significant legal interpretations of this chapter involving matters before the Foreign Intelligence Surveillance Court or the Foreign Intelligence Surveillance Court of Review, including interpretations presented in applications or pleadings filed with the Foreign Intelligence Surveillance Court or the Foreign Intelligence Surveillance Court of Review by the Department of Justice; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd145f192-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1871/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" copies of all decisions, orders, or opinions of the Foreign Intelligence Surveillance Court or Foreign Intelligence Surveillance Court of Review that include significant construction or interpretation of the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd145f193-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1871/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Frequency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The first report under this section shall be submitted not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"2004-12-17"},"text":"December 17, 2004","children":[],"tail":". Subsequent reports under this section shall be submitted semi-annually thereafter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd145f194-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1871/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submissions to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall submit to the committees of Congress referred to in subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd145f195-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1871/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 45 days after the date on which the Foreign Intelligence Surveillance Court or the Foreign Intelligence Surveillance Court of Review issues a decision, order, or opinion, including any denial or modification of an application under this chapter, that includes significant construction or interpretation of any provision of law or results in a change of application of any provision of this chapter or a novel application of any provision of this chapter, a copy of such decision, order, or opinion and any pleadings, applications, or memoranda of law associated with such decision, order, or opinion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd145f196-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1871/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of each such decision, order, or opinion, and any pleadings, applications, or memoranda of law associated with such decision, order, or opinion, that was issued during the 5-year period ending on ","children":[{"tag":"date","attrib":{"date":"2008-07-10"},"text":"July 10, 2008","children":[],"tail":", and not previously submitted in a report under subsection (a);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd145f197-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1871/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any hearing, oral argument, or other proceeding before the Foreign Intelligence Surveillance Court or Foreign Intelligence Surveillance Court of Review for which a court reporter produces a transcript, not later than 45 days after the government receives the final transcript or the date on which the matter of the hearing, oral argument, or other proceeding is resolved, whichever is later, a notice of the existence of such transcript. Not later than three business days after a committee referred to in subsection (a) requests to review an existing transcript, the Attorney General shall facilitate such request; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd145f198-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1871/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of each declassified document that has undergone review under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1872"},"text":"section 1872 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd145f199-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1871/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of national security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General, in consultation with the Director of National Intelligence, may authorize redactions of materials described in subsection (c) that are provided to the committees of Congress referred to in subsection (a), if such redactions are necessary to protect the national security of the United States and are limited to sensitive sources and methods information or the identities of targets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd145f19a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1871/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd145f19b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1871/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign Intelligence Surveillance Court","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Foreign Intelligence Surveillance Court” means the court established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1803/a"},"text":"section 1803(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd145f19c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1871/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign Intelligence Surveillance Court of Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Foreign Intelligence Surveillance Court of Review” means the court established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1803/b"},"text":"section 1803(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd145f19d-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511/tVI/s601"},"text":"Pub. L. 95–511, title VI, § 601","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tVI/s6002/a/2"},"text":"Pub. L. 108–458, title VI, § 6002(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3743"},"text":"118 Stat. 3743","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/261/tI"},"text":"Pub. L. 110–261, title I","children":[],"tail":", §§ 101(c)(2), 103, title IV, § 403(b)(2)(B), "},{"tag":"date","attrib":{"date":"2008-07-10"},"text":"July 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2459"},"text":"122 Stat. 2459","children":[],"tail":", 2460, 2474; "},{"tag":"ref","attrib":{"href":"/us/pl/114/23/tVI/s604"},"text":"Pub. L. 114–23, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-02"},"text":"June 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/297"},"text":"129 Stat. 297","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/49/s8/b"},"text":"Pub. L. 118–49, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-20"},"text":"Apr. 20, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/874"},"text":"138 Stat. 874","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd145f19e-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"idd145f19f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendment of Subsection (a)(1)","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/261/tIV/s403/b/2"},"text":"Pub. L. 110–261, title IV, § 403(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-10"},"text":"July 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2474"},"text":"122 Stat. 2474","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/112/238/s2/a/2"},"text":"Pub. L. 112–238, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-30"},"text":"Dec. 30, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1631"},"text":"126 Stat. 1631","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/118/tII/s201/a/2"},"text":"Pub. L. 115–118, title II, § 201(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-01-19"},"text":"Jan. 19, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/19"},"text":"132 Stat. 19","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tIX/s7902/a/1"},"text":"Pub. L. 118–31, div. G, title IX, § 7902(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1108"},"text":"137 Stat. 1108","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/49/s19/a/2"},"text":"Pub. L. 118–49, § 19(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-20"},"text":"Apr. 20, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/891"},"text":"138 Stat. 891","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/84/s1/a/2"},"text":"Pub. L. 119–84, § 1(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-04-18"},"text":"Apr. 18, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/770"},"text":"140 Stat. 770","children":[],"tail":", provided that, except as provided in "},{"tag":"ref","attrib":{"href":"/us/pl/110/261/s404"},"text":"section 404 of Pub. L. 110–261","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801"},"text":"section 1801 of this title","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2026-04-30"},"text":"Apr. 30, 2026","children":[],"tail":", subsection (a)(1) of this section is amended to read as it read on the day before "},{"tag":"date","attrib":{"date":"2008-07-10"},"text":"July 10, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd145f1a0-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd145f1a1-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (c)(1), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511"},"text":"Pub. L. 95–511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-25"},"text":"Oct. 25, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1783"},"text":"92 Stat. 1783","children":[],"tail":", known as the Foreign Intelligence Surveillance Act of 1978, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801"},"text":"section 1801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1861"},"text":"Section 1861 of this title","children":[],"tail":", referred to in subsec. (a)(1)(D), means "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1861"},"text":"section 1861 of this title","children":[],"tail":" prior to the amendment of section 1861 by "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/tI/s102/b"},"text":"Pub. L. 109–177, title I, § 102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/195"},"text":"120 Stat. 195","children":[],"tail":", set out as an Effective Date of 2006 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1805"},"text":"section 1805 of this title","children":[],"tail":", which amended "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1861"},"text":"section 1861 of this title","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2020-03-15"},"text":"Mar. 15, 2020","children":[],"tail":", so that such section read as it read on "},{"tag":"date","attrib":{"date":"2001-10-25"},"text":"Oct. 25, 2001","children":[],"tail":", with certain exceptions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801/b/1/C"},"text":"Section 1801(b)(1)(C) of this title","children":[],"tail":", referred to in subsec. (a)(2), was temporarily added by "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tVI/s6001/a"},"text":"Pub. L. 108–458, title VI, § 6001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3742"},"text":"118 Stat. 3742","children":[],"tail":", and provided that, as used in subchapter I of this chapter, the term “agent of a foreign power” included any person other than a United States person who “engages in international terrorism or activities in preparation therefore”. Such amendment ceased to have effect on "},{"tag":"date","attrib":{"date":"2020-03-15"},"text":"Mar. 15, 2020","children":[],"tail":"; see "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/s6001/b"},"text":"section 6001(b) of Pub. L. 108–458","children":[],"tail":", set out as a Termination Date of 2004 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801"},"text":"section 1801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd145f1a2-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511/s601"},"text":"section 601 of Pub. L. 95–511","children":[],"tail":" was renumbered section 701 and was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801"},"text":"section 1801 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/110/261"},"text":"Pub. L. 110–261","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd145f1a3-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (c)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/49"},"text":"Pub. L. 118–49","children":[],"tail":" added pars. (3) and (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23"},"text":"Pub. L. 114–23","children":[],"tail":" amended par. (1) generally. Prior to amendment, par. (1) read as follows: “a copy of any decision, order, or opinion issued by the Foreign Intelligence Surveillance Court or the Foreign Intelligence Surveillance Court of Review that includes significant construction or interpretation of any provision of this chapter, and any pleadings, applications, or memoranda of law associated with such decision, order, or opinion, not later than 45 days after such decision, order, or opinion is issued; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1)(E), (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/261/s101/c/2"},"text":"Pub. L. 110–261, § 101(c)(2)","children":[],"tail":", added subpars. (E) and (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/261/s103/a"},"text":"Pub. L. 110–261, § 103(a)","children":[],"tail":", substituted “, orders,” for “(not including orders)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/261/s103/b"},"text":"Pub. L. 110–261, § 103(b)","children":[],"tail":", added subsecs. (c) and (d)."}],"tail":"\n"},{"