{"tag":"section","attrib":{"id":"idd0f9a6a9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s211"},"text":null,"children":[{"tag":"num","attrib":{"value":"211"},"text":"§ 211.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations to detect and prevent frauds and abuses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be the duty of the Secretary of the Treasury, from time to time, to institute such investigations as may be necessary to detect and prevent frauds and abuses in any trade or transactions which may be licensed between inhabitants of loyal States and of States in insurrection. And the agents making such investigations shall have power to compel the attendance of witnesses, and to make examinations on oath.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd0f9a6aa-47c4-11f1-8bcf-c89722bddd2e"},"text":"(R.S. § 5307.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd0f9a6ab-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd0f9a6ac-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd0f9a6ad-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5307 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1864-07-02/ch225/s10"},"text":"act July 2, 1864, ch. 225, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/13/377"},"text":"13 Stat. 377","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
