{"tag":"section","attrib":{"id":"idd223ceac-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4328"},"text":null,"children":[{"tag":"num","attrib":{"value":"4328"},"text":"§ 4328.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Member of the former ruling family” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As used in this chapter, the term “member of the former ruling family” means (1) any person who was at any time between ","children":[{"tag":"date","attrib":{"date":"1917-04-06"},"text":"April 6, 1917","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1921-07-02"},"text":"July 2, 1921","children":[],"tail":", the German Emperor or the ruler of any constituent kingdom of the German Empire, or (2) the wife or any child of such person."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd223cead-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-10-06/ch106/s31"},"text":"Oct. 6, 1917, ch. 106, § 31","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1928-03-10/ch167/s15"},"text":"Mar. 10, 1928, ch. 167, § 15","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/275"},"text":"45 Stat. 275","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd223ceae-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd223ceaf-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd223ceb0-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-10-06/ch106"},"text":"act Oct. 6, 1917, ch. 106","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/411"},"text":"40 Stat. 411","children":[],"tail":", known as the Trading with the enemy Act, also known as the Trading with the Enemy Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4301"},"text":"section 4301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd223ceb1-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 31 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
