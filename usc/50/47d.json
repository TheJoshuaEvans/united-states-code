{"tag":"section","attrib":{"id":"idd0e693cc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s47d"},"text":null,"children":[{"tag":"num","attrib":{"value":"47d"},"text":"§ 47d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings; rules and regulations; conclusiveness of determinations of Attorney General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd0e693cd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s47d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General is authorized to hold such hearings and make, promulgate, issue, rescind, and amend such rules and regulations as may be necessary to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd0e693ce-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s47d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A determination made by the Attorney General under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s47b"},"text":"section 47b of this title","children":[],"tail":" shall be final and conclusive and no court shall have power or jurisdiction to review it."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd0e693cf-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-15/ch372/s5"},"text":"July 15, 1955, ch. 372, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/366"},"text":"69 Stat. 366","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/377/s1/b"},"text":"Pub. L. 93–377, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-17"},"text":"Aug. 17, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/473"},"text":"88 Stat. 473","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd0e693d0-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd0e693d1-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd0e693d2-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/377"},"text":"Pub. L. 93–377","children":[],"tail":" designated existing provisions as subsec. (a), substituted “Attorney General” for “Board as administering agent”, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
