{"tag":"section","attrib":{"id":"idd1520004-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1905"},"text":null,"children":[{"tag":"num","attrib":{"value":"1905"},"text":"§ 1905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations and administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1520005-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may prescribe regulations to carry out the program required by this chapter. Before prescribing any such regulations, the Secretary shall submit a copy of the proposed regulations to the Select Committee on Intelligence of the Senate and the Permanent Select Committee on Intelligence of the House of Representatives. Such proposed regulations may not take effect until 30 days after the date on which they are submitted to those committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1520006-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance and use of gifts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to conduct the program required by this chapter, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1520007-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1905/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive money and other property donated, bequeathed, or devised, without condition or restriction other than that it be used for the purpose of conducting the program required by this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1520008-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1905/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may use, sell, or otherwise dispose of such property for that purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1520009-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1905/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to conduct the program required by this chapter, the Secretary may accept and use the services of voluntary and noncompensated personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd152000a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1905/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Necessary expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Expenditures necessary to conduct the program required by this chapter shall be paid from the Fund, subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1904/b"},"text":"section 1904(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd152000b-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/183/tVIII/s805"},"text":"Pub. L. 102–183, title VIII, § 805","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-04"},"text":"Dec. 4, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1275"},"text":"105 Stat. 1275","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
