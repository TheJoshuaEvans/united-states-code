{"tag":"section","attrib":{"id":"idd1d9cd6b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3362"},"text":null,"children":[{"tag":"num","attrib":{"value":"3362"},"text":"§ 3362.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign Terrorist Asset Tracking Center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1d9cd6c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3362/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence shall establish within the Central Intelligence Agency an element responsible for conducting all-source intelligence analysis of information relating to the financial capabilities, practices, and activities of individuals, groups, and nations associated with international terrorism in their activities relating to international terrorism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d9cd6d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3362/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The element established under subsection (a) shall be known as the Foreign Terrorist Asset Tracking Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d9cd6e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3362/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The element required by subsection (a) shall be established as soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2002-11-27"},"text":"November 27, 2002","children":[],"tail":", but not later than 90 days after "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"November 27, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1d9cd6f-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/tIII/s341"},"text":"Pub. L. 107–306, title III, § 341","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2398"},"text":"116 Stat. 2398","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI/s1071/g/2/C"},"text":"Pub. L. 108–458, title I, § 1071(g)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3691"},"text":"118 Stat. 3691","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1d9cd70-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1d9cd71-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1d9cd72-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s404n–1"},"text":"section 404n–1 of this title","children":