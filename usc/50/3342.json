{"tag":"section","attrib":{"id":"idd1d2a199-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3342"},"text":null,"children":[{"tag":"num","attrib":{"value":"3342"},"text":"§ 3342.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security clearances for transition team members","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d2a19a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3342/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “eligible candidate” has the meaning given such term by section 3(h)(4) of the Presidential Transition Act of 1963 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s102"},"text":"3 U.S.C. 102","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d2a19b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3342/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible candidate for President may submit, before the date of the general election, requests for security clearances for prospective transition team members who will have a need for access to classified information to carry out their responsibilities as members of the President-elect’s transition team.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d2a19c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3342/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Completion date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Necessary background investigations and eligibility determinations to permit appropriate prospective transition team members to have access to classified information shall be completed, to the fullest extent practicable, by the day after the date of the general election.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1d2a19d-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/tVII/s7601/c"},"text":"Pub. L. 108–458, title VII, § 7601(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3857"},"text":"118 Stat. 3857","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/283/s2/c/1"},"text":"Pub. L. 111–283, § 2(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3048"},"text":"124 Stat. 3048","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1d2a19e-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1d2a19f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1d2a1a0-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section, referred to in par. (1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s7601"},"text":"section 7601 of Pub. L. 108–458","children":[],"tail":". See Codification note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3(h)(4) of the Presidential Transition Act of 1963, referred to in par. (1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/277/s3/h/4"},"text":"section 3(h)(4) of Pub. L. 88–277","children":[],"tail":", which is set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s102"},"text":"section 102 of Title 3","children":[],"tail":", The President."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1d2a1a1-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s435b"},"text":"section 435b of this title","children":[],"tail":" prior to editorial reclassification as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of subsec. (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s7601"},"text":"section 7601 of Pub. L. 108–458","children":[],"tail":". Subsec. (a) of section 7601 amended provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s102"},"text":"section 102 of Title 3","children":[],"tail":", The President, subsec. (b) of section 7601 is not classified to the Code, and subsec. (d) of section 7601 is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s102"},"text":"section 102 of Title 3","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1d2a1a2-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/283/s2/c/1/A"},"text":"Pub. L. 111–283, § 2(c)(1)(A)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “In this section, the term ‘major party’ shall have the meaning given under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s9002/6"},"text":"section 9002(6) of title 26","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/283/s2/c/1/B"},"text":"Pub. L. 111–283, § 2(c)(1)(B)","children":[],"tail":", substituted “eligible candidate” for “major party candidate”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
