{"tag":"section","attrib":{"id":"idd1675c40-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2363"},"text":null,"children":[{"tag":"num","attrib":{"value":"2363"},"text":"§ 2363.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress concerning assistance to states of former Soviet Union","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1675c41-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2363/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Cooperative Threat Reduction programs and other United States programs authorized in title XIV of the National Defense Authorization Act for Fiscal Year 1993 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Public Law 102–484","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5901"},"text":"22 U.S.C. 5901","children":[],"tail":" et seq.) should be expanded by offering assistance under those programs to other independent states of the former Soviet Union in addition to Russia, Ukraine, Kazakstan, and Belarus; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1675c42-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2363/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President should offer assistance to additional independent states of the former Soviet Union in each case in which the participation of such states would benefit national security interests of the United States by improving border controls and safeguards over materials and technology associated with weapons of mass destruction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1675c43-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXIV/s1453"},"text":"Pub. L. 104–201, div. A, title XIV, § 1453","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2730"},"text":"110 Stat. 2730","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tX/s1069/c/4"},"text":"Pub. L. 105–261, div. A, title X, § 1069(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2136"},"text":"112 Stat. 2136","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1675c44-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1675c45-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1675c46-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title XIV of the National Defense Authorization Act for Fiscal Year 1993, referred to in par. (1), is title XIV of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2563"},"text":"106 Stat. 2563","children":[],"tail":", known as the Former Soviet Union Demilitarization Act of 1992, which is classified generally to chapter 68 (§ 5901 et seq.) of Title 22, Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1675c47-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261"},"text":"Pub. L. 105–261","children":[],"tail":" substituted “title XIV of the National Defense Authorization Act for Fiscal Year 1993 ("},{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Public Law 102–484","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5901"},"text":"22 U.S.C. 5901","children":[],"tail":" et seq.)” for “the National Defense Authorization Act for Fiscal Years 1993 and 1994”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
