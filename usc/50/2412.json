{"tag":"section","attrib":{"id":"idd16c176a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2412"},"text":null,"children":[{"tag":"num","attrib":{"value":"2412"},"text":"§ 2412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cybersecurity Risk Inventory, Assessment, and Mitigation Working Group","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd16c176b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2412/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is in the Administration a working group, to be known as the “Cybersecurity Risk Inventory, Assessment, and Mitigation Working Group” (referred to in this section as the “working group”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16c176c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2412/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Members of the working group shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16c176d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2412/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Deputy Administrator for Defense Programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16c176e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2412/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Associate Administrator for Information Management and Chief Information Officer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16c176f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2412/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other personnel of the Administration as are determined appropriate for inclusion in the working group by the Chairperson.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16c1770-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2412/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Deputy Administrator for Defense Programs shall serve as the Chairperson of the working group, except that the Administrator may designate another member of the working group to serve as Chairperson in lieu of the Deputy Administrator if the Administrator determines it is appropriate to do so.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16c1771-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2412/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive strategy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The working group shall prepare a comprehensive strategy for inventorying the range of systems of the Administration that are potentially at risk in the operational technology and nuclear weapons information technology environments, assessing the systems at risk based on mission impact, and implementing risk mitigation actions. Such strategy shall incorporate key elements of effective cybersecurity risk management strategies, as identified by the Government Accountability Office, including the specification of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16c1772-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2412/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" goals, objectives, activities, and performance measures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16c1773-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2412/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizational roles, responsibilities, and coordination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16c1774-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2412/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resources needed to implement the strategy through 2034; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16c1775-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2412/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detailed milestones and schedules for completion of tasks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16c1776-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2412/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd16c1777-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2412/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim briefing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"December 22, 2023","children":[],"tail":", the working group shall provide to the congressional defense committees a briefing on the plan of the working group to develop the strategy required under subsection (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd16c1778-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2412/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Completed strategy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2025-04-01"},"text":"April 1, 2025","children":[],"tail":", the working group shall submit the congressional defense committees a copy of the completed strategy."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd16c1779-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2412/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The working group shall terminate on a date determined by the Administrator that is not earlier than the date that is five years after ","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"December 22, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd16c177a-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dC/tXXXII/s3222"},"text":"Pub. L. 106–65, div. C, title XXXII, § 3222","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dC/tXXXI/s3113"},"text":"Pub. L. 118–31, div. C, title XXXI, § 3113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/789"},"text":"137 Stat. 789","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
