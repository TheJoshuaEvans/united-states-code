{"tag":"section","attrib":{"id":"idd1d7838f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352h"},"text":null,"children":[{"tag":"num","attrib":{"value":"3352h"},"text":"§ 3352h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timeliness standard for rendering determinations of trust for personnel vetting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1d78390-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timeliness standard","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d78391-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352h/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall, acting through the Security Executive Agent and the Suitability and Credentialing Executive Agent, establish and publish in such public venue as the President considers appropriate, new timeliness performance standards for processing personnel vetting trust determinations in accordance with the Federal personnel vetting performance management standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d78392-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352h/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quinquennial reviews","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less frequently than once every 5 years, the President shall, acting through the Security Executive Agent and the Suitability and Credentialing Executive Agent—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1d78393-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352h/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the standards established pursuant to paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1d78394-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352h/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" pursuant to such review—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd1d78395-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352h/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" update such standards as the President considers appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd1d78396-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352h/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish in the Federal Register such updates as may be made pursuant to clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d78397-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352h/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d78398-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarterly reports on implementation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d78399-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less frequently than quarterly, the Security Executive Agent and the Suitability and Credentialing Executive Agent shall jointly make available to the public a quarterly report on the compliance of Executive agencies (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of title 5","children":[],"tail":") with the standards established pursuant to subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d7839a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disaggregation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report made available pursuant to paragraph (1) shall disaggregate, to the greatest extent practicable, data by appropriate category of personnel risk and between Government and contractor personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d7839b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Complementary standards for intelligence community","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of National Intelligence may, in consultation with the Security, Suitability, and Credentialing Performance Accountability Council established pursuant to Executive Order 13467 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"text":"50 U.S.C. 3161","children":[],"tail":" note; relating to reforming processes related to suitability for Government employment, fitness for contractor employees, and eligibility for access to classified national security information) establish for the intelligence community standards complementary to those established pursuant to subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1d7839c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352h/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data with respect to timeliness of polygraph examinations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1d7839d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352h/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to each report on compliance with timeliness standards for rendering determinations of trust for personnel vetting prepared pursuant to subsection (b), the Director of National Intelligence shall make available to the congressional intelligence committees as soon as practicable anonymized raw data with respect to the timeliness of polygraph examinations used to prepare each such report in machine-readable format for each element of the intelligence community that collects such data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1d7839e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3352h/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form and classification justification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The data provided to the congressional intelligence committees under paragraph (1) may be modified to remove any personally identifying information, shall be submitted in unclassified form to the greatest extent possible, and shall contain a justification for the classification of any such data provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1d7839f-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tVII/s7702"},"text":"Pub. L. 118–31, div. G, title VII, § 7702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1100"},"text":"137 Stat. 1100","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dF/tLXVI/s6604"},"text":"Pub. L. 118–159, div. F, title LXVI, § 6604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2503"},"text":"138 Stat. 2503","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1d783a0-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1d783a1-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd1d783a2-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order 13467, referred to in subsec. (c), is Ex. Ord. No. 13467, ","children":[{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", 73 F.R. 38103, which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"text":"section 3161 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1d783a3-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s7702"},"text":"section 7702 of Pub. L. 118–31","children":[],"tail":". Subsec. (a)(3) of "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/s7702"},"text":"section 7702 of Pub. L. 118–31","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3341"},"text":"section 3341 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1d783a4-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1d783a5-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd1d783a6-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “intelligence community” and “congressional intelligence committees” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s7002"},"text":"section 7002 of Pub. L. 118–31","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
