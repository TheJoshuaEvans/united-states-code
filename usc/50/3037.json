{"tag":"section","attrib":{"id":"idd1971f64-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3037"},"text":null,"children":[{"tag":"num","attrib":{"value":"3037"},"text":"§ 3037.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deputy Director of the Central Intelligence Agency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1971f65-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3037/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deputy Director of the Central Intelligence Agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is a Deputy Director of the Central Intelligence Agency who shall be appointed by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1971f66-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3037/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Deputy Director of the Central Intelligence Agency shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1971f67-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3037/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the Director of the Central Intelligence Agency in carrying out the duties and responsibilities of the Director of the Central Intelligence Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1971f68-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3037/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the absence or disability of the Director of the Central Intelligence Agency, or during a vacancy in the position of Director of the Central Intelligence Agency, act for and exercise the powers of the Director of the Central Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1971f69-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title I, § 104B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/tIV/s423/a"},"text":"Pub. L. 111–259, title IV, § 423(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2727"},"text":"124 Stat. 2727","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1971f6a-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1971f6b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1971f6c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s403–4c"},"text":"section 403–4c of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1971f6d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd1971f6e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/tIV/s423/c"},"text":"Pub. L. 111–259, title IV, § 423(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2728"},"text":"124 Stat. 2728","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/259/tIV/s423/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of Title 5","children":[],"tail":", Government Organization and Employees] shall apply on the earlier of—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the appointment by the President of an individual to serve as Deputy Director of the Central Intelligence Agency pursuant to section 104B of the National Security Act of 1947 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3037"},"text":"50 U.S.C. 3037","children":[],"tail":"], as added by subsection (a), except that the individual administratively performing the duties of the Deputy Director of the Central Intelligence Agency as of the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":"] may continue to perform such duties until the individual appointed to the position of Deputy Director of the Central Intelligence Agency assumes the duties of such position; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the cessation of the performance of the duties of the Deputy Director of the Central Intelligence Agency by the individual administratively performing such duties as of the date of the enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
