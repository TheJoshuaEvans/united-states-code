{"tag":"section","attrib":{"id":"idd1a5507e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3096"},"text":null,"children":[{"tag":"num","attrib":{"value":"3096"},"text":"§ 3096.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specificity of National Intelligence Program budget amounts for counterterrorism, counterproliferation, counternarcotics, and counterintelligence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1a5507f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3096/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The budget justification materials submitted to Congress in support of the budget of the President for a fiscal year that is submitted to Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":" shall set forth separately the aggregate amount requested for that fiscal year for the National Intelligence Program for each of the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1a55080-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3096/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Counterterrorism.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a55081-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3096/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Counterproliferation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a55082-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3096/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Counternarcotics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1a55083-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3096/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Counterintelligence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1a55084-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3096/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election of classified or unclassified form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts set forth under subsection (a) may be set forth in unclassified form or classified form, at the election of the Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1a55085-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title V, § 506, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/306/tIII/s311/a"},"text":"Pub. L. 107–306, title III, § 311(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2390"},"text":"116 Stat. 2390","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI/s1074/b/1/A"},"text":"Pub. L. 108–458, title I, § 1074(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3694"},"text":"118 Stat. 3694","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/87/tV/s505/2"},"text":"Pub. L. 112–87, title V, § 505(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-01-03"},"text":"Jan. 3, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1897"},"text":"125 Stat. 1897","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1a55086-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1a55087-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1a55088-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s415a"},"text":"section 415a of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd1a55089-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/87"},"text":"Pub. L. 112–87","children":[],"tail":" substituted “Director of National Intelligence.” for “Director of Central Intelligence.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1074/b/1/A/ii"},"text":"Pub. L. 108–458, § 1074(b)(1)(A)(ii)","children":[],"tail":", struck out “Foreign” before “Intelligence” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1074/b/1/A/i"},"text":"Pub. L. 108–458, § 1074(b)(1)(A)(i)","children":[],"tail":", substituted “National Intelligence Program” for “National Foreign Intelligence Program”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd1a5508a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd1a5508b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For Determination by President that amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" take effect on "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", see Memorandum of President of the United States, "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", 70 F.R. 23925, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" effective not later than six months after "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1097/a"},"text":"section 1097(a) of Pub. L. 108–458","children":[],"tail":", set out in an Effective Date of 2004 Amendment; Transition Provisions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd1a5508c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inclusion of Counternarcotics as Special Topic in Certain Budget Justification Materials","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tIII/s7320"},"text":"Pub. L. 118–31, div. G, title III, § 7320","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1036"},"text":"137 Stat. 1036","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dF/tLXVIII/s6804/b/3"},"text":"Pub. L. 119–60, div. F, title LXVIII, § 6804(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1657"},"text":"139 Stat. 1657","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dF/tLXVIII/s6804/b/3"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusion of Counternarcotics as Special Topic","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purposes of the congressional budget justification book for the National Intelligence Program (as such term is defined in section 3 of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"50 U.S.C. 3003","children":[],"tail":")) for each of fiscal years 2025 through 2026, and for any subsequent fiscal year as the Director of National Intelligence determines appropriate, information with respect to the aggregate amount of funding requested for counternarcotics required to be included as part of the budget justification materials submitted to Congress under section 506(a)(3) of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3096/a/3"},"text":"50 U.S.C. 3096(a)(3)","children":[],"tail":"] shall be included as a provision relating to a special topic in such congressional budget justification book."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a fiscal year, the special topic provision included in the congressional budget justification book pursuant to subsection (a) regarding the aggregate amount of funding requested for counternarcotics shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the main activities and investments that such requested funding would support;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a breakdown of such requested funding by program, budget category, intelligence discipline, and any other appropriate classification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comparison of aggregate requested funding and aggregate enacted funding for counternarcotics for the current fiscal year and the previous fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of full-time equivalent civilian and military personnel assigned to the counternarcotics mission of the intelligence community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Director of National Intelligence determines appropriate.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “intelligence community” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s7320"},"text":"section 7320 of Pub. L. 118–31","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/s7002"},"text":"section 7002 of Pub. L. 118–31","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
