{"tag":"section","attrib":{"id":"idd2071fb8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3918"},"text":null,"children":[{"tag":"num","attrib":{"value":"3918"},"text":"§ 3918.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of rights pursuant to written agreement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2071fb9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3918/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A servicemember may waive any of the rights and protections provided by this chapter. Any such waiver that applies to an action listed in subsection (b) of this section is effective only if it is in writing and is executed as an instrument separate from the obligation or liability to which it applies. In the case of a waiver that permits an action described in subsection (b), the waiver is effective only if made pursuant to a written agreement of the parties that is executed during or after the servicemember’s period of military service. The written agreement shall specify the legal instrument to which the waiver applies and, if the servicemember is not a party to that instrument, the servicemember concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2071fba-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3918/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions requiring waivers in writing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirement in subsection (a) for a written waiver applies to the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2071fbb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3918/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The modification, termination, or cancellation of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2071fbc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3918/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contract, lease, or bailment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2071fbd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3918/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an obligation secured by a mortgage, trust, deed, lien, or other security in the nature of a mortgage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2071fbe-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3918/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The repossession, retention, foreclosure, sale, forfeiture, or taking possession of property that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2071fbf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3918/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is security for any obligation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2071fc0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3918/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was purchased or received under a contract, lease, or bailment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2071fc1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3918/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prominent display of certain contract rights waivers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any waiver in writing of a right or protection provided by this chapter that applies to a contract, lease, or similar legal instrument must be in at least 12 point type.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2071fc2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3918/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage of periods after orders received","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2071fc3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3918/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person to whom ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3917"},"text":"section 3917 of this title","children":[],"tail":" applies shall be considered to be a servicemember; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2071fc4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3918/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period with respect to such a person specified in subsection (a) or (b), as the case may be, of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3917"},"text":"section 3917 of this title","children":[],"tail":" shall be considered to be a period of military service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2071fc5-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title I, § 107, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s1"},"text":"Pub. L. 108–189, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2839"},"text":"117 Stat. 2839","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/454/tVII/s702"},"text":"Pub. L. 108–454, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3624"},"text":"118 Stat. 3624","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2071fc6-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2071fc7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd2071fc8-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 517 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd2071fc9-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 107 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"act Oct. 17, 1940, ch. 888","children":[],"tail":", art. I, as added "},{"tag":"ref","attrib":{"href":"/us/act/1942-10-06/ch581/s4"},"text":"Oct. 6, 1942, ch. 581, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/770"},"text":"56 Stat. 770","children":[],"tail":", related to effect on rights and remedies pursuant to written agreements entered after commencement of military service, prior to the general amendment of this Act by "},{"tag":"ref","attrib":{"href":"/us/pl/108/189"},"text":"Pub. L. 108–189","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd2071fca-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/454/s702/1"},"text":"Pub. L. 108–454, § 702(1)","children":[],"tail":", inserted after first sentence: “Any such waiver that applies to an action listed in subsection (b) of this section is effective only if it is in writing and is executed as an instrument separate from the obligation or liability to which it applies.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/454/s702/2"},"text":"Pub. L. 108–454, § 702(2)","children":[],"tail":", (3), added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd2071fcb-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd2071fcc-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any case not final before ","children":[{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s3"},"text":"section 3 of Pub. L. 108–189","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3901"},"text":"section 3901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
