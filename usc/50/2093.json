{"tag":"section","attrib":{"id":"idd15de732-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2093"},"text":null,"children":[{"tag":"num","attrib":{"value":"2093"},"text":"§ 2093.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd15de733-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2093/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annuities stated as annual amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each annuity is stated as an annual amount, ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"12","children":[],"tail":" of which, rounded to the next lowest dollar, constitutes the monthly rate payable on the first business day of the month after the month or other period for which it has accrued."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15de734-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2093/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement of annuity","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15de735-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2093/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement of annuity for participants generally","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in paragraph (2), the annuity of a participant who has met the eligibility requirements for an annuity shall commence on the first day of the month after separation from the Agency or after pay ceases and the service and age requirements for title to an annuity are met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15de736-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2093/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The annuity of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd15de737-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2093/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a participant involuntarily separated from the Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd15de738-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2093/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a participant retiring under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2051"},"text":"section 2051 of this title","children":[],"tail":" due to a disability; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd15de739-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2093/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a participant who serves 3 days or less in the month of retirement;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall commence on the day after separation from the Agency or the day after pay ceases and the service and age or disability requirements for title to annuity are met.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15de73a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2093/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other annuities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any other annuity payable from the fund commences on the first day of the month after the occurrence of the event on which payment thereof is based.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15de73b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2093/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of annuity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An annuity payable from the fund shall terminate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15de73c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2093/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a retired participant, on the day death or any other terminating event provided by this subchapter occurs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15de73d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2093/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a former spouse or a survivor, on the last day of the month before death or any other terminating event occurs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15de73e-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2093/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for survivor annuities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The annuity to a survivor shall become effective as otherwise specified but shall not be paid until the survivor submits an application for such annuity, supported by such proof of eligibility as the Director may require. If such application or proof of eligibility is not submitted during the lifetime of an otherwise eligible individual, no annuity shall be due or payable to the individual’s estate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15de73f-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2093/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of annuity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual entitled to an annuity from the fund may decline to accept all or any part of the annuity by submitting a signed waiver to the Director. The waiver may be revoked in writing at any time. Payment of the annuity waived may not be made for the period during which the waiver is in effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15de740-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2093/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15de741-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2093/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application before 115th anniversary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No payment shall be made from the fund unless an application for benefits based on the service of the participant is received by the Director before the 115th anniversary of the participant’s birth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15de742-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2093/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application within 30 years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), after the death of a participant or retired participant, no benefit based on that participant’s service may be paid from the fund unless an application for the benefit is received by the Director within 30 years after the death or other event which gives rise to eligibility for the benefit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15de743-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2093/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding of State income tax from annuities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd15de744-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2093/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements with States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall, in accordance with this subsection, enter into an agreement with any State within 120 days of a request for agreement from the proper State official. The agreement shall provide that the Director shall withhold State income tax in the case of the monthly annuity of any annuitant who voluntarily requests, in writing, such withholding. The amounts withheld during any calendar quarter shall be held in the fund and disbursed to the States during the month following that calendar quarter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15de745-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2093/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on multiple requests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An annuitant may have in effect at any time only one request for withholding under this subsection, and an annuitant may not have more than two such requests during any one calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15de746-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2093/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Change in State designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), an annuitant may change the State designated by that annuitant for purposes of having withholdings made, and may request that the withholdings be remitted in accordance with such change. An annuitant also may revoke any request of that annuitant for withholding. Any change in the State designated or revocation is effective on the first day of the month after the month in which the request or the revocation is processed by the Director, but in no event later than on the first day of the second month beginning after the day on which such request or revocation is received by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15de747-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2093/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection does not give the consent of the United States to the application of a statute which imposes more burdensome requirements of the United States than on employers generally, or which subjects the United States or any annuitant to a penalty or liability because of this subsection. The Director may not accept pay from a State for services performed in withholding State income taxes from annuities. Any amount erroneously withheld from an annuity and paid to a State by the Director shall be repaid by the State in accordance with regulations prescribed by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd15de748-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2093/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “State” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of this subsection, the term “State” includes the District of Columbia and any territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd15de749-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/tII/s263"},"text":"Pub. L. 88–643, title II, § 263","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s802"},"text":"Pub. L. 102–496, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3235"},"text":"106 Stat. 3235","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tIX/s7901/d/2"},"text":"Pub. L. 118–31, div. G, title IX, § 7901(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1106"},"text":"137 Stat. 1106","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd15de74a-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd15de74b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd15de74c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/s263"},"text":"section 263 of Pub. L. 88–643","children":[],"tail":", title II, "},{"tag":"date","attrib":{"date":"1964-10-13"},"text":"Oct. 13, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1052"},"text":"78 Stat. 1052","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/269/tVI/s609"},"text":"Pub. L. 97–269, title VI, § 609","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-27"},"text":"Sept. 27, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1153"},"text":"96 Stat. 1153","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/tV/s501/2"},"text":"Pub. L. 99–335, title V, § 501(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/622"},"text":"100 Stat. 622","children":[],"tail":", related to attachment of moneys and was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403"},"text":"section 403 of this title","children":[],"tail":" prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/88/643"},"text":"Pub. L. 88–643","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s802"},"text":"section 802 of Pub. L. 102–496","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd15de74d-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (g)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" substituted “fund” for “Fund”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd15de74e-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd15de74f-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of fourth month beginning after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s805"},"text":"section 805 of Pub. L. 102–496","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
