{"tag":"section","attrib":{"id":"idd13eecc7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1810a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1810a"},"text":"§ 1810a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements for civil actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd13eecc8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1810a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a court finds that a person has violated this chapter in a civil action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1810"},"text":"section 1810 of this title","children":[],"tail":", the head of the agency that employs that person shall report to Congress on the administrative action taken against that person pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1803/m"},"text":"section 1803(m) of this title","children":[],"tail":" or any other provision of law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd13eecc9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1810a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Foreign Intelligence Surveillance Court","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a court finds that a person has violated this chapter in a civil action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1810"},"text":"section 1810 of this title","children":[],"tail":", the head of the agency that employs that person shall report the name of such person to the Foreign Intelligence Surveillance Court. The Foreign Intelligence Surveillance Court shall maintain a list of each person about whom it received a report under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd13eecca-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511/tI/s110A"},"text":"Pub. L. 95–511, title I, § 110A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/49/s15/b"},"text":"Pub. L. 118–49, § 15(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-20"},"text":"Apr. 20, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/883"},"text":"138 Stat. 883","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd13eeccb-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd13eeccc-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd13eeccd-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511"},"text":"Pub. L. 95–511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-25"},"text":"Oct. 25, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1783"},"text":"92 Stat. 1783","children":[],"tail":", known as the Foreign Intelligence Surveillance Act of 1978, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801"},"text":"section 1801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
