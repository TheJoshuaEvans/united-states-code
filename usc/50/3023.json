{"tag":"section","attrib":{"id":"idd18655ec-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3023"},"text":null,"children":[{"tag":"num","attrib":{"value":"3023"},"text":"§ 3023.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of National Intelligence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd18655ed-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3023/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of National Intelligence","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd18655ee-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3023/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is a Director of National Intelligence who shall be appointed by the President, by and with the advice and consent of the Senate. Any individual nominated for appointment as Director of National Intelligence shall have extensive national security expertise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd18655ef-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3023/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of National Intelligence shall not be located within the Executive Office of the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd18655f0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3023/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal responsibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the authority, direction, and control of the President, the Director of National Intelligence shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd18655f1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3023/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as head of the intelligence community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd18655f2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3023/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" act as the principal adviser to the President, to the National Security Council, and the Homeland Security Council for intelligence matters related to the national security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd18655f3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3023/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with section 1018 of the National Security Intelligence Reform Act of 2004, oversee and direct the implementation of the National Intelligence Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd18655f4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3023/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on dual service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The individual serving in the position of Director of National Intelligence shall not, while so serving, also serve as the Director of the Central Intelligence Agency or as the head of any other element of the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd18655f5-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title I, § 102, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI/s1011/a"},"text":"Pub. L. 108–458, title I, § 1011(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3644"},"text":"118 Stat. 3644","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd18655f6-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd18655f7-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd18655f8-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1018 of the National Security Intelligence Reform Act of 2004, referred to in subsec. (b)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1018"},"text":"section 1018 of Pub. L. 108–458","children":[],"tail":", which is set out as a note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd18655f9-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s403"},"text":"section 403 of this title","children":[],"tail":" prior to editorial reclassification and renumb