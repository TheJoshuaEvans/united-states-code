{"tag":"section","attrib":{"id":"idd1f67d64-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3734"},"text":null,"children":[{"tag":"num","attrib":{"value":"3734"},"text":"§ 3734.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on availability of funds for Cooperative Threat Reduction activities with Russian Federation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1f67d65-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3734/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd1f67d66-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3734/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States should carry out activities under the Program in the Russian Federation only if those activities are consistent with and in support of the security interests of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd1f67d67-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3734/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in carrying out any such activities after ","children":[{"tag":"date","attrib":{"date":"2014-12-19"},"text":"December 19, 2014","children":[],"tail":", the Secretary of Defense should focus on only those activities that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd1f67d68-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3734/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are in support of the arms control obligations of the United States and the Russian Federation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd1f67d69-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3734/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will reduce the threats posed by weapons of mass destruction and related materials and technology to the United States and countries in the Euro-Atlantic and Eurasian regions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd1f67d6a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3734/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Completion of Cooperative Threat Reduction activities in Russian Federation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Cooperative Threat Reduction funds made available for a fiscal year after fiscal year 2015 may not be obligated or expended for activities in the Russian Federation unless such activities in Russia are specifically authorized by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd1f67d6b-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tXIII/s1334"},"text":"Pub. L. 113–291, div. A, title XIII, § 1334","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3603"},"text":"128 Stat. 3603","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
