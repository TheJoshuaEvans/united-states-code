{"tag":"section","attrib":{"id":"idd19968b2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3041"},"text":null,"children":[{"tag":"num","attrib":{"value":"3041"},"text":"§ 3041.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of officials responsible for intelligence-related activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd19968b3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3041/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendation of DNI in certain appointments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd19968b4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3041/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the event of a vacancy in a position referred to in paragraph (2), the Director of National Intelligence shall recommend to the President an individual for nomination to fill the vacancy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd19968b5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3041/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) applies to the following positions:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd19968b6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3041/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Principal Deputy Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd19968b7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3041/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Central Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19968b8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3041/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concurrence of DNI in appointments to positions in the intelligence community","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd19968b9-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3041/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the event of a vacancy in a position referred to in paragraph (2), the head of the department or agency having jurisdiction over the position shall obtain the concurrence of the Director of National Intelligence before appointing an individual to fill the vacancy or recommending to the President an individual to be nominated to fill the vacancy. If the Director does not concur in the recommendation, the head of the department or agency concerned may not fill the vacancy or make the recommendation to the President (as the case may be). In the case in which the Director does not concur in such a recommendation, the Director and the head of the department or agency concerned may advise the President directly of the intention to withhold concurrence or to make a recommendation, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd19968ba-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3041/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) applies to the following positions:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd19968bb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3041/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Security Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd19968bc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3041/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Reconnaissance Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd19968bd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3041/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Geospatial-Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd19968be-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3041/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary of State for Intelligence and Research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd19968bf-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3041/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Intelligence and Counterintelligence of the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd19968c0-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3041/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary for Intelligence and Analysis of the Department of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd19968c1-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3041/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Executive Assistant Director for Intelligence of the Federal Bureau of Investigation or any successor to that position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd19968c2-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3041/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Homeland Security for Intelligence and Analysis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd19968c3-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3041/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with DNI in certain positions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd19968c4-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3041/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the event of a vacancy in a position referred to in paragraph (2), the head of the department or agency having jurisdiction over the position shall consult with the Director of National Intelligence before appointing an individual to fill the vacancy or recommending to the President an individual to be nominated to fill the vacancy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd19968c5-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3041/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) applies to the following positions:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd19968c6-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3041/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Defense Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd19968c7-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3041/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Commandant of the Coast Guard for Intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd19968c8-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3041/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Attorney General designated as the Assistant Attorney General for National Security under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s507A"},"text":"section 507A of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd19968c9-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title I, § 106, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVII/s706/a"},"text":"Pub. L. 102–496, title VII, § 706(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","chil