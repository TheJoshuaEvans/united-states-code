ion."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd19968cd-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s6742/b/2/A"},"text":"Pub. L. 116–92, § 6742(b)(2)(A)","children":[],"tail":", made technical amendment to section designation in original."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s6744/c/1"},"text":"Pub. L. 116–92, § 6744(c)(1)","children":[],"tail":", inserted “and Counterintelligence” after “Office of Intelligence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(F) to (H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s6744/c/2"},"text":"Pub. L. 116–92, § 6744(c)(2)","children":[],"tail":", (3), redesignated subpars. (G) to (I) as (F) to (H), respectively, and struck out former subpar. (F) which read as follows: “The Director of the Office of Counterintelligence of the Department of Energy.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s6744/c/3"},"text":"Pub. L. 116–92, § 6744(c)(3)","children":[],"tail":", redesignated subpar. (I) as (H)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s6742/b/2/B"},"text":"Pub. L. 116–92, § 6742(b)(2)(B)","children":[],"tail":", realigned margin."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (b)(2)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53"},"text":"Pub. L. 110–53","children":[],"tail":" amended subpar. (I) generally. Prior to amendment, subpar. (I) read as follows: “The Assistant Secretary of Homeland Security for Information Analysis.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177"},"text":"Pub. L. 109–177","children":[],"tail":" added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" amended text generally, substituting provisions relating to involvement of Director of National Intelligence in appointments, consisting of subsecs. (a) to (c), for provisions relating to involvement of Director of Central Intelligence in appointments, consisting of subsecs. (a) and (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" substituted “National Geospatial-Intelligence Agency” for “National Imagery and Mapping Agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177"},"text":"Pub. L. 108–177","children":[],"tail":" added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (b)(2)(C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/108"},"text":"Pub. L. 107–108","children":[],"tail":" added subpars. (C) and (D) and struck out former subpar. (C) which read as follows: “The Director of the Office of Nonproliferation and National Security of the Department of Energy.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/293"},"text":"Pub. L. 104–293","children":[],"tail":" amended section generally, substituting provisions relating to appointment of individuals responsible for intelligence-related activities for provisions relating to administrative provisions pertaining to defense elements within the intelligence community."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/359"},"text":"Pub. L. 103–359","children":[],"tail":" substituted “Central Imagery Office” for “central imagery authority” in heading and text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd19968ce-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd19968cf-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For Determination by President that amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" take effect on "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", see Memorandum of President of the United States, "},{"tag":"date","attrib":{"date":"2005-04-21"},"text":"Apr. 21, 2005","children":[],"tail":", 70 F.R. 23925, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" effective not later than six months after "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/s1097/a"},"text":"section 1097(a) of Pub. L. 108–458","children":[],"tail":", set out as an Effective Date of 2004 Amendment; Transition Provisions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
