{"tag":"section","attrib":{"id":"idd169cdfb-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2404"},"text":null,"children":[{"tag":"num","attrib":{"value":"2404"},"text":"§ 2404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deputy Administrator for Defense Programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd169cdfc-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2404/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is in the Administration a Deputy Administrator for Defense Programs, who is appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd169cdfd-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2404/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the authority, direction, and control of the Administrator, the Deputy Administrator for Defense Programs shall perform such duties and exercise such powers as the Administrator may prescribe, including the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd169cdfe-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2404/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Supporting the deterrence of strategic attacks by maintaining and enhancing the performance, reliability, and security of the United States nuclear weapons stockpile, including the ability to design, produce, and test as necessary to meet national security requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd169cdff-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2404/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Directing, managing, and overseeing the nuclear weapons production facilities and the national security laboratories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd169ce00-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dC/tXXXII/s3214"},"text":"Pub. L. 106–65, div. C, title XXXII, § 3214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/959"},"text":"113 Stat. 959","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dC/tXXXI/s3142"},"text":"Pub. L. 107–107, div. C, title XXXI, § 3142","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1370"},"text":"115 Stat. 1370","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dC/tXXXI/s3112/a"},"text":"Pub. L. 118–31, div. C, title XXXI, § 3112(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/788"},"text":"137 Stat. 788","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dC/tXXXI/s3111/a/3"},"text":"Pub. L. 118–159, div. C, title XXXI, § 3111(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2293"},"text":"138 Stat. 2293","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd169ce01-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd169ce02-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd169ce03-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" added par. (1) and struck out former par. (1) which read as follows: “Maintaining and enhancing the safety, reliability, and performance of the United States nuclear weapons stockpile, including the ability to design, produce, and test, in order to meet national security requirements.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" struck out par. (3) which read as follows: “Directing, managing, and overseeing assets to respond to incidents involving nuclear weapons and materials.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" struck out heading and text of subsec. (c). Text read as follows: “The head of each national security laboratory and nuclear weapons production facility shall, consistent with applicable contractual obligations, report to the Deputy Administrator for Defense Programs.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd169ce04-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd169ce05-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2000-03-01"},"text":"Mar. 1, 2000","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/s3299"},"text":"section 3299 of Pub. L. 106–65","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2401"},"text":"section 2401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
