{"tag":"section","attrib":{"id":"idd21576ea-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s4141"},"text":null,"children":[{"tag":"num","attrib":{"value":"4141"},"text":"§ 4141.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claims settlement period","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commission shall complete its affairs in connection with the settlement of claims pursuant to this subchapter not later than four years following the enactment of legislation making appropriations to the Commission for payment of administrative expenses incurred in carrying out its functions under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd21576eb-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-07-03/ch826"},"text":"July 3, 1948, ch. 826","children":[],"tail":", title II, § 211, as added "},{"tag":"ref","attrib":{"href":"/us/pl/87/846/tI/s103"},"text":"Pub. L. 87–846, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-22"},"text":"Oct. 22, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1111"},"text":"76 Stat. 1111","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd21576ec-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd21576ed-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd21576ee-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to s