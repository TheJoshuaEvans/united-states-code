{"tag":"section","attrib":{"id":"idd10a6fec-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1518"},"text":null,"children":[{"tag":"num","attrib":{"value":"1518"},"text":"§ 1518.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal; detoxification; report to Congress; emergencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1970-10-07"},"text":"October 7, 1970","children":[],"tail":", no chemical or biological warfare agent shall be disposed of within or outside the United States unless such agent has been detoxified or made harmless to man and his environment unless immediate disposal is clearly necessary, in an emergency, to safeguard human life. An immediate report should be made to Congress in the event of such disposal."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd10a6fed-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/441/tV/s506/d"},"text":"Pub. L. 91–441, title V, § 506(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-07"},"text":"Oct. 7, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/913"},"text":"84 Stat. 913","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd10a6fee-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd10a6fef-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd10a6ff0-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/121/tIV/s409"},"text":"Pub. L. 91–121, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-11-19"},"text":"Nov. 19, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/209"},"text":"83 Stat. 209","children":[],"tail":", which comprises this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
