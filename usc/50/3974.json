{"tag":"section","attrib":{"id":"idd20bda8a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3974"},"text":null,"children":[{"tag":"num","attrib":{"value":"3974"},"text":"§ 3974.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policies entitled to protection and lapse of policies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd20bda8b-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3974/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Veterans Affairs shall determine whether a policy is entitled to protection under this subchapter and shall notify the insured and the insurer of that determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20bda8c-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3974/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lapse protection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A policy that the Secretary determines is entitled to protection under this subchapter shall not lapse or otherwise terminate or be forfeited for the nonpayment of a premium, or interest or indebtedness on a premium, after the date on which the application for protection is received by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd20bda8d-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3974/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The protection provided by this subchapter applies during the insured’s period of military service and for a period of two years thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd20bda8e-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title IV, § 404, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s1"},"text":"Pub. L. 108–189, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2853"},"text":"117 Stat. 2853","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd20bda8f-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd20bda90-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd20bda91-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 544 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd20bda92-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 404 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"act 