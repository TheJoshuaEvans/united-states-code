{"tag":"section","attrib":{"id":"idd1520038-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1909"},"text":null,"children":[{"tag":"num","attrib":{"value":"1909"},"text":"§ 1909.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal year 1992 funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd1520039-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1909/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations to Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby authorized to be appropriated to the Fund for fiscal year 1992 the sum of $150,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd152003a-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s1909/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of obligations from Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During fiscal year 1992, there may be obligated from the Fund such amounts as may be provided in appropriations Acts, not to exceed $35,000,000. Amounts made available for obligation from the Fund for fiscal year 1992 shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd152003b-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/183/tVIII/s809"},"text":"Pub. L. 102–183, title VIII, § 809","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-04"},"text":"Dec. 4, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1277"},"text":"105 Stat. 1277","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
