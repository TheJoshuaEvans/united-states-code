{"tag":"section","attrib":{"id":"idd15de710-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2083"},"text":null,"children":[{"tag":"num","attrib":{"value":"2083"},"text":"§ 2083.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit for service while on military leave","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd15de711-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2083/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A participant who, during the period of any war or of any national emergency as proclaimed by the President or declared by the Congress, leaves the participant’s position in the Agency to enter military service shall not be considered, for purposes of this subchapter, as separated from the participant’s position in the Agency by reason of such military service, unless the participant applies for and receives a refund of contributions under this subchapter. Such a participant may not be considered as retaining such position in the Agency after ","children":[{"tag":"date","attrib":{"date":"1956-12-31"},"text":"December 31, 1956","children":[],"tail":", or upon the expiration of five years of such military service, whichever is later."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd15de712-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s2083/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except to the extent provided under section 2082(e) or 2082(h) of this title, contributions shall not be required covering periods of leave of absence from the Agency granted a participant while performing active service in the Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd15de713-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/tII/s253"},"text":"Pub. L. 88–643, title II, § 253","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s802"},"text":"Pub. L. 102–496, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3234"},"text":"106 Stat. 3234","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd15de714-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd15de715-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd15de716-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/643/s253"},"text":"section 253 of Pub. L. 88–643","children":[],"tail":", title II, "},{"tag":"date","attrib":{"date":"1964-10-13"},"text":"Oct. 13, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1052"},"text":"78 Stat. 1052","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/tV/s501/2"},"text":"Pub. L. 99–335, title V, § 501(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/622"},"text":"100 Stat. 622","children":[],"tail":", related to credit for service while on military leave and was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403"},"text":"section 403 of this title","children":[],"tail":" prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/88/643"},"text":"Pub. L. 88–643","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s802"},"text":"section 802 of Pub. L. 102–496","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd15de717-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd15de718-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of fourth month beginning after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s805"},"text":"section 805 of Pub. L. 102–496","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
