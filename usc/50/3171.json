{"tag":"section","attrib":{"id":"idd1bf8e78-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3171"},"text":null,"children":[{"tag":"num","attrib":{"value":"3171"},"text":"§ 3171.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stay of sanctions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any provision of law identified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3174"},"text":"section 3174 of this title","children":[],"tail":", the President may stay the imposition of an economic, cultural, diplomatic, or other sanction or related action by the United States Government concerning a foreign country, organization, or person when the President determines and reports to Congress in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3173"},"text":"section 3173 of this title","children":[],"tail":" that to proceed without delay would seriously risk the compromise of an ongoing criminal investigation directly related to the activities giving rise to the sanction or an intelligence source or method directly related to the activities giving rise to the sanction. Any such stay shall be effective for a period of time specified by the President, which period may not exceed 120 days, unless such period is extended in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3172"},"text":"section 3172 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd1bf8e79-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title IX, § 901, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/93/tIII/s303/a"},"text":"Pub. L. 104–93, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-01-06"},"text":"Jan. 6, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/964"},"text":"109 Stat. 964","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd1bf8e7a-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd1bf8e7b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd1bf8e7c-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s441"},"text":"section 441 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
