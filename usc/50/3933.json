{"tag":"section","attrib":{"id":"idd2072020-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3933"},"text":null,"children":[{"tag":"num","attrib":{"value":"3933"},"text":"§ 3933.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fines and penalties under contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2072021-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3933/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When an action for compliance with the terms of a contract is stayed pursuant to this chapter, a penalty shall not accrue for failure to comply with the terms of the contract during the period of the stay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2072022-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3933/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction or waiver of fines or penalties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a servicemember fails to perform an obligation arising under a contract and a penalty is incurred arising from that nonperformance, a court may reduce or waive the fine or penalty if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2072023-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3933/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the servicemember was in military service at the time the fine or penalty was incurred; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2072024-47c4-11f1-8bcf-c89722bddd2e","identifier":"/us/usc/t50/s3933/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the servicemember to perform the obligation was materially affected by such military service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2072025-47c4-11f1-8bcf-c89722bddd2e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"Oct. 17, 1940, ch. 888","children":[],"tail":", title II, § 203, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s1"},"text":"Pub. L. 108–189, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2843"},"text":"117 Stat. 2843","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2072026-47c4-11f1-8bcf-c89722bddd2e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2072027-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd2072028-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 523 of the former Appendix to this title prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd2072029-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 203 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"act Oct. 17, 1940, ch. 888","children":[],"tail":", art. II, "},{"tag":"ref","attrib":{"href":"/us/stat/54/1181"},"text":"54 Stat. 1181","children":[],"tail":", related to stay or vacation of execution of judgments and attachments, prior to the general amendment of this Act by "},{"tag":"ref","attrib":{"href":"/us/pl/108/189"},"text":"Pub. L. 108–189","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3934"},"text":"section 3934 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd207202a-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd207202b-47c4-11f1-8bcf-c89722bddd2e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any case not final before ","children":[{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s3"},"text":"section 3 of Pub. L. 108–189","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3901"},"text":"section 3901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
