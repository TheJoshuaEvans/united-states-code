{"tag":"section","attrib":{"id":"id146b9a58-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379dd–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"379dd–2"},"text":"§ 379dd–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities of the Food and Drug Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id146b9a59-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379dd–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner shall receive and assess the report submitted to the Commissioner by the Executive Director of the Foundation under section 379dd(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id146b9a5a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379dd–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning with fiscal year 2009, the Commissioner shall submit to Congress an annual report summarizing the incorporation of the information provided by the Foundation in the report described under section 379dd(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2) of this title and by other recipients of grants, contracts, memoranda of understanding, or cooperative agreements into regulatory and product review activities of the Food and Drug Administration."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id146b9a5b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379dd–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extramural grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this part and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360bbb–5"},"text":"section 360bbb–5 of this title","children":[],"tail":" shall have no effect on any grant, contract, memorandum of understanding, or cooperative agreement between the Food and Drug Administration and any other entity entered into before, on, or after "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"September 27, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id146b9a5c-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s772"},"text":"June 25, 1938, ch. 675, § 772","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/85/tVI/s601/b"},"text":"Pub. L. 110–85, title VI, § 601(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/897"},"text":"121 Stat. 897","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
