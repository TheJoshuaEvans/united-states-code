{"tag":"section","attrib":{"id":"id144a2f37-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379f"},"text":null,"children":[{"tag":"num","attrib":{"value":"379f"},"text":"§ 379f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery and retention of fees for freedom of information requests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id144a2f38-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Commissioner of Food and Drugs, may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id144a2f39-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set and charge fees, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/a/4/A"},"text":"section 552(a)(4)(A) of title 5","children":[],"tail":", to recover all reasonable costs incurred in processing requests made under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":" for records obtained or created under this chapter or any other Federal law for which responsibility for administration has been delegated to the Commissioner by the Secretary;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id144a2f3a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain all fees charged for such requests; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id144a2f3b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish an accounting system and procedures to control receipts and expenditures of fees received under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id144a2f3c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Commissioner of Food and Drugs shall not use fees received under this section for any purpose other than funding the processing of requests described in subsection (a)(1). Such fees shall not be used to reduce the amount of funds made to carry out other provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id144a2f3d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall supersede the right of a requester to obtain a waiver of fees pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/a/4/A"},"text":"section 552(a)(4)(A) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id144a2f3e-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s731"},"text":"June 25, 1938, ch. 675, § 731","children":[],"tail":", formerly § 711, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/635/tII/s201"},"text":"Pub. L. 101–635, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4584"},"text":"104 Stat. 4584","children":[],"tail":"; renumbered § 731, "},{"tag":"ref","attrib":{"href":"/us/pl/102/571/tI/s106/6"},"text":"Pub. L. 102–571, title I, § 106(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4499"},"text":"106 Stat. 4499","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id144a2f3f-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id144a2f40-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id144a2f41-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s379c"},"text":"section 379c of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/102/571"},"text":"Pub. L. 102–571","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
