l},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Fees under part 8 of subchapter C of chapter VII of the Federal Food, Drug, and Cosmetic Act [this subpart], as added by this title, shall be assessed for all biosimilar biological product applications received on or after ","children":[{"tag":"date","attrib":{"date":"2012-10-01"},"text":"October 1, 2012","children":[],"tail":", regardless of the date of the enactment of this title.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id1461fd1f-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/180/dF/tIV/s4007"},"text":"Pub. L. 117–180, div. F, title IV, § 4007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-09-30"},"text":"Sept. 30, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2167"},"text":"136 Stat. 2167","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/180/dF/tIV/s4007"},"text":"“Notwithstanding the amendments made by this title [see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/180/s4001/a"},"text":"section 4001(a) of Pub. L. 117–180","children":[],"tail":", set out as a Short Title of 2022 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"section 301 of this title","children":[],"tail":"], part 8 of subchapter C of chapter VII of the Federal Food, Drug, and Cosmetic Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s379j–51"},"text":"21 U.S.C. 379j–51","children":[],"tail":" et seq.), as in effect on the day before the date of the enactment of this title ["},{"tag":"date","attrib":{"date":"2022-09-30"},"text":"Sept. 30, 2022","children":[],"tail":"], shall continue to be in effect with respect to biosimilar biological product applications and supplements (as defined in such part as of such day) that were accepted by the Food and Drug Administration for filing on or after "},{"tag":"date","attrib":{"date":"2017-10-01"},"text":"October 1, 2017","children":[],"tail":", but before "},{"tag":"date","attrib":{"date":"2022-10-01"},"text":"October 1, 2022","children":[],"tail":", with respect to assessing and collecting any fee required by such part for a fiscal year prior to fiscal year 2023.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/52/tIV/s407"},"text":"Pub. L. 115–52, title IV, § 407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-18"},"text":"Aug. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1035"},"text":"131 Stat. 1035","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/52/tIV/s407"},"text":"“Notwithstanding the amendments made by this title [see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/52/s401/a"},"text":"section 401(a) of Pub. L. 115–52","children":[],"tail":", set out as a Short Title of 2017 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"section 301 of this title","children":[],"tail":"], part 8 of subchapter C of chapter VII of the Federal Food, Drug, and Cosmetic Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t21/s379j–51"},"text":"21 U.S.C. 379j–51","children":[],"tail":" et seq.], as in effect on the day before the date of the enactment of this title ["},{"tag":"date","attrib":{"date":"2017-08-18"},"text":"Aug. 18, 2017","children":[],"tail":"], shall continue to be in effect with respect to biosimilar biological product applications and supplements (as defined in such part as of such day) that were accepted by the Food and Drug Administration for filing on or after "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"October 1, 2012","children":[],"tail":", but before "},{"tag":"date","attrib":{"date":"2017-10-01"},"text":"October 1, 2017","children":[],"tail":", with respect to assessing and collecting any fee required by such part for a fiscal year prior to fiscal year 2018.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id1461fd20-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings Concerning Fees Relating to Biosimilar Biological Products","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/180/dF/tIV/s4001/b"},"text":"Pub. L. 117–180, div. F, title IV, § 4001(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-09-30"},"text":"Sept. 30, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2160"},"text":"136 Stat. 2160","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/180/dF/tIV/s4001/b"},"text":"“Congress finds that the fees authorized by the amendments made by this title [see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/180/s4001/a"},"text":"section 4001(a) of Pub. L. 117–180","children":[],"tail":", set out as a Short Title of 2022 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"section 301 of this title","children":[],"tail":"] will be dedicated to expediting the process for the review of biosimilar biological product applications, including postmarket safety activities, as set forth in the goals identified for purposes of part 8 of subchapter C of chapter VII of the Federal Food, Drug, and Cosmetic Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s379j–51"},"text":"21 U.S.C. 379j–51","children":[],"tail":" et seq.), in the letters from the Secretary of Health and Human Services to the Chairman of the Committee on Health, Education, Labor, and Pensions of the Senate and the Chairman of the Committee on Energy and Commerce of the House of Representatives, as set forth in the Congressional Record.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/52/tIV/s401/b"},"text":"Pub. L. 115–52, title IV, § 401(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-18"},"text":"Aug. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1028"},"text":"131 Stat. 1028","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/52/tIV/s401/b"},"text":"“The Congress finds that the fees authorized by the amendments made in this title [see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/52/s401/a"},"text":"section 401(a) of Pub. L. 115–52","children":[],"tail":", set out as a Short Title of 2017 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"section 301 of this title","children":[],"tail":"] will be dedicated to expediting the process for the review of biosimilar biological product applications, including postmarket safety activities, as set forth in the goals identified for purposes of part 8 of subchapter C of chapter VII of the Federal Food, Drug, and Cosmetic Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t21/s379j–51"},"text":"21 U.S.C. 379j–51","children":[],"tail":" et seq.], in the letters from the Secretary of Health and Human Services to the Chairman of the Committee on Health, Education, Labor, and Pensions of the Senate and the Chairman of the Committee on Energy and Commerce of the House of Representatives, as set forth in the Congressional Record.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/144/tIV/s401/b"},"text":"Pub. L. 112–144, title IV, § 401(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1026"},"text":"126 Stat. 1026","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/144/tIV/s401/b"},"text":"“The Congress finds that the fees authorized by the amendments made in this title [enacting this section and sections 379j–52 and 379j–53 of this title and amending sections 379d–4 and 379g of this title] will be dedicated to expediting the process for the review of biosimilar biological product applications, including postmarket safety activities, as set forth in the goals identified for purposes of part 8 of subchapter C of chapter VII of the Federal Food, Drug, and Cosmetic Act [this subpart], in the letters from the Secretary of Health and Human Services to the Chairman of the Committee on Health, Education, Labor, and Pensions of the Senate and the Chairman of the Committee on Energy and Commerce of the House of Representatives, as set forth in the Congressional Record.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
