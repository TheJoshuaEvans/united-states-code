{"tag":"section","attrib":{"id":"id13fb72f6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g"},"text":null,"children":[{"tag":"num","attrib":{"value":"355g"},"text":"§ 355g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilizing real world evidence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id13fb72f7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a program to evaluate the potential use of real world evidence—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13fb72f8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to help to support the approval of a new indication for a drug approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/c"},"text":"section 355(c) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13fb72f9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to help to support or satisfy postapproval study requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13fb72fa-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Real world evidence defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “real world evidence” means data regarding the usage, or the potential benefits or risks, of a drug derived from sources other than traditional clinical trials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13fb72fb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program framework","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13fb72fc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2016-12-13"},"text":"December 13, 2016","children":[],"tail":", the Secretary shall establish a draft framework for implementation of the program under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13fb72fd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of framework","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The framework shall include information describing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13fb72fe-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sources of real world evidence, including ongoing safety surveillance, observational studies, registries, claims, and patient-centered outcomes research activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13fde2ff-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gaps in data collection activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13fde300-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the standards and methodologies for collection and analysis of real world evidence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13fde301-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the priority areas, remaining challenges, and potential pilot opportunities that the program established under this section will address.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13fde302-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13fde303-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the program framework under this subsection, the Secretary shall consult with regulated industry, academia, medical professional organizations, representatives of patient advocacy organizations, consumer organizations, disease research foundations, and other interested parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13fde304-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The consultation under subparagraph (A) may be carried out through approaches such as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id13fde305-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public-private partnership with the entities described in such subparagraph in which the Secretary may participate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id13fde306-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contract, grant, or other arrangement, as the Secretary determines appropriate, with such a partnership or an independent research organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id13fde307-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public workshops with the entities described in such subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13fde308-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2016-12-13"},"text":"December 13, 2016","children":[],"tail":", and in accordance with the framework established under subsection (c), implement the program to evaluate the potential use of real world evidence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13fde309-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance for industry","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13fde30a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" utilize the program established under subsection (a), its activities, and any subsequent pilots or written reports, to inform a guidance for industry on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13fde30b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the circumstances under which sponsors of drugs and the Secretary may rely on real world evidence for the purposes described in paragraphs (1) and (2) of subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13fde30c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate standards and methodologies for collection and analysis of real world evidence submitted for such purposes;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13fde30d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"2016-12-13"},"text":"December 13, 2016","children":[],"tail":", issue draft guidance for industry as described in paragraph (1); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13fde30e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 18 months after the close of the public comment period for the draft guidance described in paragraph (2), issue revised draft guidance or final guidance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13fde30f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13fde310-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), nothing in this section prohibits the Secretary from using real world evidence for purposes not specified in this section, provided the Secretary determines that sufficient basis exists for any such nonspecified use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13fde311-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards of evidence and Secretary’s authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall not be construed to alter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13fde312-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the standards of evidence under—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id13fde313-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (c) or (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"section 355 of this title","children":[],"tail":", including the substantial evidence standard in such subsection (d); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id13fde314-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s262/a"},"text":"section 262(a) of title 42","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13fde315-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355g/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary’s authority to require postapproval studies or clinical trials, or the standards of evidence under which studies or trials are evaluated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id13fde316-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s505F"},"text":"June 25, 1938, ch. 675, § 505F","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIII/s3022"},"text":"Pub. L. 114–255, div. A, title III, § 3022","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1096"},"text":"130 Stat. 1096","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/52/tIX/s901/c"},"text":"Pub. L. 115–52, title IX, § 901(c)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2017-08-18"},"text":"Aug. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1076"},"text":"131 Stat. 1076","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id13fde317-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id13fde318-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id13fde319-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/52/s901/c"},"text":"Pub. L. 115–52, § 901(c)","children":[],"tail":", substituted “traditional” for “randomized”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/52/s901/d"},"text":"Pub. L. 115–52, § 901(d)","children":[],"tail":", substituted “3 years” for “2 years”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
