{"tag":"section","attrib":{"id":"id14811da6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399a"},"text":null,"children":[{"tag":"num","attrib":{"value":"399a"},"text":"§ 399a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of the Chief Scientist","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14811da7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish within the Office of the Commissioner an office to be known as the Office of the Chief Scientist. The Secretary shall appoint a Chief Scientist to lead such Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14811da8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of the Office","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office of the Chief Scientist shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14811da9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oversee, coordinate, and ensure quality and regulatory focus of the intramural research programs of the Food and Drug Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14811daa-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" track and, to the extent necessary, coordinate intramural research awards made by each center of the Administration or science-based office within the Office of the Commissioner, and ensure that there is no duplication of research efforts supported by the Reagan-Udall Foundation for the Food and Drug Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14811dab-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and advocate for a budget to support intramural research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14811dac-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a peer review process by which intramural research can be evaluated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14811dad-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify and solicit intramural research proposals from across the Food and Drug Administration through an advisory board composed of employees of the Administration that shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14811dae-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399a/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of each of the centers and the science-based offices within the Office of the Commissioner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14811daf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399a/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experts on trial design, epidemiology, demographics, pharmacovigilance, basic science, and public health; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14811db0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop postmarket safety performance measures that are as measurable and rigorous as the ones already developed for premarket review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14811db1-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s1010"},"text":"June 25, 1938, ch. 675, § 1010","children":[],"tail":", formerly § 910, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/85/tVI/s602"},"text":"Pub. L. 110–85, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/898"},"text":"121 Stat. 898","children":[],"tail":"; renumbered § 1010, "},{"tag":"ref","attrib":{"href":"/us/pl/111/31/dA/tI/s101/b/2"},"text":"Pub. L. 111–31, div. A, title I, § 101(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-06-22"},"text":"June 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1784"},"text":"123 Stat. 1784","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
