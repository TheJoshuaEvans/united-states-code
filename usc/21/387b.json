{"tag":"section","attrib":{"id":"id14750f29-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387b"},"text":null,"children":[{"tag":"num","attrib":{"value":"387b"},"text":"§ 387b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adulterated tobacco products","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A tobacco product shall be deemed to be adulterated if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14750f2a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it consists in whole or in part of any filthy, putrid, or decomposed substance, or is otherwise contaminated by any added poisonous or added deleterious substance that may render the product injurious to health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14750f2b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it has been prepared, packed, or held under insanitary conditions whereby it may have been contaminated with filth, or whereby it may have been rendered injurious to health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14750f2c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its package is composed, in whole or in part, of any poisonous or deleterious substance which may render the contents injurious to health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14750f2d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manufacturer or importer of the tobacco product fails to pay a user fee assessed to such manufacturer or importer pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s387s"},"text":"section 387s of this title","children":[],"tail":" by the date specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s387s"},"text":"section 387s of this title","children":[],"tail":" or by the 30th day after final agency action on a resolution of any dispute as to the amount of such fee;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14750f2e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is, or purports to be or is represented as, a tobacco product which is subject to a tobacco product standard established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s387g"},"text":"section 387g of this title","children":[],"tail":" unless such tobacco product is in all respects in conformity with such standard;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14750f2f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14750f30-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s387j/a"},"text":"section 387j(a) of this title","children":[],"tail":" to have premarket review and does not have an order in effect under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s387j/c/1/A/i"},"text":"section 387j(c)(1)(A)(i) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14750f31-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is in violation of an order under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s387j/c/1/A"},"text":"section 387j(c)(1)(A) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14750f32-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methods used in, or the facilities or controls used for, its manufacture, packing, or storage are not in conformity with applicable requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s387f/e/1"},"text":"section 387f(e)(1) of this title","children":[],"tail":" or an applicable condition prescribed by an order under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s387f/e/2"},"text":"section 387f(e)(2) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14750f33-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s387k"},"text":"section 387k of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14750f34-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s902"},"text":"June 25, 1938, ch. 675, § 902","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/31/dA/tI/s101/b/3"},"text":"Pub. L. 111–31, div. A, title I, § 101(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-06-22"},"text":"June 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1787"},"text":"123 Stat. 1787","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14750f35-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14750f36-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id14750f37-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 902 of act ","children":[{"tag":"date","attrib":{"date":"1938-06-25"},"text":"June 25, 1938","children":[],"tail":", was renumbered section 1002. Subsec. (a) of section 1002 is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"section 301 of this title","children":[],"tail":". Subsecs. (b) and (c) of section 1002 are classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s392"},"text":"section 392 of this title","children":[],"tail":". Subsec. (d) of section 1002 is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s392"},"text":"section 392 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
