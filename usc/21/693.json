{"tag":"section","attrib":{"id":"id148f4e76-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s693"},"text":null,"children":[{"tag":"num","attrib":{"value":"693"},"text":"§ 693.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection of dairy products for export","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The act of ","children":[{"tag":"date","attrib":{"date":"1891-03-03"},"text":"March 3, 1891","children":[],"tail":", as amended, for the inspection of live cattle and products thereof, shall be deemed to include dairy products intended for exportation to any foreign country, and the Secretary of Agriculture may apply, under rules and regulations to be prescribed by him, the provisions of said act for inspection and certification appropriate for ascertaining the purity and quality of such products, and may cause the same to be so marked, stamped, or labeled as to secure their identity and make known in the markets of foreign countries to which they may be sent from the United States their purity, quality, and grade; and all the provisions of said act relating to live cattle and products thereof for export shall apply to dairy products so inspected and certified."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id1491bf77-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1908-05-23/ch192"},"text":"May 23, 1908, ch. 192","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/254"},"text":"35 Stat. 254","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1491bf78-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1491bf79-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id1491bf7a-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1891-03-03"},"text":"March 3, 1891","children":[],"tail":", referred to in text, is "},{"tag":"ref","attrib":{"href":"/us/act/1891-03-03/ch555"},"text":"act Mar. 3, 1891, ch. 555","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/1089"},"text":"26 Stat. 1089","children":[],"tail":", which was superseded by "},{"tag":"ref","attrib":{"href":"/us/act/1907-03-04/ch2907"},"text":"act Mar. 4, 1907, ch. 2907","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/1260"},"text":"34 Stat. 1260","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/act/1938-06-29/ch810"},"text":"act June 29, 1938, ch. 810","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1235"},"text":"52 Stat. 1235","children":[],"tail":" (formerly classified to section 71 et seq. of this title). "},{"tag":"ref","attrib":{"href":"/us/act/1907-03-04/ch2907"},"text":"Act Mar. 4, 1907, ch. 2907","children":[],"tail":", was generally revised by "},{"tag":"ref","attrib":{"href":"/us/pl/90/201"},"text":"Pub. L. 90–201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-15"},"text":"Dec. 15, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/584"},"text":"81 Stat. 584","children":[],"tail":", and is classified to this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id1491bf7b-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Federal Meat Inspection Act which is classified to subchapters I to IV–A of this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to sections 94a and 132 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
