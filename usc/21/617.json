{"tag":"section","attrib":{"id":"id148d0426-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s617"},"text":null,"children":[{"tag":"num","attrib":{"value":"617"},"text":"§ 617.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clearance prohibited to vessel carrying meat for export without inspector’s certificate","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No clearance shall be given to any vessel having on board any fresh, salted, canned, corned, or packed beef, mutton, pork, goat or equine meat for export to and sale in a foreign country from any port in the United States, until the owner or shipper thereof shall obtain from an inspector appointed under the provisions of this chapter a certificate that the said amenable species were sound and healthy at the time of inspection, and that their meat is sound and wholesome, unless the Secretary shall have waived the requirements of such certificate for the country to which said amenable species or meats are to be exported.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id148d0427-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1907-03-04/ch2907"},"text":"Mar. 4, 1907, ch. 2907","children":[],"tail":", title I, § 17, formerly 15th par., "},{"tag":"ref","attrib":{"href":"/us/stat/34/1263"},"text":"34 Stat. 1263","children":[],"tail":"; renumbered § 17 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/90/201"},"text":"Pub. L. 90–201","children":[],"tail":", §§ 1, 3(b), 12(a), (g), "},{"tag":"date","attrib":{"date":"1967-12-15"},"text":"Dec. 15, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/584"},"text":"81 Stat. 584","children":[],"tail":", 588, 592; "},{"tag":"ref","attrib":{"href":"/us/pl/109/97/tVII/s798"},"text":"Pub. L. 109–97, title VII, § 798[(a)]","children":[],"tail":"(1), "},{"tag":"date","attrib":{"date":"2005-11-10"},"text":"Nov. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2166"},"text":"119 Stat. 2166","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id148d0428-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id148d0429-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id148d042a-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s85"},"text":"section 85 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id148d042b-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/97"},"text":"Pub. L. 109–97","children":[],"tail":" substituted “amenable species” for “cattle, sheep, swine, goats, horses, mules, and other equines” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/201"},"text":"Pub. L. 90–201","children":[],"tail":", §§ 3(b), 12(a), (g), struck out “of Agriculture” after “Secretary”, included horses, mules, and other equines in the list of animals, and substituted “goat or equine meat” for “or goat meat, being the meat of animals killed after "},{"tag":"date","attrib":{"date":"1907-03-04"},"text":"March 4, 1907","children":[],"tail":", or except as hereinbefore provided”, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id148d042c-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id148d042d-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/97"},"text":"Pub. L. 109–97","children":[],"tail":" effective the day after 120 days after "},{"tag":"date","attrib":{"date":"2005-11-10"},"text":"Nov. 10, 2005","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/97/s798/b"},"text":"section 798(b) of Pub. L. 109–97","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s601"},"text":"section 601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id148d042e-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1967 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/201"},"text":"Pub. L. 90–201","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1967-12-15"},"text":"Dec. 15, 1967","children":[],"tail":", except that with respect to equines (other than horses) and their carcasses and parts thereof, meat, and meat food products thereof, amendment effective upon expiration of sixty days after "},{"tag":"date","attrib":{"date":"1967-12-15"},"text":"Dec. 15, 1967","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/201/s20/b"},"text":"section 20(b) of Pub. L. 90–201","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s601"},"text":"section 601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
