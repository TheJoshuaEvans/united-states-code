{"tag":"section","attrib":{"id":"id143bd833-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"360eee–4"},"text":"§ 360eee–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniform national policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id143bd834-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Product tracing and other requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning on ","children":[{"tag":"date","attrib":{"date":"2013-11-27"},"text":"November 27, 2013","children":[],"tail":", no State or political subdivision of a State may establish or continue in effect any requirements for tracing products through the distribution system (including any requirements with respect to statements of distribution history, transaction history, transaction information, or transaction statement of a product as such product changes ownership in the supply chain, or verification, investigation, disposition, notification, or recordkeeping relating to such systems, including paper or electronic pedigree systems or for tracking and tracing drugs throughout the distribution system) which are inconsistent with, more stringent than, or in addition to, any requirements applicable under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s353/e"},"text":"section 353(e) of this title","children":[],"tail":" or this part (or regulations issued thereunder), or which are inconsistent with—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id143bd835-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–4/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any waiver, exception, or exemption pursuant to section 360eee or 360eee–1 of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143bd836-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–4/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any restrictions specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360eee–1"},"text":"section 360eee–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id143bd837-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wholesale distributor and third-party logistics provider standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id143bd838-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–4/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning on ","children":[{"tag":"date","attrib":{"date":"2013-11-27"},"text":"November 27, 2013","children":[],"tail":", no State or political subdivision of a State may establish or continue any standards, requirements, or regulations with respect to wholesale prescription drug distributor or third-party logistics provider licensure that are inconsistent with, less stringent than, directly related to, or covered by the standards and requirements applicable under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s353/e"},"text":"section 353(e) of this title","children":[],"tail":", in the case of a wholesale distributor, or "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360eee–3"},"text":"section 360eee–3 of this title","children":[],"tail":", in the case of a third-party logistics provider."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143bd839-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–4/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State regulation of third-party logistics providers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No State shall regulate third-party logistics providers as wholesale distributors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143bd83a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–4/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), a State may administer fee collections for effectuating the wholesale drug distributor and third-party logistics provider licensure requirements under sections 353(e), 360eee–2, and 360eee–3 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143bd83b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–4/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement, suspension, and revocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraph (1), a State—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id143bd83c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–4/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may take administrative action, including fines, to enforce a requirement promulgated by the State in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s353/e"},"text":"section 353(e) of this title","children":[],"tail":" or this part;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143e483d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–4/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide for the suspension or revocation of licenses issued by the State for violations of the laws of such State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143e483e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–4/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon conviction of violations of Federal, State, or local drug laws or regulations, may provide for fines, imprisonment, or civil penalties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143e483f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–4/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may regulate activities of licensed entities in a manner that is consistent with product tracing requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360eee–1"},"text":"section 360eee–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id143e4840-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to preempt State requirements related to the distribution of prescription drugs if such requirements are not related to product tracing as described in subsection (a) or wholesale distributor and third-party logistics provider licensure as described in subsection (b) applicable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s353/e"},"text":"section 353(e) of this title","children":[],"tail":" or this part (or regulations issued thereunder)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id143e4841-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s585"},"text":"June 25, 1938, ch. 675, § 585","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/54/tII/s205"},"text":"Pub. L. 113–54, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-11-27"},"text":"Nov. 27, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/638"},"text":"127 Stat. 638","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
