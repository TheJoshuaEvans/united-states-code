{"tag":"section","attrib":{"id":"id143260d8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3b"},"text":null,"children":[{"tag":"num","attrib":{"value":"360bbb–3b"},"text":"§ 360bbb–3b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Products held for emergency use","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is not a violation of any section of this chapter or of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"42 U.S.C. 201","children":[],"tail":" et seq.] for a government entity (including a Federal, State, local, or tribal government entity), or a person acting on behalf of such a government entity, to introduce into interstate commerce a product (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360bbb–3/a/4"},"text":"section 360bbb–3(a)(4) of this title","children":[],"tail":") intended for emergency use, if that product—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id143260d9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is intended to be held and not used; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143260da-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is held and not used, unless and until that product—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id143260db-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is approved, cleared, or licensed under section 355, 360(k), 360b, or 360e of this title or section 351 of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"42 U.S.C. 262","children":[],"tail":"] or conditionally approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360ccc"},"text":"section 360ccc of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143260dc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is authorized for investigational use under section 355, 360b, or 360j of this title or section 351 of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"42 U.S.C. 262","children":[],"tail":"]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143260dd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is authorized for use under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360bbb–3"},"text":"section 360bbb–3 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360bbb–3a"},"text":"section 360bbb–3a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id143260de-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s564B"},"text":"June 25, 1938, ch. 675, § 564B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/5/tIII/s302/d"},"text":"Pub. L. 113–5, title III, § 302(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-13"},"text":"Mar. 13, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/185"},"text":"127 Stat. 1