ag":"note","attrib":{"topic":"amendments","id":"id143260e2-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Par. (2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22/s705/d/1"},"text":"Pub. L. 116–22, § 705(d)(1)","children":[],"tail":", inserted comma after “355”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22/s705/d/2"},"text":"Pub. L. 116–22, § 705(d)(2)","children":[],"tail":", inserted “or "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360bbb–3a"},"text":"section 360bbb–3a of this title","children":[],"tail":"” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Par. (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s3088/d/1"},"text":"Pub. L. 114–255, § 3088(d)(1)","children":[],"tail":", substituted “360b, or 360e of this title” for “or 360e of this title” and inserted “or conditionally approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360ccc"},"text":"section 360ccc of this title","children":[],"tail":"” after “Public Health Service Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s3088/d/2"},"text":"Pub. L. 114–255, § 3088(d)(2)","children":[],"tail":", substituted “360b, or 360j of this title” for “or 360j of this title”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
