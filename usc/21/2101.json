{"tag":"section","attrib":{"id":"id14d22400-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2101"},"text":null,"children":[{"tag":"num","attrib":{"value":"2101"},"text":"§ 2101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d22401-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the safety and integrity of the United States food supply are vital to public health, to public confidence in the food supply, and to the success of the food sector of the Nation’s economy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d22402-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" illnesses and deaths of individuals and companion animals caused by contaminated food—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d22403-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2101/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have contributed to a loss of public confidence in food safety; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d22404-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2101/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have caused significant economic losses to manufacturers and producers not responsible for contaminated food items;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d22405-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2101/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the task of preserving the safety of the food supply of the United States faces tremendous pressures with regard to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d22406-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2101/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emerging pathogens and other contaminants and the ability to detect all forms of contamination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d22407-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2101/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an increasing volume of imported food from a wide variety of countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d22408-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2101/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a shortage of adequate resources for monitoring and inspection;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d22409-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2101/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" according to the Economic Research Service of the Department of Agriculture, the United States is increasing the amount of food that it imports such that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d2240a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2101/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from 2003 to 2007, the value of food imports has increased from $45,600,000,000 to $64,000,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d2240b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2101/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imported food accounts for 13 percent of the average American diet including 31 percent of fruits, juices, and nuts, 9.5 percent of red meat, and 78.6 percent of fish and shellfish; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d2240c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2101/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of full-time equivalent Food and Drug Administration employees conducting inspections has decreased from 2003 to 2007.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14d2240d-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/85/tX/s1001"},"text":"Pub. L. 110–85, title X, § 1001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/962"},"text":"121 Stat. 962","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
