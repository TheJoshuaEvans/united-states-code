{"tag":"section","attrib":{"id":"id14882214-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473"},"text":null,"children":[{"tag":"num","attrib":{"value":"473"},"text":"§ 473.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for improvements to meat and poultry facilities to allow for interstate shipment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14882215-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make grants to meat and poultry slaughter and processing facilities described in subsection (b) (including such facilities operating under State inspection or such facilities that are exempt from Federal inspection) to assist such facilities with respect to costs incurred in making improvements to such facilities and carrying out other planning activities necessary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14882216-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain a Federal grant of inspection under the Federal Meat Inspection Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s601"},"text":"21 U.S.C. 601","children":[],"tail":" et seq.) or the Poultry Products Inspection Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s451"},"text":"21 U.S.C. 451","children":[],"tail":" et seq.), as applicable; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14882217-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to operate as a State-inspected facility that is compliant with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14882218-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Meat Inspection Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s601"},"text":"21 U.S.C. 601","children":[],"tail":" et seq.) under the cooperative interstate shipment program established under section 501 of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s683"},"text":"21 U.S.C. 683","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14882219-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Poultry Products Inspection Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s451"},"text":"21 U.S.C. 451","children":[],"tail":" et seq.) under the cooperative interstate shipment program established under section 31 of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s472"},"text":"21 U.S.C. 472","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1488221a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible facilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for a grant under this section, a meat or poultry slaughter or processing facility shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1488221b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in operation as of the date on which the facility submits to the Secretary an application for the grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1488221c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" seeking—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1488221d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain a Federal grant of inspection described in subsection (a)(1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1488221e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be eligible for inspection under a cooperative interstate shipment program described in subparagraph (A) or (B), as applicable, of subsection (a)(2), in a State that participates in that program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1488221f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A facility that receives a grant under this section may use the grant amount for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14882220-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the modernization or expansion of existing facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14882221-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the modernization of equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14882222-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with packaging and labeling requirements under applicable law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14882223-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with safety requirements under applicable law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14882224-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of processes to ensure food safety; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14882225-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other purposes as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14882226-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14882227-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a grant under this section shall not exceed $200,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14882228-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As a condition of receiving a grant under this section, a grant recipient shall agree that the grant recipient shall make a payment (or payments) to the Secretary in an amount equal to the amount of the grant if the recipient, within 36 months of receiving such grant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14882229-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as applicable—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id1488222a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not subject to inspection under the Federal Meat Inspection Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s601"},"text":"21 U.S.C. 601","children":[],"tail":" et seq.) or the Poultry Products Inspection Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s451"},"text":"21 U.S.C. 451","children":[],"tail":" et seq.), as applicable; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1488222b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not eligible for inspection under a cooperative interstate shipment program described in subparagraph (A) or (B), as applicable, of subsection (a)(2); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1488222c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not making a good faith effort to be subject to such inspection or to be eligible under such a cooperative interstate shipment program, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1488222d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1488222e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require a recipient of a grant under this section to provide matching non-Federal funds in an amount equal to the amount of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1488222f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not require any recipient of a grant under this section to provide matching funds with respect to a grant awarded in fiscal year 2021 and fiscal year 2022.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14882230-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14882231-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports on grants made","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning not later than 1 year after the date on which the first grant is awarded under this section, and continuing annually thereafter through the year that is 10 years after the date on which the final grant is awarded under this section, the Secretary shall submit to the Committee on Agriculture and the Committee on Appropriations of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry and the Committee on Appropriations of the Senate a report on grants made under this section, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14882232-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any facilities that used a grant awarded under this section to carry out eligible activities described in subsection (c) during the year covered by the report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14882233-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operational status of facilities that were awarded grants under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14882234-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on the cooperative interstate shipment program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall submit to the Committee on Agriculture and the Committee on Appropriations of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry and the Committee on Appropriations of the Senate a report describing any recommendations, developed in consultation with all States, for possible improvements to the cooperative interstate shipment programs under section 501 of the Federal Meat Inspection Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s683"},"text":"21 U.S.C. 683","children":[],"tail":") and section 31 of the Poultry Products Inspection Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s472"},"text":"21 U.S.C. 472","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14882235-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s473/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds of the Treasury not otherwise appropriated, there is appropriated to carry out this section $60,000,000 for the period of fiscal years 2021 through 2023, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14882236-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/tVII/s764"},"text":"Pub. L. 116–260, div. N, title VII, § 764","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2115"},"text":"134 Stat. 2115","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dA/tVII/s776"},"text":"Pub. L. 117–103, div. A, title VII, § 776","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/99"},"text":"136 Stat. 99","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14882237-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14882238-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14882239-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Meat Inspection Act, referred to in subsecs. (a)(1), (2)(A), and (d)(2)(A)(i), is titles I to V of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1907-03-04/ch2907"},"text":"act Mar. 4, 1907, ch. 2907","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/201"},"text":"Pub. L. 90–201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-15"},"text":"Dec. 15, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/584"},"text":"81 Stat. 584","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tXI/s11015/a"},"text":"Pub. L. 110–246, title XI, § 11015(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2124"},"text":"122 Stat. 2124","children":[],"tail":", which are classified generally to subchapters I to IV–A (§ 601 et seq.) of chapter 12 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s601"},"text":"section 601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Poultry Products Inspection Act, referred to in subsecs. (a)(1), (2)(B), and (d)(2)(A)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/172"},"text":"Pub. L. 85–172","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-08-28"},"text":"Aug. 28, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/441"},"text":"71 Stat. 441","children":[],"tail":", which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s451"},"text":"section 451 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id1488223a-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Consolidated Appropriations Act, 2021, and not as part of the Poultry Products Inspection Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id1488223b-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (d)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":" inserted “and fiscal year 2022” after “fiscal year 2021”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1488223c-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id1488223d-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “Secretary” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/s760"},"text":"section 760 of div. N of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s5936a"},"text":"section 5936a of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
