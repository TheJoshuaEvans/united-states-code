{"tag":"section","attrib":{"id":"id14d6defd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2252"},"text":null,"children":[{"tag":"num","attrib":{"value":"2252"},"text":"§ 2252.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with international agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this Act (or an amendment made by this Act) shall be construed in a manner inconsistent with the agreement establishing the World Trade Organization or any other treaty or international agreement to which the United States is a party.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id14d6defe-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/353/tIV/s404"},"text":"Pub. L. 111–353, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3972"},"text":"124 Stat. 3972","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14d6deff-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14d6df00-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14d6df01-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/353"},"text":"Pub. L. 111–353","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3885"},"text":"124 Stat. 3885","children":[],"tail":", known as the FDA Food Safety Modernization Act, which enacted this chapter and sections 350g to 350"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–1, 379j–31, 384a to 384d, 399c, and 399d of this title, "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7625"},"text":"section 7625 of Title 7","children":[],"tail":", Agriculture, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s280g–16"},"text":"section 280g–16 of Title 42","children":[],"tail":", The Public Health and Welfare, amended sections 331, 333, 334, 350b to 350d, 350f, 374, 381, 393, and 399 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s247b–20"},"text":"section 247b–20 of Title 42","children":[],"tail":", and enacted provisions set out as notes under sections 331, 334, 342, 350b, 350d, 350e, 350g to 350j, 350"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":", and 381 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s2201"},"text":"section 2201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
