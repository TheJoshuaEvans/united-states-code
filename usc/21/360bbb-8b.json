{"tag":"section","attrib":{"id":"id1434d231-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8b"},"text":null,"children":[{"tag":"num","attrib":{"value":"360bbb–8b"},"text":"§ 360bbb–8b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of clinical investigation data from outside the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1434d232-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining whether to approve, license, or clear a drug, biological product, or device pursuant to an application submitted under this subchapter, the Secretary shall accept data from clinical investigations conducted outside of the United States, including the European Union, if the applicant demonstrates that such data are adequate under applicable standards to support approval, licensure, or clearance of the drug, biological product, or device in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1434d233-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to sponsor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary finds under subsection (a) that the data from clinical investigations conducted outside the United States, including in the European Union, are inadequate for the purpose of making a determination on approval, clearance, or licensure of a drug, biological product, or device pursuant to an application submitted under this subchapter, the Secretary shall provide written notice to the sponsor of the application of such finding and include the rationale for such finding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1434d234-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s569B"},"text":"June 25, 1938, ch. 675, § 569B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/144/tXI/s1123"},"text":"Pub. L. 112–144, title XI, § 1123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1113"},"text":"126 Stat. 1113","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIII/s3101/a/2/Q"},"text":"Pub. L. 114–255, div. A, title III, § 3101(a)(2)(Q)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1155"},"text":"130 Stat. 1155","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1434d235-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1434d236-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id1434d237-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","children":[],"tail":" substituted “drug, biological product, or device” for “drug or device” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
