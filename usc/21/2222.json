{"tag":"section","attrib":{"id":"id14d4953c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2222"},"text":null,"children":[{"tag":"num","attrib":{"value":"2222"},"text":"§ 2222.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated consortium of laboratory networks","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14d4953d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2222/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Homeland Security, in coordination with the Secretary of Health and Human Services, the Secretary of Agriculture, the Secretary of Commerce, and the Administrator of the Environmental Protection Agency, shall maintain an agreement through which relevant laboratory network members, as determined by the Secretary of Homeland Security, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d4953e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2222/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree on common laboratory methods in order to reduce the time required to detect and respond to foodborne illness outbreaks and facilitate the sharing of knowledge and information relating to animal health, agriculture, and human health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d4953f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2222/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify means by which laboratory network members could work cooperatively—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d49540-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2222/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to optimize national laboratory preparedness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d49541-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2222/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide surge capacity during emergencies; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d49542-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2222/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage in ongoing dialogue and build relationships that will support a more effective and integrated response during emergencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d49543-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2222/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Homeland Security shall, on a biennial basis, submit to the relevant committees of Congress, and make publicly available on the Internet Web site of the Department of Homeland Security, a report on the progress of the integrated consortium of laboratory networks, as established under subsection (a), in carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14d49544-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/353/tII/s203"},"text":"Pub. L. 111–353, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3929"},"text":"124 Stat. 3929","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
