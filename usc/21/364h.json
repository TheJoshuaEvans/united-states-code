{"tag":"section","attrib":{"id":"id1440b9ff-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364h"},"text":null,"children":[{"tag":"num","attrib":{"value":"364h"},"text":"§ 364h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small businesses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1440ba00-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Responsible persons, and owners and operators of facilities, whose average gross annual sales in the United States of cosmetic products for the previous 3-year period is less than $1,000,000, adjusted for inflation, and who do not engage in the manufacturing or processing of the cosmetic products described in subsection (b), shall be considered small businesses and not subject to the requirements of section 364b or 364c of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1440ba01-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements applicable to all manufacturers and processors of cosmetics","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The exemptions under subsection (a) shall not apply to any responsible person or facility engaged in the manufacturing or processing of any of the following products:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1440ba02-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cosmetic products that regularly come into contact with mucus membrane of the eye under conditions of use that are customary or usual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1440ba03-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cosmetic products that are injected.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1440ba04-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364h/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cosmetic products that are intended for internal use.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1440ba05-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364h/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cosmetic products that are intended to alter appearance for more than 24 hours under conditions of use that are customary or usual and removal by the consumer is not part of such conditions of use that are customary or usual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1440ba06-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s612"},"text":"June 25, 1938, ch. 675, § 612","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tIII/s3502"},"text":"Pub. L. 117–328, div. FF, title III, § 3502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5857"},"text":"136 Stat. 5857","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1440ba07-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1440ba08-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id1440ba09-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction; Confidentiality","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s3502"},"text":"section 3502 of Pub. L. 117–328","children":[],"tail":", which enacted this section, to be construed to authorize the disclosure of information that is prohibited from disclosure under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s331/j"},"text":"section 331(j) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1905"},"text":"section 1905 of title 18","children":[],"tail":" or that is subject to withholding under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/4"},"text":"section 552(b)(4) of title 5","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/s3503/c/2"},"text":"section 3503(c)(2) of Pub. L. 117–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s364"},"text":"section 364 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
