{"tag":"section","attrib":{"id":"id13aa6c8a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s210"},"text":null,"children":[{"tag":"num","attrib":{"value":"210"},"text":"§ 210.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pharmacist; unauthorized use of title","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any person whose permanent allegiance is due to the United States, not legally licensed as a pharmacist, to take, use, or exhibit the title of pharmacist, or licensed or registered pharmacist, or the title of druggist or apothecary, or any other title or description of like import.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id13aa6c8b-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1915-03-03/ch74/s10"},"text":"Mar. 3, 1915, ch. 74, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/821"},"text":"38 Stat. 821","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
