{"tag":"section","attrib":{"id":"id14b57366-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s887"},"text":null,"children":[{"tag":"num","attrib":{"value":"887"},"text":"§ 887.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination and consolidation of post-seizure administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Attorney General and the Secretary of the Treasury shall take such action as may be necessary to develop and maintain a joint plan to coordinate and consolidate post-seizure administration of property seized under this subchapter, subchapter II, or provisions of the customs laws relating to controlled substances.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id14b57367-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/tII/s517"},"text":"Pub. L. 91–513, title II, § 517","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6078/a"},"text":"Pub. L. 100–690, title VI, § 6078(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4325"},"text":"102 Stat. 4325","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
