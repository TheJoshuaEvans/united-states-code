{"tag":"section","attrib":{"id":"id149b3589-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s821"},"text":null,"children":[{"tag":"num","attrib":{"value":"821"},"text":"§ 821.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Attorney General is authorized to promulgate rules and regulations and to charge reasonable fees relating to the registration and control of the manufacture, distribution, and dispensing of controlled substances and to listed chemicals.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id149b358a-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/tII/s301"},"text":"Pub. L. 91–513, title II, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1253"},"text":"84 Stat. 1253","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/200/s3/a"},"text":"Pub. L. 103–200, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-17"},"text":"Dec. 17, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2336"},"text":"107 Stat. 2336","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/dB/tVI/s633/b"},"text":"Pub. L. 108–447, div. B, title VI, § 633(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2922"},"text":"118 Stat. 2922","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id149b358b-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id149b358c-3a70-11f1-b089-c1e1e512a22d"},"text":null,"childre