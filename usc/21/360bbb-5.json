{"tag":"section","attrib":{"id":"id1434d1aa-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"360bbb–5"},"text":"§ 360bbb–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Critical Path Public-Private Partnerships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1434d1ab-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Commissioner of Food and Drugs, may enter into collaborative agreements, to be known as Critical Path Public-Private Partnerships, with one or more eligible entities to implement the Critical Path Initiative of the Food and Drug Administration by developing innovative, collaborative projects in research, education, and outreach for the purpose of fostering medical product innovation, enabling the acceleration of medical product development, manufacturing, and translational therapeutics, and enhancing medical product safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1434d1ac-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible entity” means an entity that meets each of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1434d1ad-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The entity is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1434d1ae-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":") or a consortium of such institutions; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1434d1af-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":" and exempt from tax under section 501(a) of such title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d1b0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The entity has experienced personnel and clinical and other technical expertise in the biomedical sciences, which may include graduate training programs in areas relevant to priorities of the Critical Path Initiative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d1b1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The entity demonstrates to the Secretary’s satisfaction that the entity is capable of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1434d1b2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" developing and critically evaluating tools, methods, and processes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id1434d1b3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase efficiency, predictability, and productivity of medical product development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1434d1b4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to more accurately identify the benefits and risks of new and existing medical products;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1434d1b5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing partnerships, consortia, and collaborations with health care practitioners and other providers of health care goods or services; pharmacists; pharmacy benefit managers and purchasers; health maintenance organizations and other managed health care organizations; health care insurers; government agencies; patients and consumers; manufacturers of prescription drugs, biological products, diagnostic technologies, and devices; and academic scientists; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1434d1b6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" securing funding for the projects of a Critical Path Public-Private Partnership from Federal and nonfederal governmental sources, foundations, and private individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1434d1b7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not enter into a collaborative agreement under subsection (a) unless the eligible entity involved provides an assurance that the entity will not accept funding for a Critical Path Public-Private Partnership project from any organization that manufactures or distributes products regulated by the Food and Drug Administration unless the entity provides assurances in its agreement with the Food and Drug Administration that the results of the Critical Path Public-Private Partnership project will not be influenced by any source of funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1434d1b8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2007-09-27"},"text":"September 27, 2007","children":[],"tail":", and annually thereafter, the Secretary, in collaboration with the parties to each Critical Path Public-Private Partnership, shall submit a report to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Energy and Commerce of the House of Representatives—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id1434d1b9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewing the operations and activities of the Partnerships in the previous year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d1ba-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addressing such other issues relating to this section as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1434d1bb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “medical product” includes a drug, a biological product as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"section 262 of title 42","children":[],"tail":", a device, and any combination of such products."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1434d1bc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this section, there is authorized to be appropriated $1,380,822 for the period beginning on ","children":[{"tag":"date","attrib":{"date":"2022-10-01"},"text":"October 1, 2022","children":[],"tail":" and ending on "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn002085"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002085"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See 2022 Amendment notes below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1434d1bd-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s566"},"text":"June 25, 1938, ch. 675, § 566","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/85/tVI/s603"},"text":"Pub. L. 110–85, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/898"},"text":"121 Stat. 898","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/144/tXI/s1102"},"text":"Pub. L. 112–144, title XI, § 1102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1108"},"text":"126 Stat. 1108","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/52/tVI/s602"},"text":"Pub. L. 115–52, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-18"},"text":"Aug. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1048"},"text":"131 Stat. 1048","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/180/dF/tV/s5005"},"text":"Pub. L. 117–180, div. F, title V, § 5005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-09-30"},"text":"Sept. 30, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2167"},"text":"136 Stat. 2167","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/229/dC/tIII/s301"},"text":"Pub. L. 117–229, div. C, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-16"},"text":"Dec. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2311"},"text":"136 Stat. 2311","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tIII/s3101"},"text":"Pub. L. 117–328, div. FF, title III, § 3101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5807"},"text":"136 Stat. 5807","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1434d1be-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1434d1bf-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id1434d1c0-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":", which directed the substitution of “$6,000,000 for each of fiscal years 2023 through 2027” for “$1,265,753 for the period beginning on "},{"tag":"date","attrib":{"date":"2022-10-01"},"text":"October 1, 2022","children":[],"tail":" and ending on "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":"”, could not be executed because “$1,265,753” did not appear after the intervening amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/117/229/s301"},"text":"section 301 of Pub. L. 117–229","children":[],"tail":". See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/229"},"text":"Pub. L. 117–229","children":[],"tail":" substituted “$1,380,822 for the period beginning on "},{"tag":"date","attrib":{"date":"2022-10-01"},"text":"October 1, 2022","children":[],"tail":" and ending on "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":"” for “$1,265,753 for the period beginning on "},{"tag":"date","attrib":{"date":"2022-10-01"},"text":"October 1, 2022","children":[],"tail":" and ending on "},{"tag":"date","attrib":{"date":"2022-12-16"},"text":"December 16, 2022","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/180"},"text":"Pub. L. 117–180","children":[],"tail":" substituted “$1,265,753 for the period beginning on "},{"tag":"date","attrib":{"date":"2022-10-01"},"text":"October 1, 2022","children":[],"tail":" and ending on "},{"tag":"date","attrib":{"date":"2022-12-16"},"text":"December 16, 2022","children":[],"tail":"” for “$6,000,000 for each of fiscal years 2018 through 2022”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/52"},"text":"Pub. L. 115–52","children":[],"tail":" substituted “2018 through 2022” for “2013 through 2017”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/144"},"text":"Pub. L. 112–144","children":[],"tail":" amended subsec. (f) generally. Prior to amendment, text read as follows: “To carry out this section, there are authorized to be appropriated $5,000,000 for fiscal year 2008 and such sums as may be necessary for each of fiscal years 2009 through 2012.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
