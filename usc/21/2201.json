{"tag":"section","attrib":{"id":"id14d2245f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2201"},"text":null,"children":[{"tag":"num","attrib":{"value":"2201"},"text":"§ 2201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14d22460-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2201/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, in coordination with the Secretary of Agriculture, not less frequently than every 2 years, review and evaluate relevant health data and other relevant information, including from toxicological and epidemiological studies and analyses, current Good Manufacturing Practices issued by the Secretary relating to food, and relevant recommendations of relevant advisory committees, including the Food Advisory Committee, to determine the most significant foodborne contaminants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d22461-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2201/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance documents and regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Based on the review and evaluation conducted under subsection (a), and when appropriate to reduce the risk of serious illness or death to humans or animals or to prevent adulteration of the food under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s342"},"text":"section 342 of this title","children":[],"tail":" or to prevent the spread by food of communicable disease under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s264"},"text":"section 264 of title 42","children":[],"tail":", the Secretary shall issue contaminant-specific and science-based guidance documents, including guidance documents regarding action levels, or regulations. Such guidance, including guidance regarding action levels, or regulations—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d22462-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2201/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall apply to products or product classes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d22463-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2201/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall, where appropriate, differentiate between food for human consumption and food intended for consumption by animals other than humans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d22464-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2201/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be written to be facility-specific.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d22465-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2201/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No duplication of efforts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall coordinate with the Secretary of Agriculture to avoid issuing duplicative guidance on the same contaminants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d22466-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2201/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall periodically review and revise, as appropriate, the guidance documents, including guidance documents regarding action levels, or regulations promulgated under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14d22467-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/353/tI/s104"},"text":"Pub. L. 111–353, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3899"},"text":"124 Stat. 3899","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14d22468-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14d22469-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14d2246a-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Secretary, referred to in text, probably means the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14d2246b-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id14d2246c-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/353/s1/a"},"text":"Pub. L. 111–353, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3885"},"text":"124 Stat. 3885","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/353/s1/a"},"text":"“This Act [enacting this chapter and sections 350g to 350","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–1, 379j–31, 384a to 384d, 399c, and 399d of this title, "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7625"},"text":"section 7625 of Title 7","children":[],"tail":", Agriculture, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s280g–16"},"text":"section 280g–16 of Title 42","children":[],"tail":", The Public Health and Welfare, amending sections 331, 333, 334, 350b to 350d, 350f, 374, 381, 393, and 399 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s247b–20"},"text":"section 247b–20 of Title 42","children":[],"tail":", and enacting provisions set out as notes under sections 331, 334, 342, 350b, 350d, 350e, 350g to 350j, 350"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":", and 381 of this title] may be cited as the ‘FDA Food Safety Modernization Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
