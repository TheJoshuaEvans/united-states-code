{"tag":"section","attrib":{"id":"id14ba5634-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1032"},"text":null,"children":[{"tag":"num","attrib":{"value":"1032"},"text":"§ 1032.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is hereby declared to be the policy of the Congress to provide for the inspection of certain egg products, restrictions upon the disposition of certain qualities of eggs, and uniformity of standards for eggs, and otherwise regulate the processing and distribution of eggs and egg products as hereinafter prescribed to prevent the movement or sale for human food, of eggs and egg products which are adulterated or misbranded or otherwise in violation of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id14ba5635-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/597/s3"},"text":"Pub. L. 91–597, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-29"},"text":"Dec. 29, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1621"},"text":"84 Stat. 1621","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14ba5636-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14ba5637-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14ba5638-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred 