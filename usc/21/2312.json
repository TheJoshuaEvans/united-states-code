{"tag":"section","attrib":{"id":"id14d6df68-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2312"},"text":null,"children":[{"tag":"num","attrib":{"value":"2312"},"text":"§ 2312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of sanctions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The President shall impose five or more of the sanctions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s2313"},"text":"section 2313 of this title","children":[],"tail":" with respect to each foreign person that is an entity, and four or more of such sanctions with respect to each foreign person that is an individual, that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d6df69-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2312/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is identified as a foreign opioid trafficker in a report submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s2311/a"},"text":"section 2311(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d6df6a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2312/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President determines is owned, controlled, directed by, knowingly supplying or sourcing precursors for, or knowingly acting for or on behalf of, such a foreign opioid trafficker;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d6df6b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2312/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President determines has knowingly engaged in, on or after ","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"December 18, 2025","children":[],"tail":", a pattern of significant activity that has materially contributed to opioid trafficking; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d6df6c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2312/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the President determines—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d6df6d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2312/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has knowingly engaged in a pattern of providing significant financial, material, or technological support for, including through the provision of goods or services in support of, any activity or transaction described in paragraph (3); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d6df6e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2312/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is owned, controlled, or directed by any foreign person described in subparagraph (A) or in paragraph (3), or has knowingly acted or purported to act for or on behalf of, directly or indirectly, such a foreign person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14d6df6f-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dF/tLXXII/s7212"},"text":"Pub. L. 116–92, div. F, title LXXII, § 7212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2265"},"text":"133 Stat. 2265","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXIII/s8316"},"text":"Pub. L. 119–60, div. H, title LXXXIII, § 8316","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1858"},"text":"139 Stat. 1858","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14d6df70-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14d6df71-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14d6df72-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Pars. (3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" added pars. (3) and (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id14d6df73-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id14d6df74-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions and authorities of President under this section delegated to Secretary of the Treasury, in consultation with the Secretary of State, by section 1(d)(v) of Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2020-03-31"},"text":"Mar. 31, 2020","children":[],"tail":", 85 F.R. 22343, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s2311"},"text":"section 2311 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
