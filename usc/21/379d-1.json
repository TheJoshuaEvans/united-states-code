{"tag":"section","attrib":{"id":"id1447e485-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"379d–1"},"text":"§ 379d–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflicts of interest","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1447e486-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1447e487-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “advisory committee” means an advisory committee under chapter 10 of title 5 that provides advice or recommendations to the Secretary regarding activities of the Food and Drug Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1447e488-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “financial interest” means a financial interest under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s208/a"},"text":"section 208(a) of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1447e489-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recruitment for advisory committees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1447e48a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1447e48b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and implement strategies on effective outreach to potential members of advisory committees at universities, colleges, other academic research centers, professional and medical societies, and patient and consumer groups;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1447e48c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek input from professional medical and scientific societies to determine the most effective informational and recruitment activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1447e48d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at least every 180 days, request referrals for potential members of advisory committees from a variety of stakeholders, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id1447e48e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" product developers, patient groups, and disease advocacy organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1447e48f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" relevant—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id1447e490-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/b/1/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professional societies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id1447e491-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/b/1/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical societies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id1447e492-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/b/1/C/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id1447e493-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/b/1/C/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" governmental organizations; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1447e494-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in carrying out subparagraphs (A) and (B), take into account the levels of activity (including the numbers of annual meetings) and the numbers of vacancies of the advisory committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1447e495-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recruitment activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The recruitment activities under paragraph (1) may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1447e496-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advertising the process for becoming an advisory committee member at medical and scientific society conferences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1447e497-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making widely available, including by using existing electronic communications channels, the contact information for the Food and Drug Administration point of contact regarding advisory committee nominations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1447e498-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing a method through which an entity receiving funding from the National Institutes of Health, the Agency for Healthcare Research and Quality, the Centers for Disease Control and Prevention, or the Veterans Health Administration can identify a person whom the Food and Drug Administration can contact regarding the nomination of individuals to serve on advisory committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1447e499-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expertise","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this subsection, the Secretary shall seek to ensure that the Secretary has access to the most current expert advice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1447e49a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of determinations and certifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s13109/a/2"},"text":"section 13109(a)(2) of title 5","children":[],"tail":", the following shall apply:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id1447e49b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 15 or more days in advance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As soon as practicable, but (except as provided in paragraph (2)) not later than 15 days prior to a meeting of an advisory committee to which a written determination as referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s208/b/1"},"text":"section 208(b)(1) of title 18","children":[],"tail":" or a written certification as referred to in section 208(b)(3) of such title, applies, the Secretary shall disclose (other than information exempted from disclosure under section 552 or "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":" (popularly known as the Freedom of Information Act and the Privacy Act of 1974, respectively)) on the Internet Web site of the Food and Drug Administration—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1447e49c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type, nature, and magnitude of the financial interests of the advisory committee member to which such determination or certification applies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1447e49d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasons of the Secretary for such determination or certification, including, as appropriate, the public health interest in having the expertise of the member with respect to the particular matter before the advisory committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1447e49e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Less than 30 days in advance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a financial interest that becomes known to the Secretary less than 30 days prior to a meeting of an advisory committee to which a written determination as referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s208/b/1"},"text":"section 208(b)(1) of title 18","children":[],"tail":" or a written certification as referred to in section 208(b)(3) of such title applies, the Secretary shall disclose (other than information exempted from disclosure under section 552 or 552a of title 5) on the Internet Web site of the Food and Drug Administration, the information described in subparagraphs (A) and (B) of paragraph (1) as soon as practicable after the Secretary makes such determination or certification, but in no case later than the date of such meeting."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1447e49f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public record","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that the public record and transcript of each meeting of an advisory committee includes the disclosure required under subsection (c) (other than information exempted from disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1447e4a0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1447e4a1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than February 1 of each year, the Secretary shall submit to the Committee on Appropriations and the Committee on Health, Education, Labor, and Pensions of the Senate, and the Committee on Appropriations and the Committee on Energy and Commerce of the House of Representatives, a report that describes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1447e4a2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the fiscal year that ended on September 30 of the previous year, the number of persons nominated for participation at meetings for each advisory committee, the number of persons so nominated, and willing to serve, the number of vacancies on each advisory committee, and the number of persons contacted for service as members on each advisory committee meeting for each advisory committee who did not participate because of the potential for such participation to constitute a disqualifying financial interest under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s208"},"text":"section 208 of title 18","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1447e4a3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to such year, the number of persons contacted for service as members for each advisory committee meeting for each advisory committee who did not participate because of reasons other than the potential for such participation to constitute a disqualifying financial interest under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s208"},"text":"section 208 of title 18","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1447e4a4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to such year, the number of members attending meetings for each advisory committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1447e4a5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to such year, the aggregate number of disclosures required under subsection (d) and the percentage of individuals to whom such disclosures did not apply who served on such committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1447e4a6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after submitting any report under paragraph (1) to the committees specified in such paragraph, the Secretary shall make each such report available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1447e4a7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic review of guidance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less than once every 5 years, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1447e4a8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review guidance of the Food and Drug Administration with respect to advisory committees regarding disclosure of conflicts of interest and the application of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s208"},"text":"section 208 of title 18","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1447e4a9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" update such guidance as necessary to ensure that the Food and Drug Administration receives appropriate access to needed scientific expertise, with due consideration of the requirements of such section 208.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1447e4aa-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–1/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance on reported disclosed financial interest or involvement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue guidance that describes how the Secretary reviews the financial interests and involvement of advisory committee members that are disclosed under subsection (c) but that the Secretary determines not to meet the definition of a disqualifying interest under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s208"},"text":"section 208 of title 18","children":[],"tail":" for the purposes of participating in a particular matter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1447e4ab-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s712"},"text":"June 25, 1938, ch. 675, § 712","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/85/tVII/s701/a"},"text":"Pub. L. 110–85, title VII, § 701(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/900"},"text":"121 Stat. 900","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/144/tXI/s1142/a"},"text":"Pub. L. 112–144, title XI, § 1142(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1127"},"text":"126 Stat. 1127","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIII/s3101/a/2/U"},"text":"Pub. L. 114–255, div. A, title III, § 3101(a)(2)(U)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1155"},"text":"130 Stat. 1155","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/159"},"text":"Pub. L. 117–286, § 4(a)(159)","children":[],"tail":", (c)(29), "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4323"},"text":"136 Stat. 4323","children":[],"tail":", 4357.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1447e4ac-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1447e4ad-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id1447e4ae-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Privacy Act of 1974, referred to in subsec. (c)(3)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/579"},"text":"Pub. L. 93–579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-31"},"text":"Dec. 31, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1896"},"text":"88 Stat. 1896","children":[],"tail":", which enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees, and provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1974 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id1447e4af-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior 