{"tag":"section","attrib":{"id":"id147eac5b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s395"},"text":null,"children":[{"tag":"num","attrib":{"value":"395"},"text":"§ 395.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan repayment program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id147eac5c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s395/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id147eac5d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s395/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority for program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Secretary shall carry out a program of entering into contracts with appropriately qualified health professionals under which such health professionals agree to conduct research, as employees of the Food and Drug Administration, in consideration of the Federal Government agreeing to repay, for each year of such service, not more than $20,000 of the principal and interest of the educational loans of such health professionals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147eac5e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s395/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not enter into an agreement with a health professional pursuant to paragraph (1) unless such professional—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id147eac5f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s395/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a substantial amount of educational loans relative to income; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147eac60-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s395/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agrees to serve as an employee of the Food and Drug Administration for purposes of paragraph (1) for a period of not less than 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id147eac61-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s395/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of certain provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to the National Health Service Corps Loan Repayment Program established in subpart III of part D of title III of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254"},"text":"42 U.S.C. 254","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" et seq.], the provisions of such subpart shall, except as inconsistent with subsection (a) of this section, apply to the program established in such subsection in the same manner and to the same extent as such provisions apply to the National Health Service Corps Loan Repayment Program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id147eac62-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s395/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, there are authorized to be appropriated such sums as may be necessary for each of the fiscal years 1994 through 1996.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id147eac63-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s1005"},"text":"June 25, 1938, ch. 675, § 1005","children":[],"tail":", formerly § 905, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXX/s2006/2"},"text":"Pub. L. 103–43, title XX, § 2006(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/210"},"text":"107 Stat. 210","children":[],"tail":"; renumbered § 1005, "},{"tag":"ref","attrib":{"href":"/us/pl/111/31/dA/tI/s101/b/2"},"text":"Pub. L. 111–31, div. A, title I, § 101(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-06-22"},"text":"June 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1784"},"text":"123 Stat. 1784","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id147eac64-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id147eac65-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id147eac66-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Public Health Service Act, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"act July 1, 1944, ch. 373","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/682"},"text":"58 Stat. 682","children":[],"tail":". Subpart III of part D of title III of the Act is classified generally to subpart III [§ 254"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" et seq.] of part D of subchapter II of chapter 6A of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
