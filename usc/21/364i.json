{"tag":"section","attrib":{"id":"id1440ba0a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364i"},"text":null,"children":[{"tag":"num","attrib":{"value":"364i"},"text":"§ 364i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption for certain products and facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1440ba0b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, except as provided in subsection (b), a cosmetic product or facility that is also subject to the requirements of subchapter V shall be exempt from the requirements of sections 364a, 364b, 364c, 364d, 364e(a), 364f, and 364g of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1440ba0c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A facility described in subsection (a) that also manufactures or processes cosmetic products that are not subject to the requirements of subchapter V shall not be exempt from the requirements of sections 364a, 364b, 364c, 364d, 364e(a), 364f, and 364g of this title, with respect to such cosmetic products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1440ba0d-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s613"},"text":"June 25, 1938, ch. 675, § 613","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tIII/s3502"},"text":"Pub. L. 117–328, div. FF, title III, § 3502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5857"},"text":"136 Stat. 5857","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1440ba0e-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1440ba0f-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id1440ba10-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction; Confidentiality","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s3502"},"text":"section 3502 of Pub. L. 117–328","children":[],"tail":", which enacted this section, to be construed to authorize the disclosure of information that is prohibited from disclosure under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s331/j"},"text":"section 331(j) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1905"},"text":"section 1905 of title 18","children":[],"tail":" or that is subject to withholding under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/4"},"text":"section 552(b)(4) of title 5","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/s3503/c/2"},"text":"section 3503(c)(2) of Pub. L. 117–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s364"},"text":"section 364 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
