{"tag":"section","attrib":{"id":"id13f46dda-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"355–2"},"text":"§ 355–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions for delays of generic drugs and biosimilar biological products","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id13f46ddb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13f46ddc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “commercially reasonable, market-based terms” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13f46ddd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nondiscriminatory price for the sale of the covered product at or below, but not greater than, the most recent wholesale acquisition cost for the drug, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–3a/c/6/B"},"text":"section 1395w–3a(c)(6)(B) of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13f46dde-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a schedule for delivery that results in the transfer of the covered product to the eligible product developer consistent with the timing under subsection (b)(2)(A)(iv); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13f46ddf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no additional conditions are imposed on the sale of the covered product;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13f46de0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “covered product”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13f46de1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id13f46de2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any drug approved under subsection (c) or (j) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"section 355 of this title","children":[],"tail":" or biological product licensed under subsection (a) or (k) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"section 262 of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id13f46de3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any combination of a drug or biological product described in clause (i); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id13f46de4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when reasonably necessary to support approval of an application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"section 355 of this title","children":[],"tail":", or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"section 262 of title 42","children":[],"tail":", as applicable, or otherwise meet the requirements for approval under either such section, any product, including any device, that is marketed or intended for use with such a drug or biological product; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13f46de5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include any drug or biological product that appears on the drug shortage list in effect under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s356e"},"text":"section 356e of this title","children":[],"tail":", unless—"}],"tail":null},{"tag":"clause","attrib":{"id":"id13f46de6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the drug or biological product has been on the drug shortage list in effect under such ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s356e"},"text":"section 356e of this title","children":[],"tail":" continuously for more than 6 months; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id13f46de7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that inclusion of the drug or biological product as a covered product is likely to contribute to alleviating or preventing a shortage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13f46de8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “device” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s321"},"text":"section 321 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13f46de9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “eligible product developer” means a person that seeks to develop a product for approval pursuant to an application for approval under subsection (b)(2) or (j) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"section 355 of this title","children":[],"tail":" or for licensing pursuant to an application under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262/k"},"text":"section 262(k) of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13f46dea-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “license holder” means the holder of an application approved under subsection (c) or (j) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"section 355 of this title","children":[],"tail":" or the holder of a license under subsection (a) or (k) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"section 262 of title 42","children":[],"tail":" for a covered product;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13f46deb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “REMS” means a risk evaluation and mitigation strategy under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355–1"},"text":"section 355–1 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13f46dec-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “REMS with ETASU” means a REMS that contains elements to assure safe use under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355–1/f"},"text":"section 355–1(f) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13f46ded-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of Health and Human Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13f46dee-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “single, shared system of elements to assure safe use” means a single, shared system of elements to assure safe use under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355–1/f"},"text":"section 355–1(f) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13f46def-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “sufficient quantities” means an amount of a covered product that the eligible product developer determines allows it to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13f46df0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/a/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct testing to support an application under—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id13f46df1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/a/10/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (b)(2) or (j) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"section 355 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id13f46df2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/a/10/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s262/k"},"text":"section 262(k) of title 42","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13f46df3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/a/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fulfill any regulatory requirements relating to approval of such an application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13f46df4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil action for failure to provide sufficient quantities of a covered product","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13f46df5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible product developer may bring a civil action against the license holder for a covered product seeking relief under this subsection in an appropriate district court of the United States alleging that the license holder has declined to provide sufficient quantities of the covered product to the eligible product developer on commercially reasonable, market-based terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13f46df6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13f46df7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To prevail in a civil action brought under paragraph (1), an eligible product developer shall prove, by a preponderance of the evidence—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id13f46df8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id13f46df9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the covered product is not subject to a REMS with ETASU; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id13f46dfa-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the covered product is subject to a REMS with ETASU—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id13f46dfb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/2/A/i/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible product developer has obtained a covered product authorization from the Secretary in accordance with subparagraph (B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id13f46dfc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/2/A/i/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible product developer has provided a copy of the covered product authorization to the license holder;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id13f46dfd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that, as of the date on which the civil action is filed, the eligible product developer has not obtained sufficient quantities of the covered product on commercially reasonable, market-based terms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id13f46dfe-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that the eligible product developer has submitted a written request to purchase sufficient quantities of the covered product to the license holder, and such request—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id13f46dff-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/2/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was sent to a named corporate officer of the license holder;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id13f46e00-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/2/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was made by certified or registered mail with return receipt requested;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id13f46e01-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/2/A/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specified an individual as the point of contact for the license holder to direct communications related to the sale of the covered product to the eligible product developer and a means for electronic and written communications with that individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id13f46e02-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/2/A/iii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specified an address to which the covered product was to be shipped upon reaching an agreement to transfer the covered product; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id13f46e03-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that the license holder has not delivered to the eligible product developer sufficient quantities of the covered product on commercially reasonable, market-based terms—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id13f46e04-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/2/A/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a covered product that is not subject to a REMS with ETASU, by the date that is 31 days after the date on which the license holder received the request for the covered product; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id13f46e05-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/2/A/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for a covered product that is subject to a REMS with ETASU, by 31 days after the later of—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id13f46e06-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/2/A/iv/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the license holder received the request for the covered product; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id13f46e07-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/2/A/iv/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the license holder received a copy of the covered product authorization issued by the Secretary in accordance with subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13f46e08-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for covered product subject to a REMS with ETASU","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id13f46e09-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible product developer may submit to the Secretary a written request for the eligible product developer to be authorized to obtain sufficient quantities of an individual covered product subject to a REMS with ETASU.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id13f46e0a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after the date on which a request under clause (i) is received, the Secretary shall, by written notice, authorize the eligible product developer to obtain sufficient quantities of an individual covered product subject to a REMS with ETASU for purposes of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id13f46e0b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development and testing that does not involve human clinical trials, if the eligible product developer has agreed to comply with any conditions the Secretary determines necessary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id13f46e0c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" development and testing that involves human clinical trials, if the eligible product developer has—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id13f46e0d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/2/B/ii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"subitem","attrib":{"id":"id13f46e0e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/2/B/ii/II/aa/AA"},"text":null,"children":[{"tag":"num","attrib":{"value":"AA"},"text":"(AA)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submitted protocols, informed consent documents, and informational materials for testing that include protections that provide safety protections comparable to those provided by the REMS for the covered product; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subitem","attrib":{"id":"id13f46e0f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/2/B/ii/II/aa/BB"},"text":null,"children":[{"tag":"num","attrib":{"value":"BB"},"text":"(BB)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise satisfied the Secretary that such protections will be provided; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id13f46e10-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/2/B/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" met any other requirements the Secretary may establish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id13f46e11-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A covered product authorization issued under this subparagraph shall state that the provision of the covered product by the license holder under the terms of the authorization will not be a violation of the REMS for the covered product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13f46e12-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affirmative defense","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In a civil action brought under paragraph (1), it shall be an affirmative defense, on which the defendant has the burden of persuasion by a preponderance of the evidence—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13f46e13-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that, on the date on which the eligible product developer requested to purchase sufficient quantities of the covered product from the license holder—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id13f46e14-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" neither the license holder nor any of its agents, wholesalers, or distributors was engaged in the manufacturing or commercial marketing of the covered product; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id13f46e15-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" neither the license holder nor any of its agents, wholesalers, or distributors otherwise had access to inventory of the covered product to supply to the eligible product developer on commercially reasonable, market-based terms;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13f46e16-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id13f46e17-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the license holder sells the covered product through agents, distributors, or wholesalers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id13f46e18-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the license holder has placed no restrictions, explicit or implicit, on its agents, distributors, or wholesalers to sell covered products to eligible product developers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id13f46e19-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the covered product can be purchased by the eligible product developer in sufficient quantities on commercially reasonable, market-based terms from the agents, distributors, or wholesalers of the license holder; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13f46e1a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that the license holder made an offer to the individual specified pursuant to paragraph (2)(A)(iii)(III), by a means of communication (electronic, written, or both) specified pursuant to such paragraph, to sell sufficient quantities of the covered product to the eligible product developer at commercially reasonable market-based terms—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id13f46e1b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a covered product that is not subject to a REMS with ETASU, by the date that is 14 days after the date on which the license holder received the request for the covered product, and the eligible product developer did not accept such offer by the date that is 7 days after the date on which the eligible product developer received such offer from the license holder; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id13f46e1c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a covered product that is subject to a REMS with ETASU, by the date that is 20 days after the date on which the license holder received the request for the covered product, and the eligible product developer did not accept such offer by the date that is 10 days after the date on which the eligible product developer received such offer from the license holder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13f46e1d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13f46e1e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an eligible product developer prevails in a civil action brought under paragraph (1), the court shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id13f46e1f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" order the license holder to provide to the eligible product developer without delay sufficient quantities of the covered product on commercially reasonable, market-based terms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id13f46e20-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award to the eligible product developer reasonable attorney’s fees and costs of the civil action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id13f46e21-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" award to the eligible product developer a monetary amount sufficient to deter the license holder from failing to provide eligible product developers with sufficient quantities of a covered product on commercially reasonable, market-based terms, if the court finds, by a preponderance of the evidence—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id13f46e22-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/4/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the license holder delayed providing sufficient quantities of the covered product to the eligible product developer without a legitimate business justification; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id13f46e23-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/4/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the license holder failed to comply with an order issued under clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13f46e24-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum monetary amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A monetary amount awarded under subparagraph (A)(iii) shall not be greater than the revenue that the license holder earned on the covered product during the period—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id13f46e25-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" beginning on—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id13f46e26-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/4/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a covered product that is not subject to a REMS with ETASU, the date that is 31 days after the date on which the license holder received the request; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id13f46e27-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/4/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for a covered product that is subject to a REMS with ETASU, the date that is 31 days after the later of—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id13f46e28-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/4/B/i/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the license holder received the request; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id13f46e29-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/4/B/i/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the license holder received a copy of the covered product authorization issued by the Secretary in accordance with paragraph (2)(B); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id13f46e2a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ending on the date on which the eligible product developer received sufficient quantities of the covered product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13f46e2b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Avoidance of delay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The court may issue an order under subparagraph (A)(i) before conducting further proceedings that may be necessary to determine whether the eligible product developer is entitled to an award under clause (ii) or (iii) of subparagraph (A), or the amount of any such award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13f46e2c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation of liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A license holder for a covered product shall not be liable for any claim under Federal, State, or local law arising out of the failure of an eligible product developer to follow adequate safeguards to assure safe use of the covered product during development or testing activities described in this section, including transportation, handling, use, or disposal of the covered product by the eligible product developer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13f46e2d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13f46e2e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13f46e2f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “antitrust laws”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13f46e30-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the meaning given the term in subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s12"},"text":"section 12 of title 15","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13f46e31-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s45"},"text":"section 45 of title 15","children":[],"tail":" to the extent that such section applies to unfair methods of competition."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13f46e32-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antitrust laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to limit the operation of any provision of the antitrust laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13f46e33-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13f46e34-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section, the amendments made by this section, or in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355–1"},"text":"section 355–1 of this title","children":[],"tail":", shall be construed as—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id13f46e35-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibiting a license holder from providing an eligible product developer access to a covered product in the absence of an authorization under this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13f46e36-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355–2/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any way negating the applicability of a REMS with ETASU, as otherwise required under such ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355–1"},"text":"section 355–1 of this title","children":[],"tail":", with respect to such covered product."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id13f46e37-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dN/tI/s610"},"text":"Pub. L. 116–94, div. N, title I, § 610","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3130"},"text":"133 Stat. 3130","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id13f46e38-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id13f46e39-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id13f46e3a-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Further Consolidated Appropriations Act, 2020, and not as part of the Federal Food, Drug, and Cosmetic Act which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s610"},"text":"section 610 of Pub. L. 116–94","children":[],"tail":". Subsecs. (d) and (f) of "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/s610"},"text":"section 610 of Pub. L. 116–94","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355–1"},"text":"section 355–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
