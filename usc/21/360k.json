{"tag":"section","attrib":{"id":"id142409a5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360k"},"text":null,"children":[{"tag":"num","attrib":{"value":"360k"},"text":"§ 360k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and local requirements respecting devices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id142409a6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), no State or political subdivision of a State may establish or continue in effect with respect to a device intended for human use any requirement—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id142409a7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360k/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is different from, or in addition to, any requirement applicable under this chapter to the device, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142409a8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360k/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which relates to the safety or effectiveness of the device or to any other matter included in a requirement applicable to the device under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id142409a9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exempt requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon application of a State or a political subdivision thereof, the Secretary may, by regulation promulgated after notice and opportunity for an oral hearing, exempt from subsection (a), under such conditions as may be prescribed in such regulation, a requirement of such State or political subdivision applicable to a device intended for human use if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id142409aa-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360k/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirement is more stringent than a requirement under this chapter which would be applicable to the device if an exemption were not in effect under this subsection; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142409ab-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360k/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the requirement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id142409ac-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360k/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is required by compelling local conditions, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142409ad-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360k/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with the requirement would not cause the device to be in violation of any applicable requirement under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id142409ae-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s521"},"text":"June 25, 1938, ch. 675, § 521","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/295/s2"},"text":"Pub. L. 94–295, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-28"},"text":"May 28, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/574"},"text":"90 Stat. 574","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
