{"tag":"section","attrib":{"id":"id14d223d7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2012"},"text":null,"children":[{"tag":"num","attrib":{"value":"2012"},"text":"§ 2012.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of clearinghouse and advisory council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14d223d8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2012/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clearinghouse","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established, under the supervision of the Attorney General of the United States, an information clearinghouse to be known as the National Methamphetamine Information Clearinghouse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d223d9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2012/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory council","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d223da-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2012/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established an advisory council to be known as the National Methamphetamine Advisory Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d223db-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2012/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall consist of 10 members appointed by the Attorney General—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d223dc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2012/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not fewer than 3 of whom shall be representatives of law enforcement agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d223dd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2012/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not fewer than 4 of whom shall be representatives of nongovernmental and nonprofit organizations providing services or training and implementing programs or strategies related to methamphetamines; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d223de-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2012/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 of whom shall be a representative of the Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d223df-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2012/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of appointment; vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members shall be appointed for 3 years. Any vacancy in the Council shall not affect its powers, but shall be filled in the same manner as the original appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d223e0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2012/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel matters","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d223e1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2012/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Council shall be allowed travel expenses, including per diem in lieu of subsistence, at rates authorized for employees of agencies under subchapter I of chapter 57 of title 5, while away from their homes or regular places of business in the performance of services for the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d223e2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2012/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Council shall not receive compensation for the performance of the duties of a member of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14d223e3-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/469/tX/s1003"},"text":"Pub. L. 109–469, title X, § 1003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-29"},"text":"Dec. 29, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3538"},"text":"120 Stat. 3538","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
