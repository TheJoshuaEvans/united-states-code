{"tag":"section","attrib":{"id":"id14b0b9a6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s878"},"text":null,"children":[{"tag":"num","attrib":{"value":"878"},"text":"§ 878.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of enforcement personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14b0b9a7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s878/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any officer or employee of the Drug Enforcement Administration or any State, tribal, or local law enforcement officer designated by the Attorney General may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14b0b9a8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s878/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry firearms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14b0b9a9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s878/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" execute and serve search warrants, arrest warrants, administrative inspection warrants, subpenas, and summonses issued under the authority of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14b0b9aa-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s878/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make arrests without warrant (A) for any offense against the United States committed in his presence, or (B) for any felony, cognizable under the laws of the United States, if he has probable cause to believe that the person to be arrested has committed or is committing a felony;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14b0b9ab-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s878/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make seizures of property pursuant to the provisions of this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14b0b9ac-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s878/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other law enforcement duties as the Attorney General may designate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14b329ad-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s878/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local law enforcement officers performing functions under this section shall not be deemed Federal employees and shall not be subject to provisions of law relating to Federal employees, except that such officers shall be subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3374/c"},"text":"section 3374(c) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14b329ae-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/tII/s508"},"text":"Pub. L. 91–513, title II, § 508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1273"},"text":"84 Stat. 1273","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/132/s16/b"},"text":"Pub. L. 96–132, § 16(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-11-30"},"text":"Nov. 30, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1049"},"text":"93 Stat. 1049","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tI/s1869"},"text":"Pub. L. 99–570, title I, § 1869","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-55"},"text":"100 Stat. 3207–55","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/646/s86"},"text":"Pub. L. 99–646, § 86","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3620"},"text":"100 Stat. 3620","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s232/d"},"text":"Pub. L. 111–211, title II, § 232(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2278"},"text":"124 Stat. 2278","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14b329af-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14b329b0-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14b329b1-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211"},"text":"Pub. L. 111–211","children":[],"tail":" inserted “, tribal,” after “State” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570"},"text":"Pub. L. 99–570","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/99/646"},"text":"Pub. L. 99–646","children":[],"tail":" amended section substantially identically designating existing provisions as subsec. (a) and adding subsec. (b), with the exception of the amendment of subsec. (a) for which "},{"tag":"ref","attrib":{"href":"/us/pl/99/570"},"text":"Pub. L. 99–570","children":[],"tail":" directed the insertion of “or (with respect to offenses under this subchapter or subchapter II of this chapter) any State or local law enforcement officer” and "},{"tag":"ref","attrib":{"href":"/us/pl/99/646"},"text":"Pub. L. 99–646","children":[],"tail":" directed the insertion of “or any State or local law enforcement officer”, the latter of which was executed to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/132"},"text":"Pub. L. 96–132","children":[],"tail":" substituted “Drug Enforcement Administration” for “Bureau of Narcotics and Dangerous Drugs”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
