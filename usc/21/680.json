{"tag":"section","attrib":{"id":"id148f4e22-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s680"},"text":null,"children":[{"tag":"num","attrib":{"value":"680"},"text":"§ 680.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated such sums as may be necessary to carry out the provisions of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id148f4e23-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1907-03-04/ch2907"},"text":"Mar. 4, 1907, ch. 2907","children":[],"tail":", title IV, § 411, formerly § 410, as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/201/s16"},"text":"Pub. L. 90–201, § 16","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-15"},"text":"Dec. 15, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/600"},"text":"81 Stat. 600","children":[],"tail":"; renumbered § 411, "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tIX/s918/a/1/A"},"text":"Pub. L. 104–127, title IX, § 918(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1188"},"text":"110 Stat. 1188","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
