{"tag":"section","attrib":{"id":"id14cfb2a2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1710a"},"text":"§ 1710a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for disclosure of Federal sponsorship of all Federal advertising or other communication materials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14cfb2a3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each advertisement or other communication paid for by the Office, either directly or through a contract awarded by the Office, shall include a prominent notice informing the target audience that the advertisement or other communication is paid for by the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14cfb2a4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advertisement or other communication","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “advertisement or other communication” includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14cfb2a5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an advertisement disseminated in any form, including print or by any electronic means; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14cfb2a6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a communication by an individual in any form, including speech, print, or by any electronic means.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14cfb2a7-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tVII/s712"},"text":"Pub. L. 105–277, div. C, title VII, § 712","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/469/tXI/s1118"},"text":"Pub. L. 109–469, title XI, § 1118","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-29"},"text":"Dec. 29, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3546"},"text":"120 Stat. 3546","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC"},"text":"Pub. L. 105–277, div. C","children":[],"tail":". title VII, § 715, "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-693"},"text":"112 Stat. 2681–693","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/469/tVI/s602"},"text":"Pub. L. 109–469, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-29"},"text":"Dec. 29, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3533"},"text":"120 Stat. 3533","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVIII/s8202/a"},"text":"Pub. L. 115–271, title VIII, § 8202(a)","children":[],"tail":", (b)(2), "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4110"},"text":"132 Stat. 4110","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14cfb2a8-3a70-11f1-