{"tag":"section","attrib":{"id":"id14ae6e54-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s855"},"text":null,"children":[{"tag":"num","attrib":{"value":"855"},"text":"§ 855.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative fine","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In lieu of a fine otherwise authorized by this part, a defendant who derives profits or other proceeds from an offense may be fined not more than twice the gross profits or other proceeds.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id14ae6e55-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/tII/s415"},"text":"Pub. L. 91–513, title II, § 415","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s2302"},"text":"Pub. L. 98–473, title II, § 2302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2193"},"text":"98 Stat. 2193","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
