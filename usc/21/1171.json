{"tag":"section","attrib":{"id":"id14bf10f8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1171"},"text":null,"children":[{"tag":"num","attrib":{"value":"1171"},"text":"§ 1171.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drug abuse prevention function appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any request for appropriations by a department or agency of the Government submitted after ","children":[{"tag":"date","attrib":{"date":"1972-03-21"},"text":"March 21, 1972","children":[],"tail":", shall specify (1) on a line item basis, that part of the appropriations which the department or agency is requesting to carry out its drug abuse prevention functions, and (2) the authorization of the appropriations requested to carry out each of its drug abuse prevention functions."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id14bf10f9-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/255/tIV/s404"},"text":"Pub. L. 92–255, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-03-21"},"text":"Mar. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/77"},"text":"86 Stat. 77","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
