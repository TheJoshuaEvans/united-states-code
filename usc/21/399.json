{"tag":"section","attrib":{"id":"id147eac7d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399"},"text":null,"children":[{"tag":"num","attrib":{"value":"399"},"text":"§ 399.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to enhance food safety","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id147eac7e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to make grants to eligible entities to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id147eac7f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" undertake examinations, inspections, and investigations, and related food safety activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s372"},"text":"section 372 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147eac80-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" train to the standards of the Secretary for the examination, inspection, and investigation of food manufacturing, processing, packing, holding, distribution, and importation, including as such examination, inspection, and investigation relate to retail food establishments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147eac81-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" build the food safety capacity of the laboratories of such eligible entity, including the detection of zoonotic diseases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147eac82-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" build the infrastructure and capacity of the food safety programs of such eligible entity to meet the standards as outlined in the grant application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147eac83-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" take appropriate action to protect the public health in response to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id147eac84-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a notification under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s398"},"text":"section 398 of this title","children":[],"tail":", including planning and otherwise preparing to take such action; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147eac85-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a recall of food under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id147eac86-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities; application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id147eac87-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible entity” means an entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id147eac88-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id147eac89-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id147eac8a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a locality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id147eac8b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a territory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id147eac8c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304/e"},"text":"section 5304(e) of title 25","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id147eac8d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/b/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit food safety training entity that collaborates with 1 or more institutions of higher education; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147eac8e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that submits an application to the Secretary at such time, in such manner, and including such information as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147eac8f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application submitted under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id147eac90-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that the eligible entity has developed plans to engage in the types of activities described in subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147eac91-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the types of activities to be funded by the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147eac92-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an itemization of how grant funds received under this section will be expended;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147eac93-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how grant activities will be monitored; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147eac94-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement by the eligible entity to report information required by the Secretary to conduct evaluations under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id147eac95-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The funds provided under subsection (a) shall be available to an eligible entity that receives a grant under this section only to the extent such entity funds the food safety programs of such entity independently of any grant under this section in each year of the grant at a level equal to the level of such funding in the previous year, increased by the Consumer Price Index. Such non-Federal matching funds may be provided directly or through donations from public or private entities and may be in cash or in-kind, fairly evaluated, including plant, equipment, or services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id147eac96-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id147eac97-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award a grant under this section in each subsequent fiscal year without reapplication for a period of not more than 3 years, provided the requirements of subsection (c) are met for the previous fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147eac98-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award a grant under this section in a fiscal year for which the requirement of subsection (c) has not been met only if such requirement was not met because such funding was diverted for response to 1 or more natural disasters or in other extenuating circumstances that the Secretary may determine appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id147eac99-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award grants to an individual grant recipient under this section for periods of not more than 3 years. In the event the Secretary conducts a program evaluation, funding in the second year or third year of the grant, where applicable, shall be contingent on a successful program evaluation by the Secretary after the first year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id147eac9a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Progress and evaluation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id147eac9b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall measure the status and success of each grant program authorized under the FDA Food Safety Modernization Act (and any amendment made by such Act), including the grant program under this section. A recipient of a grant described in the preceding sentence shall, at the end of each grant year, provide the Secretary with information on how grant funds were spent and the status of the efforts by such recipient to enhance food safety. To the extent practicable, the Secretary shall take the performance of such a grant recipient into account when determining whether to continue funding for such recipient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147eac9c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No duplication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out paragraph (1), the Secretary shall not duplicate the efforts of the Secretary under other provisions of this chapter or the FDA Food Safety Modernization Act that require measurement and review of the activities of grant recipients under either this chapter or such Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id147eac9d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement not supplant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grant funds received under this section shall be used to supplement, and not supplant, non-Federal funds and any other Federal funds available to carry out the activities described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id147eac9e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of making grants under this section, there are authorized to be appropriated such sums as may be necessary for fiscal years 2011 through 2015.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id147eac9f-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s1009"},"text":"June 25, 1938, ch. 675, § 1009","children":[],"tail":", formerly § 909, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/188/tIII/s311"},"text":"Pub. L. 107–188, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-12"},"text":"June 12, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/673"},"text":"116 Stat. 673","children":[],"tail":"; renumbered § 1009 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/31/dA/tI"},"text":"Pub. L. 111–31, div. A, title I","children":[],"tail":", §§ 101(b)(2), 103(n), "},{"tag":"date","attrib":{"date":"2009-06-22"},"text":"June 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1784"},"text":"123 Stat. 1784","children":[],"tail":", 1838; "},{"tag":"ref","attrib":{"href":"/us/pl/111/353/tII/s210/a"},"text":"Pub. L. 111–353, title II, § 210(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3948"},"text":"124 Stat. 3948","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id147eaca0-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id147eaca1-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id147eaca2-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The FDA Food Safety Modernization Act, referred to in subsec. (f), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/353"},"text":"Pub. L. 111–353","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3885"},"text":"124 Stat. 3885","children":[],"tail":", which enacted chapter 27 (§ 2201 et seq.) and sections 350g to 350"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–1, 379j–31, 384a to 384d, 399c, and 399d of this title, "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7625"},"text":"section 7625 of Title 7","children":[],"tail":", Agriculture, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s280g–16"},"text":"section 280g–16 of Title 42","children":[],"tail":", The Public Health and Welfare, amended sections 331, 333, 334, 350b to 350d, 350f, 374, 381, 393, and 399 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s247b–20"},"text":"section 247b–20 of Title 42","children":[],"tail":", and enacted provisions set out as notes under sections 331, 334, 342, 350b, 350d, 350e, 350g to 350j, 350"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":", and 381 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s2201"},"text":"section 2201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14811da3-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/353"},"text":"Pub. L. 111–353","children":[],"tail":" amended section generally. Prior to amendment, section related to grants to States for inspections."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/31/s103/n"},"text":"Pub. L. 111–31, § 103(n)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s398"},"text":"section 398 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14811da4-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id14811da5-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/353"},"text":"Pub. L. 111–353","children":[],"tail":" to be construed to apply to certain alcohol-related facilities, to alter jurisdiction and authorities established under certain other Acts, or in a manner inconsistent with international agreements to which the United States is a party, see sections 2206, 2251, and 2252 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
