{"tag":"section","attrib":{"id":"id14b0b996-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s875"},"text":null,"children":[{"tag":"num","attrib":{"value":"875"},"text":"§ 875.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative hearings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14b0b997-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s875/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Power of Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out his functions under this subchapter, the Attorney General may hold hearings, sign and issue subpenas, administer oaths, examine witnesses, and receive evidence at any place in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14b0b998-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s875/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures applicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this subchapter, notice shall be given and hearings shall be conducted under appropriate procedures of subchapter II of chapter 5 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14b0b999-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/tII/s505"},"text":"Pub. L. 91–513, title II, § 505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1272"},"text":"84 Stat. 1272","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
