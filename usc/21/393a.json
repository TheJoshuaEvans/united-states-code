{"tag":"section","attrib":{"id":"id147eac49-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s393a"},"text":null,"children":[{"tag":"num","attrib":{"value":"393a"},"text":"§ 393a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Pediatric Therapeutics","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id147eac4a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s393a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services shall establish an Office of Pediatric Therapeutics within the Food and Drug Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id147eac4b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s393a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office of Pediatric Therapeutics shall be responsible for coordination and facilitation of all activities of the Food and Drug Administration that may have any effect on a pediatric population or the practice of pediatrics or may in any other way involve pediatric issues, including increasing pediatric access to medical devices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id147eac4c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s393a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The staff of the Office of Pediatric Therapeutics shall coordinate with employees of the Department of Health and Human Services who exercise responsibilities relating to pediatric therapeutics and shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id147eac4d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s393a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more additional individuals with expertise concerning ethical issues presented by the conduct of clinical research in the pediatric population;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147eac4e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s393a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsection (d), one or more additional individuals with necessary expertise in a pediatric subpopulation that is, as determined through consideration of the reports and recommendations issued by the Institute of Medicine and the Comptroller General of the United States, less likely to be studied as a part of a written request issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355a"},"text":"section 355a of this title","children":[],"tail":" or an assessment under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355c"},"text":"section 355c of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147eac4f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s393a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more additional individuals with expertise in pediatric epidemiology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147eac50-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s393a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more additional individuals with expertise in pediatrics as may be necessary to perform the activities described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id147eac51-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s393a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Neonatology expertise","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At least one of the individuals described in subsection (c)(2) shall have expertise in neonatology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id147eac52-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/109/s6"},"text":"Pub. L. 107–109, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-04"},"text":"Jan. 4, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1414"},"text":"115 Stat. 1414","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/85/tIII/s306/a"},"text":"Pub. L. 110–85, title III, § 306(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/864"},"text":"121 Stat. 864","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/144/tV/s511"},"text":"Pub. L. 112–144, title V, § 511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1050"},"text":"126 Stat. 1050","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/52/tV/s505/d/1"},"text":"Pub. L. 115–52, title V, § 505(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-18"},"text":"Aug. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1047"},"text":"131 Stat. 1047","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id147eac53-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id147eac54-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id147eac55-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Best Pharmaceuticals for Children Act, and not as part of the Federal Food, Drug, and Cosmetic Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id147eac56-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/52"},"text":"Pub. L. 115–52","children":[],"tail":" substituted “At least” for “For the 5-year period beginning on "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", at least”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (c)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/144/s511/1"},"text":"Pub. L. 112–144, § 511(1)","children":[],"tail":", added pars. (2) and (3) and redesignated former par. (2) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/144/s511/2"},"text":"Pub. L. 112–144, § 511(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/85"},"text":"Pub. L. 110–85","children":[],"tail":" inserted “, including increasing pediatric access to medical devices” before period at end."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
