{"tag":"section","attrib":{"id":"id14cfb2fd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1902"},"text":null,"children":[{"tag":"num","attrib":{"value":"1902"},"text":"§ 1902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purpose of this chapter is to provide authority for the identification of, and application of sanctions on a worldwide basis to, significant foreign narcotics traffickers, their organizations, and the foreign persons who provide support to those significant foreign narcotics traffickers and their organizations, whose activities threaten the national security, foreign policy, and economy of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id14cfb2fe-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/120/tVIII/s803"},"text":"Pub. L. 106–120, title VIII, § 803","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-03"},"text":"Dec. 3, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1626"},"text":"113 Stat. 1626","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14cfb2ff-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14cfb300-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14cfb301-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title VIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/120"},"text":"Pub. L. 106–120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-03"},"text":"Dec. 3, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1626"},"text":"113 Stat. 1626","children":[],"tail":", which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1901"},"text":"section 1901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
