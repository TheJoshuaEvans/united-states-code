{"tag":"section","attrib":{"id":"id14bf1054-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1054"},"text":null,"children":[{"tag":"num","attrib":{"value":"1054"},"text":"§ 1054.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report to Congressional committees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14bf1055-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1054/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002174"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002174"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No subsec. (b) has been enacted."}],"tail":" Not later than March 1 of each year following "},{"tag":"date","attrib":{"date":"1970-12-29"},"text":"December 29, 1970","children":[],"tail":", the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a comprehensive and detailed written report with respect to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id14bf1056-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1054/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the processing, storage, handling, and distribution of eggs and egg products subject to the provisions of this chapter; the inspection of establishments operated in connection therewith; the effectiveness of the operation of the inspection, including the effectiveness of the operations of State egg inspection programs; and recommendations for legislation to improve such program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14bf1057-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1054/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the administration of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1046"},"text":"section 1046 of this title","children":[],"tail":" (relating to imports) during the immediately preceding calendar year, including but not limited to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14bf1058-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1054/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification by the Secretary that foreign plants exporting eggs or egg products to the United States have complied with requirements of this chapter and regulations issued thereunder;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14bf1059-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1054/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the names and locations of plants authorized or permitted to export eggs or egg products to the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14bf105a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1054/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of inspectors employed by the Department of Agriculture in the calendar year concerned who were assigned to inspect plants referred to in paragraph (B) hereof and the frequency with which each such plant was inspected by such inspectors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14bf105b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1054/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of inspectors that were licensed by each country from which any imports were received and that were assigned, during the calendar year concerned, to inspect such imports and the facilities in which such imports were handled; and the frequency and effectiveness of such inspections;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14bf105c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1054/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total volume of eggs and egg products which was imported into the United States during the calendar year concerned from each country, including a separate itemization of the volume of each major category of such imports from each country during such year, and a detailed report of rejections of plants and products because of failure to meet appropriate standards prescribed by this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14bf105d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1054/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for legislation to improve such program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14bf105e-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/597/s26"},"text":"Pub. L. 91–597, § 26","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-29"},"text":"Dec. 29, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1634"},"text":"84 Stat. 1634","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/437/s8/4"},"text":"Pub. L. 103–437, § 8(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4588"},"text":"108 Stat. 4588","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14bf105f-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14bf1060-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14bf1061-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(1), (2)(A), (E), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/597"},"text":"Pub. L. 91–597","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-29"},"text":"Dec. 29, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1620"},"text":"84 Stat. 1620","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1031"},"text":"section 1031 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14bf1062-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/437"},"text":"Pub. L. 103–437","children":[],"tail":" substituted “Agriculture, Nutrition, and Forestry” for “Agriculture and Forestry” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14bf1063-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id14bf1064-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/597/s29"},"text":"section 29 of Pub. L. 91–597","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1031"},"text":"section 1031 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
