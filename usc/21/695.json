{"tag":"section","attrib":{"id":"id1491bf85-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s695"},"text":null,"children":[{"tag":"num","attrib":{"value":"695"},"text":"§ 695.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of cost of meat-inspection service; exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The cost of inspection rendered on and after ","children":[{"tag":"date","attrib":{"date":"1948-07-01"},"text":"July 1, 1948","children":[],"tail":", under the requirements of laws relating to Federal inspection of meat and meat food products shall be borne by the United States except the cost of overtime and holiday pay paid pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2219a"},"text":"section 2219a of title 7","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id1491bf86-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-05/ch423"},"text":"June 5, 1948, ch. 423","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/344"},"text":"62 Stat. 344","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10703/c/2"},"text":"Pub. L. 107–171, title X, § 10703(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/517"},"text":"116 Stat. 517","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1491bf87-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1491bf88-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic