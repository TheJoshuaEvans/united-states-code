{"tag":"section","attrib":{"id":"id14050f70-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356f"},"text":null,"children":[{"tag":"num","attrib":{"value":"356f"},"text":"§ 356f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hospital repackaging of drugs in shortage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14050f71-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14050f72-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drug","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “drug” excludes any controlled substance (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"section 802 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14050f73-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “health system” means a collection of hospitals that are owned and operated by the same entity and that share access to databases with drug order information for their patients.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14050f74-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repackage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section only, the term “repackage”, with respect to a drug, means to divide the volume of a drug into smaller amounts in order to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14050f75-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356f/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extend the supply of a drug in response to the placement of the drug on a drug shortage list under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s356e"},"text":"section 356e of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14050f76-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356f/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate access to the drug by hospitals within the same health system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14050f77-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion from registration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this chapter, a hospital shall not be considered an establishment for which registration is required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360"},"text":"section 360 of this title","children":[],"tail":" solely because it repackages a drug and transfers it to another hospital within the same health system in accordance with the conditions in subsection (c)—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id14050f78-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during any period in which the drug is listed on the drug shortage list under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s356e"},"text":"section 356e of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14050f79-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the 60-day period following any period described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14050f7a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (b) shall only apply to a hospital, with respect to the repackaging of a drug for transfer to another hospital within the same health system, if the following conditions are met:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14050f7b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drug for intrasystem use only","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In no case may a drug that has been repackaged in accordance with this section be sold or otherwise distributed by the health system or a hospital within the system to an entity or individual that is not a hospital within such health system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14050f7c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with State rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Repackaging of a drug under this section shall be done in compliance with applicable State requirements of each State in which the drug is repackaged and received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14050f7d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply on or after the date on which the Secretary issues final guidance that clarifies the policy of the Food and Drug Administration regarding hospital pharmacies repackaging and safely transferring repackaged drugs to other hospitals within the same health system during a drug shortage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14050f7e-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s506F"},"text":"June 25, 1938, ch. 675, § 506F","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/144/tX/s1007"},"text":"Pub. L. 112–144, title X, § 1007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1106"},"text":"126 Stat. 1106","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
