{"tag":"section","attrib":{"id":"id14d6dedb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2243"},"text":null,"children":[{"tag":"num","attrib":{"value":"2243"},"text":"§ 2243.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Smuggled food","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14d6dedc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2243/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"January 4, 2011","children":[],"tail":", the Secretary shall, in coordination with the Secretary of Homeland Security, develop and implement a strategy to better identify smuggled food and prevent entry of such food into the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d6dedd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2243/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to Homeland Security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 10 days after the Secretary identifies a smuggled food that the Secretary believes would cause serious adverse health consequences or death to humans or animals, the Secretary shall provide to the Secretary of Homeland Security a notification under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s350f/n"},"text":"section 350f(n) of this title","children":[],"tail":" describing the smuggled food and, if available, the names of the individuals or entities that attempted to import such food into the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d6dede-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2243/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d6dedf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2243/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies a smuggled food;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d6dee0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2243/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonably believes exposure to the food would cause serious adverse health consequences or death to humans or animals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d6dee1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2243/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonably believes that the food has entered domestic commerce and is likely to be consumed,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary shall promptly issue a press release describing that food and shall use other emergency communication or recall networks, as appropriate, to warn consumers and vendors about the potential threat.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d6dee2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2243/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of section","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall affect the authority of the Secretary to issue public notifications under other circumstances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d6dee3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2243/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “smuggled food” means any food that a person introduces into the United States through fraudulent means or with the intent to defraud or mislead.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14d6dee4-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/353/tIII/s309"},"text":"Pub. L. 111–353, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3966"},"text":"124 Stat. 3966","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14d6dee5-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14d6dee6-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14d6dee7-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Secretary, referred to in text, probably means the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
