{"tag":"section","attrib":{"id":"id13bfef9b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s336"},"text":null,"children":[{"tag":"num","attrib":{"value":"336"},"text":"§ 336.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report of minor violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed as requiring the Secretary to report for prosecution, or for the institution of libel or injunction proceedings, minor violations of this chapter whenever he believes that the public interest will be adequately served by a suitable written notice or warning.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id13bfef9c-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s309"},"text":"June 25, 1938, ch. 675, § 309","children":[],"tail":", formerly § 306, "},{"tag":"ref","attrib":{"href":"/us/stat/52/1045"},"text":"52 Stat. 1045","children":[],"tail":"; renumbered § 309, "},{"tag":"ref","attrib":{"href":"/us/pl/102/282/s2"},"text":"Pub. L. 102–282, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-13"},"text":"May 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/150"},"text":"106 Stat. 150","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id13bfef9d-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id13bfef9e-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id13bfef9f-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of Federal Security Administrator to Secretary of Health, Education, and Welfare [now Health and Human Services], and of Food and Drug Administration in the Department of Agriculture to Federal Security Agency, see notes set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s321"},"text":"section 321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
