{"tag":"section","attrib":{"id":"id13c71c1c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s343–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"343–3"},"text":"§ 343–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id13c71c1d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s343–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No provision of section 321(n), 343(a), or 348 of this title shall be construed to require on the label or labeling of a food a separate radiation disclosure statement that is more prominent than the declaration of ingredients required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s343/i/2"},"text":"section 343(i)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13c71c1e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s343–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this section, the term “radiation disclosure statement” means a written statement that discloses that a food has been intentionally subject to radiation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id13c71c1f-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s403C"},"text":"June 25, 1938, ch. 675, § 403C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/115/tIII/s306"},"text":"Pub. L. 105–115, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2353"},"text":"111 Stat. 2353","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id13c71c20-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id13c71c21-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id13c71c22-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/115/s501"},"text":"section 501 of Pub. L. 105–115","children":[],"tail":", set out as an Effective Date of 1997 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s321"},"text":"section 321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
