{"tag":"section","attrib":{"id":"id1469293a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379l"},"text":null,"children":[{"tag":"num","attrib":{"value":"379l"},"text":"§ 379l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1469293b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct training and education programs for the employees of the Food and Drug Administration relating to the regulatory responsibilities and policies established by this chapter, including programs for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1469293c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379l/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scientific training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1469293d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379l/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training to improve the skill of officers and employees authorized to conduct inspections under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s374"},"text":"section 374 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1469293e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379l/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training to achieve product specialization in such inspections; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1469293f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379l/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training in administrative process and procedure and integrity issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14692940-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intramural fellowships and other training programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Commissioner, may, through fellowships and other training programs, conduct and support intramural research training for predoctoral and postdoctoral scientists and physicians. Any such fellowships and training programs under this section or under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s379dd/d/2/A/ix"},"text":"section 379dd(d)(2)(A)(ix) of this title","children":[],"tail":" may include provision by such scientists and physicians of services on a voluntary and uncompensated basis, as the Secretary determines appropriate. Such scientists and physicians shall be subject to all legal and ethical requirements otherwise applicable to officers or employees of the Department of Health and Human Services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14692941-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s746"},"text":"June 25, 1938, ch. 675, § 746","children":[],"tail":", formerly § 742, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/115/tIV/s408/a"},"text":"Pub. L. 105–115, title IV, § 408(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2371"},"text":"111 Stat. 2371","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/85/tVI/s601/c"},"text":"Pub. L. 110–85, title VI, § 601(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/897"},"text":"121 Stat. 897","children":[],"tail":"; renumbered § 746, "},{"tag":"ref","attrib":{"href":"/us/pl/110/316/tII/s202/a"},"text":"Pub. L. 110–316, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3515"},"text":"122 Stat. 3515","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14692942-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14692943-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id14692944-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 746 of act ","children":[{"tag":"date","attrib":{"date":"1938-06-25"},"text":"June 25, 1938","children":[],"tail":", was renumbered section 749 and is classified to section 379"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14692945-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/85"},"text":"Pub. L. 110–85","children":[],"tail":" inserted at end “Any such fellowships and training programs under this section or under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s379dd/d/2/A/ix"},"text":"section 379dd(d)(2)(A)(ix) of this title","children":[],"tail":" may include provision by such scientists and physicians of services on a voluntary and uncompensated basis, as the Secretary determines appropriate. Such scientists and physicians shall be subject to all legal and ethical requirements otherwise applicable to officers or employees of the Department of Health and Human Services.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14692946-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id14692947-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/115/s501"},"text":"section 501 of Pub. L. 105–115","children":[],"tail":", set out as an Effective Date of 1997 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s321"},"text":"section 321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
