{"tag":"section","attrib":{"id":"id14c3cc71-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1533"},"text":null,"children":[{"tag":"num","attrib":{"value":"1533"},"text":"§ 1533.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information collection and dissemination with respect to grant recipients","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14c3cc72-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1533/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coalition information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c3cc73-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1533/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General auditing authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of audit and examination, the Administrator—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c3cc74-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1533/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have access to any books, documents, papers, and records that are pertinent to any grant or grant renewal request under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c3cc75-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1533/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may periodically request information from a grant recipient to ensure that the grant recipient meets the applicable criteria under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1532/a"},"text":"section 1532(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3cc76-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1533/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall issue a request for proposal regarding, with respect to the grants awarded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1532"},"text":"section 1532 of this title","children":[],"tail":", the application process, grant renewal, and suspension or withholding of renewal grants. Each application under this paragraph shall be in writing and shall be subject to review by the Administrator."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3cc77-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1533/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall, to the maximum extent practicable and in a manner consistent with applicable law, minimize reporting requirements by a grant recipient and expedite any application for a renewal grant made under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c3cc78-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1533/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection and dissemination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c3cc79-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1533/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may collect data from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c3cc7a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1533/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national substance use and misuse organizations that work with eligible coalitions, community anti-drug coalitions, departments or agencies of the Federal Government, or State or local governments and the governing bodies of Indian tribes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c3cc7b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1533/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other entity or organization that carries out activities that relate to the purposes of the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3cc7c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1533/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities of Administrator","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c3cc7d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1533/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the utility of specific initiatives relating to the purposes of the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c3cc7e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1533/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct an evaluation of the Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c3cc7f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1533/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" disseminate information described in this subsection to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14c3cc80-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1533/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible coalitions and other substance use and misuse organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14c3cc81-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1533/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the general public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3cc82-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1533/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall carry out activities under this subsection in consultation with the Advisory Commission and the National Community Antidrug Coalition Institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3cc83-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1533/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of certain funds for evaluation of Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts for activities under paragraph (2)(B) may not be derived from amounts under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1524/a"},"text":"section 1524(a) of this title","children":[],"tail":" except for amounts that are available under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1524/b"},"text":"section 1524(b) of this title","children":[],"tail":" for administrative costs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14c3cc84-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tI/s1033"},"text":"Pub. L. 100–690, title I, § 1033","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/20/s2/a/2"},"text":"Pub. L. 105–20, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-27"},"text":"June 27, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/230"},"text":"111 Stat. 230","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/82/s1/e"},"text":"Pub. L. 107–82, § 1(e)","children":[],"tail":", (f), "},{"tag":"date","attrib":{"date":"2001-12-14"},"text":"Dec. 14, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/818"},"text":"115 Stat. 818","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVIII/s8203/b/4/A"},"text":"Pub. L. 115–271, title VIII, § 8203(b)(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10