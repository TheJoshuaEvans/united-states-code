{"tag":"section","attrib":{"id":"id13d302f3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e"},"text":null,"children":[{"tag":"num","attrib":{"value":"350e"},"text":"§ 350e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanitary transportation practices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id13d302f4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13d302f5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bulk vehicle","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “bulk vehicle” includes a tank truck, hopper truck, rail tank car, hopper car, cargo tank, portable tank, freight container, or hopper bin, and any other vehicle in which food is shipped in bulk, with the food coming into direct contact with the vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13d302f6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “transportation” means any movement in commerce by motor vehicle or rail vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13d302f7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall by regulation require shippers, carriers by motor vehicle or rail vehicle, receivers, and other persons engaged in the transportation of food to use sanitary transportation practices prescribed by the Secretary to ensure that food is not transported under conditions that may render the food adulterated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13d302f8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations under subsection (b) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13d302f9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prescribe such practices as the Secretary determines to be appropriate relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13d302fa-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sanitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d302fb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" packaging, isolation, and other protective measures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d302fc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limitations on the use of vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d302fd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information to be disclosed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id13d302fe-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/c/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a carrier by a person arranging for the transport of food; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id13d302ff-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/c/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to a manufacturer or other person that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id13d30300-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/c/1/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arranges for the transportation of food by a carrier; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id13d30301-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/c/1/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnishes a tank vehicle or bulk vehicle for the transportation of food; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d30302-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recordkeeping; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13d30303-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13d30304-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of nonfood products that the Secretary determines may, if shipped in a bulk vehicle, render adulterated food that is subsequently transported in the same vehicle; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d30305-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of nonfood products that the Secretary determines may, if shipped in a motor vehicle or rail vehicle (other than a tank vehicle or bulk vehicle), render adulterated food that is simultaneously or subsequently transported in the same vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13d30306-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waivers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13d30307-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may waive any requirement under this section, with respect to any class of persons, vehicles, food, or nonfood products, if the Secretary determines that the waiver—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13d30308-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not result in the transportation of food under conditions that would be unsafe for human or animal health; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d30309-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not be contrary to the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13d3030a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall publish in the Federal Register any waiver and the reasons for the waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13d3030b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13d3030c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A requirement of a State or political subdivision of a State that concerns the transportation of food is preempted if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13d3030d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complying with a requirement of the State or political subdivision and a requirement of this section, or a regulation prescribed under this section, is not possible; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d3030e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirement of the State or political subdivision as applied or enforced is an obstacle to accomplishing and carrying out this section or a regulation prescribed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13d3030f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection applies to transportation that occurs on or after the effective date of the regulations promulgated under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13d30310-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350e/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance of other agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Transportation, the Secretary of Agriculture, the Administrator of the Environmental Protection Agency, and the heads of other Federal agencies, as appropriate, shall provide assistance on request, to the extent resources are available, to the Secretary for the purposes of carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id13d30311-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s416"},"text":"June 25, 1938, ch. 675, § 416","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tVII/s7202/b"},"text":"Pub. L. 109–59, title VII, § 7202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1911"},"text":"119 Stat. 1911","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id13d30312-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id13d30313-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id13d30314-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2005-10-01"},"text":"Oct. 1, 2005","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7204"},"text":"section 7204 of Pub. L. 109–59","children":[],"tail":", set out as an Effective Date of 2005 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s331"},"text":"section 331 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id13d30315-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/353/tI/s111/a"},"text":"Pub. L. 111–353, title I, § 111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3916"},"text":"124 Stat. 3916","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/353/tI/s111/a"},"text":"“Not later than 18 months after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":"], the Secretary shall promulgate regulations described in section 416(b) of the Federal Food, Drug, and Cosmetic Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s350e/b"},"text":"21 U.S.C. 350e(b)","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
