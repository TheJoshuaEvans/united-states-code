{"tag":"section","attrib":{"id":"id1440b9d4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364e"},"text":null,"children":[{"tag":"num","attrib":{"value":"364e"},"text":"§ 364e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Labeling","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1440b9d5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each cosmetic product shall bear a label that includes a domestic address, domestic phone number, or electronic contact information, which may include a website, through which the responsible person can receive adverse event reports with respect to such cosmetic product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1440b9d6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fragrance allergens","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The responsible person shall identify on the label of a cosmetic product each fragrance allergen included in such cosmetic product. Substances that are fragrance allergens for purposes of this subsection shall be determined by the Secretary by regulation. The Secretary shall issue a notice of proposed rulemaking promulgating the regulation implementing this requirement not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", and not later than 180 days after the date on which the public comment period on the proposed rulemaking closes, shall issue a final rulemaking. In promulgating regulations implementing this subsection, the Secretary shall consider international, State, and local requirements for allergen disclosure, including the substance and format of requirements in the European Union, and may establish threshold levels of amounts of substances subject to disclosure pursuant to such regulations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1440b9d7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cosmetic products for professional use","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1440b9d8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of professional","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “professional” means an individual who is licensed by an official State authority to practice in the field of cosmetology, nail care, barbering, or esthetics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1440b9d9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Professional use labeling","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A cosmetic product introduced into interstate commerce and intended to be used only by a professional shall bear a label that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1440b9da-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364e/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains a clear and prominent statement that the product shall be administered or used only by licensed professionals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1440b9db-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364e/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in conformity with the requirements of the Secretary for cosmetics labeling under this chapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1453/a"},"text":"section 1453(a) of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1440b9dc-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s609"},"text":"June 25, 1938, ch. 675, § 609","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tIII/s3502"},"text":"Pub. L. 117–328, div. FF, title III, § 3502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5854"},"text":"136 Stat. 5854","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1440b9dd-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1440b9de-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id1440b9df-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tIII/s3503/b/2"},"text":"Pub. L. 117–328, div. FF, title III, § 3503(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5859"},"text":"136 Stat. 5859","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dFF/tIII/s3503/b/2"},"text":"“Section 609(a) of the Federal Food, Drug, and Cosmetic Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s364e/a"},"text":"21 U.S.C. 364e(a)","children":[],"tail":"], as added by section 802 [probably should be “section 3502”], shall take effect on the date that is 2 years after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id1440b9e0-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction; Confidentiality","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s3502"},"text":"section 3502 of Pub. L. 117–328","children":[],"tail":", which enacted this section, to be construed to authorize the disclosure of information that is prohibited from disclosure under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s331/j"},"text":"section 331(j) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1905"},"text":"section 1905 of title 18","children":[],"tail":" or that is subject to withholding under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/4"},"text":"section 552(b)(4) of title 5","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/s3503/c/2"},"text":"section 3503(c)(2) of Pub. L. 117–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s364"},"text":"section 364 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
