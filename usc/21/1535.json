{"tag":"section","attrib":{"id":"id14c3cc96-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1535"},"text":null,"children":[{"tag":"num","attrib":{"value":"1535"},"text":"§ 1535.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental grants for coalition mentoring activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14c3cc97-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1535/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to make grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1531"},"text":"section 1531 of this title","children":[],"tail":", the Director may award an initial grant under this subsection, and renewal grants under subsection (f), to any coalition awarded a grant under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1532"},"text":"section 1532 of this title","children":[],"tail":" that meets the criteria specified in subsection (d) in order to fund coalition mentoring activities by such coalition in support of the program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c3cc98-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1535/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment with other grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c3cc99-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1535/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded to a coalition under this section is in addition to any grant awarded to the coalition under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1532"},"text":"section 1532 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3cc9a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1535/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for basic grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A coalition may not be awarded a grant under this section for a fiscal year unless the coalition was awarded a grant or renewal grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1532/b"},"text":"section 1532(b) of this title","children":[],"tail":" for that fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c3cc9b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1535/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A coalition seeking a grant under this section shall submit to the Administrator an application for the grant in such form and manner as the Administrator may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c3cc9c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1535/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A coalition meets the criteria specified in this subsection if the coalition—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c3cc9d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1535/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been in existence for at least 5 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3cc9e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1535/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has achieved, by or through its own efforts, measurable results in the prevention and treatment of substance use and misuse among youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3cc9f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1535/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has staff or members willing to serve as mentors for persons seeking to start or expand the activities of other coalitions in the prevention and treatment of substance use and misuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3cca0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1535/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has demonstrable support from some members of the community in which the coalition mentoring activities to be supported by the grant under this section are to be carried out; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3cca1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1535/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits to the Administrator a detailed plan for the coalition mentoring activities to be supported by the grant under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c3cca2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1535/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grant funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A coalition awarded a grant under this section shall use the grant amount for mentoring activities to support and encourage the development of new, self-supporting community coalitions that are focused on the prevention and treatment of substance use and misuse in such new coalitions’ communities. The mentoring coalition shall encourage such development in accordance with the plan submitted by the mentoring coalition under subsection (d)(5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c3cca3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1535/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may make a renewal grant to any coalition awarded a grant under subsection (a), or a previous renewal grant under this subsection, if the coalition, at the time of application for such renewal grant—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c3cca4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1535/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continues to meet the criteria specified in subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3cca5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1535/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has made demonstrable progress in the development of one or more new, self-supporting community coalitions that are focused on the prevention and treatment of substance use and misuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c3cca6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1535/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant amounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c3cca7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1535/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraphs (2) and (3), the total amount of grants awarded to a coalition under this section for a fiscal year may not exceed the amount of non-Federal funds raised by the coalition, including in-kind contributions, for that fiscal year. Funds appropriated for the substance use and misuse activities of a coalition that includes a representative of the Bureau of Indian Affairs, the Indian Health Service, or a tribal government agency with expertise in the field of substance use and misuse may be counted as non-Federal funds raised by the coalition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3cca8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1535/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the initial grant awarded to a coalition under subsection (a) may not exceed $75,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3cca9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1535/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total amount of renewal grants awarded to a coalition under subsection (f) for any fiscal year may not exceed $75,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c3ccaa-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1535/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal year limitation on amount available for grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total amount available for grants under this section, including renewal grants under subsection (f), in any fiscal year may not exceed the amount equal to five percent of the amount authorized to be appropriated by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1524/a"},"text":"section 1524(a) of this title","children":[],"tail":" for that fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c3ccab-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1535/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority in awarding initial grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding initial grants under this section, priority shall be given to a coalition that expressly proposes to provide mentorship to a coalition or aspiring coalition serving economically disadvantaged areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14c3ccac-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tI/s1035"},"text":"Pub. L. 100–690, title I, § 1035","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/82/s2"},"text":"Pub. L. 107–82, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-14"},"text":"Dec. 14, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/819"},"text":"115 Stat. 819","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVIII/s8203/b/4/A"},"text":"Pub. L. 115–271, title VIII, § 8203(b)(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4111"},"text":"132 Stat. 4111","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/74/s2/c/1/A/ii/II"},"text":"Pub. L. 116–74, § 2(c)(1)(A)(ii)(II)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-11-27"},"text":"Nov. 27, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1157"},"text":"133 Stat. 1157","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14c3ccad-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14c3ccae-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14c3ccaf-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/74/s2/c/1/A/ii/II"},"text":"Pub. L. 116–74, § 2(c)(1)(A)(ii)(II)","children":[],"tail":", made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8203/b/4/A"},"text":"Pub. L. 115–271, § 8203(b)(4)(A)","children":[],"tail":". See 2018 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8203/b/4/A"},"text":"Pub. L. 115–271, § 8203(b)(4)(A)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/74/s2/c/1/A/ii/II"},"text":"Pub. L. 116–74, § 2(c)(1)(A)(ii)(II)","children":[],"tail":", substituted “substance use and misuse” for “substance abuse” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14c3ccb0-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id14c3ccb1-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/74"},"text":"Pub. L. 116–74","children":[],"tail":" effective as if included in the enactment of subtitle K of title VIII of "},{"tag":"ref","attrib":{"href":"/us/pl/115/271"},"text":"Pub. L. 115–271","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/74/s2/c/2"},"text":"section 2(c)(2) of Pub. L. 116–74","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1522"},"text":"section 1522 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
