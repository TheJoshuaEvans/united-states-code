{"tag":"section","attrib":{"id":"id147c3b3b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387q"},"text":null,"children":[{"tag":"num","attrib":{"value":"387q"},"text":"§ 387q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tobacco Products Scientific Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id147c3b3c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387q/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"2009-06-22"},"text":"June 22, 2009","children":[],"tail":", the Secretary shall establish a 12-member advisory committee, to be known as the Tobacco Products Scientific Advisory Committee (in this section referred to as the “Advisory Committee”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id147c3b3d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387q/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id147c3b3e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387q/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id147c3b3f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387q/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall appoint as members of the Tobacco Products Scientific Advisory Committee individuals who are technically qualified by training and experience in medicine, medical ethics, science, or technology involving the manufacture, evaluation, or use of tobacco products, who are of appropriately diversified professional backgrounds. The committee shall be composed of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id147c3b40-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387q/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 7 individuals who are physicians, dentists, scientists, or health care professionals practicing in the area of oncology, pulmonology, cardiology, toxicology, pharmacology, addiction, or any other relevant specialty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id147c3b41-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387q/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 individual who is an officer or employee of a State or local government or of the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id147c3b42-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387q/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 individual as a representative of the general public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id147c3b43-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387q/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 individual as a representative of the interests of the tobacco manufacturing industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id147c3b44-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387q/b/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 individual as a representative of the interests of the small business tobacco manufacturing industry, which position may be filled on a rotating, sequential basis by representatives of different small business tobacco manufacturers based on areas of expertise relevant to the topics being considered by the Advisory Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id147c3b45-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387q/b/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 individual as a representative of the interests of the tobacco growers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3b46-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387q/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonvoting members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the committee appointed under clauses (iv), (v), and (vi) of subparagraph (A) shall serve as consultants to those described in clauses (i) through (iii) of subparagraph (A) and shall be nonvoting representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3b47-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387q/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflicts of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No members of the committee, other than members appointed pursuant to clauses (iv), (v), and (vi) of subparagraph (A) shall, during the member’s tenure on the committee or for the 18-month period prior to becoming such a member, receive any salary, grants, or other payments or support from any business that manufactures, distributes, markets, or sells cigarettes or other tobacco products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147c3b48-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387q/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not appoint to the Advisory Committee any individual who is in the regular full-time employ of the Food and Drug Administration or any agency responsible for the enforcement of this chapter. The Secretary may appoint Federal officials as ex officio members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147c3b49-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387q/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall designate 1 of the members appointed under clauses (i), (ii), and (iii) of paragraph (1)(A) to serve as chairperson.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id147c3b4a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387q/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Tobacco Products Scientific Advisory Committee shall provide advice, information, and recommendations to the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id147c3b4b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387q/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as provided in this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147c3b4c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387q/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the effects of the alteration of the nicotine yields from tobacco products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147c3b4d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387q/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on whether there is a threshold level below which nicotine yields do not produce dependence on the tobacco product involved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147c3b4e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387q/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on its review of other safety, dependence, or health issues relating to tobacco products as requested by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id147c3b4f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387q/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation; support; chapter 10 of title 5","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id147c3b50-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387q/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and travel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Advisory Committee who are not officers or employees of the United States, while attending conferences or meetings of the committee or otherwise engaged in its business, shall be entitled to receive compensation at rates to be fixed by the Secretary, which may not exceed the daily equivalent of the rate in effect under the Senior Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5382"},"text":"section 5382 of title 5","children":[],"tail":", for each day (including travel time) they are so engaged; and while so serving away from their homes or regular places of business each member may be allowed travel expenses, including per diem in lieu of subsistence, as authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":" for persons in the Government service employed intermittently."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147c3b51-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387q/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall furnish the Advisory Committee clerical and other assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147c3b52-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387q/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplication of chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"Section 1013 of title 5","children":[],"tail":" does not apply to the Advisory Committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id147c3b53-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387q/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proceedings of advisory panels and committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall make and maintain a transcript of any proceeding of the panel or committee. Each such panel and committee shall delete from any transcript made under this subsection information which is exempt from disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b"},"text":"section 552(b) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id147c3b54-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s917"},"text":"June 25, 1938, ch. 675, § 917","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/31/dA/tI/s101/b/3"},"text":"Pub. L. 111–31, div. A, title I, § 101(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-06-22"},"text":"June 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1824"},"text":"123 Stat. 1824","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/160"},"text":"Pub. L. 117–286, § 4(a)(160)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4323"},"text":"136 Stat. 4323","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id147c3b55-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id147c3b56-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id147c3b57-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/160/A"},"text":"Pub. L. 117–286, § 4(a)(160)(A)","children":[],"tail":", substituted “chapter 10 of title 5” for “FACA” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/160/B"},"text":"Pub. L. 117–286, § 4(a)(160)(B)","children":[],"tail":", substituted “chapter 10 of title 5” for “FACA” in heading and “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"Section 1013 of title 5","children":[],"tail":"” for “Section 14 of the Federal Advisory Committee Act” in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id147c3b58-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id147c3b59-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Modification of Deadlines for Secretarial Action","children":[],"tail":null},{"tag":"p","attrib":{},"text":"With respect to any time periods specified in an amendment by div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/31"},"text":"Pub. L. 111–31","children":[],"tail":" that begin on "},{"tag":"date","attrib":{"date":"2009-06-22"},"text":"June 22, 2009","children":[],"tail":", within which the Secretary of Health and Human Services is required to carry out and complete specified activities, with certain limitations, the calculation of such time periods shall commence on the first day of the first fiscal quarter following the initial 2 consecutive fiscal quarters of fiscal year 2010 for which the Secretary has collected fees under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s387s"},"text":"section 387s of this title","children":[],"tail":", and the Secretary may extend or reduce the duration of one or more such time periods, except that no such period shall be extended for more than 90 days, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/31/s6"},"text":"section 6 of Pub. L. 111–31","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s387"},"text":"section 387 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
