{"tag":"section","attrib":{"id":"id1472c4ea-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384a"},"text":null,"children":[{"tag":"num","attrib":{"value":"384a"},"text":"§ 384a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign supplier verification program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1472c4eb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1472c4ec-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verification requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided under subsections (e) and (f), each importer shall perform risk-based foreign supplier verification activities for the purpose of verifying that the food imported by the importer or agent of an importer is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1472c4ed-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produced in compliance with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s350g"},"text":"section 350g of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s350h"},"text":"section 350h of this title","children":[],"tail":", as appropriate; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1472c4ee-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not adulterated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s342"},"text":"section 342 of this title","children":[],"tail":" or misbranded under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s343/w"},"text":"section 343(w) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1472c4ef-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importer defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “importer” means, with respect to an article of food—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1472c4f0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States owner or consignee of the article of food at the time of entry of such article into the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1472c4f1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case when there is no United States owner or consignee as described in subparagraph (A), the United States agent or representative of a foreign owner or consignee of the article of food at the time of entry of such article into the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1472c4f2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"January 4, 2011","children":[],"tail":", the Secretary shall issue guidance to assist importers in developing foreign supplier verification programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1472c4f3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1472c4f4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"January 4, 2011","children":[],"tail":", the Secretary shall promulgate regulations to provide for the content of the foreign supplier verification program established under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1472c4f5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations promulgated under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1472c4f6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall require that the foreign supplier verification program of each importer be adequate to provide assurances that each foreign supplier to the importer produces the imported food in compliance with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id1472c4f7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384a/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" processes and procedures, including reasonably appropriate risk-based preventive controls, that provide the same level of public health protection as those required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s350g"},"text":"section 350g of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s350h"},"text":"section 350h of this title","children":[],"tail":" (taking into consideration variances granted under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s350h"},"text":"section 350h of this title","children":[],"tail":"), as appropriate; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1472c4f8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384a/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s342"},"text":"section 342 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s343/w"},"text":"section 343(w) of this title","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn002118"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002118"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1472c4f9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include such other requirements as the Secretary deems necessary and appropriate to verify that food imported into the United States is as safe as food produced and sold within the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1472c4fa-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In promulgating regulations under this subsection, the Secretary shall, as appropriate, take into account differences among importers and types of imported foods, including based on the level of risk posed by the imported food.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1472c4fb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Verification activities under a foreign supplier verification program under this section may include monitoring records for shipments, lot-by-lot certification of compliance, annual on-site inspections, checking the hazard analysis and risk-based preventive control plan of the foreign supplier, and periodically testing and sampling shipments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1472c4fc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Record maintenance and access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Records of an importer related to a foreign supplier verification program shall be maintained for a period of not less than 2 years and shall be made available promptly to a duly authorized representative of the Secretary upon request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1472c4fd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption of seafood, juice, and low-acid canned food facilities in compliance with HACCP","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall not apply to a facility if the owner, operator, or agent in charge of such facility is required to comply with, and is in compliance with, 1 of the following standards and regulations with respect to such facility:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1472c4fe-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Seafood Hazard Analysis Critical Control Points Program of the Food and Drug Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1472c4ff-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Juice Hazard Analysis Critical Control Points Program of the Food and Drug Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1472c500-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Thermally Processed Low-Acid Foods Packaged in Hermetically Sealed Containers standards of the Food and Drug Administration (or any successor standards).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The exemption under paragraph (3) shall apply only with respect to microbiological hazards that are regulated under the standards for Thermally Processed Low-Acid Foods Packaged in Hermetically Sealed Containers under part 113 of chapter ","children":[{"tag":"ref","attrib":{"idref":"fn002119"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002119"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “title”."}],"tail":" 21, Code of Federal Regulations (or any successor regulations)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1472c501-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional exemptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, by notice published in the Federal Register, shall establish an exemption from the requirements of this section for articles of food imported in small quantities for research and evaluation purposes or for personal consumption, provided that such foods are not intended for retail sale and are not sold or distributed to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1472c502-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of list of participants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall publish and maintain on the Internet Web site of the Food and Drug Administration a current list that includes the name of, location of, and other information deemed necessary by the Secretary about, importers participating under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1472c503-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s805"},"text":"June 25, 1938, ch. 675, § 805","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/353/tIII/s301/a"},"text":"Pub. L. 111–353, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3953"},"text":"124 Stat. 3953","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1472c504-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1472c505-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id1472c506-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 2 years after ","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/353/s301/d"},"text":"section 301(d) of Pub. L. 111–353","children":[],"tail":", set out as an Effective Date of 2011 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s331"},"text":"section 331 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id1472c507-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in this section to be construed to apply to certain alcohol-related facilities, to alter jurisdiction and authorities established under certain other Acts, or in a manner inconsistent with international agreements to which the United States is a party, see sections 2206, 2251, and 2252 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
