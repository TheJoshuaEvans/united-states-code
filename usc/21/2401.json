{"tag":"section","attrib":{"id":"id14d9506d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2401"},"text":null,"children":[{"tag":"num","attrib":{"value":"2401"},"text":"§ 2401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d9506e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2401/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Anti-doping organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “anti-doping organization” has the meaning given the term in Article 2 of the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d9506f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2401/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Athlete","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “athlete” has the meaning given the term in Article 2 of the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d95070-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2401/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Code","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Code” means the World Anti-Doping Code most recently adopted by WADA on ","children":[{"tag":"date","attrib":{"date":"2003-03-05"},"text":"March 5, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d95071-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2401/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Convention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Convention” means the United Nations Educational, Scientific, and Cultural Organization International Convention Against Doping in Sport done at Paris ","children":[{"tag":"date","attrib":{"date":"2005-10-19"},"text":"October 19, 2005","children":[],"tail":", and ratified by the United States in 2008."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d95072-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2401/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major international sport competition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Major International Sport Competition”— ","children":[{"tag":"ref","attrib":{"idref":"fn002206"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002206"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Term is not capitalized as used in this chapter."}],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d95073-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2401/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means a competition—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14d95074-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2401/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which one or more United States athletes and three or more athletes from other countries participate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d95075-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2401/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is governed by the anti-doping rules and principles of the Code; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d95076-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2401/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in which—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id14d95077-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2401/5/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the competition organizer or sanctioning body receives sponsorship or other financial support from an organization doing business in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14d95078-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2401/5/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the competition organizer or sanctioning body receives compensation for the right to broadcast the competition in the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d95079-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2401/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a competition that is a single event or a competition that consists of a series of events held at different times which, when combined, qualify an athlete or team for an award or other recognition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d9507a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2401/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means any individual, partnership, corporation, association, or other entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d9507b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2401/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited method","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “prohibited method” has the meaning given the term in Article 2 of the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d9507c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2401/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited substance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “prohibited substance” has the meaning given the term in Article 2 of the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d9507d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2401/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scheme in commerce","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “scheme in commerce” means any scheme effectuated in whole or in part through the use in interstate or foreign commerce of any facility for transportation or communication.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d9507e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2401/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" USADA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “USADA” means the United States Anti-Doping Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d9507f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2401/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" WADA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “WADA” means the World Anti-Doping Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14d95080-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/206/s2"},"text":"Pub. L. 116–206, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-04"},"text":"Dec. 4, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/998"},"text":"134 Stat. 998","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14d95081-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14d95082-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id14d95083-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/206/s1"},"text":"Pub. L. 116–206, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-04"},"text":"Dec. 4, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/998"},"text":"134 Stat. 998","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/206/s1"},"text":"“This Act [enacting this chapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3663A"},"text":"section 3663A of Title 18","children":[],"tail":", Crimes and Criminal Procedure] may be cited as the ‘Rodchenkov Anti-Doping Act of 2019’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
