{"tag":"section","attrib":{"id":"id14078042-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357"},"text":null,"children":[{"tag":"num","attrib":{"value":"357"},"text":"§ 357.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualification of drug development tools","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14078043-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process for qualification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14078044-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a process for the qualification of drug development tools for a proposed context of use under which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14078045-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14078046-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requestor initiates such process by submitting a letter of intent to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14078047-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary accepts or declines to accept such letter of intent;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14078048-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14078049-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary accepts the letter of intent, a requestor submits a qualification plan to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1407804a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary accepts or declines to accept the qualification plan; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1407804b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id1407804c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary accepts the qualification plan, the requestor submits to the Secretary a full qualification package;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1407804d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines whether to accept such qualification package for review; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1407804e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/a/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary accepts such qualification package for review, the Secretary conducts such review in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1407804f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance and review of submissions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14078050-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraphs (B), (C), and (D) shall apply with respect to the treatment of a letter of intent, a qualification plan, or a full qualification package submitted under paragraph (1) (referred to in this paragraph as “qualification submissions”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14078051-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance factors; nonacceptance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall determine whether to accept a qualification submission based on factors which may include the scientific merit of the qualification submission. A determination not to accept a submission under paragraph (1) shall not be construed as a final determination by the Secretary under this section regarding the qualification of a drug development tool for its proposed context of use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14078052-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization of qualification review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may prioritize the review of a full qualification package submitted under paragraph (1) with respect to a drug development tool, based on factors determined appropriate by the Secretary, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14078053-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as applicable, the severity, rarity, or prevalence of the disease or condition targeted by the drug development tool and the availability or lack of alternative treatments for such disease or condition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14078054-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification, by the Secretary or by biomedical research consortia and other expert stakeholders, of such a drug development tool and its proposed context of use as a public health priority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14078055-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Engagement of external experts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, for purposes of the review of qualification submissions, through the use of cooperative agreements, grants, or other appropriate mechanisms, consult with biomedical research consortia and may consider the recommendations of such consortia with respect to the review of any qualification plan submitted under paragraph (1) or the review of any full qualification package under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14078056-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of full qualification package","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14078057-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a comprehensive review of a full qualification package accepted under paragraph (1)(C); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14078058-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine whether the drug development tool at issue is qualified for its proposed context of use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14078059-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall determine whether a drug development tool is qualified for a proposed context of use based on the scientific merit of a full qualification package reviewed under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1407805a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of qualification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1407805b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A drug development tool determined to be qualified under subsection (a)(4) for a proposed context of use specified by the requestor may be used by any person in such context of use for the purposes described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1407805c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of a drug development tool","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (3), a drug development tool qualified under this section may be used for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1407805d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting or obtaining approval or licensure (as applicable) of a drug or biological product (including in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s356/c"},"text":"section 356(c) of this title","children":[],"tail":") under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"section 355 of this title","children":[],"tail":" or section 351 of the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"42 U.S.C. 262","children":[],"tail":"]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1407805e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting the investigational use of a drug or biological product under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/i"},"text":"section 355(i) of this title","children":[],"tail":" or section 351(a)(3) of the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262/a/3"},"text":"42 U.S.C. 262(a)(3)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1407805f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rescission or modification","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14078060-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may rescind or modify a determination under this section to qualify a drug development tool if the Secretary determines that the drug development tool is not appropriate for the proposed context of use specified by the requestor. Such a determination may be based on new information that calls into question the basis for such qualification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14078061-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meeting for review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary rescinds or modifies under subparagraph (A) a determination to qualify a drug development tool, the requestor involved shall, on request, be granted a meeting with the Secretary to discuss the basis of the Secretary’s decision to rescind or modify the determination before the effective date of the rescission or modification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14078062-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transparency","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14078063-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (3), the Secretary shall make publicly available, and update on at least a biannual basis, on the Internet website of the Food and Drug Administration the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14078064-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Information with respect to each qualification submission under the qualification process under subsection (a), including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14078065-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the stage of the review process applicable to the submission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14078066-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the most recent change in stage status;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14078067-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether external scientific experts were utilized in the development of a qualification plan or the review of a full qualification package; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14078068-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/c/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submissions from requestors under the qualification process under subsection (a), including any data and evidence contained in such submissions, and any updates to such submissions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14078069-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary’s formal written determinations in response to such qualification submissions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1407806a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any rescissions or modifications under subsection (b)(3) of a determination to qualify a drug development tool.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1407806b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Summary reviews that document conclusions and recommendations for determinations to qualify drug development tools under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1407806c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A comprehensive list of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id1407806d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/c/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all drug development tools qualified under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1407806e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/c/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all surrogate endpoints which were the basis of approval or licensure (as applicable) of a drug or biological product (including in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s356/c"},"text":"section 356(c) of this title","children":[],"tail":") under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"section 355 of this title","children":[],"tail":" or section 351 of the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"42 U.S.C. 262","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1407806f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to Trade Secrets Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Information made publicly available by the Secretary under paragraph (1) shall be considered a disclosure authorized by law for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1905"},"text":"section 1905 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14078070-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14078071-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed as authorizing or directing the Secretary to disclose—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14078072-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any information contained in an application submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"section 355 of this title","children":[],"tail":" or section 351 of the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"42 U.S.C. 262","children":[],"tail":"] that is confidential commercial or trade secret information subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/4"},"text":"section 552(b)(4) of title 5","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1905"},"text":"section 1905 of title 18","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14078073-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a drug development tool that may be used to support the development of a qualified countermeasure, security countermeasure, or qualified pandemic or epidemic product, as defined in sections 319F–1, 319F–2, and 319F–3, respectively, of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–6a"},"text":"42 U.S.C. 247d–6a","children":[],"tail":", 247d–6b, 247d–6d], any information that the Secretary determines has a significant potential to affect national security."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14078074-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public acknowledgment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case that the Secretary, pursuant to subparagraph (A)(ii), does not make information publicly available, the Secretary shall provide on the internet website of the Food and Drug Administration an acknowledgment of the information that has not been disclosed, pursuant to subparagraph (A)(ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14078075-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14078076-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to alter the standards of evidence under subsection (c) or (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"section 355 of this title","children":[],"tail":", including the substantial evidence standard in such subsection (d), or under section 351 of the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"42 U.S.C. 262","children":[],"tail":"] (as applicable); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14078077-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to limit the authority of the Secretary to approve or license products under this chapter or the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"42 U.S.C. 201","children":[],"tail":" et seq.], as applicable (as in effect before "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"December 13, 2016","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14078078-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14078079-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biomarker","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “biomarker”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1407807a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a characteristic (such as a physiologic, pathologic, or anatomic characteristic or measurement) that is objectively measured and evaluated as an indicator of normal biologic processes, pathologic processes, or biological responses to a therapeutic intervention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1407807b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a surrogate endpoint.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1407807c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biomedical research consortia","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “biomedical research consortia” means collaborative groups that may take the form of public-private partnerships and may include government agencies, institutions of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"section 1001(a) of title 20","children":[],"tail":"), patient advocacy groups, industry representatives, clinical and scientific experts, and other relevant entities and individuals."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1407807d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clinical outcome assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “clinical outcome assessment” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1407807e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a measurement of a patient’s symptoms, overall mental state, or the effects of a disease or condition on how the patient functions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1407807f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a patient-reported outcome.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14078080-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Context of use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “context of use” means, with respect to a drug development tool, the circumstances under which the drug development tool is to be used in drug development and regulatory review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14078081-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drug development tool","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “drug development tool” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14078082-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a biomarker;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14078083-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a clinical outcome assessment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14078084-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/e/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other method, material, or measure that the Secretary determines aids drug development and regulatory review for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14078085-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Patient-reported outcome","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “patient-reported outcome” means a measurement based on a report from a patient regarding the status of the patient’s health condition without amendment or interpretation of the patient’s report by a clinician or any other person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14078086-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “qualification” and “qualified” mean a determination by the Secretary that a drug development tool and its proposed context of use can be relied upon to have a specific interpretation and application in drug development and regulatory review under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14078087-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/e/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requestor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “requestor” means an entity or entities, including a drug sponsor or a biomedical research consortia, seeking to qualify a drug development tool for a proposed context of use under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14078088-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/e/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surrogate endpoint","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “surrogate endpoint” means a marker, such as a laboratory measurement, radiographic image, physical sign, or other measure, that is not itself a direct measurement of clinical benefit, and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14078089-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/e/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is known to predict clinical benefit and could be used to support traditional approval of a drug or biological product; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1407808a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s357/e/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is reasonably likely to predict clinical benefit and could be used to support the accelerated approval of a drug or biological product in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s356/c"},"text":"section 356(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1407808b-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s507"},"text":"June 25, 1938, ch. 675, § 507","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIII/s3011/a"},"text":"Pub. L. 114–255, div. A, title III, § 3011(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1086"},"text":"130 Stat. 1086","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/22/tVII/s705/e"},"text":"Pub. L. 116–22, title VII, § 705(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-06-24"},"text":"June 24, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/964"},"text":"133 Stat. 964","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1407808c-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1407808d-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id1407808e-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Public Health Service Act, referred to in subsec. (d)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"act July 1, 1944, ch. 373","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/682"},"text":"58 Stat. 682","children":[],"tail":", which is classified generally to chapter 6A (§ 201 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id1407808f-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 357, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s507"},"text":"act June 25, 1938, ch. 675, § 507","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1945-07-06/ch281/s3"},"text":"July 6, 1945, ch. 281, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/463"},"text":"59 Stat. 463","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1947-03-10/ch16/s3"},"text":"Mar. 10, 1947, ch. 16, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/12"},"text":"61 Stat. 12","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-07-13/ch305/s2"},"text":"July 13, 1949, ch. 305, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/409"},"text":"63 Stat. 409","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1953-08-05/ch334/s2"},"text":"Aug. 5, 1953, ch. 334, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/389"},"text":"67 Stat. 389","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/781/tI"},"text":"Pub. L. 87–781, title I","children":[],"tail":", §§ 105(a), (b), (d)–(f), 106(a), (b), "},{"tag":"date","attrib":{"date":"1962-10-10"},"text":"Oct. 10, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/785"},"text":"76 Stat. 785","children":[],"tail":", 786, 787; "},{"tag":"ref","attrib":{"href":"/us/pl/90/399/s105/b"},"text":"Pub. L. 90–399, § 105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-13"},"text":"July 13, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/352"},"text":"82 Stat. 352","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/300/s6/b/2"},"text":"Pub. L. 102–300, § 6(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-06-16"},"text":"June 16, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/240"},"text":"106 Stat. 240","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/80/s3/p"},"text":"Pub. L. 103–80, § 3(p)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-13"},"text":"Aug. 13, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/777"},"text":"107 Stat. 777","children":[],"tail":", related to certification of drugs containing penicillin, streptomycin, chlortetracycline, chloramphenicol, bacitracin, or any other antibiotic drug, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/115/tI/s125/b/1"},"text":"Pub. L. 105–115, title I, § 125(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2325"},"text":"111 Stat. 2325","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14078090-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22"},"text":"Pub. L. 116–22","children":[],"tail":" designated existing provisions as subpar. (A), inserted heading and “or directing” after “authorizing” in text, substituted “disclose—” for “disclose”, designated remainder of existing provisions as cl. (i) of subpar. (A), substituted “;or” for period at end, and added cl. (ii) of subpar. (A) and subpar. (B)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14078091-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id14078092-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Guidance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIII/s3011/b"},"text":"Pub. L. 114–255, div. A, title III, § 3011(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1089"},"text":"130 Stat. 1089","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/255/dA/tIII/s3011/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Health and Human Services (referred to in this section [this note] as the ‘Secretary’) shall, in consultation with biomedical research consortia (as defined in subsection (e) of section 507 of the Federal Food, Drug, and Cosmetic Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s357"},"text":"21 U.S.C. 357","children":[],"tail":"] (as added by subsection (a)) and other interested parties through a collaborative public process, issue guidance to implement such section 507 that—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides a conceptual framework describing appropriate standards and scientific approaches to support the development of biomarkers delineated under the taxonomy established under paragraph (3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to the qualification process under such section 507—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the requirements that entities seeking to qualify a drug development tool under such section shall observe when engaging in such process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outlines reasonable timeframes for the Secretary’s review of letters, qualification plans, or full qualification packages submitted under such process; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes a process by which such entities or the Secretary may consult with biomedical research consortia and other individuals and entities with expert knowledge and insights that may assist the Secretary in the review of qualification plans and full qualification submissions under such section; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes such other information as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 3 years after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":"], the Secretary shall issue draft guidance under paragraph (1) on the implementation of section 507 of the Federal Food, Drug, and Cosmetic Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t21/s357"},"text":"21 U.S.C. 357","children":[],"tail":"] (as added by subsection (a)). The Secretary shall issue final guidance on the implementation of such section not later than 6 months after the date on which the comment period for the draft guidance closes."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Taxonomy.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of informing guidance under this subsection, the Secretary shall, in consultation with biomedical research consortia and other interested parties through a collaborative public process, establish a taxonomy for the classification of biomarkers (and related scientific concepts) for use in drug development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 2 years after the date of the enactment of this Act, the Secretary shall make such taxonomy publicly available in draft form for public comment. The Secretary shall finalize the taxonomy not later than 1 year after the close of the public comment period.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
