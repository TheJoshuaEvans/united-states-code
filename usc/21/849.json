{"tag":"section","attrib":{"id":"id14a98ce3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s849"},"text":null,"children":[{"tag":"num","attrib":{"value":"849"},"text":"§ 849.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation safety offenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"(a) Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“safety rest area” means a roadside facility with parking facilities for the rest or other needs of motorists.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“truck stop” means a facility (including any parking lot appurtenant thereto) that—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(A) has the capacity to provide fuel or service, or both, to any commercial motor vehicle (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s31301"},"text":"section 31301 of title 49","children":[],"tail":"), operating in commerce (as defined in that section); and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(B) is located within 2,500 feet of the National System of Interstate and Defense Highways or the Federal-Aid Primary System.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) First offense","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"A person who violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s841/a/1"},"text":"section 841(a)(1) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s856"},"text":"section 856 of this title","children":[],"tail":" by distributing or possessing with intent to distribute a controlled substance in or on, or within 1,000 feet of, a truck stop or safety rest area is (except as provided in subsection (b)) "},{"tag":"ref","attrib":{"idref":"fn002154"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002154"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should refer to subsection (c)."}],"tail":" subject to—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(1) twice the maximum punishment authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s841/b"},"text":"section 841(b) of this title","children":[],"tail":"; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(2) twice any term of supervised release authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s841/b"},"text":"section 841(b) of this title","children":[],"tail":" for a first offense."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(c) Subsequent offense","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"A person who violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s841/a/1"},"text":"section 841(a)(1) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s856"},"text":"section 856 of this title","children":[],"tail":" by distributing or possessing with intent to distribute a controlled substance in or on, or within 1,000 feet of, a truck stop or a safety rest area after a prior conviction or convictions under subsection (a) "},{"tag":"ref","attrib":{"idref":"fn002155"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002155"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should refer to subsection (b)."}],"tail":" have become final is subject to—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(1) 3 times the maximum punishment authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s841/b"},"text":"section 841(b) of this title","children":[],"tail":"; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(2) 3 times any term of supervised release authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s841/b"},"text":"section 841(b) of this title","children":[],"tail":" for a first offense."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id14a98ce4-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/tII/s409"},"text":"Pub. L. 91–513, title II, § 409","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXVIII/s180201/b/1"},"text":"Pub. L. 103–322, title XVIII, § 180201(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2046"},"text":"108 Stat. 2046","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14a98ce5-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14a98ce6-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id14a98ce7-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 849, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/tII/s409"},"text":"Pub. L. 91–513, title II, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1266"},"text":"84 Stat. 1266","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", related to dangerous special drug offender sentencing, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII"},"text":"Pub. L. 98–473, title II","children":[],"tail":", §§ 219(a), 235(a)(1), "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2027"},"text":"98 Stat. 2027","children":[],"tail":", 2031, eff. "},{"tag":"date","attrib":{"date":"1987-11-01"},"text":"Nov. 1, 1987","children":[],"tail":", and applicable only to offenses committed after the taking effect of such repeal."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
