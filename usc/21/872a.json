{"tag":"section","attrib":{"id":"id14b0b964-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s872a"},"text":null,"children":[{"tag":"num","attrib":{"value":"872a"},"text":"§ 872a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public-private education program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14b0b965-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s872a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory panel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall establish an advisory panel consisting of an appropriate number of representatives from Federal, State, tribal, and local law enforcement and regulatory agencies with experience in investigating and prosecuting illegal transactions of precursor chemicals. The Attorney General shall convene the panel as often as necessary to develop and coordinate educational programs for wholesale and retail distributors of precursor chemicals and supplies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14b0b966-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s872a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of current efforts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall continue to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14b0b967-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s872a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain an active program of seminars and training to educate wholesale and retail distributors of precursor chemicals and supplies regarding the identification of suspicious transactions and their responsibility to report such transactions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14b0b968-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s872a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assistance to State, tribal, and local law enforcement and regulatory agencies to facilitate the establishment and maintenance of educational programs for distributors of precursor chemicals and supplies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14b0b969-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/237/tV/s503"},"text":"Pub. L. 104–237, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-03"},"text":"Oct. 3, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3112"},"text":"110 Stat. 3112","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s232/b"},"text":"Pub. L. 111–211, title II, § 232(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2278"},"text":"124 Stat. 2278","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14b0b96a-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14b0b96b-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id14b0b96c-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Comprehensive Methamphetamine Control Act of 1996, and not as part of the Controlled Substances Act which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14b0b96d-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s232/b/1"},"text":"Pub. L. 111–211, § 232(b)(1)","children":[],"tail":", inserted “tribal,” after “State,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s232/b/2"},"text":"Pub. L. 111–211, § 232(b)(2)","children":[],"tail":", inserted “, tribal,” after “State”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
