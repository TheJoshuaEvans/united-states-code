{"tag":"section","attrib":{"id":"id14d6df06-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2301"},"text":null,"children":[{"tag":"num","attrib":{"value":"2301"},"text":"§ 2301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d6df07-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States should apply economic and other financial sanctions to foreign traffickers of illicit opioids to protect the national security, foreign policy, and economy of the United States and the health of the people of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d6df08-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is imperative that the People’s Republic of China follow through on full implementation of the new regulations, adopted ","children":[{"tag":"date","attrib":{"date":"2019-05-01"},"text":"May 1, 2019","children":[],"tail":", to treat all fentanyl analogues as controlled substances under the laws of the People’s Republic of China, including by devoting sufficient resources for implementation and strict enforcement of the new regulations; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d6df09-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2301/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective enforcement of the new regulations should result in diminished trafficking of illicit fentanyl originating from the People’s Republic of China into the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14d6df0a-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dF/tLXXII/s7202"},"text":"Pub. L. 116–92, div. F, title LXXII, § 7202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2262"},"text":"133 Stat. 2262","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14d6df0b-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14d6df0c-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id14d6df0d-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dF/tLXXII/s7201"},"text":"Pub. L. 116–92, div. F, title LXXII, § 7201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2262"},"text":"133 Stat. 2262","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dF/tLXXII/s7201"},"text":"“This title [enacting this chapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2291h"},"text":"section 2291h of Title 22","children":[],"tail":", Foreign Relations and Intercourse] may be cited as the ‘Fentanyl Sanctions Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
