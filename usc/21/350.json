{"tag":"section","attrib":{"id":"id13d091b3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350"},"text":null,"children":[{"tag":"num","attrib":{"value":"350"},"text":"§ 350.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vitamins and minerals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id13d091b4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority and limitations of Secretary; applicability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13d091b5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13d091b6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may not establish, under section 321(n), 341, or 343 of this title, maximum limits on the potency of any synthetic or natural vitamin or mineral within a food to which this section applies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d091b7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may not classify any natural or synthetic vitamin or mineral (or combination thereof) as a drug solely because it exceeds the level of potency which the Secretary determines is nutritionally rational or useful;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d091b8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary may not limit, under section 321(n), 341, or 343 of this title, the combination or number of any synthetic or natural—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id13d091b9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vitamin,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id13d091ba-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mineral, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id13d091bb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350/a/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other ingredient of food,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"within a food to which this section applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13d091bc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) shall not apply in the case of a vitamin, mineral, other ingredient of food, or food, which is represented for use by individuals in the treatment or management of specific diseases or disorders, by children, or by pregnant or lactating women. For purposes of this subparagraph,","children":[{"tag":"ref","attrib":{"idref":"fn002018"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002018"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “paragraph”."}],"tail":" the term “children” means individuals who are under the age of twelve years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13d091bd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Labeling and advertising requirements for foods","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13d091be-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A food to which this section applies shall not be deemed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s343"},"text":"section 343 of this title","children":[],"tail":" to be misbranded solely because its label bears, in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s343/i/2"},"text":"section 343(i)(2) of this title","children":[],"tail":", all the ingredients in the food or its advertising contains references to ingredients in the food which are not vitamins or minerals."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13d091bf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The labeling for any food to which this section applies may not list its ingredients which are not dietary supplement ingredients described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s321/ff"},"text":"section 321(ff) of this title","children":[],"tail":" (i) except as a part of a list of all the ingredients of such food, and (ii) unless such ingredients are listed in accordance with applicable regulations under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s343"},"text":"section 343 of this title","children":[],"tail":". To the extent that compliance with clause (i) of this subparagraph is impracticable or results in deception or unfair competition, exemptions shall be established by regulations promulgated by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13d091c0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13d091c1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section, the term “food to which this section applies” means a food for humans which is a food for special dietary use—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13d091c2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is or contains any natural or synthetic vitamin or mineral, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d091c3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id13d091c4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is intended for ingestion in tablet, capsule, powder, softgel, gelcap, or liquid form, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id13d091c5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if not intended for ingestion in such a form, is not represented as conventional food and is not represented for use as a sole item of a meal or of the diet.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13d091c6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of paragraph (1)(B)(i), a food shall be considered as intended for ingestion in liquid form only if it is formulated in a fluid carrier and it is intended for ingestion in daily quantities measured in drops or similar small units of measure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13d091c7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of paragraph (1) and of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s343/j"},"text":"section 343(j) of this title","children":[],"tail":" insofar as that section is applicable to food to which this section applies, the term “special dietary use” as applied to food used by man means a particular use for which a food purports or is represented to be used, including but not limited to the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13d091c8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Supplying a special dietary need that exists by reason of a physical, physiological, pathological, or other condition, including but not limited to the condition of disease, convalescence, pregnancy, lactation, infancy, allergic hypersensitivity to food, underweight, overweight, or the need to control the intake of sodium.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d091c9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Supplying a vitamin, mineral, or other ingredient for use by man to supplement his diet by increasing the total dietary intake.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d091ca-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Supplying a special dietary need by reason of being a food for use as the sole item of the diet.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id13d091cb-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s411"},"text":"June 25, 1938, ch. 675, § 411","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/278/tV/s501/a"},"text":"Pub. L. 94–278, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-22"},"text":"Apr. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/410"},"text":"90 Stat. 410","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/417"},"text":"Pub. L. 103–417","children":[],"tail":", §§ 3(c), 7(d), "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4328"},"text":"108 Stat. 4328","children":[],"tail":", 4331.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id13d091cc-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id13d091cd-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id13d091ce-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/417/s7/d"},"text":"Pub. L. 103–417, § 7(d)","children":[],"tail":", redesignated subpar. (A) as par. (2), substituted “dietary supplement ingredients described in "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s321/ff"},"text":"section 321(ff) of this title","children":[],"tail":"” for “vitamins or minerals”, and struck out former subpar. (B), which read as follows: “Notwithstanding the provisions of subparagraph (A), the labeling and advertising for any food to which this section applies may not give prominence to or emphasize ingredients which are not—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) vitamins,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) minerals, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iii) represented as a source of vitamins or minerals.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/417/s3/c/1"},"text":"Pub. L. 103–417, § 3(c)(1)","children":[],"tail":", inserted “powder, softgel, gelcap,” after “capsule,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/417/s3/c/2"},"text":"Pub. L. 103–417, § 3(c)(2)","children":[],"tail":", struck out “does not simulate and” after “in such a form,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id13d091cf-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id13d091d0-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provision that dietary supplements may be labeled after ","children":[{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", in accordance with amendments made by "},{"tag":"ref","attrib":{"href":"/us/pl/103/417/s7/d"},"text":"section 7(d) of Pub. L. 103–417","children":[],"tail":", and shall be so labeled after "},{"tag":"date","attrib":{"date":"1996-12-31"},"text":"Dec. 31, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/417/s7/e"},"text":"section 7(e) of Pub. L. 103–417","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s343"},"text":"section 343 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id13d091d1-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendment of Inconsistent Regulations by Secretary","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/278/tV/s501/b"},"text":"Pub. L. 94–278, title V, § 501(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-22"},"text":"Apr. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/411"},"text":"90 Stat. 411","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/88/tV/s509/b"},"text":"“The Secretary of Health and Human Services shall amend any regulation promulgated under the Federal Food, Drug, and Cosmetic Act [this chapter] which is inconsistent with section 411 of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s350"},"text":"section 350 of this title","children":[],"tail":"] (as added by subsection (a)) and such amendments shall be promulgated in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
