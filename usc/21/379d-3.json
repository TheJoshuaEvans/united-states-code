{"tag":"section","attrib":{"id":"id1447e4bc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"379d–3"},"text":"§ 379d–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Streamlined hiring authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1447e4bd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any other personnel authorities under other provisions of law, the Secretary may, without regard to the provisions of title 5 governing appointments in the competitive service, appoint employees to positions in the Food and Drug Administration to perform, administer, or support activities described in subsection (b), if the Secretary determines that such appointments are needed to achieve the objectives specified in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1447e4be-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The activities described in this subsection are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1447e4bf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities under this chapter related to the process for the review of device applications (as defined in ","children":[{"tag":"ref","a