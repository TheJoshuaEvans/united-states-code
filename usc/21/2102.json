{"tag":"section","attrib":{"id":"id14d2240e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2102"},"text":null,"children":[{"tag":"num","attrib":{"value":"2102"},"text":"§ 2102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ensuring the safety of pet food","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14d2240f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Processing and ingredient standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2007-09-27"},"text":"September 27, 2007","children":[],"tail":", the Secretary of Health and Human Services (referred to in this chapter as the “Secretary”), in consultation with the Association of American Feed Control Officials and other relevant stakeholder groups, including veterinary medical associations, animal health organizations, and pet food manufacturers, shall by regulation establish—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d22410-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" processing standards for pet food; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d22411-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" updated standards for the labeling of pet food that include nutritional and ingredient information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d22412-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early warning surveillance systems and notification during pet food recalls","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2007-09-27"},"text":"September 27, 2007","children":[],"tail":", the Secretary shall establish an early warning and surveillance system to identify adulteration of the pet food supply and outbreaks of illness associated with pet food. In establishing such system, the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d22413-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider using surveillance and monitoring mechanisms similar to, or in coordination with, those used to monitor human or animal health, such as the Foodborne Diseases Active Surveillance Network (FoodNet) and PulseNet of the Centers for Disease Control and Prevention, the Food Emergency Response Network of the Food and Drug Administration and the Department of Agriculture, and the National Animal Health Laboratory Network of the Department of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d22414-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with relevant professional associations and private sector veterinary hospitals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d22415-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2102/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with the National Companion Animal Surveillance Program, the Health Alert Network, or other notification networks as appropriate to inform veterinarians and relevant stakeholders during any recall of pet food; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d22416-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2102/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use such information and conduct such other activities as the Secretary deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14d22417-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/85/tX/s1002"},"text":"Pub. L. 110–85, title X, § 1002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/963"},"text":"121 Stat. 963","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/234/tIII/s306/b"},"text":"Pub. L. 115–234, title III, § 306(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-14"},"text":"Aug. 14, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2441"},"text":"132 Stat. 2441","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14d22418-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14d22419-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14d2241a-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this title”, meaning title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/85"},"text":"Pub. L. 110–85","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/962"},"text":"121 Stat. 962","children":[],"tail":", which enacted this chapter and "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s350f"},"text":"section 350f of this title","children":[],"tail":", amended sections 321 and 331 of this title, and enacted provisions set out as notes under sections 350f and 2110 of this title. For complete classification of title X to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14d2241b-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/234"},"text":"Pub. L. 115–234","children":[],"tail":" redesignated pars. (2) and (3) as (1) and (2), respectively, and struck out former par. (1) which read as follows: “ingredient standards and definitions with respect to pet food;”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
