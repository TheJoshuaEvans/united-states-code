{"tag":"section","attrib":{"id":"id13fb72c7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f"},"text":null,"children":[{"tag":"num","attrib":{"value":"355f"},"text":"§ 355f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of exclusivity period for new qualified infectious disease products","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id13fb72c8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary approves an application pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"section 355 of this title","children":[],"tail":" for a drug that has been designated as a qualified infectious disease product under subsection (d), the 4- and 5-year periods described in subsections (c)(3)(E)(ii) and (j)(5)(F)(ii) of "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"section 355 of this title","children":[],"tail":", the 3-year periods described in clauses (iii) and (iv) of subsection (c)(3)(E) and clauses (iii) and (iv) of subsection (j)(5)(F) of "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"section 355 of this title","children":[],"tail":", or the 7-year period described in "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360cc"},"text":"section 360cc of this title","children":[],"tail":", as applicable, shall be extended by 5 years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13fb72c9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to pediatric exclusivity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any extension under subsection (a) of a period shall be in addition to any extension of the period under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355a"},"text":"section 355a of this title","children":[],"tail":" with respect to the drug."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13fb72ca-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) does not apply to the approval of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13fb72cb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a supplement to an application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/b"},"text":"section 355(b) of this title","children":[],"tail":" for any qualified infectious disease product for which an extension described in subsection (a) is in effect or has expired;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13fb72cc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a subsequent application filed with respect to a product approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"section 355 of this title","children":[],"tail":" for a change that results in a new indication, route of administration, dosing schedule, dosage form, delivery system, delivery device, or strength;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13fb72cd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a product that does not meet the definition of a qualified infectious disease product under subsection (g) based upon its approved uses; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13fb72ce-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an application pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s262/a"},"text":"section 262(a) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13fb72cf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13fb72d0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The manufacturer or sponsor of a drug may request the Secretary to designate a drug as a qualified infectious disease product at any time before the submission of an application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/b"},"text":"section 355(b) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262/a"},"text":"section 262(a) of title 42","children":[],"tail":" for such drug. The Secretary shall, not later than 60 days after the submission of such a request, determine whether the drug is a qualified infectious disease product."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13fb72d1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (3), a designation under this subsection shall not be withdrawn for any reason, including modifications to the list of qualifying pathogens under subsection (f)(2)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13fb72d2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation of designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may revoke a designation of a drug as a qualified infectious disease product if the Secretary finds that the request for such designation contained an untrue statement of material fact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13fb72d3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13fb72d4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", the Secretary shall adopt final regulations implementing this section, including developing the list of qualifying pathogens described in subsection (f)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13fb72d5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In promulgating a regulation implementing this section, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13fb72d6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue a notice of proposed rulemaking that includes the proposed regulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13fb72d7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a period of not less than 60 days for comments on the proposed regulation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13fb72d8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish the final regulation not less than 30 days before the effective date of the regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13fb72d9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary shall promulgate regulations implementing this section only as described in paragraph (2), except that the Secretary may issue interim guidance for sponsors seeking designation under subsection (d) prior to the promulgation of such regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13fb72da-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation prior to regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall designate drugs as qualified infectious disease products under subsection (d) prior to the promulgation of regulations under this subsection, if such drugs meet the definition of a qualified infectious disease product described in subsection (g).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13fb72db-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying pathogen","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13fb72dc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “qualifying pathogen” means a pathogen identified and listed by the Secretary under paragraph (2) that has the potential to pose a serious threat to public health, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13fb72dd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resistant gram positive pathogens, including methicillin-resistant Staphylococcus aureus, vancomycin-resistant Staphylococcus aureus, and vancomycin-resistant enterococcus;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13fb72de-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multi-drug resistant gram negative bacteria, including Acinetobacter, Klebsiella, Pseudomonas, and E. coli species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13fb72df-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multi-drug resistant tuberculosis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13fb72e0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Clostridium difficile.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13fb72e1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" List of qualifying pathogens","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13fb72e2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish and maintain a list of qualifying pathogens, and shall make public the methodology for developing such list.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13fb72e3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing and maintaining the list of pathogens described under this section, the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id13fb72e4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consider—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id13fb72e5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/f/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact on the public health due to drug-resistant organisms in humans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id13fb72e6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/f/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of growth of drug-resistant organisms in humans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id13fb72e7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/f/2/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the increase in resistance rates in humans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id13fb72e8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/f/2/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the morbidity and mortality in humans; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id13fb72e9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with experts in infectious diseases and antibiotic resistance, including the Centers for Disease Control and Prevention, the Food and Drug Administration, medical professionals, and the clinical research community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13fb72ea-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every 5 years, or more often as needed, the Secretary shall review, provide modifications to, and publish the list of qualifying pathogens under subparagraph (A) and shall by regulation revise the list as necessary, in accordance with subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13fb72eb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified infectious disease product","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified infectious disease product” means a drug (including a biological product), including an antibacterial or antifungal drug, for human use that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13fb72ec-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acts on bacteria or fungi or on substances produced by such bacteria or fungi; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13fb72ed-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is intended to treat a serious or life-threatening infection, including such an infection caused by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13fb72ee-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an antibacterial or antifungal resistant pathogen, including novel or emerging infectious pathogens; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13fb72ef-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355f/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualifying pathogens listed by the Secretary under subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id13fb72f0-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s505E"},"text":"June 25, 1938, ch. 675, § 505E","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/144/tVIII/s801/a"},"text":"Pub. L. 112–144, title VIII, § 801(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1077"},"text":"126 Stat. 1077","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tIII/s3212/a"},"text":"Pub. L. 117–328, div. FF, title III, § 3212(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5826"},"text":"136 Stat. 5826","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id13fb72f1-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id13fb72f2-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id13fb72f3-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s3212/a/1"},"text":"Pub. L. 117–328, § 3212(a)(1)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s3212/a/2"},"text":"Pub. L. 117–328, § 3212(a)(2)","children":[],"tail":", inserted “or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262/a"},"text":"section 262(a) of title 42","children":[],"tail":"” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/b"},"text":"section 355(b) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s3212/a/3"},"text":"Pub. L. 117–328, § 3212(a)(3)","children":[],"tail":", amended subsec. (g) generally. Prior to amendment, text read as follows: “The term ‘qualified infectious disease product’ means an antibacterial or antifungal drug for human use intended to treat serious or life-threatening infections, including those caused by—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) an antibacterial or antifungal resistant pathogen, including novel or emerging infectious pathogens; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) qualifying pathogens listed by the Secretary under subsection (f).”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id13fb72f4-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id13fb72f5-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/144/tVIII/s801/b"},"text":"Pub. L. 112–144, title VIII, § 801(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1079"},"text":"126 Stat. 1079","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/144/tVIII/s801/b"},"text":"“Section 505E of the Federal Food, Drug, and Cosmetic Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355f"},"text":"21 U.S.C. 355f","children":[],"tail":"], as added by subsection (a), applies only with respect to a drug that is first approved under section 505(c) of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/c"},"text":"21 U.S.C. 355(c)","children":[],"tail":") on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
