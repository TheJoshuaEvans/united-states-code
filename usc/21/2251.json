1"},"text":"section 181 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The United States Warehouse Act, referred to in par. (4)(F), is part C of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"act Aug. 11, 1916, ch. 313","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/486"},"text":"39 Stat. 486","children":[],"tail":", which is classified generally to chapter 10 (§ 241 et seq.) of Title 7, Agriculture. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s241"},"text":"section 241 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Agricultural Adjustment Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s601"},"text":"7 U.S.C. 601","children":[],"tail":" et seq.), reenacted with the amendments made by the Agricultural Marketing Agreement Act of 1937, referred to in par. (4)(H), is title I of "},{"tag":"ref","attrib":{"href":"/us/act/1933-05-12/ch25"},"text":"act May 12, 1933, ch. 25","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/31"},"text":"48 Stat. 31","children":[],"tail":", which is classified generally to chapter 26 (§ 601 et seq.) of Title 7, Agriculture. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s601"},"text":"section 601 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Homeland Security Act of 2002, referred to in par. (5), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2135"},"text":"116 Stat. 2135","children":[],"tail":", which is classified principally to