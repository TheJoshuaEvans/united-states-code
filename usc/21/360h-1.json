{"tag":"section","attrib":{"id":"id141f4e03-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360h–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"360h–1"},"text":"§ 360h–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program to improve the device recall system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id141f4e04-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360h–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id141f4e05-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360h–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a program to routinely and systematically assess information relating to device recalls and use such information to proactively identify strategies for mitigating health risks presented by defective or unsafe devices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id141f4e06-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360h–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clarify procedures for conducting device recall audit checks to improve the ability of investigators to perform those checks in a consistent manner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id141f4e07-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360h–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop detailed criteria for assessing whether a person performing a device recall has performed an effective correction or action plan for the recall; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id141f4e08-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360h–1/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" document the basis for each termination by the Food and Drug Administration of a device recall.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id141f4e09-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360h–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program established under subsection (a)(1) shall, at a minimum, identify—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id141f4e0a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360h–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trends in the number and types of device recalls;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id141f4e0b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360h–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" devices that are most frequently the subject of a recall; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id141f4e0c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360h–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" underlying causes of device recalls.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id141f4e0d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360h–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “recall” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id141f4e0e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360h–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the removal from the market of a device pursuant to an order of the Secretary under subsection (b) or (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360h"},"text":"section 360h of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id141f4e0f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360h–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the correction or removal from the market of a device at the initiative of the manufacturer or importer of the device that is required to be reported to the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360i/g"},"text":"section 360i(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id141f4e10-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s518A"},"text":"June 25, 1938, ch. 675, § 518A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/144/tVI/s605"},"text":"Pub. L. 112–144, title VI, § 605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1053"},"text":"126 Stat. 1053","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIII/s3101/a/2/K"},"text":"Pub. L. 114–255, div. A, title III, § 3101(a)(2)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1154"},"text":"130 Stat. 1154","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id141f4e11-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id141f4e12-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id141f4e13-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","children":[],"tail":" redesignated subsec. (d) as (c) and struck out former subsec. (c). Prior to amendment, text read as follows: “The Secretary shall document the basis for the termination by the Food and Drug Administration of a device recall.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
