{"tag":"section","attrib":{"id":"id1407809f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s359"},"text":null,"children":[{"tag":"num","attrib":{"value":"359"},"text":"§ 359.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability of subchapter to cosmetics","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This subchapter, as amended by the Drug Amendments of 1962, shall not apply to any cosmetic unless such cosmetic is also a drug or device or component thereof.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id140780a0-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s509"},"text":"June 25, 1938, ch. 675, § 509","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/87/781/tI/s113"},"text":"Pub. L. 87–781, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-10"},"text":"Oct. 10, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/791"},"text":"76 Stat. 791","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id140780a1-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id140780a2-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id140780a3-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, as amended by the Drug Amendments of 1962, referred to in text, means the amendment of this subchapter by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/781"},"text":"Pub. L. 87–781","children":[],"tail":" which enacted sections 358 to 360 of this title, amended sections 351 to 353, 355, and 357 of this title, and enacted provisions set out as notes under sections 352, 355, 358, and 360 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Drug Amendments of 1962, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/781"},"text":"Pub. L. 87–781","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-10"},"text":"Oct. 10, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/780"},"text":"76 Stat. 780","children":[],"tail":", as amended. For complete classification of this Act to the Code, see Short Title of 1962 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"section 301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
