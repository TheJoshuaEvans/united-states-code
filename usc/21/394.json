{"tag":"section","attrib":{"id":"id147eac57-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s394"},"text":null,"children":[{"tag":"num","attrib":{"value":"394"},"text":"§ 394.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientific review groups","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Without regard to the provisions of title 5 governing appointments in the competitive service and without regard to the provisions of chapter 51 and subchapter III of chapter 53 of such title relating to classification and General Schedule pay rates, the Commissioner of Food and Drugs may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id147eac58-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s394/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish such technical and scientific review groups as are needed to carry out the functions of the Food and Drug Administration (including functions prescribed under this chapter); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147eac59-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s394/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint and pay the members of such groups, except that officers and employees of the United States shall not receive additional compensation for service as members of such groups.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id147eac5a-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s1004"},"text":"June 25, 1938, ch. 675, § 1004","children":[],"tail":", formerly § 903, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/635/tIII/s301"},"text":"Pub. L. 101–635, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4584"},"text":"104 Stat. 4584","children":[],"tail":"; renumbered § 904, "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXX/s2006/1"},"text":"Pub. L. 103–43, title XX, § 2006(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/209"},"text":"107 Stat. 209","children":[],"tail":"; renumbered § 1004, "},{"tag":"ref","attrib":{"href":"/us/pl/111/31/dA/tI/s101/b/2"},"text":"Pub. L. 111–31, div. A, title I, § 101(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-06-22"},"text":"June 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1784"},"text":"123 Stat. 1784","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
