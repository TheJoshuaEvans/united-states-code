{"tag":"section","attrib":{"id":"id14abfdff-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s852"},"text":null,"children":[{"tag":"num","attrib":{"value":"852"},"text":"§ 852.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of treaties and other international agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in the Single Convention on Narcotic Drugs, the Convention on Psychotropic Substances, or other treaties or international agreements shall be construed to limit the provision of treatment, education, or rehabilitation as alternatives to conviction or criminal penalty for offenses involving any drug or other substance subject to control under any such treaty or agreement.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id14abfe00-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/tII/s412"},"text":"Pub. L. 91–513, title II, § 412","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/633/tI/s107/a"},"text":"Pub. L. 95–633, title I, § 107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3773"},"text":"92 Stat. 3773","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14abfe01-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14abfe02-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id14abfe03-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on date the Convention on Psychotropic Substances enters into force in the United States [","children":[{"tag":"date","attrib":{"date":"1980-07-15"},"text":"July 15, 1980","children":[],"tail":"], see "},{"tag":"ref","attrib":{"href":"/us/pl/95/633/s112"},"text":"section 112 of Pub. L. 95–633","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s801a"},"text":"section 801a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
