{"tag":"section","attrib":{"id":"id14b7e502-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s954"},"text":null,"children":[{"tag":"num","attrib":{"value":"954"},"text":"§ 954.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transshipment and in-transit shipment of controlled substances","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Notwithstanding sections 952, 953, and 957 of this title—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14b7e503-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s954/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A controlled substance in schedule I may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14b7e504-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s954/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be imported into the United States for transshipment to another country, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14b7e505-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s954/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be transferred or transshipped from one vessel, vehicle, or aircraft to another vessel, vehicle, or aircraft within the United States for immediate exportation,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"if and only if it is so imported, transferred, or transshipped (i) for scientific, medical, or other legitimate purposes in the country of destination, and (ii) with the prior written approval of the Attorney General (which shall be granted or denied within 21 days of the request).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14b7e506-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s954/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A controlled substance in schedule II, III, or IV may be so imported, transferred, or transshipped if and only if advance notice is given to the Attorney General in accordance with regulations of the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14b7e507-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/tIII/s1004"},"text":"Pub. L. 91–513, title III, § 1004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1287"},"text":"84 Stat. 1287","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14b7e508-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14b7e509-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14b7e50a-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Schedules I, II, III, and IV, referred to in text, are set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s812/c"},"text":"section 812(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14b7e50b-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id14b7e50c-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of seventh calendar month that begins after ","children":[{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", see 1105(a) of "},{"tag":"ref","attrib":{"href":"/us/pl/91/513"},"text":"Pub. L. 91–513","children":[],"tail":", set out as a under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s951"},"text":"section 951 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
