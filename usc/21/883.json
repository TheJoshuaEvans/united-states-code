{"tag":"section","attrib":{"id":"id14b32a3b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s883"},"text":null,"children":[{"tag":"num","attrib":{"value":"883"},"text":"§ 883.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Before any violation of this subchapter is reported by the Administrator of the Drug Enforcement Administration to any United States attorney for institution of a criminal proceeding, the Administrator may require that the person against whom such proceeding is contemplated is given appropriate notice and an opportunity to present his views, either orally or in writing, with regard to such contemplated proceeding.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id14b32a3c-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/tII/s513"},"text":"Pub. L. 91–513, title II, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1278"},"text":"84 Stat. 1278","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/132/s16/c"},"text":"Pub. L. 96–132, § 16(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-11-30"},"text":"Nov. 30, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1049"},"text":"93 Stat. 1049","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14b32a3d-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14b32a3e-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14b32a3f-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1979—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/132"},"text":"Pub. L. 96–132","children":[],"tail":" substituted “Administrator of the Drug Enforcement Administration” for “Director of the Bureau of Narcotics and Dangerous Drugs” and “Administrator may” for “Director may”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
