{"tag":"section","attrib":{"id":"id13ce484d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s347b"},"text":null,"children":[{"tag":"num","attrib":{"value":"347b"},"text":"§ 347b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contravention of State laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this Act shall be construed as authorizing the possession, sale, or serving of colored oleomargarine or colored margarine in any State or Territory in contravention of the laws of such State or Territory.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id13ce484e-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-16/ch61/s6"},"text":"Mar. 16, 1950, ch. 61, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/22"},"text":"64 Stat. 22","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id13ce484f-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id13ce4850-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id13ce4851-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-16/ch61"},"text":"act Mar. 16, 1950, ch. 61","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/20"},"text":"64 Stat. 20","children":[],"tail":", which is classified to sections 331, 342, 347 to 347b of this title, and sections 45 and 55 of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id13ce4852-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Federal Food, Drug, and Cosmetic Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id13ce4853-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id13ce4854-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1950-07-01"},"text":"July 1, 1950","children":[],"tail":", see section 7 of act "},{"tag":"date","attrib":{"date":"1950-03-16"},"text":"Mar. 16, 1950","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s347"},"text":"section 347 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
