{"tag":"section","attrib":{"id":"id14ae6e56-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s856"},"text":null,"children":[{"tag":"num","attrib":{"value":"856"},"text":"§ 856.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintaining drug-involved premises","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14ae6e57-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s856/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful acts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as authorized by this subchapter, it shall be unlawful to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14ae6e58-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s856/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly open, lease, rent, use, or maintain any place, whether permanently or temporarily, for the purpose of manufacturing, distributing, or using any controlled substance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14ae6e59-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s856/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manage or control any place, whether permanently or temporarily, either as an owner, lessee, agent, employee, occupant, or mortgagee, and knowingly and intentionally rent, lease, profit from, or make available for use, with or without compensation, the place for the purpose of unlawfully manufacturing, storing, distributing, or using a controlled substance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14ae6e5a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s856/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who violates subsection (a) of this section shall be sentenced to a term of imprisonment of not more than 20 years or a fine of not more than $500,000, or both, or a fine of $2,000,000 for a person other than an individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14ae6e5b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s856/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violation as offense against property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A violation of subsection (a) shall be considered an offense against property for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3663A/c/1/A/ii"},"text":"section 3663A(c)(1)(A)(ii) of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14ae6e5c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s856/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14ae6e5d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s856/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any person who violates subsection (a) shall be subject to a civil penalty of not more than the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14ae6e5e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s856/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $250,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14ae6e5f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s856/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 times the gross receipts, either known or estimated, that were derived from each violation that is attributable to the person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14ae6e60-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s856/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a civil penalty is calculated under paragraph (1)(B), and there is more than 1 defendant, the court may apportion the penalty between multiple violators, but each violator shall be jointly and severally liable for the civil penalty under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14ae6e61-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s856/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaratory and injunctive remedies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who violates subsection (a) shall be subject to declaratory and injunctive remedies as set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s843/f"},"text":"section 843(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14ae6e62-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/tII/s416"},"text":"Pub. L. 91–513, title II, § 416","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tI/s1841/a"},"text":"Pub. L. 99–570, title I, § 1841(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-52"},"text":"100 Stat. 3207–52","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXVI/s3613/e"},"text":"Pub. L. 106–310, div. B, title XXXVI, § 3613(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1230"},"text":"114 Stat. 1230","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/21/tVI/s608/b/1"},"text":"Pub. L. 108–21, title VI, § 608(b)(1)","children":[],"tail":", (2), (c), "},{"tag":"date","attrib":{"date":"2003-04-30"},"text":"Apr. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/691"},"text":"117 Stat. 691","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14ae6e63-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14ae6e64-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14ae6e65-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21/s608/b/2"},"text":"Pub. L. 108–21, § 608(b)(2)","children":[],"tail":", substituted “Maintaining drug-involved premises” for “Establishment of manufacturing operations” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21/s608/b/1/A"},"text":"Pub. L. 108–21, § 608(b)(1)(A)","children":[],"tail":", substituted “open, lease, rent, use, or maintain any place, whether permanently or temporarily,” for “open or maintain any place”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21/s608/b/1/B"},"text":"Pub. L. 108–21, § 608(b)(1)(B)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows: “manage or control any building, room, or enclosure, either as an owner, lessee, agent, employee, or mortgagee, and knowingly and intentionally rent, lease, or make available for use, with or without compensation, the building, room, or enclosure for the purpose of unlawfully manufacturing, storing, distributing, or using a controlled substance.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21/s608/c"},"text":"Pub. L. 108–21, § 608(c)","children":[],"tail":", added subsecs. (d) and (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310"},"text":"Pub. L. 106–310","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
