{"tag":"section","attrib":{"id":"id13e15a94-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s353a–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"353a–1"},"text":"§ 353a–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced communication","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id13e15a95-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s353a–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submissions from State boards of pharmacy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In a manner specified by the Secretary of Health and Human Services (referred to in this section as the “Secretary”), the Secretary shall receive submissions from State boards of pharmacy—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13e15a96-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s353a–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing actions taken against compounding pharmacies, as described in subsection (b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13e15a97-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s353a–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expressing concerns that a compounding pharmacy may be acting contrary to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s353a"},"text":"section 353a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13e15a98-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s353a–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of submissions from State boards of pharmacy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An action referred to in subsection (a)(1) is, with respect to a pharmacy that compounds drugs, any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13e15a99-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s353a–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The issuance of a warning letter, or the imposition of sanctions or penalties, by a State for violations of a State’s pharmacy regulations pertaining to compounding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13e15a9a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s353a–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The suspension or revocation of a State-issued pharmacy license or registration for violations of a State’s pharmacy regulations pertaining to compounding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13e15a9b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s353a–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The recall of a compounded drug due to concerns relating to the quality or purity of such drug.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13e15a9c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s353a–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall implement subsection (a) in consultation with the National Association of Boards of Pharmacy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13e15a9d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s353a–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notifying State boards of pharmacy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall immediately notify State boards of pharmacy when—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13e15a9e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s353a–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary receives a submission under subsection (a)(1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13e15a9f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s353a–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary makes a determination that a pharmacy is acting contrary to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s353a"},"text":"section 353a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id13e15aa0-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/54/tI/s105"},"text":"Pub. L. 113–54, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-11-27"},"text":"Nov. 27, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/597"},"text":"127 Stat. 597","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id13e15aa1-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id13e15aa2-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id13e15aa3-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Compounding Quality Act and also as part of the Drug Quality and Security Act, and not as part of the Federal Food, Drug, and Cosmetic Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
