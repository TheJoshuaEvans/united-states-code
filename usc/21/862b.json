{"tag":"section","attrib":{"id":"id14b0b8dd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862b"},"text":null,"children":[{"tag":"num","attrib":{"value":"862b"},"text":"§ 862b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctioning for testing positive for controlled substances","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, States shall not be prohibited by the Federal Government from testing welfare recipients for use of controlled substances nor from sanctioning welfare recipients who test positive for use of controlled substances.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id14b0b8de-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/tIX/s902"},"text":"Pub. L. 104–193, title IX, § 902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2347"},"text":"110 Stat. 2347","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14b0b8df-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14b0b8e0-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id14b0b8e1-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Personal Responsibility and Work Opportunity Reconciliation Act of 1996, and not as part of the Controlled Substances Act which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
