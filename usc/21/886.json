{"tag":"section","attrib":{"id":"id14b57345-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s886"},"text":null,"children":[{"tag":"num","attrib":{"value":"886"},"text":"§ 886.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments and advances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14b57346-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s886/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment to informers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General is authorized to pay any person, from funds appropriated for the Drug Enforcement Administration, for information concerning a violation of this subchapter, such sum or sums of money as he may deem appropriate, without reference to any moieties or rewards to which such person may otherwise be entitled by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14b57347-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s886/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement for purchase of controlled substances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Moneys expended from appropriations of the Drug Enforcement Administration for purchase of controlled substances and subsequently recovered shall be reimbursed to the current appropriation for the Administration.","children":[{"tag":"ref","attrib":{"idref":"fn002165"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002165"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Codification note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14b57348-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s886/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance of funds for enforcement purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General is authorized to direct the advance of funds by the Treasury Department in connection with the enforcement of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14b57349-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s886/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drug Pollution Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14b5734a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s886/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established in the Treasury a trust fund to be known as the “Drug Pollution Fund” (hereinafter referred to in this subsection as the “Fund”), consisting of amounts appropriated or credited to such Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s841/b/6"},"text":"section 841(b)(6) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14b5734b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s886/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are hereby appropriated to the Fund amounts equivalent to the fines imposed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s841/b/6"},"text":"section 841(b)(6) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14b5734c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s886/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts in the Fund shall be available, as provided in appropriations Acts, for the purpose of making payments in accordance with paragraph (4) for the clean up of certain pollution resulting from the actions referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s841/b/6"},"text":"section 841(b)(6) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14b5734d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s886/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14b5734e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s886/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury, after consultation with the Attorney General, shall make payments under paragraph (3), in such amounts as the Secretary determines appropriate, to the heads of executive agencies or departments that meet the requirements of subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14b5734f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s886/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to receive a payment under paragraph (3), the head of an executive agency or department shall submit an application in such form and containing such information as the Secretary of the Treasury shall by regulation require. Such application shall contain a description of the fine imposed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s841/b/6"},"text":"section 841(b)(6) of this title","children":[],"tail":", the circumstances surrounding the imposition of such fine, and the type and severity of pollution that resulted from the actions to which such fine applies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14b57350-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s886/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of subchapter B of chapter 98 of title 26, the Fund established under this paragraph shall be treated in the same manner as a trust fund established under subchapter A of such chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14b57351-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/tII/s516"},"text":"Pub. L. 91–513, title II, § 516","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1279"},"text":"84 Stat. 1279","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/132/s16/b"},"text":"Pub. L. 96–132, § 16(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-11-30"},"text":"Nov. 30, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1049"},"text":"93 Stat. 1049","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6254/i"},"text":"Pub. L. 100–690, title VI, § 6254(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4367"},"text":"102 Stat. 4367","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14b57352-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14b57353-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id14b57354-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b), “Administration” substituted for “Bureau” as the probable intent of Congress in view of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/132"},"text":"Pub. L. 96–132","children":[],"tail":", which substituted references to the Drug Enforcement Administration for references to the Bureau of Narcotics and Dangerous Drugs wherever appearing in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14b57355-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/132"},"text":"Pub. L. 96–132","children":[],"tail":" substituted “Drug Enforcement Administration” for “Bureau of Narcotics and Dangerous Drugs”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14b57356-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id14b57357-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reimbursement by Drug Enforcement Administration of Expenses Incurred To Remediate Methamphetamine Laboratories","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXVI/s3672"},"text":"Pub. L. 106–310, div. B, title XXXVI, § 3672","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1246"},"text":"114 Stat. 1246","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/310/dB/tXXXVI/s3672"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General, acting through the Administrator of the Drug Enforcement Administration, may reimburse States, units of local government, Indian tribal governments, other public entities, and multi-jurisdictional or regional consortia thereof for expenses incurred to clean up and safely dispose of substances associated with clandestine methamphetamine laboratories which may present a danger to public health or the environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional DEA Personnel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"From amounts appropriated or otherwise made available to carry out this section, the Attorney General may hire not more than five additional Drug Enforcement Administration personnel to administer this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to the Attorney General to carry out this section $20,000,000 for fiscal year 2001.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
