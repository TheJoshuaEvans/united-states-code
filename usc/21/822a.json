{"tag":"section","attrib":{"id":"id149b360c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s822a"},"text":null,"children":[{"tag":"num","attrib":{"value":"822a"},"text":"§ 822a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prescription drug take back expansion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id149b360d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s822a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of covered entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered entity” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id149b360e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s822a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State, local, or tribal law enforcement agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id149b360f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s822a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a manufacturer, distributor, or reverse distributor of prescription medications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id149b3610-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s822a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a retail pharmacy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id149b3611-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s822a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a registered narcotic treatment program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id149b3612-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s822a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a hospital or clinic with an onsite pharmacy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id149b3613-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s822a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an eligible long-term care facility; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id149b3614-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s822a/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other entity authorized by the Drug Enforcement Administration to dispose of prescription medications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id149b3615-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s822a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General, in coordination with the Administrator of the Drug Enforcement Administration, the Secretary of Health and Human Services, and the Director of the Office of National Drug Control Policy, shall coordinate with covered entities in expanding or making available disposal sites for unwanted prescription medications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id149b3616-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/198/tII/s203"},"text":"Pub. L. 114–198, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-22"},"text":"July 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/717"},"text":"130 Stat. 717","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id149b3617-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id149b3618-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id149b3619-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Comprehensive Addiction and Recovery Act of 2016, and not as part of the Controlled Substances Act which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id149b361a-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id149b361b-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Guidance on At-Home Drug Disposal Systems","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/tI/s111"},"text":"Pub. L. 119–44, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-01"},"text":"Dec. 1, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/678"},"text":"139 Stat. 678","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/44/tI/s111"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than one year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-12-01"},"text":"Dec. 1, 2025","children":[],"tail":"], the Secretary of Health and Human Services, in consultation with the Administrator of the Drug Enforcement Administration, shall publish guidance to facilitate the use of at-home safe disposal systems for applicable drugs."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The guidance under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommended standards for effective at-home drug disposal systems to meet applicable requirements enforced by the Food and Drug Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommended information to include as instructions for use to disseminate with at-home drug disposal systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" best practices and educational tools to support the use of an at-home drug disposal system, as appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommended use of licensed health providers for the dissemination of education, instruction, and at-home drug disposal systems, as appropriate.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id149b361c-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Access to Increased Drug Disposal","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/tIII"},"text":"Pub. L. 115–271, title III","children":[],"tail":", subtitle B, ch. 6, "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3950"},"text":"132 Stat. 3950","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/271/tIII"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3251"},"text":"“SEC. 3251.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This chapter may be cited as the ‘Access to Increased Drug Disposal Act of 2018’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3252"},"text":"“SEC. 3252.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" DEFINITIONS.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘Attorney General’ means the Attorney General, acting through the Assistant Attorney General for the Office of Justice Programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘authorized collector’ means a narcotic treatment program, a hospital or clinic with an on-site pharmacy, a retail pharmacy, or a reverse distributor, that is authorized as a collector under section 1317.40 of title 21, Code of Federal Regulations (or any successor regulation);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘covered grant’ means a grant awarded under section 3003 [probably means section 3253; no ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s3003"},"text":"section 3003 of Pub. L. 115–271","children":[],"tail":" has been enacted]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘eligible collector’ means a person who is eligible to be an authorized collector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3253"},"text":"“SEC. 3253.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" AUTHORITY TO MAKE GRANTS.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“The Attorney General shall award grants to States to enable the States to increase the participation of eligible collectors as authorized collectors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3254"},"text":"“SEC. 3254.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" APPLICATION.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“A State desiring a covered grant shall submit to the Attorney General an application that, at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the single State agency that oversees pharmaceutical care and will be responsible for complying with the requirements of the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" details a plan to increase participation rates of eligible collectors as authorized collectors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes how the State will select eligible collectors to be served under the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3255"},"text":"“SEC. 3255.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" USE OF GRANT FUNDS.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“A State that receives a covered grant, and any subrecipient of the grant, may use the grant amounts only for the costs of installation, maintenance, training, purchasing, and disposal of controlled substances associated with the participation of eligible collectors as authorized collectors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3256"},"text":"“SEC. 3256.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ELIGIBILITY FOR GRANT.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“The Attorney General shall award a covered grant to 5 States, not less than 3 of which shall be States in the lowest quartile of States based on the participation rate of eligible collectors as authorized collectors, as determined by the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3257"},"text":"“SEC. 3257.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" DURATION OF GRANTS.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“The Attorney General shall determine the period of years for which a covered grant is made to a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3258"},"text":"“SEC. 3258.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ACCOUNTABILITY AND OVERSIGHT.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“A State that receives a covered grant shall submit to the Attorney General a report, at such time and in such manner as the Attorney General may reasonably require, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lists the ultimate recipients of the grant amounts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the activities undertaken by the State using the grant amounts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains performance measures relating to the effectiveness of the grant, including changes in the participation rate of eligible collectors as authorized collectors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3259"},"text":"“SEC. 3259.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" DURATION OF PROGRAM.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“The Attorney General may award covered grants for each of the first 5 fiscal years beginning after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3260"},"text":"“SEC. 3260.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" AUTHORIZATION OF APPROPRIATIONS.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“There is authorized to be appropriated to the Attorney General such sums as may be necessary to carry out this chapter.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
