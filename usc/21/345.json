{"tag":"section","attrib":{"id":"id13c9661e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s345"},"text":null,"children":[{"tag":"num","attrib":{"value":"345"},"text":"§ 345.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations making exemptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate regulations exempting from any labeling requirement of this chapter (1) small open containers of fresh fruits and fresh vegetables and (2) food which is, in accordance with the practice of the trade, to be processed, labeled, or repacked in substantial quantities at establishments other than those where originally processed or packed, on condition that such food is not adulterated or misbranded under the provisions of this chapter upon removal from such processing, labeling, or repacking establishment. This section does not apply to the labeling requirements of sections 343(q) and 343(r) of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id13c9661f-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s405"},"text":"June 25, 1938, ch. 675, § 405","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1049"},"text":"52 Stat. 1049","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/535/s5/a"},"text":"Pub. L. 101–535, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-08"},"text":"Nov. 8, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2362"},"text":"104 Stat. 2362","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id13c96620-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id13c96621-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id13c96622-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/535"},"text":"Pub. L. 101–535","children":[],"tail":" inserted at end “This section does not apply to the labeling requirements of sections 343(q) and 343(r) of this title.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id13c96623-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id13c96624-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/535"},"text":"Pub. L. 101–535","children":[],"tail":" effective six months after the date of the promulgation of final regulations to implement "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s343/r"},"text":"section 343(r) of this title","children":[],"tail":", or if such regulations are not promulgated, the date proposed regulations are to be considered as such final regulations ("},{"tag":"date","attrib":{"date":"1992-11-08"},"text":"Nov. 8, 1992","children":[],"tail":"), with exception for persons marketing food the brand name of which contains a term defined by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s343/r/2/A/i"},"text":"section 343(r)(2)(A)(i) of this title","children":[],"tail":",