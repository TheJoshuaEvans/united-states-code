{"tag":"section","attrib":{"id":"id1466defa-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–61"},"text":null,"children":[{"tag":"num","attrib":{"value":"379j–61"},"text":"§ 379j–61.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subpart:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1466defb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–61/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “affiliate” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s379g/11"},"text":"section 379g(11) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1466defc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–61/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “gross annual sales” means the total worldwide gross annual sales, in United States dollars, for an outsourcing facility, including the sales of all the affiliates of the outsourcing facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1466defd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–61/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “outsourcing facility” has the meaning given to such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s353b/d/4"},"text":"section 353b(d)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1466defe-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–61/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “reinspection” means, with respect to an outsourcing facility, 1 or more inspections conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s374"},"text":"section 374 of this title","children":[],"tail":" subsequent to an inspection conducted under such provision which identified noncompliance materially related to an applicable requirement of this chapter, specifically to determine whether compliance has been achieved to the Secretary’s satisfaction."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1466deff-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s744J"},"text":"June 25, 1938, ch. 675, § 744J","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/54/tI/s102/b"},"text":"Pub. L. 113–54, title I, § 102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-11-27"},"text":"Nov. 27, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/593"},"text":"127 Stat. 593","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
