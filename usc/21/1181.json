{"tag":"section","attrib":{"id":"id14c1813a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1181"},"text":null,"children":[{"tag":"num","attrib":{"value":"1181"},"text":"§ 1181.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The authority of the Secretary to enter into contracts under this subchapter and subchapter V shall be effective for any fiscal year only to such extent or in such amounts as are provided in advance by appropriation Acts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id14c1813b-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/255/tIV/s414"},"text":"Pub. L. 92–255, title IV, § 414","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/181/s9/a"},"text":"Pub. L. 96–181, § 9(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-01-02"},"text":"Jan. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1314"},"text":"93 Stat. 1314","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14c1813c-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14c1813d-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14c1813e-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapter V, referred to in text, consisted of sections 501 to 504 of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/255"},"text":"