{"tag":"section","attrib":{"id":"id14d2246d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202"},"text":null,"children":[{"tag":"num","attrib":{"value":"2202"},"text":"§ 2202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Agriculture and Food Defense Strategy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14d2246e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development and submission of strategy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d2246f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"January 4, 2011","children":[],"tail":", the Secretary of Health and Human Services and the Secretary of Agriculture, in coordination with the Secretary of Homeland Security, shall prepare and transmit to the relevant committees of Congress, and make publicly available on the Internet Web sites of the Department of Health and Human Services and the Department of Agriculture, the National Agriculture and Food Defense Strategy."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d22470-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The strategy shall include an implementation plan for use by the Secretaries described under paragraph (1) in carrying out the strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d22471-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The strategy shall include a coordinated research agenda for use by the Secretaries described under paragraph (1) in conducting research to support the goals and activities described in paragraphs (1) and (2) of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d22472-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 4 years after the date on which the strategy is submitted to the relevant committees of Congress under paragraph (1), and not less frequently than every 4 years thereafter, the Secretary of Health and Human Services and the Secretary of Agriculture, in coordination with the Secretary of Homeland Security, shall revise and submit to the relevant committees of Congress the strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d22473-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency with existing plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The strategy described in paragraph (1) shall be consistent with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d22474-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Incident Management System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d22475-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Response Framework;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d22476-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Infrastructure Protection Plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d22477-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/a/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Preparedness Goals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d22478-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/a/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant national strategies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d22479-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Components","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d2247a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The strategy shall include a description of the process to be used by the Department of Health and Human Services, the Department of Agriculture, and the Department of Homeland Security—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d2247b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to achieve each goal described in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d2247c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to evaluate the progress made by Federal, State, local, and tribal governments towards the achievement of each goal described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d2247d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The strategy shall include a description of the process to be used by the Department of Health and Human Services, the Department of Agriculture, and the Department of Homeland Security to achieve the following goals:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d2247e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparedness goal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Enhance the preparedness of the agriculture and food system by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14d2247f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting vulnerability assessments of the agriculture and food system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d22480-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mitigating vulnerabilities of the system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d22481-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving communication and training relating to the system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d22482-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and conducting exercises to test decontamination and disposal plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d22483-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing modeling tools to improve event consequence assessment and decision support; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d22484-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparing risk communication tools and enhancing public awareness through outreach.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d22485-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detection goal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Improve agriculture and food system detection capabilities by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14d22486-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying contamination in food products at the earliest possible time; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d22487-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting surveillance to prevent the spread of diseases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d22488-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency response goal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Ensure an efficient response to agriculture and food emergencies by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14d22489-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immediately investigating animal disease outbreaks and suspected food contamination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d2248a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventing additional human illnesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d2248b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" organizing, training, and equipping animal, plant, and food emergency response teams of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id14d2248c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2/C/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14d2248d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2/C/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State, local, and tribal governments;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d2248e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designing, developing, and evaluating training and exercises carried out under agriculture and food defense plans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d2248f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensuring consistent and organized risk communication to the public by—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id14d22490-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2/C/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14d22491-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2/C/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State, local, and tribal governments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14d22492-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2/C/v/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the private sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d22493-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery goal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Secure agriculture and food production after an agriculture or food emergency by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14d22494-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" working with the private sector to develop business recovery plans to rapidly resume agriculture, food production, and international trade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d22495-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting exercises of the plans described in subparagraph (C) with the goal of long-term recovery results;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d22496-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" rapidly removing, and effectively disposing of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id14d22497-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2/D/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contaminated agriculture and food products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14d22498-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2/D/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" infected plants and animals; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d22499-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decontaminating and restoring areas affected by an agriculture or food emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d2249a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in coordination with the Secretary of Agriculture and the Secretary of Homeland Security, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d2249b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop metrics to measure progress for the evaluation process described in paragraph (1)(B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d2249c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report on the progress measured in subparagraph (A) as part of the National Agriculture and Food Defense strategy described in subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d2249d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2202/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the interest of national security, the Secretary of Health and Human Services and the Secretary of Agriculture, in coordination with the Secretary of Homeland Security, may determine the manner and format in which the National Agriculture and Food Defense strategy established under this section is made publicly available on the Internet Web sites of the Department of Health and Human Services, the Department of Homeland Security, and the Department of Agriculture, as described in subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14d4949e-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/353/tI/s108"},"text":"Pub. L. 111–353, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3910"},"text":"124 Stat. 3910","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14d4949f-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14d494a0-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14d494a1-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Secretary, referred to in subsec. (b)(3), probably means the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
