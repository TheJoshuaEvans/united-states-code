{"tag":"section","attrib":{"id":"id141cdd46-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"360e–1"},"text":"§ 360e–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pediatric uses of devices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id141cdd47-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New devices","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id141cdd48-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person that submits to the Secretary an application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360j/m"},"text":"section 360j(m) of this title","children":[],"tail":", or an application (or supplement to an application) or a product development protocol under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360e"},"text":"section 360e of this title","children":[],"tail":", shall include in the application or protocol the information described in paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id141cdd49-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The application or protocol described in paragraph (1) shall include, with respect to the device for which approval is sought and if readily available—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id141cdd4a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–1/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any pediatric subpopulations that suffer from the disease or condition that the device is intended to treat, diagnose, or cure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id141cdd4b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–1/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of affected pediatric patients.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id141cdd4c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2007-09-27"},"text":"September 27, 2007","children":[],"tail":", and annually thereafter, the Secretary shall submit to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Energy and Commerce of the House of Representatives a report that includes—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id141cdd4d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–1/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of devices approved in the year preceding the year in which the report is submitted, for which there is a pediatric subpopulation that suffers from the disease or condition that the device is intended to treat, diagnose, or cure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id141cdd4e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–1/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any information, based on a review of data available to the Secretary, regarding devices used in pediatric patients but not labeled for such use for which the Secretary determines that approved pediatric labeling could confer a benefit to pediatric patients;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id141cdd4f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–1/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of pediatric devices that receive a humanitarian use exemption under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360j/m"},"text":"section 360j(m) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id141cdd50-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–1/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of devices approved in the year preceding the year in which the report is submitted, labeled for use in pediatric patients;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id141cdd51-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–1/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of pediatric devices approved in the year preceding the year in which the report is submitted, exempted from a fee pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s379j/a/2/B/v"},"text":"section 379j(a)(2)(B)(v) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id141cdd52-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–1/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the review time for each device described in subparagraphs (A), (C), (D), and (E);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id141cdd53-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–1/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of devices for which the Secretary relied on data with respect to adults to support a determination of a reasonable assurance of safety and effectiveness in pediatric patients; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id141cdd54-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–1/a/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of devices for which the Secretary relied on data from one pediatric subpopulation to support a determination of a reasonable assurance of safety and effectiveness in another pediatric subpopulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For the items described in this paragraph, such report shall disaggregate the number of devices by pediatric subpopulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id141cdd55-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of pediatric effectiveness based on similar course of disease or condition or similar effect of device on adults","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id141cdd56-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the course of the disease or condition and the effects of the device are sufficiently similar in adults and pediatric patients, the Secretary may conclude that adult data may be used to support a determination of a reasonable assurance of effectiveness in pediatric populations, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id141cdd57-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extrapolation between subpopulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A study may not be needed in each pediatric subpopulation if data from one subpopulation can be extrapolated to another subpopulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id141cdd58-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pediatric subpopulation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “pediatric subpopulation” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360j/m/6/E/ii"},"text":"section 360j(m)(6)(E)(ii) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id141cdd59-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s515A"},"text":"June 25, 1938, ch. 675, § 515A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/85/tIII/s302"},"text":"Pub. L. 110–85, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/859"},"text":"121 Stat. 859","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/52/tV/s502/a"},"text":"Pub. L. 115–52, title V, § 502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-18"},"text":"Aug. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1037"},"text":"131 Stat. 1037","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id141cdd5a-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id141cdd5b-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id141cdd5c-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/52"},"text":"Pub. L. 115–52","children":[],"tail":" added subpars. (B), (C), (G), and (H), redesignated former subpars. (B) to (D) as (D) to (F), respectively, substituted “(C), (D), and (E);” for “(B), and (C).” in subpar. (F), and inserted concluding provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id141cdd5d-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id141cdd5e-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Final Rule Relating to Tracking of Pediatric Uses of Devices","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/144/tVI/s620/b"},"text":"Pub. L. 112–144, title VI, § 620(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1064"},"text":"126 Stat. 1064","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/144/tVI/s620/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Secretary of Health and Human Services shall issue—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proposed rule implementing section 515A(a)(2) of the Federal Food, Drug, and Cosmetic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360e–1/a/2"},"text":"21 U.S.C. 360e–1(a)(2)","children":[],"tail":") not later than "},{"tag":"date","attrib":{"date":"2012-12-31"},"text":"December 31, 2012","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a final rule implementing such section not later than ","children":[{"tag":"date","attrib":{"date":"2013-12-31"},"text":"December 31, 2013","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
