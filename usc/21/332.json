{"tag":"section","attrib":{"id":"id13b65329-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s332"},"text":null,"children":[{"tag":"num","attrib":{"value":"332"},"text":"§ 332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunction proceedings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id13b6532a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s332/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of courts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The district courts of the United States and the United States courts of the Territories shall have jurisdiction, for cause shown ","children":[{"tag":"ref","attrib":{"idref":"fn002009"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002009"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" to restrain violations of "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s331"},"text":"section 331 of this title","children":[],"tail":", except paragraphs (h), (i), and (j)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13b6532b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s332/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violation of injunction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In case of violation of an injunction or restraining order issued under this section, which also constitutes a violation of this chapter, trial shall be by the court, or, upon demand of the accused, by a jury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sou