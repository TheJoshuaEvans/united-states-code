{"tag":"section","attrib":{"id":"id14cfb351-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1906"},"text":null,"children":[{"tag":"num","attrib":{"value":"1906"},"text":"§ 1906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14cfb352-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14cfb353-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1906/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whoever willfully violates the provisions of this chapter, or any license rule, or regulation issued pursuant to this chapter, or willfully neglects or refuses to comply with any order of the President issued under this chapter shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14cfb354-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1906/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imprisoned for not more than 10 years,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14cfb355-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1906/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fined in the amount provided in title 18 or, in the case of an entity, fined not more than $10,000,000,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14cfb356-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1906/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any officer, director, or agent of any entity who knowingly participates in a violation of the provisions of this chapter shall be imprisoned for not more than 30 years, fined not more than $5,000,000, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14cfb357-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A civil penalty not to exceed $1,000,000 may be imposed by the Secretary of the Treasury on any person who violates any license, order, rule, or regulation issued in compliance with the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14cfb358-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1906/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review of civil penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any penalty imposed under subsection (b) shall be subject to judicial review only to the extent provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s702"},"text":"section 702 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14cfb359-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/120/tVIII/s807"},"text":"Pub. L. 106–120, title VIII, § 807","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-03"},"text":"Dec. 3, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1631"},"text":"113 Stat. 1631","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
