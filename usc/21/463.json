{"tag":"section","attrib":{"id":"id1485d84d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s463"},"text":null,"children":[{"tag":"num","attrib":{"value":"463"},"text":"§ 463.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1485d84e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s463/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Storage and handling of poultry products; violation of regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may by regulations prescribe conditions under which poultry products capable of use as human food, shall be stored or otherwise handled by any person engaged in the business of buying, selling, freezing, storing, or transporting, in or for commerce, or importing, such articles, whenever the Secretary deems such action necessary to assure that such articles will not be adulterated or misbranded when delivered to the consumer. Violation of any such regulation is prohibited.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1485d84f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s463/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other necessary rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate such other rules and regulations as are necessary to carry out the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1485d850-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s463/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oral presentation of views","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In applying the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553/c"},"text":"section 553(c) of title 5","children":[],"tail":" to proposed rule making under this chapter, an opportunity for the oral presentation of views shall be accorded all interested persons."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1485d851-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/172/s14"},"text":"Pub. L. 85–172, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-08-28"},"text":"Aug. 28, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/447"},"text":"71 Stat. 447","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/492/s13"},"text":"Pub. L. 90–492, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-18"},"text":"Aug. 18, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/803"},"text":"82 Stat. 803","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1485d852-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1485d853-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id1485d854-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/492"},"text":"Pub. L. 90–492","children":[],"tail":" designated existing provisions as par. (b), added pars. (a) and (c), and in par. (b), as so designated, substituted “such other rules” for “such rules”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1485d855-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id1485d856-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1968 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/492"},"text":"Pub. L. 90–492","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1968-08-18"},"text":"Aug. 18, 1968","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/492/s20"},"text":"section 20 of Pub. L. 90–492","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s451"},"text":"section 451 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
