{"tag":"section","attrib":{"id":"id143bd807-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"360eee–3"},"text":"§ 360eee–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National standards for third-party logistics providers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id143bd808-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No third-party logistics provider in any State may conduct activities in any State unless each facility of such third-party logistics provider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id143bd809-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id143bd80a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is licensed by the State from which the drug is distributed by the third-party logistics provider, in accordance with the regulations promulgated under subsection (d); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143bd80b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the State from which the drug distributed by the third-party logistics provider has not established a licensure requirement, is licensed by the Secretary, in accordance with the regulations promulgated under subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143bd80c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the drug is distributed interstate, is licensed by the State into which the drug is distributed by the third-party logistics provider if such State licenses third-party logistics providers that distribute drugs into the State and the third-party logistics provider is not licensed by the Secretary as described in paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id143bd80d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning 1 year after ","children":[{"tag":"date","attrib":{"date":"2013-11-27"},"text":"November 27, 2013","children":[],"tail":", a facility of a third-party logistics provider shall report to the Secretary, on an annual basis pursuant to a schedule determined by the Secretary—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id143bd80e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State by which the facility is licensed and the appropriate identification number of such license; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143bd80f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address of the facility and all trade names under which such facility conducts business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id143bd810-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id143bd811-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized fees of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State does not establish a licensing program for a third-party logistics provider, the Secretary shall license the third-party logistics provider located in such State and may collect a reasonable fee in such amount necessary to reimburse the Secretary for costs associated with establishing and administering the licensure program and conducting periodic inspections under this section. The Secretary shall adjust fee rates as needed on an annual basis to generate only the amount of revenue needed to perform this service. Fees authorized under this paragraph shall be collected and available for obligation only to the extent and in the amount provided in advance in appropriations Acts. Such fees are authorized to remain available until expended. Such sums as may be necessary may be transferred from the Food and Drug Administration salaries and expenses appropriation account without fiscal year limitation to such appropriation account for salaries and expenses with such fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143bd812-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State licensing fees","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id143bd813-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State established program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall prohibit a State that has established a program to license a third-party logistics provider from collecting fees from a third-party logistics provider for such a license.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143bd814-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No State established program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that does not establish a program to license a third-party logistics provider in accordance with this section shall be prohibited from collecting a State licensing fee from a third-party logistics provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id143bd815-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id143bd816-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2013-11-27"},"text":"November 27, 2013","children":[],"tail":", the Secretary shall issue regulations regarding the standards for licensing under subsection (a), including the revocation and reissuance of such license, to third-party logistics providers under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143bd817-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such regulations shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id143bd818-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a process by which a third-party accreditation program approved by the Secretary shall, upon request by a third-party logistics provider, issue a license to each third-party logistics provider that meets the requirements set forth in this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143bd819-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a process by which the Secretary shall issue a license to each third-party logistics provider that meets the requirements set forth in this section if the Secretary is not able to approve a third-party accreditation program because no such program meets the Secretary’s requirements necessary for approval of such a third-party accreditation program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143bd81a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" require that the entity complies with storage practices, as determined by the Secretary for such facility, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id143bd81b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining access to warehouse space of suitable size to facilitate safe operations, including a suitable area to quarantine suspect product;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id143bd81c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining adequate security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id143bd81d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/d/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" having written policies and procedures to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id143bd81e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/d/2/C/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address receipt, security, storage, inventory, shipment, and distribution of a product;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id143bd81f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/d/2/C/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify, record, and report confirmed losses or thefts in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id143bd820-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/d/2/C/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" correct errors and inaccuracies in inventories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id143bd821-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/d/2/C/iii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide support for manufacturer recalls;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id143bd822-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/d/2/C/iii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare for, protect against, and address any reasonably foreseeable crisis that affects security or operation at the facility, such as a strike, fire, or flood;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id143bd823-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/d/2/C/iii/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that any expired product is segregated from other products and returned to the manufacturer or repackager or destroyed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id143bd824-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/d/2/C/iii/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain the capability to trace the receipt and outbound distribution of a product, and supplies and records of inventory; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id143bd825-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/d/2/C/iii/VIII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VIII"},"text":"(VIII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quarantine or destroy a suspect product if directed to do so by the respective manufacturer, wholesale distributor, dispenser, or an authorized government agency;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143bd826-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for periodic inspection by the licensing authority, as determined by the Secretary, of such facility warehouse space to ensure compliance with this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143bd827-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibit a facility from having as a manager or designated representative anyone convicted of any felony violation of subsection (i) or (k) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s331"},"text":"section 331 of this title","children":[],"tail":" or any violation of "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1365"},"text":"section 1365 of title 18","children":[],"tail":", relating to product tampering;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143bd828-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for mandatory background checks of a facility manager or a designated representative of such manager;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143bd829-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require a third-party logistics provider to provide the applicable licensing authority, upon a request by such authority, a list of all product manufacturers, wholesale distributors, and dispensers for whom the third-party logistics provider provides services at such facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143bd82a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/d/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include procedures under which any third-party logistics provider license—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id143bd82b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/d/2/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expires on the date that is 3 years after issuance of the license; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id143bd82c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/d/2/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be renewed for additional 3-year periods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143bd82d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In promulgating the regulations under this subsection, the Secretary shall, notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id143bd82e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue a notice of proposed rulemaking that includes a copy of the proposed regulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143bd82f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a period of not less than 60 days for comments on the proposed regulation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143bd830-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that the final regulation takes effect upon the expiration of 1 year after the date that such final regulation is issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id143bd831-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–3/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Validity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A license issued under this section shall remain valid as long as such third-party logistics provider remains licensed consistent with this section. If the Secretary finds that the third-party accreditation program demonstrates that all applicable requirements for licensure under this section are met, the Secretary shall issue a license under this section to a third-party logistics provider receiving accreditation, pursuant to subsection (d)(2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id143bd832-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s584"},"text":"June 25, 1938, ch. 675, § 584","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/54/tII/s205"},"text":"Pub. L. 113–54, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-11-27"},"text":"Nov. 27, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/636"},"text":"127 Stat. 636","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
