{"tag":"section","attrib":{"id":"id14c181b4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1505a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1505a"},"text":"§ 1505a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on development and deployment of narcotics detection technologies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14c181b5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1505a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than December 1st of each year, the Director of the Office of National Drug Control Policy shall submit to Congress and the President a report on the development and deployment of narcotics detection technologies by Federal agencies. Each such report shall be prepared in consultation with the Secretary of Defense, the Secretary of State, the Secretary of Homeland Security, and the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c181b6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1505a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters to be included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c181b7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1505a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of each project implemented by a Federal agency relating to the development or deployment of narcotics detection technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c181b8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1505a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency responsible for each project described in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c181b9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1505a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of funds obligated or expended to carry out each project described in paragraph (1) during the fiscal year in which the report is submitted or during any fiscal year preceding the fiscal year in which the report is submitted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c181ba-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1505a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of funds estimated to be obligated or expended for each project described in paragraph (1) during any fiscal year after the fiscal year in which the report is submitted to Congress; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c181bb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1505a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed timeline for implementation of each project described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14c181bc-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1034"},"text":"Pub. L. 105–85, div. A, title X, § 1034","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1884"},"text":"111 Stat. 1884","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/e/10"},"text":"Pub. L. 107–296, title XVII, § 1704(e)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2315"},"text":"116 Stat. 2315","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14c181bd-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14c181be-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id14c181bf-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Defense Authorization Act for Fiscal Year 1998, and not as part of the National Narcotics Leadership Act of 1988 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14c181c0-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “of Homeland Security” for “of Transportation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14c181c1-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id14c181c2-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective on the date of transfer of the Coast Guard to the Department of Homeland Security, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1704/g"},"text":"section 1704(g) of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
