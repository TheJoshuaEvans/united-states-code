{"tag":"section","attrib":{"id":"id14bf10b4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1115"},"text":null,"children":[{"tag":"num","attrib":{"value":"1115"},"text":"§ 1115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice relating to the control of dangerous drugs","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Whenever the Attorney General determines that there is evidence that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14bf10b5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1115/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a drug or other substance, which is not a controlled substance (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802/6"},"text":"section 802(6) of this title","children":[],"tail":"), has a potential for abuse, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14bf10b6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1115/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a controlled substance should be transferred or removed from a schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s812"},"text":"section 812 of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"he shall, prior to initiating any proceeding under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s811/a"},"text":"section 811(a) of this title","children":[],"tail":", give the President timely notice of such determination. Information forwarded to the Attorney General pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s811/f"},"text":"section 811(f) of this title","children":[],"tail":" shall also be forwarded by the Secretary of Health and Human Services to the President