{"tag":"section","attrib":{"id":"id14d494d1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205"},"text":null,"children":[{"tag":"num","attrib":{"value":"2205"},"text":"§ 2205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food allergy and anaphylaxis management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14d494d2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d494d3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early childhood education program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “early childhood education program” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d494d4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Head Start program or an Early Head Start program carried out under the Head Start Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9831"},"text":"42 U.S.C. 9831","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d494d5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State licensed or regulated child care program or school; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d494d6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State prekindergarten program that serves children from birth through kindergarten.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d494d7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ESEA definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “local educational agency”, “secondary school”, “elementary school”, and “parent” have the meanings given the terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d494d8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" School","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “school” includes public—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d494d9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" kindergartens;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d494da-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elementary schools; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d494db-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" secondary schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d494dc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d494dd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of voluntary food allergy and anaphylaxis management guidelines","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d494de-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d494df-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"January 4, 2011","children":[],"tail":", the Secretary, in consultation with the Secretary of Education, shall—"}],"tail":null},{"tag":"clause","attrib":{"id":"id14d494e0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop guidelines to be used on a voluntary basis to develop plans for individuals to manage the risk of food allergy and anaphylaxis in schools and early childhood education programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d494e1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make such guidelines available to local educational agencies, schools, early childhood education programs, and other interested entities and individuals to be implemented on a voluntary basis only.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d494e2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of FERPA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each plan described in subparagraph (A) that is developed for an individual shall be considered an education record for the purpose of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232g"},"text":"section 1232g of title 20","children":[],"tail":" (commonly referred to as the “Family Educational Rights and Privacy Act of 1974”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d494e3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The voluntary guidelines developed by the Secretary under paragraph (1) shall address each of the following and may be updated as the Secretary determines necessary:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d494e4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Parental obligation to provide the school or early childhood education program, prior to the start of every school year, with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14d494e5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" documentation from their child’s physician or nurse—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id14d494e6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting a diagnosis of food allergy, and any risk of anaphylaxis, if applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14d494e7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying any food to which the child is allergic;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14d494e8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/2/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing, if appropriate, any prior history of anaphylaxis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14d494e9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/2/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" listing any medication prescribed for the child for the treatment of anaphylaxis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14d494ea-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/2/A/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detailing emergency treatment procedures in the event of a reaction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14d494eb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/2/A/i/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" listing the signs and symptoms of a reaction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14d494ec-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/2/A/i/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the child’s readiness for self-administration of prescription medication; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d494ed-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of substitute meals that may be offered to the child by school or early childhood education program food service personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d494ee-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The creation and maintenance of an individual plan for food allergy management, in consultation with the parent, tailored to the needs of each child with a documented risk for anaphylaxis, including any procedures for the self-administration of medication by such children in instances where—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14d494ef-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the children are capable of self-administering medication; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d494f0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such administration is not prohibited by State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d494f1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Communication strategies between individual schools or early childhood education programs and providers of emergency medical services, including appropriate instructions for emergency medical response.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d494f2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Strategies to reduce the risk of exposure to anaphylactic causative agents in classrooms and common school or early childhood education program areas such as cafeterias.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d494f3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The dissemination of general information on life-threatening food allergies to school or early childhood education program staff, parents, and children.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d494f4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Food allergy management training of school or early childhood education program personnel who regularly come into contact with children with life-threatening food allergies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d494f5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authorization and training of school or early childhood education program personnel to administer epinephrine when the nurse is not immediately available.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d494f6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The timely accessibility of epinephrine by school or early childhood education program personnel when the nurse is not immediately available.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d494f7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The creation of a plan contained in each individual plan for food allergy management that addresses the appropriate response to an incident of anaphylaxis of a child while such child is engaged in extracurricular programs of a school or early childhood education program, such as non-academic outings and field trips, before- and after-school programs or before- and after-early child education program programs,","children":[{"tag":"ref","attrib":{"idref":"fn002199"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002199"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" and school-sponsored or early childhood education program-sponsored programs held on weekends."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d494f8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Maintenance of information for each administration of epinephrine to a child at risk for anaphylaxis and prompt notification to parents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d494f9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other elements the Secretary determines necessary for the management of food allergies and anaphylaxis in schools and early childhood education programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d494fa-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to State law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section or the guidelines developed by the Secretary under paragraph (1) shall be construed to preempt State law, including any State law regarding whether students at risk for anaphylaxis may self-administer medication.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d494fb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" School-based food allergy management grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d494fc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award grants to local educational agencies to assist such agencies with implementing voluntary food allergy and anaphylaxis management guidelines described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d494fd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d494fe-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this subsection, a local educational agency shall submit an application to the Secretary at such time, in such manner, and including such information as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d494ff-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application submitted under subparagraph (A) shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14d49500-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that the local educational agency has developed plans in accordance with the food allergy and anaphylaxis management guidelines described in subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d49501-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of the activities to be funded by the grant in carrying out the food allergy and anaphylaxis management guidelines, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id14d49502-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the guidelines will be carried out at individual schools served by the local educational agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14d49503-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the local educational agency will inform parents and students of the guidelines in place;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14d49504-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how school nurses, teachers, administrators, and other school-based staff will be made aware of, and given training on, when applicable, the guidelines in place; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14d49505-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/2/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other activities that the Secretary determines appropriate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d49506-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an itemization of how grant funds received under this subsection will be expended;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d49507-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how adoption of the guidelines and implementation of grant activities will be monitored; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d49508-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement by the local educational agency to report information required by the Secretary to conduct evaluations under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d49509-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each local educational agency that receives a grant under this subsection may use the grant funds for the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d4950a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Purchase of materials and supplies, including limited medical supplies such as epinephrine and disposable wet wipes, to support carrying out the food allergy and anaphylaxis management guidelines described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d4950b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In partnership with local health departments, school nurse, teacher, and personnel training for food allergy management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d4950c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Programs that educate students as to the presence of, and policies and procedures in place related to, food allergies and anaphylactic shock.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d4950d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Outreach to parents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d4950e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other activities consistent with the guidelines described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d4950f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award grants under this subsection for a period of not more than 2 years. In the event the Secretary conducts a program evaluation under this subsection, funding in the second year of the grant, where applicable, shall be contingent on a successful program evaluation by the Secretary after the first year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d49510-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on grant funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not provide grant funding to a local educational agency under this subsection after such local educational agency has received 2 years of grant funding under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d49511-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount of annual awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded under this subsection may not be made in an amount that is more than $50,000 annually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d49512-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this subsection, the Secretary shall give priority to local educational agencies with the highest percentages of children who are counted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6333/c"},"text":"section 6333(c) of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d49513-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d49514-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not award a grant under this subsection unless the local educational agency agrees that, with respect to the costs to be incurred by such local educational agency in carrying out the grant activities, the local educational agency shall make available (directly or through donations from public or private entities) non-Federal funds toward such costs in an amount equal to not less than 25 percent of the amount of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d49515-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of amount of non-Federal contribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Non-Federal funds required under subparagraph (A) may be cash or in kind, including plant, equipment, or services. Amounts provided by the Federal Government, and any portion of any service subsidized by the Federal Government, may not be included in determining the amount of such non-Federal funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d49516-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A local educational agency that receives a grant under this subsection may use not more than 2 percent of the grant amount for administrative costs related to carrying out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d49517-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Progress and evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the completion of the grant period referred to in paragraph (4), a local educational agency shall provide the Secretary with information on how grant funds were spent and the status of implementation of the food allergy and anaphylaxis management guidelines described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d49518-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement, not supplant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grant funds received under this subsection shall be used to supplement, and not supplant, non-Federal funds and any other Federal funds available to carry out the activities described in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d49519-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/c/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this subsection $30,000,000 for fiscal year 2011 and such sums as may be necessary for each of the 4 succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d4951a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary nature of guidelines","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d4951b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The food allergy and anaphylaxis management guidelines developed by the Secretary under subsection (b) are voluntary. Nothing in this section or the guidelines developed by the Secretary under subsection (b) shall be construed to require a local educational agency to implement such guidelines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d4951c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2205/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), the Secretary may enforce an agreement by a local educational agency to implement food allergy and anaphylaxis management guidelines as a condition of the receipt of a grant under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14d4951d-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/353/tI/s112"},"text":"Pub. L. 111–353, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3916"},"text":"124 Stat. 3916","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/jj"},"text":"Pub. L. 114–95, title IX, § 9215(jj)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2175"},"text":"129 Stat. 2175","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14d4951e-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14d4951f-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14d49520-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Head Start Act, referred to in subsec. (a)(1)(A), is subchapter B (§ 635 et seq.) of chapter 8 of subtitle A of title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/499"},"text":"95 Stat. 499","children":[],"tail":", which is classified generally to subchapter II (§ 9831 et seq.) of chapter 105 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9801"},"text":"section 9801 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14d49521-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14d49522-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id14d49523-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
