{"tag":"section","attrib":{"id":"id148a93ef-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s611"},"text":null,"children":[{"tag":"num","attrib":{"value":"611"},"text":"§ 611.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Devices, marks, labels, and certificates; simulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id148a93f0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s611/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Devices to be made under authorization of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No brand manufacturer, printer, or other person, firm, or corporation shall cast, print, lithograph, or otherwise make any device containing any official mark or simulation thereof, or any label bearing any such mark or simulation, or any form of official certificate or simulation thereof, except as authorized by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id148a93f1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s611/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other misconduct","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No person, firm, or corporation shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id148a93f2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s611/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forge any official device, mark, or certificate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id148a93f3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s611/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without authorization from the Secretary use any official device, mark, or certificate, or simulation thereof, or alter, detach, deface, or destroy any official device, mark, or certificate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id148a93f4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s611/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contrary to the regulations prescribed by the Secretary, fail to use, or to detach, deface, or destroy any official device, mark, or certificate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id148a93f5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s611/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly possess, without promptly notifying the Secretary or his representative, any official device or any counterfeit, simulated, forged, or improperly altered official certificate or any device or label or any carcass of any animal, or part or product thereof, bearing any counterfeit, simulated, forged, or improperly altered official mark;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id148a93f6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s611/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly make any false statement in any shipper’s certificate or other nonofficial or official certificate provided for in the regulations prescribed by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id148a93f7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s611/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly represent that any article has been inspected and passed, or exempted, under this chapter when, in fact, it has, respectively, not been so inspected and passed, or exempted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id148a93f8-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1907-03-04/ch2907"},"text":"Mar. 4, 1907, ch. 2907","children":[],"tail":", title I, § 11, formerly 9th par., "},{"tag":"ref","attrib":{"href":"/us/stat/34/1263"},"text":"34 Stat. 1263","children":[],"tail":"; renumbered § 11 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/90/201"},"text":"Pub. L. 90–201","children":[],"tail":", §§ 1, 8, "},{"tag":"date","attrib":{"date":"1967-12-15"},"text":"Dec. 15, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/584"},"text":"81 Stat. 584","children":[],"tail":", 589.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id148a93f9-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id148a93fa-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id148a93fb-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s79"},"text":"section 79 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id148a93fc-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/201/s8"},"text":"Pub. L. 90–201, § 8","children":[],"tail":", clarified application to brand manufacturers and printers of existing prohibition against counterfeiting official marks, labels or certificates, the provisions with respect to forgery, unauthorized use or failure to use official marks, or similar items, and similar offenses, and existing prohibitions with respect to false statements in official or nonofficial certificates, and added restriction upon possession of official devices, or devices, labels, meat, or other articles bearing counterfeit official marks, counterfeit official certificates, or similar items, and prohibition against false representations."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id148a93fd-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id148a93fe-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1967 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/201"},"text":"Pub. L. 90–201","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1967-12-15"},"text":"Dec. 15, 1967","children":[],"tail":", except that with respect to equines (other than horses) and their carcasses and parts thereof, meat, and meat food products thereof, amendment effective upon expiration of sixty days after "},{"tag":"date","attrib":{"date":"1967-12-15"},"text":"Dec. 15, 1967","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/201/s20/b"},"text":"section 20(b) of Pub. L. 90–201","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s601"},"text":"section 601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
