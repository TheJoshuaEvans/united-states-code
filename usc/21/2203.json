{"tag":"section","attrib":{"id":"id14d494a2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2203"},"text":null,"children":[{"tag":"num","attrib":{"value":"2203"},"text":"§ 2203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food and Agriculture Coordinating Councils","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Homeland Security, in coordination with the Secretary of Health and Human Services and the Secretary of Agriculture, shall within 180 days of ","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"January 4, 2011","children":[],"tail":", and annually thereafter, submit to the relevant committees of Congress, and make publicly available on the Internet Web site of the Department of Homeland Security, a report on the activities of the Food and Agriculture Government Coordinating Council and the Food and Agriculture Sector Coordinating Council, including the progress of such Councils on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d494a3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2203/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating partnerships between public and private entities to help coordinate and enhance the protection of the agriculture and food system of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d494a4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2203/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for the regular and timely interchange of information between each council relating to the security of the agriculture and food system (including intelligence information);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d494a5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2203/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying best practices and methods for improving the coordination among Federal, State, local, and private sector preparedness and response plans for agriculture and food defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d494a6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2203/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommending methods by which to protect the economy and the public health of the United States from the effects of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d494a7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2203/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" animal or plant disease outbreaks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d494a8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2203/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" food contamination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d494a9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2203/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" natural disasters affecting agriculture and food.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14d494aa-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/353/tI/s109"},"text":"Pub. L. 111–353, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3912"},"text":"124 Stat. 3912","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
