{"tag":"section","attrib":{"id":"id1434d223-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8a"},"text":null,"children":[{"tag":"num","attrib":{"value":"360bbb–8a"},"text":"§ 360bbb–8a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Optimizing global clinical trials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1434d224-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1434d225-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with other regulatory authorities of similar standing, medical research companies, and international organizations to foster and encourage uniform, scientifically driven clinical trial standards with respect to medical products around the world; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d226-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" enhance the commitment to provide consistent parallel scientific advice to manufacturers seeking simultaneous global development of new medical products in order to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1434d227-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance medical product development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1434d228-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the use of foreign data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1434d229-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize the need to conduct duplicative clinical studies, preclinical studies, or nonclinical studies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1434d22a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical product","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “medical product” means a drug, as defined in subsection (g) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s321"},"text":"section 321 of this title","children":[],"tail":", a device, as defined in subsection (h) of such section, or a biological product, as defined in section 351(i) of the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262/i"},"text":"42 U.S.C. 262(i)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1434d22b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings clause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall alter the criteria for evaluating the safety or effectiveness of a medical product under this chapter or under the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"42 U.S.C. 201","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1434d22c-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s569A"},"text":"June 25, 1938, ch. 675, § 569A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/144/tXI/s1123"},"text":"Pub. L. 112–144, title XI, § 1123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1113"},"text":"126 Stat. 1113","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIII/s3101/a/2/P"},"text":"Pub. L. 114–255, div. A, title III, § 3101(a)(2)(P)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1154"},"text":"130 Stat. 1154","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1434d22d-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1434d22e-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id1434d22f-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Public Health Service Act, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"act July 1, 1944, ch. 373","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/682"},"text":"58 Stat. 682","children":[],"tail":", which is classified generally to chapter 6A (§ 201 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id1434d230-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","children":[],"tail":" inserted “or under the Public Health Service Act” before period at end."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
