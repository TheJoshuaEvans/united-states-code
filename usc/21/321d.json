{"tag":"section","attrib":{"id":"id13b40999-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s321d"},"text":null,"children":[{"tag":"num","attrib":{"value":"321d"},"text":"§ 321d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Market names for catfish and ginseng","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id13b4099a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s321d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Catfish labeling","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13b4099b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s321d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, for purposes of the Federal Food, Drug, and Cosmetic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"21 U.S.C. 301","children":[],"tail":" et seq.)—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13b4099c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s321d/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “catfish” may only be considered to be a common or usual name (or part thereof) for fish classified within the family Ictaluridae; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13b4099d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s321d/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only labeling or advertising for fish classified within that family may include the term “catfish”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13b4099e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s321d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13b4099f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s321d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ginseng labeling","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13b409a0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s321d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, for purposes of the Federal Food, Drug, and Cosmetic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"21 U.S.C. 301","children":[],"tail":" et seq.)—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13b409a1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s321d/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “ginseng” may only be considered to be a common or usual name (or part thereof) for any herb or herbal ingredient derived from a plant classified within the genus Panax; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13b409a2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s321d/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only labeling or advertising for herbs or herbal ingredients classified within that genus may include the term “ginseng”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13b409a3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s321d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id13b409a4-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10806"},"text":"Pub. L. 107–171, title X, § 10806","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/526"},"text":"116 Stat. 526","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id13b409a5-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id13b409a6-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id13b409a7-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Food, Drug, and Cosmetic Act, referred to in subsecs. (a)(1), (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675"},"text":"act June 25, 1938, ch. 675","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1040"},"text":"52 Stat. 1040","children":[],"tail":", which is classified generally to this chapter. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"section 301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id13b409a8-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s10806"},"text":"section 10806 of Pub. L. 107–171","children":[],"tail":". Subsecs. (a)(2) and (b)(2) of "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/s10806"},"text":"section 10806 of Pub. L. 107–171","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s343"},"text":"section 343 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Farm Security and Rural Investment Act of 2002, and not as part of Federal Food, Drug, and Cosmetic Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
