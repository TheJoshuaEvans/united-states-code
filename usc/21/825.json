{"tag":"section","attrib":{"id":"id14a0175a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s825"},"text":null,"children":[{"tag":"num","attrib":{"value":"825"},"text":"§ 825.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Labeling and packaging","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14a0175b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s825/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Symbol","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful to distribute a controlled substance in a commercial container unless such container, when and as required by regulations of the Attorney General, bears a label (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s321/k"},"text":"section 321(k) of this title","children":[],"tail":") containing an identifying symbol for such substance in accordance with such regulations. A different symbol shall be required for each schedule of controlled substances."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14a0175c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s825/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful distribution without identifying symbol","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for the manufacturer of any controlled substance to distribute such substance unless the labeling (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s321/m"},"text":"section 321(m) of this title","children":[],"tail":") of such substance contains, when and as required by regulations of the Attorney General, the identifying symbol required under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14a0175d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s825/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Warning on label","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe regulations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s353/b"},"text":"section 353(b) of this title","children":[],"tail":" which shall provide that the label of a drug listed in schedule II, III, or IV shall, when dispensed to or for a patient, contain a clear, concise warning that it is a crime to transfer the drug to any person other than the patient."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14a0175e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s825/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Containers to be securely sealed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful to distribute controlled substances in schedule I or II, and narcotic drugs in schedule III or IV, unless the bottle or other container, stopper, covering, or wrapper thereof is securely sealed as required by regulations of the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14a0175f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s825/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False labeling of anabolic steroids","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14a01760-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s825/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It shall be unlawful to import, export, manufacture, distribute, dispense, or possess with intent to manufacture, distribute, or dispense, an anabolic steroid or product containing an anabolic steroid, unless the steroid or product bears a label clearly identifying an anabolic steroid or product containing an anabolic steroid by the nomenclature used by the International Union of Pure and Applied Chemistry (IUPAC).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14a01761-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s825/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14a01762-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s825/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A product described in subparagraph (B) is exempt from the International Union of Pure and Applied Chemistry nomenclature requirement of this subsection if such product is labeled in the manner required under the Federal Food, Drug, and Cosmetic Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"21 U.S.C. 301","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14a01763-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s825/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A product is described in this subparagraph if the product—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14a01764-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s825/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the subject of an approved application as described in section 505(b) or (j) of the Federal Food, Drug, and Cosmetic Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/b"},"text":"21 U.S.C. 355(b)","children":[],"tail":", (j)]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14a01765-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s825/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is exempt from the provisions of section 505 of such Act relating to new drugs because—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id14a01766-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s825/e/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is intended solely for investigational use as described in section 505(i) of such Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14a01767-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s825/e/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such product is being used exclusively for purposes of a clinical trial that is the subject of an effective investigational new drug application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14a01768-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/tII/s305"},"text":"Pub. L. 91–513, title II, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1256"},"text":"84 Stat. 1256","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/260/s3/a"},"text":"Pub. L. 113–260, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2931"},"text":"128 Stat. 2931","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14a01769-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14a0176a-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14a0176b-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Schedules I, II, III, and IV, referred to in subsecs. (c) and (d), are set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s812/c"},"text":"section 812(c) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Food, Drug, and Cosmetic Act, referred to in subsec. (e)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675"},"text":"act June 25, 1938, ch. 675","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1040"},"text":"52 Stat. 1040","children":[],"tail":", which is classified generally to chapter 9 (§ 301 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"section 301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14a0176c-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/260"},"text":"Pub. L. 113–260","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14a0176d-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id14a0176e-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of seventh calendar month that begins after ","children":[{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", but with Attorney General authorized to postpone such effective date for such period as he might determine to be necessary for the efficient administration of this subchapter, see "},{"tag":"ref","attrib":{"href":"/us/pl/91/513/s704/c"},"text":"section 704(c) of Pub. L. 91–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id14a0176f-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Identification and Publication of List of Products Containing Anabolic Steroids","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/260/s4"},"text":"Pub. L. 113–260, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2932"},"text":"128 Stat. 2932","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/260/s4"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General may, in the Attorney General’s discretion, collect data and analyze products to determine whether they contain anabolic steroids and are properly labeled in accordance with this Act [see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/260/s1"},"text":"section 1 of Pub. L. 113–260","children":[],"tail":", set out as a Short Title of 2014 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"section 801 of this title","children":[],"tail":"] and the amendments made by this Act. The Attorney General may publish in the Federal Register or on the website of the Drug Enforcement Administration a list of products which the Attorney General has determined, based on substantial evidence, contain an anabolic steroid and are not labeled in accordance with this Act and the amendments made by this Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Absence From List","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The absence of a product from the list referred to in subsection (a) shall not constitute evidence that the product does not contain an anabolic steroid.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
