{"tag":"section","attrib":{"id":"id1479f1ff-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387l"},"text":null,"children":[{"tag":"num","attrib":{"value":"387l"},"text":"§ 387l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1479f200-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1479f201-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387l/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1479f202-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387l/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the promulgation of a regulation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s387g"},"text":"section 387g of this title","children":[],"tail":" establishing, amending, or revoking a tobacco product standard; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1479f203-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387l/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a denial of an application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s387j/c"},"text":"section 387j(c) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"any person adversely affected by such regulation or denial may file a petition for judicial review of such regulation or denial with the United States Court of Appeals for the District of Columbia or for the circuit in which such person resides or has their principal place of business.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1479f204-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387l/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1479f205-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387l/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copy of petition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A copy of the petition filed under paragraph (1) shall be transmitted by the clerk of the court involved to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1479f206-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387l/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Record of proceedings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On receipt of a petition under subparagraph (A), the Secretary shall file in the court in which such petition was filed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id1479f207-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387l/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the record of the proceedings on which the regulation or order was based; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1479f208-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387l/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the reasons for the issuance of such a regulation or order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1479f209-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387l/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of record","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “record” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id1479f20a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387l/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all notices and other matter published in the Federal Register with respect to the regulation or order reviewed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1479f20b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387l/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all information submitted to the Secretary with respect to such regulation or order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1479f20c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387l/a/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proceedings of any panel or advisory committee with respect to such regulation or order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1479f20d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387l/a/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any hearing held with respect to such regulation or order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1479f20e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387l/a/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information identified by the Secretary, in the administrative proceeding held with respect to such regulation or order, as being relevant to such regulation or order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1479f20f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard of review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the filing of the petition under subsection (a) for judicial review of a regulation or order, the court shall have jurisdiction to review the regulation or order in accordance with chapter 7 of title 5 and to grant appropriate relief, including interim relief, as provided for in such chapter. A regulation or denial described in subsection (a) shall be reviewed in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s706/2/A"},"text":"section 706(2)(A) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1479f210-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387l/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finality of judgment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The judgment of the court affirming or setting aside, in whole or in part, any regulation or order shall be final, subject to review by the Supreme Court of the United States upon certiorari or certification, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1254"},"text":"section 1254 of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1479f211-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387l/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other remedies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The remedies provided for in this section shall be in addition to, and not in lieu of, any other remedies provided by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1479f212-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387l/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations and orders must recite basis in record","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To facilitate judicial review, a regulation or order issued under section 387f, 387g, 387h, 387i, 387j, or 387p of this title shall contain a statement of the reasons for the issuance of such regulation or order in the record of the proceedings held in connection with its issuance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1479f213-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s912"},"text":"June 25, 1938, ch. 675, § 912","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/31/dA/tI/s101/b/3"},"text":"Pub. L. 111–31, div. A, title I, § 101(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-06-22"},"text":"June 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1819"},"text":"123 Stat. 1819","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
