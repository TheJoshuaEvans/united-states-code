{"tag":"section","attrib":{"id":"id1447e4fb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"379d–4"},"text":"§ 379d–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1447e4fc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Generic drugs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning with fiscal year 2013 and ending after fiscal year 2017, not later than 120 days after the end of each fiscal year for which fees are collected under subpart 7 of part C, the Secretary shall prepare and submit to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Energy and Commerce of the House of Representatives a report concerning, for all applications for approval of a generic drug under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/j"},"text":"section 355(j) of this title","children":[],"tail":", amendments to such applications, and prior approval supplements with respect to such applications filed in the previous fiscal year—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id1447e4fd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–4/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of such applications that met the goals identified for purposes of subpart 7 of part C, in the letters from the Secretary of Health and Human Services to the Chairman of the Committee on Health, Education, Labor, and Pensions of the Senate and the Chairman of the Committee on Energy and Commerce of the House of Representatives, as set forth in the Congressional Record;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1447e4fe-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–4/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average total time to decision by the Secretary for applications for approval of a generic drug under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/j"},"text":"section 355(j) of this title","children":[],"tail":", amendments to such applications, and prior approval supplements with respect to such applications filed in the previous fiscal year, including the number of calendar days spent during the review by the Food and Drug Administration and the number of calendar days spent by the sponsor responding to a complete response letter;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1447e4ff-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–4/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of applications under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/j"},"text":"section 355(j) of this title","children":[],"tail":", amendments to such applications, and prior approval supplements with respect to such applications that were pending with the Secretary for more than 10 months on "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1447e500-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–4/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of applications described in paragraph (3) on which the Food and Drug Administration took final regulatory action in the previous fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1447e501-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biosimilar biological products","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1447e502-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–4/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning with fiscal year 2014, not later than 120 days after the end of each fiscal year for which fees are collected under subpart 8 of part C, the Secretary shall prepare and submit to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Energy and Commerce of the House of Representatives a report concerning—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1447e503-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–4/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of applications for approval filed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s262/k"},"text":"section 262(k) of title 42","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1447e504-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–4/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of applications described in subparagraph (A) that were approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1447e505-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–4/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the performance report described in paragraph (1), the Secretary shall include an explanation of how the Food and Drug Administration is managing the biological product review program to ensure that the user fees collected under subpart 2 ","children":[{"tag":"ref","attrib":{"idref":"fn002095"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002095"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably means subpart 2 of part C."}],"tail":" are not used to review an application under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262/k"},"text":"section 262(k) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1447e506-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s715"},"text":"June 25, 1938, ch. 675, § 715","children":[],"tail":", as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/144/tIII/s308"},"text":"Pub. L. 112–144, title III, § 308","children":[],"tail":", title IV, § 408, "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1025"},"text":"126 Stat. 1025","children":[],"tail":", 1039.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1447e507-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1447e508-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading",