{"tag":"section","attrib":{"id":"id1440b9c9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364d"},"text":null,"children":[{"tag":"num","attrib":{"value":"364d"},"text":"§ 364d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safety substantiation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1440b9ca-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substantiation of safety","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A responsible person for a cosmetic product shall ensure, and maintain records supporting, that there is adequate substantiation of safety of such cosmetic product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1440b9cb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coal-tar hair dye","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to coal-tar hair dye that otherwise complies with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s361/a"},"text":"section 361(a) of this title","children":[],"tail":". A responsible person for a coal-tar hair dye shall maintain records related to the safety of such product."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1440b9cc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1440b9cd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adequate substantiation of safety","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “adequate substantiation of safety” means tests or studies, research, analyses, or other evidence or information that is considered, among experts qualified by scientific training and experience to evaluate the safety of cosmetic products and their ingredients, sufficient to support a reasonable certainty that a cosmetic product is safe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1440b9ce-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “safe” means that the cosmetic product, including any ingredient thereof, is not injurious to users under the conditions of use prescribed in the labeling thereof, or under such conditions of use as are customary or usual. The Secretary shall not consider a cosmetic ingredient or cosmetic product injurious to users solely because it can cause minor and transient reactions or minor and transient skin irritations in some users. In determining for purposes of this section whether a cosmetic product is safe, the Secretary may consider, as appropriate and available, the cumulative or other relevant exposure to the cosmetic product, including any ingredient thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1440b9cf-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s608"},"text":"June 25, 1938, ch. 675, § 608","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tIII/s3502"},"text":"Pub. L. 117–328, div. FF, title III, § 3502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5854"},"text":"136 Stat. 5854","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1440b9d0-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1440b9d1-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id1440b9d2-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction; Confidentiality","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s3502"},"text":"section 3502 of Pub. L. 117–328","children":[],"tail":", which enacted this section, to be construed to authorize the disclosure of information that is prohibited from disclosure under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s331/j"},"text":"section 331(j) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1905"},"text":"section 1905 of title 18","children":[],"tail":" or that is subject to withholding under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/4"},"text":"section 552(b)(4) of title 5","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/s3503/c/2"},"text":"section 3503(c)(2) of Pub. L. 117–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s364"},"text":"section 364 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id1440b9d3-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Talc-Containing Cosmetics","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tIII/s3505"},"text":"Pub. L. 117–328, div. FF, title III, § 3505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5859"},"text":"136 Stat. 5859","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dFF/tIII/s3505"},"text":"\n","children":[{"tag":"p","attrib":{},"text":"“The Secretary of Health and Human Services—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than one year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"], shall promulgate proposed regulations to establish and require standardized testing methods for detecting and identifying asbestos in talc-containing cosmetic products; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 180 days after the date on which the public comment period on the proposed regulations closes, shall issue such final regulations.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
