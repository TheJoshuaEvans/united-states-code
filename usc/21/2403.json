{"tag":"section","attrib":{"id":"id14d95088-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2403"},"text":null,"children":[{"tag":"num","attrib":{"value":"2403"},"text":"§ 2403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalties and statute of limitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14d95089-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2403/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d9508a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2403/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whoever violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s2402"},"text":"section 2402 of this title","children":[],"tail":" shall be sentenced to a term of imprisonment for not more than 10 years, fined $250,000 if the person is an individual or $1,000,000 if the defendant is other than an individual, or both."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d9508b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2403/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeiture","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any property real or personal, tangible or intangible, may be seized and criminally forfeited to the United States if that property—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d9508c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2403/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is used or intended to be used, in any manner, to commit or facilitate a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s2402"},"text":"section 2402 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d9508d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2403/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constitutes or is traceable to the proceeds taken, obtained, or retained in connection with or as a result of a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s2402"},"text":"section 2402 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d9508e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2403/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on prosecution","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d9508f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2403/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person shall be prosecuted, tried, or punished for violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s2402"},"text":"section 2402 of this title","children":[],"tail":" unless the indictment is returned or the information is filed within 10 years after the date on which the offense was completed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d95090-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2403/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tolling","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon application in the United States, filed before a return of an indictment, indicating that evidence of an offense under this chapter is in a foreign country, the district court before which a grand jury is impaneled to investigate the offense shall suspend the running of this statute of limitation for the offense if the court finds by a preponderance of the evidence that an official request has been made for such evidence and that it reasonably appears, or reasonably appeared at the time the request was made, that such evidence is, or was, in such foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14d95091-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/206/s4"},"text":"Pub. L. 116–206, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-04"},"text":"Dec. 4, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/999"},"text":"134 Stat. 999","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
