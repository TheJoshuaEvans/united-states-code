{"tag":"section","attrib":{"id":"id13a5b194-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s141"},"text":null,"children":[{"tag":"num","attrib":{"value":"141"},"text":"§ 141.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of importation without permit","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1927-05-16"},"text":"May 16, 1927","children":[],"tail":", the importation into the United States of milk and cream is prohibited unless the person by whom such milk or cream is shipped or transported into the United States holds a valid permit from the Secretary of Health and Human Services."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id13a5b195-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-02-15/ch155/s1"},"text":"Feb. 15, 1927, ch. 155, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1101"},"text":"44 Stat. 1101","children":[],"tail":"; 1940 Reorg. Plan No. IV, § 12, eff. "},{"tag":"date","attrib":{"date":"1940-06-30"},"text":"June 30, 1940","children":[],"tail":", 5 F.R. 2421, "},{"tag":"ref","attrib":{"href":"/us/stat/54/1237"},"text":"54 Stat. 1237","children":[],"tail":"; 1953 Reorg. Plan No. 1, § 5, eff. "},{"tag":"date","attrib":{"date":"1953-04-11"},"text":"Apr. 11, 1953","children":[],"tail":", 18 F.R. 2053, "},{"tag":"ref","attrib":{"href":"/us/stat/67/631"},"text":"67 Stat. 631","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id13a5b196-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id13a5b197-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id13a5b198-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Health and Human Services” substituted in text for “Secretary of Health, Education, and Welfare” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id13a5b199-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1943-07-12/ch221/tII"},"text":"Act July 12, 1943, ch. 221, title II","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/57/499"},"text":"57 Stat. 499","children":[],"tail":", provided in part that act "},{"tag":"date","attrib":{"date":"1927-02-15"},"text":"Feb. 15, 1927","children":[],"tail":", which is classified to this subchapter, may be cited as “Import Milk Act”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id13a5b19a-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id13a5b19b-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of Federal Security Administrator to Secretary of Health, Education, and Welfare [now Health and Human Services], and of Food and Drug Administration to Federal Security Agency, see notes set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s321"},"text":"section 321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
