{"tag":"section","attrib":{"id":"id13d7be3a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j"},"text":null,"children":[{"tag":"num","attrib":{"value":"350j"},"text":"§ 350j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Targeting of inspection resources for domestic facilities, foreign facilities, and ports of entry; annual report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id13d7be3b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification and inspection of facilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13d7be3c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall identify high-risk facilities and shall allocate resources to inspect facilities according to the known safety risks of the facilities, which shall be based on the following factors:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13d7be3d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The known safety risks of the food manufactured, processed, packed, or held at the facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d7be3e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The compliance history of a facility, including with regard to food recalls, outbreaks of foodborne illness, and violations of food safety standards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d7be3f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rigor and effectiveness of the facility’s hazard analysis and risk-based preventive controls.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d7be40-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the food manufactured, processed, packed, or held at the facility meets the criteria for priority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s381/h/1"},"text":"section 381(h)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d7be41-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the food or the facility that manufactured, processed, packed, or held such food has received a certification as described in section 381(q) or 384b of this title, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d7be42-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other criteria deemed necessary and appropriate by the Secretary for purposes of allocating inspection resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13d7be43-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspections","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13d7be44-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning on ","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"January 4, 2011","children":[],"tail":", the Secretary shall increase the frequency of inspection of all facilities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d7be45-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic high-risk facilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall increase the frequency of inspection of domestic facilities identified under paragraph (1) as high-risk facilities such that each such facility is inspected—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id13d7be46-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less often than once in the 5-year period following ","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"January 4, 2011","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id13d7be47-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less often than once every 3 years thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d7be48-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic non-high-risk facilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that each domestic facility that is not identified under paragraph (1) as a high-risk facility is inspected—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id13d7be49-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less often than once in the 7-year period following ","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"January 4, 2011","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id13d7be4a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less often than once every 5 years thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d7be4b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign facilities","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id13d7be4c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Year 1","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the 1-year period following ","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"January 4, 2011","children":[],"tail":", the Secretary shall inspect not fewer than 600 foreign facilities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id13d7be4d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In each of the 5 years following the 1-year period described in clause (i), the Secretary shall inspect not fewer than twice the number of foreign facilities inspected by the Secretary during the previous year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d7be4e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reliance on Federal, State, or local inspections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In meeting the inspection requirements under this subsection for domestic facilities, the Secretary may rely on inspections conducted by other Federal, State, or local agencies under interagency agreement, contract, memoranda of understanding, or other obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13d7be4f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification and inspection at ports of entry","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Secretary of Homeland Security, shall allocate resources to inspect any article of food imported into the United States according to the known safety risks of the article of food, which shall be based on the following factors:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13d7be50-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The known safety risks of the food imported.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13d7be51-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The known safety risks of the countries or regions of origin and countries through which such article of food is transported.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13d7be52-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The compliance history of the importer, including with regard to food recalls, outbreaks of foodborne illness, and violations of food safety standards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13d7be53-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rigor and effectiveness of the activities conducted by the importer of such article of food to satisfy the requirements of the foreign supplier verification program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s384a"},"text":"section 384a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13d7be54-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the food importer participates in the voluntary qualified importer program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s384b"},"text":"section 384b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13d7be55-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the food meets the criteria for priority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s381/h/1"},"text":"section 381(h)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13d7be56-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the food or the facility that manufactured, processed, packed, or held such food received a certification as described in section 381(q) or 384b of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13d7be57-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other criteria deemed necessary and appropriate by the Secretary for purposes of allocating inspection resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13d7be58-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency agreements with respect to seafood","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13d7be59-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services, the Secretary of Commerce, the Secretary of Homeland Security, the Chairman of the Federal Trade Commission, and the heads of other appropriate agencies may enter into such agreements as may be necessary or appropriate to improve seafood safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13d7be5a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The agreements under paragraph (1) may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13d7be5b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperative arrangements for examining and testing seafood imports that leverage the resources, capabilities, and authorities of each party to the agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d7be5c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination of inspections of foreign facilities to increase the percentage of imported seafood and seafood facilities inspected;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d7be5d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standardization of data on seafood names, inspection records, and laboratory testing to improve interagency coordination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d7be5e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination to detect and investigate violations under applicable Federal law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d7be5f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a process, including the use or modification of existing processes, by which officers and employees of the National Oceanic and Atmospheric Administration may be duly designated by the Secretary to carry out seafood examinations and investigations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s381"},"text":"section 381 of this title","children":[],"tail":" or section 203 of the Food Allergen Labeling and Consumer Protection Act of 2004;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d7be60-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sharing of information concerning observed non-compliance with United States food requirements domestically and in foreign nations and new regulatory decisions and policies that may affect the safety of food imported into the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d7be61-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting joint training on subjects that affect and strengthen seafood inspection effectiveness by Federal authorities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d7be62-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outreach on Federal efforts to enhance seafood safety and compliance with Federal food safety requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13d7be63-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall improve coordination and cooperation with the Secretary of Agriculture and the Secretary of Homeland Security to target food inspection resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13d7be64-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350j/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “facility” means a domestic facility or a foreign facility that is required to register under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s350d"},"text":"section 350d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id13d7be65-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s421"},"text":"June 25, 1938, ch. 675, § 421","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/353/tII/s201/a"},"text":"Pub. L. 111–353, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3923"},"text":"124 Stat. 3923","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id13d7be66-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id13d7be67-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id13d7be68-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 203 of the Food Allergen Labeling and Consumer Protection Act of 2004, referred to in subsec. (c)(2)(E), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/282/s203"},"text":"section 203 of Pub. L. 108–282","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-02"},"text":"Aug. 2, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/906"},"text":"118 Stat. 906","children":[],"tail":", which amended sections 321, 343, and 343–1 of this title and enacted provisions set out as notes under sections 321 and 343 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id13d7be69-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id13d7be6a-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in this section to be construed to apply to certain alcohol-related facilities, to alter jurisdiction and authorities established under certain other Acts, or in a manner inconsistent with international agreements to which the United States is a party, see sections 2206, 2251, and 2252 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id13d7be6b-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Advisory Committee Consultation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/353/tII/s201/c"},"text":"Pub. L. 111–353, title II, § 201(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3926"},"text":"124 Stat. 3926","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/353/tII/s201/c"},"text":"“In allocating inspection resources as described in section 421 of the Federal Food, Drug, and Cosmetic Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s450j"},"text":"21 U.S.C. 450j","children":[],"tail":"] (as added by subsection (a)), the Secretary may, as appropriate, consult with any relevant advisory committee within the Department of Health and Human Services.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
