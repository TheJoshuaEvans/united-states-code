{"tag":"section","attrib":{"id":"id14d22421-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2104"},"text":null,"children":[{"tag":"num","attrib":{"value":"2104"},"text":"§ 2104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and Federal cooperation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14d22422-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall work with the States in undertaking activities and programs that assist in improving the safety of food, including fresh and processed produce, so that State food safety programs and activities conducted by the Secretary function in a coordinated and cost-effective manner. With the assistance provided under subsection (b), the Secretary shall encourage States to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d22423-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2104/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish, continue, or strengthen State food safety programs, especially with respect to the regulation of retail commercial food establishments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d22424-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2104/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish procedures and requirements for ensuring that processed produce under the jurisdiction of State food safety programs is not unsafe for human consumption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d22425-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide to a State, for planning, developing, and implementing such a food safety program—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d22426-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advisory assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d22427-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance, training, and laboratory assistance (including necessary materials and equipment); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d22428-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2104/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial and other assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d22429-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, under an agreement entered into with a Federal, State, or local agency, use, on a reimbursable basis or otherwise, the personnel, services, and facilities of the agency to carry out the responsibilities of the agency under this section. An agreement entered into with a State agency under this subsection may provide for training of State employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14d2242a-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/85/tX/s1004"},"text":"Pub. L. 110–85, title X, § 1004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/964"},"text":"121 Stat. 964","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
