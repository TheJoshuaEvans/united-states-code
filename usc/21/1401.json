{"tag":"section","attrib":{"id":"id14c1815d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1401"},"text":null,"children":[{"tag":"num","attrib":{"value":"1401"},"text":"§ 1401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pesticide monitoring and enforcement information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14c1815e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1401/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data management systems","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c1815f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1401/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 480 days after ","children":[{"tag":"date","attrib":{"date":"1988-08-23"},"text":"August 23, 1988","children":[],"tail":", the Secretary of Health and Human Services shall place in effect computerized data management systems for the Food and Drug Administration under which the Administration will—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c18160-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1401/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" record, summarize, and evaluate the results of its program for monitoring food products for pesticide residues,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c18161-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1401/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify gaps in its pesticide monitoring program in the monitoring of (i) pesticides, (ii) food products, and (iii) food from specific countries and from domestic sources,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c18162-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1401/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detect trends in the presence of pesticide residues in food products and identify public health problems emerging from the occurrence of pesticide residues in food products,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c18163-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1401/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" focus its testing resources for monitoring pesticide residues in food on detecting those residues which pose a public health concern,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c18164-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1401/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare summaries of the information listed in subsection (b), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c18165-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1401/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information to assist the Environmental Protection Agency in carrying out its responsibilities under the Federal Insecticide, Fungicide, and Rodenticide Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136"},"text":"7 U.S.C. 136","children":[],"tail":" et seq.] and the Federal Food, Drug, and Cosmetic Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"21 U.S.C. 301","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c18166-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1401/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As soon as practicable, the Secretary of Health and Human Services shall develop a means to enable the computerized data management systems placed into effect under paragraph (1) to make the summary described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c18167-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1401/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c18168-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1401/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) does not limit the authority of the Food and Drug Administration to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14c18169-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1401/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the computerized data management systems placed in effect under paragraph (1), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14c1816a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1401/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop additional data management systems,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to facilitate the regulation of any substance or product covered under the requirements of the Federal Food, Drug, and Cosmetic Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"21 U.S.C. 301","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c1816b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1401/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In placing into effect the computerized data management systems under paragraph (1) and in carrying out paragraph (2), the Secretary shall comply with applicable regulations governing computer system design and procurement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c1816c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1401/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Food and Drug Administration shall use the computerized data management systems placed into effect under subsection (a)(1) to prepare a summary of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c1816d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1401/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c1816e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1401/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of imported and domestically produced food products analyzed for compliance with the requirements of the Federal Food, Drug, and Cosmetic Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"21 U.S.C. 301","children":[],"tail":" et seq.] regarding the presence of pesticide residues,"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c1816f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1401/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of samples of each such food product analyzed for such compliance by country of origin,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c18170-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1401/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the pesticide residues which may be detected using the testing methods employed,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c18171-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1401/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the pesticide residues in such food detected and the levels detected,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c18172-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1401/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the compliance status of each sample of such food tested and the violation rate for each country-product combination, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c18173-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1401/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the action taken with respect to each sample of such food found to be in violation of the Federal Food, Drug, and Cosmetic Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"21 U.S.C. 301","children":[],"tail":" et seq.] and its ultimate disposition, and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c18174-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1401/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c18175-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1401/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the country of origin of each imported food product referred to in paragraph (1)(A), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c18176-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1401/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States district of entry for each such imported food product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c18177-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1401/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Volume data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Food and Drug Administration shall use the computerized data management systems placed into effect under subsection (a)(1) to summarize the volume of each type of food product subject to the requirements of the Federal Food, Drug, and Cosmetic Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"21 U.S.C. 301","children":[],"tail":" et seq.] which is imported into the United States and which has an entry value which exceeds an amount established by the Secretary of Health and Human Services. The summary shall be made by country of origin and district of entry. Information with respect to volumes of food products to be included in the summary shall, to the extent feasible, be obtained from data bases of other Federal agencies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c18178-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1401/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compilation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after the expiration of 1 year after the data management systems are placed into effect under subsection (a) and annually thereafter, the Secretary of Health and Human Services shall compile a summary of the information described in subsection (b) with respect to the previous year. When the Food and Drug Administration is able to make summaries under subsection (c), the Secretary shall include in the compilation under the preceding sentence a compilation of the information described in subsection (c). Compilations under this subsection shall be made available to Federal and State agencies and other interested persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14c18179-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tIV/s4702"},"text":"Pub. L. 100–418, title IV, § 4702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1412"},"text":"102 Stat. 1412","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14c1817a-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14c1817b-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14c1817c-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Insecticide, Fungicide, and Rodenticide Act, referred to in subsec. (a)(1)(F), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-06-25/ch125"},"text":"act June 25, 1947, ch. 125","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/92/516"},"text":"Pub. L. 92–516","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-21"},"text":"Oct. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/973"},"text":"86 Stat. 973","children":[],"tail":", which is classified generally to subchapter II (§ 136 et seq.) of chapter 6 of Title 7, Agriculture. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s136"},"text":"section 136 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Food, Drug, and Cosmetic Act, referred to in subsecs. (a) to (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675"},"text":"act June 25, 1938, ch. 675","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1040"},"text":"52 Stat. 1040","children":[],"tail":", which is classified generally to chapter 9 (§ 301 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"section 301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14c1817d-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id14c1817e-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tIV/s4701"},"text":"Pub. L. 100–418, title IV, § 4701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1411"},"text":"102 Stat. 1411","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/418/tIV/s4701"},"text":"“This subtitle [subtitle G (§§ 4701–4704) of title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":", enacting this chapter] may be cited as the ‘Pesticide Monitoring Improvements Act of 1988’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id14c1817f-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Imported Meat, Poultry Products, Eggs, and Egg Products","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tIV/s4506"},"text":"Pub. L. 100–418, title IV, § 4506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1404"},"text":"102 Stat. 1404","children":[],"tail":", required the Secretary of Agriculture, not later than 90 days after "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", to submit a report to Congress concerning the planned distribution, in fiscal years 1988 and 1989, of the resources of the Department of Agriculture available for sampling imported covered products to ensure compliance with the requirements of the Federal Meat Inspection Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s601"},"text":"21 U.S.C. 601","children":[],"tail":" et seq.), the Poultry Products Inspection Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s451"},"text":"21 U.S.C. 451","children":[],"tail":" et seq.), and the Egg Products Inspection Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1031"},"text":"21 U.S.C. 1031","children":[],"tail":" et seq.) that govern the level of residues of pesticides, drugs, and other products permitted in or on such products."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
