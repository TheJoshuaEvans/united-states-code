{"tag":"section","attrib":{"id":"id13a34060-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a"},"text":null,"children":[{"tag":"num","attrib":{"value":"136a"},"text":"§ 136a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of fees for inspection services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id13a34061-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarantine and inspection fees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13a34062-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture may prescribe and collect fees sufficient—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13a34063-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to cover the cost of providing agricultural quarantine and inspection services in connection with the arrival at a port in the customs territory of the United States, or the preclearance or preinspection at a site outside the customs territory of the United States, of an international passenger, commercial vessel, commercial aircraft, commercial truck, or railroad car;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13a34064-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to cover the cost of administering this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13a34065-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through fiscal year 2002, to maintain a reasonable balance in the Agricultural Quarantine Inspection User Fee Account established under paragraph (5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13a34066-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In setting the fees under paragraph (1), the Secretary shall ensure that the amount of the fees is commensurate with the costs of agricultural quarantine and inspection services with respect to the class of persons or entities paying the fees. The costs of the services with respect to passengers as a class includes the costs of related inspections of the aircraft or other vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13a34067-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fees collected under this subsection by any person on behalf of the Secretary are held in trust for the United States and shall be remitted to the Secretary in such manner and at such times as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13a34068-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Late payment penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a person subject to a fee under this subsection fails to pay the fee when due, the Secretary shall assess a late payment penalty, and the overdue fees shall accrue interest, as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3717"},"text":"section 3717 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13a34069-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural Quarantine Inspection User Fee Account","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13a3406a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a fund, to be known as the “Agricultural Quarantine Inspection User Fee Account”, which shall contain all of the fees collected under this subsection and late payment penalties and interest charges collected under paragraph (4) through fiscal year 2002.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13a3406b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of fiscal years 1996 through 2002, funds in the Agricultural Quarantine Inspection User Fee Account shall be available, in such amounts as are provided in advance in appropriations Acts, to cover the costs associated with the provision of agricultural quarantine and inspection services and the administration of this subsection. Amounts made available under this subparagraph shall be available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13a3406c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fees and other amounts collected under this subsection in any of fiscal years 1996 through 2002 in excess of $100,000,000 shall be available for the purposes specified in subparagraph (B) until expended, without further appropriation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13a3406d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of amounts collected after fiscal year 2002","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After ","children":[{"tag":"date","attrib":{"date":"2002-09-30"},"text":"September 30, 2002","children":[],"tail":", the unobligated balance in the Agricultural Quarantine Inspection User Fee Account and fees and other amounts collected under this subsection shall be credited to the Department of Agriculture accounts that incur the costs associated with the provision of agricultural quarantine and inspection services and the administration of this subsection. The fees and other amounts shall remain available to the Secretary until expended without fiscal year limitation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13a3406e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The number of full-time equivalent positions in the Department of Agriculture attributable to the provision of agricultural quarantine and inspection services and the administration of this subsection shall not be counted toward the limitation on the total number of full-time equivalent positions in all agencies specified in section 5(b) of the Federal Workforce Restructuring Act of 1994 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/226"},"text":"Public Law 103–226","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3101"},"text":"5 U.S.C. 3101","children":[],"tail":" note) or other limitation on the total number of full-time equivalent positions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13a3406f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13a34070-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Animal inspection and veterinary diagnostics","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13a34071-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Animal inspection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may prescribe and collect fees to reimburse the Secretary for the cost of carrying out the provisions of the Federal Animal Quarantine Laws that relate to the importation, entry, and exportation of animals, articles, or means of conveyance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13a34072-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veterinary diagnostics","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may prescribe and collect fees to recover the costs of carrying out the provisions of the Animal Health Protection Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8301"},"text":"7 U.S.C. 8301","children":[],"tail":" et seq.] that relate to veterinary diagnostics."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13a34073-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All fees collected pursuant to this subsection and any late payment penalties or accrued interest collected pursuant to this subsection shall be credited to the accounts that incur the cost and shall remain available until expended without fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13a34074-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person for whom an activity related to the importation, entry, or exportation of an animal, article, or means of conveyance or relating to veterinary diagnostics, is performed pursuant to the section, shall be liable for payment of fees assessed. Upon failure to pay such fees when due, the Secretary shall assess a late payment penalty, and such overdue fees shall accrue interest, as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3717"},"text":"section 3717 of title 31","children":[],"tail":". All fees, late payment penalties, and accrued interest collected shall be credited to such accounts that incur the costs and shall remain available until expended without fiscal year limitation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13a34075-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leins ","children":[{"tag":"ref","attrib":{"idref":"fn002000"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002000"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Liens”."}],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13a34076-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall have a lien against the animal, article, means of conveyance, or facility for which services have been provided under this section for the fees, any late payment penalty, and any accrued interest assessed under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13a34077-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other animals, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any person who fails to make payment when due under this subsection, the Secretary shall have a lien against any animal, article, or means of conveyance thereafter imported, moved in interstate commerce, or attempted to be exported by the person after the date of such failure until the date on which such owner or operator make ","children":[{"tag":"ref","attrib":{"idref":"fn002001"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002001"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “makes”."}],"tail":" full payment to the Secretary under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13a34078-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sales of animals, etc.","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id13a34079-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/c/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, if a person does not pay fees, late payment penalties, or accrued interest on such, after providing reasonable notice of default to such person, sell at public sale after reasonable public notice, or otherwise dispose of, any such animal, article, means of conveyance or facility on which the Secretary has a lien under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id13a3407a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/c/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the sale proceeds under clause (i) exceed the fees due, any late payment penalty assessed, any accrued interest on such, and the expenses associated with the sale, such excess shall be paid to the owner of the animal, article, means of conveyance, or facility if such owner submits an application for such excess together with proof of ownership not later than 6 months after the date of such sale. If no such application is made, such excess shall be credited to accounts that incur the costs associated with the fees collected and shall remain available until expended, without fiscal year limitation. The Secretary shall suspend performance of services to persons who have failed to pay fees, late payment penalty, or accrued interest under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13a3407b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may prescribe such regulations as the Secretary determines necessary to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13a3407c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of amounts owed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An action may be brought for the recovery of fees, late payment penalties, and accrued interest which have not been paid in accordance with this section against any person obligated for payment of such assessments under this section in any United States district court or other United States court for any territory or possession in any jurisdiction in which such person is found or resides or transacts business, and such court shall have jurisdiction to hear and decide such action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13a3407d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13a3407e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Animal quarantine laws","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “animal quarantine laws” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13a3407f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 306 of the Tariff Act of 1930 ","children":[{"tag":"ref","attrib":{"idref":"fn002002"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002002"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" See References in Text note below."}],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1306"},"text":"19 U.S.C. 1306","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13a34080-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/act/1890-08-30/s9"},"text":"section 9 of the Act of August 30, 1890","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s101"},"text":"21 U.S.C. 101","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13a34081-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Animal Health Protection Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8301"},"text":"7 U.S.C. 8301","children":[],"tail":" et seq.]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13a34082-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other Act administered by the Secretary relating to plant or animal diseases or pests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13a34083-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Customs territory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of subsection (a), the term “customs territory of the United States” means the 50 States, the District of Columbia, and Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13a34084-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this section, the term “person” means an individual, corporation, partnership, trust, association, or any other public or private entity, or any officer, employee, or agent thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13a34085-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s136a/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"co