{"tag":"section","attrib":{"id":"id1447e4ce-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–3a"},"text":null,"children":[{"tag":"num","attrib":{"value":"379d–3a"},"text":"§ 379d–3a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hiring authority for scientific, technical, and professional personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1447e4cf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–3a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, notwithstanding title 5, governing appointments in the competitive service, appoint outstanding and qualified candidates to scientific, technical, or professional positions, including cross-cutting operational positions, that support the development, review, and regulation of medical products and the regulation of food and cosmetics. Such positions shall be within the competitive service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1447e4d0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–3a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1447e4d1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–3a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, including any requirement with respect to General Schedule pay rates under subchapter III of chapter 53 of title 5, and consistent with the requirements of paragraph (2), the Commissioner of Food and Drugs may determine and set—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1447e4d2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–3a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the annual rate of pay of any individual appointed under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1447e4d3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–3a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of retaining qualified employees, the annual rate of pay for any qualified scientific, technical, or professional personnel appointed to a position described in subsection (a) before ","children":[{"tag":"date","attrib":{"date":"2016-12-13"},"text":"December 13, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1447e4d4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–3a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The annual rate of pay established pursuant to paragraph (1) may not exceed the amount of annual compensation (excluding expenses) specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s102"},"text":"section 102 of title 3","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1447e4d5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–3a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The annual rate of pay provided to an individual in accordance with this section shall be publicly available information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1447e4d6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–3a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authorities under this section shall not be construed to affect the authority provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s379d–3"},"text":"section 379d–3 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1447e4d7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–3a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on workforce planning","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1447e4d8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–3a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", the Secretary shall submit a report on workforce planning to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Energy and Commerce of the House of Representatives that includes—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1447e4d9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–3a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an updated analysis of the workforce needs at the Food and Drug Administration and the Secretary’s strategic plan for addressing such needs, including through use of the authority under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1447e4da-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–3a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of how the Secretary has used the authorities provided under this section, and a plan for how the Secretary will use the authority under this section, and other applicable hiring authorities, for employees of the Food and Drug Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1447e4db-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–3a/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an updated recruitment and retention plan for hiring qualified scientific, technical, and professional candidates, which may include the use of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id1447e4dc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–3a/d/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruitment through nongovernmental recruitment or placement agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1447e4dd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–3a/d/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruitment through academic institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1447e4de-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–3a/d/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruitment or hiring bonuses, if applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1447e4df-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–3a/d/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruitment using targeted direct hiring authorities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1447e4e0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–3a/d/1/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retention of qualified scientific, technical, and professional employees using the authority under this section, or other applicable authorities of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1447e4e1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d–3a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report under paragraph (1) may include the recommendations of the Commissioner of Food and Drugs that would help the Food and Drug Administration to better recruit and retain qualified individuals for scientific, technical, or professional positions at the agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1447e4e2-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s714A"},"text":"June 25, 1938, ch. 675, § 714A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIII/s3072/a"},"text":"Pub. L. 114–255, div. A, title III, § 3072(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1134"},"text":"130 Stat. 1134","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tIII/s3624"},"text":"Pub. L. 117–328, div. FF, title III, § 3624","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5879"},"text":"136 Stat. 5879","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1447e4e3-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1447e4e4-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id1447e4e5-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s3624/1"},"text":"Pub. L. 117–328, § 3624(1)","children":[],"tail":", inserted “, including cross-cutting operational positions,” after “professional positions” and “and the regulation of food and cosmetics” after “medical products”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s3624/2/A"},"text":"Pub. L. 117–328, § 3624(2)(A)","children":[],"tail":", in introductory provisions, substituted “"},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"December 13, 2016","children":[],"tail":"” and “that includes” for “that examines the extent to which the Food and Drug Administration has a critical need for qualified individuals for scientific, technical, or professional positions, including”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s3624/2/B"},"text":"Pub. L. 117–328, § 3624(2)(B)","children":[],"tail":", inserted “updated” before “analysis” and substituted semicolon for “; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s3624/2/D"},"text":"Pub. L. 117–328, § 3624(2)(D)","children":[],"tail":", added subpar. (B). Former subpar. (B) redesignated (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s3624/2/C"},"text":"Pub. L. 117–328, § 3624(2)(C)","children":[],"tail":", (E), redesignated subpar. (B) as (C) and substituted “an updated recruitment” for “a recruitment” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
