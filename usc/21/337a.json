{"tag":"section","attrib":{"id":"id13bfefaf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s337a"},"text":null,"children":[{"tag":"num","attrib":{"value":"337a"},"text":"§ 337a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extraterritorial jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is extraterritorial jurisdiction over any violation of this chapter relating to any article regulated under this chapter if such article was intended for import into the United States or if any act in furtherance of the violation was committed in the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id13bfefb0-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s311"},"text":"June 25, 1938, ch. 675, § 311","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/144/tVII/s718"},"text":"Pub. L. 112–144, title VII, § 718","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1077"},"text":"126 Stat. 1077","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
