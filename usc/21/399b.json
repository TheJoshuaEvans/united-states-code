{"tag":"section","attrib":{"id":"id14811db2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399b"},"text":null,"children":[{"tag":"num","attrib":{"value":"399b"},"text":"§ 399b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Women’s Health","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14811db3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Office of the Commissioner, an office to be known as the Office of Women’s Health (referred to in this section as the “Office”). The Office shall be headed by a director who shall be appointed by the Commissioner of Food and Drugs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14811db4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Office shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14811db5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to the Commissioner of Food and Drugs on current Food and Drug Administration (referred to in this section as the “Administration”) levels of activity regarding women’s participation in clinical trials and the analysis of data by sex in the testing of drugs, medical devices, and biological products across, where appropriate, age, biological, and sociocultural contexts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14811db6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish short-range and long-range goals and objectives within the Administration for issues of particular concern to women’s health within the jurisdiction of the Administration, including, where relevant and appropriate, adequate inclusion of women and analysis of data by sex in Administration protocols and policies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14811db7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information to women and health care providers on those areas in which differences between men and women exist;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14811db8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with pharmaceutical, biologics, and device manufacturers, health professionals with expertise in women’s issues, consumer organizations, and women’s health professionals on Administration policy with regard to women;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14811db9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make annual estimates of funds needed to monitor clinical trials and analysis of data by sex in accordance with needs that are identified; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14811dba-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399b/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as a member of the Department of Health and Human Services Coordinating Committee on Women’s Health (established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s237a/b/4"},"text":"section 237a(b)(4) of title 42","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14811dbb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, there are authorized to be appropriated such sums as may be necessary for each of the fiscal years 2010 through 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14811dbc-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s1011"},"text":"June 25, 1938, ch. 675, § 1011","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIII/s3509/g"},"text":"Pub. L. 111–148, title III, § 3509(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/536"},"text":"124 Stat. 536","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14811dbd-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14811dbe-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id14811dbf-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 1011 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675"},"text":"act June 25, 1938, ch. 675","children":[],"tail":", was enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/111/353/tII/s209/a"},"text":"Pub. L. 111–353, title II, § 209(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3945"},"text":"124 Stat. 3945","children":[],"tail":", and subsequently renumbered section 1012 by "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIII/s3073/b/2"},"text":"Pub. L. 114–255, div. A, title III, § 3073(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1137"},"text":"130 Stat. 1137","children":[],"tail":", and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s399c"},"text":"section 399c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
