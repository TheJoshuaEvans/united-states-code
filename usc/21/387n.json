{"tag":"section","attrib":{"id":"id1479f216-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387n"},"text":null,"children":[{"tag":"num","attrib":{"value":"387n"},"text":"§ 387n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of and coordination with the Federal Trade Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1479f217-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1479f218-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387n/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except where expressly provided in this subchapter, nothing in this subchapter shall be construed as limiting or diminishing the authority of the Federal Trade Commission to enforce the laws under its jurisdiction with respect to the advertising, sale, or distribution of tobacco products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1479f219-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387n/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any advertising that violates this subchapter or a provision of the regulations referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s387a–1"},"text":"section 387a–1 of this title","children":[],"tail":", is an unfair or deceptive act or practice under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s45/a"},"text":"section 45(a) of title 15","children":[],"tail":" and shall be considered a violation of a rule promulgated under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s57a"},"text":"section 57a of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1479f21a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to the requirements of section 4 of the Federal Cigarette Labeling and Advertising Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1333"},"text":"15 U.S.C. 1333","children":[],"tail":"] and section 3 of the Comprehensive Smokeless Tobacco Health Education Act of 1986 ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s4402"},"text":"15 U.S.C. 4402","children":[],"tail":"]—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id147c3b0b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387n/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the Federal Trade Commission shall coordinate with the Secretary concerning the enforcement of such Act as such enforcement relates to unfair or deceptive acts or practices in the advertising of cigarettes or smokeless tobacco; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147c3b0c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387n/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall consult with the Chairman of such Commission in revising the label statements and requirements under such sections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id147c3b0d-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s914"},"text":"June 25, 1938, ch. 675, § 914","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/31/dA/tI/s101/b/3"},"text":"Pub. L. 111–31, div. A, title I, § 101(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-06-22"},"text":"June 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1820"},"text":"123 Stat. 1820","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id147c3b0e-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id147c3b0f-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id147c3b10-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Cigarette Labeling and Advertising Act, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/92"},"text":"Pub. L. 89–92","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-27"},"text":"July 27, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/282"},"text":"79 Stat. 282","children":[],"tail":", which is classified generally to chapter 36 (§ 1331 et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1331"},"text":"section 1331 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Comprehensive Smokeless Tobacco Health Education Act of 1986, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/252"},"text":"Pub. L. 99–252","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-02-27"},"text":"Feb. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/30"},"text":"100 Stat. 30","children":[],"tail":", which is classified principally to chapter 70 (§ 4401 et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s4401"},"text":"section 4401 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
