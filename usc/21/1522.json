{"tag":"section","attrib":{"id":"id14c3cbd6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1522"},"text":null,"children":[{"tag":"num","attrib":{"value":"1522"},"text":"§ 1522.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this subchapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c3cbd7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1522/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce substance use and misuse among youth in communities throughout the United States, and over time, to reduce substance use and misuse among adults;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3cbd8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1522/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to strengthen collaboration among communities, the Federal Government, and State, local, and tribal governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3cbd9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1522/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance intergovernmental cooperation and coordination on the issue of substance use and misuse among youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3cbda-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1522/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to serve as a catalyst for increased citizen participation and greater collaboration among all sectors and organizations of a community that first demonstrates a long-term commitment to reducing substance use and misuse among youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3cbdb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1522/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to rechannel resources from the fiscal year 1998 Federal drug control budget to provide technical assistance, guidance, and financial support to communities that demonstrate a long-term commitment in reducing substance use and misuse among youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3cbdc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1522/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to disseminate to communities timely information regarding the state-of-the-art practices and initiatives that have proven to be effective in reducing substance use and misuse among youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3cbdd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1522/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance, not supplant, local community initiatives for reducing substance use and misuse among youth; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3cbde-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1522/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage the creation of and support for community anti-drug coalitions throughout the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14c3cbdf-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tI/s1022"},"text":"Pub. L. 100–690, title I, § 1022","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/20/s2/a/2"},"text":"Pub. L. 105–20, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-27"},"text":"June 27, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/225"},"text":"111 Stat. 225","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVIII/s8203/b/1"},"text":"Pub. L. 115–271, title VIII, § 8203(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4111"},"text":"132 Stat. 4111","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/74/s2/c/1/A/ii/II"},"text":"Pub. L. 116–74, § 2(c)(1)(A)(ii)(II)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-11-27"},"text":"Nov. 27, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1157"},"text":"133 Stat. 1157","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14c3cbe0-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14c3cbe1-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14c3cbe2-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/74/s2/c/1/A/ii/II"},"text":"Pub. L. 116–74, § 2(c)(1)(A)(ii)(II)","children":[],"tail":", made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8203/b/1"},"text":"Pub. L. 115–271, § 8203(b)(1)","children":[],"tail":". See 2018 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8203/b/1"},"text":"Pub. L. 115–271, § 8203(b)(1)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/74/s2/c/1/A/ii/II"},"text":"Pub. L. 116–74, § 2(c)(1)(A)(ii)(II)","children":[],"tail":", substituted “substance use and misuse” for “substance abuse” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14c3cbe3-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id14c3cbe4-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/74/s2/c/2"},"text":"Pub. L. 116–74, § 2(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-11-27"},"text":"Nov. 27, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1158"},"text":"133 Stat. 1158","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/74/s2/c/2"},"text":"“The amendments made by this subsection [amending this section, sections 1506, 1523, 1524, 1531 to 1533, 1535, 1541 to 1548, and 1705 of this title, and provisions set out as notes under sections 1521, 1524, and 1532 of this title] shall take effect as if included in the enactment of the Substance Abuse Prevention Act of 2018 (subtitle K of title VIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271"},"text":"Public Law 115–271","children":[],"tail":") [see Tables for classification].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
