{"tag":"section","attrib":{"id":"id1434d1c1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5a"},"text":null,"children":[{"tag":"num","attrib":{"value":"360bbb–5a"},"text":"§ 360bbb–5a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emerging technology program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1434d1c2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1434d1c3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program to support the adoption of, and improve the development of, innovative approaches to drug design and manufacturing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d1c4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program under paragraph (1), the Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1434d1c5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate and increase communication between public and private entities, consortia, and individuals with respect to innovative drug product design and manufacturing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1434d1c6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solicit information regarding, and conduct or support research on, innovative approaches to drug product design and manufacturing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1434d1c7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" convene meetings with representatives of industry, academia, other Federal agencies, international agencies, and other interested persons, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1434d1c8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5a/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" convene working groups to support drug product design and manufacturing research and development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1434d1c9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5a/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support education and training for regulatory staff and scientists related to innovative approaches to drug product design and manufacturing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1434d1ca-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5a/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advance regulatory science related to the development and review of innovative approaches to drug product design and manufacturing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1434d1cb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5a/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" convene or participate in working groups to support the harmonization of international regulatory requirements related to innovative approaches to drug product design and manufacturing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1434d1cc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5a/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award grants or contracts to carry out or support the program under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d1cd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants and contracts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To seek a grant or contract under this section, an entity shall submit an application—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1434d1ce-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in such form and manner as the Secretary may require; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1434d1cf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" containing such information as the Secretary may require, including a description of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id1434d1d0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5a/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the entity will conduct the activities to be supported through the grant or contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1434d1d1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5a/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how such activities will further research and development related to, or adoption of, innovative approaches to drug product design and manufacturing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1434d1d2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1434d1d3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue or update guidance to help facilitate the adoption of, and advance the development of, innovative approaches to drug product design and manufacturing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d1d4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include in such guidance descriptions of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1434d1d5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any regulatory requirements related to the development or review of technologies related to innovative approaches to drug product design and manufacturing, including updates and improvements to such technologies after product approval; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1434d1d6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data that can be used to demonstrate the identity, safety, purity, and potency of drugs manufactured using such technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1434d1d7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 4 years after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", the Secretary shall submit to the Committee on Energy and Commerce of the House of Representatives and the Committee on Health, Education, Labor, and Pensions of the Senate a report containing—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id1434d1d8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an annual accounting of the allocation of funds made available to carry out this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d1d9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how Food and Drug Administration staff were utilized to carry out this section and, as applicable, any challenges or limitations related to staffing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d1da-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of public meetings held or participated in by the Food and Drug Administration pursuant to this section, including meetings convened as part of a working group described in subparagraph (D) or (G) of subsection (a)(2), and the topics of each such meeting; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d1db-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–5a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of drug products approved or licensed, after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", using an innovative approach to drug product design and manufacturing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1434d1dc-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s566A"},"text":"June 25, 1938, ch. 675, § 566A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tIII/s3203"},"text":"Pub. L. 117–328, div. FF, title III, § 3203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5814"},"text":"136 Stat. 5814","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
