{"tag":"section","attrib":{"id":"id14b32a20-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s882"},"text":null,"children":[{"tag":"num","attrib":{"value":"882"},"text":"§ 882.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunctions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14b32a21-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s882/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The district courts of the United States and all courts exercising general jurisdiction in the territories and possessions of the United States shall have jurisdiction in proceedings in accordance with the Federal Rules of Civil Procedure to enjoin violations of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14b32a22-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s882/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jury trial","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In case of an alleged violation of an injunction or restraining order issued under this section, trial shall, upon demand of the accused, be by a jury in accordance with the Federal Rules of Civil Procedure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14b32a23-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s882/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State cause of action pertaining to online pharmacies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14b32a24-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s882/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any case in which the State has reason to believe that an interest of the residents of that State has been or is being threatened or adversely affected by the action of a person, entity, or Internet site that violates the provisions of section 823(g), 829(e), or 831 of this title, the State may bring a civil action on behalf of such residents in a district court of the United States with appropriate jurisdiction—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14b32a25-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s882/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enjoin the conduct which violates this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14b32a26-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s882/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enforce compliance with this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14b32a27-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s882/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain damages, restitution, or other compensation, including civil penalties under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s842/b"},"text":"section 842(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14b32a28-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s882/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain such other legal or equitable relief as the court may find appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14b32a29-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s882/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service; intervention","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14b32a2a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s882/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prior to filing a complaint under paragraph (1), the State shall serve a copy of the complaint upon the Attorney General and upon the United States Attorney for the judicial district in which the complaint is to be filed. In any case where such prior service is not feasible, the State shall serve the complaint on the Attorney General and the appropriate United States Attorney on the same day that the State’s complaint is filed in Federal district court of the United States. Such proceedings shall be independent of, and not in lieu of, criminal prosecutions or any other proceedings under this subchapter or any other laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14b32a2b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s882/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon receiving notice respecting a civil action pursuant to this section, the United States shall have the right to intervene in such action and, upon so intervening, to be heard on all matters arising therein, and to file petitions for appeal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14b32a2c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s882/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Service of a State’s complaint on the United States as required in this paragraph shall be made in accord with the requirements of rule 4(i)(1) of the Federal Rule ","children":[{"tag":"ref","attrib":{"idref":"fn002164"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002164"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Rules”."}],"tail":" of Civil Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14b32a2d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s882/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers conferred by State law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of bringing any civil action under paragraph (1), nothing in this chapter shall prevent an attorney general of a State from exercising the powers conferred on the attorney general of a State by the laws of such State to conduct investigations or to administer oaths or affirmations or to compel the attendance of witnesses of or the production of documentary or other evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14b32a2e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s882/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venue","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any civil action brought under paragraph (1) in a district court of the United States may be brought in the district in which the defendant is found, is an inhabitant, or transacts business or wherever venue is proper under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1391"},"text":"section 1391 of title 28","children":[],"tail":". Process in such action may be served in any district in which the defendant is an inhabitant or in which the defendant may be found."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14b32a2f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s882/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No private right of action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No private right of action is created under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14b32a30-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s882/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No civil action may be brought under paragraph (1) against—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14b32a31-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s882/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14b32a32-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s882/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian Tribe or tribal organization, to the extent such tribe or tribal organization is lawfully carrying out a contract or compact under the Indian Self-Determination and Education Assistance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"25 U.S.C. 5301","children":[],"tail":" et seq.]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14b32a33-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s882/c/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any employee of the United States or such Indian tribe or tribal organization, provided such agent or employee is acting in the usual course of business or employment, and within the scope of the official duties of such agent or employee therewith.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14b32a34-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/tII/s512"},"text":"Pub. L. 91–513, title II, § 512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1278"},"text":"84 Stat. 1278","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/425/s3/h"},"text":"Pub. L. 110–425, § 3(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-15"},"text":"Oct. 15, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4830"},"text":"122 Stat. 4830","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/215/tI/s103/b/1/I"},"text":"Pub. L. 117–215, title I, § 103(b)(1)(I)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-02"},"text":"Dec. 2, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2263"},"text":"136 Stat. 2263","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14b32a35-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14b32a36-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14b32a37-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Civil Procedure, referred to in subsecs. (a), (b), and (c)(2)(C), are set out in the Appendix to Title 28, Judiciary and Judicial Procedure.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsecs. (a) and (c)(2)(A), was in the original “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513"},"text":"Pub. L. 91–513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1242"},"text":"84 Stat. 1242","children":[],"tail":", and is popularly known as the “Controlled Substances Act”. For complete classification of title II to the Code, see second paragraph of Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"section 801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c)(3), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513"},"text":"Pub. L. 91–513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1236"},"text":"84 Stat. 1236","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"section 801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act, referred to in subsec. (c)(6)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which is classified principally to chapter 46 (§ 5301 et seq.) of Title 25, Indians. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of Title 25","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14b32a38-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/215"},"text":"Pub. L. 117–215","children":[],"tail":" substituted “823(g)” for “823(f)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/425"},"text":"Pub. L. 110–425","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14b32a39-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id14b32a3a-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/425"},"text":"Pub. L. 110–425","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"2008-10-15"},"text":"Oct. 15, 2008","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/425/s3/j"},"text":"section 3(j) of Pub. L. 110–425","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"section 802 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
