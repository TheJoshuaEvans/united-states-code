text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8202/b/2"},"text":"Pub. L. 115–271, § 8202(b)(2)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s715"},"text":"Pub. L. 105–277, § 715","children":[],"tail":". See 1998 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8202/a"},"text":"Pub. L. 115–271, § 8202(a)","children":[],"tail":", revived and restored this section as in effect on "},{"tag":"date","attrib":{"date":"2003-09-29"},"text":"Sept. 29, 2003","children":[],"tail":", and as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/469"},"text":"Pub. L. 109–469","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/112/166"},"text":"Pub. L. 112–166","children":[],"tail":". See Reauthorization of the Office of National Drug Control Policy note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1701"},"text":"section 1701 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/469"},"text":"Pub. L. 109–469","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s715"},"text":"Pub. L. 105–277, § 715","children":[],"tail":", which provided for the repeal of this section. See 1998 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s715"},"text":"Pub. L. 105–277, § 715","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/469/s602"},"text":"Pub. L. 109–469, § 602","children":[],"tail":", which provided for the repeal of this section effective "},{"tag":"date","attrib":{"date":"2010-09-30"},"text":"Sept. 30, 2010","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8202/b/