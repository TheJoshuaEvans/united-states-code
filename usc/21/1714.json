{"tag":"section","attrib":{"id":"id14cfb2bc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1714"},"text":null,"children":[{"tag":"num","attrib":{"value":"1714"},"text":"§ 1714.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards for demonstration programs by local partnerships to coerce abstinence in chronic hard-drug users under community supervision through the use of drug testing and sanctions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14cfb2bd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1714/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall make competitive awards to fund demonstration programs by eligible partnerships for the purpose of reducing the use of illicit drugs by chronic hard-drug users living in the community while under the supervision of the criminal justice system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14cfb2be-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1714/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of award amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Award amounts received under this section shall be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14cfb2bf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1714/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the efforts of the agencies, organizations, and researchers included in the eligible partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14cfb2c0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1714/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and field a drug testing and graduated sanctions program for chronic hard-drug users living in the community under criminal justice supervision; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14cfb2c1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1714/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist individuals described in subsection (a) by strengthening rehabilitation efforts through such means as job training, drug treatment, or other services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14cfb2c2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1714/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible partnership defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible partnership” means a working group whose application to the Director—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14cfb2c3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1714/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identifies the roles played, and certifies the involvement of, two or more agencies or organizations, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14cfb2c4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1714/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State, local, or tribal agencies (such as those carrying out police, probation, prosecution, courts, corrections, parole, or treatment functions);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14cfb2c5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1714/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal agencies (such as the Drug Enforcement Agency, the Bureau of Alcohol, Tobacco, Firearms, and Explosives, and United States Attorney offices); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14cfb2c6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1714/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community-based organizations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14cfb2c7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1714/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a qualified researcher;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14cfb2c8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1714/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a plan for using judicial or other criminal justice authority to administer drug tests to individuals described in subsection (a) at least twice a week, and to swiftly and certainly impose a known set of graduated sanctions for non-compliance with community-release provisions relating to drug abstinence (whether imposed as a pre-trial, probation, or parole condition or otherwise);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14cfb2c9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1714/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a strategy for responding to a range of substance use and abuse problems and a range of criminal histories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14cfb2ca-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1714/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a plan for integrating data infrastructure among the agencies and organizations included in the eligible partnership to enable seamless, real-time tracking of individuals described in subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14cfb2cb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1714/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a plan to monitor and measure the progress toward reducing the percentage of the population of individuals described in subsection (a) who, upon being summoned for a drug test, either fail to show up or who test positive for drugs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14cfb2cc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1714/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14cfb2cd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1714/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2009-06-01"},"text":"June 1, 2009","children":[],"tail":", the Director shall submit to Congress a report that identifies the best practices in reducing the use of illicit drugs by chronic hard-drug users, including the best practices identified through the activities funded under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14cfb2ce-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1714/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2010-06-01"},"text":"June 1, 2010","children":[],"tail":", the Director shall submit to Congress a report on the demonstration programs funded under this section, including on the matters specified in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14cfb2cf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1714/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $4,900,000 for each of fiscal years 2007 through 2009.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14cfb2d0-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tV