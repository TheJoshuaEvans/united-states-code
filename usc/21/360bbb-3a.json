{"tag":"section","attrib":{"id":"id142ff0af-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a"},"text":null,"children":[{"tag":"num","attrib":{"value":"360bbb–3a"},"text":"§ 360bbb–3a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency use of medical products","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id142ff0b0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id142ff0b1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible product","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible product” means a product that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id142ff0b2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is approved or cleared under this subchapter, conditionally approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360ccc"},"text":"section 360ccc of this title","children":[],"tail":", or licensed under section 351 of the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"42 U.S.C. 262","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142ff0b3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id142ff0b4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is intended for use to prevent, diagnose, or treat a disease or condition involving a biological, chemical, radiological, or nuclear agent or agents; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id142ff0b5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is intended for use to prevent, diagnose, or treat a serious or life-threatening disease or condition caused by a product described in clause (i); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142ff0b6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is intended for use during the circumstances under which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id142ff0b7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a determination described in subparagraph (A), (B), or (C) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360bbb–3/b/1"},"text":"section 360bbb–3(b)(1) of this title","children":[],"tail":" has been made by the Secretary of Homeland Security, the Secretary of Defense, or the Secretary, respectively; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id142ff0b8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of a material threat described in subparagraph (D) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360bbb–3/b/1"},"text":"section 360bbb–3(b)(1) of this title","children":[],"tail":" has been made pursuant to section 319F–2 of the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–6b"},"text":"42 U.S.C. 247d–6b","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142ff0b9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Product","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “product” means a drug, device, or biological product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id142ff0ba-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expiration dating","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id142ff0bb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may extend the expiration date and authorize the introduction or delivery for introduction into interstate commerce of an eligible product after the expiration date provided by the manufacturer if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id142ff0bc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the expiration date extension is intended to support the United States ability to protect—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id142ff0bd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public health; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id142ff0be-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" military preparedness and effectiveness; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142ff0bf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expiration date extension is supported by an appropriate scientific evaluation that is conducted or accepted by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142ff0c0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements and conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any extension of an expiration date under paragraph (1) shall, as part of the extension, identify—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id142ff0c1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each specific lot, batch, or other unit of the product for which extended expiration is authorized;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142ff0c2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the duration of the extension; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142ff0c3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other requirements or conditions as the Secretary may deem appropriate for the protection of the public health, which may include requirements for, or conditions on, product sampling, storage, packaging or repackaging, transport, labeling, notice to product recipients, recordkeeping, periodic testing or retesting, or product disposition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142ff0c4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this chapter or the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"42 U.S.C. 201","children":[],"tail":" et seq.], an eligible product shall not be considered an unapproved product (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360bbb–3/a/2/A"},"text":"section 360bbb–3(a)(2)(A) of this title","children":[],"tail":") and shall not be deemed adulterated or misbranded under this chapter because, with respect to such product, the Secretary has, under paragraph (1), extended the expiration date and authorized the introduction or delivery for introduction into interstate commerce of such product after the expiration date provided by the manufacturer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142ff0c5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expiration date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “expiration date” means the date established through appropriate stability testing required by the regulations issued by the Secretary to ensure that the product meets applicable standards of identity, strength, quality, and purity at the time of use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id142ff0c6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Current good manufacturing practice","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id142ff0c7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, when the circumstances of a domestic, military, or public health emergency or material threat described in subsection (a)(1)(C) so warrant, authorize, with respect to an eligible product, deviations from current good manufacturing practice requirements otherwise applicable to the manufacture, processing, packing, or holding of products subject to regulation under this chapter, including requirements under section 351 or 360j(f)(1) of this title or applicable conditions prescribed with respect to the eligible product by an order under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360j/f/2"},"text":"section 360j(f)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142ff0c8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this chapter or the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"42 U.S.C. 201","children":[],"tail":" et seq.], an eligible product shall not be considered an unapproved product (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360bbb–3/a/2/A"},"text":"section 360bbb–3(a)(2)(A) of this title","children":[],"tail":") and shall not be deemed adulterated or misbranded under this chapter because, with respect to such product, the Secretary has authorized deviations from current good manufacturing practices under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id142ff0c9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency dispensing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements of subsections (b) and (f) of section 353, section 354, and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360j/e"},"text":"section 360j(e) of this title","children":[],"tail":" shall not apply to an eligible product, and the product shall not be considered an unapproved product (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360bbb–3/a/2/A"},"text":"section 360bbb–3(a)(2)(A) of this title","children":[],"tail":") and shall not be deemed adulterated or misbranded under this chapter because it is dispensed without an individual prescription, if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id142ff0ca-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the product is dispensed during the circumstances described in subsection (a)(1)(C); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142ff0cb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such dispensing without an individual prescription occurs—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id142ff0cc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as permitted under the law of the State in which the product is dispensed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142ff0cd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with an order issued by the Secretary, for the purposes and duration of the circumstances described in subsection (a)(1)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id142ff0ce-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency use instructions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id142ff0cf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through an appropriate official within the Department of Health and Human Services, may create and issue emergency use instructions to inform health care providers or individuals to whom an eligible product is to be administered concerning such product’s approved, licensed, or cleared conditions of use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142ff0d0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provisions of this chapter or the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"42 U.S.C. 201","children":[],"tail":" et seq.], a product shall not be considered an unapproved product and shall not be deemed adulterated or misbranded under this chapter because of the issuance of emergency use instructions under paragraph (1) with respect to such product or the introduction or delivery for introduction of such product into interstate commerce accompanied by such instructions—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id142ff0d1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during an emergency response to an actual emergency that is the basis for a determination described in subsection (a)(1)(C); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142ff0d2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–3a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a government entity (including a Federal, State, local, or tribal government entity), or a person acting on behalf of such a government entity, in preparation for an emergency response.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id142ff0d3-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s564A"},"text":"June 25, 1938, ch. 675, § 564A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/5/tIII/s302/b"},"text":"Pub. L. 113–5, title III, § 302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-13"},"text":"Mar. 13, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/183"},"text":"127 Stat. 183","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIII/s3088/c"},"text":"Pub. L. 114–255, div. A, title III, § 3088(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1149"},"text":"130 Stat. 1149","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/22/tVII/s705/c"},"text":"Pub. L. 116–22, title VII, § 705(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-06-24"},"text":"June 24, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/964"},"text":"133 Stat. 964","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id143260d4-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id143260d5-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id143260d6-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Public Health Service Act, referred to in subsecs. (b)(3), (c)(2), and (e)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"act July 1, 1944, ch. 373","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/682"},"text":"58 Stat. 682","children":[],"tail":", which is classified generally to chapter 6A (§ 201 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id143260d7-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (e)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22"},"text":"Pub. L. 116–22","children":[],"tail":" substituted “subsection (a)(1)(C)” for “subsection (a)(1)(C)(i)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s3088/c/1"},"text":"Pub. L. 114–255, § 3088(c)(1)","children":[],"tail":", inserted “, conditionally approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360ccc"},"text":"section 360ccc of this title","children":[],"tail":",” after “subchapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s3088/c/2"},"text":"Pub. L. 114–255, § 3088(c)(2)","children":[],"tail":", substituted “subsections (b) and (f) of section 353, section 354, and "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360j/e"},"text":"section 360j(e) of this title","children":[],"tail":"” for “sections 353(b) and 360j(e) of this title” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
