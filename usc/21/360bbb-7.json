{"tag":"section","attrib":{"id":"id1434d1ec-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"360bbb–7"},"text":"§ 360bbb–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1434d1ed-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a drug, the Secretary may require notification to the Secretary by a regulated person if the regulated person knows—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1434d1ee-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–7/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the use of such drug in the United States may result in serious injury or death;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d1ef-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–7/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of a significant loss or known theft of such drug intended for use in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d1f0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–7/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1434d1f1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–7/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such drug has been or is being counterfeited; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1434d1f2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–7/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id1434d1f3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–7/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the counterfeit product is in commerce in the United States or could be reasonably expected to be introduced into commerce in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1434d1f4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–7/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such drug has been or is being imported into the United States or may reasonably be expected to be offered for import into the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1434d1f5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner of notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notification under this section shall be made in such manner and by such means as the Secretary may specify by regulation or guidance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1434d1f6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–7/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings clause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as limiting any other authority of the Secretary to require notifications related to a drug under any other provision of this chapter or the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"42 U.S.C. 201","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1434d1f7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–7/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “regulated person” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1434d1f8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–7/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person who is required to register under section 360 or 381(s) of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d1f9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–7/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a wholesale distributor of a drug product; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d1fa-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–7/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other person that distributes drugs except a person that distributes drugs exclusively for retail sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1434d1fb-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s568"},"text":"June 25, 1938, ch. 675, § 568","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/144/tVII/s715/b"},"text":"Pub. L. 112–144, title VII, § 715(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1075"},"text":"126 Stat. 1075","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1434d1fc-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1434d1fd-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id1434d1fe-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Public Health Service Act, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"act July 1, 1944, ch. 373","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/682"},"text":"58 Stat. 682","children":[],"tail":", which is classified generally to chapter 6A (§ 201 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
