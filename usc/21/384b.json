{"tag":"section","attrib":{"id":"id1472c508-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384b"},"text":null,"children":[{"tag":"num","attrib":{"value":"384b"},"text":"§ 384b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary qualified importer program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1472c509-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"January 4, 2011","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id1472c50a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish a program, in consultation with the Secretary of Homeland Security—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1472c50b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for the expedited review and importation of food offered for importation by importers who have voluntarily agreed to participate in such program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1472c50c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s384d"},"text":"section 384d of this title","children":[],"tail":", establish a process for the issuance of a facility certification to accompany food offered for importation by importers who have voluntarily agreed to participate in such program; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1472c50d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue a guidance document related to participation in, revocation of such participation in, reinstatement in, and compliance with, such program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1472c50e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An importer may request the Secretary to provide for the expedited review and importation of designated foods in accordance with the program established by the Secretary under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1472c50f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of intent to participate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An importer that intends to participate in the program under this section in a fiscal year shall submit a notice and application to the Secretary of such intent at the time and in a manner established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1472c510-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Eligibility shall be limited to an importer offering food for importation from a facility that has a certification described in subsection (a). In reviewing the applications and making determinations on such applications, the Secretary shall consider the risk of the food to be imported based on factors, such as the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1472c511-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The known safety risks of the food to be imported.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1472c512-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The compliance history of foreign suppliers used by the importer, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1472c513-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The capability of the regulatory system of the country of export to ensure compliance with United States food safety standards for a designated food.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1472c514-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384b/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The compliance of the importer with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s384a"},"text":"section 384a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1472c515-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384b/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The recordkeeping, testing, inspections and audits of facilities, traceability of articles of food, temperature controls, and sourcing practices of the importer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1472c516-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384b/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The potential risk for intentional adulteration of the food.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1472c517-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384b/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other factor that the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1472c518-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and revocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any importer qualified by the Secretary in accordance with the eligibility criteria set forth in this section shall be reevaluated not less often than once every 3 years and the Secretary shall promptly revoke the qualified importer status of any importer found not to be in compliance with such criteria.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1472c519-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False statements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any statement or representation made by an importer to the Secretary shall be subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1001"},"text":"section 1001 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1472c51a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “importer” means the person that brings food, or causes food to be brought, from a foreign country into the customs territory of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1472c51b-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s806"},"text":"June 25, 1938, ch. 675, § 806","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/353/tIII/s302"},"text":"Pub. L. 111–353, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3955"},"text":"124 Stat. 3955","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1472c51c-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1472c51d-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id1472c51e-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in this section to be construed to alter jurisdiction and authorities established under certain other Acts or in a manner inconsistent with international agreements to which the United States is a party, see sections 2251 and 2252 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
