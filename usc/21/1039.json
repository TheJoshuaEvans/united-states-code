{"tag":"section","attrib":{"id":"id14bc9fb2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1039"},"text":null,"children":[{"tag":"num","attrib":{"value":"1039"},"text":"§ 1039.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eggs and egg products not intended for use as human food; inspection; denaturing or otherwise identifying","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Inspection shall not be provided under this chapter at any plant for the processing of any egg products which are not intended for use as human food, but such articles, prior to their offer for sale or transportation in commerce, shall be denatured or otherwise identified as prescribed by regulations of the Secretary to deter their use for human food. No person shall buy, sell, or transport or offer to buy or sell, or offer or receive for transportation, in commerce, any restricted eggs or egg products which are not intended for use as human food unless they are denatured or otherwise identified as required by the regulations of the Secretary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id14bc9fb3-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/597/s10"},"text":"Pub. L. 91–597, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-29"},"text":"Dec. 29, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1627"},"text":"84 Stat. 1627","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14bc9fb4-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14bc9fb5-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14bc9fb6-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/597"},"text":"Pub. L. 91–597","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-29"},"text":"Dec. 29, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1620"},"text":"84 Stat. 1620","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1031"},"text":"section 1031 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14bc9fb7-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id14bc9fb8-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/597/s29"},"text":"section 29 of Pub. L. 91–597","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1031"},"text":"section 1031 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
