{"tag":"section","attrib":{"id":"id14050f1f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356c–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"356c–1"},"text":"§ 356c–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reporting on drug shortages","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14050f20-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356c–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than March 31 of each calendar year, the Secretary shall submit to the Committee on Energy and Commerce of the House of Representatives and the Committee on Health, Education, Labor, and Pensions of the Senate a report, with respect to the preceding calendar year, on drug shortages that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14050f21-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356c–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifies the number of manufacturers that submitted a notification to the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s356c/a"},"text":"section 356c(a) of this title","children":[],"tail":" during such calendar year;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14050f22-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356c–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the communication between the field investigators of the Food and Drug Administration and the staff of the Center for Drug Evaluation and Research’s Office of Compliance and Drug Shortage Program, including the Food and Drug Administration’s procedures for enabling and ensuring such communication;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14050f23-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356c–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the coordination and alignment activities undertaken pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s356d/g"},"text":"section 356d(g) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14050f24-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356c–1/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides the number of reports that were required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s374/b/2"},"text":"section 374(b)(2) of this title","children":[],"tail":" to be sent to the appropriate offices of the Food and Drug Administration with expertise regarding drug shortages, and the number of such reports that were sent;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14050f25-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356c–1/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14050f26-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356c–1/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lists the major actions taken by the Secretary to prevent or mitigate the drug shortages described in paragraph (9);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14050f27-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356c–1/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the list under subparagraph (A), includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14050f28-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356c–1/a/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of applications and supplements for which the Secretary expedited review under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s356c/g/1"},"text":"section 356c(g)(1) of this title","children":[],"tail":" during such calendar year; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14050f29-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356c–1/a/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of establishment inspections or reinspections that the Secretary expedited under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s356c/g/2"},"text":"section 356c(g)(2) of this title","children":[],"tail":" during such calendar year;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14050f2a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356c–1/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the coordination between the Food and Drug Administration and the Drug Enforcement Administration on efforts to prevent or alleviate drug shortages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14050f2b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356c–1/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the number of and describes the instances in which the Food and Drug Administration exercised regulatory flexibility and discretion to prevent or alleviate a drug shortage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14050f2c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356c–1/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lists the names of manufacturers that were issued letters under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s356c/f"},"text":"section 356c(f) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14050f2d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356c–1/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifies the number of drug shortages occurring during such calendar year, as identified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14050f2e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356c–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trend analysis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to retain a third party to conduct a study, if the Secretary believes such a study would help clarify the causes, trends, or solutions related to drug shortages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14050f2f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356c–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “drug shortage” or “shortage” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s356c"},"text":"section 356c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14050f30-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s506C–1"},"text":"June 25, 1938, ch. 675, § 506C–1","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/144/tX/s1002"},"text":"Pub. L. 112–144, title X, § 1002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1102"},"text":"126 Stat. 1102","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIII/s3101/a/2/F"},"text":"Pub. L. 114–255, div. A, title III, § 3101(a)(2)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1153"},"text":"130 Stat. 1153","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tIII/s3616/b/1"},"text":"Pub. L. 117–328, div. FF, title III, § 3616(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5875"},"text":"136 Stat. 5875","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14050f31-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14050f32-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14050f33-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s3616/b/1/A"},"text":"Pub. L. 117–328, § 3616(b)(1)(A)","children":[],"tail":", (B), added pars. (3) and (4) and redesignated former par. (3) as (5). Former pars. (4) and (5) redesignated (6) and (7), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s3616/b/1/C"},"text":"Pub. L. 117–328, § 3616(b)(1)(C)","children":[],"tail":", substituted “paragraph (9)” for “paragraph (7)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s3616/b/1/A"},"text":"Pub. L. 117–328, § 3616(b)(1)(A)","children":[],"tail":", redesignated pars. (4) to (7) as (6) to (9), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","children":[],"tail":", in introductory provisions, substituted “Not later than March 31 of each calendar year,” for “Not later than the end of calendar year 2013, and not later than the end of each calendar year thereafter,” and inserted “, with respect to the preceding calendar year,” after “a report”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14050f34-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id14050f35-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tIII/s3616/b/2"},"text":"Pub. L. 117–328, div. FF, title III, § 3616(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5875"},"text":"136 Stat. 5875","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dFF/tIII/s3616/b/2"},"text":"“The amendments made by paragraph (1) [amending this section] shall apply with respect to reports submitted under section 506C–1 of the Federal Food, Drug, and Cosmetic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s356c–1"},"text":"21 U.S.C. 356c–1","children":[],"tail":") on or after "},{"tag":"date","attrib":{"date":"2024-03-31"},"text":"March 31, 2024","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
