tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/144/tIII/s304/a"},"text":"Pub. L. 112–144, title III, § 304(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1024"},"text":"126 Stat. 1024","children":[],"tail":", which provided that this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s379j–42"},"text":"section 379j–42 of this title","children":[],"tail":" would cease to be effective "},{"tag":"date","attrib":{"date":"2017-10-01"},"text":"Oct. 1, 2017","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/52/tIII/s305/c/1"},"text":"Pub. L. 115–52, title III, § 305(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-18"},"text":"Aug. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1027"},"text":"131 Stat. 1027","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/52/tIII/s305/c/1"},"text":"Pub. L. 115–52, title III, § 305(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-18"},"text":"Aug. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1027"},"text":"131 Stat. 1027","children":[],"tail":", provided that the repeal of "},{"tag":"ref","attrib":{"href":"/us/pl/112/144/s304/a"},"text":"section 304(a) of Pub. L. 112–144","children":[],"tail":", formerly set out above, is effective "},{"tag":"date","attrib":{"date":"2017-10-01"},"text":"Oct. 1, 2017","children":[],"tail":".]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/144/tIII/s305"},"text":"Pub. L. 112–144, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1024"},"text":"126 Stat. 1024","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/144/tIII/s305"},"text":"“The amendments made by this title [enacting this section and sections 379d–4, 379j–42, and 379j–43 of this title and amending sections 352 and 379d–3 of this title] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2012-10-01"},"text":"October 1, 2012","children":[],"tail":", or the date of the enactment of this title ["},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":"], whichever is later, except that fees under section 302 [enacting this section and sections 379j–42 and 379j–43 of this title] shall be assessed for all human generic drug submissions and Type II active pharmaceutical drug master files received on or after "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"October 1, 2012","children":[],"tail":", regardless of the date of enactment of this title.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"id145d41e8-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Clause","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/180/dF/tIII/s3006"},"text":"Pub. L. 117–180, div. F, title III, § 3006","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-09-30"},"text":"Sept. 30, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2159"},"text":"136 Stat. 2159","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/180/dF/tIII/s3006"},"text":"“Notwithstanding the amendments made by this title [amending sections 379j–42 and 379j–43 of this title and repealing provisions set out as notes under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s379j–43"},"text":"section 379j–43 of this title","children":[],"tail":"], part 7 of subchapter C of chapter VII of the Federal Food, Drug, and Cosmetic Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s379j–41"},"text":"21 U.S.C. 379j–41","children":[],"tail":" et seq.), as in effect on the day before the date of the enactment of this title ["},{"tag":"date","attrib":{"date":"2022-09-30"},"text":"Sept. 30, 2022","children":[],"tail":"], shall continue to be in effect with respect to abbreviated new drug applications (as defined in such part as of such day) that were received by the Food and Drug Administration within the meaning of section 505(j)(5)(A) of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/j/5/A"},"text":"21 U.S.C. 355(j)(5)(A)","children":[],"tail":"), prior approval supplements that were submitted, and drug master files for Type II active pharmaceutical ingredients that were first referenced on or after "},{"tag":"date","attrib":{"date":"2017-10-01"},"text":"October 1, 2017","children":[],"tail":", but before "},{"tag":"date","attrib":{"date":"2022-10-01"},"text":"October 1, 2022","children":[],"tail":", with respect to assessing and collecting any fee required by such part for a fiscal year prior to fiscal year 2023.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/52/tIII/s307"},"text":"Pub. L. 115–52, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-18"},"text":"Aug. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1027"},"text":"131 Stat. 1027","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/52/tIII/s307"},"text":"“Notwithstanding the amendments made by this title [amending this section and sections 379j–42 and 379j–43 of this title and repealing provisions set out as notes under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s379j–43"},"text":"section 379j–43 of this title","children":[],"tail":"], part 7 of subchapter C of chapter VII of the Federal Food, Drug, and Cosmetic Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t21/s379j–41"},"text":"21 U.S.C. 379j–41","children":[],"tail":" et seq.], as in effect on the day before the date of the enactment of this title ["},{"tag":"date","attrib":{"date":"2017-08-18"},"text":"Aug. 18, 2017","children":[],"tail":"], shall continue to be in effect with respect to abbreviated new drug applications (as defined in such part as of such day) that were received by the Food and Drug Administration within the meaning of section 505(j)(5)(A) of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/j/5/A"},"text":"21 U.S.C. 355(j)(5)(A)","children":[],"tail":"), prior approval supplements that were submitted, and drug master files for Type II active pharmaceutical ingredients that were first referenced on or after "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"October 1, 2012","children":[],"tail":", but before "},{"tag":"date","attrib":{"date":"2017-10-01"},"text":"October 1, 2017","children":[],"tail":", with respect to assessing and collecting any fee required by such part for a fiscal year prior to fiscal year 2018.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id145fb2e9-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings Concerning Fees Relating to Human Generic Drugs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/180/dF/tIII/s3001/b"},"text":"Pub. L. 117–180, div. F, title III, § 3001(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-09-30"},"text":"Sept. 30, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2155"},"text":"136 Stat. 2155","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/180/dF/tIII/s3001/b"},"text":"“Congress finds that the fees authorized by the amendments made by this title [amending sections 379j–42 and 379j–43 of this title and repealing provisions set out as notes under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s379j–43"},"text":"section 379j–43 of this title","children":[],"tail":"] will be dedicated to human generic drug activities, as set forth in the goals identified for purposes of part 7 of subchapter C of chapter VII of the Federal Food, Drug, and Cosmetic Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s379j–41"},"text":"21 U.S.C. 379j–41","children":[],"tail":" et seq.), in the letters from the Secretary of Health and Human Services to the Chairman of the Committee on Health, Education, Labor, and Pensions of the Senate and the Chairman of the Committee on Energy and Commerce of the House of Representatives, as set forth in the Congressional Record.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/52/tIII/s301/b"},"text":"Pub. L. 115–52, title III, § 301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-18"},"text":"Aug. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1020"},"text":"131 Stat. 1020","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/52/tIII/s301/b"},"text":"“The Congress finds that the fees authorized by the amendments made in this title [amending this section and sections 379j–42 and 379j–43 of this title and repealing provisions set out as notes under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s379j–43"},"text":"section 379j–43 of this title","children":[],"tail":"] will be dedicated to human generic drug activities, as set forth in the goals identified for purposes of part 7 of subchapter C of chapter VII of the Federal Food, Drug, and Cosmetic Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t21/s379j–41"},"text":"21 U.S.C. 379j–41","children":[],"tail":" et seq.], in the letters from the Secretary of Health and Human Services to the Chairman of the Committee on Health, Education, Labor, and Pensions of the Senate and the Chairman of the Committee on Energy and Commerce of the House of Representatives, as set forth in the Congressional Record.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/144/tIII/s301/b"},"text":"Pub. L. 112–144, title III, § 301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1008"},"text":"126 Stat. 1008","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/144/tIII/s301/b"},"text":"“The Congress finds that the fees authorized by the amendments made in this title [enacting this section and sections 379d–4, 379j–42, and 379j–43 of this title and amending sections 352 and 379d–3 of this title] will be dedicated to human generic drug activities, as set forth in the goals identified for purposes of part 7 of subchapter C of chapter VII of the Federal Food, Drug, and Cosmetic Act [this subpart], in the letters from the Secretary of Health and Human Services to the Chairman of the Committee on Health, Education, Labor, and Pensions of the Senate and the Chairman of the Committee on Energy and Commerce of the House of Representatives, as set forth in the Congressional Record.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
