{"tag":"section","attrib":{"id":"id145d41a5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41"},"text":null,"children":[{"tag":"num","attrib":{"value":"379j–41"},"text":"§ 379j–41.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subpart:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id145d41a6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “abbreviated new drug application”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id145d41a7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means an application submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/j"},"text":"section 355(j) of this title","children":[],"tail":", an abbreviated application submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s357"},"text":"section 357 of this title","children":[],"tail":" (as in effect on the day before "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"November 21, 1997","children":[],"tail":"), or an abbreviated new drug application submitted pursuant to regulations in effect prior to the implementation of the Drug Price Competition and Patent Term Restoration Act of 1984; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d41a8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include an application—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id145d41a9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a positron emission tomography drug; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id145d41aa-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submitted by a State or Federal governmental entity for a drug that is not distributed commercially.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id145d41ab-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “active pharmaceutical ingredient” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id145d41ac-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a substance, or a mixture when the substance is unstable or cannot be transported on its own, intended—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id145d41ad-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be used as a component of a drug; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id145d41ae-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to furnish pharmacological activity or other direct effect in the diagnosis, cure, mitigation, treatment, or prevention of disease, or to affect the structure or any function of the human body; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d41af-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a substance intended for final crystallization, purification, or salt formation, or any combination of those activities, to become a substance or mixture described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id145d41b0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “adjustment factor” means a factor applicable to a fiscal year that is the Consumer Price Index for all urban consumers (all items; United States city average) for October of the preceding fiscal year divided by such Index for October 2011.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id145d41b1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “affiliate” means a business entity that has a relationship with a second business entity if, directly or indirectly—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id145d41b2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one business entity controls, or has the power to control, the other business entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d41b3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a third party controls, or has power to control, both of the business entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id145d41b4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “contract manufacturing organization facility” means a manufacturing facility of a finished dosage form of a drug approved pursuant to an abbreviated new drug application, where such manufacturing facility is not identified in an approved abbreviated new drug application held by the owner of such facility or an affiliate of such owner or facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id145d41b5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id145d41b6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “facility”—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id145d41b7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means a business or other entity—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id145d41b8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/6/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under one management, either direct or indirect; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id145d41b9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/6/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at one geographic location or address engaged in manufacturing or processing an active pharmaceutical ingredient or a finished dosage form; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id145d41ba-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include a business or other entity whose only manufacturing or processing activities are one or more of the following: repackaging, relabeling, or testing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d41bb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of subparagraph (A), separate buildings within close proximity are considered to be at one geographic location or address if the activities in them are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id145d41bc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" closely related to the same business enterprise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id145d41bd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the supervision of the same local management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id145d41be-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/6/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capable of being inspected by the Food and Drug Administration during a single inspection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d41bf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a business or other entity would meet the definition of a facility under this paragraph but for being under multiple management, the business or other entity is deemed to constitute multiple facilities, one per management entity, for purposes of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id145d41c0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “finished dosage form” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id145d41c1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a drug product in the form in which it will be administered to a patient, such as a tablet, capsule, solution, or topical application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d41c2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a drug product in a form in which reconstitution is necessary prior to administration to a patient, such as oral suspensions or lyophilized powders; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d41c3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any combination of an active pharmaceutical ingredient with another component of a drug product for purposes of production of a drug product described in subparagraph (A) or (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id145d41c4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “generic drug submission” means an abbreviated new drug application, an amendment to an abbreviated new drug application, or a prior approval supplement to an abbreviated new drug application.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id145d41c5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “human generic drug activities” means the following activities of the Secretary associated with generic drugs and inspection of facilities associated with generic drugs:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id145d41c6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The activities necessary for the review of generic drug submissions, including review of drug master files referenced in such submissions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d41c7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The issuance of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id145d41c8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/9/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approval letters which approve abbreviated new drug applications or supplements to such applications; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id145d41c9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/9/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete response letters which set forth in detail the specific deficiencies in such applications and, where appropriate, the actions necessary to place such applications in condition for approval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d41ca-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The issuance of letters related to Type II active pharmaceutical drug master files which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id145d41cb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/9/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth in detail the specific deficiencies in such submissions, and where appropriate, the actions necessary to resolve those deficiencies; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id145d41cc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/9/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" document that no deficiencies need to be addressed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d41cd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Inspections related to generic drugs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d41ce-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/9/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Monitoring of research conducted in connection with the review of generic drug submissions and drug master files.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d41cf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/9/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Postmarket safety activities with respect to drugs approved under abbreviated new drug applications or supplements, including the following activities:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id145d41d0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/9/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Collecting, developing, and reviewing safety information on approved drugs, including adverse event reports.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id145d41d1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/9/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing and using improved adverse-event data-collection systems, including information technology systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id145d41d2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/9/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing and using improved analytical tools to assess potential safety problems, including access to external data bases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id145d41d3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/9/F/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Implementing and enforcing section 355(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of this title (relating to postapproval studies and clinical trials and labeling changes) and "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/p"},"text":"section 355(p) of this title","children":[],"tail":" (relating to risk evaluation and mitigation strategies) insofar as those activities relate to abbreviated new drug applications."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id145d41d4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/9/F/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/k/5"},"text":"section 355(k)(5) of this title","children":[],"tail":" (relating to adverse-event reports and postmarket safety activities)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d41d5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/9/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Regulatory science activities related to generic drugs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id145d41d6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “positron emission tomography drug” has the meaning given to the term “compounded positron emission tomography drug” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s321/ii"},"text":"section 321(ii) of this title","children":[],"tail":", except that paragraph (1)(B) of such section shall not apply."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id145d41d7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “prior approval supplement” means a request to the Secretary to approve a change in the drug substance, drug product, production process, quality controls, equipment, or facilities covered by an approved abbreviated new drug application when that change has a substantial potential to have an adverse effect on the identity, strength, quality, purity, or potency of the drug product as these factors may relate to the safety or effectiveness of the drug product.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id145d41d8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “resources allocated for human generic drug activities” means the expenses for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id145d41d9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" officers and employees of the Food and Drug Administration, contractors of the Food and Drug Administration, advisory committees, and costs related to such officers and employees and to contracts with such contractors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d41da-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" management of information, and the acquisition, maintenance, and repair of computer resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d41db-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/12/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leasing, maintenance, renovation, and repair of facilities and acquisition, maintenance, and repair of fixtures, furniture, scientific equipment, and other necessary materials and supplies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d41dc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/12/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collecting fees under subsection (a) and accounting for resources allocated for the review of abbreviated new drug applications and supplements and inspection related to generic drugs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id145d41dd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–41/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Type II active pharmaceutical ingredient drug master file” means a submission of information to the Secretary by a person that intends to authorize the Food and Drug Administration to reference the information to support approval of a generic drug submission without the submitter having to disclose the information to the generic drug submission applicant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id145d41de-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s744A"},"text":"June 25, 1938, ch. 675, § 744A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/144/tIII/s302"},"text":"Pub. L. 112–144, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1008"},"text":"126 Stat. 1008","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/52/tIII/s302"},"text":"Pub. L. 115–52, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-18"},"text":"Aug. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1020"},"text":"131 Stat. 1020","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id145d41df-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id145d41e0-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/180/s3004/a"},"text":"section 3004(a) of Pub. L. 117–180","children":[],"tail":", see Effective and Termination Dates note set out below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id145d41e1-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id145d41e2-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s357"},"text":"Section 357 of this title","children":[],"tail":", referred to in par. (1)(A), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/105/115/tI/s125/b/1"},"text":"Pub. L. 105–115, title I, § 125(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2325"},"text":"111 Stat. 2325","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Drug Price Competition and Patent Term Restoration Act of 1984, referred to in par. (1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/417"},"text":"Pub. L. 98–417","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-09-24"},"text":"Sept. 24, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1585"},"text":"98 Stat. 1585","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1984 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"section 301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id145d41e3-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Par. (1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/52/s302/1"},"text":"Pub. L. 115–52, § 302(1)","children":[],"tail":", substituted “application—” for “application for a positron emission tomography drug.” and added cls. (i) and (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (5) to (13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/52/s302/2"},"text":"Pub. L. 115–52, § 302(2)","children":[],"tail":", (3), added par. (5) and redesignated former pars. (5) to (12) as (6) to (13), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id145d41e4-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id145d41e5-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/180/dF/tIII/s300