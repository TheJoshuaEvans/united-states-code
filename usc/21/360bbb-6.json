{"tag":"section","attrib":{"id":"id1434d1dd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"360bbb–6"},"text":"§ 360bbb–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Risk communication","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1434d1de-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee on Risk Communication","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1434d1df-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–6/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish an advisory committee to be known as the “Advisory Committee on Risk Communication” (referred to in this section as the “Committee”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d1e0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–6/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall advise the Commissioner on methods to effectively communicate risks associated with the products regulated by the Food and Drug Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d1e1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–6/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that the Committee is composed of experts on risk communication, experts on the risks described in subsection (b), and representatives of patient, consumer, and health professional organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d1e2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–6/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permanence of Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"Section 1013 of title 5","children":[],"tail":" shall not apply to the Committee established under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1434d1e3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships for risk communication","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1434d1e4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–6/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall partner with professional medical societies, medical schools, academic medical centers, and other stakeholders to develop robust and multi-faceted systems for communication to health care providers about emerging postmarket drug risks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d1e5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–6/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The systems developed under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1434d1e6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–6/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" account for the diversity among physicians in terms of practice, willingness to adopt technology, and medical specialty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1434d1e7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–6/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include the use of existing communication channels, including electronic communications, in place at the Food and Drug Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1434d1e8-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s567"},"text":"June 25, 1938, ch. 675, § 567","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/85/tIX/s917"},"text":"Pub. L. 110–85, title IX, § 917","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/960"},"text":"121 Stat. 960","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/157"},"text":"Pub. L. 117–286, § 4(a)(157)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4323"},"text":"136 Stat. 4323","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1434d1e9-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1434d1ea-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id1434d1eb-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"Section 1013 of title 5","children":[],"tail":"” for “Section 14 of the Federal Advisory Committee Act”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
