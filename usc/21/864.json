{"tag":"section","attrib":{"id":"id14b0b90a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s864"},"text":null,"children":[{"tag":"num","attrib":{"value":"864"},"text":"§ 864.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Anhydrous ammonia","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14b0b90b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s864/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It is unlawful for any person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14b0b90c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s864/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to steal anhydrous ammonia, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14b0b90d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s864/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to transport stolen anhydrous ammonia across State lines,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"knowing, intending, or having reasonable cause to believe that such anhydrous ammonia will be used to manufacture a controlled substance in violation of this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14b0b90e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s864/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who violates subsection (a) shall be imprisoned or fined, or both, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s843/d"},"text":"section 843(d) of this title","children":[],"tail":" as if such violation were a violation of a provision of "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s843"},"text":"section 843 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14b0b90f-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/tII/s423"},"text":"Pub. L. 91–513, title II, § 423","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXVI/s3653/a"},"text":"Pub. L. 106–310, div. B, title XXXVI, § 3653(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1240"},"text":"114 Stat. 1240","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
