{"tag":"section","attrib":{"id":"id14029ecd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356b"},"text":null,"children":[{"tag":"num","attrib":{"value":"356b"},"text":"§ 356b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports of postmarketing studies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14029ece-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14029ecf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A sponsor of a drug that has entered into an agreement with the Secretary to conduct a postmarketing study of a drug shall submit to the Secretary, within 1 year after the approval of such drug and annually thereafter until the study is completed or terminated, a report of the progress of the study or the reasons for the failure of the sponsor to conduct the study. The report shall be submitted in such form as is prescribed by the Secretary in regulations issued by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14029ed0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accelerated approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), a sponsor of a drug approved pursuant to accelerated approval shall submit to the Secretary a report of the progress of any study required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s356/c"},"text":"section 356(c) of this title","children":[],"tail":", including progress toward enrollment targets, milestones, and other information as required by the Secretary, not later than 180 days after the approval of such drug and not less frequently than every 180 days thereafter, until the study is completed or terminated. The Secretary shall promptly publish on the website of the Food and Drug Administration, in an easily searchable format, the information reported under this paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14029ed1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements prior to effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any agreement entered into between the Secretary and a sponsor of a drug, prior to ","children":[{"tag":"date","attrib":{"date":"1997-11-21"},"text":"November 21, 1997","children":[],"tail":", to conduct a postmarketing study of a drug shall be subject to the requirements of paragraph (1). An initial report for such an agreement shall be submitted within 6 months after the date of the issuance of the regulations under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14029ed2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of information as public information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any information pertaining to a report described in subsection (a) shall be considered to be public information to the extent that the information is necessary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14029ed3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify the sponsor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14029ed4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish the status of a study described in subsection (a) and the reasons, if any, for any failure to carry out the study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14029ed5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of studies and reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall annually develop and publish in the Federal Register a report that provides information on the status of the postmarketing studies—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14029ed6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that sponsors have entered into agreements to conduct; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14029ed7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which reports have been submitted under subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14029ed8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a sponsor fails to complete an agreed upon study required by this section by its original or otherwise negotiated deadline, the Secretary shall publish a statement on the Internet site of the Food and Drug Administration stating that the study was not completed and, if the reasons for such failure to complete the study were not satisfactory to the Secretary, a statement that such reasons were not satisfactory to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14029ed9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to studies of the type required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s356/c/2/A"},"text":"section 356(c)(2)(A) of this title","children":[],"tail":" or under section 314.510 or 601.41 of title 21, Code of Federal Regulations, as each of such sections was in effect on the day before the effective date of this subsection, the Secretary may require that a sponsor who, for reasons not satisfactory to the Secretary, fails to complete by its deadline a study under any of such sections of such type for a drug or biological product (including such a study conducted after such effective date) notify practitioners who prescribe such drug or biological product of the failure to complete such study and the questions of clinical benefit, and, where appropriate, questions of safety, that remain unanswered as a result of the failure to complete such study. Nothing in this subsection shall be construed as altering the requirements of the types of studies required under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s356/c/2/A"},"text":"section 356(c)(2)(A) of this title","children":[],"tail":" or under section 314.510 or 601.41 of title 21, Code of Federal Regulations, as so in effect, or as prohibiting the Secretary from modifying such sections of title 21 of such Code to provide for studies in addition to those of such type."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14029eda-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s506B"},"text":"June 25, 1938, ch. 675, § 506B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/115/tI/s130/a"},"text":"Pub. L. 105–115, title I, § 130(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2331"},"text":"111 Stat. 2331","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/188/tV/s506"},"text":"Pub. L. 107–188, title V, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-12"},"text":"June 12, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/693"},"text":"116 Stat. 693","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/144/tIX/s902/c"},"text":"Pub. L. 112–144, title IX, § 902(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1088"},"text":"126 Stat. 1088","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tIII/s3210/b"},"text":"Pub. L. 117–328, div. FF, title III, § 3210(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5823"},"text":"136 Stat. 5823","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14029edb-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14029edc-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14029edd-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The effective date of this subsection, referred to in subsec. (e), is ","children":[{"tag":"date","attrib":{"date":"2002-10-01"},"text":"Oct. 1, 2002","children":[],"tail":", see Effective Date of 2002 Amendment note set out below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14029ede-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" added par. (2) and redesignated former par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/144"},"text":"Pub. L. 112–144","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t21/s356/c/2/A"},"text":"section 356(c)(2)(A) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t21/s356/b/2/A"},"text":"section 356(b)(2)(A) of this title","children":[],"tail":"” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/188"},"text":"Pub. L. 107–188","children":[],"tail":" added subsecs. (d) and (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14029edf-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id14029ee0-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/188/tV/s508"},"text":"Pub. L. 107–188, title V, § 508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-12"},"text":"June 12, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/694"},"text":"116 Stat. 694","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/188/tV/s508"},"text":"“The amendments made by this subtitle [subtitle A (§§ 501–509) of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/188"},"text":"Pub. L. 107–188","children":[],"tail":", amending this section and sections 379g and 379h of this title] shall take effect "},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"October 1, 2002","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id14029ee1-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/115/s501"},"text":"section 501 of Pub. L. 105–115","children":[],"tail":", set out as an Effective Date of 1997 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s321"},"text":"section 321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id14029ee2-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in amendment made by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" to be construed to affect ongoing withdrawal proceedings for products approved pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s356/c"},"text":"section 356(c) of this title","children":[],"tail":" for which a notice of proposed withdrawal has been published in the Federal Register prior to "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/s3210/f"},"text":"section 3210(f) of Pub. L. 117–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s356"},"text":"section 356 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id14029ee3-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report to Congressional Committees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/115/tI/s130/b"},"text":"Pub. L. 105–115, title I, § 130(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2331"},"text":"111 Stat. 2331","children":[],"tail":", provided that not later than "},{"tag":"date","attrib":{"date":"2001-10-01"},"text":"Oct. 1, 2001","children":[],"tail":", the Secretary was to submit to Congress a report containing a summary of the reports submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s356b"},"text":"section 356b of this title","children":[],"tail":" and an evaluation and legislative recommendations relating to postmarketing studies of drugs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
