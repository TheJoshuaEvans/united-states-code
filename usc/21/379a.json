{"tag":"section","attrib":{"id":"id1447e46d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379a"},"text":null,"children":[{"tag":"num","attrib":{"value":"379a"},"text":"§ 379a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumption of existence of jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In any action to enforce the requirements of this chapter respecting a device, tobacco product, food, drug, or cosmetic the connection with interstate commerce required for jurisdiction in such action shall be presumed to exist.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id1447e46e-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s709"},"text":"June 25, 1938, ch. 675, § 709","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/295/s8"},"text":"Pub. L. 94–295, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-28"},"text":"May 28, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/583"},"text":"90 Stat. 583","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/115/tIV/s419"},"text":"Pub. L. 105–115, title IV, § 419","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2379"},"text":"111 Stat. 2379","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/31/dA/tI/s103/k"},"text":"Pub. L. 111–31, div. A, title I, § 103(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-06-22"},"text":"June 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1837"},"text":"123 Stat. 1837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1447e46f-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","chil