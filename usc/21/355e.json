{"tag":"section","attrib":{"id":"id13fb72b3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355e"},"text":null,"children":[{"tag":"num","attrib":{"value":"355e"},"text":"§ 355e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pharmaceutical security","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id13fb72b4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop standards and identify and validate effective technologies for the purpose of securing the drug supply chain against counterfeit, diverted, subpotent, substandard, adulterated, misbranded, or expired drugs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13fb72b5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards development","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13fb72b6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, in consultation with the agencies specified in paragraph (4), manufacturers, distributors, pharmacies, and other supply chain stakeholders, prioritize and develop standards for the identification, validation, authentication, and tracking and tracing of prescription drugs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13fb72b7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standardized numeral identifier","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 months after ","children":[{"tag":"date","attrib":{"date":"2007-09-27"},"text":"September 27, 2007","children":[],"tail":", the Secretary shall develop a standardized numerical identifier (which, to the extent practicable, shall be harmonized with international consensus standards for such an identifier) to be applied to a prescription drug at the point of manufacturing and repackaging (in which case the numerical identifier shall be linked to the numerical identifier applied at the point of manufacturing) at the package or pallet level, sufficient to facilitate the identification, validation, authentication, and tracking and tracing of the prescription drug."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13fb72b8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promising technologies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The standards developed under this subsection shall address promising technologies, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13fb72b9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355e/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" radio frequency identification technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13fb72ba-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355e/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nanotechnology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13fb72bb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355e/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encryption technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13fb72bc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355e/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other track-and-trace or authentication technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13fb72bd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355e/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency collaboration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this subsection, the Secretary shall consult with Federal health and security agencies, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13fb72be-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355e/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Justice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13fb72bf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355e/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Homeland Security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13fb72c0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355e/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Commerce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13fb72c1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355e/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other appropriate Federal and State agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13fb72c2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection and enforcement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13fb72c3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall expand and enhance the resources and facilities of agency components of the Food and Drug Administration involved with regulatory and criminal enforcement of this chapter to secure the drug supply chain against counterfeit, diverted, subpotent, substandard, adulterated, misbranded, or expired drugs including biological products and active pharmaceutical ingredients from domestic and foreign sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13fb72c4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall undertake enhanced and joint enforcement activities with other Federal and State agencies, and establish regional capacities for the validation of prescription drugs and the inspection of the prescription drug supply chain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13fb72c5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “prescription drug” means a drug subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s353/b/1"},"text":"section 353(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id13fb72c6-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s505D"},"text":"June 25, 1938, ch. 675, § 505D","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/85/tIX/s913"},"text":"Pub. L. 110–85, title IX, § 913","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/952"},"text":"121 Stat. 952","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
