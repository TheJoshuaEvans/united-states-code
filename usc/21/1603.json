{"tag":"section","attrib":{"id":"id14c63d41-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1603"},"text":null,"children":[{"tag":"num","attrib":{"value":"1603"},"text":"§ 1603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General requirements; applicability; preemption","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14c63d42-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1603/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c63d43-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1603/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any civil action covered by this chapter, a biomaterials supplier may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c63d44-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1603/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" raise any exclusion from liability set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1604"},"text":"section 1604 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c63d45-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1603/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a motion for dismissal or for summary judgment as set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1605"},"text":"section 1605 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c63d46-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1603/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, a Federal or State court in which an action covered by this chapter is pending shall, in connection with a motion under section 1605 or 1606 of this title, use the procedures set forth in this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c63d47-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1603/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c63d48-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1603/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), this chapter applies to any civil action brought by a claimant, whether in a Federal or State court, on the basis of any legal theory, for harm allegedly caused, directly or indirectly, by an implant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c63d49-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1603/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A civil action brought by a purchaser of a medical device, purchased for use in providing professional health care services, for loss or damage to an implant or for commercial loss to the purchaser—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c63d4a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1603/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be considered an action that is subject to this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c63d4b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1603/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be governed by applicable commercial or contract law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c63d4c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1603/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of preemption","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c63d4d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1603/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This chapter supersedes any State law regarding recovery for harm caused by an implant and any rule of procedure applicable to a civil action to recover damages for such harm only to the extent that this chapter establishes a rule of law applicable to the recovery of such damages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c63d4e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1603/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any issue that arises under this chapter and that is not governed by a rule of law applicable to the recovery of damages described in paragraph (1) shall be governed by applicable Federal or State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c63d4f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1603/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statutory construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter may be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c63d50-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1603/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to affect any defense available to a defendant under any other provisions of Federal or State law in an action alleging harm caused by an implant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c63d51-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1603/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to create a cause of action or Federal court jurisdiction pursuant to section 1331 or 1337 of title 28 that otherwise would not exist under applicable Federal or State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14c63d52-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/230/s4"},"text":"Pub. L. 105–230, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-13"},"text":"Aug. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1523"},"text":"112 Stat. 1523","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14c63d53-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14c63d54-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id14c63d55-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to all civil actions covered under this chapter commenced on or after ","children":[{"tag":"date","attrib":{"date":"1998-08-13"},"text":"Aug. 13, 1998","children":[],"tail":", including any in which the harm or harmful conduct occurred before such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/230/s8"},"text":"section 8 of Pub. L. 105–230","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1601"},"text":"section 1601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
