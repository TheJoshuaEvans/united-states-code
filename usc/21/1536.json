{"tag":"section","attrib":{"id":"id14c3ccb2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536"},"text":null,"children":[{"tag":"num","attrib":{"value":"1536"},"text":"§ 1536.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community-based coalition enhancement grants to address local drug crises","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14c3ccb3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c3ccb4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Substance Abuse and Mental Health Services Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3ccb5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the Office of National Drug Control Policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3ccb6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drug-Free Communities Act of 1997","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Drug-Free Communities Act of 1997” means chapter 2 of the National Narcotics Leadership Act of 1988 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1521"},"text":"21 U.S.C. 1521","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3ccb7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means an organization that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c3ccb8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on or before the date of submitting an application for a grant under this section, receives or has received a grant under the Drug-Free Communities Act of 1997; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c3ccb9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has documented, using local data, rates of abuse of opioids or methamphetamines at levels that are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14c3ccba-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significantly higher than the national average as determined by the Secretary (including appropriate consideration of the results of the Monitoring the Future Survey published by the National Institute on Drug Abuse and the National Survey on Drug Use and Health published by the Substance Abuse and Mental Health Services Administration); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14c3ccbb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" higher than the national average, as determined by the Secretary (including appropriate consideration of the results of the surveys described in clause (i)), over a sustained period of time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3ccbc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emerging drug abuse issue","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “emerging drug abuse issue” means a substance use disorder within an area involving—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c3ccbd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sudden increase in demand for particular drug abuse treatment services relative to previous demand; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c3ccbe-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a lack of resources in the area to address the emerging problem.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3ccbf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local drug crisis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “local drug crisis” means, with respect to the area served by an eligible entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c3ccc0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sudden increase in the abuse of opioids or methamphetamines, as documented by local data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c3ccc1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the abuse of prescription medications, specifically opioids or methamphetamines, that is significantly higher than the national average, over a sustained period of time, as documented by local data; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c3ccc2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sudden increase in opioid-related deaths, as documented by local data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3ccc3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opioid","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “opioid” means any drug having an addiction-forming or addiction-sustaining liability similar to morphine or being capable of conversion into a drug having such addiction-forming or addiction-sustaining liability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c3ccc4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director, in coordination with the Administrator, may make grants to eligible entities to implement comprehensive community-wide strategies that address local drug crises and emerging drug abuse issues within the area served by the eligible entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c3ccc5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c3ccc6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity seeking a grant under this section shall submit an application to the Director at such time, in such manner, and accompanied by such information as the Director may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3ccc7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of an application for a grant under this section, the Director shall require an eligible entity to submit a detailed, comprehensive, multisector plan for addressing the local drug crisis or emerging drug abuse issue within the area served by the eligible entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c3ccc8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity shall use a grant received under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c3ccc9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for programs designed to implement comprehensive community-wide prevention strategies to address the local drug crisis in the area served by the eligible entity, in accordance with the plan submitted under subsection (c)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3ccca-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain specialized training and technical assistance from the organization funded under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/82/s4"},"text":"section 4 of Public Law 107–82","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1521"},"text":"21 U.S.C. 1521","children":[],"tail":" note); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3cccb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for programs designed to implement comprehensive community-wide strategies to address emerging drug abuse issues in the community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c3cccc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement not supplant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity shall use Federal funds received under this section only to supplement the funds that would, in the absence of those Federal funds, be made available from other Federal and non-Federal sources for the activities described in this section, and not to supplant those funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c3cccd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under this section shall be subject to the same evaluation requirements and procedures as the evaluation requirements and procedures imposed on the recipient of a grant under the Drug-Free Communities Act of 1997, and may also include an evaluation of the effectiveness at reducing abuse of opioids or methamphetamines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c3ccce-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 8 percent of the amounts made available to carry out this section for a fiscal year may be used to pay for administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c3cccf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may enter into an interagency agreement with the Administrator to delegate authority for the execution of grants and for such other activities as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c3ccd0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1536/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, there are authorized to be appropriated $5,000,000 for each of fiscal years 2017 through 2021.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14c3ccd1-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/198/tI/s103"},"text":"Pub. L. 114–198, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-22"},"text":"July 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/699"},"text":"130 Stat. 699","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14c3ccd2-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14c3ccd3-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14c3ccd4-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Drug-Free Communities Act of 1997, referred to in subsec. (a)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/20"},"text":"Pub. L. 105–20","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-27"},"text":"June 27, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/224"},"text":"111 Stat. 224","children":[],"tail":", section 2(a)(2) of which enacted chapter 2 of the National Narcotics Leadership Act of 1988, which is classified to this subchapter. For complete classification of the Drug-Free Communities Act of 1997 to the Code, see Short Title of 1997 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1501"},"text":"section 1501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id14c3ccd5-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Comprehensive Addiction and Recovery Act of 2016, and not as part of the National Narcotics Leadership Act of 1988 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
