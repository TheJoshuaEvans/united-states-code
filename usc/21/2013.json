{"tag":"section","attrib":{"id":"id14d223e4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2013"},"text":null,"children":[{"tag":"num","attrib":{"value":"2013"},"text":"§ 2013.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NMIC requirements and review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14d223e5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2013/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The NMIC shall promote sharing information regarding successful law enforcement, treatment, environmental, prevention, social services, and other programs related to the production, use, or effects of methamphetamine and grants available for such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d223e6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2013/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Components","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The NMIC shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d223e7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2013/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a toll-free number; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d223e8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2013/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a website that provides a searchable database, which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d223e9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2013/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides information on the short-term and long-term effects of methamphetamine use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d223ea-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2013/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides information regarding methamphetamine treatment and prevention programs and strategies and programs for drug endangered children, including descriptions of successful programs and strategies and contact information for such programs and strategies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d223eb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2013/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides information regarding grants for methamphetamine-related programs, including contact information and links to websites;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d223ec-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2013/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allows a qualified entity to submit items to be posted on the website regarding successful public or private programs or other useful information related to the production, use, or effects of methamphetamine;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d223ed-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2013/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a restricted section that may only be accessed by a law enforcement organization that contains successful strategies, training techniques, and other information that the Council determines helpful to law enforcement agency efforts to identify or combat the production, use, or effects of methamphetamine;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d223ee-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2013/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allows public access to all information not in a restricted section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d223ef-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2013/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains any additional information the Council determines may be useful in identifying or combating the production, use, or effects of methamphetamine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Thirty days after the website in paragraph (2) is operational, no funds shall be expended to continue the website methresources.gov.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d223f0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2013/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of posted information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d223f1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2013/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after the date of submission of an item by a qualified entity, the Council shall review an item submitted for posting on the website described in subsection (b)(2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d223f2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2013/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to evaluate and determine whether the item, as submitted or as modified, meets the requirements for posting; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d223f3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2013/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the Attorney General, to determine whether the item should be posted in a restricted section of the website.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d223f4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2013/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 45 days after the date of submission of an item, the Council shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d223f5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2013/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" post the item on the website described in subsection (b)(2); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d223f6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2013/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the qualified entity that submitted the item regarding the reason such item shall not be posted and modifications, if any, that the qualified entity may make to allow the item to be posted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14d223f7-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/469/tX/s1004"},"text":"Pub. L. 109–469, title X, § 1004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-29"},"text":"Dec. 29, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3538"},"text":"120 Stat. 3538","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
