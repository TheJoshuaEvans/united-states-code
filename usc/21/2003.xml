<section xmlns="http://xml.house.gov/schemas/uslm/1.0" style="-uslm-lc:I80" id="id14d223bd-3a70-11f1-b089-c1e1e512a22d" identifier="/us/usc/t21/s2003"><num value="2003">§ 2003.</num><heading> Authorization of appropriations</heading>
<chapeau style="-uslm-lc:I11" class="indent0">There are authorized to be appropriated to the United States Anti-Doping Agency—</chapeau><paragraph style="-uslm-lc:I12" class="indent1" id="id14d223be-3a70-11f1-b089-c1e1e512a22d" identifier="/us/usc/t21/s2003/1"><num value="1">(1)</num><content> for fiscal year 2023, $15,500,000;</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="id14d223bf-3a70-11f1-b089-c1e1e512a22d" identifier="/us/usc/t21/s2003/2"><num value="2">(2)</num><content> for fiscal year 2024, $16,200,000;</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="id14d223c0-3a70-11f1-b089-c1e1e512a22d" identifier="/us/usc/t21/s2003/3"><num value="3">(3)</num><content> for fiscal year 2025, $16,900,000;</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="id14d223c1-3a70-11f1-b089-c1e1e512a22d" identifier="/us/usc/t21/s2003/4"><num value="4">(4)</num><content> for fiscal year 2026, $17,700,000;</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="id14d223c2-3a70-11f1-b089-c1e1e512a22d" identifier="/us/usc/t21/s2003/5"><num value="5">(5)</num><content> for fiscal year 2027, $18,500,000;</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="id14d223c3-3a70-11f1-b089-c1e1e512a22d" identifier="/us/usc/t21/s2003/6"><num value="6">(6)</num><content> for fiscal year 2028, $19,800,000;</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="id14d223c4-3a70-11f1-b089-c1e1e512a22d" identifier="/us/usc/t21/s2003/7"><num value="7">(7)</num><content> for fiscal year 2029, $22,100,000;</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="id14d223c5-3a70-11f1-b089-c1e1e512a22d" identifier="/us/usc/t21/s2003/8"><num value="8">(8)</num><content> for fiscal year 2030, $24,900,000; and</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="id14d223c6-3a70-11f1-b089-c1e1e512a22d" identifier="/us/usc/t21/s2003/9"><num value="9">(9)</num><content> for fiscal year 2031, $23,700,000.</content>
</paragraph>
