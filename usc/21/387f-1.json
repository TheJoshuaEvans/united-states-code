{"tag":"section","attrib":{"id":"id147780d1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387f–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"387f–1"},"text":"§ 387f–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement action plan for advertising and promotion restrictions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id147780d2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387f–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id147780d3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387f–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"2009-06-22"},"text":"June 22, 2009","children":[],"tail":", the Secretary of Health and Human Services (in this section referred to as the “Secretary”) shall develop and publish an action plan to enforce restrictions adopted pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s387f"},"text":"section 387f of this title","children":[],"tail":", as added by section 101(b) of this division, or pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s387a–1/a"},"text":"section 387a–1(a) of this title","children":[],"tail":", on promotion and advertising of menthol and other cigarettes to youth."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147780d4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387f–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The action plan required by paragraph (1) shall be developed in consultation with public health organizations and other stakeholders with demonstrated expertise and experience in serving minority communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147780d5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387f–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The action plan required by paragraph (1) shall include provisions designed to ensure enforcement of the restrictions described in paragraph (1) in minority communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id147780d6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387f–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and local activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id147780d7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387f–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information on authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 months after ","children":[{"tag":"date","attrib":{"date":"2009-06-22"},"text":"June 22, 2009","children":[],"tail":", the Secretary shall inform State, local, and tribal governments of the authority provided to such entities under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1334/c"},"text":"section 1334(c) of title 15","children":[],"tail":", as added by section 203 of this division, or preserved by such entities under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s387p"},"text":"section 387p of this title","children":[],"tail":", as added by section 101(b) of this division."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147780d8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387f–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of communities seeking assistance to prevent underage tobacco use, the Secretary shall provide such assistance, including assistance with strategies to address the prevention of underage tobacco use in communities with a disproportionate use of menthol cigarettes by minors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id147780d9-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/31/dA/tI/s105"},"text":"Pub. L. 111–31, div. A, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-06-22"},"text":"June 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1841"},"text":"123 Stat. 1841","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id147780da-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id147780db-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id147780dc-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Family Smoking Prevention and Tobacco Control Act, and not as part of the Federal Food, Drug, and Cosmetic Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id147780dd-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id147780de-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Modification of Deadlines for Secretarial Action","children":[],"tail":null},{"tag":"p","attrib":{},"text":"With respect to any time periods specified in div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/31"},"text":"Pub. L. 111–31","children":[],"tail":" that begin on "},{"tag":"date","attrib":{"date":"2009-06-22"},"text":"June 22, 2009","children":[],"tail":", within which the Secretary of Health and Human Services is required to carry out and complete specified activities, with certain limitations, the calculation of such time periods shall commence on the first day of the first fiscal quarter following the initial 2 consecutive fiscal quarters of fiscal year 2010 for which the Secretary has collected fees under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s387s"},"text":"section 387s of this title","children":[],"tail":", and the Secretary may extend or reduce the duration of one or more such time periods, except that no such period shall be extended for more than 90 days, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/31/s6"},"text":"section 6 of Pub. L. 111–31","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s387"},"text":"section 387 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
