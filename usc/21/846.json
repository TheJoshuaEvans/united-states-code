{"tag":"section","attrib":{"id":"id14a98cb7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s846"},"text":null,"children":[{"tag":"num","attrib":{"value":"846"},"text":"§ 846.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attempt and conspiracy","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person who attempts or conspires to commit any offense defined in this subchapter shall be subject to the same penalties as those prescribed for the offense, the commission of which was the object of the attempt or conspiracy.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id14a98cb8-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/tII/s406"},"text":"Pub. L. 91–513, title II, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1265"},"text":"84 Stat. 1265","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6470/a"},"text":"Pub. L. 100–690, title VI, § 6470(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4377"},"text":"102 Stat. 4377","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14a98cb9-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14a98cba-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14a98cbb-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" substituted “shall be subject to the same penalties as those prescribed for the offense” for “is punishable by imprisonment or fine or both which may not exceed the maximum punishment prescribed for the offense”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14a98cbc-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id14a98cbd-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of seventh calendar month that begins after ","children":[{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/513/s704"},"text":"section 704 of Pub. L. 91–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
