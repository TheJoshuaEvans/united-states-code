{"tag":"section","attrib":{"id":"id14a4d1bd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s832"},"text":null,"children":[{"tag":"num","attrib":{"value":"832"},"text":"§ 832.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspicious orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14a4d1be-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s832/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each registrant shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14a4d1bf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s832/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" design and operate a system to identify suspicious orders for the registrant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14a4d1c0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s832/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the system designed and operated under paragraph (1) by the registrant complies with applicable Federal and State privacy laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14a4d1c1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s832/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon discovering a suspicious order or series of orders, notify the Administrator of the Drug Enforcement Administration and the Special Agent in Charge of the Division Office of the Drug Enforcement Administration for the area in which the registrant is located or conducts business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14a4d1c2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s832/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspicious order database","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14a4d1c3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s832/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2018-10-24"},"text":"October 24, 2018","children":[],"tail":", the Attorney General shall establish a centralized database for collecting reports of suspicious orders."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14a4d1c4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s832/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Satisfaction of reporting requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a registrant reports a suspicious order to the centralized database established under paragraph (1), the registrant shall be considered to have complied with the requirement under subsection (a)(3) to notify the Administrator of the Drug Enforcement Administration and the Special Agent in Charge of the Division Office of the Drug Enforcement Administration for the area in which the registrant is located or conducts business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14a4d1c5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s832/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sharing information with the States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14a4d1c6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s832/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall prepare and make available information regarding suspicious orders in a State, including information in the database established under subsection (b)(1), to the point of contact for purposes of administrative, civil, and criminal oversight relating to the diversion of controlled substances for the State, as designated by the Governor or chief executive officer of the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14a4d1c7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s832/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall provide information in accordance with paragraph (1) within a reasonable period of time after obtaining the information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14a4d1c8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s832/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In establishing the process for the provision of information under this subsection, the Attorney General shall coordinate with States to ensure that the Attorney General has access to information, as permitted under State law, possessed by the States relating to prescriptions for controlled substances that will assist in enforcing Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14a4d1c9-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/tII/s312"},"text":"Pub. L. 91–513, title II, § 312","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/tIII/s3292/b"},"text":"Pub. L. 115–271, title III, § 3292(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3956"},"text":"132 Stat. 3956","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
