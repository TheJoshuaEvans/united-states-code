{"tag":"section","attrib":{"id":"id1469291b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379k"},"text":null,"children":[{"tag":"num","attrib":{"value":"379k"},"text":"§ 379k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information system","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish and maintain an information system to track the status and progress of each application or submission (including a petition, notification, or other similar form of request) submitted to the Food and Drug Administration requesting agency action.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id1469291c-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s745"},"text":"June 25, 1938, ch. 675, § 745","children":[],"tail":", formerly § 741, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/115/tIV/s407/a"},"text":"Pub. L. 105–115, title IV, § 407(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2370"},"text":"111 Stat. 2370","children":[],"tail":"; renumbered § 745, "},{"tag":"ref","attrib":{"href":"/us/pl/110/316/tII/s202/a"},"text":"Pub. L. 110–316, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3515"},"text":"122 Stat. 3515","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1469291d-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1469291e-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id1469291f-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/115/s501"},"text":"section 501 of Pub. L. 105–115","children":[],"tail":", set out as an Effective Date of 1997 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s321"},"text":"section 321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id14692920-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report on Status of System","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/115/tIV/s407/b"},"text":"Pub. L. 105–115, title IV, § 407(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2370"},"text":"111 Stat. 2370","children":[],"tail":", provided that not later than 1 year after "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", Secretary of Health and Human Services was to submit report to Congress on status of system to be established under this section, including projected costs of system and concerns about confidentiality."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
