{"tag":"section","attrib":{"id":"id13a0f732-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s114i"},"text":null,"children":[{"tag":"num","attrib":{"value":"114i"},"text":"§ 114i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pseudorabies eradication","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id13a0f733-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s114i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Congress finds that efforts to eradicate pseudorabies in United States swine populations by the Department of Agriculture in cooperation with State agencies and the pork industry have a high priority and should be continued until pseudorabies is completely eradicated in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13a0f734-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s114i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall establish and carry out a program for the eradication of pseudorabies in United States swine populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13a0f735-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s114i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds for testing and control of pseudorabies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that not less than 65 percent of the funds appropriated for the program established under subsection (b) shall be used for testing and screening of animals and for other purposes directly related to the eradication or control of pseudorabies. This requirement on the use of appropriated funds for this program shall not be implemented in a manner that would adversely affect any other animal or plant disease or pest eradication or control program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13a0f736-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s114i/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for each of the fiscal years 1991 through 2007 such sums as may be necessary for the purpose of carrying out the program established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id13a0f737-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXV/s2506"},"text":"Pub. L. 101–624, title XXV, § 2506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4068"},"text":"104 Stat. 4068","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tIX/s916"},"text":"Pub. L. 104–127, title IX, § 916","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1187"},"text":"110 Stat. 1187","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10505"},"text":"Pub. L. 107–171, title X, § 10505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/511"},"text":"116 Stat. 511","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id13a0f738-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id13a0f739-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id13a0f73a-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":" substituted “2007” for “2002”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" substituted “2002” for “1995”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
