{"tag":"section","attrib":{"id":"id1440b94e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364"},"text":null,"children":[{"tag":"num","attrib":{"value":"364"},"text":"§ 364.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1440b94f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adverse event","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “adverse event” means any health-related event associated with the use of a cosmetic product that is adverse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1440b950-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cosmetic product","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “cosmetic product” means a preparation of cosmetic ingredients with a qualitatively and quantitatively set composition for use in a finished product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1440b951-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facility","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1440b952-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “facility” includes any establishment (including an establishment of an importer) that manufactures or processes cosmetic products distributed in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1440b953-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such term does not include any of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id1440b954-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Beauty shops and salons, unless such establishment manufactures or processes cosmetic products at that location.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1440b955-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cosmetic product retailers, including individual sales representatives, direct sellers (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s3508/b/2"},"text":"section 3508(b)(2) of title 26","children":[],"tail":"), retail distribution facilities, and pharmacies, unless such establishment manufactures or processes cosmetic products that are not sold directly to consumers at that location."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1440b956-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hospitals, physicians’ offices, and health care clinics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1440b957-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Public health agencies and other nonprofit entities that provide cosmetic products directly to the consumer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1440b958-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Entities (such as hotels and airlines) that provide complimentary cosmetic products to customers incidental to other services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1440b959-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/3/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Trade shows and other venues where cosmetic product samples are provided free of charge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1440b95a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/3/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An establishment that manufactures or processes cosmetic products that are solely for use in research or evaluation, including for production testing and not offered for retail sale.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1440b95b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/3/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An establishment that solely performs one or more of the following with respect to cosmetic products:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id1440b95c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/3/B/viii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Labeling.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id1440b95d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/3/B/viii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Relabeling.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id1440b95e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/3/B/viii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Packaging.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id1440b95f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/3/B/viii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repackaging.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id1440b960-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/3/B/viii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Holding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id1440b961-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/3/B/viii/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Distributing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1440b962-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Clarification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purposes of subparagraph (B)(viii), the terms “packaging” and “repackaging” do not include filling a product container with a cosmetic product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1440b963-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsible person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “responsible person” means the manufacturer, packer, or distributor of a cosmetic product whose name appears on the label of such cosmetic product in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s364e/a"},"text":"section 364e(a) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1453/a"},"text":"section 1453(a) of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1440b964-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Serious adverse event","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “serious adverse event” means an adverse event that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1440b965-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" results in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id1440b966-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" death;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1440b967-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a life-threatening experience;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1440b968-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inpatient hospitalization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1440b969-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/5/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a persistent or significant disability or incapacity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1440b96a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/5/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a congenital anomaly or birth defect;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1440b96b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/5/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an infection; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1440b96c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/5/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significant disfigurement (including serious and persistent rashes, second- or third-degree burns, significant hair loss, or persistent or significant alteration of appearance), other than as intended, under conditions of use that are customary or usual; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1440b96d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s364/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires, based on reasonable medical judgment, a medical or surgical intervention to prevent an outcome described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1440b96e-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s604"},"text":"June 25, 1938, ch. 675, § 604","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tIII/s3502"},"text":"Pub. L. 117–328, div. FF, title III, § 3502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5847"},"text":"136 Stat. 5847","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1440b96f-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1440b970-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id1440b971-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 364, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s604"},"text":"act June 25, 1938, ch. 675, § 604","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1055"},"text":"52 Stat. 1055","children":[],"tail":", directed Secretary to promulgate regulations for listing of coal-tar colors for cosmetics, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/86/618/tI/s103/a/3"},"text":"Pub. L. 86–618, title I, § 103(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/398"},"text":"74 Stat. 398","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s379e"},"text":"section 379e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1440b972-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id1440b973-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction; Confidentiality","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tIII/s3503/c"},"text":"Pub. L. 117–328, div. FF, title III, § 3503(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5859"},"text":"136 Stat. 5859","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dFF/tIII/s3503/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary [of Health and Human Services] shall take appropriate measures to ensure that there are in effect effective procedures to prevent the unauthorized disclosure of any trade secret or confidential commercial information that is obtained by the Secretary of Health and Human Services pursuant to this subtitle [subtitle E (§§ 3501–3508) of title III of div. FF of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":", see Short Title of 2022 Amendment set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"section 301 of this title","children":[],"tail":"], including the amendments made by this subtitle."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Clarification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this subtitle, including the amendments made by this subtitle, shall be construed to authorize the disclosure of information that is prohibited from disclosure under section 301(j) of the Federal Food, Drug, and Cosmetic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s331/j"},"text":"21 U.S.C. 331(j)","children":[],"tail":") or "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1905"},"text":"section 1905 of title 18","children":[],"tail":", United States Code, or that is subject to withholding under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/4"},"text":"section 552(b)(4) of title 5","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
