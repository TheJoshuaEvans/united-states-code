{"tag":"section","attrib":{"id":"id1434d1ff-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"360bbb–8"},"text":"§ 360bbb–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with external experts on rare diseases, targeted therapies, and genetic targeting of treatments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1434d200-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of promoting the efficiency of and informing the review by the Food and Drug Administration of new drugs and biological products for rare diseases and drugs and biological products that are genetically targeted, the following shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1434d201-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with stakeholders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Consistent with sections X.C and IX.E.4 of the PDUFA Reauthorization Performance Goals and Procedures Fiscal Years 2013 through 2017, as referenced in the letters described in section 101(b) of the Prescription Drug User Fee Amendments of 2012, the Secretary shall ensure that opportunities exist, at a time the Secretary determines appropriate, for consultations with stakeholders on the topics described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d202-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with external experts","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1434d203-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop and maintain a list of external experts who, because of their special expertise, are qualified to provide advice on rare disease issues, including topics described in subsection (b). The Secretary may, when appropriate to address a specific regulatory question, consult such external experts on issues related to the review of new drugs and biological products for rare diseases and drugs and biological products that are genetically targeted, including the topics described in subsection (b), when such consultation is necessary because the Secretary lacks the specific scientific, medical, or technical expertise necessary for the performance of the Secretary’s regulatory responsibilities and the necessary expertise can be provided by the external experts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1434d204-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" External experts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), external experts are individuals who possess scientific or medical training that the Secretary lacks with respect to one or more rare diseases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1434d205-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Topics for consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Topics for consultation pursuant to this section may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1434d206-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rare diseases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d207-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the severity of rare diseases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d208-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the unmet medical need associated with rare diseases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d209-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the willingness and ability of individuals with a rare disease to participate in clinical trials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d20a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the benefits and risks of therapies to treat rare diseases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d20b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the general design of clinical trials for rare disease populations and subpopulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d20c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the demographics and the clinical description of patient populations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d20d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the science of small population studies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1434d20e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classification as special government employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The external experts who are consulted under this section may be considered special government employees, as defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s202"},"text":"section 202 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1434d20f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of confidential information and trade secrets","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1434d210-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to alter the protections offered by laws, regulations, and policies governing disclosure of confidential commercial or trade secret information, and any other information exempt from disclosure pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b"},"text":"section 552(b) of title 5","children":[],"tail":" as such provisions would be applied to consultation with individuals and organizations prior to "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d211-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consent required for disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not disclose confidential commercial or trade secret information to an expert consulted under this section without the written consent of the sponsor unless the expert is a special government employee (as defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s202"},"text":"section 202 of title 18","children":[],"tail":") or the disclosure is otherwise authorized by law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1434d212-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to limit the ability of the Secretary to consult with individuals and organizations as authorized prior to ","children":[{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1434d213-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No right or obligation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1434d214-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No right to consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to create a legal right for a consultation on any matter or require the Secretary to meet with any particular expert or stakeholder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d215-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No altering of goals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to alter agreed upon goals and procedures identified in the letters described in section 101(b) of the Prescription Drug User Fee Amendments of 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d216-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No change to number of review cycles","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section is intended to increase the number of review cycles as in effect before ","children":[{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1434d217-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No delay in product review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1434d218-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Prior to a consultation with an external expert, as described in this section, relating to an investigational new drug application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/i"},"text":"section 355(i) of this title","children":[],"tail":", a new drug application under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/b"},"text":"section 355(b) of this title","children":[],"tail":", or a biologics license application under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"section 262 of title 42","children":[],"tail":", the Director of the Center for Drug Evaluation and Research or the Director of the Center for Biologics Evaluation and Research (or appropriate Division Director), as appropriate, shall determine that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1434d219-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such consultation will—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id1434d21a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/g/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the Secretary’s ability to complete the Secretary’s review; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1434d21b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/g/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address outstanding deficiencies in the application; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1434d21c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sponsor authorized such consultation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1434d21d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–8/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of this subsection shall apply only in instances where the consultation is undertaken solely under the authority of this section. The requirements of this subsection shall not apply to any consultation initiated under any other authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1434d21e-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s569"},"text":"June 25, 1938, ch. 675, § 569","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/144/tIX/s903"},"text":"Pub. L. 112–144, title IX, § 903","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1088"},"text":"126 Stat. 1088","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIII/s3101/a/2/O"},"text":"Pub. L. 114–255, div. A, title III, § 3101(a)(2)(O)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1154"},"text":"130 Stat. 1154","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tIII/s3202/e"},"text":"Pub. L. 117–328, div. FF, title III, § 3202(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5812"},"text":"136 Stat. 5812","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1434d21f-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1434d220-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id1434d221-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 101(b) of the Prescription Drug User Fee Amendments of 2012, referred to in subsecs. (a)(1) and (f)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/144/s101/b"},"text":"section 101(b) of Pub. L. 112–144","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s379g"},"text":"section 379g of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id1434d222-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","children":[],"tail":" substituted “subsection (b)” for “subsection (c)” before period in first sentence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
