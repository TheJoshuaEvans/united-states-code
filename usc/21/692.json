{"tag":"section","attrib":{"id":"id148f4e71-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s692"},"text":null,"children":[{"tag":"num","attrib":{"value":"692"},"text":"§ 692.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection extended to reindeer","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of the meat-inspection law may be extended to the inspection of reindeer.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id148f4e72-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-06-30/ch131"},"text":"June 30, 1914, ch. 131","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/420"},"text":"38 Stat. 420","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id148f4e73-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id148f4e74-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id148f4e75-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the appropriation act cited as the credit to this section and not as part of the Federal Meat Inspection Act which is classified to subchapters I to IV–A of this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s94"},"text":"section 94 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
