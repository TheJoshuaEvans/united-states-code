{"tag":"section","attrib":{"id":"id14d49531-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2221"},"text":null,"children":[{"tag":"num","attrib":{"value":"2221"},"text":"§ 2221.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food emergency response network","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary, in coordination with the Secretary of Agriculture, the Secretary of Homeland Security, and State, local, and tribal governments shall, not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"January 4, 2011","children":[],"tail":", and biennially thereafter, submit to the relevant committees of Congress, and make publicly available on the Internet Web site of the Department of Health and Human Services, a report on the progress in implementing a national food emergency response laboratory network that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d49532-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2221/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides ongoing surveillance, rapid detection, and surge capacity for large-scale food-related emergencies, including intentional adulteration of the food supply;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d49533-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2221/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinates the food laboratory capacities of State, local, and tribal food laboratories, including the adoption of novel surveillance and identification technologies and the sharing of data between Federal agencies and State laboratories to develop national situational awareness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d49534-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2221/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides accessible, timely, accurate, and consistent food laboratory services throughout the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d49535-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2221/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develops and implements a methods repository for use by Federal, State, and local officials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d49536-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2221/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" responds to food-related emergencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d49537-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2221/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is integrated with relevant laboratory networks administered by other Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14d49538-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/353/tII/s202/b"},"text":"Pub. L. 111–353, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3929"},"text":"124 Stat. 3929","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14d49539-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14d4953a-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14d4953b-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Secretary, referred to in text, probably means the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
