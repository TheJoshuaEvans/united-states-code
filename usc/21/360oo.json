{"tag":"section","attrib":{"id":"id142da5b4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360oo"},"text":null,"children":[{"tag":"num","attrib":{"value":"360oo"},"text":"§ 360oo.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited acts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id142da5b5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360oo/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It shall be unlawful—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id142da5b6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360oo/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any manufacturer to introduce, or to deliver for introduction, into commerce, or to import into the United States, any electronic product which does not comply with an applicable standard prescribed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360kk"},"text":"section 360kk of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142da5b7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360oo/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any person to fail to furnish any notification or other material or information required by section 360","children":[{"tag":"i","attrib":{},"text":"ll","children":[],"tail":" or 360nn of this title; or to fail to comply with the requirements of section 360"},{"tag":"i","attrib":{},"text":"ll","children":[],"tail":"(f) of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142da5b8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360oo/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any person to fail or to refuse to establish or maintain records required by this part or to permit access by the Secretary or any of his duly authorized representatives to, or the copying of, such records, or to permit entry or inspection, as required by or pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360nn"},"text":"section 360nn of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142da5b9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360oo/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any person to fail or to refuse to make any report required pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360nn/b"},"text":"section 360nn(b) of this title","children":[],"tail":" or to furnish or preserve any information required pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360nn/f"},"text":"section 360nn(f) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142da5ba-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360oo/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any person (A) to fail to issue a certification as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360kk/h"},"text":"section 360kk(h) of this title","children":[],"tail":", or (B) to issue such a certification when such certification is not based upon a test or testing program meeting the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360kk/h"},"text":"section 360kk(h) of this title","children":[],"tail":" or when the issuer, in the exercise of due care, would have reason to know that such certification is false or misleading in a material respect."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id142da5bb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360oo/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may exempt any electronic product, or class thereof, from all or part of subsection (a), upon such conditions as he may find necessary to protect the public health or welfare, for the purpose of research, investigations, studies, demonstrations, or training, or for reasons of national security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id142da5bc-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s538"},"text":"June 25, 1938, ch. 675, § 538","children":[],"tail":", formerly "},{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tIII/s538"},"text":"act July 1, 1944, ch. 373, title III, § 538","children":[],"tail":", formerly § 360B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/602/s2/3"},"text":"Pub. L. 90–602, § 2(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-18"},"text":"Oct. 18, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1184"},"text":"82 Stat. 1184","children":[],"tail":"; renumbered § 538 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/629/s19/a/1/B"},"text":"Pub. L. 101–629, § 19(a)(1)(B)","children":[],"tail":", (2)(F), (3), (4), "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4529"},"text":"104 Stat. 4529","children":[],"tail":", 4530; "},{"tag":"ref","attrib":{"href":"/us/pl/103/80/s4/a/2"},"text":"Pub. L. 103–80, § 4(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-13"},"text":"Aug. 13, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/779"},"text":"107 Stat. 779","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id142da5bd-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id142da5be-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id142da5bf-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s263j"},"text":"section 263j of Title 42","children":[],"tail":", The Public Health and Welfare, prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/101/629"},"text":"Pub. L. 101–629","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id142da5c0-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/80"},"text":"Pub. L. 103–80","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/101/629/s19/a/4"},"text":"Pub. L. 101–629, § 19(a)(4)","children":[],"tail":", which renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s263j"},"text":"section 263j of Title 42","children":[],"tail":", The Public Health and Welfare, as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/629/s19/a/2/F/i"},"text":"Pub. L. 101–629, § 19(a)(2)(F)(i)","children":[],"tail":", substituted “section 360kk” for “section 263f”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/629/s19/a/2/F/ii"},"text":"Pub. L. 101–629, § 19(a)(2)(F)(ii)","children":[],"tail":", (iii), substituted “section 360"},{"tag":"i","attrib":{},"text":"ll","children":[],"tail":" or 360nn” for “section 263g or 263i” and “section 360"},{"tag":"i","attrib":{},"text":"ll","children":[],"tail":"(f)” for “section 263g(f)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/629/s19/a/1/B"},"text":"Pub. L. 101–629, § 19(a)(1)(B)","children":[],"tail":", (2)(F)(iii), substituted “this part” for “this subpart” and “section 360nn” for “section 263i”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/629/s19/a/2/F/iii"},"text":"Pub. L. 101–629, § 19(a)(2)(F)(iii)","children":[],"tail":", substituted “section 360nn(b)” for “section 263i(b)” and “section 360nn(f)” for “section 263i(f)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/629/s19/a/2/F/i"},"text":"Pub. L. 101–629, § 19(a)(2)(F)(i)","children":[],"tail":", substituted “section 360kk(h)” for “section 263f(h)” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id142da5c1-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id142da5c2-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Noninterference With Other Federal Agencies","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of this section not to be construed to supersede or limit the functions under any other provision of law of any officer or agency of the United States, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/602/s4"},"text":"section 4 of Pub. L. 90–602","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360hh"},"text":"section 360hh of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
