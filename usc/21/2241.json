{"tag":"section","attrib":{"id":"id14d6deca-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2241"},"text":null,"children":[{"tag":"num","attrib":{"value":"2241"},"text":"§ 2241.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection by the Secretary of Commerce","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d6decb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2241/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce, in coordination with the Secretary of Health and Human Services, may send 1 or more inspectors to a country or facility of an exporter from which seafood imported into the United States originates. The inspectors shall assess practices and processes used in connection with the farming, cultivation, harvesting, preparation for market, or transportation of such seafood and may provide technical assistance related to such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d6decc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2241/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d6decd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2241/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Health and Human Services, in coordination with the Secretary of Commerce, shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14d6dece-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2241/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare an inspection report for each inspection conducted under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d6decf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2241/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the report to the country or exporter that is the subject of the report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d6ded0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2241/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a 30-day period during which the country or exporter may provide a rebuttal or other comments on the findings of the report to the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d6ded1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2241/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution and use of report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services shall consider the inspection reports described in subparagraph (A) in distributing inspection resources under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s350j"},"text":"section 350j of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14d6ded2-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/353/tIII/s306/b"},"text":"Pub. L. 111–353, title III, § 306(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3959"},"text":"124 Stat. 3959","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
