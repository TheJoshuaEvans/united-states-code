{"tag":"section","attrib":{"id":"id148821d4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472"},"text":null,"children":[{"tag":"num","attrib":{"value":"472"},"text":"§ 472.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interstate shipment of poultry inspected by Federal and State agencies for certain small establishments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id148821d5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id148821d6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate State agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “appropriate State agency” means a State agency described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s454/a/1"},"text":"section 454(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id148821d7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designated personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “designated personnel” means inspection personnel of a State agency that have undergone all necessary inspection training and certification to assist the Secretary in the administration and enforcement of this chapter, including rules and regulations issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id148821d8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible establishment” means an establishment that is in compliance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id148821d9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State inspection program of the State in which the establishment is located; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id148821da-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this chapter, including rules and regulations issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id148821db-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Poultry item","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “poultry item” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id148821dc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a portion of poultry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id148821dd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a poultry product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id148821de-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selected establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “selected establishment” means an eligible establishment that is selected by the Secretary, in coordination with the appropriate State agency of the State in which the eligible establishment is located, under subsection (b) to ship poultry items in interstate commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id148821df-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary to allow shipments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id148821e0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), the Secretary, in coordination with the appropriate State agency of the State in which an establishment is located, may select the establishment to ship poultry items in interstate commerce, and place on each poultry item shipped in interstate commerce a Federal mark, stamp, tag, or label of inspection, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id148821e1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the poultry item qualifies for the Federal mark, stamp, tag, or label of inspection under the requirements of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id148821e2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment is an eligible establishment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id148821e3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inspection services for the establishment are provided by designated personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id148821e4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited establishments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out paragraph (1), the Secretary, in coordination with an appropriate State agency, shall not select an establishment that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id148821e5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on average, employs more than 25 employees (including supervisory and nonsupervisory employees), as defined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id148821e6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as of the date of the enactment of this section, ships in interstate commerce carcasses, portions of carcasses, or poultry items that are inspected by the Secretary in accordance with this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id148821e7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id148821e8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a Federal establishment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id148821e9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was a Federal establishment as of the date of the enactment of this section, and was reorganized on a later date under the same name or a different name or person by the person, firm, or corporation that controlled the establishment as of the date of the enactment of this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id148821ea-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" was a State establishment as of the date of the enactment of this section that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id148821eb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/b/2/C/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as of the date of the enactment of this section, employed more than 25 employees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id148821ec-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/b/2/C/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was reorganized on a later date by the person, firm, or corporation that controlled the establishment as of the date of the enactment of this section;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id148821ed-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in violation of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id148821ee-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located in a State that does not have a State inspection program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id148821ef-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the subject of a transition carried out in accordance with a procedure developed by the Secretary under paragraph (3)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id148821f0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishments that employ more than 25 employees","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id148821f1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may develop a procedure to transition to a Federal establishment any establishment under this section that, on average, consistently employs more than 25 employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id148821f2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility of certain establishments","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id148821f3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State establishment that employs more than 25 employees but less than 35 employees as of the date of the enactment of this section may be selected as a selected establishment under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id148821f4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State establishment shall be subject to the procedures established under subparagraph (A) beginning on the date that is 3 years after the effective date described in subsection (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id148821f5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of State costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall reimburse a State for costs related to the inspection of selected establishments in the State in accordance with Federal requirements in an amount of not less than 60 percent of eligible State costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id148821f6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination between Federal and State agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id148821f7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall designate an employee of the Federal Government as State coordinator for each appropriate State agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id148821f8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide oversight and enforcement of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id148821f9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to oversee the training and inspection activities of designated personnel of the State agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id148821fa-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supervision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State coordinator shall be under the direct supervision of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id148821fb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of State coordinator","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id148821fc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State coordinator shall visit selected establishments with a frequency that is appropriate to ensure that selected establishments are operating in a manner that is consistent with this chapter (including regulations and policies under this chapter).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id148821fd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarterly reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State coordinator shall, on a quarterly basis, submit to the Secretary a report that describes the status of each selected establishment that is under the jurisdiction of the State coordinator with respect to the level of compliance of each selected establishment with the requirements of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id148821fe-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immediate notification requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a State coordinator determines that any selected establishment that is under the jurisdiction of the State coordinator is in violation of any requirement of this chapter, the State coordinator shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id148821ff-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/d/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immediately notify the Secretary of the violation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14882200-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/d/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deselect the selected establishment or suspend inspection at the selected establishment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14882201-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Performance evaluations of State coordinators designated under this subsection shall be conducted by the Secretary as part of the Federal agency management control system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14882202-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14882203-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic audits conducted by Inspector General of the Department of Agriculture","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after the effective date described in subsection (i), and not less often than every 3 years thereafter, the Inspector General of the Department of Agriculture shall conduct an audit of each activity taken by the Secretary under this section for the period covered by the audit to determine compliance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14882204-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit conducted by Comptroller General of the United States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not earlier than 3 years, nor later than 5 years, after the date of the enactment of this section, the Comptroller General of the United States shall conduct an audit of the implementation of this section to determine—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14882205-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of the implementation of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14882206-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of selected establishments selected by the Secretary to ship poultry items under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14882207-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide grants to appropriate State agencies to assist the appropriate State agencies in helping establishments covered by this chapter to transition to selected establishments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14882208-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any selected establishment that the Secretary determines to be in violation of any requirement of this chapter shall be transitioned to a Federal establishment in accordance with a procedure developed by the Secretary under subsection (b)(3)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14882209-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section limits the jurisdiction of the Secretary with respect to the regulation of poultry and poultry products under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1488220a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1488220b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section takes effect on the date on which the Secretary, after providing a period of public comment (including through the conduct of public meetings or hearings), promulgates final regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1488220c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s472/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after the date of the enactment of this section, the Secretary shall promulgate final regulations in accordance with paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1488220d-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/172/s31"},"text":"Pub. L. 85–172, § 31","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXI/s11015/b"},"text":"Pub. L. 110–234, title XI, § 11015(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1365"},"text":"122 Stat. 1365","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XI, § 11015(b), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2127.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1488220e-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1488220f-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14882210-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsecs. (b)(2)(B), (C)(ii), (iii), (3)(B)(i), (e)(2), and (i)(2), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Final regulations to carry out this section, referred to in subsec. (i)(1), were published in the Federal Register on ","children":[{"tag":"date","attrib":{"date":"2011-05-02"},"text":"May 2, 2011","children":[],"tail":", eff. "},{"tag":"date","attrib":{"date":"2011-07-01"},"text":"July 1, 2011","children":[],"tail":"; see 76 F.R. 24756."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id14882211-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14882212-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id14882213-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
