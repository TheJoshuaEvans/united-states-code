{"tag":"section","attrib":{"id":"id1485d823-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s459"},"text":null,"children":[{"tag":"num","attrib":{"value":"459"},"text":"§ 459.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance by all establishments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1485d824-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s459/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No establishment processing poultry or poultry products for commerce otherwise subject to this chapter shall process any poultry or poultry product except in compliance with the requirements of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1485d825-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s459/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any establishment subject to inspection under this chapter that believes, or has reason to believe, that an adulterated or misbranded poultry or poultry product received by or originating from the establishment has entered into commerce shall promptly notify the Secretary with regard to the type, amount, origin, and destination of the poultry or poultry product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1485d826-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s459/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plans and reassessments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require that each establishment subject to inspection under this chapter shall, at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1485d827-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s459/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and maintain current procedures for the recall of all poultry or poultry products produced and shipped by the establishment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1485d828-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s459/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" document each reassessment of the process control plans of the establishment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1485d829-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s459/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon request, make the procedures and reassessed process control plans available to inspectors appointed by the Secretary for review and copying.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1485d82a-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/172/s10"},"text":"Pub. L. 85–172, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-08-28"},"text":"Aug. 28, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/446"},"text":"71 Stat. 446","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/492/s10"},"text":"Pub. L. 90–492, § 10","children":[],"tail":", "},{"tag":"date","at