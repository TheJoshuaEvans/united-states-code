{"tag":"section","attrib":{"id":"id14811dc0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399c"},"text":null,"children":[{"tag":"num","attrib":{"value":"399c"},"text":"§ 399c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improving the training of State, local, territorial, and tribal food safety officials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14811dc1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall set standards and administer training and education programs for the employees of State, local, territorial, and tribal food safety officials relating to the regulatory responsibilities and policies established by this chapter, including programs for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14811dc2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scientific training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14811dc3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training to improve the skill of officers and employees authorized to conduct inspections under sections 372 and 374 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14811dc4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training to achieve advanced product or process specialization in such inspections;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14811dc5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training that addresses best practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14811dc6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399c/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training in administrative process and procedure and integrity issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14811dc7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399c/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training in appropriate sampling and laboratory analysis methodology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14811dc8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399c/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training in building enforcement actions following inspections, examinations, testing, and investigations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14811dc9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships with State and local officials","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14811dca-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, pursuant to a contract or memorandum of understanding between the Secretary and the head of a State, local, territorial, or tribal department or agency, is authorized and encouraged to conduct examinations, testing, and investigations for the purposes of determining compliance with the food safety provisions of this chapter through the officers and employees of such State, local, territorial, or tribal department or agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14811dcb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A contract or memorandum described under paragraph (1) shall include provisions to ensure adequate training of such officers and employees to conduct such examinations, testing, and investigations. The contract or memorandum shall contain provisions regarding reimbursement. Such provisions may, at the sole discretion of the head of the other department or agency, require reimbursement, in whole or in part, from the Secretary for the examinations, testing, or investigations performed pursuant to this section by the officers or employees of the State, territorial, or tribal department or agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14811dcc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be construed to limit the authority of the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s372"},"text":"section 372 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14811dcd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure coordination with the extension activities of the National Institute of Food and Agriculture of the Department of Agriculture in advising producers and small processors transitioning into new practices required as a result of the enactment of the FDA Food Safety Modernization Act and assisting regulated industry with compliance with such Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14811dce-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Food Safety Training, Education, Extension, Outreach and Technical Assistance Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14811dcf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to improve food safety and reduce the incidence of foodborne illness, the Secretary shall, not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"January 4, 2011","children":[],"tail":", enter into one or more memoranda of understanding, or enter into other cooperative agreements, with the Secretary of Agriculture to establish a competitive grant program within the National Institute for Food and Agriculture to provide food safety training, education, extension, outreach, and technical assistance to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14811dd0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399c/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owners and operators of farms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14811dd1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399c/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small food processors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14811dd2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399c/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small fruit and vegetable merchant wholesalers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14811dd3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The competitive grant program established under paragraph (1) shall be carried out in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7625"},"text":"section 7625 of title 7","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14811dd4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out this section for fiscal years 2011 through 2015.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14811dd5-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s1012"},"text":"June 25, 1938, ch. 675, § 1012","children":[],"tail":", formerly § 1011, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/353/tII/s209/a"},"text":"Pub. L. 111–353, title II, § 209(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3945"},"text":"124 Stat. 3945","children":[],"tail":"; renumbered § 1012, "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIII/s3073/b/2"},"text":"Pub. L. 114–255, div. A, title III, § 3073(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1137"},"text":"130 Stat. 1137","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14811dd6-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14811dd7-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14811dd8-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The FDA Food Safety Modernization Act, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/353"},"text":"Pub. L. 111–353","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3885"},"text":"124 Stat. 3885","children":[],"tail":", which enacted chapter 27 (§ 2201 et seq.) and sections 350g to 350"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–1, 379j–31, 384a to 384d, 399c, and 399d of this title, "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7625"},"text":"section 7625 of Title 7","children":[],"tail":", Agriculture, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s280g–16"},"text":"section 280g–16 of Title 42","children":[],"tail":", The Public Health and Welfare, amended sections 331, 333, 334, 350b to 350d, 350f, 374, 381, 393, and 399 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s247b–20"},"text":"section 247b–20 of Title 42","children":[],"tail":", and enacted provisions set out as notes under sections 331, 334, 342, 350b, 350d, 350e, 350g to 350j, 350"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":", and 381 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s2201"},"text":"section 2201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id14811dd9-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1012 of act ","children":[{"tag":"date","attrib":{"date":"1938-06-25"},"text":"June 25, 1938","children":[],"tail":", was renumbered section 1013 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s399d"},"text":"section 399d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14811dda-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id14811ddb-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in this section to be construed to apply to certain alcohol-related facilities, to alter jurisdiction and authorities established under certain other Acts, or in a manner inconsistent with international agreements to which the United States is a party, see sections 2206, 2251, and 2252 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
