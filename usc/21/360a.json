{"tag":"section","attrib":{"id":"id140c3b29-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360a"},"text":null,"children":[{"tag":"num","attrib":{"value":"360a"},"text":"§ 360a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clinical trial guidance for antibiotic drugs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id140c3b2a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2007-09-27"},"text":"September 27, 2007","children":[],"tail":", the Secretary shall issue guidance for the conduct of clinical trials with respect to antibiotic drugs, including antimicrobials to treat acute bacterial sinusitis, acute bacterial otitis media, and acute bacterial exacerbation of chronic bronchitis. Such guidance shall indicate the appropriate models and valid surrogate markers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id140c3b2b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"2007-09-27"},"text":"September 27, 2007","children":[],"tail":", the Secretary shall review and update the guidance described under subsection (a) to reflect developments in scientific and medical information and technology."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id140c3b2c-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s511"},"text":"June 25, 1938, ch. 675, § 511","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/85/tIX/s911"},"text":"Pub. L. 110–85, title IX, § 911","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/951"},"text":"121 Stat. 951","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id140c3b2d-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id140c3b2e-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id140c3b2f-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 360a, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s511"},"text":"act June 25, 1938, ch. 675, § 511","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1965-07-15"},"text":"July 15, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/89/74/s3/b"},"text":"Pub. L. 89–74, § 3(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/227"},"text":"79 Stat. 227","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1968-10-24"},"text":"Oct. 24, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/90/639/s2/a"},"text":"Pub. L. 90–639, § 2(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1361"},"text":"82 Stat. 1361","children":[],"tail":", regulated the manufacture, compounding, and processing of depres