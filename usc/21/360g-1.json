{"tag":"section","attrib":{"id":"id141cddc3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360g–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"360g–1"},"text":"§ 360g–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency documentation and review of significant decisions regarding devices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id141cddc4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360g–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Documentation of rationale for significant decisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id141cddc5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360g–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide a substantive summary of the scientific and regulatory rationale for any significant decision of the Center for Devices and Radiological Health regarding submission or review of a report under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360/k"},"text":"section 360(k) of this title","children":[],"tail":", a petition for classification under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360c/f"},"text":"section 360c(f) of this title","children":[],"tail":", an application under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360e"},"text":"section 360e of this title","children":[],"tail":", or an application for an exemption under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360j/g"},"text":"section 360j(g) of this title","children":[],"tail":", including documentation of significant controversies or differences of opinion and the resolution of such controversies or differences of opinion."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id141cddc6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360g–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of documentation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon request, the Secretary shall furnish such substantive summary to the person who is seeking to submit, or who has submitted, such report or application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id141cddc7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360g–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of least burdensome requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The substantive summary required under this subsection shall include a brief statement regarding how the least burdensome requirements were considered and applied consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360c/i/1/D"},"text":"section 360c(i)(1)(D) of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360c/a/3/D"},"text":"section 360c(a)(3)(D) of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360e/c/5"},"text":"section 360e(c)(5) of this title","children":[],"tail":", as applicable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id141cddc8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360g–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of significant decisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id141cddc9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360g–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request for supervisory review of significant decision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person may request a supervisory review of the significant decision described in subsection (a)(1). Such review may be conducted at the next supervisory level or higher above the individual who made the significant decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id141cddca-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360g–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of request","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person requesting a supervisory review under paragraph (1) shall submit such request to the Secretary not later than 30 days after such decision and shall indicate in the request whether such person seeks an in-person meeting or a teleconference review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id141cddcb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360g–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timeframe","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id141cddcc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360g–1/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the Secretary shall schedule an in-person or teleconference review, if so requested, not later than 30 days after such request is made. The Secretary shall issue a decision to the person requesting a review under this subsection not later than 45 days after the request is made under paragraph (1), or, in the case of a person who requests an in-person meeting or teleconference, 30 days after such meeting or teleconference.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id141cddcd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360g–1/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) shall not apply in cases that are referred to experts outside of the Food and Drug Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id141cddce-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s517A"},"text":"June 25, 1938, ch. 675, § 517A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/144/tVI/s603"},"text":"Pub. L. 112–144, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1051"},"text":"126 Stat. 1051","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIII"},"text":"Pub. L. 114–255, div. A, title III","children":[],"tail":", §§ 3051(b), 3058(c), "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1124"},"text":"130 Stat. 1124","children":[],"tail":", 1129; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tIII/s3308/b/3"},"text":"Pub. L. 117–328, div. FF, title III, § 3308(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5836"},"text":"136 Stat. 5836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id141cddcf-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id141cddd0-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id141cddd1-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" amended par. (1) generally. Prior to amendment, text read as follows: “The Secretary shall provide a substantive summary of the scientific and regulatory rationale for any significant decision of the Center for Devices and Radiological Health regarding submission or review of a report under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360/k"},"text":"section 360(k) of this title","children":[],"tail":", an application under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360e"},"text":"section 360e of this title","children":[],"tail":", a request for designation under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360e–3"},"text":"section 360e–3 of this title","children":[],"tail":", or an application for an exemption under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360j/g"},"text":"section 360j(g) of this title","children":[],"tail":", including documentation of significant controversies or differences of opinion and the resolution of such controversies or differences of opinion.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s3051/b"},"text":"Pub. L. 114–255, § 3051(b)","children":[],"tail":", inserted “a request for designation under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360e–3"},"text":"section 360e–3 of this title","children":[],"tail":",” after “application under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360e"},"text":"section 360e of this title","children":[],"tail":",”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s3058/c"},"text":"Pub. L. 114–255, § 3058(c)","children":[],"tail":", added par. (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
