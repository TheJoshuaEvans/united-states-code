{"tag":"section","attrib":{"id":"id1445741b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s374a"},"text":null,"children":[{"tag":"num","attrib":{"value":"374a"},"text":"§ 374a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspections relating to food allergens","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Health and Human Services shall conduct inspections consistent with the authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s374"},"text":"section 374 of this title","children":[],"tail":" of facilities in which foods are manufactured, processed, packed, or held—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id1445741c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s374a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that the entities operating the facilities comply with practices to reduce or eliminate cross-contact of a food with residues of major food allergens that are not intentional ingredients of the food; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1445741d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s374a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that major food allergens are properly labeled on foods.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1445741e-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/282/tII/s205"},"text":"Pub. L. 108–282, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-02"},"text":"Aug. 2, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/909"},"text":"118 Stat. 909","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1445741f-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14457420-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id14457421-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as a part of the Food Allergen Labeling and Consumer Protection Act of 2004, and not as part of the Federal Food, Drug, and Cosmetic Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
