{"tag":"section","attrib":{"id":"id14c18124-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1178"},"text":null,"children":[{"tag":"num","attrib":{"value":"1178"},"text":"§ 1178.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records and audit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14c18125-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1178/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance records; contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each recipient of assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1177"},"text":"section 1177 of this title","children":[],"tail":" pursuant to grants or contracts entered into under other than competitive bidding procedures shall keep such records as the Secretary shall prescribe, including rec­ords which fully disclose the amount and disposition by such recipient of the proceeds of such grant or contract, the total cost of the project or undertaking in connection with which such grant or contract is given or used, and the amount of that portion of the cost of the project or undertaking supplied by other sources, and such other records as will facilitate an effective audit."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c18126-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1178/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to pertinent information for audit and examination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and Comptroller General of the United States, or any of their duly authorized representatives, shall have access for the purpose of audit and examination to any books, documents, papers, and records of such recipients that are pertinent to such grants or contracts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14c18127-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/255/tIV/s411"},"text":"Pub. L. 92–255, title IV, § 411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-03-21"},"text":"Mar. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/83"},"text":"86 Stat. 83","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s971"},"text":"Pub. L. 97–35, title IX, § 971","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/597"},"text":"95 Stat. 597","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14c18128-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14c18129-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14c1812a-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" struck out reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1176"},"text":"section 1176 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
