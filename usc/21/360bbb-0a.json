{"tag":"section","attrib":{"id":"id142da61c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a"},"text":null,"children":[{"tag":"num","attrib":{"value":"360bbb–0a"},"text":"§ 360bbb–0a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigational drugs for use by eligible patients","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id142da61d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id142da61e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “eligible patient” means a patient—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id142da61f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has been diagnosed with a life-threatening disease or condition (as defined in section 312.81 of title 21, Code of Federal Regulations (or any successor regulations));","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142da620-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who has exhausted approved treatment options and is unable to participate in a clinical trial involving the eligible investigational drug, as certified by a physician, who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id142da621-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in good standing with the physician’s licensing organization or board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id142da622-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not be compensated directly by the manufacturer for so certifying; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142da623-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has provided to the treating physician written informed consent regarding the eligible investigational drug, or, as applicable, on whose behalf a legally authorized representative of the patient has provided such consent;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142da624-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “eligible investigational drug” means an investigational drug (as such term is used in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360bbb"},"text":"section 360bbb of this title","children":[],"tail":")—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id142da625-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which a Phase 1 clinical trial has been completed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142da626-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has not been approved or licensed for any use under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"section 355 of this title","children":[],"tail":" or section 351 of the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"42 U.S.C. 262","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142da627-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id142da628-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which an application has been filed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/b"},"text":"section 355(b) of this title","children":[],"tail":" or section 351(a) of the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262/a"},"text":"42 U.S.C. 262(a)","children":[],"tail":"]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id142da629-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that is under investigation in a clinical trial that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id142da62a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/a/2/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is intended to form the primary basis of a claim of effectiveness in support of approval or licensure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"section 355 of this title","children":[],"tail":" or section 351 of the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"42 U.S.C. 262","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id142da62b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/a/2/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the subject of an active investigational new drug application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/i"},"text":"section 355(i) of this title","children":[],"tail":" or section 351(a)(3) of the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262/a/3"},"text":"42 U.S.C. 262(a)(3)","children":[],"tail":"], as applicable; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142da62c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the active development or production of which is ongoing and has not been discontinued by the manufacturer or placed on clinical hold under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/i"},"text":"section 355(i) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142da62d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “phase 1 trial” means a phase 1 clinical investigation of a drug as described in section 312.21 of title 21, Code of Federal Regulations (or any successor regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id142da62e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Eligible investigational drugs provided to eligible patients in compliance with this section are exempt from sections 352(f), 353(b)(4), 355(a), and 355(i) of this title, section 351(a) of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s262/a"},"text":"42 U.S.C. 262(a)","children":[],"tail":"], and parts 50, 56, and 312 of title 21, Code of Federal Regulations (or any successor regulations), provided that the sponsor of such eligible investigational drug or any person who manufactures, distributes, prescribes, dispenses, introduces or delivers for introduction into interstate commerce, or provides to an eligible patient an eligible investigational drug pursuant to this section is in compliance with the applicable requirements set forth in sections 312.6, 312.7, and 312.8(d)(1) of title 21, Code of Federal Regulations (or any successor regulations) that apply to investigational drugs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id142da62f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of clinical outcomes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id142da630-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this chapter, the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"42 U.S.C. 201","children":[],"tail":" et seq.], or any other provision of Federal law, the Secretary may not use a clinical outcome associated with the use of an eligible investigational drug pursuant to this section to delay or adversely affect the review or approval of such drug under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"section 355 of this title","children":[],"tail":" or section 351 of the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"42 U.S.C. 262","children":[],"tail":"] unless—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id142da631-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary makes a determination, in accordance with paragraph (2), that use of such clinical outcome is critical to determining the safety of the eligible investigational drug; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142da632-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sponsor requests use of such outcomes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142da633-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary makes a determination under paragraph (1)(A), the Secretary shall provide written notice of such determination to the sponsor, including a public health justification for such determination, and such notice shall be made part of the administrative record. Such determination shall not be delegated below the director of the agency center that is charged with the premarket review of the eligible investigational drug.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id142da634-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id142da635-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The manufacturer or sponsor of an eligible investigational drug shall submit to the Secretary an annual summary of any use of such drug under this section. The summary shall include the number of doses supplied, the number of patients treated, the uses for which the drug was made available, and any known serious adverse events. The Secretary shall specify by regulation the deadline of submission of such annual summary and may amend section 312.33 of title 21, Code of Federal Regulations (or any successor regulations) to require the submission of such annual summary in conjunction with the annual report for an applicable investigational new drug application for such drug.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142da636-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Posting of information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall post an annual summary report of the use of this section on the internet website of the Food and Drug Administration, including the number of drugs for which clinical outcomes associated with the use of an eligible investigational drug pursuant to this section was—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id142da637-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used in accordance with subsection (c)(1)(A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142da638-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used in accordance with subsection (c)(1)(B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142da639-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0a/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not used in the review of an application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"section 355 of this title","children":[],"tail":" or section 351 of the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"42 U.S.C. 262","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id142da63a-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s561B"},"text":"June 25, 1938, ch. 675, § 561B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/176/s2/a"},"text":"Pub. L. 115–176, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-05-30"},"text":"May 30, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1372"},"text":"132 Stat. 1372","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id142da63b-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id142da63c-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id142da63d-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Public Health Service Act, referred to in subsec. (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"act July 1, 1944, ch. 373","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/682"},"text":"58 Stat. 682","children":[],"tail":", which is classified generally to chapter 6A (§ 201 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id142da63e-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id142da63f-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Limitation of Liability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/176/s2/b"},"text":"Pub. L. 115–176, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-05-30"},"text":"May 30, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1374"},"text":"132 Stat. 1374","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/176/s2/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alleged acts or omissions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to any alleged act or omission with respect to an eligible investigational drug provided to an eligible patient pursuant to section 561B of the Federal Food, Drug, and Cosmetic Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360bbb–0a"},"text":"21 U.S.C. 360bbb–0a","children":[],"tail":"] and in compliance with such section, no liability in a cause of action shall lie against—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sponsor or manufacturer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a prescriber, dispenser, or other individual entity (other than a sponsor or manufacturer), unless the relevant conduct constitutes reckless or willful misconduct, gross negligence, or an intentional tort under any applicable State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination not to provide drug","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No liability shall lie against a sponsor manufacturer, prescriber, dispenser or other individual entity for its determination not to provide access to an eligible investigational drug under section 561B of the Federal Food, Drug, and Cosmetic Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as set forth in paragraphs (1) and (2), nothing in this section shall be construed to modify or otherwise affect the right of any person to bring a private action under any State or Federal product liability, tort, consumer protection, or warranty law.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
