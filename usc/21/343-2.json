{"tag":"section","attrib":{"id":"id13c71c12-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s343–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"343–2"},"text":"§ 343–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dietary supplement labeling exemptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id13c71c13-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s343–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A publication, including an article, a chapter in a book, or an official abstract of a peer-reviewed scientific publication that appears in an article and was prepared by the author or the editors of the publication, which is reprinted in its entirety, shall not be defined as labeling when used in connection with the sale of a dietary supplement to consumers when it—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13c71c14-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s343–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not false or misleading;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13c71c15-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s343–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not promote a particular manufacturer or brand of a dietary supplement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13c71c16-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s343–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is displayed or presented, or is displayed or presented with other such items on the same subject matter, so as to present a balanced view of the available scientific information on a dietary supplement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13c71c17-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s343–2/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if displayed in an establishment, is physically separate from the dietary supplements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13c71c18-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s343–2/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not have appended to it any information by sticker or any other method.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13c71c19-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s343–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to or restrict a retailer or wholesaler of dietary supplements in any way whatsoever in the sale of books or other publications as a part of the business of such retailer or wholesaler.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13c71c1a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s343–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Burden of proof","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any proceeding brought under subsection (a), the burden of proof shall be on the United States to establish that an article or other such matter is false or misleading.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id13c71c1b-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s403B"},"text":"June 25, 1938, ch. 675, § 403B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/417/s5"},"text":"Pub. L. 103–417, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4328"},"text":"108 Stat. 4328","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
