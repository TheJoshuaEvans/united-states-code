{"tag":"section","attrib":{"id":"id14050f36-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d"},"text":null,"children":[{"tag":"num","attrib":{"value":"356d"},"text":"§ 356d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination; task force and strategic plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14050f37-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Task force and strategic plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14050f38-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14050f39-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Task force","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", the Secretary shall establish a task force to develop and implement a strategic plan for enhancing the Secretary’s response to preventing and mitigating drug shortages."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14050f3a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategic plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The strategic plan described in subparagraph (A) shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14050f3b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plans for enhanced interagency and intra-agency coordination, communication, and decisionmaking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14050f3c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plans for ensuring that drug shortages are considered when the Secretary initiates a regulatory action that could precipitate a drug shortage or exacerbate an existing drug shortage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14050f3d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plans for effective communication with outside stakeholders, including who the Secretary should alert about potential or actual drug shortages, how the communication should occur, and what types of information should be shared;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14050f3e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plans for considering the impact of drug shortages on research and clinical trials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14050f3f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d/a/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an examination of whether to establish a “qualified manufacturing partner program”, as described in subparagraph (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14050f40-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the examination of a “qualified manufacturing partner program” under subparagraph (B)(v), the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14050f41-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall take into account that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id14050f42-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d/a/1/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a “qualified manufacturer”, for purposes of such program, would need to have the capability and capacity to supply products determined or anticipated to be in shortage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14050f43-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d/a/1/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in examining the capability and capacity to supply products in shortage, the “qualified manufacturer” could have a site that manufactures a drug listed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s356e"},"text":"section 356e of this title","children":[],"tail":" or have the capacity to produce drugs in response to a shortage within a rapid timeframe; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14050f44-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall examine whether incentives are necessary to encourage the participation of “qualified manufacturers” in such a program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14050f45-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this paragraph, the task force shall ensure consultation with the appropriate offices within the Food and Drug Administration, including the Office of the Commissioner, the Center for Drug Evaluation and Research, the Office of Regulatory Affairs, and employees within the Department of Health and Human Services with expertise regarding drug shortages. The Secretary shall engage external stakeholders and experts as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14050f46-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", the task force shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14050f47-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish the strategic plan described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14050f48-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit such plan to Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14050f49-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Communication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that, prior to any enforcement action or issuance of a warning letter that the Secretary determines could reasonably be anticipated to lead to a meaningful disruption in the supply in the United States of a drug described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s356c/a"},"text":"section 356c(a) of this title","children":[],"tail":", there is communication with the appropriate office of the Food and Drug Administration with expertise regarding drug shortages regarding whether the action or letter could cause, or exacerbate, a shortage of the drug."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14050f4a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines, after the communication described in subsection (b), that an enforcement action or a warning letter could reasonably cause or exacerbate a shortage of a drug described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s356c/a"},"text":"section 356c(a) of this title","children":[],"tail":", then the Secretary shall evaluate the risks associated with the impact of such shortage upon patients and those risks associated with the violation involved before taking such action or issuing such letter, unless there is imminent risk of serious adverse health consequences or death to humans."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14050f4b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting by other entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall identify or establish a mechanism by which health care providers and other third-party organizations may report to the Secretary evidence of a drug shortage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14050f4c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No determination, finding, action, or omission of the Secretary under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14050f4d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be subject to judicial review; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14050f4e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be construed to establish a defense to an enforcement action by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14050f4f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall cease to be effective on the date that is 5 years after ","children":[{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":". Subsections (b), (c), and (e) shall not be in effect during the period beginning 5 years after "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":". Subsections (b), (c), and (e) shall be in effect beginning on "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14050f50-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure timely and effective internal coordination and alignment among the field investigators of the Food and Drug Administration and the staff of the Center for Drug Evaluation and Research’s Office of Compliance and Drug Shortage Program regarding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14050f51-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reviews of reports shared pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s374/b/2"},"text":"section 374(b)(2) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14050f52-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356d/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any feedback or corrective or preventive actions in response to such reports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14050f53-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s506D"},"text":"June 25, 1938, ch. 675, § 506D","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/144/tX/s1003"},"text":"Pub. L. 112–144, title X, § 1003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1103"},"text":"126 Stat. 1103","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tIII/s3616/a"},"text":"Pub. L. 117–328, div. FF, title III, § 3616(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5874"},"text":"136 Stat. 5874","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14050f54-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14050f55-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14050f56-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s3616/a/2"},"text":"Pub. L. 117–328, § 3616(a)(2)","children":[],"tail":", amended subsec. (f) generally. Prior to amendment, text read as follows: “Subsections (a), (b), (c), and (e) shall cease to be effective on the date that is 5 years after "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s3616/a/1"},"text":"Pub. L. 117–328, § 3616(a)(1)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
