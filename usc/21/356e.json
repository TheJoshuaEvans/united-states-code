{"tag":"section","attrib":{"id":"id14050f57-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356e"},"text":null,"children":[{"tag":"num","attrib":{"value":"356e"},"text":"§ 356e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drug shortage list","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14050f58-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall maintain an up-to-date list of drugs that are determined by the Secretary to be in shortage in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14050f59-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each drug on such list, the Secretary shall include the following information:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14050f5a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name of the drug in shortage, including the National Drug Code number for such drug.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14050f5b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name of each manufacturer of such drug.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14050f5c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The reason for the shortage, as determined by the Secretary, selecting from the following categories:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14050f5d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356e/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Requirements related to complying with good manufacturing practices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14050f5e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356e/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Regulatory delay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14050f5f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356e/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Shortage of an active ingredient.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14050f60-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356e/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Shortage of an inactive ingredient component.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14050f61-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356e/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Discontinuance of the manufacture of the drug.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14050f62-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356e/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Delay in shipping of the drug.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14050f63-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356e/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Demand increase for the drug.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14050f64-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356e/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The estimated duration of the shortage as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14050f65-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14050f66-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraphs (2) and (3), the Secretary shall make the information in such list publicly available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14050f67-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trade secrets and confidential information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section alters or amends ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1905"},"text":"section 1905 of title 18","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/4"},"text":"section 552(b)(4) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14050f68-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356e/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public health exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may choose not to make information collected under this section publicly available under paragraph (1) or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s356c/c"},"text":"section 356c(c) of this title","children":[],"tail":" if the Secretary determines that disclosure of such information would adversely affect the public health (such as by increasing the possibility of hoarding or other disruption of the availability of drug products to patients)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14050f69-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2020-03-27"},"text":"March 27, 2020","children":[],"tail":", and every 90 days thereafter, the Secretary shall transmit a report regarding the drugs of the current drug shortage list under this section to the Administrator of the Centers for Medicare & Medicaid Services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14050f6a-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s506E"},"text":"June 25, 1938, ch. 675, § 506E","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/144/tX/s1004"},"text":"Pub. L. 112–144, title X, § 1004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1104"},"text":"126 Stat. 1104","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIII/s3101/a/2/G"},"text":"Pub. L. 114–255, div. A, title III, § 3101(a)(2)(G)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1153"},"text":"130 Stat. 1153","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIII/s3112/c"},"text":"Pub. L. 116–136, div. A, title III, § 3112(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/362"},"text":"134 Stat. 362","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14050f6b-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14050f6c-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14050f6d-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136"},"text":"Pub. L. 116–136","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(3)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","children":[],"tail":", which directed substitution of “discontinuance” for “discontinuation”, was executed by substituting “Discontinuance” for “Discontinuation” to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14050f6e-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id14050f6f-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136"},"text":"Pub. L. 116–136","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/s3112/g"},"text":"section 3112(g) of Pub. L. 116–136","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s356c"},"text":"section 356c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
