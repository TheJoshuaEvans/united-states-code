{"tag":"section","attrib":{"id":"id1472c58d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384e"},"text":null,"children":[{"tag":"num","attrib":{"value":"384e"},"text":"§ 384e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognition of foreign government inspections","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1472c58e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1472c58f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may enter into arrangements and agreements with a foreign government or an agency of a foreign government to recognize the inspection of foreign establishments registered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360/i"},"text":"section 360(i) of this title","children":[],"tail":" in order to facilitate preapproval or risk-based inspections in accordance with the schedule established in paragraph (2) or (3) of "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360/h"},"text":"section 360(h) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1472c590-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may enter into arrangements and agreements with a foreign government or an agency of a foreign government under this section only with a foreign government or an agency of a foreign government that the Secretary has determined as having the capability of conducting inspections that meet the applicable requirements of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1472c591-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall perform such reviews and audits of drug safety programs, systems, and standards of a foreign government or agency for the foreign government as the Secretary deems necessary to determine that the foreign government or agency of the foreign government is capable of conducting inspections that meet the applicable requirements of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1472c592-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Results of inspection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The results of inspections performed by a foreign government or an agency of a foreign government under this section may be used as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1472c593-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence of compliance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s351/a/2/B"},"text":"section 351(a)(2)(B) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s381/r"},"text":"section 381(r) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1472c594-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any other purposes as determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1472c595-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1472c596-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", the Secretary shall periodically assess whether additional arrangements and agreements with a foreign government or an agency of a foreign government, as allowed under this section, are appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1472c597-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s384e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning not later than 4 years after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", and every 4 years thereafter, the Secretary shall submit to the Committee on Energy and Commerce of the House of Representatives and the Committee on Health, Education, Labor, and Pensions of the Senate a report describing the findings and conclusions of each review conducted under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1472c598-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s809"},"text":"June 25, 1938, ch. 675, § 809","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/144/tVII/s712"},"text":"Pub. L. 112–144, title VII, § 712","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1072"},"text":"126 Stat. 1072","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIII/s3101/a/2/X"},"text":"Pub. L. 114–255, div. A, title III, § 3101(a)(2)(X)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1156"},"text":"130 Stat. 1156","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/52/tVII/s701/b"},"text":"Pub. L. 115–52, title VII, § 701(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-18"},"text":"Aug. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1055"},"text":"131 Stat. 1055","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tIII/s3613/c"},"text":"Pub. L. 117–328, div. FF, title III, § 3613(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5872"},"text":"136 Stat. 5872","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1472c599-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1472c59a-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id1472c59b-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s3613/c/1"},"text":"Pub. L. 117–328, § 3613(c)(1)","children":[],"tail":", inserted “preapproval or” before “risk-based inspections”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s3613/c/2"},"text":"Pub. L. 117–328, § 3613(c)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/52"},"text":"Pub. L. 115–52","children":[],"tail":" substituted “paragraph (2) or (3) of section 360(h)” for “section 360(h)(3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","children":[],"tail":" substituted “conducting” for “conduction”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
