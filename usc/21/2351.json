{"tag":"section","attrib":{"id":"id14d95028-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2351"},"text":null,"children":[{"tag":"num","attrib":{"value":"2351"},"text":"§ 2351.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finding; policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14d95029-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2351/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Congress finds that international trafficking of fentanyl, fentanyl precursors, or other related opioids constitutes an unusual and extraordinary threat to the national security, foreign policy, and economy of the United States, and is a national emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d9502a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2351/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be the policy of the United States to apply economic and other financial sanctions to those who engage in the international trafficking of fentanyl, fentanyl precursors, or other related opioids to protect the national security, foreign policy, and economy of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14d9502b-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/50/dE/tI/s3101"},"text":"Pub. L. 118–50, div. E, title I, § 3101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-24"},"text":"Apr. 24, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/936"},"text":"138 Stat. 936","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
