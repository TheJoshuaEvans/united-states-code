{"tag":"section","attrib":{"id":"id148a9407-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s613"},"text":null,"children":[{"tag":"num","attrib":{"value":"613"},"text":"§ 613.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plans and reassessments","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require that each establishment subject to inspection under this chapter shall, at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id148a9408-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s613/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and maintain current procedures for the recall of all meat or meat food products produced and shipped by the establishment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id148a9409-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s613/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" document each reassessment of the process control plans of the establishment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id148a940a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s613/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon request, make the procedures and reassessed process control plans available to inspectors appointed by the Secretary for review and copying.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id148a940b-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1907-03-04/ch2907"},"text":"Mar. 4, 1907, ch. 2907","children":[],"tail":", title I, § 13, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/