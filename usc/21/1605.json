{"tag":"section","attrib":{"id":"id14c63d7f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605"},"text":null,"children":[{"tag":"num","attrib":{"value":"1605"},"text":"§ 1605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures for dismissal of civil actions against biomaterials suppliers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14c63d80-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motion to dismiss","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A defendant may, at any time during which a motion to dismiss may be filed under applicable law, move to dismiss an action against it on the grounds that the defendant is a biomaterials supplier and one or more of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c63d81-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The defendant is not liable as a manufacturer, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1604/b"},"text":"section 1604(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c63d82-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The defendant is not liable as a seller, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1604/c"},"text":"section 1604(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c63d83-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The defendant is not liable for furnishing raw materials or component parts for the implant that failed to meet applicable contractual requirements or specifications, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1604/d"},"text":"section 1604(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c63d84-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The claimant did not name the manufacturer as a party to the action, as provided in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c63d85-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manufacturer of implant shall be named a party","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any civil action covered by this chapter, the claimant shall be required to name the manufacturer of the implant as a party to the action, unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c63d86-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manufacturer is subject to service of process solely in a jurisdiction in which the biomaterials supplier is not domiciled or subject to a service of process; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c63d87-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a claim against the manufacturer is barred by applicable law or rule of practice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c63d88-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proceeding on motion to dismiss","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following rules shall apply to any proceeding on a motion to dismiss filed by a defendant under this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c63d89-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of motion to dismiss on discovery","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c63d8a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), if a defendant files a motion to dismiss under subsection (a), no discovery shall be permitted in connection with the action that is the subject of the motion, other than discovery necessary to determine a motion to dismiss for lack of jurisdiction, until such time as the court rules on the motion to dismiss.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c63d8b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discovery","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a defendant files a motion to dismiss under subsection (a)(3) on the grounds that it did not furnish raw materials or component parts for the implant that failed to meet applicable contractual requirements or specifications, the court may permit discovery limited to issues that are directly relevant to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14c63d8c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the pending motion to dismiss; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14c63d8d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the jurisdiction of the court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c63d8e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affidavits","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c63d8f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defendant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A defendant may submit affidavits supporting the grounds for dismissal contained in its motion to dismiss under subsection (a). If the motion is made under subsection (a)(1), the defendant may submit an affidavit demonstrating that the defendant has not included the implant on a list, if any, filed with the Secretary pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360/j"},"text":"section 360(j) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c63d90-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claimant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In response to a motion to dismiss, the claimant may submit affidavits demonstrating that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14c63d91-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary has, with respect to the defendant and the implant that allegedly caused harm to the claimant, issued a declaration pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1604/b/2/B"},"text":"section 1604(b)(2)(B) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14c63d92-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defendant is a seller of the implant who is liable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1604/c"},"text":"section 1604(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c63d93-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis of ruling on motion to dismiss","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The court shall rule on a motion to dismiss filed under subsection (a) solely on the basis of the pleadings and affidavits of the parties made pursuant to this subsection. The court shall grant a motion to dismiss filed under subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c63d94-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless the claimant submits a valid affidavit that demonstrates that the defendant is not a biomaterials supplier;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c63d95-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" unless the court determines, to the extent raised in the pleadings and affidavits, that one or more of the following apply:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14c63d96-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defendant may be liable as a manufacturer, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1604/b"},"text":"section 1604(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14c63d97-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defendant may be liable as a seller, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1604/c"},"text":"section 1604(c) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14c63d98-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defendant may be liable for furnishing raw materials or component parts for the implant that failed to meet applicable contractual requirements or specifications, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1604/d"},"text":"section 1604(d) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c63d99-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the claimant did not name the manufacturer as a party to the action, as provided in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c63d9a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of motion as motion for summary judgment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The court may treat a motion to dismiss as a motion for summary judgment subject to subsection (d) in order to determine whether the pleadings and affidavits, in connection with such action, raise genuine issues of material fact concerning whether the defendant furnished raw materials or component parts of the implant that failed to meet applicable contractual requirements or specifications as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1604/d"},"text":"section 1604(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c63d9b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summary judgment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c63d9c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c63d9d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis for entry of judgment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a motion to dismiss of a biomaterials supplier is to be treated as a motion for summary judgment under subsection (c)(4) or if a biomaterials supplier moves for summary judgment, the biomaterials supplier shall be entitled to entry of judgment without trial if the court finds there is no genuine issue of material fact for each applicable element set forth in paragraphs (1) and (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1604/d"},"text":"section 1604(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c63d9e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issues of material fact","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a finding made under subparagraph (A), the court shall consider a genuine issue of material fact to exist only if the evidence submitted by the claimant would be sufficient to allow a reasonable jury to reach a verdict for the claimant if the jury found the evidence to be credible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c63d9f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discovery made prior to a ruling on a motion for summary judgment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, under applicable rules, the court permits discovery prior to a ruling on a motion for summary judgment governed by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1604/d"},"text":"section 1604(d) of this title","children":[],"tail":", such discovery shall be limited solely to establishing whether a genuine issue of material fact exists as to the applicable elements set forth in paragraphs (1) and (2) of "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1604/d"},"text":"section 1604(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c63da0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discovery with respect to a biomaterials supplier","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A biomaterials supplier shall be subject to discovery in connection with a motion seeking dismissal or summary judgment on the basis of the inapplicability of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1604/d"},"text":"section 1604(d) of this title","children":[],"tail":" or the failure to establish the applicable elements of "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1604/d"},"text":"section 1604(d) of this title","children":[],"tail":" solely to the extent permitted by the applicable Federal or State rules for discovery against nonparties."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c63da1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dismissal with prejudice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An order granting a motion to dismiss or for summary judgment pursuant to this section shall be entered with prejudice, except insofar as the moving defendant may be rejoined to the action as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1606"},"text":"section 1606 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c63da2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1605/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manufacturer conduct of litigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The manufacturer of an implant that is the subject of an action covered under this chapter shall be permitted to conduct litigation on any motion for summary judgment or dismissal filed by a biomaterials supplier who is a defendant under this section on behalf of such supplier if the manufacturer and any other defendant in such action enter into a valid and applicable contractual agreement under which the manufacturer agrees to bear the cost of such litigation or to conduct such litigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14c63da3-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/230/s6"},"text":"Pub. L. 105–230, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-13"},"text":"Aug. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1526"},"text":"112 Stat. 1526","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14c63da4-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14c63da5-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id14c63da6-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to all civil actions covered under this chapter commenced on or after ","children":[{"tag":"date","attrib":{"date":"1998-08-13"},"text":"Aug. 13, 1998","children":[],"tail":", including any in which the harm or harmful conduct occurred before such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/230/s8"},"text":"section 8 of Pub. L. 105–230","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1601"},"text":"section 1601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
