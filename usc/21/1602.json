{"tag":"section","attrib":{"id":"id14c63d07-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602"},"text":null,"children":[{"tag":"num","attrib":{"value":"1602"},"text":"§ 1602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":" As used in this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c63d08-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biomaterials supplier","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c63d09-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “biomaterials supplier” means an entity that directly or indirectly supplies a component part or raw material for use in the manufacture of an implant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c63d0a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such term includes any person who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14c63d0b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has submitted master files to the Secretary for purposes of premarket approval of a medical device; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14c63d0c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" licenses a biomaterials supplier to produce component parts or raw materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c63d0d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claimant","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c63d0e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “claimant” means any person who brings a civil action, or on whose behalf a civil action is brought, arising from harm allegedly caused directly or indirectly by an implant, including a person other than the individual into whose body, or in contact with whose blood or tissue, the implant is placed, who claims to have suffered harm as a result of the implant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c63d0f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action brought on behalf of an estate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to an action brought on behalf of or through the estate of a deceased individual into whose body, or in contact with whose blood or tissue the implant was placed, such term includes the decedent that is the subject of the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c63d10-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action brought on behalf of a minor or incompetent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to an action brought on behalf of or through a minor or incompetent, such term includes the parent or guardian of the minor or incompetent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c63d11-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such term does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14c63d12-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a provider of professional health care services in any case in which—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id14c63d13-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/2/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale or use of an implant is incidental to such services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14c63d14-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/2/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the essence of the professional health care services provided is the furnishing of judgment, skill, or services;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14c63d15-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person acting in the capacity of a manufacturer, seller, or biomaterials supplier; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14c63d16-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a person alleging harm caused by either the silicone gel or the silicone envelope utilized in a breast implant containing silicone gel, except that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id14c63d17-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/2/D/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" neither the exclusion provided by this clause nor any other provision of this chapter may be construed as a finding that silicone gel (or any other form of silicone) may or may not cause harm; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14c63d18-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/2/D/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the existence of the exclusion under this clause may not—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id14c63d19-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/2/D/iii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be disclosed to a jury in any civil action or other proceeding; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id14c63d1a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/2/D/iii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as necessary to establish the applicability of this chapter, otherwise be presented in any civil action or other proceeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c63d1b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Component part","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c63d1c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “component part” means a manufactured piece of an implant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c63d1d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain components","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such term includes a manufactured piece of an implant that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14c63d1e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has significant non-implant applications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14c63d1f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alone, has no implant value or purpose, but when combined with other component parts and materials, constitutes an implant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c63d20-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Harm","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c63d21-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “harm” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14c63d22-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any injury to or damage suffered by an individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14c63d23-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any illness, disease, or death of that individual resulting from that injury or damage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14c63d24-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any loss to that individual or any other individual resulting from that injury or damage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c63d25-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term does not include any commercial loss or loss of or damage to an implant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c63d26-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “implant” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c63d27-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a medical device that is intended by the manufacturer of the device—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14c63d28-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be placed into a surgically or naturally formed or existing cavity of the body for a period of at least 30 days; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14c63d29-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to remain in contact with bodily fluids or internal human tissue through a surgically produced opening for a period of less than 30 days; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c63d2a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suture materials used in implant procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c63d2b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manufacturer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “manufacturer” means any person who, with respect to an implant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c63d2c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is engaged in the manufacture, preparation, propagation, compounding, or processing (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360/a/1"},"text":"section 360(a)(1) of this title","children":[],"tail":") of the implant; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c63d2d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is required—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14c63d2e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to register with the Secretary pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360"},"text":"section 360 of this title","children":[],"tail":" and the regulations issued under such section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14c63d2f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to include the implant on a list of devices filed with the Secretary pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360/j"},"text":"section 360(j) of this title","children":[],"tail":" and the regulations issued under such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c63d30-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical device","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “medical device” means a device, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s321/h"},"text":"section 321(h) of this title","children":[],"tail":", and includes any device component of any combination product as that term is used in "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s353/g"},"text":"section 353(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c63d31-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Raw material","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “raw material” means a substance or product that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c63d32-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a generic use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c63d33-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be used in an application other than an implant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c63d34-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c63d35-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seller","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c63d36-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “seller” means a person who, in the course of a business conducted for that purpose, sells, distributes, leases, packages, labels, or otherwise places an implant in the stream of commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c63d37-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14c63d38-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/10/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a seller or lessor of real property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14c63d39-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/10/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a provider of professional health care services in any case in which—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id14c63d3a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/10/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale or use of the implant is incidental to such services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14c63d3b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/10/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the essence of the professional health care services provided is the furnishing of judgment, skill, or services; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14c63d3c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1602/10/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person who acts in only a financial capacity with respect to the sale of an implant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14c63d3d-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/230/s3"},"text":"Pub. L. 105–230, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-13"},"text":"Aug. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1520"},"text":"112 Stat. 1520","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14c63d3e-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14c63d3f-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id14c63d40-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to all civil actions covered under this chapter commenced on or after ","children":[{"tag":"date","attrib":{"date":"1998-08-13"},"text":"Aug. 13, 1998","children":[],"tail":", including any in which the harm or harmful conduct occurred before such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/230/s8"},"text":"section 8 of Pub. L. 105–230","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1601"},"text":"section 1601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
