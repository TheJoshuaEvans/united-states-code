{"tag":"section","attrib":{"id":"id146928e7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73"},"text":null,"children":[{"tag":"num","attrib":{"value":"379j–73"},"text":"§ 379j–73.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reauthorization; reporting requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id146928e8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id146928e9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 calendar days after the end of each fiscal year for which fees are collected under this subpart, the Secretary shall prepare and submit to the Committee on Energy and Commerce of the House of Representatives and the Committee on Health, Education, Labor, and Pensions of the Senate a report concerning the progress of the Food and Drug Administration in achieving the goals identified in the letters described in section 6502 of the Over-the-Counter Monograph Drug User Fee Amendments during such fiscal year and the future plans of the Food and Drug Administration for meeting such goals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id146928ea-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning with fiscal year 2026, the annual report under this subsection shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id146928eb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the progress of the Food and Drug Administration in achieving the goals, and future plans for meeting the goals, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id146928ec-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of Tier 1 OTC monograph order requests for which a proposed order was issued, and the number of such requests for which a final order was issued, in the previous fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id146928ed-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of Tier 2 OTC monograph order requests for which a proposed order was issued, and the number of such requests for which a final order was issued, in the previous fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id146928ee-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of specified safety OTC monograph order requests for which a proposed order was issued, and the number of such requests for which a final order was issued, in the previous fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id146928ef-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of generally recognized as safe and effective finalization OTC monograph order requests for which a proposed order was issued, and the number of such requests for which a final order was issued, in the previous fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id146928f0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/a/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average timeline for processing OTC monograph order requests, in the aggregate and by submission type, in the previous fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id146928f1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/a/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" postmarket safety activities with respect to OTC monograph drugs, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id146928f2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/a/2/A/vi/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collecting, developing, and reviewing safety information on OTC monograph drugs, including adverse event reports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id146928f3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/a/2/A/vi/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and using improved analytical tools, adverse event data-collection systems, including information technology systems, to assess potential safety problems, including access to external databases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id146928f4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/a/2/A/vi/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s379aa"},"text":"section 379aa of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id146928f5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information regarding registration of OTC monograph drug facilities and contract manufacturing organization facilities and payment of registration fees by such facilities, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id146928f6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the OTC monograph drug facilities and contract manufacturing organization facilities that were first registered under section 360(c) or 360(i) of this title in the fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id146928f7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each OTC monograph drug facility and contract manufacturing organization facility that was assessed a facility fee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s379j–72/a"},"text":"section 379j–72(a) of this title","children":[],"tail":" in the fiscal year, whether the facility paid such fee;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id146928f8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the status of implementation of evidence and testing standards under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355h/r"},"text":"section 355h(r) of this title","children":[],"tail":" for nonprescription drugs intended for topical administration, including—"}],"tail":null},{"tag":"clause","attrib":{"id":"id146928f9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application of evidence or testing standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id146928fa-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of active ingredient requests for nonprescription drugs intended for topical administration reviewed using the standards under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355h/b"},"text":"section 355h(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id146928fb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress of the Food and Drug Administration in allowing nonclinical testing alternatives to animal testing for the consideration of sunscreen active ingredients.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id146928fc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in paragraph (2) shall be construed to authorize the disclosure of information that is prohibited from disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s331/j"},"text":"section 331(j) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1905"},"text":"section 1905 of title 18","children":[],"tail":" or that is subject to withholding under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/4"},"text":"section 552(b)(4) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id146928fd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 calendar days after the end of each fiscal year for which fees are collected under this subpart, the Secretary shall prepare and submit to the Committee on Energy and Commerce of the House of Representatives and the Committee on Health, Education, Labor, and Pensions of the Senate a report on the implementation of the authority for such fees during such fiscal year and the use, by the Food and Drug Administration, of the fees collected for such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id146928fe-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make the reports required under subsections (a) and (b) available to the public on the internet website of the Food and Drug Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id146928ff-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reauthorization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14692900-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing recommendations to present to the Congress with respect to the goals described in subsection (a), and plans for meeting the goals, for OTC monograph drug activities for the first 5 fiscal years after fiscal year 2030, and for the reauthorization of this subpart for such fiscal years, the Secretary shall consult with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14692901-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Commerce of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14692902-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Health, Education, Labor, and Pensions of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14692903-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scientific and academic experts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14692904-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health care professionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14692905-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of patient and consumer advocacy groups; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14692906-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the regulated industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14692907-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public review of recommendations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After negotiations with the regulated industry, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14692908-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" present the recommendations developed under paragraph (1) to the congressional committees specified in such paragraph;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14692909-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish such recommendations in the Federal Register;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1469290a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for a period of 30 calendar days for the public to provide written comments on such recommendations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1469290b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold a meeting at which the public may present its views on such recommendations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1469290c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after consideration of such public views and comments, revise such recommendations as necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1469290d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmittal of recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2030-01-15"},"text":"January 15, 2030","children":[],"tail":", the Secretary shall transmit to the Congress the revised recommendations under paragraph (2), a summary of the views and comments received under such paragraph, and any changes made to the recommendations in response to such views and comments."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1469290e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minutes of negotiation meetings","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1469290f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make publicly available, on the public website of the Food and Drug Administration, robust written minutes of all negotiation meetings conducted under this subsection between the Food and Drug Administration and the regulated industry, not later than 30 days after each such negotiation meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14692910-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–73/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The robust written minutes described under subparagraph (A) shall contain, in detail, any substantive proposal made by any party to the negotiations as well as significant controversies or differences of opinion during the negotiations and their resolution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14692911-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s744N"},"text":"June 25, 1938, ch. 675, § 744N","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIII/s3862"},"text":"Pub. L. 116–136, div. A, title III, § 3862","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/468"},"text":"134 Stat. 468","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/37/dF/tV/s6505/a"},"text":"Pub. L. 119–37, div. F, title V, § 6505(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-11-12"},"text":"Nov. 12, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/642"},"text":"139 Stat. 642","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14692912-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id14692913-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/37/s6509/b"},"text":"section 6509(b) of Pub. L. 119–37","children":[],"tail":", see Termination Date note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14692914-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14692915-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 6502 of the Over-the-Counter Monograph Drug User Fee Amendments, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/37/dF/tV/s6502"},"text":"section 6502 of title V of div. F of Pub. L. 119–37","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s379j–71"},"text":"section 379j–71 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14692916-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/37/s6505/a/1"},"text":"Pub. L. 119–37, § 6505(a)(1)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, substituted “Not later than 120 calendar days after the end of each fiscal year” for “Beginning with fiscal year 2021, and not later than 120 calendar days after the end of