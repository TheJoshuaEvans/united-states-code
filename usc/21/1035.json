{"tag":"section","attrib":{"id":"id14bc9f7b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1035"},"text":null,"children":[{"tag":"num","attrib":{"value":"1035"},"text":"§ 1035.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanitary operating practices in official plants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14bc9f7c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1035/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Premises, facilities, and equipment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each official plant shall be operated in accordance with such sanitary practices and shall have such premises, facilities, and equipment as are required by regulations promulgated by the Secretary to effectuate the purposes of this chapter, including requirements for segregation and disposition of restricted eggs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14bc9f7d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1035/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refusal by Secretary to inspect nonconforming plants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall refuse to render inspection to any plant whose premises, facilities, or equipment, or the operation thereof, fail to meet the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14bc9f7e-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/597/s6"},"text":"Pub. L. 91–597, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-29"},"t