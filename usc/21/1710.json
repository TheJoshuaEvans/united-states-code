{"tag":"section","attrib":{"id":"id14cfb27d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710"},"text":null,"children":[{"tag":"num","attrib":{"value":"1710"},"text":"§ 1710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drug Interdiction Coordinator and Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14cfb27e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Interdiction Coordinator","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14cfb27f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall designate or appoint an appointee in the Senior Executive Service or an appointee in a position at level 15 of the General Schedule (or equivalent) as the United States Interdiction Coordinator to perform the duties of that position described in paragraph (2) and such other duties as may be determined by the Director with respect to coordination of efforts to interdict illicit drugs from entering the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14cfb280-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The United States Interdiction Coordinator shall be responsible to the Director for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14cfb281-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating the interdiction activities of the National Drug Control Program agencies to ensure consistency with the National Drug Control Strategy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14cfb282-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on behalf of the Director, developing and issuing, on or before September 1 of each year and in accordance with paragraph (4), a National Interdiction Command and Control Plan to ensure the coordination and consistency described in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14cfb283-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the sufficiency of assets committed to illicit drug interdiction by the relevant National Drug Control Program agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14cfb284-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advising the Director on the efforts of each National Drug Control Program agency to implement the National Interdiction Command and Control Plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14cfb285-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall assign such permanent staff of the Office as he considers appropriate to assist the United States Interdiction Coordinator to carry out the responsibilities described in paragraph (2), and may request that appropriate National Drug Control Program agencies detail or assign staff to assist in carrying out such responsibilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14cfb286-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Interdiction Command and Control Plan","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14cfb287-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Interdiction Command and Control Plan shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14cfb288-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth the Government’s strategy for drug interdiction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14cfb289-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state the specific roles and responsibilities of the relevant National Drug Control Program agencies for implementing that strategy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14cfb28a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/a/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the specific resources required to enable the relevant National Drug Control Program agencies to implement that strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14cfb28b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with other agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before submission of the National Drug Control Strategy or annual assessment required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1705"},"text":"section 1705 of this title","children":[],"tail":", as applicable, the United States Interdiction Coordinator shall issue the National Interdiction Command and Control Plan in consultation with the other members of the Interdiction Committee described in subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14cfb28c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On or before September 1 of each year, the Director, acting through the United States Interdiction Coordinator, shall provide to the appropriate congressional committees, to the Committee on Armed Services and the Committee on Homeland Security of the House of Representatives, and to the Committee on Homeland Security and Governmental Affairs and the Committee on Armed Services of the Senate a report that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14cfb28d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/a/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id14cfb28e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/a/4/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of that year’s National Interdiction Command and Control Plan, including information about how each National Drug Control Program agency conducting drug interdiction activities is engaging with relevant international partners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14cfb28f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/a/4/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information for the previous 10 years regarding the number and type of seizures of drugs by each National Drug Control Program agency conducting drug interdiction activities and statistical information on the geographic areas of such seizures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14cfb290-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/a/4/C/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information for the previous 10 years regarding the number of air and maritime patrol hours undertaken by each National Drug Control Program agency conducting drug interdiction activities and statistical information on the geographic areas in which such patrol hours took place; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14cfb291-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/a/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include recommendations for changes to existing agency authorities or laws governing interagency relationships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14cfb292-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classified annex","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report required to be submitted under subparagraph (C) shall be in unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14cfb293-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interdiction Committee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14cfb294-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Interdiction Committee shall meet to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14cfb295-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discuss and resolve issues related to the coordination, oversight and integration of international, border, and domestic drug interdiction efforts in support of the National Drug Control Strategy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14cfb296-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the annual National Interdiction Command and Control Plan, and provide advice to the Director and the United States Interdiction Coordinator concerning that plan and how to strengthen international partnerships to better achieve the goals of that plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14cfb297-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide such other advice to the Director concerning drug interdiction strategy and policies as the committee determines is appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14cfb298-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall designate one of the members of the Interdiction Committee to serve as Chairperson.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14cfb299-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Interdiction Committee shall meet, in person and not through any delegate or representative, at least once per calendar year, before June 1. At the call of the Director or the Chairperson, the Interdiction Committee may hold additional meetings, which shall be attended by the members in person, or through such delegates or representatives as the members may choose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14cfb29a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than September 30 of each year, the Chairperson of the Interdiction Committee shall submit to the Director and to the appropriate congressional committees a report describing the results of the meetings and any significant findings of the Committee during the previous 12 months. The report required under this paragraph shall be in unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14cfb29b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1710/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may facilitate international drug control coordination efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14cfb29c-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tVII/s711"},"text":"Pub. L. 105–277, div. C, title VII, § 711","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/469/tI/s103/f/1"},"text":"Pub. L. 109–469, title I, § 103(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-29"},"text":"Dec. 29, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3507"},"text":"120 Stat. 3507","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tVII/s715"},"text":"Pub. L. 105–277, div. C, title VII, § 715","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-693"},"text":"112 Stat. 2681–693","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/469/tVI/s602"},"text":"Pub. L. 109–469, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-29"},"text":"Dec. 29, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3533"},"text":"120 Stat. 3533","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVIII"},"text":"Pub. L. 115–271, title VIII","children":[],"tail":", §§ 8202(a), (b)(2), 8219, "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4110"},"text":"132 Stat. 4110","children":[],"tail":", 4132.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14cfb29d-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14cfb29e-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14cfb29f-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Schedule, referred to in subsec. (a)(1), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id14cfb2a0-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s711"},"text":"section 711 of Pub. L. 105–277","children":[],"tail":", div. C, title VII, "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-691"},"text":"112 Stat. 2681–691","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tVII/s715"},"text":"Pub. L. 105–277, div. C, title VII, § 715","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-693"},"text":"112 Stat. 2681–693","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/469/tVI/s602"},"text":"Pub. L. 109–469, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-29"},"text":"Dec. 29, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3553"},"text":"120 Stat. 3553","children":[],"tail":", related to drug interdiction, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVIII/s8219/a"},"text":"Pub. L. 115–271, title VIII, § 8219(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4132"},"text":"132 Stat. 4132","children":[],"tail":". See 2018 and 2006 Amendment notes below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14cfb2a1-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8219/a"},"text":"Pub. L. 115–271, § 8219(a)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tVII/s711"},"text":"Pub. L. 105–277, div. C, title VII, § 711","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-691"},"text":"112 Stat. 2681–691","children":[],"tail":". See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8202/b/2"},"text":"Pub. L. 115–271, § 8202(b)(2)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s715"},"text":"Pub. L. 105–277, § 715","children":[],"tail":". See 1998 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8202/a"},"text":"Pub. L. 115–271, § 8202(a)","children":[],"tail":", revived and restored this section as in effect on "},{"tag":"date","attrib":{"date":"2003-09-29"},"text":"Sept. 29, 2003","children":[],"tail":", and as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/469"},"text":"Pub. L. 109–469","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/112/166"},"text":"Pub. L. 112–166","children":[],"tail":". See Reauthorization of the Office of National Drug Control Policy note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1701"},"text":"section 1701 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8219/b/1/A"},"text":"Pub. L. 115–271, § 8219(b)(1)(A)","children":[],"tail":", substituted “The Director shall designate or appoint an appointee in the Senior Executive Service or an appointee in a position at level 15 of the General Schedule (or equivalent) as the United” for “The United” and “to perform” for “shall perform”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8219/b/1/B"},"text":"Pub. L. 115–271, § 8219(b)(1)(B)","children":[],"tail":", substituted “September 1” for “March 1” and “paragraph (4)” for “paragraph (3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8219/b/1/C"},"text":"Pub. L. 115–271, § 8219(b)(1)(C)","children":[],"tail":", struck out “also, at his discretion,” after “and may” and substituted “assist in carrying out such responsibilities” for “the Office of Supply Reduction for that purpose”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8219/b/1/D/i"},"text":"Pub. L. 115–271, § 8219(b)(1)(D)(i)","children":[],"tail":", substituted “Before submission of the National Drug Control Strategy or annual assessment required under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1705"},"text":"section 1705 of this title","children":[],"tail":", as applicable, the United” for “The United”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8219/b/1/D/iv/I"},"text":"Pub. L. 115–271, § 8219(b)(1)(D)(iv)(I)","children":[],"tail":", in introductory provisions, substituted “September 1” for “March 1” and “a report that” for “, which shall include”, inserted “the Director, acting through” after “each year,” and a comma after “Coordinator”, and struck out “a report on behalf of the Director” after “shall provide”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8219/b/1/D/ii"},"text":"Pub. L. 115–271, § 8219(b)(1)(D)(ii)","children":[],"tail":", (iii), redesignated subpar. (D) as (C) and struck out former subpar. (C). Prior to amendment, text of subpar. (C) read as follows: “The National Interdiction Command and Control Plan shall not change existing agency authorities or the laws governing interagency relationships, but may include recommendations about changes to such authorities or laws.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(C)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8219/b/1/D/iv/II"},"text":"Pub. L. 115–271, § 8219(b)(1)(D)(iv)(II)","children":[],"tail":", (III), inserted cl. (i) designation and introductory provisions and redesignated former cls. (i) to (iii) as subcls. (I) to (III), respectively, of cl. (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(C)(i)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8219/b/1/D/iv/IV/aa"},"text":"Pub. L. 115–271, § 8219(b)(1)(D)(iv)(IV)(aa)","children":[],"tail":", inserted “, including information about how each National Drug Control Program agency conducting drug interdiction activities is engaging with relevant international partners” after “Plan”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(C)(i)(II). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8219/b/1/D/iv/IV/bb"},"text":"Pub. L. 115–271, § 8219(b)(1)(D)(iv)(IV)(bb)","children":[],"tail":", substituted “and statistical” for “, as well as statistical”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(C)(i)(III). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8219/b/1/D/iv/IV/cc"},"text":"Pub. L. 115–271, § 8219(b)(1)(D)(iv)(IV)(cc)","children":[],"tail":", substituted “and statistical” for “, as well as statistical” and “; and” for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8219/b/1/D/iv/V"},"text":"Pub. L. 115–271, § 8219(b)(1)(D)(iv)(V)","children":[],"tail":", added cl. (ii). Former cl. (ii) redesignated subcl. (II) of cl. (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(C)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8219/b/1/D/iv/II"},"text":"Pub. L. 115–271, § 8219(b)(1)(D)(iv)(II)","children":[],"tail":", redesignated cl. (iii) as subcl. (III) of cl. (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8219/b/1/D/v"},"text":"Pub. L. 115–271, § 8219(b)(1)(D)(v)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8219/b/2/A"},"text":"Pub. L. 115–271, § 8219(b)(2)(A)","children":[],"tail":", inserted “and how to strengthen international partnerships to better achieve the goals of that plan” after “that plan”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8219/b/2/B"},"text":"Pub. L. 115–271, § 8219(b)(2)(B)","children":[],"tail":", substituted “Chairperson” for “Chairman” in heading and for “chairman” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8219/b/2/C"},"text":"Pub. L. 115–271, § 8219(b)(2)(C)","children":[],"tail":", substituted “before June 1” for “prior to March 1”, “Chairperson” for “current chairman”, and “the members may” for “they may” and struck out “either” after “the call of” and after “by the members”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8219/b/2/D"},"text":"Pub. L. 115–271, § 8219(b)(2)(D)","children":[],"tail":", struck out “a report” after “shall submit”, inserted “a report” after “committees”, and substituted “Chairperson of the Interdiction Committee” for “chairman of the Interdiction Committee” and “The report required under this paragraph shall be in unclassified form, but may include a classified annex.” for “Any content of such a report that involves information classified under criteria established by an Executive order, or whose public disclosure, as determined by the Director, the chairman, or any member, would be detrimental to the law enforcement or national security activities of any Federal, State, local, or tribal agency, shall be presented to Congress separately from the rest of the report.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8219/b/3"},"text":"Pub. L. 115–271, § 8219(b)(3)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/469/s602"},"text":"Pub. L. 109–469, § 602","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s715"},"text":"Pub. L. 105–277, § 715","children":[],"tail":", which provided for the repeal of this section. See 1998 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/469/s103/f/1"},"text":"Pub. L. 109–469, § 103(f)(1)","children":[],"tail":", directed that section 711 of Office of National Drug Control Policy Reauthorization Act of 1998 ("},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tVII"},"text":"Pub. L. 105–277, div. C, title VII","children":[],"tail":") be amended by “adding at the end” a new section 711, which comprises this section. A prior section 711 of the Act was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8219/a"},"text":"Pub. L. 115–271, § 8219(a)","children":[],"tail":". See 2018 Amendment note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s715"},"text":"Pub. L. 105–277, § 715","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/469/s602"},"text":"Pub. L. 109–469, § 602","children":[],"tail":", which provided for the repeal of title VII of the Office of National Drug Control Policy Reauthorization Act of 1988 ("},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tVII"},"text":"Pub. L. 105–277, div. C, title VII","children":[],"tail":") effective "},{"tag":"date","attrib":{"date":"2010-09-30"},"text":"Sept. 30, 2010","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8202/b/2"},"text":"Pub. L. 115–271, § 8202(b)(2)","children":[],"tail":". See former "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1712"},"text":"section 1712 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
