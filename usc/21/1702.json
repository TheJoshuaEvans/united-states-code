{"tag":"section","attrib":{"id":"id14c886ea-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1702"},"text":null,"children":[{"tag":"num","attrib":{"value":"1702"},"text":"§ 1702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of National Drug Control Policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14c886eb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Office","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established in the Executive Office of the President an Office of National Drug Control Policy, which shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c886ec-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1702/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lead the national drug control effort, including coordinating with the National Drug Control Program agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c886ed-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1702/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate and oversee the implementation of the national drug control policy, including the National Drug Control Strategy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c886ee-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1702/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess and certify the adequacy of National Drug Control Programs and the budget for those programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c886ef-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1702/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the effectiveness of national drug control policy efforts, including the National Drug Control Program Agencies’ ","children":[{"tag":"ref","attrib":{"idref":"fn002182"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002182"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “agencies’ ”."}],"tail":" programs, by developing and applying specific goals and performance measurements and monitoring the agencies’ program-level spending;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c886f0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1702/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and respond to emerging drug threats related to illicit drug use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c886f1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1702/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer the Drug-Free Communities Program, the High Intensity Drug Trafficking Areas Program, and other grant programs directly authorized to be administered by the Office in furtherance of the National Drug Control Strategy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c886f2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1702/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate broad-scale information sharing and data standardization among Federal, State, and local entities to support the national drug control efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c886f3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVIII/s8222/1"},"text":"Pub. L. 115–271, title VIII, § 8222(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4142"},"text":"132 Stat. 4142","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c886f4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access by Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The location of the Office in the Executive Office of the President shall not be construed as affecting access by Congress, or any committee of the House of Representatives or the Senate, to any—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c886f5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1702/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information, document, or study in the possession of, or conducted by or at the direction of the Director; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c886f6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1702/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personnel of the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c886f7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1702/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of National Drug Control Policy Gift Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c886f8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1702/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a fund for the receipt of gifts, both real and personal, for the purpose of aiding or facilitating the work of the Office under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1703/c"},"text":"section 1703(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c886f9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1702/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office may accept, hold, and administer contributions to the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c886fa-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1702/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of amounts deposited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts deposited in the Fund are authorized to be appropriated, to remain available until expended for authorized purposes at the discretion of the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c886fb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1702/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ethics guidelines","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall establish written guidelines setting forth the criteria to be used in determining whether a gift or donation should be declined under this subsection because the acceptance of the gift or donation would—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c886fc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1702/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflect unfavorably upon the ability of the Director or the Office, or any employee of the Office, to carry out responsibilities or official duties under this chapter in a fair and objective manner; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c886fd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1702/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compromise the integrity or the appearance of integrity of programs or services provided under this chapter or of any official involved in those programs or services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c886fe-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1702/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registry of gifts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall maintain a list of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c886ff-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1702/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the source and amount of each gift or donation accepted by the Office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c88700-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1702/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the source and amount of each gift or donation accepted by a contractor to be used in its performance of a contract for the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c88701-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1702/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall include in the annual assessment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1705/g"},"text":"section 1705(g) of this title","children":[],"tail":" a copy of the registry maintained under paragraph (5)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14c88702-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tVII"},"text":"Pub. L. 105–277, div. C, title VII","children":[],"tail":", §§ 703, 715, "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-672"},"text":"112 Stat. 2681–672","children":[],"tail":", 2681–693; "},{"tag":"ref","attrib":{"href":"/us/pl/109/469/tI/s102"},"text":"Pub. L. 109–469, title I, § 102","children":[],"tail":", title VI, § 602, title XI, § 1120, "},{"tag":"date","attrib":{"date":"2006-12-29"},"text":"Dec. 29, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3505"},"text":"120 Stat. 3505","children":[],"tail":", 3533, 3548; "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVIII"},"text":"Pub. L. 115–271, title VIII","children":[],"tail":", §§ 8202(a), (b)(2), 8217(a), (b), 8222(1), "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4110"},"text":"132 Stat. 4110","children":[],"tail":", 4119, 4142; "},{"tag":"ref","attrib":{"href":"/us/pl/116/74/s2/a/2"},"text":"Pub. L. 116–74, § 2(a)(2)","children":[],"tail":", (4), "},{"tag":"date","attrib":{"date":"2019-11-27"},"text":"Nov. 27, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1155"},"text":"133 Stat. 1155","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14c88703-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14c88704-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14c88705-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (d)(4), was in the original a reference to “this title”, meaning title VII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC"},"text":"Pub. L. 105–277, div. C","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-670"},"text":"112 Stat. 2681–670","children":[],"tail":", which is classified principally to this chapter. For complete classification of title VII to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1701"},"text":"section 1701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14c88706-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/74/s2/a/2"},"text":"Pub. L. 116–74, § 2(a)(2)","children":[],"tail":", substituted “National Drug Control Program agencies” for “National Drug Control Program Agencies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/74/s2/a/4/A/i"},"text":"Pub. L. 116–74, § 2(a)(4)(A)(i)","children":[],"tail":", substituted “programs,” for “program,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/74/s2/a/4/A/ii"},"text":"Pub. L. 116–74, § 2(a)(4)(A)(ii)","children":[],"tail":", substituted “High Intensity” for “High-Intensity”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/74/s2/a/4/B"},"text":"Pub. L. 116–74, § 2(a)(4)(B)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to this chapter in subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8202/b/2"},"text":"Pub. L. 115–271, § 8202(b)(2)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s715"},"text":"Pub. L. 105–277, § 715","children":[],"tail":". See 1998 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8202/a"},"text":"Pub. L. 115–271, § 8202(a)","children":[],"tail":", revived and restored this section as in effect on "},{"tag":"date","attrib":{"date":"2003-09-29"},"text":"Sept. 29, 2003","children":[],"tail":", and as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/469"},"text":"Pub. L. 109–469","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/112/166"},"text":"Pub. L. 112–166","children":[],"tail":". See Reauthorization of the Office of National Drug Control Policy note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1701"},"text":"section 1701 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8217/a/4"},"text":"Pub. L. 115–271, § 8217(a)(4)","children":[],"tail":", struck out concluding provisions which read as follows: “When developing the national drug control policy, any policy of the Director relating to syringe exchange programs for intravenous drug users shall be based on the best available medical and scientific evidence regarding their effectiveness in promoting individual health and preventing the spread of infectious disease, and their impact on drug addiction and use. In making any policy relating to syringe exchange programs, the Director shall consult with the National Institutes of Health and the National Academy of Sciences.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8217/a/1"},"text":"Pub. L. 115–271, § 8217(a)(1)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “develop national drug control policy;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8217/a/2"},"text":"Pub. L. 115–271, § 8217(a)(2)","children":[],"tail":", inserted before semicolon at end “, including the National Drug Control Strategy”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8217/a/3"},"text":"Pub. L. 115–271, § 8217(a)(3)","children":[],"tail":", (4), added pars. (4) to (7) and struck out former par. (4) which read as follows: “evaluate the effectiveness of the national drug control policy and the National Drug Control Program agencies’ programs, by developing and applying specific goals and performance measurements.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8222/1"},"text":"Pub. L. 115–271, § 8222(1)","children":[],"tail":", struck out subsec. (b) which related to Director of National Drug Control Policy and Deputy Directors."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8217/b"},"text":"Pub. L. 115–271, § 8217(b)","children":[],"tail":", added pars. (4) to (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/469/s602"},"text":"Pub. L. 109–469, § 602","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s715"},"text":"Pub. L. 105–277, § 715","children":[],"tail":", which provided for the repeal of this section. See 1998 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/469/s1120"},"text":"Pub. L. 109–469, § 1120","children":[],"tail":", inserted concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/469/s102/a"},"text":"Pub. L. 109–469, § 102(a)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) related to establishment of Office of National Drug Control Policy."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/469/s102/b"},"text":"Pub. L. 109–469, § 102(b)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) related to Director and Deputy Directors of National Drug Control Policy."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s715"},"text":"Pub. L. 105–277, § 715","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/469/s602"},"text":"Pub. L. 109–469, § 602","children":[],"tail":", which provided for the repeal of this section effective "},{"tag":"date","attrib":{"date":"2010-09-30"},"text":"Sept. 30, 2010","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/s8202/b/2"},"text":"Pub. L. 115–271, § 8202(b)(2)","children":[],"tail":". See former "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1712"},"text":"section 1712 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14c88707-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id14c88708-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Gifts to Office of National Drug Control Policy","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/75/dE/tII"},"text":"Pub. L. 119–75, div. E, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-02-03"},"text":"Feb. 3, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/453"},"text":"140 Stat. 453","children":[],"tail":", provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/75/dE/tII"},"text":"“That the Office [of National Drug Control Policy] is authorized to accept, hold, administer, and utilize gifts, both real and personal, public and private, without fiscal year limitation, for the purpose of aiding or facilitating the work of the Office.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/47/dB/tII"},"text":"Pub. L. 118–47, div. B, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-23"},"text":"Mar. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/535"},"text":"138 Stat. 535","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dE/tII"},"text":"Pub. L. 117–328, div. E, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4664"},"text":"136 Stat. 4664","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dE/tII"},"text":"Pub. L. 117–103, div. E, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/253"},"text":"136 