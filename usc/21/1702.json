":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/141/tIII"},"text":"Pub. L. 102–141, title III","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/847"},"text":"105 Stat. 847","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509/tIII"},"text":"Pub. L. 101–509, title III","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1402"},"text":"104 Stat. 1402","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/136/tIII"},"text":"Pub. L. 101–136, title III","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-03"},"text":"Nov. 3, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/793"},"text":"103 Stat. 793","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id14c88709-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"id14c8870a-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Ex. Ord. No. 12911. Seal for Office of National Drug Control Policy","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 12911, ","children":[{"tag":"date","attrib":{"date":"1994-04-25"},"text":"Apr. 25, 1994","children":[],"tail":", 59 F.R. 21121 [22121], provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States of America, it is hereby ordered as follows:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Section","children":[],"tail":" 1. There is approved for the Office of National Drug Control Policy in the Executive Office of the President an official seal described as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"On a blue disc the Arms of the United States proper above a curved gold scroll inscribed “OFFICE OF NATIONAL DRUG CONTROL POLICY” in blue letters, all within a white border edged in gold and inscribed “EXECUTIVE OFFICE OF THE PRESIDENT OF THE UNITED STATES” in blue letters.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This design is appropriate for the Office of National Drug Control Policy. The dark blue in this seal is suggested by the Seal of the President and denotes the direct organizational link of the Office of National Drug Control Policy with the Presidential office. The Arms of the United States refer to the entire Nation and represent the involvement in drug control policies that are necessary to assist the President in his role as Chief Executive of the United States.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 2. The seal shall be of the design that is attached hereto and made a part of this order."}],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"William J. Clinton.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"img","attrib":{"src":"file:///t211702.eps"},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
