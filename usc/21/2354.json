{"tag":"section","attrib":{"id":"id14d95042-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2354"},"text":null,"children":[{"tag":"num","attrib":{"value":"2354"},"text":"§ 2354.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties; waivers; exceptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14d95043-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2354/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person that violates, attempts to violate, conspires to violate, or causes a violation of this subchapter or any regulation, license, or order issued to carry out this subchapter shall be subject to the penalties set forth in subsections (b) and (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1705"},"text":"section 1705 of title 50","children":[],"tail":" to the same extent as a person that commits an unlawful act described in subsection (a) of that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d95044-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2354/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National security waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may waive the application of sanctions under this subchapter with respect to a foreign person if the President determines that such waiver is in the national security interest of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d95045-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2354/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d95046-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2354/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for intelligence activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subchapter shall not apply with respect to activities subject to the reporting requirements under title V of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3091"},"text":"50 U.S.C. 3091","children":[],"tail":" et seq.) or any authorized intelligence activities of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d95047-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2354/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for compliance with international obligations and law enforcement activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Sanctions under this subchapter shall not apply with respect to an alien if admitting or paroling the alien into the United States is necessary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d95048-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2354/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to permit the United States to comply with the Agreement regarding the Headquarters of the United Nations, signed at Lake Success on ","children":[{"tag":"date","attrib":{"date":"1947-06-26"},"text":"June 26, 1947","children":[],"tail":", and entered into force "},{"tag":"date","attrib":{"date":"1947-11-21"},"text":"November 21, 1947","children":[],"tail":", between the United Nations and the United States, or other applicable international obligations of the United States; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d95049-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2354/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out or assist law enforcement activity of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d9504a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2354/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Humanitarian exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may not impose sanctions under this subchapter with respect to any person for conducting or facilitating a transaction for the sale of agricultural commodities, food, medicine, or medical devices or for the provision of humanitarian assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14d9504b-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/50/dE/tI/s3104"},"text":"Pub. L. 118–50, div. E, title I, § 3104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-24"},"text":"Apr. 24, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/937"},"text":"138 Stat. 937","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14d9504c-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14d9504d-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14d9504e-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Security Act of 1947, referred to in subsec. (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"act July 26, 1947, ch. 343","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/495"},"text":"61 Stat. 495","children":[],"tail":". Title V of the Act is classified generally to subchapter III (§ 3091 et seq.) of chapter 44 of Title 50, War and National Defense. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
