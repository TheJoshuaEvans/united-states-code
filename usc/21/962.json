{"tag":"section","attrib":{"id":"id14ba55ba-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s962"},"text":null,"children":[{"tag":"num","attrib":{"value":"962"},"text":"§ 962.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Second or subsequent offenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14ba55bb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s962/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of imprisonment and fine","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person convicted of any offense under this subchapter is, if the offense is a second or subsequent offense, punishable by a term of imprisonment twice that otherwise authorized, by twice the fine otherwise authorized, or by both. If the conviction is for an offense punishable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s960/b"},"text":"section 960(b) of this title","children":[],"tail":", and if it is the offender’s second or subsequent offense, the court shall impose, in addition to any term of imprisonment and fine, twice the term of supervised release otherwise authorized."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14ba55bc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s962/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, a person shall be considered convicted of a second or subsequent offense if, prior to the commission of such offense, one or more prior convictions of such person for a felony drug offense have become final.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14ba55bd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s962/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures applicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s851"},"text":"Section 851 of this title","children":[],"tail":" shall apply with respect to any proceeding to sentence a person under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14ba55be-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/tIII/s1012"},"text":"Pub. L. 91–513, title III, § 1012","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1290"},"text":"84 Stat. 1290","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII"},"text":"Pub. L. 98–473, title II","children":[],"tail":", §§ 225(b), 505, "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2030"},"text":"98 Stat. 2030","children":[],"tail":", 2070; "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tI"},"text":"Pub. L. 99–570, title I","children":[],"tail":", §§ 1004(a), 1005(c), "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-6"},"text":"100 Stat. 3207–6","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIX/s90105/b"},"text":"Pub. L. 103–322, title IX, § 90105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1988"},"text":"108 Stat. 1988","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14ba55bf-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14ba55c0-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14ba55c1-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “one or more prior convictions of such person for a felony drug offense have become final” for “one or more prior convictions of him for a felony under any provision of this subchapter or subchapter I of this chapter or other law of a State, the United States, or a foreign country relating to narcotic drugs, marihuana, or depressant or stimulant drugs, have become final”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/s1005/c"},"text":"Pub. L. 99–570, § 1005(c)","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s225"},"text":"Pub. L. 98–473, § 225","children":[],"tail":". See 1984 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/s1004/a"},"text":"Pub. L. 99–570, § 1004(a)","children":[],"tail":", substituted “term of supervised release” for “special parole term”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/s225/b"},"text":"Pub. L. 98–473, § 225(b)","c