{"tag":"section","attrib":{"id":"id14371c1f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd"},"text":null,"children":[{"tag":"num","attrib":{"value":"360ddd"},"text":"§ 360ddd.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14371c20-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “designated medical gas” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14371c21-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Oxygen that meets the standards set forth in an official compendium.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14371c22-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nitrogen that meets the standards set forth in an official compendium.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14371c23-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nitrous oxide that meets the standards set forth in an official compendium.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14371c24-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Carbon dioxide that meets the standards set forth in an official compendium.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14371c25-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Helium that meets the standards set forth in an official compendium.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14371c26-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Carbon monoxide that meets the standards set forth in an official compendium.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14371c27-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Medical air that meets the standards set forth in an official compendium.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14371c28-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other medical gas deemed appropriate by the Secretary, after taking into account any investigational new drug application or investigational new animal drug application for the same medical gas submitted in accordance with regulations applicable to such applications in title 21 of the Code of Federal Regulations, unless any period of exclusivity for a new drug under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/c/3/E/ii"},"text":"section 355(c)(3)(E)(ii) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/j/5/F/ii"},"text":"section 355(j)(5)(F)(ii) of this title","children":[],"tail":", or the extension of any such period under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355a"},"text":"section 355a of this title","children":[],"tail":", or any period of exclusivity for a new animal drug under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360b/c/2/F"},"text":"section 360b(c)(2)(F) of this title","children":[],"tail":", applicable to such medical gas has not expired."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14371c29-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “medical gas” means a drug that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14371c2a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is manufactured or stored in a liquefied, nonliquefied, or cryogenic state; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14371c2b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is administered as a gas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14371c2c-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s575"},"text":"June 25, 1938, ch. 675, § 575","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/144/tXI/s1111"},"text":"Pub. L. 112–144, title XI, § 1111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1108"},"text":"126 Stat. 1108","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIII/s3101/a/2/R"},"text":"Pub. L. 114–255, div. A, title III, § 3101(a)(2)(R)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1155"},"text":"130 Stat. 1155","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14371c2d-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14371c2e-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14371c2f-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Par. (1)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","children":[],"tail":" inserted “for a new drug” after “any period of exclusivity” and “or any period of exclusivity for a new animal drug under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360b/c/2/F"},"text":"section 360b(c)(2)(F) of this title","children":[],"tail":",” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355a"},"text":"section 355a of this title","children":[],"tail":",”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14371c30-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id14371c31-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Changes to Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/144/tXI/s1112"},"text":"Pub. L. 112–144, title XI, § 1112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1111"},"text":"126 Stat. 1111","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/144/tXI/s1112"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":"], the Secretary, after obtaining input from medical gas manufacturers and any other interested members of the public, shall—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine whether any changes to the Federal drug regulations are necessary for medical gases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Energy and Commerce of the House of Representatives a report regarding any such changes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary determines under subsection (a) that changes to the Federal drug regulations are necessary for medical gases, the Secretary shall issue final regulations revising the Federal drug regulations with respect to medical gases not later than 48 months after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘Federal drug regulations’ means regulations in title 21 of the Code of Federal Regulations pertaining to drugs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘medical gas’ has the meaning given to such term in section 575 of the Federal Food, Drug, and Cosmetic Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360ddd"},"text":"21 U.S.C. 360ddd","children":[],"tail":"], as added by section 1111 of this Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘Secretary’ means the Secretary of Health and Human Services, acting through the Commissioner of Food and Drugs.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id14371c32-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rules of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/144/tXI/s1113"},"text":"Pub. L. 112–144, title XI, § 1113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1112"},"text":"126 Stat. 1112","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/144/tXI/s1113"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Nothing in this subtitle [subtitle B (§§ 1111–1113) of title XI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/144"},"text":"Pub. L. 112–144","children":[],"tail":", enacting this section and sections 360ddd–1 and 360ddd–2 of this title and provisions set out as notes under this section] and the amendments made by this subtitle applies with respect to—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a drug that is approved prior to ","children":[{"tag":"date","attrib":{"date":"2012-05-01"},"text":"May 1, 2012","children":[],"tail":", pursuant to an application submitted under section 505 or 512 of the Federal Food, Drug, and Cosmetic Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"21 U.S.C. 355","children":[],"tail":", 360b);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any gas listed in subparagraphs (A) through (G) of section 575(1) of the Federal Food, Drug, and Cosmetic Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360ddd/1"},"text":"21 U.S.C. 360ddd(1)","children":[],"tail":"], as added by section 1111 of this Act, or any combination of any such gases, for an indication that—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not included in, or is different from, those specified in subclauses (I) through (VII) of section 576(a)(3)(A)(i) of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360ddd–1/a/3/A/i"},"text":"21 U.S.C. 360ddd–1(a)(3)(A)(i)","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is approved on or after ","children":[{"tag":"date","attrib":{"date":"2012-05-01"},"text":"May 1, 2012","children":[],"tail":", pursuant to an application submitted under section 505 or 512 ["},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"21 U.S.C. 355","children":[],"tail":", 360b]; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any designated medical gas added pursuant to subparagraph (H) of section 575(1) of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360ddd/1"},"text":"21 U.S.C. 360ddd(1)","children":[],"tail":"] for an indication that—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not included in, or is different from, those originally added pursuant to subparagraph (H) of section 575(1) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360ddd/1/H"},"text":"21 U.S.C. 360ddd(1)(H)","children":[],"tail":"] and section 576(a)(3)(A)(i)(VIII) ["},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360ddd–1/a/3/A/i/VIII"},"text":"21 U.S.C. 360ddd–1(a)(3)(A)(i)(VIII)","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is approved on or after ","children":[{"tag":"date","attrib":{"date":"2012-05-01"},"text":"May 1, 2012","children":[],"tail":", pursuant to an application submitted under section 505 or 512 of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"21 U.S.C. 355","children":[],"tail":", 360b].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
