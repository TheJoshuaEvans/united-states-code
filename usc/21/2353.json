{"tag":"section","attrib":{"id":"id14d95038-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2353"},"text":null,"children":[{"tag":"num","attrib":{"value":"2353"},"text":"§ 2353.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of sanctions with respect to fentanyl trafficking by transnational criminal organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14d95039-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2353/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall impose the sanctions described in subsection (b) with respect to any foreign person the President determines—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d9503a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2353/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is knowingly involved in the significant trafficking of fentanyl, fentanyl precursors, or other related opioids, including such trafficking by a transnational criminal organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d9503b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2353/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise is knowingly involved in significant activities of a transnational criminal organization relating to the trafficking of fentanyl, fentanyl precursors, or other related opioids.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d9503c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2353/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions described","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, pursuant to the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" et seq.), may block and prohibit all transactions in property and interests in property of a foreign person described in subsection (a) if such property and interests in property are in the United States, come within the United States, or are or come within the possession or control of a United States person."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d9503d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2353/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2024-04-24"},"text":"April 24, 2024","children":[],"tail":", and annually thereafter, the President shall submit to the appropriate congressional committees a report on actions taken by the executive branch with respect to the foreign persons identified under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14d9503e-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/50/dE/tI/s3103"},"text":"Pub. L. 118–50, div. E, title I, § 3103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-24"},"text":"Apr. 24, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/936"},"text":"138 Stat. 936","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14d9503f-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14d95040-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14d95041-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The International Emergency Economic Powers Act, referred to in subsec. (b), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/223"},"text":"Pub. L. 95–223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-28"},"text":"Dec. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1626"},"text":"91 Stat. 1626","children":[],"tail":", which is classified generally to chapter 35 (§ 1701 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
