{"tag":"section","attrib":{"id":"id13a5b1aa-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s145"},"text":null,"children":[{"tag":"num","attrib":{"value":"145"},"text":"§ 145.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person who knowingly violates any provision of this subchapter shall, in addition to all other penalties prescribed by law, be punished by a fine of not less than $50 nor more than $2,000, or by imprisonment for not more than one year, or by both such fine and imprisonment.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id13a5b1ab-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-02-15/ch155/s5"},"text":"Feb. 15, 1927, ch. 155, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1103"},"text":"44 Stat. 1103","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
