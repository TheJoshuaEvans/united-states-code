{"tag":"section","attrib":{"id":"id1469294f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379r"},"text":null,"children":[{"tag":"num","attrib":{"value":"379r"},"text":"§ 379r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National uniformity for nonprescription drugs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14692950-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379r/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), (c)(1), (d), (e), or (f), no State or political subdivision of a State may establish or continue in effect any requirement—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14692951-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379r/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that relates to the regulation of a drug that is not subject to the requirements of section 353(b)(1) or 353(f)(1)(A) of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14692952-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379r/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is different from or in addition to, or that is otherwise not identical with, a requirement under this chapter, the Poison Prevention Packaging Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1471"},"text":"15 U.S.C. 1471","children":[],"tail":" et seq.), or the Fair Packaging and Labeling Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1451"},"text":"15 U.S.C. 1451","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14692953-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379r/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14692954-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379r/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon application of a State or political subdivision thereof, the Secretary may by regulation, after notice and opportunity for written and oral presentation of views, exempt from subsection (a), under such conditions as may be prescribed in such regulation, a State or political subdivision requirement that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14692955-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379r/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protects an important public interest that would otherwise be unprotected, including the health and safety of children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14692956-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379r/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would not cause any drug to be in violation of any applicable requirement or prohibition under Federal law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14692957-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379r/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would not unduly burden interstate commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14692958-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379r/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timely action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make a decision on the exemption of a State or political subdivision requirement under paragraph (1) not later than 120 days after receiving the application of the State or political subdivision under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14692959-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379r/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1469295a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379r/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1469295b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379r/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State or political subdivision requirement that relates to the practice of pharmacy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1469295c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379r/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State or political subdivision requirement that a drug be dispensed only upon the prescription of a practitioner licensed by law to administer such drug.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1469295d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379r/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safety or effectiveness","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a), a requirement that relates to the regulation of a drug shall be deemed to include any requirement relating to public information or any other form of public communication relating to a warning of any kind for a drug.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1469295e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379r/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1469295f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379r/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a drug described in subsection (a)(1) that is not the subject of an application approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"section 355 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s357"},"text":"section 357 of this title","children":[],"tail":" (as in effect on the day before "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"November 21, 1997","children":[],"tail":") or a final order under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355h"},"text":"section 355h of this title","children":[],"tail":" by the Secretary establishing conditions under which the drug is generally recognized as safe and effective, subsection (a) shall apply only with respect to a requirement of a State or political subdivision of a State that relates to the same subject as, but is different from or in addition to, or that is otherwise not identical with—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14692960-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379r/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a regulation or order in effect with respect to the drug pursuant to a statute described in subsection (a)(2); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14692961-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379r/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other requirement in effect with respect to the drug pursuant to an amendment to such a statute made on or after ","children":[{"tag":"date","attrib":{"date":"1997-11-21"},"text":"November 21, 1997","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14692962-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379r/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State initiatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to a State requirement adopted by a State public initiative or referendum enacted prior to ","children":[{"tag":"date","attrib":{"date":"1997-09-01"},"text":"September 1, 1997","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14692963-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379r/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on product liability law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to modify or otherwise affect any action or the liability of any person under the product liability law of any State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14692964-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379r/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State enforcement authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall prevent a State or political subdivision thereof from enforcing, under any relevant civil or other enforcement authority, a requirement that is identical to a requirement of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14692965-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s751"},"text":"June 25, 1938, ch. 675, § 751","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/115/tIV/s412/a"},"text":"Pub. L. 105–115, title IV, § 412(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2373"},"text":"111 Stat. 2373","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIII/s3851/c"},"text":"Pub. L. 116–136, div. A, title III, § 3851(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/454"},"text":"134 Stat. 454","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14692966-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14692967-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14692968-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Poison Prevention Packaging Act of 1970, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/601"},"text":"Pub. L. 91–601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-30"},"text":"Dec. 30, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1670"},"text":"84 Stat. 1670","children":[],"tail":", which is classified principally to chapter 39A (§ 1471 et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1471"},"text":"section 1471 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Fair Packaging and Labeling Act, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/755"},"text":"Pub. L. 89–755","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-03"},"text":"Nov. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1296"},"text":"80 Stat. 1296","children":[],"tail":", which is classified generally to chapter 39 (§ 1451 et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1451"},"text":"section 1451 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14692969-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s3851/c/1"},"text":"Pub. L. 116–136, § 3851(c)(1)","children":[],"tail":", in introductory provisions, substituted “final order under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355h"},"text":"section 355h of this title","children":[],"tail":"” for “final regulation promulgated” and struck out “and not misbranded” after “safe and effective”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s3851/c/2"},"text":"Pub. L. 116–136, § 3851(c)(2)","children":[],"tail":", substituted “regulation or order in effect” for “regulation in effect”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1469296a-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id1469296b-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/115/s501"},"text":"section 501 of Pub. L. 105–115","children":[],"tail":", set out as an Effective Date of 1997 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s321"},"text":"section 321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
