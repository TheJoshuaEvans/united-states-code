{"tag":"section","attrib":{"id":"id142679fe-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n"},"text":null,"children":[{"tag":"num","attrib":{"value":"360n"},"text":"§ 360n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority review to encourage treatments for tropical diseases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id142679ff-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14267a00-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “priority review”, with respect to a human drug application as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s379g/1"},"text":"section 379g(1) of this title","children":[],"tail":", means review and action by the Secretary on such application not later than 6 months after receipt by the Secretary of such application, as described in the Manual of Policies and Procedures of the Food and Drug Administration and goals identified in the letters described in section 101(c) of the Food and Drug Administration Amendments Act of 2007."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14267a01-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority review voucher","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “priority review voucher” means a voucher issued by the Secretary to the sponsor of a tropical disease product application that entitles the holder of such voucher to priority review of a single human drug application submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/b/1"},"text":"section 355(b)(1) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"section 262 of title 42","children":[],"tail":" after the date of approval of the tropical disease product application."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14267a02-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tropical disease","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “tropical disease” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14267a03-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tuberculosis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14267a04-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Malaria.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14267a05-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Blinding trachoma.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14267a06-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Buruli Ulcer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14267a07-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cholera.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14267a08-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Dengue/dengue haemorrhagic fever.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14267a09-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Dracunculiasis (guinea-worm disease).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14267a0a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fascioliasis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14267a0b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Human African trypanosomiasis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14267a0c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Leishmaniasis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14267a0d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/3/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Leprosy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14267a0e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/3/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lymphatic filariasis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14267a0f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/3/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Onchocerciasis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14267a10-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/3/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Schistosomiasis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14267a11-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/3/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Soil transmitted helmithiasis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14267a12-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/3/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Yaws.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14267a13-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/3/Q"},"text":null,"children":[{"tag":"num","attrib":{"value":"Q"},"text":"(Q)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Filovirus Diseases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14267a14-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/3/R"},"text":null,"children":[{"tag":"num","attrib":{"value":"R"},"text":"(R)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Zika Virus Disease.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14267a15-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/3/S"},"text":null,"children":[{"tag":"num","attrib":{"value":"S"},"text":"(S)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other infectious disease for which there is no significant market in developed nations and that disproportionately affects poor and marginalized populations, designated by order of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14267a16-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tropical disease product application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “tropical disease product application” means an application that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14267a17-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is a human drug application as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s379g/1"},"text":"section 379g(1) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{"id":"id14267a18-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for prevention or treatment of a tropical disease;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14267a19-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary deems eligible for priority review;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14267a1a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that contains reports of one or more new clinical investigations (other than bioavailability studies) that are essential to the approval of the application and conducted or sponsored by the sponsor of such application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14267a1b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that contains an attestation from the sponsor of the application that such reports were not submitted as part of an application for marketing approval or licensure by a regulatory authority in India, Brazil, Thailand, or any country that is a member of the Pharmaceutical Inspection Convention or the Pharmaceutical Inspection Cooperation Scheme prior to ","children":[{"tag":"date","attrib":{"date":"2007-09-27"},"text":"September 27, 2007","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn002076"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002076"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should be a semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14267a1c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is approved after ","children":[{"tag":"date","attrib":{"date":"2007-09-27"},"text":"September 27, 2007","children":[],"tail":", by the Secretary for use in the prevention, detection, or treatment of a tropical disease; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14267a1d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14267a1e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a human drug, no active moiety (as defined by the Secretary in section 314.3 of title 21, Code of Federal Regulations (or any successor regulations)) of which has been approved in any other application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/b/1"},"text":"section 355(b)(1) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14267a1f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/a/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a biological product, no active ingredient of which has been approved in any other application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"section 262 of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14267a20-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority review voucher","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14267a21-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award a priority review voucher to the sponsor of a tropical disease product application upon approval by the Secretary of such tropical disease product application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14267a22-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transferability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The sponsor of a tropical disease product that receives a priority review voucher under this section may transfer (including by sale) the entitlement to such voucher to a sponsor of a human drug for which an application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/b/1"},"text":"section 355(b)(1) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"section 262 of title 42","children":[],"tail":" will be submitted after the date of the approval of the tropical disease product application. There is no limit on the number of times a priority review voucher may be transferred before such voucher is used."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14267a23-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14267a24-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No award for prior approved application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A sponsor of a tropical disease product may not receive a priority review voucher under this section if the tropical disease product application was submitted to the Secretary prior to ","children":[{"tag":"date","attrib":{"date":"2007-09-27"},"text":"September 27, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14267a25-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" One-year waiting period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue a priority review voucher to the sponsor of a tropical disease product no earlier than the date that is 1 year after ","children":[{"tag":"date","attrib":{"date":"2007-09-27"},"text":"September 27, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14267a26-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The sponsor of a human drug application shall notify the Secretary not later than 90 days prior to submission of the human drug application that is the subject of a priority review voucher of an intent to submit the human drug application, including the date on which the sponsor intends to submit the application. Such notification shall be a legally binding commitment to pay for the user fee to be assessed in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14267a27-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority review user fee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14267a28-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a user fee program under which a sponsor of a human drug application that is the subject of a priority review voucher shall pay to the Secretary a fee determined under paragraph (2). Such fee shall be in addition to any fee required to be submitted by the sponsor under subchapter VII.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14267a29-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fee amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the priority review user fee shall be determined each fiscal year by the Secretary and based on the average cost incurred by the agency in the review of a human drug application subject to priority review in the previous fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14267a2a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual fee setting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish, before the beginning of each fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2007-09-30"},"text":"September 30, 2007","children":[],"tail":", for that fiscal year, the amount of the priority review user fee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14267a2b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14267a2c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The priority review user fee required by this subsection shall be due upon the submission of a human drug application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/b/1"},"text":"section 355(b)(1) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"section 262 of title 42","children":[],"tail":" for which the priority review voucher is used."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14267a2d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Complete application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application described under subparagraph (A) for which the sponsor requests the use of a priority review voucher shall be considered incomplete if the fee required by this subsection and all other applicable user fees are not paid in accordance with the Secretary’s procedures for paying such fees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14267a2e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No waivers, exemptions, reductions, or refunds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not grant a waiver, exemption, reduction, or refund of any fees due and payable under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14267a2f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offsetting collections","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Fees collected pursuant to this subsection for any fiscal year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14267a30-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be deposited and credited as offsetting collections to the account providing appropriations to the Food and Drug Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14267a31-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be collected for any fiscal year except to the extent provided in advance in appropriation Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14267a32-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s524"},"text":"June 25, 1938, ch. 675, § 524","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/85/tXI/s1102"},"text":"Pub. L. 110–85, title XI, § 1102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/972"},"text":"121 Stat. 972","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/233/s2"},"text":"Pub. L. 113–233, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2127"},"text":"128 Stat. 2127","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/146/s2"},"text":"Pub. L. 114–146, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-04-19"},"text":"Apr. 19, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/357"},"text":"130 Stat. 357","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIII/s3101/a/2/M"},"text":"Pub. L. 114–255, div. A, title III, § 3101(a)(2)(M)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1154"},"text":"130 Stat. 1154","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/52/tVI/s611/a"},"text":"Pub. L. 115–52, title VI, § 611(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-18"},"text":"Aug. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1054"},"text":"131 Stat. 1054","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/9/s1/a/3"},"text":"Pub. L. 117–9, § 1(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-04-23"},"text":"Apr. 23, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/257"},"text":"135 Stat. 257","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14267a33-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14267a34-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14267a35-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 101(c) of the Food and Drug Administration Amendments Act of 2007, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/85/s101/c"},"text":"section 101(c) of Pub. L. 110–85","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s379g"},"text":"section 379g of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14267a36-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(4)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/9"},"text":"Pub. L. 117–9","children":[],"tail":" amended subpar. (C) generally. Prior to amendment, subpar. (C) read as follows: “is for a human drug, no active ingredient (including any ester or salt of the active ingredient) of which has been approved in any other application under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/b/1"},"text":"section 355(b)(1) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"section 262 of title 42","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(4)(A)(iii), (iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/52"},"text":"Pub. L. 115–52","children":[],"tail":" added cls. (iii) and (iv)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(3)(Q). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/146/s2/2"},"text":"Pub. L. 114–146, § 2(2)","children":[],"tail":", substituted “Filovirus Diseases” for “Filoviruses”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(R), (S). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/146/s2/1"},"text":"Pub. L. 114–146, § 2(1)","children":[],"tail":", (3), added subpar. (R) and redesignated former subpar. (R) as (S)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"section 262 of title 42","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(3)(Q), (R). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/233/s2/1"},"text":"Pub. L. 113–233, § 2(1)","children":[],"tail":", added subpar. (Q), redesignated former subpar. (Q) as (R), and in subpar. (R) substituted “order of” for “regulation by”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/233/s2/2/A"},"text":"Pub. L. 113–233, § 2(2)(A)","children":[],"tail":", inserted at end “There is no limit on the number of times a priority review voucher may be transferred before such voucher is used.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/233/s2/2/B"},"text":"Pub. L. 113–233, § 2(2)(B)","children":[],"tail":", substituted “90 days” for “365 days”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14267a37-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id14267a38-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/52/tVI/s611/b"},"text":"Pub. L. 115–52, title VI, § 611(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-18"},"text":"Aug. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1054"},"text":"131 Stat. 1054","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/52/tVI/s611/b"},"text":"“The amendments made by subsection (a) [amending this section] shall apply to human drug applications submitted after ","children":[{"tag":"date","attrib":{"date":"2017-09-30"},"text":"September 30, 2017","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
