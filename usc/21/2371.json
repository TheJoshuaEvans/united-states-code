{"tag":"section","attrib":{"id":"id14d95064-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2371"},"text":null,"children":[{"tag":"num","attrib":{"value":"2371"},"text":"§ 2371.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception relating to importation of goods","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14d95065-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2371/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority or a requirement to block and prohibit all transactions in all property and interests in property under this chapter shall not include the authority or a requirement to impose sanctions on the importation of goods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d95066-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2371/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Good defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “good” means any article, natural or manmade substance, material, supply or manufactured product, including inspection and test equipment, and excluding technical data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14d95067-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/50/dE/tIII/s3301"},"text":"Pub. L. 118–50, div. E, title III, § 3301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-24"},"text":"Apr. 24, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/941"},"text":"138 Stat. 941","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14d95068-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14d95069-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14d9506a-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this division”, meaning div. E of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/50"},"text":"Pub. L. 118–50","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-24"},"text":"Apr. 24, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/934"},"text":"138 Stat. 934","children":[],"tail":", known as the Fentanyl Eradication and Narcotics Deterrence Off Fentanyl or the FEND Off Fentanyl Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s2341"},"text":"section 2341 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
