{"tag":"section","attrib":{"id":"id1447e47e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d"},"text":null,"children":[{"tag":"num","attrib":{"value":"379d"},"text":"§ 379d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Automation of Food and Drug Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1447e47f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Commissioner of Food and Drugs, shall automate appropriate activities of the Food and Drug Administration to ensure timely review of activities regulated under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1447e480-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated each fiscal year such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1447e481-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s711"},"text":"June 25, 1938, ch. 675, § 711","children":[],"tail":", formerly § 712, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/635/tIV/s401"},"text":"Pub. L. 101–635, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4585"},"text":"104 Stat. 4585","children":[],"tail":"; renumbered § 711, "},{"tag":"ref","attrib":{"href":"/us/pl/102/571/tI/s106/3"},"text":"Pub. L. 102–571, title I, § 106(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4498"},"text":"106 Stat. 4498","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1447e482-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1447e483-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id1447e484-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 711 of act ","children":[{"tag":"date","attrib":{"date":"1938-06-25"},"text":"June 25, 1938","children":[],"tail":", was renumbered section 731 by "},{"tag":"ref","attrib":{"href":"/us/pl/102/571"},"text":"Pub. L. 102–571","children":[],"tail":" and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s379f"},"text":"section 379f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
