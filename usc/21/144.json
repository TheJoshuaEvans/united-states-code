{"tag":"section","attrib":{"id":"id13a5b1a8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s144"},"text":null,"children":[{"tag":"num","attrib":{"value":"144"},"text":"§ 144.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful receiving of imported milk or cream","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any person in the United States to receive milk or cream imported into the United States unless the importation is in accordance with the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id13a5b1a9-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-02-15/ch155/s4"},"text":"Feb. 15, 1927, ch. 155, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1103"},"text":"44 Stat. 1103","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
