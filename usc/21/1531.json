{"tag":"section","attrib":{"id":"id14c3cc05-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1531"},"text":null,"children":[{"tag":"num","attrib":{"value":"1531"},"text":"§ 1531.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of drug-free communities support program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14c3cc06-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1531/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall establish a program to support communities in the development and implementation of comprehensive, long-term plans and programs to prevent and treat substance use and misuse among youth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c3cc07-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1531/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the Program, the Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c3cc08-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1531/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make and track grants to grant recipients;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3cc09-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1531/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for technical assistance and training, data collection, and dissemination of information on state-of-the-art practices that the Director determines to be effective in reducing substance use and misuse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3cc0a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1531/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the general administration of the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c3cc0b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1531/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after receiving recommendations from the Advisory Commission under section 1542(a)(1) ","children":[{"tag":"ref","attrib":{"idref":"fn002178"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002178"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, the Director shall appoint an Administrator to carry out the Program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c3cc0c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1531/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may employ any necessary staff and may enter into contracts or agreements with national drug control agencies, including interagency agreements to delegate authority for the execution of grants and for such other activities necessary to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14c3cc0d-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tI/s1031"},"text":"Pub. L. 100–690, title I, § 1031","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/20/s2/a/2"},"text":"Pub. L. 105–20, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-27"},"text":"June 27, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/226"},"text":"111 Stat. 226","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVIII/s8203/b/4/A"},"text":"Pub. L. 115–271, title VIII, § 8203(b)(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4111"},"text":"132 Stat. 4111","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/74/s2/c/1/A/ii/II"},"text":"Pub. L. 116–74, § 2(c)(1)(A)(ii)(II)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-11-27"},"text":"Nov. 27, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1157"},"text":"133 Stat. 1157","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14c3cc0e-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14c3cc0f-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14c3cc10-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"