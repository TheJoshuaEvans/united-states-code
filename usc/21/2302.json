{"tag":"section","attrib":{"id":"id14d6df0e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302"},"text":null,"children":[{"tag":"num","attrib":{"value":"2302"},"text":"§ 2302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d6df0f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alien; national; national of the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “alien”, “national”, and “national of the United States” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of title 8","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d6df10-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees and leadership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate congressional committees and leadership” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d6df11-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations, the Committee on Armed Services, the Committee on Banking, Housing, and Urban Affairs, the Committee on Foreign Relations, the Committee on Homeland Security and Governmental Affairs, the Committee on the Judiciary, the Select Committee on Intelligence, and the majority leader and the minority leader of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d6df12-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations, the Committee on Armed Services, the Committee on Financial Services, the Committee on Foreign Affairs, the Committee on Homeland Security, the Committee on the Judiciary, the Committee on Oversight and Reform, the Permanent Select Committee on Intelligence, and the Speaker and the minority leader of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d6df13-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controlled substance; listed chemical","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “controlled substance”, “listed chemical”, “narcotic drug”, and “opioid” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"section 802 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d6df14-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “entity” means a partnership, joint venture, association, corporation, organization, network, group, or subgroup, or any form of business collaboration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d6df15-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign opioid trafficker","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “foreign opioid trafficker” means— ","children":[{"tag":"ref","attrib":{"idref":"fn002205"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002205"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d6df16-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" any foreign person that the President determines plays a significant role in opioid trafficking; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d6df17-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" include—"}],"tail":null},{"tag":"clause","attrib":{"id":"id14d6df18-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any entity of the People’s Republic of China that the President determines—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id14d6df19-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/5/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produces, manufactures, distributes, sells, or knowingly finances or transports any goods described in clause (i) or (ii) of paragraph (8)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14d6df1a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/5/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates a pattern of failing to take credible steps (including implementing appropriate know-your-customer procedures or cooperating with United States counternarcotics efforts) to detect or prevent opioid trafficking; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d6df1b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any senior official of the Government of the People’s Republic of China that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id14d6df1c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/5/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has significant regulatory or law enforcement responsibilities with respect to the activities of an entity described in clause (i); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14d6df1d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/5/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aids and abets opioid trafficking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d6df1e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “foreign person”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d6df1f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14d6df20-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any citizen or national of a foreign country; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d6df21-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any entity not organized under the laws of the United States or a jurisdiction within the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d6df22-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include the government of a foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d6df23-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Knowingly","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “knowingly”, with respect to conduct, a circumstance, or a result, means that a person has actual knowledge, or should have known, of the conduct, the circumstance, or the result.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d6df24-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opioid trafficking","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “opioid trafficking” means any illicit activity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d6df25-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to produce, manufacture, distribute, sell, or knowingly finance or transport—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14d6df26-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/8/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" synthetic opioids, including controlled substances that are synthetic opioids and listed chemicals that are synthetic opioids; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d6df27-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/8/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" active pharmaceutical ingredients or chemicals that are used in the production of controlled substances that are synthetic opioids;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d6df28-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to attempt to carry out an activity described in subparagraph (A); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d6df29-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist, abet, conspire, or collude with other persons to carry out such an activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d6df2a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means an individual or entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d6df2b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “United States person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d6df2c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any citizen or national of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d6df2d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any alien lawfully admitted for permanent residence in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d6df2e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any entity organized under the laws of the United States or any jurisdiction within the United States (including a foreign branch of such an entity); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d6df2f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2302/10/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person located in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14d6df30-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dF/tLXXII/s7203"},"text":"Pub. L. 116–92, div. F, title LXXII, § 7203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2262"},"text":"133 Stat. 2262","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXIII/s8314"},"text":"Pub. L. 119–60, div. H, title LXXXIII, § 8314","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1856"},"text":"139 Stat. 1856","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14d6df31-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14d6df32-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14d6df33-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title LXXII of div. F of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2262"},"text":"133 Stat. 2262","children":[],"tail":", known as the Fentanyl Sanctions Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s2301"},"text":"section 2301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14d6df34-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" designated existing provisions as subpar. (A) and added subpar. (B)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14d6df35-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id14d6df36-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id14d6df37-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction Regarding the Use of Military Force","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXIII/s8320"},"text":"Pub. L. 119–60, div. H, title LXXXIII, § 8320","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1863"},"text":"139 Stat. 1863","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dH/tLXXXIII/s8320"},"text":"“Nothing in this subtitle [subtitle B (§§ 8311–8320) of title LXXXIII of div. H of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", amending this section, sections 2311 and 2312 of this title, and "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2291h"},"text":"section 2291h of Title 22","children":[],"tail":", Foreign Relations and Intercourse, enacting provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s2313"},"text":"section 2313 of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of Title 22","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of Title 50","children":[],"tail":", War and National Defense, and amending provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2291"},"text":"section 2291 of Title 22","children":[],"tail":"], or the amendments made by this subtitle, may be construed as authorizing the use of military force.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
