{"tag":"section","attrib":{"id":"id13a5b1b7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s149"},"text":null,"children":[{"tag":"num","attrib":{"value":"149"},"text":"§ 149.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"When used in this subchapter—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id13a5b1b8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s149/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “person” means an individual, partnership, association, or corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13a5b1b9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s149/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “United States” means the fifty States and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id13a5b1ba-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-02-15/ch155/s9"},"text":"Feb. 15, 1927, ch. 155, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1103"},"text":"44 Stat. 1103","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/70/s19"},"text":"Pub. L. 86–70, § 19","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-06-25"},"text":"June 25, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/145"},"text":"73 Stat. 145","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/624/s15"},"text":"Pub. L. 86–624, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/415"},"text":"74 Stat. 415","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id13a5b1bb-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id13a5b1bc-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id13a5b1bd-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1960—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/624"},"text":"Pub. L. 86–624","children":[],"tail":" substituted “means the fifty States and the District of Columbia” for “means continental United States, including Alaska”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/70"},"text":"Pub. L. 86–70","children":[],"tail":" inserted “, including Alaska” after “continental United States”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
