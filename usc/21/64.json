{"tag":"section","attrib":{"id":"id139e85cd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s64"},"text":null,"children":[{"tag":"num","attrib":{"value":"64"},"text":"§ 64.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations for enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services is authorized and directed to make and enforce such regulations as may in his judgment be necessary to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id139e85ce-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1923-03-04/ch262/s4"},"text":"Mar. 4, 1923, ch. 262, § 4","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-27/ch743"},"text":"Aug. 27, 1935, ch. 743","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/885"},"text":"49 Stat. 885","children":[],"tail":"; 1940 Reorg. Plan No. IV, § 12, eff. "},{"tag":"date","attrib":{"date":"1940-06-30"},"text":"June 30, 1940","children":[],"tail":", 5 F.R. 2421, "},{"tag":"ref","attrib":{"href":"/us/stat/54/1237"},"text":"54 Stat. 1237","children":[],"tail":"; 1953 Reorg. Plan No. 1, § 5, eff. "},{"tag":"date","attrib":{"date":"1953-04-11"},"text":"Apr. 11, 1953","children":[],"tail":", 18 F.R. 2053, "},{"tag":"ref","attrib":{"href":"/us/stat/67/631"},"text":"67 Stat. 631","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id139e85cf-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id139e85d0-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id139e85d1-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Health and Human Services” substituted in text for “Secretary of Health, Education, and Welfare” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id139e85d2-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id139e85d3-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of Federal Security Administrator to Secretary of Health, Education, and Welfare [now Health and Human Services], and of Food and Drug Administration to Federal Security Agency, see notes set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s321"},"text":"section 321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
