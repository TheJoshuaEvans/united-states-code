{"tag":"section","attrib":{"id":"id14c3cc8a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1534"},"text":null,"children":[{"tag":"num","attrib":{"value":"1534"},"text":"§ 1534.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance and training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14c3cc8b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1534/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c3cc8c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1534/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance and agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to any grant recipient or other organization, the Administrator may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c3cc8d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1534/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offer technical assistance and training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c3cc8e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1534/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into contracts and cooperative agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c3cc8f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1534/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","