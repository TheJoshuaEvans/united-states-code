tail":null},{"tag":"content","attrib":{},"text":" any other activity related to the purposes of the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14c3cc95-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tI/s1034"},"text":"Pub. L. 100–690, title I, § 1034","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/20/s2/a/2"},"text":"Pub. L. 105–20, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-27"},"text":"June 27, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/231"},"text":"111 Stat. 231","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
