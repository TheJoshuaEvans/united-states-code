{"tag":"section","attrib":{"id":"id14692982-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"379aa"},"text":"§ 379aa.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Serious adverse event reporting for nonprescription drugs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14692983-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14692984-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adverse event","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “adverse event” means any health-related event associated with the use of a nonprescription drug that is adverse, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14692985-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an event occurring from an overdose of the drug, whether accidental or intentional;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14692986-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an event occurring from abuse of the drug;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14692987-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an event occurring from withdrawal from the drug; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14692988-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any failure of expected pharmacological action of the drug.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14692989-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprescription drug","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “nonprescription drug” means a drug that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1469298a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s353/b"},"text":"section 353(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1469298b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not subject to approval in an application submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"section 355 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1469298c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Serious adverse event","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “serious adverse event” is an adverse event that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1469298d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" results in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id1469298e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" death;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1469298f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a life-threatening experience;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14692990-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/a/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inpatient hospitalization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14692991-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/a/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a persistent or significant disability or incapacity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14692992-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/a/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a congenital anomaly or birth defect; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14692993-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires, based on reasonable medical judgment, a medical or surgical intervention to prevent an outcome described under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14692994-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Serious adverse event report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “serious adverse event report” means a report that is required to be submitted to the Secretary under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14692995-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14692996-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The manufacturer, packer, or distributor whose name (pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s352/b/1"},"text":"section 352(b)(1) of this title","children":[],"tail":") appears on the label of a nonprescription drug marketed in the United States (referred to in this section as the “responsible person”) shall submit to the Secretary any report received of a serious adverse event associated with such drug when used in the United States, accompanied by a copy of the label on or within the retail package of such drug."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14692997-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retailer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A retailer whose name appears on the label described in paragraph (1) as a distributor may, by agreement, authorize the manufacturer or packer of the nonprescription drug to submit the required reports for such drugs to the Secretary so long as the retailer directs to the manufacturer or packer all adverse events associated with such drug that are reported to the retailer through the address or telephone number described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s352/x"},"text":"section 352(x) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14692998-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14692999-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The responsible person shall submit to the Secretary a serious adverse event report no later than 15 business days after the report is received through the address or phone number described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s352/x"},"text":"section 352(x) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1469299a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New medical information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The responsible person shall submit to the Secretary any new medical information, related to a submitted serious adverse event report that is received by the responsible person within 1 year of the initial report, no later than 15 business days after the new information is received by the responsible person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1469299b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidation of reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop systems to ensure that duplicate reports of, and new medical information related to, a serious adverse event shall be consolidated into a single report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1469299c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, after providing notice and an opportunity for comment from interested parties, may establish an exemption to the requirements under paragraphs (1) and (2) if the Secretary determines that such exemption would have no adverse effect on public health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1469299d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each serious adverse event report under this section shall be submitted to the Secretary using the MedWatch form, which may be modified by the Secretary for nonprescription drugs, and may be accompanied by additional information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1469299e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance and inspection of records","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1469299f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The responsible person shall maintain records related to each report of an adverse event received by the responsible person for a period of 6 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id146929a0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records inspection","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id146929a1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The responsible person shall permit an authorized person to have access to records required to be maintained under this section, during an inspection pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s374"},"text":"section 374 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id146929a2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this paragraph, the term “authorized person” means an officer or employee of the Department of Health and Human Services who has—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id146929a3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate credentials, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id146929a4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" been duly designated by the Secretary to have access to the records required under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id146929a5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protected information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A serious adverse event report submitted to the Secretary under this section, including any new medical information submitted under subsection (c)(2), or an adverse event report voluntarily submitted to the Secretary shall be considered to be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id146929a6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a safety report under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s379v"},"text":"section 379v of this title","children":[],"tail":" and may be accompanied by a statement, which shall be a part of any report that is released for public disclosure, that denies that the report or the records constitute an admission that the product involved caused or contributed to the adverse event; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id146929a7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a record about an individual under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":" (commonly referred to as the “Privacy Act of 1974”) and a medical or similar file the disclosure of which would constitute a violation of section 552 of such title 5 (commonly referred to as the “Freedom of Information Act”), and shall not be publicly disclosed unless all personally identifiable information is redacted."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id146929a8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The submission of any adverse event report in compliance with this section shall not be construed as an admission that the nonprescription drug involved caused or contributed to the adverse event.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id146929a9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id146929aa-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No State or local government shall establish or continue in effect any law, regulation, order, or other requirement, related to a mandatory system for adverse event reports for nonprescription drugs, that is different from, in addition to, or otherwise not identical to, this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id146929ab-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of section","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id146929ac-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall affect the authority of the Secretary to provide adverse event reports and information to any health, food, or drug officer or employee of any State, territory, or political subdivision of a State or territory, under a memorandum of understanding between the Secretary and such State, territory, or political subdivision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id146929ad-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personally-identifiable information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, personally-identifiable information in adverse event reports provided by the Secretary to any health, food, or drug officer or employee of any State, territory, or political subdivision of a State or territory, shall not—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id146929ae-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/h/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be made publicly available pursuant to any State or other law requiring disclosure of information or records; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id146929af-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/h/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise be disclosed or distributed to any party without the written consent of the Secretary and the person submitting such information to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id146929b0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of safety reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall permit a State, territory, or political subdivision of a State or territory, to use any safety report received from the Secretary in a manner inconsistent with subsection (g) or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s379v"},"text":"section 379v of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id146929b1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id146929b2-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s760"},"text":"June 25, 1938, ch. 675, § 760","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/462/s2/a"},"text":"Pub. L. 109–462, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3469"},"text":"120 Stat. 3469","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id146929b3-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id146929b4-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id146929b5-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 1 year after ","children":[{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/462/s2/e/1"},"text":"section 2(e)(1) of Pub. L. 109–462","children":[],"tail":", set out as an Effective Date of 2006 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s352"},"text":"section 352 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id146929b6-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Modifications","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/462/s2/b"},"text":"Pub. L. 109–462, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3472"},"text":"120 Stat. 3472","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/462/s2/b"},"text":"“The Secretary of Health and Human Services may modify requirements under the amendments made by this section [enacting this section and amending sections 331 and 352 of this title] in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":", United States Code, to maintain consistency with international harmonization efforts over time.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id146929b7-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Guidance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/462/s2/e/3"},"text":"Pub. L. 109–462, § 2(e)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3472"},"text":"120 Stat. 3472","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/462/s2/e/3"},"text":"“Not later than 270 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":"], the Secretary of Health and Human Services shall issue guidance on the minimum data elements that should be included in a serious adverse event report described under the amendments made by this Act [see Short Title of 2006 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"section 301 of this title","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/462/s3/d/3"},"text":"Pub. L. 109–462, § 3(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3475"},"text":"120 Stat. 3475","children":[],"tail":", enacted provisions substantially identical to those enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/109/462/s2/e/3"},"text":"Pub. L. 109–462, § 2(e)(3)","children":[],"tail":", set out above."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
