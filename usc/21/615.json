{"tag":"section","attrib":{"id":"id148a9415-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s615"},"text":null,"children":[{"tag":"num","attrib":{"value":"615"},"text":"§ 615.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection of carcasses, meat of which is intended for export","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall also cause to be made a careful inspection of the carcasses and parts thereof of all amenable species, the meat of which, fresh, salted, canned, corned, packed, cured, or otherwise prepared, is intended and offered for export to any foreign country, at such times and places and in such manner as he may deem proper.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id148a9416-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1907-03-04/ch2907"},"text":"Mar. 4, 1907, ch. 2907","children":[],"tail":", title I, § 15, formerly 13th par., "},{"tag":"ref","attrib":{"href":"/us/stat/34/1263"},"text":"34 Stat. 1263","children":[],"tail":"; renumbered § 15 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/90/201"},"text":"Pub. L. 90–201","children":[],"tail":", §§ 1, 3(b), 12(a), "},{"tag":"date","attrib":{"date":"1967-12-15"},"text":"Dec. 15, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/584"},"text":"81 Stat. 584","children":[],"tail":", 588, 592; "},{"tag":"ref","attrib":{"href":"/us/pl/109/97/tVII/s798"},"text":"Pub. L. 109–97, title VII, § 798[(a)]","children":[],"tail":"(1), "},{"tag":"date","attrib":{"date":"2005-11-10"},"text":"Nov. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2166"},"text":"119 Stat. 2166","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id148a9417-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id148a9418-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id148a9419-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s83"},"text":"section 83 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id148a941a-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/97"},"text":"Pub. L. 109–97","children":[],"tail":" substituted “amenable species” for “cattle, sheep, swine, goats, horses, mules, and other equines”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/201"},"text":"Pub. L. 90–201","children":[],"tail":", §§ 3(b), 12(a), struck out “of Agriculture” after “Secretary” and included horses, mules, and other equines in the list of animals, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id148d041b-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id148d041c-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"