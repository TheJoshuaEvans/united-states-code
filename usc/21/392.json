{"tag":"section","attrib":{"id":"id147c3bf9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s392"},"text":null,"children":[{"tag":"num","attrib":{"value":"392"},"text":"§ 392.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption of meats and meat food products","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id147c3bfa-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s392/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law determinative of exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Meats and meat food products shall be exempt from the provisions of this chapter to the extent of the application or the extension thereto of the Meat Inspection Act, approved ","children":[{"tag":"date","attrib":{"date":"1907-03-04"},"text":"March 4, 1907","children":[],"tail":", as amended ["},{"tag":"ref","attrib":{"href":"/us/usc/t21/s601"},"text":"21 U.S.C. 601","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id147c3bfb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s392/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Laws unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing contained in this chapter shall be construed as in any way affecting, modifying, repealing, or superseding the provisions of section 351 of Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"42 U.S.C. 262","children":[],"tail":"] (relating to viruses, serums, toxins, and analogous products applicable to man); the virus, serum, toxin, and analogous products provisions, applicable to domestic animals, of the Act of Congress approved "},{"tag":"date","attrib":{"date":"1913-03-04"},"text":"March 4, 1913","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/37/832-833"},"text":"37 Stat. 832–833","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t21/s151"},"text":"21 U.S.C. 151","children":[],"tail":" et seq.]; the Filled Cheese Act of "},{"tag":"date","attrib":{"date":"1896-06-06"},"text":"June 6, 1896","children":[],"tail":" (U.S.C., 1934 ed., title 26, ch. 10), the Filled Milk Act of "},{"tag":"date","attrib":{"date":"1923-03-04"},"text":"March 4, 1923","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t21/s61"},"text":"21 U.S.C. 61","children":[],"tail":" et seq.]; or the Import Milk Act of "},{"tag":"date","attrib":{"date":"1927-02-15"},"text":"February 15, 1927","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t21/s141"},"text":"21 U.S.C. 141","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id147c3bfc-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s1002/b"},"text":"June 25, 1938, ch. 675, § 1002(b)","children":[],"tail":", (c), formerly § 902(b), (c), "},{"tag":"ref","attrib":{"href":"/us/stat/52/1059"},"text":"52 Stat. 1059","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/399/s107"},"text":"Pub. L. 90–399, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-13"},"text":"July 13, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/353"},"text":"82 Stat. 353","children":[],"tail":"; renumbered § 1002(b), (c), "},{"tag":"ref","attrib":{"href":"/us/pl/111/31/dA/tI/s101/b/2"},"text":"Pub. L. 111–31, div. A, title I, § 101(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-06-22"},"text":"June 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1784"},"text":"123 Stat. 