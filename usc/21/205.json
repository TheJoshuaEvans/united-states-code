{"tag":"section","attrib":{"id":"id13a7fb7a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s205"},"text":null,"children":[{"tag":"num","attrib":{"value":"205"},"text":"§ 205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Display of license in pharmacy","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every license to practice pharmacy shall be conspicuously displayed by the person to whom the same has been issued in the pharmacy, drug store, or place of business, if any, of which the said person is the owner or part owner or manager.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id13a7fb7b-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1915-03-03/ch74/s5"},"text":"Mar. 3, 1915, ch. 74, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/819"},"text":"38 Stat. 819","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
