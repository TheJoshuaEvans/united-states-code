{"tag":"section","attrib":{"id":"id14ae6e6f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s859"},"text":null,"children":[{"tag":"num","attrib":{"value":"859"},"text":"§ 859.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution to persons under age twenty-one","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14ae6e70-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s859/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First offense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s860"},"text":"section 860 of this title","children":[],"tail":", any person at least eighteen years of age who violates "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s841/a/1"},"text":"section 841(a)(1) of this title","children":[],"tail":" by distributing a controlled substance to a person under twenty-one years of age is (except as provided in subsection (b)) subject to (1) twice the maximum punishment authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s841/b"},"text":"section 841(b) of this title","children":[],"tail":", and (2) at least twice any term of supervised release authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s841/b"},"text":"section 841(b) of this title","children":[],"tail":", for a first offense involving the same controlled substance and schedule. Except to the extent a greater minimum sentence is otherwise provided by "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s841/b"},"text":"section 841(b) of this title","children":[],"tail":", a term of imprisonment under this subsection shall be not less than one year. The mandatory minimum sentencing provisions of this subsection shall not apply to offenses involving 5 grams or less of marihuana."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14ae6e71-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s859/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Second offense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s860"},"text":"section 860 of this title","children":[],"tail":", any person at least eighteen years of age who violates "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s841/a/1"},"text":"section 841(a)(1) of this title","children":[],"tail":" by distributing a controlled substance to a person under twenty-one years of age after a prior conviction under subsection (a) of this section (or under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s333/b"},"text":"section 333(b) of this title","children":[],"tail":" as in effect prior to "},{"tag":"date","attrib":{"date":"1971-05-01"},"text":"May 1, 1971","children":[],"tail":") has become final, is subject to (1) three times the maximum punishment authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s841/b"},"text":"section 841(b) of this title","children":[],"tail":", and (2) at least three times any term of supervised release authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s841/b"},"text":"section 841(b) of this title","children":[],"tail":", for a second or subsequent offense involving the same controlled substance and schedule. Except to the extent a greater minimum sentence is otherwise provided by "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s841/b"},"text":"section 841(b) of this title","children":[],"tail":", a term of imprisonment under this subsection shall be not less than one year. Penalties for third and subsequent convictions shall be governed by "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s841/b/1/A"},"text":"section 841(b)(1)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14ae6e72-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/tII/s418"},"text":"Pub. L. 91–513, title II, § 418","children":[],"tail":", formerly § 405, "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1265"},"text":"84 Stat. 1265","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII"},"text":"Pub. L. 98–473, title II","children":[],"tail":", §§ 224(b), 503(b)(3), "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2030"},"text":"98 Stat. 2030","children":[],"tail":", 2070; "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tI"},"text":"Pub. L. 99–570, title I","children":[],"tail":", §§ 1004(a), 1005(b)(1), 1105(a), (b), "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-6"},"text":"100 Stat. 3207–6","children":[],"tail":", 3207–11; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI"},"text":"Pub. L. 100–690, title VI","children":[],"tail":", §§ 6452(b), 6455, 6456, "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4371"},"text":"102 Stat. 4371","children":[],"tail":", 4372; renumbered § 418 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tX"},"text":"Pub. L. 101–647, title X","children":[],"tail":", §§ 1002(a), 1003(a), title XXXV, § 3599L, "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4827"},"text":"104 Stat. 4827","children":[],"tail":", 4828, 4932.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"us