{"tag":"section","attrib":{"id":"id13fb72ae-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s355d"},"text":null,"children":[{"tag":"num","attrib":{"value":"355d"},"text":"§ 355d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internal committee for review of pediatric plans, assessments, deferrals, deferral extensions, and waivers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish an internal committee within the Food and Drug Administration to carry out the activities as described in sections 355a(f) and 355c(f) of this title. Such internal committee shall include employees of the Food and Drug Administration, with expertise in pediatrics (including representation from the Office of Pediatric Therapeutics), biopharmacology, statistics, chemistry, legal issues, pediatric ethics, neonatology, and the appropriate expertise pertaining to the pediatric product under review, such as expertise in child and adolescent psychiatry or pediatric rare diseases, and other individuals designated by the Secretary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id13fb72af-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s505C"},"text":"June 25, 1938, ch. 675, § 505C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/85/tIV/s403"},"text":"Pub. L. 110–85, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/875"},"text":"121 Stat. 875","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/144/tV/s509/c"},"text":"Pub. L. 112–144, title V, § 509(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1049"},"text":"126 Stat. 1049","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/52/tV/s505/f"},"text":"Pub. L. 115–52, title V, § 505(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-18"},"text":"Aug. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1047"},"text":"131 Stat. 1047","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id13fb72b0-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id13fb72b1-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id13fb72b2-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/52"},"text":"Pub. L. 115–52","children":[],"tail":" inserted “or pediatric rare diseases” after “psychiatry”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/144"},"text":"Pub. L. 112–144","children":[],"tail":" inserted “deferral extensions,” after “deferrals,” in section catchline and “neonatology,” after “pediatric ethics,” in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
