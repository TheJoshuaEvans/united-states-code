{"tag":"section","attrib":{"id":"id14029e95-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"356–2"},"text":"§ 356–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accelerated approval Council","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14029e96-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356–2/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", the Secretary shall establish an intra-agency coordinating council (referred to in this subsection as the “Council”) within the Food and Drug Administration to ensure the consistent and appropriate use of accelerated approval across the Food and Drug Administration, pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s356/c"},"text":"section 356(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14029e97-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356–2/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The members of the Council shall consist of the following senior officials, or a designee of such official, from the Food and Drug Administration and relevant Centers:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14029e98-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356–2/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Center for Drug Evaluation and Research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14029e99-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356–2/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Center for Biologics Evaluation and Research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14029e9a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356–2/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Oncology Center of Excellence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14029e9b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356–2/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of New Drugs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14029e9c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356–2/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Orphan Products Development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14029e9d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356–2/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Tissues and Advanced Therapies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14029e9e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356–2/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Medical Policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14029e9f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356–2/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At least 3 directors of review divisions or offices overseeing products approved under accelerated approval, including at least one director within the Office of Neuroscience.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14029ea0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356–2/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of the Council","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14029ea1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356–2/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall convene not fewer than 3 times per calendar year to discuss issues related to accelerated approval, including any relevant cross-disciplinary approaches related to product review with respect to accelerated approval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14029ea2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356–2/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy development","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall directly engage with product review teams to support the consistent and appropriate use of accelerated approval across the Food and Drug Administration. Such engagement may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14029ea3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356–2/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing guidance for Food and Drug Administration staff and best practices for, and across, product review teams, including with respect to communication between sponsors and the Food and Drug Administration and the review of products under accelerated approval;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14029ea4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356–2/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing training for product review teams; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14029ea5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356–2/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advising review divisions on best practices with respect to product-specific development, review, and withdrawal of products under accelerated approval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14029ea6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356–2/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of a report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", and annually thereafter, the Council shall publish on the public website of the Food and Drug Administration a report on the activities of the Council."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14029ea7-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tIII/s3210/e"},"text":"Pub. L. 117–328, div. FF, title III, § 3210(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5824"},"text":"136 Stat. 5824","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14029ea8-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14029ea9-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id14029eaa-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Food and Drug Omnibus Reform Act of 2022, and not as part of the Federal Food, Drug, and Cosmetic Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14029eab-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id14029eac-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s3210/e"},"text":"section 3210(e) of Pub. L. 117–328","children":[],"tail":", which enacted this section, to be construed to affect ongoing withdrawal proceedings for products approved pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s356/c"},"text":"section 356(c) of this title","children":[],"tail":" for which a notice of proposed withdrawal has been published in the Federal Register prior to "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/s3210/f"},"text":"section 3210(f) of Pub. L. 117–328","children":[],"tail":", set out as a Construction of 2022 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s356"},"text":"section 356 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id14029ead-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary as used in this section means the Secretary of Health and Human Services, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/s3002"},"text":"section 3002 of div. FF of Pub. L. 117–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s350a–1"},"text":"section 350a–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
