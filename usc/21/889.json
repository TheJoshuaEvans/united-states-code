{"tag":"section","attrib":{"id":"id14b5736e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s889"},"text":null,"children":[{"tag":"num","attrib":{"value":"889"},"text":"§ 889.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Production control of controlled substances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14b5736f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s889/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14b57370-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s889/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “controlled substance” has the same meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802/6"},"text":"section 802(6) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14b57371-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s889/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14b57372-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s889/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” means each of the fifty States, the District of Columbia, the Commonwealth of Puerto Rico, Guam, the Virgin Islands of the United States, American Samoa, the Commonwealth of the Northern Mariana Islands, or the Trust Territory of the Pacific Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14b57373-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s889/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons ineligible for Federal agricultural program benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, following ","children":[{"tag":"date","attrib":{"date":"1985-12-23"},"text":"December 23, 1985","children":[],"tail":", any person who is convicted under Federal or State law of planting, cultivation, growing, producing, harvesting, or storing a controlled substance in any crop year shall be ineligible for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id14b57374-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s889/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as to any commodity produced during that crop year, and the four succeeding crop years, by such person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14b57375-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s889/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any price support or payment made available under the Agricultural Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"7 U.S.C. 1421","children":[],"tail":" et seq.), the Commodity Credit Corporation Charter Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s714"},"text":"15 U.S.C. 714","children":[],"tail":" et seq.), or any other Act;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14b57376-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s889/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a farm storage facility loan made under section 4(h) of the Commodity Credit Corporation Charter Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s714b/h"},"text":"15 U.S.C. 714b(h)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14b57377-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s889/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" crop insurance under the Federal Crop Insurance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1501"},"text":"7 U.S.C. 1501","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14b57378-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s889/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a disaster payment made under the Agricultural Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"7 U.S.C. 1421","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14b57379-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s889/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a loan made, insured or guaranteed under the Consolidated Farm and Rural Development Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"7 U.S.C. 1921","children":[],"tail":" et seq.) or any other provision of law administered by the Farmers Home Administration; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14b5737a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s889/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a payment made under section 4 or 5 of the Commodity Credit Corporation Charter Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s714b"},"text":"15 U.S.C. 714b","children":[],"tail":" or 714c) for the storage of an agricultural commodity that is—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14b5737b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s889/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produced during that crop year, or any of the four succeeding crop years, by such person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14b5737c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s889/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquired by the Commodity Credit Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14b5737d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s889/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1985-12-23"},"text":"December 23, 1985","children":[],"tail":", the Secretary shall issue such regulations as the Secretary determines are necessary to carry out this section, including regulations that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id14b5737e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s889/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" define the term “person”;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14b5737f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s889/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" govern the determination of persons who shall be ineligible for program benefits under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14b57380-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s889/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect the interests of tenants and sharecroppers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14b57381-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/tII/s519"},"text":"Pub. L. 91–513, title II, § 519","children":[],"tail":", formerly "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVII/s1764"},"text":"Pub. L. 99–198, title XVII, § 1764","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1652"},"text":"99 Stat. 1652","children":[],"tail":"; renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/91/513/s519"},"text":"§ 519 of Pub. L. 91–513","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tX/s1002/h/2"},"text":"Pub. L. 101–647, title X, § 1002(h)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4828"},"text":"104 Stat. 4828","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14b57382-3a70-11f1-b089-c1e1