{"tag":"section","attrib":{"id":"id148821c7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s471"},"text":null,"children":[{"tag":"num","attrib":{"value":"471"},"text":"§ 471.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safe Meat and Poultry Inspection Panel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id148821c8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s471/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The advisory panel known as the “Safe Meat and Poultry Inspection Panel” established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s679a"},"text":"section 679a of this title","children":[],"tail":" shall review and evaluate, as the panel considers necessary, the adequacy, necessity, safety, cost-effectiveness, and scientific merit of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id148821c9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s471/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inspection procedures of, and work rules and worker relations involving Federal employees employed in, plants inspected under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id148821ca-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s471/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" informal petitions or proposals for changes in inspection procedures, processes, and techniques of plants inspected under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id148821cb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s471/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" formal changes in poultry inspection regulations promulgated under this chapter, whether in notice, proposed, or final form; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id148821cc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s471/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other matters as may be referred to the panel by the Secretary regarding the quality or effectiveness of a safe and cost-effective poultry inspection system under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id148821cd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s471/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id148821ce-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s471/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Safe Meat and Poultry Inspection Panel shall submit to the Secretary a report on the results of each review and evaluation carried out under paragraph (1), including such recommendations as the panel considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id148821cf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s471/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports on formal changes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a report concerning a formal change in poultry inspection regulations, the report shall be made within the time limits prescribed for formal comments on such changes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id148821d0-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/172/s30"},"text":"Pub. L. 85–172, § 30","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tIX/s918/a/2"},"text":"Pub. L. 104–127, title IX, § 918(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1190"},"text":"110 Stat. 1190","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id148821d1-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id148821d2-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id148821d3-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Use of Appropriated Funds","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/dA/tVII/s741"},"text":"Pub. L. 113–235, div. A, title VII, § 741","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2170"},"text":"128 Stat. 2170","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/235/dA/tVII/s741"},"text":"“Hereafter, none of the funds appropriated by this or any other Act may be used to carry out section 410 of the Federal Meat Inspection Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s679a"},"text":"21 U.S.C. 679a","children":[],"tail":") or section 30 of the Poultry Products Inspection Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s471"},"text":"21 U.S.C. 471","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
