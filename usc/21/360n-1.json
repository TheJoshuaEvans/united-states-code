{"tag":"section","attrib":{"id":"id14267a39-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"360n–1"},"text":"§ 360n–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority review for qualified infectious disease products","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14267a3a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary designates a drug under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355f/d"},"text":"section 355f(d) of this title","children":[],"tail":" as a qualified infectious disease product, then the Secretary shall give priority review to the first application submitted for approval for such drug under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/b"},"text":"section 355(b) of this title","children":[],"tail":", or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262/a"},"text":"section 262(a) of title 42","children":[],"tail":", that requires clinical data (other than bioavailability studies) to demonstrate safety or effectiveness."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14267a3b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360n–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall prohibit the Secretary from giving priority review to a human drug application or efficacy supplement submitted for approval under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/b"},"text":"section 355(b) of this title","children":[],"tail":" that otherwise meets the criteria for the Secretary to grant priority review."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14267a3c-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s524A"},"text":"June 25, 1938, ch. 675, § 524A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/144/tVIII/s802/a"},"text":"Pub. L. 112–144, title VIII, § 802(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1079"},"text":"126 Stat. 1079","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIII/s3101/a/2/N"},"text":"Pub. L. 114–255, div. A, title III, § 3101(a)(2)(N)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1154"},"text":"130 Stat. 1154","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tIII/s3212/b"},"text":"Pub. L. 117–328, div. FF, title III, § 3212(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5826"},"text":"136 Stat. 5826","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14267a3d-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14267a3e-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14267a3f-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" inserted “, or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262/a"},"text":"section 262(a) of title 42","children":[],"tail":", that requires clinical data (other than bioavailability studies) to demonstrate safety or effectiveness” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, substituted “the first application” for “any application”, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14267a40-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id14267a41-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/144/tVIII/s802/b"},"text":"Pub. L. 112–144, title VIII, § 802(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1079"},"text":"126 Stat. 1079","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/144/tVIII/s802/b"},"text":"“Section 524A of the Federal Food, Drug, and Cosmetic Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360n–1"},"text":"21 U.S.C. 360n–1","children":[],"tail":"], as added by subsection (a), applies only with respect to an application that is submitted under section 505(b) of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/b"},"text":"21 U.S.C. 355(b)","children":[],"tail":") on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
