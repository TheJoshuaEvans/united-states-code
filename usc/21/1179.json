{"tag":"section","attrib":{"id":"id14c1812b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1179"},"text":null,"children":[{"tag":"num","attrib":{"value":"1179"},"text":"§ 1179.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Drug Abuse Training Center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14c1812c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1179/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; functions; general policies; transfer of supervision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall establish a National Drug Abuse Training Center (hereinafter in this section referred to as the “Center”) to develop, conduct, and support a full range of training programs relating to drug abuse prevention functions. The Director shall consult with the National Advisory Council for Drug Abuse Prevention regarding the general policies of the Center. The Director may supervise the operation of the Center initially, but shall transfer the supervision of the operation of the Center to the National Institute on Drug Abuse not later than ","children":[{"tag":"date","attrib":{"date":"1974-12-31"},"text":"December 31, 1974","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c1812d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1179/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities and material","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Center shall conduct or arrange for training programs, seminars, meetings, conferences, and other related activities, including the furnishing of training and educational materials for use by others.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c1812e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1179/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons eligible for services and facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The services and facilities of the Center shall, in accordance with regulations prescribed by the Director, be available to (1) Federal, State, and local governmental officials, and their respective staffs, (2) medical and paramedical personnel, and educators, and (3) other persons, including drug dependent persons, requiring training or education in drug abuse prevention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c1812f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1179/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; fiscal year availability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c18130-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1179/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of carrying out this section, there are authorized to be appropriated $1,000,000 for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1972-06-30"},"text":"June 30, 1972","children":[],"tail":", $3,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1973-06-30"},"text":"June 30, 1973","children":[],"tail":", $5,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1974-06-30"},"text":"June 30, 1974","children":[],"tail":", and $6,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1975-06-30"},"text":"June 30, 1975","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c18131-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1179/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sums appropriated under this subsection shall remain available for obligation or expenditure in the fiscal year for which appropriated and in the fiscal year next following.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14c18132-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/255/tIV/s412"},"text":"Pub. L. 92–255, title IV, § 412","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-03-21"},"text":"Mar. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/84"},"text":"86 Stat. 84","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14c18133-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14c18134-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14c18135-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Advisory Council for Drug Abuse Prevention, referred to in subsec. (a), was established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1151"},"text":"section 1151 of this title","children":[],"tail":", which was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/92/255/tI/s104"},"text":"Pub. L. 92–255, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-03-21"},"text":"Mar. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/67"},"text":"86 Stat. 67","children":[],"tail":", eff. "},{"tag":"date","attrib":{"date":"1975-06-30"},"text":"June 30, 1975","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
