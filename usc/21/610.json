{"tag":"section","attrib":{"id":"id148a93e1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s610"},"text":null,"children":[{"tag":"num","attrib":{"value":"610"},"text":"§ 610.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited acts","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"No person, firm, or corporation shall, with respect to any cattle, sheep, swine, goats, horses, mules, or other equines, or any carcasses, parts of carcasses, meat or meat food products of any such animals—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id148a93e2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s610/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Slaughtering animals or preparation of articles capable of use as human food","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"slaughter any such animals or prepare any such articles which are capable of use as human food at any establishment preparing any such articles for commerce, except in compliance with the requirements of this chapter;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id148a93e3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s610/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Humane methods of slaughter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"slaughter or handle in connection with slaughter any such animals in any manner not in accordance with the Act of ","children":[{"tag":"date","attrib":{"date":"1958-08-27"},"text":"August 27, 1958","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/72/862"},"text":"72 Stat. 862","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1901–190"},"text":"7 U.S.C. 1901–190","children":[],"tail":"6);"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id148a93e4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s610/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sales, transportation, and other transactions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"sell, transport, offer for sale or transportation, or receive for transportation, in commerce, (1) any such articles which (A) are capable of use as human food and (B) are adulterated or misbranded at the time of such sale, transportation, offer for sale or transportation, or receipt for transportation; or (2) any articles required to be inspected under this subchapter unless they have been so inspected and passed;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id148a93e5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s610/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adulteration or misbranding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"do, with respect to any such articles which are capable of use as human food, any act while they are being transported in commerce or held for sale after such transportation, which is intended to cause or has the effect of causing such articles to be adulterated or misbranded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id148a93e6-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1907-03-04/ch2907"},"text":"Mar. 4, 1907, ch. 2907","children":[],"tail":", title I, § 10, formerly 8th par., "},{