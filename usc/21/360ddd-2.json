{"tag":"section","attrib":{"id":"id14371c5e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"360ddd–2"},"text":"§ 360ddd–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability of drug fees to designated medical gases","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A designated medical gas, alone or in combination with another designated gas or gases (as medically appropriate) deemed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360ddd–1"},"text":"section 360ddd–1 of this title","children":[],"tail":" to have in effect an approved application shall not be assessed fees under section 379h(a) or 379j–12(a) of this title on the basis of such deemed approval."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id14371c5f-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s577"},"text":"June 25, 1938, ch. 675, § 577","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/144/tXI/s1111"},"text":"Pub. L. 112–144, title XI, § 1111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1111"},"text":"126 Stat. 1111","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIII/s3101/a/2/T"},"text":"Pub. L. 114–255, div. A, title III, § 3101(a)(2)(T)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1155"},"text":"130 Stat. 1155","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14371c60-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes