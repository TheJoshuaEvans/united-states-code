{"tag":"section","attrib":{"id":"id14bf102f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1050"},"text":null,"children":[{"tag":"num","attrib":{"value":"1050"},"text":"§ 1050.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of district courts; United States as plaintiff in enforcement and restraining proceedings; subpenas for witnesses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The United States district courts and the District Court of the Virgin Islands are vested with jurisdiction specifically to enforce, and to prevent and restrain violations of, this chapter, and shall have jurisdiction in all other cases, arising under this chapter, except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1047"},"text":"section 1047 of this title","children":[],"tail":". All proceedings for the enforcement or to restrain violations of this chapter shall be by and in the name of the United States. Subpenas for witnesses who are required to attend a court of the United States, in any district, may run into any other district in any such proceeding."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id14bf1030-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/597/s21"},"text":"Pub. L. 91–597, § 21","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-29"},"text":"Dec. 29, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1632"},"text":"84 Stat. 1632","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14bf1031-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14bf1032-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14bf1033-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/597"},"text":"Pub. L. 91–597","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-29"},"text":"Dec. 29, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1620"},"text":"84 Stat. 1620","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1031"},"text":"section 1031 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14bf1034-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id14bf1035-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/597/s29"},"text":"section 29 of Pub. L. 91–597","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1031"},"text":"section 1031 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
