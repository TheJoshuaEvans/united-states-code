{"tag":"section","attrib":{"id":"id13d7be25-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350i"},"text":null,"children":[{"tag":"num","attrib":{"value":"350i"},"text":"§ 350i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection against intentional adulteration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id13d7be26-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13d7be27-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350i/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13d7be28-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350i/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a vulnerability assessment of the food system, including by consideration of the Department of Homeland Security biological, chemical, radiological, or other terrorism risk assessments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d7be29-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350i/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the best available understanding of uncertainties, risks, costs, and benefits associated with guarding against intentional adulteration of food at vulnerable points; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d7be2a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350i/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the types of science-based mitigation strategies or measures that are necessary to protect against the intentional adulteration of food.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13d7be2b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350i/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the interest of national security, the Secretary, in consultation with the Secretary of Homeland Security, may determine the time, manner, and form in which determinations made under paragraph (1) are made publicly available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13d7be2c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"January 4, 2011","children":[],"tail":", the Secretary, in coordination with the Secretary of Homeland Security and in consultation with the Secretary of Agriculture, shall promulgate regulations to protect against the intentional adulteration of food subject to this chapter. Such regulations shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id13d7be2d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify how a person shall assess whether the person is required to implement mitigation strategies or measures intended to protect against the intentional adulteration of food; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13d7be2e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify appropriate science-based mitigation strategies or measures to prepare and protect the food supply chain at specific vulnerable points, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13d7be2f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Regulations promulgated under subsection (b) shall apply only to food for which there is a high risk of intentional contamination, as determined by the Secretary, in consultation with the Secretary of Homeland Security, under subsection (a), that could cause serious adverse health consequences or death to humans or animals and shall include those foods—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13d7be30-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350i/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the Secretary has identified clear vulnerabilities (including short shelf-life or susceptibility to intentional contamination at critical control points); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13d7be31-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350i/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in bulk or batch form, prior to being packaged for the final consumer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13d7be32-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350i/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to farms, except for those that produce milk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13d7be33-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350i/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “farm” has the meaning given that term in section 1.227 of title 21, Code of Federal Regulations (or any successor regulation).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id13d7be34-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s420"},"text":"June 25, 1938, ch. 675, § 420","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/353/tI/s106/a"},"text":"Pub. L. 111–353, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3905"},"text":"124 Stat. 3905","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id13d7be35-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id13d7be36-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id13d7be37-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in this section to be construed to apply to certain alcohol-related facilities, to alter jurisdiction and authorities established under certain other Acts, or in a manner inconsistent with international agreements to which the United States is a party, see sections 2206, 2251, and 2252 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id13d7be38-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Guidance Documents","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/353/tI/s106/b"},"text":"Pub. L. 111–353, title I, § 106(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3906"},"text":"124 Stat. 3906","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/353/tI/s106/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":"], the Secretary of Health and Human Services, in consultation with the Secretary of Homeland Security and the Secretary of Agriculture, shall issue guidance documents related to protection against the intentional adulteration of food, including mitigation strategies or measures to guard against such adulteration as required under section 420 of the Federal Food, Drug, and Cosmetic Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t21/s450i"},"text":"21 U.S.C. 450i","children":[],"tail":"], as added by subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The guidance documents issued under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a model assessment for a person to use under subsection (b)(1) of section 420 of the Federal Food, Drug, and Cosmetic Act, as added by subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include examples of mitigation strategies or measures described in subsection (b)(2) of such section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify situations in which the examples of mitigation strategies or measures described in subsection (b)(2) of such section are appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limited distribution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the interest of national security, the Secretary of Health and Human Services, in consultation with the Secretary of Homeland Security, may determine the time, manner, and form in which the guidance documents issued under paragraph (1) are made public, including by releasing such documents to targeted audiences.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id13d7be39-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Periodic Review","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/353/tI/s106/c"},"text":"Pub. L. 111–353, title I, § 106(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3906"},"text":"124 Stat. 3906","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/353/tI/s106/c"},"text":"“The Secretary of Health and Human Services shall periodically review and, as appropriate, update the regulations under section 420(b) of the Federal Food, Drug, and Cosmetic Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s450i/b"},"text":"21 U.S.C. 450i(b)","children":[],"tail":"], as added by subsection (a), and the guidance documents under subsection (b) ["},{"tag":"ref","attrib":{"href":"/us/pl/111/353/s106/b"},"text":"section 106(b) of Pub. L. 111–353","children":[],"tail":", set out above].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
