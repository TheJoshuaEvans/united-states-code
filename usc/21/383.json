{"tag":"section","attrib":{"id":"id14705468-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s383"},"text":null,"children":[{"tag":"num","attrib":{"value":"383"},"text":"§ 383.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of International Relations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14705469-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s383/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Department of Health and Human Services an Office of International Relations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1470546a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s383/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements with foreign countries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the functions of the office under subsection (a), the Secretary may enter into agreements with foreign countries to facilitate commerce in devices between the United States and such countries consistent with the requirements of this chapter. In such agreements, the Secretary shall encourage the mutual recognition of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1470546b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s383/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" good manufacturing practice regulations promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360j/f"},"text":"section 360j(f) of this title","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1470546c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s383/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other regulations and testing protocols as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1470546d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s383/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Harmonizing regulatory requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1470546e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s383/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall support the Office of the United States Trade Representative, in consultation with the Secretary of Commerce, in meetings with representatives of other countries to discuss methods and approaches to reduce the burden of regulation and harmonize regulatory requirements if the Secretary determines that such harmonization continues consumer protections consistent with the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1470546f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s383/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall support the Office of the United States Trade Representative, in consultation with the Secretary of Commerce, in efforts to move toward the acceptance of mutual recognition agreements relating to the regulation of drugs, biological products, devices, foods, food additives, and color additives, and the regulation of good manufacturing practices, between the European Union and the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14705470-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s383/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14705471-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s383/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall regularly participate in meetings with representatives of other foreign governments to discuss and reach agreement on methods and approaches to harmonize regulatory requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14705472-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s383/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out subparagraph (A), the Secretary may participate in appropriate fora, including the International Medical Device Regulators Forum, and may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14705473-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s383/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide guidance to such fora on strategies, policies, directions, membership, and other activities of a forum as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14705474-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s383/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent appropriate, solicit, review, and consider comments from industry, academia, health care professionals, and patient groups regarding the activities of such fora; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14705475-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s383/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent appropriate, inform the public of the Secretary’s activities within such fora, and share with the public any documentation relating to a forum’s strategies, policies, and other activities of such fora.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14705476-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s383/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to devices, the Secretary may, when appropriate, enter into arrangements with nations regarding methods and approaches to harmonizing regulatory requirements for activities, including inspections and common international labeling symbols.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14705477-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s383/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraphs (1) through (4) shall not apply with respect to products defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s321/ff"},"text":"section 321(ff) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14705478-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s803"},"text":"June 25, 1938, ch. 675, § 803","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/629/s15/a"},"text":"Pub. L. 101–629, § 15(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4525"},"text":"104 Stat. 4525","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/115/tIV/s410/b"},"text":"Pub. L. 105–115, title IV, § 410(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2373"},"text":"111 Stat. 2373","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/144/tVI"},"text":"Pub. L. 112–144, title VI","children":[],"tail":", §§ 609, 610, "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1059"},"text":"126 Stat. 1059","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14705479-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1470547a-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id1470547b-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/144/s610"},"text":"Pub. L. 112–144, § 610","children":[],"tail":", designated existing provisions as subpar. (A) and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/144/s609"},"text":"Pub. L. 112–144, § 609","children":[],"tail":", amended par. (4) generally. Prior to amendment, par. (4) read as follows: “The Secretary shall, not later than 180 days after "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"November 21, 1997","children":[],"tail":", make public a plan that establishes a framework for achieving mutual recognition of good manufacturing practices inspections.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/115"},"text":"Pub. L. 105–115","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1470547c-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id1470547d-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/115"},"text":"Pub. L. 105–115","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/115/s501"},"text":"section 501 of Pub. L. 105–115","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s321"},"text":"section 321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id1470547e-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report on Activities of Office of International Relations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/629/s15/b"},"text":"Pub. L. 101–629, § 15(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4525"},"text":"104 Stat. 4525","children":[],"tail":", directed Secretary of Health and Human Services, not later than 2 years after "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", to prepare and submit to the appropriate committees of Congress a report on the activities of the Office of International Relations under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s383"},"text":"21 U.S.C. 383","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
