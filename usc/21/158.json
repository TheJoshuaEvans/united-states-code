{"tag":"section","attrib":{"id":"id13a7fb00-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s158"},"text":null,"children":[{"tag":"num","attrib":{"value":"158"},"text":"§ 158.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offenses; punishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person, firm, or corporation who shall violate any of the provisions of this chapter shall be deemed guilty of a misdemeanor, and shall, upon conviction, be punished by a fine of not exceeding $1,000 or by imprisonment not exceeding one year, or by both such fine and imprisonment, in the discretion of the court.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id13a7fb01-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch145/s1"},"text":"Mar. 4, 1913, ch. 145, § 1","children":[],"tail":" (part), "},{"tag":"ref","attrib":{"href":"/us/stat/37/833"},"text":"37 Stat. 833","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id13a7fb02-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id13a7fb03-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id13a7fb04-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For explanation of “this chapter”, referred to in text, see References in Text note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s156"},"text":"section 156 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id13a7fb05-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"See note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s151"},"text":"section 151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
