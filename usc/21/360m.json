ref","attrib":{"href":"/us/stat/136/2312"},"text":"136 Stat. 2312","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tIII/s3109"},"text":"Pub. L. 117–328, div. FF, title III, § 3109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5808"},"text":"136 Stat. 5808","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id142679f5-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id142679f6-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id142679f7-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360e–3"},"text":"Section 360e–3 of this title","children":[],"tail":", referred to in subsec. (a)(3)(A)(ii), was in the original a reference to section 515C of act "},{"tag":"date","attrib":{"date":"1938-06-25"},"text":"June 25, 1938","children":[],"tail":", which was renumbered section 515B by "},{"tag":"ref","attrib":{"href":"/us/pl/115/52/tIX/s901/f/2"},"text":"Pub. L. 115–52, title IX, § 901(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-18"},"text":"Aug. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1077"},"text":"131 Stat. 1077","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id142679f8-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" substituted “on "},{"tag":"date","attrib":{"date":"2027-10-01"},"text":"October 1, 2027","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2022-12-24"},"text":"December 24, 2022","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/229"},"text":"Pub. L. 117–229","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2022-12-24"},"text":"December 24, 2022","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2022-12-17"},"text":"December 17, 2022","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/180"},"text":"Pub. L. 117–180","children":[],"tail":" substituted “December 17” for “October 1”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(3)(A)(ii) to (iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/52/s206/1/A"},"text":"Pub. L. 115–52, § 206(1)(A)","children":[],"tail":", added cls. (ii) to (iv) and struck out former cls. (ii) and (iii) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) a class II device which is intended to be permanently implantable or life sustaining or life supporting; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iii) a class II device which requires clinical data in the report submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360/k"},"text":"section 360(k) of this title","children":[],"tail":" for the device, except that the number of class II devices to which the Secretary applies this clause for a year, less the number of such reports to which clauses (i) and (ii) apply, may not exceed 6 percent of the number that is equal to the total number of reports submitted to the Secretary under such section for such year less the number of such reports to which such clauses apply for such year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/52/s206/1/B"},"text":"Pub. L. 115–52, § 206(1)(B)","children":[],"tail":", added subpar. (B) and struck out former subpar. (B). Prior to amendment, text read as follows: “In determining for a year the ratio described in subparagraph (A)(iii), the Secretary shall not include in the numerator class III devices that the Secretary reclassified into class II, and the Secretary shall include in the denominator class II devices for which reports under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360/k"},"text":"section 360(k) of this title","children":[],"tail":" were not required to be submitted by reason of the operation of "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360/m"},"text":"section 360(m) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/52/s206/1/C"},"text":"Pub. L. 115–52, § 206(1)(C)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(D), (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/52/s206/2/A"},"text":"Pub. L. 115–52, § 206(2)(A)","children":[],"tail":", redesignated subpar. (E) as (D) and struck out former subpar. (D). Prior to amendment, text of subpar. (D) read as follows: “The Secretary shall include in the annual report required under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s393/g"},"text":"section 393(g) of this title","children":[],"tail":" the names of all accredited persons and the particular activities under subsection (a) for which each such person is accredited and the name of each accredited person whose accreditation has been withdrawn during the year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/52/s206/2/B/iii"},"text":"Pub. L. 115–52, § 206(2)(B)(iii)","children":[],"tail":", added subpar. (E). Former subpar. (E) redesignated (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/52/s206/2/B/i"},"text":"Pub. L. 115–52, § 206(2)(B)(i)","children":[],"tail":", (ii), redesignated subpar. (E) as (F) and substituted “Such person shall agree, at a minimum, to include in its request for accreditation a commitment to, at the time of accreditation, and at any time it is performing any review pursuant to this section” for “The operations of such person shall be in accordance with generally accepted professional and ethical business practices and shall agree in writing that as a minimum it will” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/52/s206/3"},"text":"Pub. L. 115–52, § 206(3)","children":[],"tail":", substituted “2022’ for “2017”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","children":[],"tail":" struck out subsec. (d) which related to report to Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (b)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/144/s611/a"},"text":"Pub. L. 112–144, § 611(a)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/144/s611/b"},"text":"Pub. L. 112–144, § 611(b)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2017-10-01"},"text":"October 1, 2017","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"October 1, 2012","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (b)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/31"},"text":"Pub. L. 111–31","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s393/g"},"text":"section 393(g) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/85"},"text":"Pub. L. 110–85","children":[],"tail":" substituted “2012” for “2007”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/250/s202/1"},"text":"Pub. L. 107–250, § 202(1)","children":[],"tail":", substituted “The authority provided by this section terminates "},{"tag":"date","attrib":{"date":"2007-10-01"},"text":"October 1, 2007","children":[],"tail":".” for “The authority provided by this section terminates—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) 5 years after the date on which the Secretary notifies Congress that at least 2 persons accredited under subsection (b) of this section are available to review at least 60 percent of the submissions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360/k"},"text":"section 360(k) of this title","children":[],"tail":", or"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) 4 years after the date on which the Secretary notifies Congress that the Secretary has made a determination described in paragraph (2)(B) of subsection (a) of this section for at least 35 percent of the devices that are subject to review under paragraph (1) of such subsection,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"whichever occurs first.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/250/s202/2"},"text":"Pub. L. 107–250, § 202(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id142679f9-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id142679fa-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/180"},"text":"Pub. L. 117–180","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-10-01"},"text":"Oct. 1, 2022","children":[],"tail":", with fees under subpart 3 of part C of subchapter VII of this chapter to be assessed for all submissions listed in "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s379j/a/2/A"},"text":"section 379j(a)(2)(A) of this title","children":[],"tail":" received on or after "},{"tag":"date","attrib":{"date":"2022-10-01"},"text":"Oct. 1, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/180/s2008"},"text":"section 2008 of Pub. L. 117–180","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360d"},"text":"section 360d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id142679fb-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/52"},"text":"Pub. L. 115–52","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2017-10-01"},"text":"Oct. 1, 2017","children":[],"tail":", with fees under subpart 3 of part C of subchapter VII of this chapter to be assessed for all submissions listed in "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s379j/a/2/A"},"text":"section 379j(a)(2)(A) of this title","children":[],"tail":" received on or after "},{"tag":"date","attrib":{"date":"2017-10-01"},"text":"Oct. 1, 2017","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/52/s209"},"text":"section 209 of Pub. L. 115–52","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s379i"},"text":"section 379i of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id142679fc-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/115/s501"},"text":"section 501 of Pub. L. 105–115","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s321"},"text":"section 321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id142679fd-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reports on Program of Accreditation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/115/tII/s210/d"},"text":"Pub. L. 105–115, title II, § 210(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2345"},"text":"111 Stat. 2345","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/115/tII/s210/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Comptroller general.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation of program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 5 years after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":"], the Comptroller General of the United States shall submit to the Committee on Commerce [now Committee on Energy and Commerce] of the House of Representatives and the Committee on Labor and Human Resources [now Committee on Health, Education, Labor, and Pensions] of the Senate a report describing the extent to which the program of accreditation required by the amendment made by subsection (a) [enacting this section] has been implemented."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evaluation of program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 6 months prior to the date on which, pursuant to subsection (c) of section 523 of the Federal Food, Drug, and Cosmetic Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360m/c"},"text":"21 U.S.C. 360m(c)","children":[],"tail":"] (as added by subsection (a)), the authority provided under subsection (a) of such section will terminate, the Comptroller General shall submit to the Committee on Commerce [now Committee on Energy and Commerce] of the House of Representatives and the Committee on Labor and Human Resources [now Committee on Health, Education, Labor, and Pensions] of the Senate a report describing the use of accredited persons under such section 523, including an evaluation of the extent to which such use assisted the Secretary in carrying out the duties of the Secretary under such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"21 U.S.C. 301","children":[],"tail":" et seq.] with respect to devices, and the extent to which such use promoted actions which are contrary to the purposes of such Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusion of certain devices within program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 3 years after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":"], the Secretary of Health and Human Services shall submit to the Committee on Commerce of the House of Representatives and the Committee on Labor and Human Resources [now Committee on Health, Education, Labor, and Pensions] of the Senate a report providing a determination by the Secretary of whether, in the program of accreditation established pursuant to the amendment made by subsection (a), the limitation established in clause (iii) of section 523(a)(3)(A) of the Federal Food, Drug, and Cosmetic Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360m/a/3/A"},"text":"21 U.S.C. 360m(a)(3)(A)","children":[],"tail":"] (relating to class II devices for which clinical data are required in reports under section 510(k) ["},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360/k"},"text":"21 U.S.C. 360(k)","children":[],"tail":"]) should be removed.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
