{"tag":"section","attrib":{"id":"id142409c5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m"},"text":null,"children":[{"tag":"num","attrib":{"value":"360m"},"text":"§ 360m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accredited persons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id142409c6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id142409c7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and classification of devices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"1997-11-21"},"text":"November 21, 1997","children":[],"tail":", the Secretary shall, subject to paragraph (3), accredit persons for the purpose of reviewing reports submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360/k"},"text":"section 360(k) of this title","children":[],"tail":" and making recommendations to the Secretary regarding the initial classification of devices under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360c/f/1"},"text":"section 360c(f)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142409c8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements regarding review","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id142409c9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making a recommendation to the Secretary under paragraph (1), an accredited person shall notify the Secretary in writing of the reasons for the recommendation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142409ca-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time period for review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the date on which the Secretary is notified under subparagraph (A) by an accredited person with respect to a recommendation of an initial classification of a device, the Secretary shall make a determination with respect to the initial classification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142409cb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may change the initial classification under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360c/f/1"},"text":"section 360c(f)(1) of this title","children":[],"tail":" that is recommended under paragraph (1) by an accredited person, and in such case shall provide to such person, and the person who submitted the report under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360/k"},"text":"section 360(k) of this title","children":[],"tail":" for the device, a statement explaining in detail the reasons for the change."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142409cc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain devices","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id142409cd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An accredited person may not be used to perform a review of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id142409ce-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a class III device;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id142409cf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a device classified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360c/f/2"},"text":"section 360c(f)(2) of this title","children":[],"tail":" or designated under section 360e–3(d) "},{"tag":"ref","attrib":{"idref":"fn002075"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002075"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id142409d0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/a/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a device that is intended to be permanently implantable, life sustaining, or life supporting, unless otherwise determined by the Secretary in accordance with subparagraph (B)(i)(II) and listed as eligible for review under subparagraph (B)(iii); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id142409d1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/a/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a device that is of a type, or subset of a type, listed as not eligible for review under subparagraph (B)(iii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142409d2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation for review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id142409d3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" issue draft guidance on the factors the Secretary will use in determining whether a class I or class II device type, or subset of such device types, is eligible for review by an accredited person, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id142409d4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/a/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the risk of the device type, or subset of such device type; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id142409d5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/a/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the device type, or subset of such device type, is permanently implantable, life sustaining, or life supporting, and whether there is a detailed public health justification for permitting the review by an accredited person of such device type or subset;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id142409d6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 24 months after the date on which the Secretary issues such draft guidance, finalize such guidance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id142409d7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beginning on the date such guidance is finalized, designate and post on the internet website of the Food and Drug Administration, an updated list of class I and class II device types, or subsets of such device types, and the Secretary’s determination with respect to whether each such device type, or subset of a device type, is eligible or not eligible for review by an accredited person under this section based on the factors described in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142409d8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Until the date on which the updated list is designated and posted in accordance with subparagraph (B)(iii), the list in effect on ","children":[{"tag":"date","attrib":{"date":"2017-08-18"},"text":"August 18, 2017","children":[],"tail":", shall be in effect."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id142409d9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accreditation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id142409da-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for such accreditation through programs administered by the Food and Drug Administration, other government agencies, or by other qualified nongovernment organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142409db-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accreditation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id142409dc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1997-11-21"},"text":"November 21, 1997","children":[],"tail":", the Secretary shall establish and publish in the Federal Register criteria to accredit or deny accreditation to persons who request to perform the duties specified in subsection (a). The Secretary shall respond to a request for accreditation within 60 days of the receipt of the request. The accreditation of such person shall specify the particular activities under subsection (a) for which such person is accredited."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142409dd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal of accreditation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may suspend or withdraw accreditation of any person accredited under this paragraph, after providing notice and an opportunity for an informal hearing, when such person is substantially not in compliance with the requirements of this section or poses a threat to public health or fails to act in a manner that is consistent with the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142409de-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance auditing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To ensure that persons accredited under this section will continue to meet the standards of accreditation, the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id142409df-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make onsite visits on a periodic basis to each accredited person to audit the performance of such person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id142409e0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take such additional measures as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142679e1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic reaccreditation","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id142679e2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to suspension or withdrawal under subparagraph (B), any accreditation under this section shall be valid for a period of 3 years after its issuance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id142679e3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Response to reaccreditation request","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the submission of a request by an accredited person for reaccreditation under this section, the Secretary shall approve or deny such request not later than 60 days after receipt of the request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id142679e4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/b/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", the Secretary shall establish and publish in the Federal Register criteria to reaccredit or deny reaccreditation to persons under this section. The reaccreditation of persons under this section shall specify the particular activities under subsection (a), and the devices, for which such persons are reaccredited."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142679e5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An accredited person shall, at a minimum, meet the following requirements:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id142679e6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such person may not be an employee of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142679e7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such person shall be an independent organization which is not owned or controlled by a manufacturer, supplier, or vendor of devices and which has no organizational, material, or financial affiliation with such a manufacturer, supplier, or vendor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142679e8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such person shall be a legally constituted entity permitted to conduct the activities for which it seeks accreditation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142679e9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such person shall not engage in the design, manufacture, promotion, or sale of devices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142679ea-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The operations of such person shall be in accordance with generally accepted professional and ethical business practices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142679eb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such person shall agree, at a minimum, to include in its request for accreditation a commitment to, at the time of accreditation, and at any time it is performing any review pursuant to this section—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id142679ec-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/b/3/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify that reported information accurately reflects data reviewed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id142679ed-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/b/3/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit work to that for which competence and capacity are available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id142679ee-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/b/3/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treat information received, records, reports, and recommendations as proprietary information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id142679ef-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/b/3/F/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promptly respond and attempt to resolve complaints regarding its activities for which it is accredited; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id142679f0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/b/3/F/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect against the use, in carrying out subsection (a) with respect to a device, of any officer or employee of the person who has a financial conflict of interest regarding the device, and annually make available to the public disclosures of the extent to which the person, and the officers and employees of the person, have maintained compliance with requirements under this clause relating to financial conflicts of interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142679f1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of accredited persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide each person who chooses to use an accredited person to receive a ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360/k"},"text":"section 360(k) of this title","children":[],"tail":" report a panel of at least two or more accredited persons from which the regulated person may select one for a specific regulatory function."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142679f2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation of accredited persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Compensation for an accredited person shall be determined by agreement between the accredited person and the person who engages the services of the accredited person, and shall be paid by the person who engages such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id142679f3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360m/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority provided by this section terminates on ","children":[{"tag":"date","attrib":{"date":"2027-10-01"},"text":"October 1, 2027","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id142679f4-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s523"},"text":"June 25, 1938, ch. 675, § 523","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/115/tII/s210/a"},"text":"Pub. L. 105–115, title II, § 210(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2342"},"text":"111 Stat. 2342","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/250/tII/s202"},"text":"Pub. L. 107–250, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-26"},"text":"Oct. 26, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1609"},"text":"116 Stat. 1609","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/85/tII/s221"},"text":"Pub. L. 110–85, title II, § 221","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", "},