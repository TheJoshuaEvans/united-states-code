{"tag":"section","attrib":{"id":"id147eac67-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s396"},"text":null,"children":[{"tag":"num","attrib":{"value":"396"},"text":"§ 396.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Practice of medicine","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to limit or interfere with the authority of a health care practitioner to prescribe or administer any legally marketed device to a patient for any condition or disease within a legitimate health care practitioner-patient relationship. This section shall not limit any existing authority of the Secretary to establish and enforce restrictions on the sale or distribution, or in the labeling, of a device that are part of a determination of substantial equivalence, established as a condition of approval, or promulgated through regulations. Further, this section shall not change any existing prohibition on the promotion of unapproved uses of legally marketed devices.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id147eac68-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s1006"},"text":"June 25, 1938, ch. 675, § 1006","children":[],"tail":", formerly § 906, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/115/tII/s214"},"text":"Pub. L. 105–115, title II, § 214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2348"},"text":"111 Stat. 2348","children":[],"tail":"; renumbered § 1006, "},{"tag":"ref","attrib":{"href":"/us/pl/111/31/dA/tI/s101/b/2"},"text":"Pub. L. 111–31, div. A, title I, § 101(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-06-22"},"text":"June 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1784"},"text":"123 Stat. 1784","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id147eac69-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id147eac6a-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id147eac6b-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/115/s501"},"text":"section 501 of Pub. L. 105–115","children":[],"tail":", set out as an Effective Date of 1997 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s321"},"text":"section 321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
