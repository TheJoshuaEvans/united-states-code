{"tag":"section","attrib":{"id":"id148367f8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s456"},"text":null,"children":[{"tag":"num","attrib":{"value":"456"},"text":"§ 456.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation of premises, facilities and equipment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id148367f9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s456/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanitary practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each official establishment slaughtering poultry or processing poultry products for commerce or otherwise subject to inspection under this chapter shall have such premises, facilities, and equipment, and be operated in accordance with such sanitary practices, as are required by regulations promulgated by the Secretary for the purpose of preventing the entry into or flow or movement in commerce or burdensome effect upon commerce, of poultry products which are adulterated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id148367fa-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s456/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refusal of inspection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall refuse to render inspection to any establishment whose premises, facilities, or equipment, or the operation thereof, fail to meet the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id148367fb-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/172/s7"},"text":"Pub. L. 85–172, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-08-28"},"text":"Aug. 28, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/444"},"text":"71 Stat. 444","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/492/s7"},"text":"Pub. L. 90–492, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-18"},"text":"Aug. 18, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/799"},"text":"82 Stat. 799","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id148367fc-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id148367fd-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id148367fe-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1968—Par. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/492"},"text":"Pub. L. 90–492","children":[],"tail":" substituted “otherwise subject to inspection under this chapter” for “in or for marketing in a designated major consuming area”, “burdensome effect upon commerce” for “in a designated major consuming area”, and “which are adulterated” for “which are unwholesome or adulterated”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id148367ff-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id14836800-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1968 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/492"},"text":"Pub. L. 90–492","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1968-08-18"},"text":"Aug. 18, 1968","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/492/s20"},"text":"section 20 of Pub. L. 90–492","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s451"},"text":"section 451 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
