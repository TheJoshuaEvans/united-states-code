{"tag":"section","attrib":{"id":"id13bfefa0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s337"},"text":null,"children":[{"tag":"num","attrib":{"value":"337"},"text":"§ 337.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proceedings in name of United States; provision as to subpoenas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id13bfefa1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s337/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b), all such proceedings for the enforcement, or to restrain violations, of this chapter shall be by and in the name of the United States. Subpoenas for witnesses who are required to attend a court of the United States, in any district, may run into any other district in any proceeding under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13bfefa2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s337/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13bfefa3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s337/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State may bring in its own name and within its jurisdiction proceedings for the civil enforcement, or to restrain violations, of section 341, 343(b), 343(c), 343(d), 343(e), 343(f), 343(g), 343(h), 343(i), 343(k), 343(q), or 343(r) of this title if the food that is the subject of the proceedings is located in the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13bfefa4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s337/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No proceeding may be commenced by a State under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13bfefa5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s337/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before 30 days after the State has given notice to the Secretary that the State intends to bring such proceeding,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13bfefa6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s337/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before 90 days after the State has given notice to the Secretary of such intent if the Secretary has, within such 30 days, commenced an informal or formal enforcement action pertaining to the food which would be the subject of such proceeding, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13bfefa7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s337/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary is diligently prosecuting a proceeding in court pertaining to such food, has settled such proceeding, or has settled the informal or formal enforcement action pertaining to such food.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In any court proceeding described in subparagraph (C), a State may intervene as a matter of right.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id13bfefa8-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s310"},"text":"June 25, 1938, ch. 675, § 310","children":[],"tail":", formerly § 307, "},{"tag":"ref","attrib":{"href":"/us/stat/52/1046"},"text":"52 Stat. 1046","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-09-03/ch1263/s37"},"text":"Sept. 3, 1954, ch. 1263, § 37","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1239"},"text":"68 Stat. 1239","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/535/s4"},"text":"Pub. L. 101–535, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-08"},"text":"Nov. 8, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2362"},"text":"104 Stat. 2362","children":[],"tail":"; renumbered § 310, "},{"tag":"ref","attrib":{"href":"/us/pl/102/282/s2"},"text":"Pub. L. 102–282, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-13"},"text":"May 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/150"},"text":"106 Stat. 150","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id13bfefa9-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id13bfefaa-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id13bfefab-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/535"},"text":"Pub. L. 101–535","children":[],"tail":" substituted “(a) Except as provided in subsection (b), all” for “All” and “any proceeding under this section” for “any such proceeding” and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Act ","children":[{"tag":"date","attrib":{"date":"1954-09-03"},"text":"Sept. 3, 1954","children":[],"tail":", struck out reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s654"},"text":"section 654 of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id13bfefac-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id13bfefad-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/535"},"text":"Pub. L. 101–535","children":[],"tail":" effective 24 months after "},{"tag":"date","attrib":{"date":"1990-11-08"},"text":"Nov. 8, 1990","children":[],"tail":", except that such amendment effective "},{"tag":"date","attrib":{"date":"1993-12-31"},"text":"Dec. 31, 1993","children":[],"tail":", with respect to dietary supplements of vitamins, minerals, herbs, or other similar nutritional substances, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/535/s10/a/1/C"},"text":"section 10(a)(1)(C) of Pub. L. 101–535","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s343"},"text":"section 343 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id13bfefae-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of Amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/535"},"text":"Pub. L. 101–535","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"Amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/535"},"text":"Pub. L. 101–535","children":[],"tail":" not to be construed to alter authority of Secretary of Health and Human Services and Secretary of Agriculture under the Federal Food, Drug, and Cosmetic Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"21 U.S.C. 301","children":[],"tail":" et seq.), the Federal Meat Inspection Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s601"},"text":"21 U.S.C. 601","children":[],"tail":" et seq.), the Poultry Products Inspection Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s451"},"text":"21 U.S.C. 451","children":[],"tail":" et seq.), and the Egg Products Inspection Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1031"},"text":"21 U.S.C. 1031","children":[],"tail":" et seq.), see "},{"tag":"ref","attrib":{"href":"/us/pl/101/535/s9"},"text":"section 9 of Pub. L. 101–535","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s343"},"text":"section 343 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
