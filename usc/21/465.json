{"tag":"section","attrib":{"id":"id1485d877-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s465"},"text":null,"children":[{"tag":"num","attrib":{"value":"465"},"text":"§ 465.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations upon entry of poultry products and other materials into official establishments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may limit the entry of poultry products and other materials into any official establishment, under such conditions as he may prescribe to assure that allowing the entry of such articles into such inspected establishments will be consistent with the purposes of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id1485d878-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/172/s16"},"text":"Pub. L. 85–172, § 16","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-08-28"},"text":"Aug. 28, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/448"},"text":"71 Stat. 448","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/492/s15"},"text":"Pub. L. 90–492, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-18"},"text":"Aug. 18, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/805"},"text":"82 Stat. 805","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1485d879-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1485d87a-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id1485d87b-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/492"},"text":"Pub. L. 90–492","children":[],"tail":" substituted provisions authorizing the Secretary to limit the entry of poultry products and other materials into any official establishment for provisions that any person distributing unwholesome or adulterated exempted poultry or poultry products intended for human consumption shall be guilty of a misdemeanor and subject to penalties upon conviction thereof."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1485d87c-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id1485d87d-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1968 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/492"},"text":"Pub. L. 90–492","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1968-08-18"},"text":"Aug. 18, 1968","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/492/s20"},"text":"section 20 of Pub. L. 90–492","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s451"},"text":"section 451 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
