{"tag":"section","attrib":{"id":"id141cdd92-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"360e–4"},"text":"§ 360e–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Predetermined change control plans for devices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id141cdd93-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approved devices","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id141cdd94-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–4/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360e/d/5/A"},"text":"section 360e(d)(5)(A) of this title","children":[],"tail":", a supplemental application shall not be required for a change to a device approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360e"},"text":"section 360e of this title","children":[],"tail":", if such change is consistent with a predetermined change control plan that is approved pursuant to paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id141cdd95-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–4/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Predetermined change control plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may approve a predetermined change control plan submitted in an application, including a supplemental application, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360e"},"text":"section 360e of this title","children":[],"tail":" that describes planned changes that may be made to the device (and that would otherwise require a supplemental application under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360e"},"text":"section 360e of this title","children":[],"tail":"), if the device remains safe and effective without any change."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id141cdd96-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–4/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may require that a change control plan include labeling required for safe and effective use of the device as such device changes pursuant to such plan, notification requirements if the device does not function as intended pursuant to such plan, and performance requirements for changes made under the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id141cdd97-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cleared devices","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id141cdd98-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–4/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360/k"},"text":"section 360(k) of this title","children":[],"tail":", a premarket notification shall not be required for a change to a device cleared under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360/k"},"text":"section 360(k) of this title","children":[],"tail":", if such change is consistent with an established predetermined change control plan granted pursuant to paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id141cdd99-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–4/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Predetermined change control plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may clear a predetermined change control plan submitted in a notification submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360/k"},"text":"section 360(k) of this title","children":[],"tail":" that describes planned changes that may be made to the device (and that would otherwise require a new notification), if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id141cdd9a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–4/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the device remains safe and effective without any such change; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id141cdd9b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–4/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the device would remain substantially equivalent to the predicate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id141cdd9c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–4/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may require that a change control plan include labeling required for safe and effective use of the device as such device changes pursuant to such plan, notification requirements if the device does not function as intended pursuant to such plan, and performance requirements for changes made under the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id141cdd9d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360e–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Predicate devices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making a determination of substantial equivalence pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360c/i"},"text":"section 360c(i) of this title","children":[],"tail":", the Secretary shall not compare a device to changed versions of a device implemented in accordance with an established predetermined change control plan as a predicate device. Only the version of the device cleared or approved, prior to changes made under the predetermined change control plan, may be used by a sponsor as a predicate device."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id141cdd9e-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s515C"},"text":"June 25, 1938, ch. 675, § 515C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tIII/s3308/a"},"text":"Pub. L. 117–328, div. FF, title III, § 3308(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5835"},"text":"136 Stat. 5835","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id141cdd9f-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id141cdda0-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id141cdda1-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 515C of act ","children":[{"tag":"date","attrib":{"date":"1938-06-25"},"text":"June 25, 1938","children":[],"tail":", was renumbered section 515B and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360e–3"},"text":"section 360e–3 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
