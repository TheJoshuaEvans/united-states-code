{"tag":"section","attrib":{"id":"id14ae6ea1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862"},"text":null,"children":[{"tag":"num","attrib":{"value":"862"},"text":"§ 862.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of Federal benefits to drug traffickers and possessors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14ae6ea2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drug traffickers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14ae6ea3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any individual who is convicted of any Federal or State offense consisting of the distribution of controlled substances shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14ae6ea4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the discretion of the court, upon the first conviction for such an offense be ineligible for any or all Federal benefits for up to 5 years after such conviction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14ae6ea5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the discretion of the court, upon a second conviction for such an offense be ineligible for any or all Federal benefits for up to 10 years after such conviction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14ae6ea6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon a third or subsequent conviction for such an offense be permanently ineligible for all Federal benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14ae6ea7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The benefits which are denied under this subsection shall not include benefits relating to long-term drug treatment programs for addiction for any person who, if there is a reasonable body of evidence to substantiate such declaration, declares himself to be an addict and submits himself to a long-term treatment program for addiction, or is deemed to be rehabilitated pursuant to rules established by the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14ae6ea8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drug possessors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14ae6ea9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any individual who is convicted of any Federal or State offense involving the possession of a controlled substance (as such term is defined for purposes of this subchapter) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14ae6eaa-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" upon the first conviction for such an offense and at the discretion of the court—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14ae6eab-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be ineligible for any or all Federal benefits for up to one year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14ae6eac-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be required to successfully complete an approved drug treatment program which includes periodic testing to insure that the individual remains drug free;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14ae6ead-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be required to perform appropriate community service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14ae6eae-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any combination of clause (i), (ii), or (iii); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14ae6eaf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon a second or subsequent conviction for such an offense be ineligible for all Federal benefits for up to 5 years after such conviction as determined by the court. The court shall continue to have the discretion in subparagraph (A) above. In imposing penalties and conditions under subparagraph (A), the court may require that the completion of the conditions imposed by clause (ii) or (iii) be a requirement for the reinstatement of benefits under clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14ae6eb0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The penalties and conditions which may be imposed under this subsection shall be waived in the case of a person who, if there is a reasonable body of evidence to substantiate such declaration, declares himself to be an addict and submits himself to a long-term treatment program for addiction, or is deemed to be rehabilitated pursuant to rules established by the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14ae6eb1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of period of ineligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The period of ineligibility referred to in subsections (a) and (b) shall be suspended if the individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14ae6eb2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/c/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completes a supervised drug rehabilitation program after becoming ineligible under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14ae6eb3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/c/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has otherwise been rehabilitated; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14ae6eb4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/c/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has made a good faith effort to gain admission to a supervised drug rehabilitation program, but is unable to do so because of inaccessibility or unavailability of such a program, or the inability of the individual to pay for such a program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14ae6eb5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14ae6eb6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “Federal benefit”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14ae6eb7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means the issuance of any grant, contract, loan, professional license, or commercial license provided by an agency of the United States or by appropriated funds of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14ae6eb8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include any retirement, welfare, Social Security, health, disability, veterans benefit, public housing, or other similar benefit, or any other benefit for which payments or services are required for eligibility; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14ae6eb9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “veterans benefit” means all benefits provided to veterans, their families, or survivors by virtue of the service of a veteran in the Armed Forces of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14ae6eba-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability of this section to Government witnesses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The penalties provided by this section shall not apply to any individual who cooperates or testifies with the Government in the prosecution of a Federal or State offense or who is in a Government witness protection program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14ae6ebb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to affect the obligation of the United States to any Indian or Indian tribe arising out of any treaty, statute, Executive order, or the trust responsibility of the United States owing to such Indian or Indian tribe. Nothing in this subsection shall exempt any individual Indian from the sanctions provided for in this section, provided that no individual Indian shall be denied any benefit under Federal Indian programs comparable to those described in subsection (d)(1)(B) or (d)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14ae6ebc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14ae6ebd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" On or before ","children":[{"tag":"date","attrib":{"date":"1989-05-01"},"text":"May 1, 1989","children":[],"tail":", the President shall transmit to the Congress a report—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14ae6ebe-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delineating the role of State courts in implementing this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14ae6ebf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing the manner in which Federal agencies will implement and enforce the requirements of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14ae6ec0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detailing the means by which Federal and State agencies, courts, and law enforcement agencies will exchange and share the data and information necessary to implement and enforce the withholding of Federal benefits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14ae6ec1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/g/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommending any modifications to improve the administration of this section or otherwise achieve the goal of discouraging the trafficking and possession of controlled substances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14ae6ec2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No later than ","children":[{"tag":"date","attrib":{"date":"1989-09-01"},"text":"September 1, 1989","children":[],"tail":", the Congress shall consider the report of the President and enact such changes as it deems appropriate to further the goals of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14ae6ec3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s862/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The denial of Federal benefits set forth in this section shall take effect for convictions occurring after ","children":[{"tag":"date","attrib":{"date":"1989-09-01"},"text":"September 1, 1989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14ae6ec4-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/tII/s421"},"text":"Pub. L. 91–513, title II, § 421","children":[],"tail":", formerly "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tV/s5301"},"text":"Pub. L. 100–690, title V, § 5301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4310"},"text":"102 Stat. 4310","children":[],"tail":"; renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/91/513/s421"},"text":"§ 421 of Pub. L. 91–513","children":[],"tail":" and amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tX/s1002/d"},"text":"Pub. L. 101–647, title X, § 1002(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4827"},"text":"104 Stat. 4827","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14ae6ec5-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14ae6ec6-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id14ae6ec7-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s853a"},"text":"section 853a of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14ae6ec8-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/s1002/d/1"},"text":"Pub. L. 101–647, § 1002(d)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s853a"},"text":"section 853a of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/s1002/d/2"},"text":"Pub. L. 101–647, § 1002(d)(2)","children":[],"tail":", struck out “(as such terms are defined for purposes of the Controlled Substances Act)” after “controlled substances” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
