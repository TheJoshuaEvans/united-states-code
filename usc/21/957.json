{"tag":"section","attrib":{"id":"id14b7e525-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s957"},"text":null,"children":[{"tag":"num","attrib":{"value":"957"},"text":"§ 957.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons required to register","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14b7e526-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s957/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No person may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14b7e527-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s957/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" import into the customs territory of the United States from any place outside thereof (but within the United States), or import into the United States from any place outside thereof, any controlled substance or list I chemical, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14b7e528-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s957/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" export from the United States any controlled substance or list I chemical,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"unless there is in effect with respect to such person a registration issued by the Attorney General under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s958"},"text":"section 958 of this title","children":[],"tail":", or unless such person is exempt from registration under subsection (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14b7e529-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s957/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14b7e52a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s957/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following persons shall not be required to register under the provisions of this section and may lawfully possess a controlled substance or list I chemical:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14b7e52b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s957/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An agent or an employee of any importer or exporter registered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s958"},"text":"section 958 of this title","children":[],"tail":" if such agent or employee is acting in the usual course of his business or employment."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14b7e52c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s957/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A common or contract carrier or warehouseman, or an employee thereof, whose possession of any controlled substance or list I chemical is in the usual course of his business or employment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14b7e52d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s957/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An ultimate user who possesses such substance for a purpose specified in section 802(25) ","children":[{"tag":"ref","attrib":{"idref":"fn002166"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002166"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title and in conformity with an exemption granted under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s956/a"},"text":"section 956(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14b7e52e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s957/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General may, by regulation, waive the requirement for registration of certain importers and exporters if he finds it consistent with the public health and safety; and may authorize any such importer or exporter to possess controlled substances or list I chemicals for purposes of importation and exportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14b7e52f-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/tIII/s1007"},"text":"Pub. L. 91–513, title III, § 1007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1288"},"text":"84 Stat. 1288","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s523"},"text":"Pub. L. 98–473, title II, § 523","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2076"},"text":"98 Stat. 2076","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/200/s3/e"},"text":"Pub. L. 103–200, § 3(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-17"},"text":"Dec. 17, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2337"},"text":"107 Stat. 2337","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14b7e530-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14b7e531-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14b7e532-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802/25"},"text":"Section 802(25) of this title","children":[],"tail":", referred to in subsec. (b)(1)(C), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s802/26"},"text":"section 802(26) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s507/a"},"text":"Pub. L. 98–473, title II, § 507(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2071"},"text":"98 Stat. 2071","children":[],"tail":", and was further redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s802/27"},"text":"section 802(27) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tI/s1003/b/2"},"text":"Pub. L. 99–570, title I, § 1003(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-6"},"text":"100 Stat. 3207–6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14b7e533-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/200/s3/e/1/A"},"text":"Pub. L. 103–200, § 3(e)(1)(A)","children":[],"tail":", inserted “or list I chemical” after “controlled substance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/200/s3/e/1/B"},"text":"Pub. L. 103–200, § 3(e)(1)(B)","children":[],"tail":", substituted “or list I chemical,” for “in schedule I, II, III, IV, or V,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/200/s3/e/2/A"},"text":"Pub. L. 103–200, § 3(e)(2)(A)","children":[],"tail":", inserted “or list I chemical” after “controlled substance” in introductory provisions and subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/200/s3/e/2/B"},"text":"Pub. L. 103–200, § 3(e)(2)(B)","children":[],"tail":", inserted “or list I chemicals” after “controlled substances”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":" inserted reference to schedule V."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14b7e534-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id14b7e535-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/200"},"text":"Pub. L. 103–200","children":[],"tail":" effective on date that is 120 days after "},{"tag":"date","attrib":{"date":"1993-12-17"},"text":"Dec. 17, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/200/s11"},"text":"section 11 of Pub. L. 103–200","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"section 802 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id14b7e536-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of seventh calendar month that begins after ","children":[{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", see 1105(a) of "},{"tag":"ref","attrib":{"href":"/us/pl/91/513"},"text":"Pub. L. 91–513","children":[],"tail":", set out as a under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s951"},"text":"section 951 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id14b7e537-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Provisional Registration","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/tIII/s1104"},"text":"Pub. L. 91–513, title III, § 1104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1294"},"text":"84 Stat. 1294","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is engaged in importing or exporting any controlled substance on the day before the effective date of section 1007 [","children":[{"tag":"date","attrib":{"date":"1971-05-01"},"text":"May 1, 1971","children":[],"tail":"],"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who notifies the Attorney General that he is so engaged, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is registered on such day under section 510 of the Federal Food, Drug, and Cosmetic Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360"},"text":"section 360 of this title","children":[],"tail":"] or under section 4722 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954, "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4722"},"text":"section 4722 of title 26","children":[],"tail":"],"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall, with respect to each establishment for which such registration is in effect under any such section, be deemed to have a provisional registration under section 1008 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s958"},"text":"section 958 of this title","children":[],"tail":"] for the import or export (as the case may be) of controlled substances."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During the period his provisional registration is in effect under this section, the registration number assigned such person under such section 510 or under such section 4722 (as the case may be) shall be his registration number for purposes of part A of this title [this subchapter].","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of section 304 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s824"},"text":"section 824 of this title","children":[],"tail":"], relating to suspension and revocation of registration, shall apply to a provisional registration under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Unless sooner suspended or revoked under subsection (b), a provisional registration of a person under subsection (a)(1) of this section shall be in effect until—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which such person has registered with the Attorney General under section 1008 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s958"},"text":"section 958 of this title","children":[],"tail":"] or has had his registration denied under such section, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such date as may be prescribed by the Attorney General for registration of importers or exporters, as the case may be,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"whichever occurs first.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
