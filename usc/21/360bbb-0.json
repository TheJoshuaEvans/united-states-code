{"tag":"section","attrib":{"id":"id142da60a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0"},"text":null,"children":[{"tag":"num","attrib":{"value":"360bbb–0"},"text":"§ 360bbb–0.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expanded access policy required for investigational drugs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id142da60b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The manufacturer or distributor of one or more investigational drugs for the diagnosis, monitoring, or treatment of one or more serious diseases or conditions shall make available the policy of the manufacturer or distributor on evaluating and responding to requests submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360bbb/b"},"text":"section 360bbb(b) of this title","children":[],"tail":" for provision of such a drug."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id142da60c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability of expanded access policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The policies under subsection (a) shall be made public and readily available, such as by posting such policies on a publicly available Internet website. Such policies may be generally applicable to all investigational drugs of such manufacturer or distributor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id142da60d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A policy described in subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id142da60e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contact information for the manufacturer or distributor to facilitate communication about requests described in subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142da60f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for making such requests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142da610-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the general criteria the manufacturer or distributor will use to evaluate such requests for individual patients, and for responses to such requests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142da611-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the length of time the manufacturer or distributor anticipates will be necessary to acknowledge receipt of such requests; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142da612-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a hyperlink or other reference to the clinical trial record containing information about the expanded access for such drug that is required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s282/j/2/A/ii/II/gg"},"text":"section 282(j)(2)(A)(ii)(II)(gg) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id142da613-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No guarantee of access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The posting of policies by manufacturers and distributors under subsection (a) shall not serve as a guarantee of access to any specific investigational drug by any individual patient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id142da614-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revised policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall prevent a manufacturer or distributor from revising a policy required under this section at any time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id142da615-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall apply to a manufacturer or distributor with respect to an investigational drug beginning on the earlier of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id142da616-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first initiation of a phase 2 or phase 3 study (as such terms are defined in section 312.21(b) and (c) of title 21, Code of Federal Regulations (or any successor regulations)) with respect to such investigational drug; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142da617-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360bbb–0/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as applicable, 15 days after the drug receives a designation as a breakthrough therapy, fast track product, or regenerative advanced therapy under subsection (a), (b), or (g), respectively, of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s356"},"text":"section 356 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id142da618-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s561A"},"text":"June 25, 1938, ch. 675, § 561A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIII/s3032"},"text":"Pub. L. 114–255, div. A, title III, § 3032","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1100"},"text":"130 Stat. 1100","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/52/tVI/s610/c"},"text":"Pub. L. 115–52, title VI, § 610(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-18"},"text":"Aug. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1053"},"text":"131 Stat. 1053","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id142da619-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id142da61a-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id142da61b-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/52"},"text":"Pub. L. 115–52","children":[],"tail":" substituted “earlier” for “later” in introductory provisions, added par. (2), redesignated former par. (2) as (1), and struck out former par. (1) which read as follows: “the date that is 60 calendar days after "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"December 13, 2016","children":[],"tail":"; or”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
