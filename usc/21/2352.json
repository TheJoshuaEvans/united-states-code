{"tag":"section","attrib":{"id":"id14d9502c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2352"},"text":null,"children":[{"tag":"num","attrib":{"value":"2352"},"text":"§ 2352.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of national emergency authorities; reporting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14d9502d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2352/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may exercise all authorities provided under sections 1702 and 1704 of title 50 to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d9502e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2352/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d9502f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2352/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2024-04-24"},"text":"April 24, 2024","children":[],"tail":", and annually thereafter, the President shall submit to the appropriate congressional committees a report on actions taken by the executive branch pursuant to this subchapter and any national emergency declared with respect to the trafficking of fentanyl and trade in other illicit drugs, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d95030-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2352/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issuance of any new or revised regulations, policies, or guidance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d95031-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2352/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the imposition of sanctions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d95032-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2352/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the collection of relevant information from outside parties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d95033-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2352/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issuance or closure of general licenses, specific licenses, and statements of licensing policy by the Office of Foreign Assets Control;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d95034-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2352/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any pending enforcement cases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d95035-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2352/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of mitigation procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d95036-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2352/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report required under paragraph (1) shall be submitted in unclassified form, but may include the matters required under subparagraphs (C), (D), (E), and (F) of such paragraph in a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14d95037-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/50/dE/tI/s3102"},"text":"Pub. L. 118–50, div. E, title I, § 3102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-24"},"text":"Apr. 24, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/936"},"text":"138 Stat. 936","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
