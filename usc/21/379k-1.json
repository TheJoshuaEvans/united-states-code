:{"href":"/us/usc/t21/s379j/a/2/A"},"text":"section 379j(a)(2)(A) of this title","children":[],"tail":" received on or after "},{"tag":"date","attrib":{"date":"2017-10-01"},"text":"Oct. 1, 2017","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/52/s209"},"text":"section 209 of Pub. L. 115–52","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s379i"},"text":"section 379i of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
