{"tag":"section","attrib":{"id":"id14692921-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379k–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"379k–1"},"text":"§ 379k–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic format for submissions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14692922-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379k–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drugs and biologics","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14692923-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379k–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning no earlier than 24 months after the issuance of a final guidance issued after public notice and opportunity for comment, submissions under subsection (b), (i), or (j) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"section 355 of this title","children":[],"tail":" or subsection (a) or (k) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"section 262 of title 42","children":[],"tail":" shall be submitted in such electronic format as specified by the Secretary in such guidance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14692924-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379k–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the guidance under paragraph (1), the Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14692925-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379k–1/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a timetable for establishment by the Secretary of further standards for electronic submission as required by such paragraph; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14692926-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379k–1/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth criteria for waivers of and exemptions from the requirements of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14692927-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379k–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall not apply to submissions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360bbb"},"text":"section 360bbb of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14692928-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379k–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Devices","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14692929-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379k–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning after the issuance of final guidance implementing this paragraph, presubmissions and submissions for devices under section 360(k), 360c(f)(2)(A), 360e(c), 360e(d), 360e(f), 360j(g), 360j(m), or 360bbb–3 of this title or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"section 262 of title 42","children":[],"tail":", and any supplements to such presubmissions or submissions, shall include an electronic copy of such presubmissions or submissions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1469292a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379k–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the guidance under paragraph (1), the Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1469292b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379k–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide standards for the electronic copy required under such paragraph; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1469292c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379k–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth criteria for waivers of and exemptions from the requirements of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1469292d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379k–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presubmissions and submissions solely in electronic format","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1469292e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379k–1/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning on such date as the Secretary specifies in final guidance issued under subparagraph (C), presubmissions and submissions for devices described in paragraph (1) (and any appeals of action taken by the Secretary with respect to such presubmissions or submissions) shall be submitted solely in such electronic format as specified by the Secretary in such guidance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1469292f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379k–1/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Draft guidance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, not later than ","children":[{"tag":"date","attrib":{"date":"2019-10-01"},"text":"October 1, 2019","children":[],"tail":", issue draft guidance providing for—"}],"tail":null},{"tag":"clause","attrib":{"id":"id14692930-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379k–1/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any further standards for the submission by electronic format required under subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14692931-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379k–1/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a timetable for the establishment by the Secretary of such further standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14692932-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379k–1/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" criteria for waivers of and exemptions from the requirements of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14692933-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379k–1/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, not later than 1 year after the close of the public comment period on the draft guidance issued under subparagraph (B), issue final guidance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14692934-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s745A"},"text":"June 25, 1938, ch. 675, § 745A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/144/tXI/s1136"},"text":"Pub. L. 112–144, title XI, § 1136","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1123"},"text":"126 Stat. 1123","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/52/tII/s207"},"text":"Pub. L. 115–52, title II, § 207