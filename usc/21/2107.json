{"tag":"section","attrib":{"id":"id14d2243c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2107"},"text":null,"children":[{"tag":"num","attrib":{"value":"2107"},"text":"§ 2107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d2243d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2107/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is vital for Congress to provide the Food and Drug Administration with additional resources, authorities, and direction with respect to ensuring the safety of the food supply of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d2243e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2107/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional inspectors are required to improve the Food and Drug Administration’s ability to safeguard the food supply of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d2243f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2107/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because of the increasing volume of international trade in food products the Secretary should make it a priority to enter into agreements with the trading partners of the United States with respect to food safety; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d22440-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2107/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Congress should work to develop a comprehensive response to the issue of food safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14d22441-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/85/tX/s1008"},"text":"Pub. L. 110–85, title X, § 1008","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/970"},"text":"121 Stat. 970","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
