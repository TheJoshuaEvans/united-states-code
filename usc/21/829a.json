{"tag":"section","attrib":{"id":"id14a26109-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s829a"},"text":null,"children":[{"tag":"num","attrib":{"value":"829a"},"text":"§ 829a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delivery of a controlled substance by a pharmacy to an administering practitioner","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14a2610a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s829a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802/10"},"text":"section 802(10) of this title","children":[],"tail":", a pharmacy may deliver a controlled substance to a practitioner in accordance with a prescription that meets the requirements of this subchapter and the regulations issued by the Attorney General under this subchapter, for the purpose of administering the controlled substance by the practitioner if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id14a2610b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s829a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the controlled substance is delivered by the pharmacy to the prescribing practitioner or the practitioner administering the controlled substance, as applicable, at the location listed on the practitioner’s certificate of registration issued under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14a2610c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s829a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the controlled substance is a drug in schedule III, IV, or V to be administered—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14a2610d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s829a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by injection or implantation for the purpose of maintenance or detoxification treatment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14a2610e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s829a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to a risk evaluation and mitigation strategy pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355–1"},"text":"section 355–1 of this title","children":[],"tail":" that includes elements to assure safe use of the drug described in subsection (f)(3)(E) of such section, including a requirement for post-administration monitoring by a health care provider;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14a2610f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s829a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the pharmacy and the practitioner are authorized to conduct the activities specified in this section under the law of the State in which such activities take place;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14a26110-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s829a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prescription is not issued to supply any practitioner with a stock of controlled substances for the purpose of general dispensing to patients;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14a26111-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s829a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subsection (b), the controlled substance is to be administered only to the patient named on the prescription not later than 45 days after the date of receipt of the controlled substance by the practitioner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14a26112-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s829a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding any exceptions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s827"},"text":"section 827 of this title","children":[],"tail":", the prescribing practitioner, and the practitioner administering the controlled substance, as applicable, maintain complete and accurate records of all controlled substances delivered, received, administered, or otherwise disposed of under this section, including the persons to whom controlled substances were delivered and such other information as may be required by regulations of the Attorney General."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14a26113-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s829a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification of number of days before which controlled substance shall be administered","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14a26114-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s829a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial 2-year period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the 2-year period beginning on ","children":[{"tag":"date","attrib":{"date":"2018-10-24"},"text":"October 24, 2018","children":[],"tail":", the Attorney General, in coordination with the Secretary, may reduce the number of days described in subsection (a)(5) if the Attorney General determines that such reduction will—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14a26115-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s829a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce the risk of diversion; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14a26116-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s829a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect the public health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14a26117-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s829a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modifications after submission of report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the date on which the report described in section 3204(b) of the SUPPORT for Patients and Communities Act is submitted, the Attorney General, in coordination with the Secretary, may modify the number of days described in subsection (a)(5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14a26118-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s829a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum number of days","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any modification under this subsection shall be for a period of not less than 7 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14a26119-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/tII/s309A"},"text":"Pub. L. 91–513, title II, § 309A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/tIII/s3204/a"},"text":"Pub. L. 115–271, title III, § 3204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3945"},"text":"132 Stat. 3945","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/215/tI/s103/b/1/E"},"text":"Pub. L. 117–215, title I, § 103(b)(1)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-02"},"text":"Dec. 2, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2263"},"text":"136 Stat. 2263","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI"},"text":"Pub. L. 117–328, div. FF, title I","children":[],"tail":", §§ 1262(b)(2), 1264, "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5682"},"text":"136 Stat. 5682","children":[],"tail":", 5685; "},{"tag":"ref","attrib":{"href":"/us/pl/119/26/s4/2/B/iii"},"text":"Pub. L. 119–26, § 4(2)(B)(iii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-16"},"text":"July 16, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/416"},"text":"139 Stat. 416","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/44/tIV/s401"},"text":"Pub. L. 119–44, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-01"},"text":"Dec. 1, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/689"},"text":"139 Stat. 689","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14a2611a-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14a2611b-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14a2611c-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Schedules III, IV, and V, referred to in subsec. (a)(2), are set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s812/c"},"text":"section 812(c) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3204(b) of the SUPPORT for Patients and Communities Act, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s3204/b"},"text":"section 3204(b) of Pub. L. 115–271","children":[],"tail":", title III, "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3946"},"text":"132 Stat. 3946","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14a2611d-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s401"},"text":"Pub. L. 119–44, § 401","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows: “the controlled substance is a narcotic drug in schedule III, IV, or V to be administered for the purpose of maintenance or detoxification treatment and is to be administered by injection or implantation;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/26/s4/2/B/iii"},"text":"Pub. L. 119–26, § 4(2)(B)(iii)","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1262/b/2"},"text":"Pub. L. 117–328, § 1262(b)(2)","children":[],"tail":". See 2022 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1262/b/2"},"text":"Pub. L. 117–328, § 1262(b)(2)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/119/26/s4/2/B/iii"},"text":"Pub. L. 119–26, § 4(2)(B)(iii)","children":[],"tail":", substituted “the controlled substance is a narcotic drug in schedule III, IV, or V to be administered for the purpose of maintenance or detoxification treatment and is to be administered by injection or implantation;” for “the controlled substance is to be administered for the purpose of maintenance or detoxification treatment under section 823(g)(2) and—”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the practitioner who issued the prescription is a qualifying practitioner authorized under, and acting within the scope of that section; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the controlled substance is to be administered by injection or implantation;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/215"},"text":"Pub. L. 117–215","children":[],"tail":" substituted “823(h)(2)” for “823(g)(2)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1264"},"text":"Pub. L. 117–328, § 1264","children":[],"tail":", substituted “45 days” for “14 days”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14a2611e-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id14a2611f-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/26/s4"},"text":"Pub. L. 119–26, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-16"},"text":"July 16, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/416"},"text":"139 Stat. 416","children":[],"tail":", provided that the amendment made by section 4(2)(B)(iii) is effective as if included in the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
