{"tag":"section","attrib":{"id":"id147c3bce-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v"},"text":null,"children":[{"tag":"num","attrib":{"value":"387v"},"text":"§ 387v.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting on tobacco regulation activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id147c3bcf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For fiscal year 2022 and each subsequent fiscal year for which fees are collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s387s"},"text":"section 387s of this title","children":[],"tail":", the Secretary of Health and Human Services shall, not later than 180 days after the end of the fiscal year, prepare and submit to the Committee on Energy and Commerce and the Committee on Appropriations of the House of Representatives, and the Committee on Health, Education, Labor, and Pensions and the Committee on Appropriations of the Senate, an annual report that contains the information required under subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id147c3bd0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted under subsection (a) shall contain the following information for the previous fiscal year:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id147c3bd1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Total annual user fee collections.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147c3bd2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Total amount of fees obligated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147c3bd3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of unobligated carryover balance from fees collected.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147c3bd4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount obligated by the Center for Tobacco Products for each of the following activities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id147c3bd5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Compliance and enforcement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3bd6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Public education campaigns.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3bd7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Scientific research and research infrastructure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3bd8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Communications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3bd9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Leadership, management oversight, and administrative services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3bda-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/b/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Related overhead activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147c3bdb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The numbers of applications, categorized by class of tobacco product and review pathway under sections 387e, 387j, and 387k of this title, that were—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id147c3bdc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submitted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3bdd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pending;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3bde-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accepted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3bdf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refused to file;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3be0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/b/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withdrawn;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3be1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/b/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" denied;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3be2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/b/5/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorized for marketing under an order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3be3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/b/5/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issued a deficiency letter or environmental information request letter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3be4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/b/5/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referred to the Tobacco Products Scientific Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147c3be5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number and titles of draft and final guidance documents and proposed and final regulations issued on topics related to the process for the review of tobacco product applications, whether such regulations and guidance documents were issued as required by statute or by other legal or regulatory requirements, and whether the issuance met the deadlines set forth by the applicable statute or other requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147c3be6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number and titles of public meetings related to the review of tobacco product applications by the Center for Tobacco Products or other offices or centers within the Food and Drug Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147c3be7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of pre-submission meetings relating to applications under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s387j"},"text":"section 387j of this title","children":[],"tail":", including the number of meeting requests received, the number of meetings held, and the median amount of time between when such meeting requests were made and when the requests were granted or denied."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147c3be8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of full-time equivalent employees funded pursuant to fees collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s387s"},"text":"section 387s of this title","children":[],"tail":", including identification of the centers and offices within the Food and Drug Administration in which such positions are located."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147c3be9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of inspections and investigations conducted at domestic and foreign establishments required to register under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s387e"},"text":"section 387e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147c3bea-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total number of compliance and enforcement actions issued or taken with respect to tobacco products, including warning letters, civil money penalties, no-tobacco-sale orders, and other enforcement actions (including seizures, injunctions, and criminal prosecution).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id147c3beb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services shall make the reports required under this section available to the public on the website of the Food and Drug Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id147c3bec-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387v/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Reporting under this section shall include best estimates for any reporting category for which the Food and Drug Administration does not have precise calculations. Such best estimates shall be accompanied with an explanatory statement for why the Food and Drug Administration does not have access to, or cannot calculate, the exact figure and a date by which the Food and Drug Administration will update its internal accounting procedures to allow for such reporting. If a category is successfully reported by the Food and Drug Administration with regard to another type of user fee but is provided a best estimate by the Center for Tobacco Products, the explanatory statement shall include information regarding how the Food and Drug Administration will align systems and apply learning across the agency to allow for accurate reporting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id147c3bed-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dP/tI/s112"},"text":"Pub. L. 117–103, div. P, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/790"},"text":"136 Stat. 790","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id147c3bee-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id147c3bef-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id147c3bf0-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Consolidated Appropriations Act, 2022, and not as part of the Federal Food, Drug, and Cosmetic Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id147c3bf1-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id147c3bf2-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report on Removal of All Illegal ENDS Products From the Market","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/37/dB/tVII/s772/c"},"text":"Pub. L. 119–37, div. B, title VII, § 772(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-11-12"},"text":"Nov. 12, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/556"},"text":"139 Stat. 556","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/37/dB/tVII/s772/c"},"text":"“The Commissioner of Food and Drugs shall submit a semi-annual written report to the Committees on Appropriations of both Houses of Congress on the progress that the Center for Tobacco Products is making in removing all illegal ENDS products from the market: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the initial report shall be submitted not later than 180 days after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2025-11-12"},"text":"Nov. 12, 2025","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
