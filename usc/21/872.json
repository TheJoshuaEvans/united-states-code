{"tag":"section","attrib":{"id":"id14b0b94b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s872"},"text":null,"children":[{"tag":"num","attrib":{"value":"872"},"text":"§ 872.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education and research programs of Attorney General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14b0b94c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s872/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General is authorized to carry out educational and research programs directly related to enforcement of the laws under his jurisdiction concerning drugs or other substances which are or may be subject to control under this subchapter. Such programs may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14b0b94d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s872/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational and training programs on drug abuse and controlled substances law enforcement for local, State, tribal, and Federal personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14b0b94e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s872/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies or special projects designed to compare the deterrent effects of various enforcement strategies on drug use and abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14b0b94f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s872/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies or special projects designed to assess and detect accurately the presence in the human body of drugs or other substances which are or may be subject to control under this subchapter, including the development of rapid field identification methods which would enable agents to detect microquantities of such drugs or other substances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14b0b950-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s872/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies or special projects designed to evaluate the nature and sources of the supply of illegal drugs throughout the country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14b0b951-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s872/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies or special projects to develop more effective methods to prevent diversion of controlled substances into illegal channels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14b0b952-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s872/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies or special projects to develop information necessary to carry out his functions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s811"},"text":"section 811 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14b0b953-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s872/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may enter into contracts for such educational and research activities without performance bonds and without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14b0b954-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s872/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of research populations; authorization to withhold","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may authorize persons engaged in research to withhold the names and other identifying characteristics of persons who are the subjects of such research. Persons who obtain this authorization may not be compelled in any Federal, State, tribal, or local civil, criminal, administrative, legislative, or other proceeding to identify the subjects of research for which such authorization was obtained.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14b0b955-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s872/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affect of treaties and other international agreements on confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in the Single Convention on Narcotic Drugs, the Convention on Psychotropic Substances, or other treaties or international agreements shall be construed to limit, modify, or prevent the protection of the confidentiality of patient records or of the names and other identifying characteristics of research subjects as provided by any Federal, State, or local law or regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14b0b956-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s872/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of controlled substances in research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General, on his own motion or at the request of the Secretary, may authorize the possession, distribution, and dispensing of controlled substances by persons engaged in research. Persons who obtain this authorization shall be exempt from State or Federal prosecution for possession, distribution, and dispensing of controlled substances to the extent authorized by the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14b0b957-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s872/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program to curtail diversion of precursor and essential chemicals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall maintain an active program, both domestic and international, to curtail the diversion of precursor chemicals and essential chemicals used in the illicit manufacture of controlled substances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14b0b958-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/tII/s502"},"text":"Pub. L. 91–513, title II, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1271"},"text":"84 Stat. 1271","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/633/tI/s108/a"},"text":"Pub. L. 95–633, title I, § 108(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3773"},"text":"92 Stat. 3773","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6060"},"text":"Pub. L. 100–690, title VI, § 6060","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4320"},"text":"102 Stat. 4320","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s232/a"},"text":"Pub. L. 111–211, title II, § 232(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2278"},"text":"124 Stat. 2278","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14b0b959-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14b0b95a-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id14b0b95b-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":"” substituted for “section 3709 of the Revised Statutes ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s5"},"text":"41 U.S.C. 5","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14b0b95c-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsecs. (a)(1), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211"},"text":"Pub. L. 111–211","children":[],"tail":" inserted “tribal,” after “State,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/633"},"text":"Pub. L. 95–633","children":[],"tail":" added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14b0b95d-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id14b0b95e-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" effective 120 days after "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/s6061"},"text":"section 6061 of Pub. L. 100–690","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"section 802 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id14b0b95f-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/633"},"text":"Pub. L. 95–633","children":[],"tail":" effective on date the Convention on Psychotropic Substances enters into force in the United States ["},{"tag":"date","attrib":{"date":"1980-07-15"},"text":"July 15, 1980","children":[],"tail":"], see "},{"tag":"ref","attrib":{"href":"/us/pl/95/633/s112"},"text":"section 112 of Pub. L. 95–633","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s801a"},"text":"section 801a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id14b0b960-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effect of Grants","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s232/e"},"text":"Pub. L. 111–211, title II, § 232(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2279"},"text":"124 Stat. 2279","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/211/tII/s232/e"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Nothing in this section [amending this section and sections 872a, 873, and 878 of this title] or any amendment made by this section—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allows the grant to be made to, or used by, an entity for law enforcement activities that the entity lacks jurisdiction to perform; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has any effect other than to authorize, award, or deny a grant of funds to a federally recognized Indian tribe for the purposes described in the relevant grant program.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “Indian tribe” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s232/e"},"text":"section 232(e) of Pub. L. 111–211","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/s203/a"},"text":"section 203(a) of Pub. L. 111–211","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2801"},"text":"section 2801 of Title 25","children":[],"tail":", Indians.]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id14b0b961-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Training for Drug Enforcement Administration and State and Local Law Enforcement Personnel Relating to Clandestine Laboratories","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXVI/s3623"},"text":"Pub. L. 106–310, div. B, title XXXVI, § 3623","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1231"},"text":"114 Stat. 1231","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/310/dB/tXXXVI/s3623"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Drug Enforcement Administration shall carry out the programs described in subsection (b) with respect to the law enforcement personnel of States and localities determined by the Administrator to have significant levels of methamphetamine-related or amphetamine-related crime or projected by the Administrator to have the potential for such levels of crime in the future.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The duration of any program under that subsection may not exceed 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Programs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The programs described in this subsection are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advanced mobile clandestine laboratory training teams","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A program of advanced mobile clandestine laboratory training teams, which shall provide information and training to State and local law enforcement personnel in techniques utilized in conducting undercover investigations and conspiracy cases, and other information designed to assist in the investigation of the illegal manufacturing and trafficking of amphetamine and methamphetamine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Basic clandestine laboratory certification training","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A program of basic clandestine laboratory certification training, which shall provide information and training—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to Drug Enforcement Administration personnel and State and local law enforcement personnel for purposes of enabling such personnel to meet any certification requirements under law with respect to the handling of wastes created by illegal amphetamine and methamphetamine laboratories; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to State and local law enforcement personnel for purposes of enabling such personnel to provide the information and training covered by subparagraph (A) to other State and local law enforcement personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Clandestine laboratory recertification and awareness training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A program of clandestine laboratory recertification and awareness training, which shall provide information and training to State and local law enforcement personnel for purposes of enabling such personnel to provide recertification and awareness training relating to clandestine laboratories to additional State and local law enforcement personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated for each of fiscal years 2000, 2001, and 2002 amounts as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,500,000 to carry out the program described in subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,000,000 to carry out the program described in subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000 to carry out the program described in subsection (b)(3).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id14b0b962-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Educational Program for Police Departments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/305/s4"},"text":"Pub. L. 104–305, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-13"},"text":"Oct. 13, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3809"},"text":"110 Stat. 3809","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/305/s4"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Attorney General may—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create educational materials regarding the use of controlled substances (as that term is defined in section 102 of the Controlled Substances Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"21 U.S.C. 802","children":[],"tail":"]) in the furtherance of rapes and sexual assaults; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate those materials to police departments throughout the United States.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id14b0b963-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study and Report on Measures To Prevent Sales of Agents Used in Methamphetamine Production","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/237/tII/s202"},"text":"Pub. L. 104–237, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-03"},"text":"Oct. 3, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3101"},"text":"110 Stat. 3101","children":[],"tail":", required the Attorney General of the United States to conduct a study on measures to effectively prevent the diversion of red phosphorous, iodine, hydrochloric gas, and other agents for use in the production of methamphetamine, and to submit to Congress no later than "},{"tag":"date","attrib":{"date":"1998-01-01"},"text":"Jan. 1, 1998","children":[],"tail":", a report of the findings pursuant to the study on the need for and advisability of preventive measures."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
