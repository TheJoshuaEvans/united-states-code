{"tag":"section","attrib":{"id":"id14d95004-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341"},"text":null,"children":[{"tag":"num","attrib":{"value":"2341"},"text":"§ 2341.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d95005-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d95006-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Banking, Housing, and Urban Affairs of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d95007-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d95008-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Financial Services of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d95009-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d9500a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “foreign person”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d9500b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14d9500c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any citizen or national of a foreign country; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d9500d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any entity not organized under the laws of the United States or a jurisdiction within the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d9500e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include the government of a foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d9500f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Knowingly","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “knowingly”, with respect to conduct, a circumstance, or a result, means that a person has actual knowledge, or should have known, of the conduct, the circumstance, or the result.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d95010-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trafficking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “trafficking”, with respect to fentanyl, fentanyl precursors, or other related opioids, has the meaning given the term “opioid trafficking” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s2302/8"},"text":"section 2302(8) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d95011-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transnational criminal organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “transnational criminal organization” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d95012-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any organization designated as a significant transnational criminal organization under part 590 of title 31, Code of Federal Regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d95013-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any of the organizations known as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14d95014-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Sinaloa Cartel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d95015-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Jalisco New Generation Cartel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d95016-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Gulf Cartel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d95017-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341/5/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Los Zetas Cartel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d95018-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341/5/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Juarez Cartel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d95019-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341/5/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Tijuana Cartel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d9501a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341/5/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Beltran-Leyva Cartel; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d9501b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341/5/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" La Familia Michoacana; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d9501c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any successor organization to an organization described in subparagraph (B) or as otherwise determined by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d9501d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “United States person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d9501e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States citizen or an alien lawfully admitted for permanent residence to the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d9501f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity organized under the laws of the United States or of any jurisdiction within the United States, including a foreign branch of such an entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d95020-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2341/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14d95021-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/50/dE/s3003"},"text":"Pub. L. 118–50, div. E, § 3003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-24"},"text":"Apr. 24, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/935"},"text":"138 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14d95022-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14d95023-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14d95024-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in introductory provisions, was in the original “this division”, meaning div. E of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/50"},"text":"Pub. L. 118–50","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-24"},"text":"Apr. 24, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/934"},"text":"138 Stat. 934","children":[],"tail":", known as the Fentanyl Eradication and Narcotics Deterrence Off Fentanyl or the FEND Off Fentanyl Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14d95025-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id14d95026-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/50/dE/s3001"},"text":"Pub. L. 118–50, div. E, § 3001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-24"},"text":"Apr. 24, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/934"},"text":"138 Stat. 934","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/50/dE/s3001"},"text":"“This division [enacting this chapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s2313a"},"text":"section 2313a of this title","children":[],"tail":" and amending sections 1701 and 4315 of Title 50, War and National Defense] may be cited as the ‘Fentanyl Eradication and Narcotics Deterrence Off Fentanyl’ [sic; probably should be followed by “Act”] or the ‘FEND Off Fentanyl Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
