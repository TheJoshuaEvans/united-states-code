{"tag":"section","attrib":{"id":"id14c63d56-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604"},"text":null,"children":[{"tag":"num","attrib":{"value":"1604"},"text":"§ 1604.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of biomaterials suppliers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14c63d57-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1606"},"text":"section 1606 of this title","children":[],"tail":", a biomaterials supplier shall not be liable for harm to a claimant caused by an implant unless such supplier is liable—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c63d58-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a manufacturer of the implant, as provided in subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c63d59-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a seller of the implant, as provided in subsection (c); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c63d5a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for furnishing raw materials or component parts for the implant that failed to meet applicable contractual requirements or specifications, as provided in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c63d5b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability as manufacturer","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c63d5c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A biomaterials supplier may, to the extent required and permitted by any other applicable law, be liable for harm to a claimant caused by an implant if the biomaterials supplier is the manufacturer of the implant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c63d5d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grounds for liability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The biomaterials supplier may be considered the manufacturer of the implant that allegedly caused harm to a claimant only if the biomaterials supplier—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c63d5e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14c63d5f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" registered or was required to register with the Secretary pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360"},"text":"section 360 of this title","children":[],"tail":" and the regulations issued under such section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14c63d60-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" included or was required to include the implant on a list of devices filed with the Secretary pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360/j"},"text":"section 360(j) of this title","children":[],"tail":" and the regulations issued under such section;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c63d61-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is the subject of a declaration issued by the Secretary pursuant to paragraph (3) that states that the supplier, with respect to the implant that allegedly caused harm to the claimant, was required to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14c63d62-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" register with the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360"},"text":"section 360 of this title","children":[],"tail":", and the regulations issued under such section, but failed to do so; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14c63d63-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include the implant on a list of devices filed with the Secretary pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360/j"},"text":"section 360(j) of this title","children":[],"tail":" and the regulations issued under such section, but failed to do so; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c63d64-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is related by common ownership or control to a person meeting all the requirements described in subparagraph (A) or (B), if the court deciding a motion to dismiss in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1605/c/3/B/i"},"text":"section 1605(c)(3)(B)(i) of this title","children":[],"tail":" finds, on the basis of affidavits submitted in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1605"},"text":"section 1605 of this title","children":[],"tail":", that it is necessary to impose liability on the biomaterials supplier as a manufacturer because the related manufacturer meeting the requirements of subparagraph (A) or (B) lacks sufficient financial resources to satisfy any judgment that the court feels it is likely to enter should the claimant prevail."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c63d65-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative procedures","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c63d66-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may issue a declaration described in paragraph (2)(B) on the motion of the Secretary or on petition by any person, after providing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14c63d67-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notice to the affected persons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14c63d68-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an opportunity for an informal hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c63d69-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Docketing and final decision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Immediately upon receipt of a petition filed pursuant to this paragraph, the Secretary shall docket the petition. Not later than 120 days after the petition is filed, the Secretary shall issue a final decision on the petition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c63d6a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of statute of limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any applicable statute of limitations shall toll during the period from the time a claimant files a petition with the Secretary under this paragraph until such time as either (i) the Secretary issues a final decision on the petition, or (ii) the petition is withdrawn.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c63d6b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stay pending petition for declaration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a claimant has filed a petition for a declaration with respect to a defendant, and the Secretary has not issued a final decision on the petition, the court shall stay all proceedings with respect to that defendant until such time as the Secretary has issued a final decision on the petition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c63d6c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability as seller","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A biomaterials supplier may, to the extent required and permitted by any other applicable law, be liable as a seller for harm to a claimant caused by an implant only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c63d6d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the biomaterials supplier—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c63d6e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" held title to the implant and then acted as a seller of the implant after its initial sale by the manufacturer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c63d6f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acted under contract as a seller to arrange for the transfer of the implant directly to the claimant after the initial sale by the manufacturer of the implant; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c63d70-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the biomaterials supplier is related by common ownership or control to a person meeting all the requirements described in paragraph (1), if a court deciding a motion to dismiss in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1605/c/3/B/ii"},"text":"section 1605(c)(3)(B)(ii) of this title","children":[],"tail":" finds, on the basis of affidavits submitted in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1605"},"text":"section 1605 of this title","children":[],"tail":", that it is necessary to impose liability on the biomaterials supplier as a seller because the related seller meeting the requirements of paragraph (1) lacks sufficient financial resources to satisfy any judgment that the court feels it is likely to enter should the claimant prevail."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14c63d71-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for failure to meet applicable contractual requirements or specifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A biomaterials supplier may, to the extent required and permitted by any other applicable law, be liable for harm to a claimant caused by an implant if the claimant in an action shows, by a preponderance of the evidence, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14c63d72-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the biomaterials supplier supplied raw materials or component parts for use in the implant that either—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14c63d73-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" did not constitute the product described in the contract between the biomaterials supplier and the person who contracted for the supplying of the product; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14c63d74-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" failed to meet any specifications that were—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14c63d75-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accepted, pursuant to applicable law, by the biomaterials supplier;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14c63d76-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" published by the biomaterials supplier;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14c63d77-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided by the biomaterials supplier to the person who contracted for such product;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14c63d78-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/d/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contained in a master file that was submitted by the biomaterials supplier to the Secretary and that is currently maintained by the biomaterials supplier for purposes of premarket approval of medical devices; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14c63d79-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/d/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" included in the submissions for purposes of premarket approval or review by the Secretary under section 360, 360c, 360e, or 360j of this title, and received clearance from the Secretary if such specifications were accepted, pursuant to applicable law, by the biomaterials supplier; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14c63d7a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1604/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such failure to meet applicable contractual requirements or specifications was an actual and proximate cause of the harm to the claimant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14c63d7b-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/230/s5"},"text":"Pub. L. 105–230, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-13"},"text":"Aug. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1524"},"text":"112 Stat. 1524","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14c63d7c-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14c63d7d-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id14c63d7e-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to all civil actions covered under this chapter commenced on or after ","children":[{"tag":"date","attrib":{"date":"1998-08-13"},"text":"Aug. 13, 1998","children":[],"tail":", including any in which the harm or harmful conduct occurred before such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/230/s8"},"text":"section 8 of Pub. L. 105–230","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1601"},"text":"section 1601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
