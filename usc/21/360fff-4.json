{"tag":"section","attrib":{"id":"id143e48c8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"360fff–4"},"text":"§ 360fff–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance; other provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id143e48c9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id143e48ca-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–4/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id143e48cb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–4/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Draft guidance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2014-11-26"},"text":"November 26, 2014","children":[],"tail":", the Secretary shall issue draft guidance on the implementation of, and compliance with, the requirements with respect to sunscreen under this part, including guidance on—"}],"tail":null},{"tag":"clause","attrib":{"id":"id143e48cc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–4/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the format and content of information submitted by a sponsor in support of a request under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360fff–1"},"text":"section 360fff–1 of this title","children":[],"tail":" or a pending request;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id143e48cd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–4/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the data required to meet the safety and efficacy standard for determining whether a nonprescription sunscreen active ingredient or combination of nonprescription sunscreen active ingredients is GRASE and is not misbranded;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id143e48ce-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–4/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the process by which a request under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360fff–1"},"text":"section 360fff–1 of this title","children":[],"tail":" or a pending request is withdrawn; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id143e48cf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–4/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the process by which the Secretary will carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360fff–3/c"},"text":"section 360fff–3(c) of this title","children":[],"tail":", including with respect to how the Secretary will address the total number of requests received under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360fff–1"},"text":"section 360fff–1 of this title","children":[],"tail":" and pending requests."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143e48d0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–4/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall finalize the guidance described in subparagraph (A) not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2014-11-26"},"text":"November 26, 2014","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143e48d1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–4/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability of Paperwork Reduction Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 35 of title 44 shall not apply to collections of information made for purposes of guidance under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143e48d2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–4/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submissions pending issuance of final guidance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Irrespective of whether final guidance under paragraph (1) has been issued—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id143e48d3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–4/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" persons may, beginning on ","children":[{"tag":"date","attrib":{"date":"2014-11-26"},"text":"November 26, 2014","children":[],"tail":", make submissions under this part; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143e48d4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–4/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall review and act upon such submissions in accordance with this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id143e48d5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of construction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id143e48d6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–4/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Currently marketed sunscreens","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this part shall be construed to affect the marketing of sunscreens that are marketed in interstate commerce on or before ","children":[{"tag":"date","attrib":{"date":"2014-11-26"},"text":"November 26, 2014","children":[],"tail":", except as otherwise provided in this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143e48d7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–4/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ensuring safety and effectiveness","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this part shall be construed to alter the authority of the Secretary with respect to prohibiting the marketing of a sunscreen that is not safe and effective or is misbranded, or with respect to imposing restrictions on the marketing of a sunscreen to ensure safety and effectiveness, except as otherwise provided in this part, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360fff–3/e"},"text":"section 360fff–3(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143e48d8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–4/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other drugs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360fff–6"},"text":"section 360fff–6 of this title","children":[],"tail":", nothing in this part shall be construed to affect the authority of the Secretary under this chapter or the Public Health Service Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"42 U.S.C. 201","children":[],"tail":" et seq.) with respect to a drug other than a nonprescription sunscreen."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143e48d9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–4/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on drugs otherwise approved","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this part shall affect the marketing of a drug approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"section 355 of this title","children":[],"tail":" or section 351 of the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"42 U.S.C. 262","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id143e48da-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The timelines for the processes and procedures under paragraphs (1), (2), (5), and (6) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360fff–3/a"},"text":"section 360fff–3(a) of this title","children":[],"tail":" shall not apply to any requests submitted to the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360fff–1"},"text":"section 360fff–1 of this title","children":[],"tail":" after the date that is 6 years after "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"November 26, 2014","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id143e48db-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s586D"},"text":"June 25, 1938, ch. 675, § 586D","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/195/s2/a"},"text":"Pub. L. 113–195, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2044"},"text":"128 Stat. 2044","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id143e48dc-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id143e48dd-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id143e48de-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Public Health Service Act, referred to in subsec. (b)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"act July 1, 1944, ch. 373","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/682"},"text":"58 Stat. 682","children":[],"tail":", which is classified generally to chapter 6A (§ 201 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
