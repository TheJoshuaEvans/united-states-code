{"tag":"section","attrib":{"id":"id13a7fb78-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s204"},"text":null,"children":[{"tag":"num","attrib":{"value":"204"},"text":"§ 204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of license","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If the applicant for license as a pharmacist has complied with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s203"},"text":"section 203 of this title","children":[],"tail":", the consul shall issue to him a license which shall entitle him to practice pharmacy in the consular districts of the United States in China, subject to the provisions of this chapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id13a7fb79-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1915-03-03/ch74/s3"},"text":"Mar. 3, 1915, ch. 74, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/819"},"text":"38 Stat. 819","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
