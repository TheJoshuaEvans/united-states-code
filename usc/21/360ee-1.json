{"tag":"section","attrib":{"id":"id1428c49d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ee–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"360ee–1"},"text":"§ 360ee–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FDA rare neurodegenerative disease grant program","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Health and Human Services, acting through the Commissioner of Food and Drugs, shall award grants and contracts to public and private entities to cover the costs of research on, and development of interventions intended to prevent, diagnose, mitigate, treat, or cure, amyotrophic lateral sclerosis and other rare neurodegenerative diseases in adults and children, including costs incurred with respect to the development and critical evaluation of tools, methods, and processes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1428c49e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ee–1/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to characterize such neurodegenerative diseases and their natural history;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1428c49f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ee–1/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify molecular targets for such neurodegenerative diseases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1428c4a0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ee–1/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to increase efficiency and productivity of clinical development of therapies, including through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1428c4a1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ee–1/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of master protocols and adaptive and add-on clinical trial designs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1428c4a2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ee–1/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts to establish new or leverage existing clinical trial networks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1428c4a3-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/79/s5"},"text":"Pub. L. 117–79, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-23"},"text":"Dec. 23, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1537"},"text":"135 Stat. 1537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1428c4a4-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1428c4a5-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id1428c4a6-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Accelerating Access to Critical Therapies for ALS Act, and not as part of the Federal Food, Drug, and Cosmetic Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
