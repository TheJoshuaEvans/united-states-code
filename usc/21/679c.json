{"tag":"section","attrib":{"id":"id148f4e17-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679c"},"text":null,"children":[{"tag":"num","attrib":{"value":"679c"},"text":"§ 679c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion of Food Safety Inspection Service activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id148f4e18-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture may utilize existing authorities to give high priority to enhancing and expanding the capacity of the Food Safety Inspection Service to conduct activities to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id148f4e19-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance the ability of the Service to inspect and ensure the safety and wholesomeness of meat and poultry products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id148f4e1a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the capacity of the Service to inspect international meat and meat products, poultry and poultry products, and egg products at points of origin and at ports of entry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id148f4e1b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthen the ability of the Service to collaborate with relevant agencies within the Department of Agriculture and with other entities in the Federal Government, the States, and Indian tribes (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304/e"},"text":"section 5304(e) of title 25","children":[],"tail":") through the sharing of information and technology; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id148f4e1c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise expand the capacity of the Service to protect against the threat of bioterrorism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id148f4e1d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section, $15,000,000 for fiscal year 2002, and such sums as may be necessary for each subsequent fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id148f4e1e-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/188/tIII/s332"},"text":"Pub. L. 107–188, title III, § 332","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-12"},"text":"June 12, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/679"},"text":"116 Stat. 679","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id148f4e1f-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id148f4e20-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id148f4e21-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Public Health Security and Bioterrorism Preparedness and Response Act of 2002, and not as part of the Federal Meat Inspection Act which is classified to subchapters I to IV–A of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
