{"tag":"section","attrib":{"id":"id143e4860-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"360fff–2"},"text":"§ 360fff–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility determinations; data submission; filing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id143e4861-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility determinations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id143e4862-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 calendar days after the date of receipt of a request under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360fff–1"},"text":"section 360fff–1 of this title","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id143e4863-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine, in accordance with paragraph (2), whether the request is eligible for further review under subsection (b) and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360fff–3"},"text":"section 360fff–3 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143e4864-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the sponsor of the determination of the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143e4865-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make such determination publicly available in accordance with paragraph (3) and subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143e4866-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for eligibility","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id143e4867-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for review under subsection (b) and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360fff–3"},"text":"section 360fff–3 of this title","children":[],"tail":", a request shall be for a nonprescription sunscreen active ingredient or combination of nonprescription sunscreen active ingredients, for use under specified conditions, to be prescribed, recommended, or suggested in the labeling thereof, that—"}],"tail":null},{"tag":"clause","attrib":{"id":"id143e4868-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not included in part 352 of title 21, Code of Federal Regulations (or any successor regulations) concerning nonprescription sunscreen; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id143e4869-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been used to a material extent and for a material time under such conditions, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s321/p/2"},"text":"section 321(p)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143e486a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of time and extent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A sponsor shall include in a request under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360fff–1"},"text":"section 360fff–1 of this title","children":[],"tail":" the information required under section 330.14 of title 21, Code of Federal Regulations (or any successor regulations) to meet the standard described in subparagraph (A)(ii)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143e486b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id143e486c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redactions for confidential information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a nonprescription sunscreen active ingredient or combination of nonprescription sunscreen active ingredients is determined under paragraph (1)(A) to be eligible for further review, the Secretary shall make the request publicly available, with redactions for information that is treated as confidential under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b"},"text":"section 552(b) of title 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1905"},"text":"section 1905 of title 18","children":[],"tail":", or "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s331/j"},"text":"section 331(j) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143e486d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of confidential information by sponsor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the time that a request is made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360fff–1"},"text":"section 360fff–1 of this title","children":[],"tail":", the sponsor of such request shall identify any information that such sponsor considers to be confidential information described in subparagraph (A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143e486e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality during eligibility review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The information contained in a request under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360fff–1"},"text":"section 360fff–1 of this title","children":[],"tail":" shall remain confidential during the Secretary’s consideration under this section of whether the request is eligible for further review consistent with section 330.14 of title 21, Code of Federal Regulations (or any successor regulations)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id143e486f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data submission and filing of requests","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id143e4870-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a request under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360fff–1"},"text":"section 360fff–1 of this title","children":[],"tail":" that is determined to be eligible under subsection (a) for further review under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360fff–3"},"text":"section 360fff–3 of this title","children":[],"tail":", the Secretary shall, in notifying the public under subsection (a)(1)(C) of such eligibility determination, post the eligibility determination on the Internet website of the Food and Drug Administration, invite the sponsor of such request and any other interested party to submit comments, and provide a period of not less than 45 calendar days for comments in support of or otherwise relating to a GRASE determination, including published and unpublished data and other information related to the safety and efficacy of such request."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143e4871-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing determination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 calendar days after the submission of data and other information described in paragraph (1) by the sponsor, the Secretary shall determine whether the data and other information submitted by the sponsor under this section are sufficiently complete, including being formatted in a manner that enables the Secretary to determine the completeness of such data and information, to enable the Secretary to conduct a substantive review under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360fff–3"},"text":"section 360fff–3 of this title","children":[],"tail":" with respect to such request. Not later than 60 calendar days after the submission of data and other information described in paragraph (1) by the sponsor, if the Secretary determines—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id143e4872-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that such data and other information are sufficiently complete, the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id143e4873-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue a written notification to the sponsor of the determination to file such request, and make such notification publicly available; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id143e4874-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" file such request made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360fff–1"},"text":"section 360fff–1 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143e4875-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that such data and other information are not sufficiently complete, the Secretary shall issue a written notification to the sponsor of the determination to refuse to file the request, which shall include the reasons for the refusal, including why such data and other information are not sufficiently complete, and make such notification publicly available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143e4876-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refusal to file a request","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id143e4877-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request for meetings; submission of additional data or other information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary refuses to file a request made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360fff–1"},"text":"section 360fff–1 of this title","children":[],"tail":", the sponsor may—"}],"tail":null},{"tag":"clause","attrib":{"id":"id143e4878-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within 30 calendar days of receipt of written notification of such refusal, request, in writing, a meeting with the Secretary regarding the filing determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id143e4879-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit additional data or other information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143e487a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id143e487b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a sponsor seeks a meeting under subparagraph (A)(i), the Secretary shall convene the meeting within 30 calendar days of the request for such meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id143e487c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions after meeting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Following any meeting held under clause (i)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id143e487d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/b/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may file the request within 60 calendar days;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id143e487e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/b/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sponsor may submit additional data or other information; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id143e487f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/b/3/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the sponsor elects, within 120 calendar days, to have the Secretary file the request (with or without amendments to correct any purported deficiencies to the request)—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id143e4880-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/b/3/B/ii/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall file the request over protest, not later than 30 calendar days after the sponsor makes such election;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id143e4881-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/b/3/B/ii/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the time of filing, the Secretary shall provide written notification of such filing to the sponsor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id143e4882-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/b/3/B/ii/III/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall make such notification publicly available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id143e4883-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests filed over protest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not require the sponsor to resubmit a copy of the request for purposes of filing a request filed over protest, as described in clause (ii)(III).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143e4884-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submissions of additional data or other information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 60 calendar days of any submission of additional data or other information under subparagraph (A)(ii) or (B)(ii)(II), the Secretary shall reconsider the previous determination made under paragraph (2) with respect to the applicable request and make a new determination in accordance with paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143e4885-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id143e4886-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redactions for confidential information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the period of confidentiality described in subsection (a)(3)(C), the Secretary shall make data and other information submitted in connection with a request under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360fff–1"},"text":"section 360fff–1 of this title","children":[],"tail":" publicly available, with redactions for information that is treated as confidential under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b"},"text":"section 552(b) of title 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1905"},"text":"section 1905 of title 18","children":[],"tail":", or "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s331/j"},"text":"section 331(j) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143e4887-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff–2/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of confidential information by sponsor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person submitting information under this section shall identify at the time of such submission the portions of such information that the person considers to be confidential information described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id143e4888-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s586B"},"text":"June 25, 1938, ch. 675, § 586B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/195/s2/a"},"text":"Pub. L. 113–195, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2036"},"text":"128 Stat. 2036","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
