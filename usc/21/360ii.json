{"tag":"section","attrib":{"id":"id142b3530-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"360ii"},"text":"§ 360ii.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program of control","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id142b3531-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ii/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish and carry out an electronic product radiation control program designed to protect the public health and safety from electronic product radiation. As a part of such program, he shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id142b3532-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ii/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360kk"},"text":"section 360kk of this title","children":[],"tail":", develop and administer performance standards for electronic products;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142b3533-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ii/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plan, conduct, coordinate, and support research, development, training, and operational activities to minimize the emissions of and the exposure of people to, unnecessary electronic product radiation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142b3534-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ii/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain liaison with and receive information from other Federal and State departments and agencies with related interests, professional organizations, industry, industry and labor associations, and other organizations on present and future potential electronic product radiation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142b3535-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ii/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" study and evaluate emissions of, and conditions of exposure to, electronic product radiation and intense magnetic fields;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142b3536-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ii/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop, test, and evaluate the effectiveness of procedures and techniques for minimizing exposure to electronic product radiation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142b3537-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ii/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult and maintain liaison with the Secretary of Commerce, the Secretary of Defense, the Secretary of Labor, the Atomic Energy Commission, and other appropriate Federal departments and agencies on (A) techniques, equipment, and programs for testing and evaluating electronic product radiation, and (B) the development of performance standards pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360kk"},"text":"section 360kk of this title","children":[],"tail":" to control such radiation emissions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id142b3538-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ii/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the purposes of subsection (a), the Secretary is authorized to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id142b3539-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ii/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id142b353a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ii/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and make available, through publications and other appropriate means, the results of, and other information concerning, research and studies relating to the nature and extent of the hazards and control of electronic product radiation; and (B) make such recommendations relating to such hazards and control as he considers appropriate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142b353b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ii/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make grants to public and private agencies, organizations, and institutions, and to individuals for the purposes stated in paragraphs (2), (4), and (5) of subsection (a) of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142b353c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ii/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contract with public or private agencies, institutions, and organizations, and with individuals, without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3324"},"text":"section 3324 of title 31","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142b353d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ii/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procure (by negotiation or otherwise) electronic products for research and testing purposes, and sell or otherwise dispose of such products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id142b353e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ii/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Record keeping","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id142b353f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ii/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each recipient of assistance under this part pursuant to grants or contracts entered into under other than competitive bidding procedures shall keep such records as the Secretary shall prescribe, including records which fully disclose the amount and disposition by such recipient of the proceeds of such assistance, the total cost of the project or undertaking in connection with which such assistance is given or used, and the amount of that portion of the cost of the project or undertaking supplied by other sources, and such other records as will facilitate an effective audit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142b3540-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ii/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary and the Comptroller General of the United States, or any of their duly authorized representatives, shall have access for the purpose of audit and examination to any books, documents, papers, and records of the recipients that are pertinent to the grants or contracts entered into under this part under other than competitive bidding procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id142b3541-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s532"},"text":"June 25, 1938, ch. 675, § 532","children":[],"tail":", formerly "},{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tIII/s532"},"text":"act July 1, 1944, ch. 373, title III, § 532","children":[],"tail":", formerly § 356, as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/602/s2/3"},"text":"Pub. L. 90–602, § 2(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-18"},"text":"Oct. 18, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1174"},"text":"82 Stat. 1174","children":[],"tail":"; renumbered § 532 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/629/s19/a/1/B"},"text":"Pub. L. 101–629, § 19(a)(1)(B)","children":[],"tail":", (2)(A), (3), (4), "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4529"},"text":"104 Stat. 4529","children":[],"tail":", 4530; "},{"tag":"ref","attrib":{"href":"/us/pl/103/80/s4/a/2"},"text":"Pub. L. 103–80, § 4(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-13"},"text":"Aug. 13, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/779"},"text":"107 Stat. 779","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id142b3542-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id142b3543-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id142b3544-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b)(3), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":"” substituted for “section 3709 of the Revised Statutes of the United States ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s5"},"text":"41 U.S.C. 5","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s263d"},"text":"section 263d of Title 42","children":[],"tail":", The Public Health and Welfare, prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/101/629"},"text":"Pub. L. 101–629","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id142b3545-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/80"},"text":"Pub. L. 103–80","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/101/629/s19/a/4"},"text":"Pub. L. 101–629, § 19(a)(4)","children":[],"tail":", which renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s263d"},"text":"section 263d of Title 42","children":[],"tail":", The Public Health and Welfare, as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(1), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/629/s19/a/2/A/i"},"text":"Pub. L. 101–629, § 19(a)(2)(A)(i)","children":[],"tail":", substituted “section 360kk” for “section 263f”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/629/s19/a/2/A/ii"},"text":"Pub. L. 101–629, § 19(a)(2)(A)(ii)","children":[],"tail":", substituted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3324"},"text":"section 3324 of title 31","children":[],"tail":" for reference to section 3648 of the Revised Statutes ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s529"},"text":"31 U.S.C. 529","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/629/s19/a/1/B"},"text":"Pub. L. 101–629, § 19(a)(1)(B)","children":[],"tail":", substituted “this part” for “this subpart”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id142b3546-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id142b3547-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Atomic Energy Commission abolished and functions transferred by sections 5814 and 5841 of Title 42, The Public Health and Welfare. See also Transfer of Functions notes set out under those sections.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id142b3548-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Noninterference With Other Federal Agencies","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of this section not to be construed to supersede or limit the functions under any other provision of law or any officer or agency of the United States, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/602/s4"},"text":"section 4 of Pub. L. 90–602","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360hh"},"text":"section 360hh of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
