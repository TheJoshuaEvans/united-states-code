{"tag":"section","attrib":{"id":"id143e4845-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff"},"text":null,"children":[{"tag":"num","attrib":{"value":"360fff"},"text":"§ 360fff.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id143e4846-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Advisory Committee” means the Nonprescription Drug Advisory Committee of the Food and Drug Administration or any successor to such Committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143e4847-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “final sunscreen order” means an order published by the Secretary in the Federal Register containing information stating that a nonprescription sunscreen active ingredient or combination of nonprescription sunscreen active ingredients—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id143e4848-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is GRASE and is not misbranded if marketed in accordance with such order; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143e4849-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not GRASE and is misbranded;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143e484a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “GRASE” means generally recognized, among experts qualified by scientific training and experience to evaluate the safety and effectiveness of drugs, as safe and effective for use under the conditions prescribed, recommended, or suggested in the labeling of a drug as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s321/p"},"text":"section 321(p) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143e484b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “GRASE determination” means, with respect to a nonprescription active ingredient or a combination of nonprescription active ingredients, a determination of whether such ingredient or combination of ingredients is GRASE;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143e484c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “nonprescription” means not subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s353/b/1"},"text":"section 353(b)(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143e484d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “pending request” means each request with respect to a nonprescription sunscreen active ingredient submitted under section 330.14 of title 21, Code of Federal Regulations (as in effect on ","children":[{"tag":"date","attrib":{"date":"2014-11-26"},"text":"November 26, 2014","children":[],"tail":") for consideration for inclusion in the over-the-counter drug monograph system—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id143e484e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that was determined to be eligible for such review by publication of a notice of eligibility in the Federal Register prior to ","children":[{"tag":"date","attrib":{"date":"2014-11-26"},"text":"November 26, 2014","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143e484f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which safety and effectiveness data have been submitted to the Secretary prior to ","children":[{"tag":"date","attrib":{"date":"2014-11-26"},"text":"November 26, 2014","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143e4850-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “proposed sunscreen order” means an order containing a tentative determination published by the Secretary in the Federal Register containing information proposing that a nonprescription sunscreen active ingredient or combination of nonprescription sunscreen active ingredients—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id143e4851-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is GRASE and is not misbranded if marketed in accordance with such order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143e4852-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not GRASE and is misbranded; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143e4853-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not GRASE and is misbranded because the data are insufficient to classify such ingredient or combination of ingredients as GRASE and not misbranded and additional information is necessary to allow the Secretary to determine otherwise;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143e4854-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “sponsor” means the person that submitted—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id143e4855-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a request under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360fff–1"},"text":"section 360fff–1 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143e4856-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a pending request; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143e4857-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other application subject to this part;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143e4858-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “sunscreen” means a drug containing one or more sunscreen active ingredients; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143e4859-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360fff/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “sunscreen active ingredient” means an active ingredient that is intended for application to the skin of humans for purposes of absorbing, reflecting, or scattering ultraviolet radiation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id143e485a-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s586"},"text":"June 25, 1938, ch. 675, § 586","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/195/s2/a"},"text":"Pub. L. 113–195, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2035"},"text":"128 Stat. 2035","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id143e485b-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id143e485c-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id143e485d-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/195/s2/b"},"text":"Pub. L. 113–195, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2045"},"text":"128 Stat. 2045","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/195/s2/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Nothing in the amendment made by this section [enacting this section and sections 360fff–1 to [former] 360fff–5 of this title] shall be construed to—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit the right of a sponsor (as defined in section 586(8) of the Federal Food, Drug, and Cosmetic Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360fff/8"},"text":"21 U.S.C. 360fff(8)","children":[],"tail":"], as added by subsection (a)) to request that the Secretary of Health and Human Services convene an advisory committee; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit the authority of the Secretary of Health and Human Services to meet with a sponsor (as defined in section 586(8) of the Federal Food, Drug, and Cosmetic Act, as added by subsection (a)).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
