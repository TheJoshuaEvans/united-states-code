{"tag":"section","attrib":{"id":"id148821bb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s468"},"text":null,"children":[{"tag":"num","attrib":{"value":"468"},"text":"§ 468.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost of inspection; overtime","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The cost of inspection rendered under the requirements of this chapter, shall be borne by the United States, except the cost of overtime and holiday pay paid pursuant to the ","children":[{"tag":"ref","attrib":{"idref":"fn002132"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002132"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “the” probably should not appear."}],"tail":" "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2219a"},"text":"section 2219a of title 7","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id148821bc-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/172/s25"},"text":"Pub. L. 85–172, § 25","children":[],"tail":", formerly § 19, "},{"tag":"date","attrib":{"date":"1957-08-28"},"text":"Aug. 28, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/448"},"text":"71 Stat. 448","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/90/492/s17"},"text":"Pub. L. 90–492, § 17","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-18"},"text":"Aug. 18, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/805"},"text":"82 Stat. 805","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10703/c/1"},"text":"Pub. L. 107–171, title X, § 10703(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/517"},"text":"116 Stat. 517","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id148821bd-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id148821be-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id148821bf-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2219a"},"text":"Section 2219a of title 7","children":[],"tail":", referred to in text, was in the original “section 10703 of the Farm Security and Rural Investment Act of 2002”, meaning "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/s10703"},"text":"section 10703 of Pub. L. 107–171","children":[],"tail":", which enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2219a"},"text":"section 2219a of Title 7","children":[],"tail":", Agriculture, amended this section, "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s695"},"text":"section 695 of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5549"},"text":"section 5549 of Title 5","children":[],"tail":", Government Organization and Employees, and repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s394"},"text":"section 394 of Title 7","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id148821c0-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":" substituted “except the cost of overtime and holiday pay paid pursuant to the "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2219a"},"text":"section 2219a of title 7","children":[],"tail":".” for “except that the cost of overtime and holiday work performed in establishments subject to the provisions of this chapter at such rates as the Secretary may determine shall be borne by such establishments. Sums received by the Secretary in reimbursement for sums paid out by him for such premium pay work shall be available without fiscal year limitation to carry out the purposes of this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
