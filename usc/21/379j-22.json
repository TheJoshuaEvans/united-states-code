{"tag":"section","attrib":{"id":"id145d4145-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–22"},"text":null,"children":[{"tag":"num","attrib":{"value":"379j–22"},"text":"§ 379j–22.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reauthorization; reporting requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id145d4146-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–22/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning with fiscal year 2024, not later than 120 days after the end of each fiscal year during which fees are collected under this subpart, the Secretary shall prepare and submit to the Committee on Health, Education, Labor, and Pensions of the Senate, and the Committee on Energy and Commerce of the House of Representatives a report concerning the progress of the Food and Drug Administration in achieving the goals identified in the letters described in section 201(b) ","children":[{"tag":"ref","attrib":{"idref":"fn002105"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002105"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Animal Generic Drug User Fee Amendments of 2023 toward expediting the generic new animal drug development process and the review of abbreviated applications for generic new animal drugs, supplemental abbreviated applications for generic new animal drugs, and investigational submissions for generic new animal drugs during such fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id145d4147-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–22/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning with fiscal year 2024, not later than 120 days after the end of each fiscal year during which fees are collected under this subpart, the Secretary shall prepare and submit to the Committee on Health, Education, Labor and Pensions of the Senate and the Committee on Energy and Commerce of the House of Representatives a report on the implementation of the authority for such fees during such fiscal year and the use, by the Food and Drug Administration, of the fees collected during such fiscal year for which the report is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id145d4148-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–22/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make the reports required under subsections (a) and (b) available to the public on the Internet Web site of the Food and Drug Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id145d4149-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–22/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reauthorization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id145d414a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–22/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing recommendations to present to Congress with respect to the goals, and plans for meeting the goals, for the process for the review of abbreviated applications for generic new animal drugs for the first 5 fiscal years after fiscal year 2028, and for the reauthorization of this subpart for such fiscal years, the Secretary shall consult with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id145d414b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–22/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Commerce of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d414c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–22/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Health, Education, Labor, and Pensions of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d414d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–22/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scientific and academic experts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d414e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–22/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veterinary professionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d414f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–22/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of patient and consumer advocacy groups; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d4150-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–22/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the regulated industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id145d4151-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–22/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior public input","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Prior to beginning negotiations with the regulated industry on the reauthorization of this subpart, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id145d4152-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–22/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish a notice in the Federal Register requesting public input on the reauthorization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d4153-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–22/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold a public meeting at which the public may present its views on the reauthorization, including specific suggestions for changes to the goals referred to in subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d4154-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–22/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a period of 30 days after the public meeting to obtain written comments from the public suggesting changes to this subpart; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d4155-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–22/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish the comments on the Food and Drug Administration’s Internet Web site.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id145d4156-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–22/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less frequently than once every 4 months during negotiations with the regulated industry, the Secretary shall hold discussions with representatives of veterinary, patient, and consumer advocacy groups to continue discussions of their views on the reauthorization and their suggestions for changes to this subpart as expressed under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id145d4157-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–22/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public review of recommendations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After negotiations with the regulated industry, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id145d4158-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–22/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" present the recommendations developed under paragraph (1) to the congressional committees specified in such paragraph;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d4159-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–22/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish such recommendations in the Federal Register;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d415a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–22/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for a period of 30 days for the public to provide written comments on such recommendations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d415b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–22/d/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold a meeting at which the public may present its views on such recommendations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d415c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–22/d/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after consideration of such public views and comments, revise such recommendations as necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id145d415d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–22/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmittal of recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2028-01-15"},"text":"January 15, 2028","children":[],"tail":", the Secretary shall transmit to Congress the revised recommendations under paragraph (4), a summary of the views and comments received under such paragraph, and any changes made to the recommendations in response to such views and comments."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id145d415e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–22/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minutes of negotiation meetings","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id145d415f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–22/d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before presenting the recommendations developed under paragraphs (1) through (5) to Congress, the Secretary shall make publicly available, on the Internet Web site of the Food and Drug Administration, minutes of all negotiation meetings conducted under this subsection between the Food and Drug Administration and the regulated industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id145d4160-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379j–22/d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The minutes described under subparagraph (A) shall summarize any substantive proposal made by any party to the negotiations as well as significant controversies or differences of opinion during the negotiations and their resolution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id145d4161-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s742"},"text":"June 25, 1938, ch. 675, § 742","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/316/tII/s203"},"text":"Pub. L. 110–316, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3522"},"text":"122 Stat. 3522","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/14/tII/s203"},"text":"Pub. L. 113–14, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-06-13"},"text":"June 13, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/472"},"text":"127 Stat. 472","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/234/tII/s203"},"text":"Pub. L. 115–234, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-14"},"text":"Aug. 14, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2435"},"text":"132 Stat. 2435","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/15/dB/tIII/s2313"},"text":"Pub. L. 118–15, div. B, title III, § 2313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-09-30"},"text":"Sept. 30, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/93"},"text":"137 Stat. 93","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id145d4162-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id145d4163-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/15/s2316/b"},"text":"section 2316(b) of Pub. L. 118–15","children":[],"tail":", see Termination Date note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id145d4164-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id145d4165-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 201(b) of the Animal Generic Drug User Fee Amendments of 2023, referred to in subsec. (a), probably should be a reference to section 2311(b) of the Animal Generic Drug User Fee Amendments of 2023, chapter 2 of subtitle A of title III of div. B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/15"},"text":"Pub. L. 118–15","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s379j–21"},"text":"section 379j–21 of this title","children":[],"tail":". The Animal Generic Drug User Fee Amendments of 2023 does not contain a section 201(b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id145d4166-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 742 of act ","children":[{"tag":"date","attrib":{"date":"1938-06-25"},"text":"June 25, 1938","children":[],"tail":", was renumbered section 746 and is classified to section 379"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id145d4167-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/15/s2313/1"},"text":"Pub. L. 118–15, § 2313(1)","children":[],"tail":", (2), substituted “2024” for “2019” and “2023” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/15/s2313/2"},"text":"Pub. L. 118–15, § 2313(2)","children":[],"tail":", substituted “2024” for “2019”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/15/s2313/3"},"text":"Pub. L. 118–15, § 2313(3)","children":[],"tail":", substituted “2028” for “2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/234/s203/1"},"text":"Pub. L. 115–234, § 203(1)","children":[],"tail":", (3), substituted “2019” for “2014” and “2018” for “2013”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/234/s203/2"},"text":"Pub. L. 115–234, § 203(2)","children":[],"tail":", (3), substituted “2019” for “2014” and “to the Committee on Health, Education, Labor and Pensions” for “to Committee on Health, Education, Labor, and Pensions”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/p