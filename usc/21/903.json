{"tag":"section","attrib":{"id":"id14b57399-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s903"},"text":null,"children":[{"tag":"num","attrib":{"value":"903"},"text":"§ 903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of State law","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No provision of this subchapter shall be construed as indicating an intent on the part of the Congress to occupy the field in which that provision operates, including criminal penalties, to the exclusion of any State law on the same subject matter which would otherwise be within the authority of the State, unless there is a positive conflict between that provision of this subchapter and that State law so that the two cannot consistently stand together.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id14b5739a-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/tII/s708"},"text":"Pub. L. 91–513, title II, § 708","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1284"},"text":"84 Stat. 1284","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14b5739b-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14b5739c-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14b5739d-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in text, was in the original “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513"},"text":"Pub. L. 91–513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1242"},"text":"84 Stat. 1242","children":[],"tail":", and is popularly known as the “Controlled Substances Act”. For complete classification of title II to the Code, see second paragraph of Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"section 801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
