{"tag":"section","attrib":{"id":"id149b355d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s813"},"text":null,"children":[{"tag":"num","attrib":{"value":"813"},"text":"§ 813.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of controlled substance analogues","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id149b355e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s813/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A controlled substance analogue shall, to the extent intended for human consumption, be treated, for the purposes of any Federal law as a controlled substance in schedule I.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id149b355f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s813/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether a controlled substance analogue was intended for human consumption under subsection (a), the following factors may be considered, along with any other relevant factors:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id149b3560-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s813/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The marketing, advertising, and labeling of the substance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id149b3561-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s813/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The known efficacy or usefulness of the substance for the marketed, advertised, or labeled purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id149b3562-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s813/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The difference between the price at which the substance is sold and the price at which the substance it is purported to be or advertised as is normally sold.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id149b3563-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s813/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The diversion of the substance from legitimate channels and the clandestine importation, manufacture, or distribution of the substance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id149b3564-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s813/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the defendant knew or should have known the substance was intended to be consumed by injection, inhalation, ingestion, or any other immediate means.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id149b3565-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s813/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any controlled substance analogue that is manufactured, formulated, sold, distributed, or marketed with the intent to avoid the provisions of existing drug laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id149b3566-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s813/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, evidence that a substance was not marketed, advertised, or labeled for human consumption, by itself, shall not be sufficient to establish that the substance was not intended for human consumption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id149b3567-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/tII/s203"},"text":"Pub. L. 91–513, title II, § 203","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tI/s1202"},"text":"Pub. L. 99–570, title I, § 1202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-13"},"text":"100 Stat. 3207–13","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6470/c"},"text":"Pub. L. 100–690, title VI, § 6470(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4378"},"text":"102 Stat. 4378","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/tIII/s3241"},"text":"Pub. L. 115–271, title III, § 3241","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3950"},"text":"132 Stat. 3950","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id149b3568-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id149b3569-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id149b356a-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Schedule I, referred to in subsec. (a), is set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s812/c"},"text":"section 812(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id149b356b-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271"},"text":"Pub. L. 115–271","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsecs. (b) and (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" substituted “any Federal law” for “this subchapter and subchapter II of this chapter”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
