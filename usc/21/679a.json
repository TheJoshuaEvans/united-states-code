{"tag":"section","attrib":{"id":"id148f4def-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679a"},"text":null,"children":[{"tag":"num","attrib":{"value":"679a"},"text":"§ 679a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safe Meat and Poultry Inspection Panel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id148f4df0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Department of Agriculture a permanent advisory panel to be known as the “Safe Meat and Poultry Inspection Panel” (referred to in this section as the “panel”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id148f4df1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id148f4df2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The panel shall review and evaluate, as the panel considers necessary, the adequacy, necessity, safety, cost-effectiveness, and scientific merit of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id148f4df3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inspection procedures of, and work rules and worker relations involving Federal employees employed in, plants inspected under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id148f4df4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" informal petitions or proposals for changes in inspection procedures, processes, and techniques of plants inspected under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id148f4df5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" formal changes in meat inspection regulations promulgated under this chapter, whether in notice, proposed, or final form; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id148f4df6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679a/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other matters as may be referred to the panel by the Secretary regarding the quality or effectiveness of a safe and cost-effective meat inspection system under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id148f4df7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id148f4df8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The panel shall submit to the Secretary a report on the results of each review and evaluation carried out under paragraph (1), including such recommendations as the panel considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id148f4df9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports on formal changes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a report concerning a formal change in meat inspection regulations, the report shall be made within the time limits prescribed for formal comments on such changes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id148f4dfa-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication in Federal Register","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report of the panel to the Secretary shall be published in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id148f4dfb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretarial response","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after the publication of a panel report under subsection (b)(2)(C), the Secretary shall publish in the Federal Register any response required of the Secretary to the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id148f4dfc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition of panel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The panel shall be composed of 7 members, not fewer than 5 of whom shall be from the food science, meat science, or poultry science profession, appointed to staggered terms not to exceed 3 years by the Secretary from nominations received from the National Institutes of Health and the Federation of American Societies of Food Animal Science and based on the professional qualifications of the nominees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id148f4dfd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nominations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id148f4dfe-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial panel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In constituting the initial panel, the Secretary shall solicit 6 nominees from the National Institutes of Health and 6 nominees from the Federation of American Societies of Food Animal Science for membership on the panel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id148f4dff-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any subsequent vacancy on the panel shall be filled by the Secretary after soliciting 2 nominees from the National Institutes of Health and 2 nominees from the Federation of American Societies of Food Animal Science.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id148f4e00-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for nominees","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id148f4e01-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679a/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each nominee provided under paragraph (1) or (2) shall have a background in public health issues and a scientific expertise in food, meat, or poultry science or in veterinary science.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id148f4e02-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679a/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may require nominees to submit such information as the Secretary considers necessary prior to completing the selection process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id148f4e03-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679a/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional nominees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any list of nominees provided under paragraph (1) or (2) is unsatisfactory to the Secretary, the Secretary may request the nominating entities to submit an additional list of nominees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id148f4e04-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"While away from the home or regular place of business of a member of the panel in the performance of services for the panel, the member shall be allowed travel expenses, including per diem in lieu of subsistence, at the same rate as a person employed intermittently in the Government service would be allowed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id148f4e05-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflicts of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate regulations regarding conflicts of interest with respect to the members of the panel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id148f4e06-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 and title XVIII of the Food and Agriculture Act of 1977 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2281"},"text":"7 U.S.C. 2281","children":[],"tail":" et seq.) shall not apply to the panel."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id148f4e07-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From funds available to the Secretary to carry out this chapter and the Poultry Products Inspection Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s451"},"text":"21 U.S.C. 451","children":[],"tail":" et seq.), the Secretary shall allocate such sums as may be necessary to carry out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id148f4e08-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1907-03-04/ch2907"},"text":"Mar. 4, 1907, ch. 2907","children":[],"tail":", title IV, § 410, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tIX/s918/a/1/B"},"text":"Pub. L. 104–127, title IX, § 918(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1188"},"text":"110 Stat. 1188","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/161"},"text":"Pub. L. 117–286, § 4(a)(161)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4323"},"text":"136 Stat. 4323","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id148f4e09-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id148f4e0a-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id148f4e0b-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Food and Agriculture Act of 1977, referred to in subsec. (h), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113"},"text":"Pub. L. 95–113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/913"},"text":"91 Stat. 913","children":[],"tail":". Title XVIII of the Act is classified generally to chapter 55A (§ 2281 et seq.) of Title 7, Agriculture. For complete classification of this Act to the Code, see Short Title of 1977 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1281"},"text":"section 1281 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Poultry Products Inspection Act, referred to in subsec. (i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/172"},"text":"Pub. L. 85–172","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-08-28"},"text":"Aug. 28, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/441"},"text":"71 Stat. 441","children":[],"tail":", which is classified generally to chapter 10 (§ 451 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s451"},"text":"section 451 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id148f4e0c-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 410 of act ","children":[{"tag":"date","attrib":{"date":"1907-03-04"},"text":"Mar. 4, 1907","children":[],"tail":", was renumbered section 411, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s680"},"text":"section 680 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id148f4e0d-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 U.S.C. App.)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id148f4e0e-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id148f4e0f-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Use of Appropriated Funds","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For prohibition of use of funds appropriated by div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" or any other Act to carry out this section, see section 741 "},{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s471"},"text":"section 471 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
