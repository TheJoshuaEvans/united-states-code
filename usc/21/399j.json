{"tag":"section","attrib":{"id":"id14836775-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399j"},"text":null,"children":[{"tag":"num","attrib":{"value":"399j"},"text":"§ 399j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abraham Accords Office","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14836776-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Commissioner of Food and Drugs, shall establish within the Food and Drug Administration an office, to be known as the Abraham Accords Office, to be headed by a director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14836777-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2026-02-03"},"text":"February 3, 2026","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id14836778-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399j/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in consultation with the governments of Abraham Accords countries, as well as appropriate United States Government diplomatic and security personnel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14836779-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399j/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select the location of the Abraham Accords Office in an Abraham Accords country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1483677a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399j/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish such office; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1483677b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399j/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assign to such office such personnel of the Food and Drug Administration as the Secretary determines necessary to carry out the functions of such office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1483677c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Director of the Abraham Accords Office, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1483677d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399j/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" after the Abraham Accords Office is established—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1483677e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399j/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as part of the Food and Drug Administration’s work to strengthen the international oversight of regulated commodities, provide technical assistance to regulatory partners in Abraham Accords countries on strengthening regulatory oversight and converging regulatory requirements for the oversight of regulated products, including good manufacturing practices and other issues relevant to manufacturing medical products that are regulated by the Food and Drug Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1483677f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399j/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate interactions between the Food and Drug Administration and interested parties in Abraham Accords countries, including by sharing relevant information regarding United States regulatory pathways with such parties, and facilitate feedback on the research, development, and manufacturing of products regulated in accordance with this chapter; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14836780-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399j/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out other functions and activities as the Secretary determines to be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14836781-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399j/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abraham Accords country defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “Abraham Accords country” means a country identified by the Department of State as having signed the Abraham Accords Declaration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14836782-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s399j/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to require any action inconsistent with a national security recommendation provided by the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14836783-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s1015"},"text":"June 25, 1938, ch. 675, § 1015","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/119/75/dJ/tVI/s6611/a"},"text":"Pub. L. 119–75, div. J, title VI, § 6611(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-02-03"},"text":"Feb. 3, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/701"},"text":"140 Stat. 701","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14836784-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14836785-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":null}
