{"tag":"section","attrib":{"id":"id14050f8e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356h"},"text":null,"children":[{"tag":"num","attrib":{"value":"356h"},"text":"§ 356h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive generic therapies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14050f8f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, at the request of an applicant of a drug that is designated as a competitive generic therapy pursuant to subsection (b), expedite the development and review of an abbreviated new drug application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/j"},"text":"section 355(j) of this title","children":[],"tail":" for such drug."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14050f90-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation process","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14050f91-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The applicant may request the Secretary to designate the drug as a competitive generic therapy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14050f92-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A request under paragraph (1) may be made concurrently with, or at any time prior to, the submission of an abbreviated new drug application for the drug under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/j"},"text":"section 355(j) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14050f93-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356h/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A drug is eligible for designation as a competitive generic therapy under this section if the Secretary determines that there is inadequate generic competition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14050f94-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356h/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 calendar days after the receipt of a request under paragraph (1), the Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14050f95-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356h/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine whether the drug that is the subject of the request meets the criteria described in paragraph (3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14050f96-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356h/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary finds that the drug meets such criteria, designate the drug as a competitive generic therapy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14050f97-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In expediting the development and review of an application under subsection (a), the Secretary may, as requested by the applicant, take actions including the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14050f98-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356h/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hold meetings with the applicant and the review team throughout the development of the drug prior to submission of the application for such drug under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/j"},"text":"section 355(j) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14050f99-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356h/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provide timely advice to, and interactive communication with, the applicant regarding the development of the drug to ensure that the development program to gather the data necessary for approval is as efficient as practicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14050f9a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356h/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Involve senior managers and experienced review staff, as appropriate, in a collaborative, coordinated review of such application, including with respect to drug-device combination products and other complex products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14050f9b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356h/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Assign a cross-disciplinary project lead—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14050f9c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356h/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate an efficient review of the development program and application, including manufacturing inspections; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14050f9d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356h/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to serve as a scientific liaison between the review team and the applicant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14050f9e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356h/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after the date of the approval of an application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/j"},"text":"section 355(j) of this title","children":[],"tail":" with respect to a drug for which the development and review is expedited under this section, the sponsor of such drug shall report to the Secretary on whether the drug has been marketed in interstate commerce since the date of such approval."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14050f9f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356h/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14050fa0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356h/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “generic drug” means a drug that is approved pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/j"},"text":"section 355(j) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14050fa1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356h/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “inadequate generic competition” means, with respect to a drug, there is not more than one approved drugs ","children":[{"tag":"ref","attrib":{"idref":"fn002058"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002058"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “drug”."}],"tail":" on the list of drugs described in "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/j/7/A"},"text":"section 355(j)(7)(A) of this title","children":[],"tail":" (not including drugs on the discontinued section of such list) that is—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14050fa2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356h/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reference listed drug; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14050fa3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356h/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a generic drug with the same reference listed drug as the drug for which designation as a competitive generic therapy is sought.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14050fa4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s356h/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “reference listed drug” means the listed drug (as such term is used in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/j"},"text":"section 355(j) of this title","children":[],"tail":") for the drug involved."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14050fa5-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s506H"},"text":"June 25, 1938, ch. 675, § 506H","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/52/tVIII/s803/a"},"text":"Pub. L. 115–52, title VIII, § 803(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-18"},"text":"Aug. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1070"},"text":"131 Stat. 1070","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14050fa6-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14050fa7-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id14050fa8-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Guidance; Amended Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/52/tVIII/s803/b"},"text":"Pub. L. 115–52, title VIII, § 803(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-18"},"text":"Aug. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1071"},"text":"131 Stat. 1071","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/52/tVIII/s803/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Issuance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Health and Human Services shall—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 18 months after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2017-08-18"},"text":"Aug. 18, 2017","children":[],"tail":"], issue draft guidance on section 506H of the Federal Food, Drug, and Cosmetic Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t21/s356h"},"text":"21 U.S.C. 356h","children":[],"tail":"], as added by subsection (a); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 1 year after the close of the comment period for the draft guidance, issue final guidance on such section 506H.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The guidance issued under this paragraph shall—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the process and criteria by which the Secretary makes a designation under section 506H of the Federal Food, Drug, and Cosmetic Act, as added by subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the actions the Secretary may take to expedite the development and review of a competitive generic therapy pursuant to such a designation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include good review management practices for competitive generic therapies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amended regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Health and Human Services shall issue or revise any regulations as may be necessary to carry out this section not later than 2 years after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2017-08-18"},"text":"Aug. 18, 2017","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
