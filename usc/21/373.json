{"tag":"section","attrib":{"id":"id14430363-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s373"},"text":null,"children":[{"tag":"num","attrib":{"value":"373"},"text":"§ 373.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14430364-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s373/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of enforcing the provisions of this chapter, carriers engaged in interstate commerce, and persons receiving food, drugs, devices, tobacco products, or cosmetics in interstate commerce or holding such articles so received, shall, upon the request of an officer or employee duly designated by the Secretary, permit such officer or employee, at reasonable times, to have access to and to copy all records showing the movement in interstate commerce of any food, drug, device, tobacco product, or cosmetic, or the holding thereof during or after such movement, and the quantity, shipper, and consignee thereof; and it shall be unlawful for any such carrier or person to fail to permit such access to and copying of any such record so requested when such request is accompanied by a statement in writing specifying the nature or kind of food, drug, device, tobacco product, or cosmetic to which such request relates, except that evidence obtained under this section, or any evidence which is directly or indirectly derived from such evidence, shall not be used in a criminal prosecution of the person from whom obtained, and except that carriers shall not be subject to the other provisions of this chapter by reason of their receipt, carriage, holding, or delivery of food, drugs, devices, tobacco products, or cosmetics in the usual course of business as carriers, except as provided in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14430365-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s373/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food transportation records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A shipper, carrier by motor vehicle or rail vehicle, receiver, or other person subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s350e"},"text":"section 350e of this title","children":[],"tail":" shall, on request of an officer or employee designated by the Secretary, permit the officer or employee, at reasonable times, to have access to and to copy all records that the Secretary requires to be kept under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s350e/c/1/E"},"text":"section 350e(c)(1)(E) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14430366-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s703"},"text":"June 25, 1938, ch. 675, § 703","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1057"},"text":"52 Stat. 1057","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/452/tII/s230"},"text":"Pub. L. 91–452, title II, § 230","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-15"},"text":"Oct. 15, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/930"},"text":"84 Stat. 930","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/80/s3/z"},"text":"Pub. L. 103–80, § 3(z)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-13"},"text":"Aug. 13, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/778"},"text":"107 Stat. 778","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tVII/s7202/c"},"text":"Pub. L. 109–59, title VII, § 7202(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1913"},"text":"119 Stat. 1913","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/31/dA/tI/s103/h"},"text":"Pub. L. 111–31, div. A, title I, § 103(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-06-22"},"text":"June 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1837"},"text":"123 Stat. 1837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14430367-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14430368-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14430369-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/31"},"text":"Pub. L. 111–31","children":[],"tail":" inserted “tobacco product,” after “device,” in two places and “tobacco products,” after “devices,” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" struck out “of interstate shipment” after “Records” in section catchline, designated existing provisions as subsec. (a), inserted subsec. heading, substituted “carriers, except as provided in subsection (b)” for “carriers” before period at end, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/80"},"text":"Pub. L. 103–80","children":[],"tail":" substituted “, except that” for “: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That” and “, and except that” for “: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/452"},"text":"Pub. L. 91–452","children":[],"tail":" inserted “, or any evidence which is directly or indirectly derived from such evidence,” after “under this section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1443036a-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id1443036b-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2005-10-01"},"text":"Oct. 1, 2005","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7204"},"text":"section 7204 of Pub. L. 109–59","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s331"},"text":"section 331 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id1443036c-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"