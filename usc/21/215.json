{"tag":"section","attrib":{"id":"id13aa6c97-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s215"},"text":null,"children":[{"tag":"num","attrib":{"value":"215"},"text":"§ 215.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Consul” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The word “consul” as used in this chapter shall mean the consular officer in charge of the district concerned.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id13aa6c98-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1915-03-03/ch74/s12"},"text":"Mar. 3, 1915, ch. 74, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/822"},"text":"38 Stat. 822","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
