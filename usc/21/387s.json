{"tag":"section","attrib":{"id":"id147c3b69-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s"},"text":null,"children":[{"tag":"num","attrib":{"value":"387s"},"text":"§ 387s.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" User fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id147c3b6a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of quarterly fee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning on ","children":[{"tag":"date","attrib":{"date":"2009-06-22"},"text":"June 22, 2009","children":[],"tail":", the Secretary shall in accordance with this section assess user fees on, and collect such fees from, each manufacturer and importer of tobacco products subject to this subchapter. The fees shall be assessed and collected with respect to each quarter of each fiscal year, and the total amount assessed and collected for a fiscal year shall be the amount specified in subsection (b)(1) for such year, subject to subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id147c3b6b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of user fee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id147c3b6c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The total amount of user fees authorized to be assessed and collected under subsection (a) for a fiscal year is the following, as applicable to the fiscal year involved:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id147c3b6d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2009, $85,000,000 (subject to subsection (e)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3b6e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2010, $235,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3b6f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2011, $450,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3b70-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2012, $477,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3b71-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2013, $505,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3b72-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2014, $534,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3b73-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2015, $566,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3b74-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2016, $599,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3b75-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2017, $635,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3b76-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2018, $672,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3b77-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2019 and each subsequent fiscal year, $712,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147c3b78-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocations of assessment by class of tobacco products","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id147c3b79-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total user fees assessed and collected under subsection (a) each fiscal year with respect to each class of tobacco products shall be an amount that is equal to the applicable percentage of each class for the fiscal year multiplied by the amount specified in paragraph (1) for the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3b7a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable percentage","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id147c3b7b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A), the applicable percentage for a fiscal year for each of the following classes of tobacco products shall be determined in accordance with clause (ii):","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id147c3b7c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cigarettes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id147c3b7d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cigars, including small cigars and cigars other than small cigars.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id147c3b7e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/2/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Snuff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id147c3b7f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/2/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chewing tobacco.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id147c3b80-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/2/B/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pipe tobacco.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id147c3b81-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/2/B/i/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Roll-your-own tobacco.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id147c3b82-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The applicable percentage of each class of tobacco product described in clause (i) for a fiscal year shall be the percentage determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s518d/c"},"text":"section 518d(c) of title 7","children":[],"tail":" for each such class of product for such fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id147c3b83-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding clause (ii), no user fees shall be assessed on a class of tobacco products unless such class of tobacco products is listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s387a/b"},"text":"section 387a(b) of this title","children":[],"tail":" or is deemed by the Secretary in a regulation under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s387a/b"},"text":"section 387a(b) of this title","children":[],"tail":" to be subject to this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id147c3b84-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallocations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a class of tobacco products that is not listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s387a/b"},"text":"section 387a(b) of this title","children":[],"tail":" or deemed by the Secretary in a regulation under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s387a/b"},"text":"section 387a(b) of this title","children":[],"tail":" to be subject to this subchapter, the amount of user fees that would otherwise be assessed to such class of tobacco products shall be reallocated to the classes of tobacco products that are subject to this subchapter in the same manner and based on the same relative percentages otherwise determined under clause (ii)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147c3b85-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of user fee by company","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id147c3b86-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The total user fee to be paid by each manufacturer or importer of a particular class of tobacco products shall be determined for each quarter by multiplying—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id147c3b87-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such manufacturer’s or importer’s percentage share as determined under paragraph (4); by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id147c3b88-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the portion of the user fee amount for the current quarter to be assessed on all manufacturers and importers of such class of tobacco products as determined under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3b89-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No fee in excess of percentage share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No manufacturer or importer of tobacco products shall be required to pay a user fee in excess of the percentage share of such manufacturer or importer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147c3b8a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of assessment within each class of tobacco product","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The percentage share of each manufacturer or importer of a particular class of tobacco products of the total user fee to be paid by all manufacturers or importers of that class of tobacco products shall be the percentage determined for purposes of allocations under subsections (e) through (h) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s518d"},"text":"section 518d of title 7","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147c3b8b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation for cigars","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (4), if a user fee assessment is imposed on cigars, the percentage share of each manufacturer or importer of cigars shall be based on the excise taxes paid by such manufacturer or importer during the prior fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147c3b8c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall notify each manufacturer and importer of tobacco products subject to this section of the amount of the quarterly assessment imposed on such manufacturer or importer under this subsection for each quarter of each fiscal year. Such notifications shall occur not later than 30 days prior to the end of the quarter for which such assessment is made, and payments of all assessments shall be made by the last day of the quarter involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147c3b8d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Memorandum of understanding","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id147c3b8e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall request the appropriate Federal agency to enter into a memorandum of understanding that provides for the regular and timely transfer from the head of such agency to the Secretary of the information described in paragraphs (2)(B)(ii) and (4) and all necessary information regarding all tobacco product manufacturers and importers required to pay user fees. The Secretary shall maintain all disclosure restrictions established by the head of such agency regarding the information provided under the memorandum of understanding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3b8f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assurances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning not later than fiscal year 2015, and for each subsequent fiscal year, the Secretary shall ensure that the Food and Drug Administration is able to determine the applicable percentages described in paragraph (2) and the percentage shares described in paragraph (4). The Secretary may carry out this subparagraph by entering into a contract with the head of the Federal agency referred to in subparagraph (A) to continue to provide the necessary information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id147c3b90-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crediting and availability of fees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id147c3b91-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fees authorized under subsection (a) shall be collected and available for obligation only to the extent and in the amount provided in advance in appropriations Acts, subject to paragraph (2)(D). Such fees are authorized to remain available until expended. Such sums as may be necessary may be transferred from the Food and Drug Administration salaries and expenses appropriation account without fiscal year limitation to such appropriation account for salaries and expenses with such fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147c3b92-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id147c3b93-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fees appropriated under paragraph (3) are available only for the purpose of paying the costs of the activities of the Food and Drug Administration related to the regulation of tobacco products under this subchapter and the Family Smoking Prevention and Tobacco Control Act (referred to in this subsection as “tobacco regulation activities”), except that such fees may be used for the reimbursement specified in subparagraph (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3b94-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against use of other funds","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id147c3b95-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clause (ii), fees collected under subsection (a) are the only funds authorized to be made available for tobacco regulation activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id147c3b96-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Startup costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Clause (i) does not apply until ","children":[{"tag":"date","attrib":{"date":"2009-10-01"},"text":"October 1, 2009","children":[],"tail":". Until such date, any amounts available to the Food and Drug Administration (excluding user fees) shall be available and allocated as needed to pay the costs of tobacco regulation activities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3b97-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of start-up amounts","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id147c3b98-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amounts allocated for the start-up period pursuant to subparagraph (B)(ii) shall be reimbursed through any appropriated fees collected under subsection (a), in such manner as the Secretary determines appropriate to ensure that such allocation results in no net change in the total amount of funds otherwise available, for the period from ","children":[{"tag":"date","attrib":{"date":"2008-10-01"},"text":"October 1, 2008","children":[],"tail":", through "},{"tag":"date","attrib":{"date":"2010-09-30"},"text":"September 30, 2010","children":[],"tail":", for Food and Drug Administration programs and activities (other than tobacco regulation activities) for such period."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id147c3b99-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of reimbursed amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts reimbursed under clause (i) shall be available for the programs and activities for which funds allocated for the start-up period were available, prior to such allocation, until ","children":[{"tag":"date","attrib":{"date":"2010-09-30"},"text":"September 30, 2010","children":[],"tail":", notwithstanding any otherwise applicable limits on amounts for such programs or activities for a fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3b9a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fee collected during start-up period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the first sentence of paragraph (1), fees under subsection (a) may be collected through ","children":[{"tag":"date","attrib":{"date":"2009-09-30"},"text":"September 30, 2009","children":[],"tail":" under subparagraph (B)(ii) and shall be available for obligation and remain available until expended. Such offsetting collections shall be credited to the salaries and expenses account of the Food and Drug Administration."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id147c3b9b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligation of start-up costs in anticipation of available fee collections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, following the enactment of an appropriation for fees under this section for fiscal year 2010, or any portion thereof, obligations for costs of tobacco regulation activities during the start-up period may be incurred in anticipation of the receipt of offsetting fee collections through procedures specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1534"},"text":"section 1534 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147c3b9c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For fiscal year 2009 and each subsequent fiscal year, there is authorized to be appropriated for fees under this section an amount equal to the amount specified in subsection (b)(1) for the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id147c3b9d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of unpaid fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case where the Secretary does not receive payment of a fee assessed under subsection (a) within 30 days after it is due, such fee shall be treated as a claim of the United States Government subject to subchapter II of chapter 37 of title 31.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id147c3b9e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability to fiscal year 2009","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the date of enactment of the Family Smoking Prevention and Tobacco Control Act occurs during fiscal year 2009, the following applies, subject to subsection (c):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id147c3b9f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall determine the fees that would apply for a single quarter of such fiscal year according to the application of subsection (b) to the amount specified in paragraph (1)(A) of such subsection (referred to in this subsection as the “quarterly fee amounts”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147c3ba0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the quarter in which such date of enactment occurs, the amount of fees assessed shall be a pro rata amount, determined according to the number of days remaining in the quarter (including such date of enactment) and according to the daily equivalent of the quarterly fee amounts. Fees assessed under the preceding sentence shall not be collected until the next quarter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id147c3ba1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s387s/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the quarter following the quarter to which paragraph (2) applies, the full quarterly fee amounts shall be assessed and collected, in addition to collection of the pro rata fees assessed under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id147c3ba2-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s919"},"text":"June 25, 1938, ch. 675, § 919","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/31/dA/tI/s101/b/3"},"text":"Pub. L. 111–31, div. A, title I, § 101(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-06-22"},"text":"June 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1826"},"text":"123 Stat. 1826","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id147c3ba3-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id147c3ba4-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id147c3ba5-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Family Smoking Prevention and Tobacco Control Act, referred to in subsec. (c)(2)(A), is div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/31"},"text":"Pub. L. 111–31","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-06-22"},"text":"June 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1776"},"text":"123 Stat. 1776","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2009 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"section 301 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of the Family Smoking Prevention and Tobacco Control Act and such date of enactment, referred to in subsec. (e), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/31"},"text":"Pub. L. 111–31","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2009-06-22"},"text":"June 22, 2009","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
