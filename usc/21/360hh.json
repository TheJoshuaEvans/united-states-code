{"tag":"section","attrib":{"id":"id142b351e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360hh"},"text":null,"children":[{"tag":"num","attrib":{"value":"360hh"},"text":"§ 360hh.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id142b351f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360hh/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “electronic product radiation” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id142b3520-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360hh/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any ionizing or non-ionizing electromagnetic or particulate radiation, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id142b3521-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360hh/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any sonic, infrasonic, or ultrasonic wave, which is emitted from an electronic product as the result of the operation of an electronic circuit in such product;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142b3522-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360hh/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “electronic product” means (A) any manufactured or assembled product which, when in operation, (i) contains or acts as part of an electronic circuit and (ii) emits (or in the absence of effective shielding or other controls would emit) electronic product radiation, or (B) any manufactured or assembled article which is intended for use as a component, part, or accessory of a product described in clause (A) and which when in operation emits (or in the absence of effective shielding or other controls would emit) such radiation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142b3523-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360hh/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “manufacturer” means any person engaged in the business of manufacturing, assembling, or importing of electronic products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142b3524-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360hh/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “commerce” means (A) commerce between any place in any State and any place outside thereof; and (B) commerce wholly within the District of Columbia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id142b3525-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360hh/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” includes the District of Columbia, the Commonwealth of Puerto Rico, the Northern Mariana Islands, the Virgin Islands, Guam, and American Samoa.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id142b3526-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s531"},"text":"June 25, 1938, ch. 675, § 531","children":[],"tail":", formerly "},{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tIII/s531"},"text":"act July 1, 1944, ch. 373, title III, § 531","children":[],"tail":", formerly § 355, as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/602/s2/3"},"text":"Pub. L. 90–602, § 2(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-18"},"text":"Oct. 18, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1174"},"text":"82 Stat. 1174","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tIX/s905/b/1"},"text":"Pub. L. 94–484, title IX, § 905(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2325"},"text":"90 Stat. 2325","children":[],"tail":"; renumbered § 531 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/629/s19/a/1/B"},"text":"Pub. L. 101–629, § 19(a)(1)(B)","children":[],"tail":", (3), (4), "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4529"},"text":"104 Stat. 4529","children":[],"tail":", 4530; "},{"tag":"ref","attrib":{"href":"/us/pl/103/80/s4/a/2"},"text":"Pub. L. 103–80, § 4(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-13"},"text":"Aug. 13, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/779"},"text":"107 Stat. 779","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id142b3527-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id142b3528-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id142b3529-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s263c"},"text":"section 263c of Title 42","children":[],"tail":", The Public Health and Welfare, prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/101/629"},"text":"Pub. L. 101–629","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id142b352a-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/80"},"text":"Pub. L. 103–80","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/101/629/s19/a/4"},"text":"Pub. L. 101–629, § 19(a)(4)","children":[],"tail":", which renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s263c"},"text":"section 263c of Title 42","children":[],"tail":", The Public Health and Welfare, as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/629/s19/a/1/B"},"text":"Pub. L. 101–629, § 19(a)(1)(B)","children":[],"tail":", substituted “this part” for “this subpart” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/484"},"text":"Pub. L. 94–484","children":[],"tail":" defined “State” to include Northern Mariana Islands."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id142b352b-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id142b352c-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/602"},"text":"Pub. L. 90–602","children":[],"tail":", which enacted provisions now comprising this part (§§ 360hh to 360ss), as the “Radiation Control for Health and Safety Act of 1968”, see "},{"tag":"ref","attrib":{"href":"/us/pl/90/602/s1"},"text":"section 1 of Pub. L. 90–602","children":[],"tail":", set out as a Short Title of 1968 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"section 301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id142b352d-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfer of Subpart; Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/629/s19/c"},"text":"Pub. L. 101–629, § 19(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4530"},"text":"104 Stat. 4530","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/629/s19/c"},"text":"“The transfer of subpart 3 of part F of title III of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s263b"},"text":"42 U.S.C. 263b","children":[],"tail":" et seq.] to the Federal Food, Drug, and Cosmetic Act [this chapter] does not change the application of the requirements of such subpart and such Act to electronic products which were in effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id142b352e-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary” and “Department”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/602/s3"},"text":"Pub. L. 90–602, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-18"},"text":"Oct. 18, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1186"},"text":"82 Stat. 1186","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/88/tV/s509/b"},"text":"“As used in the amendments made by section 2 of this Act [enacting provisions now comprising sections 360hh to 360ss of this title], except when otherwise specified, the term ‘Secretary’ means the Secretary of Health and Human Services, and the term ‘Department’ means the Department of Health and Human Services.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id142b352f-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Noninterference With Other Federal Agencies","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/602/s4"},"text":"Pub. L. 90–602, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-18"},"text":"Oct. 18, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1187"},"text":"82 Stat. 1187","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/602/s4"},"text":"“The amendments made by section 2 of this Act [enacting provisions now comprising sections 360hh to 360ss of this title] shall not be construed as superseding or limiting the functions, under any other provision of law, of any officer or agency of the United States.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
