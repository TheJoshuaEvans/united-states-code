{"tag":"section","attrib":{"id":"id146929b8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"379aa–1"},"text":"§ 379aa–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Serious adverse event reporting for dietary supplements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id146929b9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id146929ba-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adverse event","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “adverse event” means any health-related event associated with the use of a dietary supplement that is adverse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id146929bb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Serious adverse event","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “serious adverse event” is an adverse event that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id146929bc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" results in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id146929bd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" death;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id146929be-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a life-threatening experience;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id146929bf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inpatient hospitalization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id146929c0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a persistent or significant disability or incapacity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id146929c1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/a/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a congenital anomaly or birth defect; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id146929c2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires, based on reasonable medical judgment, a medical or surgical intervention to prevent an outcome described under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id146929c3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Serious adverse event report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “serious adverse event report” means a report that is required to be submitted to the Secretary under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id146929c4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id146929c5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The manufacturer, packer, or distributor of a dietary supplement whose name (pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s343/e/1"},"text":"section 343(e)(1) of this title","children":[],"tail":") appears on the label of a dietary supplement marketed in the United States (referred to in this section as the “responsible person”) shall submit to the Secretary any report received of a serious adverse event associated with such dietary supplement when used in the United States, accompanied by a copy of the label on or within the retail packaging of such dietary supplement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id146929c6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retailer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A retailer whose name appears on the label described in paragraph (1) as a distributor may, by agreement, authorize the manufacturer or packer of the dietary supplement to submit the required reports for such dietary supplements to the Secretary so long as the retailer directs to the manufacturer or packer all adverse events associated with such dietary supplement that are reported to the retailer through the address or telephone number described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s343/y"},"text":"section 343(y) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id146929c7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id146929c8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The responsible person shall submit to the Secretary a serious adverse event report no later than 15 business days after the report is received through the address or phone number described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s343/y"},"text":"section 343(y) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id146929c9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New medical information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The responsible person shall submit to the Secretary any new medical information, related to a submitted serious adverse event report that is received by the responsible person within 1 year of the initial report, no later than 15 business days after the new information is received by the responsible person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id146929ca-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidation of reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop systems to ensure that duplicate reports of, and new medical information related to, a serious adverse event shall be consolidated into a single report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id146929cb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, after providing notice and an opportunity for comment from interested parties, may establish an exemption to the requirements under paragraphs (1) and (2) if the Secretary determines that such exemption would have no adverse effect on public health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id146929cc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each serious adverse event report under this section shall be submitted to the Secretary using the MedWatch form, which may be modified by the Secretary for dietary supplements, and may be accompanied by additional information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id146929cd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance and inspection of records","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id146929ce-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The responsible person shall maintain records related to each report of an adverse event received by the responsible person for a period of 6 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id146929cf-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records inspection","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id146929d0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The responsible person shall permit an authorized person to have access to records required to be maintained under this section during an inspection pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s374"},"text":"section 374 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id146b99d1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this paragraph, the term “authorized person” means an officer or employee of the Department of Health and Human Services, who has—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id146b99d2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate credentials, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id146b99d3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" been duly designated by the Secretary to have access to the records required under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id146b99d4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protected information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A serious adverse event report submitted to the Secretary under this section, including any new medical information submitted under subsection (c)(2), or an adverse event report voluntarily submitted to the Secretary shall be considered to be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id146b99d5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a safety report under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s379v"},"text":"section 379v of this title","children":[],"tail":" and may be accompanied by a statement, which shall be a part of any report that is released for public disclosure, that denies that the report or the records constitute an admission that the product involved caused or contributed to the adverse event; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id146b99d6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a record about an individual under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":" (commonly referred to as the “Privacy Act of 1974”) and a medical or similar file the disclosure of which would constitute a violation of section 552 of such title 5 (commonly referred to as the “Freedom of Information Act”), and shall not be publicly disclosed unless all personally identifiable information is redacted."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id146b99d7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The submission of any adverse event report in compliance with this section shall not be construed as an admission that the dietary supplement involved caused or contributed to the adverse event.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id146b99d8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id146b99d9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No State or local government shall establish or continue in effect any law, regulation, order, or other requirement, related to a mandatory system for adverse event reports for dietary supplements, that is different from, in addition to, or otherwise not identical to, this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id146b99da-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of section","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id146b99db-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall affect the authority of the Secretary to provide adverse event reports and information to any health, food, or drug officer or employee of any State, territory, or political subdivision of a State or territory, under a memorandum of understanding between the Secretary and such State, territory, or political subdivision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id146b99dc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personally-identifiable information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, personally-identifiable information in adverse event reports provided by the Secretary to any health, food, or drug officer or employee of any State, territory, or political subdivision of a State or territory, shall not—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id146b99dd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/h/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be made publicly available pursuant to any State or other law requiring disclosure of information or records; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id146b99de-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/h/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise be disclosed or distributed to any party without the written consent of the Secretary and the person submitting such information to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id146b99df-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of safety reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall permit a State, territory, or political subdivision of a State or territory, to use any safety report received from the Secretary in a manner inconsistent with subsection (g) or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s379v"},"text":"section 379v of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id146b99e0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s379aa–1/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id146b99e1-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s761"},"text":"June 25, 1938, ch. 675, § 761","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/462/s3/a"},"text":"Pub. L. 109–462, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3472"},"text":"120 Stat. 3472","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id146b99e2-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id146b99e3-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id146b99e4-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 1 year after ","children":[{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/462/s3/d/1"},"text":"section 3(d)(1) of Pub. L. 109–462","children":[],"tail":", set out as an Effective Date of 2006 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s343"},"text":"section 343 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
