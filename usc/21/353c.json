{"tag":"section","attrib":{"id":"id13e15b0a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s353c"},"text":null,"children":[{"tag":"num","attrib":{"value":"353c"},"text":"§ 353c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prereview of television advertisements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id13e15b0b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s353c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may require the submission of any television advertisement for a drug (including any script, story board, rough, or a completed video production of the television advertisement) to the Secretary for review under this section not later than 45 days before dissemination of the television advertisement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13e15b0c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s353c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting a review of a television advertisement under this section, the Secretary may make recommendations with respect to information included in the label of the drug—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13e15b0d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s353c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" on changes that are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13e15b0e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s353c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary to protect the consumer good and well-being; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13e15b0f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s353c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with prescribing information for the product under review; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13e15b10-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s353c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if appropriate and if information exists, on statements for inclusion in the advertisement to address the specific efficacy of the drug as it relates to specific population groups, including elderly populations, children, and racial and ethnic minorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13e15b11-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s353c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No authority to require changes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided by subsection (e), this section does not authorize the Secretary to make or direct changes in any material submitted pursuant to subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13e15b12-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s353c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elderly populations, children, racially and ethnically diverse communities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In formulating recommendations under subsection (b), the Secretary shall take into consideration the impact of the advertised drug on elderly populations, children, and racially and ethnically diverse communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13e15b13-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s353c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific disclosures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13e15b14-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s353c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Serious risk; safety protocol","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting a review of a television advertisement under this section, if the Secretary determines that the advertisement would be false or misleading without a specific disclosure about a serious risk listed in the labeling of the drug involved, the Secretary may require inclusion of such disclosure in the advertisement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13e15b15-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s353c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date of approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting a review of a television advertisement under this section, the Secretary may require the advertisement to include, for a period not to exceed 2 years from the date of the approval of the drug under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"section 355 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"section 262 of title 42","children":[],"tail":", a specific disclosure of such date of approval if the Secretary determines that the advertisement would otherwise be false or misleading."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id13e15b16-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s353c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed as having any effect on requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s352/n"},"text":"section 352(n) of this title","children":[],"tail":" or on the authority of the Secretary under section 314.550, 314.640, 601.45, or 601.94 of title 21, Code of Federal Regulations (or successor regulations)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id13e3a507-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s503C"},"text":"June 25, 1938, ch. 675, § 503C","children":[],"tail":", formerly § 503B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/85/tIX/s901/d/2"},"text":"Pub. L. 110–85, title IX, § 901(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/939"},"text":"121 Stat. 939","children":[],"tail":", renumbered § 503C, "},{"tag":"ref","attrib":{"href":"/us/pl/113/54/tI/s102/a/1"},"text":"Pub. L. 113–54, title I, § 102(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-11-27"},"text":"Nov. 27, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/587"},"text":"127 Stat. 587","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id13e3a508-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id13e3a509-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id13e3a50a-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s353b"},"text":"section 353b of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/113/54"},"text":"Pub. L. 113–54","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id13e3a50b-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id13e3a50c-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/85/s909"},"text":"section 909 of Pub. L. 110–85","children":[],"tail":", set out as an Effective Date of 2007 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s331"},"text":"section 331 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
