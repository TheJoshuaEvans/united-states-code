{"tag":"section","attrib":{"id":"id14ba55b0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s961"},"text":null,"children":[{"tag":"num","attrib":{"value":"961"},"text":"§ 961.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited acts B","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any person who violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s954"},"text":"section 954 of this title","children":[],"tail":" or fails to notify the Attorney General of an importation or exportation under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s971"},"text":"section 971 of this title","children":[],"tail":" shall be subject to the following penalties:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id14ba55b1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s961/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), any such person shall, with respect to any such violation, be subject to a civil penalty of not more than $25,000. Sections 842(c)(1) and (c)(3) of this title shall apply to any civil penalty assessed under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14ba55b2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s961/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If such a violation is prosecuted by an information or indictment which alleges that the violation was committed knowingly or intentionally and the trier of fact specifically finds that the violation was so committed, such person shall be sentenced to imprisonment for not more than one year or a fine of not more than $25,000 or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14ba55b3-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/tIII/s1011"},"text":"Pub. L. 91–513, title III, § 1011","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1290"},"text":"84 Stat. 1290","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6053/d"},"text":"Pub. L. 100–690, title VI, § 6053(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4316"},"text":"102 Stat. 4316","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14ba55b4-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14ba55b5-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14ba55b6-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" inserted “or fails to notify the Attorney General of an importation or exportation under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s971"},"text":"section 971 of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id14ba55b7-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib"