{"tag":"section","attrib":{"id":"id14cfb35a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1907"},"text":null,"children":[{"tag":"num","attrib":{"value":"1907"},"text":"§ 1907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14cfb35b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1907/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “entity” means a partnership, joint venture, association, corporation, organization, network, group, or subgroup, or any form of business collaboration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14cfb35c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1907/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “foreign person” means any citizen or national of a foreign state or any entity not organized under the laws of the United States, but does not include a foreign state.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14cfb35d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1907/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Narcotics trafficking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “narcotics trafficking” means any illicit activity to cultivate, produce, manufacture, distribute, sell, finance, or transport narcotic drugs, controlled substances, or listed chemicals, or otherwise endeavor or attempt to do so, or to assist, abet, conspire, or collude with others to do so.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14cfb35e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1907/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Narcotic drug; controlled substance; listed chemical","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “narcotic drug”, “controlled substance”, and “listed chemical” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"section 802 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14cfb35f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1907/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means an individual or entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14cfb360-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1907/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States person” means any United States citizen or national, permanent resident alien, an entity organized under the laws of the United States (including its foreign branches), or any person within the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14cfb361-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1907/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Significant foreign narcotics trafficker","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “significant foreign narcotics trafficker” means any foreign person that plays a significant role in international narcotics trafficking, that the President has determined to be appropriate for sanctions pursuant to this chapter, and that the President has publicly identified in the report required under subsection (b) or (h)(1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1903"},"text":"section 1903 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14cfb362-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/120/tVIII/s808"},"text":"Pub. L. 106–120, title VIII, § 808","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-03"},"text":"Dec. 3, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1632"},"text":"113 Stat. 1632","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
