{"tag":"section","attrib":{"id":"id148f4de5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679"},"text":null,"children":[{"tag":"num","attrib":{"value":"679"},"text":"§ 679.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of Federal Food, Drug, and Cosmetic Act","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id148f4de6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities under food, drug, and cosmetic provisions unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provisions of law, including section 1002(b) of the Federal Food, Drug, and Cosmetic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s392/a"},"text":"21 U.S.C. 392(a)","children":[],"tail":"), the provisions of this chapter shall not derogate from any authority conferred by the Federal Food, Drug, and Cosmetic Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"21 U.S.C. 301","children":[],"tail":" et seq.] prior to "},{"tag":"date","attrib":{"date":"1967-12-15"},"text":"December 15, 1967","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id148f4de7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s679/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement proceedings; detainer authority of representatives of Secretary of Health and Human Services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The detainer authority conferred by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s672"},"text":"section 672 of this title","children":[],"tail":" shall apply to any authorized representative of the Secretary of Health and Human Services for purposes of the enforcement of the Federal Food, Drug, and Cosmetic Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"21 U.S.C. 301","children":[],"tail":" et seq.] with respect to any carcass, part thereof, meat, or meat food product of cattle, sheep, swine, goats, or equines that is outside any premises at which inspection is being maintained under this chapter, and for such purposes the first reference to the Secretary in "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s672"},"text":"section 672 of this title","children":[],"tail":" shall be deemed to refer to the Secretary of Health and Human Services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id148f4de8-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1907-03-04/ch2907"},"text":"Mar. 4, 1907, ch. 2907","children":[],"tail":", title IV, § 409, as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/201/s16"},"text":"Pub. L. 90–201, § 16","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-15"},"text":"Dec. 15, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/600"},"text":"81 Stat. 600","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/31/dA/tI/s103"},"text":"Pub. L. 111–31, div. A, title I, § 103","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"2009-06-22"},"text":"June 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1838"},"text":"123 Stat. 1838","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id148f4de9-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id148f4dea-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id148f4deb-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Food, Drug, and Cosmetic Act, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675"},"text":"act June 25, 1938, ch. 675","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1040"},"text":"52 Stat. 1040","children":[],"tail":", which is classified generally to chapter 9 (§ 301 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"section 301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id148f4dec-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/31"},"text":"Pub. L. 111–31","children":[],"tail":" substituted “section 1002(b)” for “section 902(b)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id148f4ded-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id148f4dee-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Health and Human Services” substituted for “Secretary of Health, Education, and Welfare” in subsec. (b) pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
