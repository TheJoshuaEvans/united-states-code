{"tag":"section","attrib":{"id":"id14cfb2d4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1715"},"text":null,"children":[{"tag":"num","attrib":{"value":"1715"},"text":"§ 1715.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GAO audit","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 4 years after ","children":[{"tag":"date","attrib":{"date":"2018-10-24"},"text":"October 24, 2018","children":[],"tail":", and every 4 years thereafter, the Comptroller General of the United States shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id14cfb2d5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1715/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct an audit relating to the programs and operations of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14cfb2d6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1715/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office; ","children":[{"tag":"ref","attrib":{"idref":"fn002191"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002191"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14cfb2d7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1715/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" certain programs within the Office,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" including—"}],"tail":null},{"tag":"clause","attrib":{"id":"id14cfb2d8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1715/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the High Intensity Drug Trafficking Areas Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14cfb2d9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1715/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Drug-Free Communities Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14cfb2da-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1715/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the campaign under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1708/f"},"text":"section 1708(f) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14cfb2db-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1715/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the Director ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and the appropriate congressional committees "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" a report containing an evaluation of and recommendations on the—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14cfb2dc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1715/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policies and activities of the programs and operations subject to the audit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14cfb2dd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1715/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economy, efficiency, and effectiveness in the administration of the reviewed programs and operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14cfb2de-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s1715/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policy or management changes needed to prevent and detect fraud and abuse in such programs and operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14cfb2df-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVIII/s8220"},"text":"Pub. L. 115–271, title VIII, § 8220","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4134"},"text":"132 Stat. 4134","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14cfb2e0-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14cfb2e1-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14cfb2e2-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The terms “Office”, “Director”, and “appropriate congressional committees”, referred to in text, probably have the meanings given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1701"},"text":"section 1701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id14cfb2e3-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Substance Abuse Prevention Act of 2018, and also as part of the Substance Use–Disorder Prevention that Promotes Opioid Recovery and Treatment for Patients and Communities Act, also known as the SUPPORT for Patients and Communities Act, and not as part of the Office of National Drug Control Policy Reauthorization Act of 1998 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
