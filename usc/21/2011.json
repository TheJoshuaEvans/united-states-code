{"tag":"section","attrib":{"id":"id14d223d1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2011"},"text":null,"children":[{"tag":"num","attrib":{"value":"2011"},"text":"§ 2011.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d223d2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2011/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Council” means the National Methamphetamine Advisory Council established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s2012/b/1"},"text":"section 2012(b)(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d223d3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2011/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “drug endangered children” means children whose physical, mental, or emotional health are at risk because of the production, use, or other effects of methamphetamine production or use by another person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d223d4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2011/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “National Methamphetamine Information Clearinghouse” or “NMIC” means the information clearinghouse established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s2012/a"},"text":"section 2012(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d223d5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2011/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “qualified entity” means a State, local, or tribal government, school board, or public health, law enforcement, nonprofit, community anti-drug coalition, or other nongovernmental organization providing services related to methamphetamines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14d223d6-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/469/tX/s1002"},"text":"Pub. L. 109–469, title X, § 1002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-29"},"text":"Dec. 29, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3537"},"text":"120 Stat. 3537","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
