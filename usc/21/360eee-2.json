{"tag":"section","attrib":{"id":"id143bd7ed-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"360eee–2"},"text":"§ 360eee–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National standards for prescription drug wholesale distributors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id143bd7ee-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2013-11-27"},"text":"November 27, 2013","children":[],"tail":", establish by regulation standards for the licensing of persons under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s353/e/1"},"text":"section 353(e)(1) of this title","children":[],"tail":", including the revocation, reissuance, and renewal of such license."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id143bd7ef-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of ensuring uniformity with respect to standards set forth in this section, the standards established under subsection (a) shall apply to all State and Federal licenses described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s353/e/1"},"text":"section 353(e)(1) of this title","children":[],"tail":" and shall include standards for the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id143bd7f0-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The storage and handling of prescription drugs, including facility requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143bd7f1-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The establishment and maintenance of records of the distributions of such drugs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143bd7f2-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The furnishing of a bond or other equivalent means of security, as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id143bd7f3-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–2/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id143bd7f4-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–2/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the issuance or renewal of a wholesale distributor license, an applicant that is not a government owned and operated wholesale distributor shall submit a surety bond of $100,000 or other equivalent means of security acceptable to the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id143bd7f5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–2/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of clause (i), the State or other applicable authority may accept a surety bond in the amount of $25,000 if the annual gross receipts of the previous tax year for the wholesaler is $10,000,000 or less.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id143bd7f6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–2/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a wholesale distributor can provide evidence that it possesses the required bond in a State, the requirement for a bond in another State shall be waived.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143bd7f7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–2/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mandatory background checks and fingerprinting of facility managers or designated representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143bd7f8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–2/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The establishment and implementation of qualifications for key personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143bd7f9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–2/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The mandatory physical inspection of any facility to be used in wholesale distribution within a reasonable time frame from the initial application of the facility and to be conducted by the licensing authority or by the State, consistent with subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143bd7fa-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–2/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In accordance with subsection (d), the prohibition of certain persons from receiving or maintaining licensure for wholesale distribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id143bd7fb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To satisfy the inspection requirement under subsection (b)(6), the Federal or State licensing authority may conduct the inspection or may accept an inspection by the State in which the facility is located, or by a third-party accreditation or inspection service approved by the Secretary or the State licensing such wholesale distributor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id143bd7fc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited persons","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The standards established under subsection (a) shall include requirements to prohibit a person from receiving or maintaining licensure for wholesale distribution if the person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id143bd7fd-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–2/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been convicted of any felony for conduct relating to wholesale distribution, any felony violation of subsection (i) or (k) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s331"},"text":"section 331 of this title","children":[],"tail":", or any felony violation of "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1365"},"text":"section 1365 of title 18","children":[],"tail":" relating to product tampering; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143bd7fe-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–2/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has engaged in a pattern of violating the requirements of this section, or State requirements for licensure, that presents a threat of serious adverse health consequences or death to humans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id143bd7ff-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in promulgating any regulation pursuant to this section, shall, notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id143bd800-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–2/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue a notice of proposed rulemaking that includes a copy of the proposed regulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143bd801-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–2/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a period of not less than 60 days for comments on the proposed regulation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id143bd802-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360eee–2/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that the final regulation take effect on the date that is 2 years after the date such final regulation is published.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id143bd803-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s583"},"text":"June 25, 1938, ch. 675, § 583","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/54/tII/s204/a/5"},"text":"Pub. L. 113–54, title II, § 204(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-11-27"},"text":"Nov. 27, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/634"},"text":"127 Stat. 634","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id143bd804-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id143bd805-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id143bd806-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-01-01"},"text":"Jan. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/113/54/s204/c"},"text":"section 204(c) of Pub. L. 113–54","children":[],"tail":", set out as an Effective Date of 2013 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s353"},"text":"section 353 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
