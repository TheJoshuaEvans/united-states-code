{"tag":"section","attrib":{"id":"id14371c33-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"360ddd–1"},"text":"§ 360ddd–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulation of medical gases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14371c34-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of designated medical gases","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14371c35-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning 180 days after ","children":[{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", any person who seeks to initially introduce or deliver for introduction a designated medical gas into interstate commerce may file with the Secretary a request for certification of a medical gas as a designated medical gas. Any such request shall contain the following information:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14371c36-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the medical gas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14371c37-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name and address of the sponsor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14371c38-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name and address of the facility or facilities where the medical gas is or will be manufactured.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14371c39-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other information deemed appropriate by the Secretary to determine whether the medical gas is a designated medical gas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14371c3a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant of certification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The certification requested under paragraph (1) is deemed to be granted unless, within 60 days of the filing of such request, the Secretary finds that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14371c3b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the medical gas subject to the certification is not a designated medical gas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14371c3c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the request does not contain the information required under paragraph (1) or otherwise lacks sufficient information to permit the Secretary to determine that the medical gas is a designated medical gas; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14371c3d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" denying the request is necessary to protect the public health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14371c3e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of certification","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14371c3f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14371c40-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approved uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A designated medical gas for which a certification is granted under paragraph (2) is deemed, alone or in combination, as medically appropriate, with another designated medical gas or gases for which a certification or certifications have been granted, to have in effect an approved application under section 355 or 360b of this title, subject to all applicable postapproval requirements, for the following indications for use:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id14371c41-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of oxygen, the treatment or prevention of hypoxemia or hypoxia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14371c42-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of nitrogen, use in hypoxic challenge testing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14371c43-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/3/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of nitrous oxide, analgesia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14371c44-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/3/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of carbon dioxide, use in extracorporeal membrane oxygenation therapy or respiratory stimulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14371c45-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/3/A/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of helium, the treatment of upper airway obstruction or increased airway resistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14371c46-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/3/A/i/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of medical air, to reduce the risk of hyperoxia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14371c47-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/3/A/i/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of carbon monoxide, use in lung diffusion testing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14371c48-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/3/A/i/VIII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VIII"},"text":"(VIII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other indication for use for a designated medical gas or combination of designated medical gases deemed appropriate by the Secretary, unless any period of exclusivity for a new drug under clause (iii) or (iv) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/c/3/E"},"text":"section 355(c)(3)(E) of this title","children":[],"tail":", clause (iii) or (iv) of "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/j/5/F"},"text":"section 355(j)(5)(F) of this title","children":[],"tail":", or "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360cc"},"text":"section 360cc of this title","children":[],"tail":", or the extension of any such period under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355a"},"text":"section 355a of this title","children":[],"tail":", applicable to such indication for use for such gas or combination of gases has not expired."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14371c49-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Labeling","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements of sections 353(b)(4) and 352(f) of this title are deemed to have been met for a designated medical gas if the labeling on the final use container for such medical gas bears—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id14371c4a-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s353/b/4"},"text":"section 353(b)(4) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14371c4b-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a warning statement concerning the use of the medical gas as determined by the Secretary by regulation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id14371c4c-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/3/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate directions and warnings concerning storage and handling.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14371c4d-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability of exclusivity provisions","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14371c4e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No exclusivity for a certified medical gas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No designated medical gas deemed under subparagraph (A)(i) to have in effect an approved application is eligible for any period of exclusivity for a new drug under section 355(c), 355(j), or 360cc of this title, or the extension of any such period under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355a"},"text":"section 355a of this title","children":[],"tail":", on the basis of such deemed approval."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14371c4f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No period of exclusivity under section 355(c), 355(j), or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360cc"},"text":"section 360cc of this title","children":[],"tail":", or the extension of any such period under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s355a"},"text":"section 355a of this title","children":[],"tail":", with respect to an application for a drug product, shall prohibit, limit, or otherwise affect the submission, grant, or effect of a certification under this section, except as provided in subsection (a)(3)(A)(i)(VIII) and "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360ddd/1/H"},"text":"section 360ddd(1)(H) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14371c50-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal, suspension, or revocation of approval","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14371c51-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal, suspension of approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this part limits the Secretary’s authority to withdraw or suspend approval of a drug product, including a designated medical gas deemed under this section to have in effect an approved application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"section 355 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360b"},"text":"section 360b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14371c52-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation of certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may revoke the grant of a certification under paragraph (2) if the Secretary determines that the request for certification contains any material omission or falsification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14371c53-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prescription requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14371c54-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A designated medical gas shall be subject to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s353/b/1"},"text":"section 353(b)(1) of this title","children":[],"tail":" unless the Secretary exercises the authority provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s353/b/3"},"text":"section 353(b)(3) of this title","children":[],"tail":" to remove such medical gas from the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s353/b/1"},"text":"section 353(b)(1) of this title","children":[],"tail":", the gas is approved for use without a prescription pursuant to an application under section 355 or 360b of this title, or the use in question is authorized pursuant to another provision of this chapter relating to use of medical products in emergencies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14371c55-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oxygen","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14371c56-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No prescription required for certain uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraph (1), oxygen may be provided without a prescription for the following uses:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14371c57-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For use in the event of depressurization or other environmental oxygen deficiency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14371c58-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For oxygen deficiency or for use in emergency resuscitation, when administered by properly trained personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14371c59-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s360ddd–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Labeling","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For oxygen provided pursuant to subparagraph (A), the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s353/b/4"},"text":"section 353(b)(4) of this title","children":[],"tail":" shall be deemed to have been met if its labeling bears a warning that the oxygen can be used for emergency use only and for all other medical applications a prescription is required."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14371c5a-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675/s576"},"text":"June 25, 1938, ch. 675, § 576","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/144/tXI/s1111"},"text":"Pub. L. 112–144, title XI, § 1111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-09"},"text":"July 9, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1109"},"text":"126 Stat. 1109","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIII/s3101/a/2/S"},"text":"Pub. L. 114–255, div. A, title III, § 3101(a)(2)(S)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1155"},"text":"130 Stat. 1155","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14371c5b-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14371c5c-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id14371c5d-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s3101/a/2/S/i"},"text":"Pub. L. 114–255, § 3101(a)(2)(S)(i)","children":[],"tail":", inserted “who seeks to initially introduce or deliver for introduction a designated medical gas into interstate commerce” after “any person” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(A)(i)(VIII). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s3101/a/2/S/ii/I/aa"},"text":"Pub. L. 114–255, § 3101(a)(2)(S)(ii)(I)(aa)","children":[],"tail":", inserted “for a new drug” after “any period of exclusivity”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s3101/a/2/S/ii/I/bb"},"text":"Pub. L. 114–255, § 3101(a)(2)(S)(ii)(I)(bb)","children":[],"tail":", inserted “the” before “final use” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s3101/a/2/S/ii/II/aa"},"text":"Pub. L. 114–255, § 3101(a)(2)(S)(ii)(II)(aa)","children":[],"tail":", inserted “for a new drug” after “any period of exclusivity”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s3101/a/2/S/ii/II/bb"},"text":"Pub. L. 114–255, § 3101(a)(2)(S)(ii)(II)(bb)","children":[],"tail":", inserted comma after “drug product”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
