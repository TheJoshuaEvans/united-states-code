{"tag":"section","attrib":{"id":"id14d9504f-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2355"},"text":null,"children":[{"tag":"num","attrib":{"value":"2355"},"text":"§ 2355.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of forfeited property of transnational criminal organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14d95050-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2355/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of forfeited property to forfeiture funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id14d95051-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2355/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any covered forfeited property shall be deposited into the Department of the Treasury Forfeiture Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s9705"},"text":"section 9705 of title 31","children":[],"tail":" or the Department of Justice Assets Forfeiture Fund established under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s524/c"},"text":"section 524(c) of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d95052-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2355/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2024-04-24"},"text":"April 24, 2024","children":[],"tail":", and every 180 days thereafter, the President shall submit to the appropriate congressional committees a report on any deposits made under paragraph (1) during the 180-day period preceding submission of the report."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id14d95053-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2355/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered forfeited property defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “covered forfeited property” means property—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id14d95054-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2355/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forfeited to the United States under chapter 46 or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1963"},"text":"section 1963 of title 18","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id14d95055-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2355/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that belonged to or was possessed by an individual affiliated with or connected to a transnational criminal organization subject to sanctions under—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id14d95056-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2355/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d95057-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2355/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Fentanyl Sanctions Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s2301"},"text":"21 U.S.C. 2301","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id14d95058-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2355/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Executive Order 14059 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" note; relating to imposing sanctions on foreign persons involved in the global illicit drug trade)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d95059-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2355/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Blocked Assets Under Terrorism Risk Insurance Act of 2002","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter may be construed to affect the treatment of blocked assets of a terrorist party described in section 201(a) of the Terrorism Risk Insurance Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1610"},"text":"28 U.S.C. 1610","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14d9505a-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/50/dE/tI/s3105"},"text":"Pub. L. 118–50, div. E, title I, § 3105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-24"},"text":"Apr. 24, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/938"},"text":"138 Stat. 938","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id14d9505b-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id14d9505c-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id14d9505d-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Fentanyl Sanctions Act, referred to in subsec. (a)(3)(B)(ii), is title LXXII of div. F of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":", which is classified principally to chapter 28 (§ 2301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s2301"},"text":"section 2301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 201(a) of the Terrorism Risk Insurance Act of 2002, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/297/s201/a"},"text":"section 201(a) of Pub. L. 107–297","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1610"},"text":"section 1610 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
