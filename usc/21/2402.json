{"tag":"section","attrib":{"id":"id14d95084-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2402"},"text":null,"children":[{"tag":"num","attrib":{"value":"2402"},"text":"§ 2402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major international doping fraud conspiracies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id14d95085-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2402/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any person, other than an athlete, to knowingly carry into effect, attempt to carry into effect, or conspire with any other person to carry into effect a scheme in commerce to influence by use of a prohibited substance or prohibited method any major international sports competition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id14d95086-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s2402/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extraterritorial jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is extraterritorial Federal jurisdiction over an offense under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id14d95087-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/206/s3"},"text":"Pub. L. 116–206, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-04"},"text":"Dec. 4, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/999"},"text":"134 Stat. 999","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
