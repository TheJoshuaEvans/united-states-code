{"tag":"section","attrib":{"id":"id13d7bec5-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350l–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"350l–1"},"text":"§ 350l–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id13d7bec6-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350l–1/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"January 4, 2011","children":[],"tail":", and annually thereafter, the Secretary of Health and Human Services (referred to in this section as the “Secretary”) shall submit a report to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Energy and Commerce of the House of Representatives on the use of recall authority under section 350"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title (as added by subsection (a)) "},{"tag":"ref","attrib":{"idref":"fn002029"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002029"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and any public health advisories issued by the Secretary that advise against the consumption of an article of food on the ground that the article of food is adulterated and poses an imminent danger to health."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id13d7bec7-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350l–1/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report under paragraph (1) shall include, with respect to the report year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id13d7bec8-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350l–1/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity of each article of food that was the subject of a public health advisory described in paragraph (1), an opportunity to cease distribution and recall under subsection (a) of section 350","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title, or a mandatory recall order under subsection (b) of such section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d7bec9-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350l–1/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of responsible parties, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s350f"},"text":"section 350f of this title","children":[],"tail":", formally given the opportunity to cease distribution of an article of food and recall such article, as described in section 350"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(a) of such title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d7beca-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350l–1/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of responsible parties described in subparagraph (B) who did not cease distribution of or recall an article of food after given the opportunity to cease distribution or recall under section 350","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(a) of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d7becb-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350l–1/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of recall orders issued under section 350","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(b) of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id13d7becc-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s350l–1/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any instances in which there was no testing that confirmed adulteration of an article of food that was the subject of a recall under section 350","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(b) of this title or a public health advisory described in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id13d7becd-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/353/tII/s206/f"},"text":"Pub. L. 111–353, title II, § 206(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3943"},"text":"124 Stat. 3943","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id13d7bece-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id13d7becf-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id13d7bed0-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsection (a), referred to in par. (1), means subsec. (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/353/s206"},"text":"section 206 of Pub. L. 111–353","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id13d7bed1-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the FDA Food Safety Modernization Act, and not as part of the Federal Food, Drug, and Cosmetic Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id13d7bed2-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id13d7bed3-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in this section to be construed to alter jurisdiction and authorities established under certain other Acts or in a manner inconsistent with international agreements to which the United States is a party, see sections 2251 and 2252 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
