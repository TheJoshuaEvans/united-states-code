{"tag":"section","attrib":{"id":"id148d041e-3a70-11f1-b089-c1e1e512a22d","identifier":"/us/usc/t21/s616"},"text":null,"children":[{"tag":"num","attrib":{"value":"616"},"text":"§ 616.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspectors of carcasses, etc., meat of which is intended for export; certificates of condition","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s615"},"text":"section 615 of this title","children":[],"tail":" the Secretary may appoint inspectors who shall be authorized to give an official certificate stating the condition in which said cattle, sheep, swine, goats, horses, mules, or other equines, and the meat thereof, are found."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id148d041f-3a70-11f1-b089-c1e1e512a22d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1907-03-04/ch2907"},"text":"Mar. 4, 1907, ch. 2907","children":[],"tail":", title I, § 16, formerly 14th par., "},{"tag":"ref","attrib":{"href":"/us/stat/34/1263"},"text":"34 Stat. 1263","children":[],"tail":"; renumbered § 16 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/90/201"},"text":"Pub. L. 90–201","children":[],"tail":", §§ 1, 3(b), 12(a), "},{"tag":"date","attrib":{"date":"1967-12-15"},"text":"Dec. 15, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/584"},"text":"81 Stat. 584","children":[],"tail":", 588, 592.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id148d0420-3a70-11f1-b089-c1e1e512a22d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id148d0421-3a70-11f1-b089-c1e1e512a22d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib