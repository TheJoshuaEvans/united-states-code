{"tag":"section","attrib":{"id":"idb973831e-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s5006"},"text":null,"children":[{"tag":"num","attrib":{"value":"5006"},"text":"§ 5006.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lien on compensation of contractor","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb973831f-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s5006/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9738320-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s5006/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performs service for a contractor or subcontractor in the transportation of mail;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9738321-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s5006/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" files his contract for service with the Postal Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9738322-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s5006/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" files satisfactory evidence of performance with the Postal Service;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall have a lien on money due the contractor or subcontractor for the service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9738323-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s5006/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Postal Service may pay the person establishing a lien under subsection (a) of this section the sum due him, when the contractor or subcontractor fails to pay the person the amount of his lien within 2 months after the expiration of the month in which the service was performed. It shall charge the amount so paid to the contract. The payments may not exceed the annual rate of pay of the contractor or subcontractor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9738324-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/767"},"text":"84 Stat. 767","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9738325-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9738326-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9738327-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1971-07-01"},"text":"July 1, 1971","children":[],"tail":", pursuant to Resolution No. 71–9 of the Board of Governors. See "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
