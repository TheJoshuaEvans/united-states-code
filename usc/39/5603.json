{"tag":"section","attrib":{"id":"idb9783d50-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s5603"},"text":null,"children":[{"tag":"num","attrib":{"value":"5603"},"text":"§ 5603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation of mail by vessel as freight or express","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Postal Service may require that mail be transported by freight or express when—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9783d51-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s5603/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is no competition on a water route and the rate or compensation asked is excessive; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9783d52-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s5603/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no proposal is received.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"A common carrier by water that fails or refuses to transport the mail when required to do so under this section shall be fined not more than $500 for each day of refusal.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9783d53-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/773"},"text":"84 Stat. 773","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9783d54-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9783d55-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9783d56-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1971-07-01"},"text":"July 1, 1971","children":[],"tail":", pursuant to Resolution No. 71–9 of the Board of Governors. See "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
