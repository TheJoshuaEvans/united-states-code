{"tag":"section","attrib":{"id":"idb9652b11-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3201"},"text":null,"children":[{"tag":"num","attrib":{"value":"3201"},"text":"§ 3201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9652b12-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3201/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “penalty mail” means official mail, other than franked mail, which is authorized by law to be transmitted in the mail without prepayment of postage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652b13-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3201/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “penalty cover” means envelopes, wrappers, labels, or cards used to transmit penalty mail;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652b14-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3201/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “frank” means the autographic or facsimile signature of persons authorized by sections 3210–3216 and 3218 of this title to transmit matter through the mail without prepayment of postage or other indicia contemplated by sections 733 and 907 of title 44;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652b15-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3201/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “franked mail” means mail which is transmitted in the mail under a frank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652b16-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3201/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Members of Congress” includes Senators, Representatives, Delegates, and Resident Commissioners; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652b17-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3201/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “missing child” has the meaning provided by section 403(1) of the Juvenile Justice and Delinquency Prevention Act of 1974.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9652b18-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/751"},"text":"84 Stat. 751","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/87/s1/b"},"text":"Pub. L. 99–87, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-09"},"text":"Aug. 9, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/291"},"text":"99 Stat. 291","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9652b19-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9652b1a-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"ta