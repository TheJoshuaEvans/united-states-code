{"tag":"section","attrib":{"id":"idb96ea1b5-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652"},"text":null,"children":[{"tag":"num","attrib":{"value":"3652"},"text":"§ 3652.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports to the Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb96ea1b6-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Costs, Revenues, Rates, and Service","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c), the Postal Service shall, no later than 90 days after the end of each year, prepare and submit to the Postal Regulatory Commission a report (together with such nonpublic annex to the report as the Commission may require under subsection (e))—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96ea1b7-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which shall analyze costs, revenues, rates, and quality of service, using such methodologies as the Commission shall by regulation prescribe, and in sufficient detail to demonstrate that all products during such year complied with all applicable requirements of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96ea1b8-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which shall, for each market-dominant product provided in such year, provide—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb96ea1b9-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" product information, including mail volumes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96ea1ba-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" measures of the quality of service afforded by the Postal Service in connection with such product, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb96ea1bb-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level of service (described in terms of speed of delivery and reliability) provided; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb96ea1bc-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree of customer satisfaction with the service provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Inspector General shall regularly audit the data collection systems and procedures utilized in collecting information and preparing such report (including any annex thereto and the information required under subsection (b)). The results of any such audit shall be submitted to the Postal Service and the Postal Regulatory Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96ea1bd-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information Relating to Workshare Discounts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Postal Service shall include, in each report under subsection (a), the following information with respect to each market-dominant product for which a workshare discount was in effect during the period covered by such report:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96ea1be-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The per-item cost avoided by the Postal Service by virtue of such discount.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96ea1bf-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The percentage of such per-item cost avoided that the per-item workshare discount represents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96ea1c0-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The per-item contribution made to institutional costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96ea1c1-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Market Tests","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsections (a) and (b) with respect to experimental products offered through market tests under section 3641 in a year, the Postal Service shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96ea1c2-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report data on the costs, revenues, and quality of service by market test, which may be reported in summary form; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96ea1c3-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report such data as the Postal Regulatory Commission requires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96ea1c4-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Supporting Matter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Postal Regulatory Commission shall have access, in accordance with such regulations as the Commission shall prescribe, to the working papers and any other supporting matter of the Postal Service and the Inspector General in connection with any information submitted under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96ea1c5-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content and Form of Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96ea1c6-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Postal Regulatory Commission shall, by regulation, prescribe the content and form of the public reports (and any nonpublic annex and supporting matter relating to the report) to be provided by the Postal Service under this section. In carrying out this subsection, the Commission shall give due consideration to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb97111c7-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing the public with timely, adequate information to assess the lawfulness of rates charged;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb97111c8-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" avoiding unnecessary or unwarranted administrative effort and expense on the part of the Postal Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb97111c9-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protecting the confidentiality of commercially sensitive information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97111ca-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revised requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission may, on its own motion or on request of an interested party, initiate proceedings (to be conducted in accordance with regulations that the Commission shall prescribe) to improve the quality, accuracy, or completeness of Postal Service data required by the Commission under this subsection whenever it shall appear that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb97111cb-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the attribution of costs or revenues to products has become significantly inaccurate or can be significantly improved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb97111cc-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quality of service data has become significantly inaccurate or can be significantly improved; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb97111cd-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such revisions are, in the judgment of the Commission, otherwise necessitated by the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb97111ce-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Confidential Information.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb97111cf-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Postal Service determines that any document or portion of a document, or other matter, which it provides to the Postal Regulatory Commission in a nonpublic annex under this section or under subsection (d) contains information which is described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s410/c"},"text":"section 410(c) of this title","children":[],"tail":", or exempt from public disclosure under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b"},"text":"section 552(b) of title 5","children":[],"tail":", the Postal Service shall, at the time of providing such matter to the Commission, notify the Commission of its determination, in writing, and describe with particularity the documents (or portions of documents) or other matter for which confidentiality is sought and the reasons therefor."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97111d0-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any information or other matter described in paragraph (1) to which the Commission gains access under this section shall be subject to paragraphs (2) and (3) of section 504(g) in the same way as if the Commission had received notification with respect to such matter under section 504(g)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb97111d1-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Postal Service shall submit to the Postal Regulatory Commission, together with any other submission that the Postal Service is required to make under this section in a year, copies of its then most recent—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb97111d2-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comprehensive statement under section 2401(e);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97111d3-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performance plan under section 2803; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97111d4-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3652/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" program performance reports under section 2804.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb97111d5-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435/tII/s204/b"},"text":"Pub. L. 109–435, title II, § 204(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3211"},"text":"120 Stat. 3211","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
