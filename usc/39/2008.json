{"tag":"section","attrib":{"id":"idb95b8e0d-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2008"},"text":null,"children":[{"tag":"num","attrib":{"value":"2008"},"text":"§ 2008.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit and expenditures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb95b8e0e-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2008/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The accounts and operations of the Postal Service shall be audited by the Comptroller General and reports thereon made to the Congress to the extent and at such times as he may determine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95b8e0f-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2008/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Postal Service shall maintain an adequate internal audit of the financial transactions of the Postal Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95b8e10-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2008/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject only to the provisions of this chapter, the Postal Service is authorized to make such expenditures and to enter into such contracts, agreements, and arrangements, upon such terms and conditions and in such manner as it deems necessary, including the final settlement of all claims and litigation by or against the Postal Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95b8e11-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2008/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section shall be construed as denying to the Postal Service the power to obtain audits of the accounts of the Postal Service and reports concerning its financial condition and operations by certified public accounting firms. Such audits and reports shall be in addition to those required by this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95b8e12-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2008/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At least once each year beginning with the fiscal year commencing after ","children":[{"tag":"date","attrib":{"date":"1971-06-30"},"text":"June 30, 1971","children":[],"tail":", the Postal Service shall obtain a certification from an independent, certified public accounting firm of the accuracy of any financial statements of the Postal Service used in determining and establishing postal rates."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb95b8e13-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/741"},"text":"84 Stat. 741","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb95b8e14-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb95b8e15-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb95b8e16-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1971-07-01"},"text":"July 1, 1971","children":[],"tail":", pursuant to Resolution No. 71–9 of the Board of Governors. See "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
