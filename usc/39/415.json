{"tag":"section","attrib":{"id":"idb94fa6d7-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s415"},"text":null,"children":[{"tag":"num","attrib":{"value":"415"},"text":"§ 415.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on restriction or elimination of services","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Postal Service may not restrict, eliminate, or adversely affect any service provided by the Postal Service as a result of the payment of any penalty imposed under the Occupational Safety and Health Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s651"},"text":"29 U.S.C. 651","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb94fa6d8-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/241/s4/a"},"text":"Pub. L. 105–241, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-09-28"},"text":"Sept. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1573"},"text":"112 Stat. 1573","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb94fa6d9-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb94fa6da-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb94fa6db-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Occupational Safety and Health Act of 1970, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/596"},"text":"Pub. L. 91–596","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-29"},"text":"Dec. 29, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1590"},"text":"84 Stat. 1590","children":[],"tail":", which is classified principally to chapter 15 (§ 651 et seq.) of Title 29, Labor. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s651"},"text":"section 651 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
