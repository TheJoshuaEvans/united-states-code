{"tag":"section","attrib":{"id":"idb9679bd7-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3213"},"text":null,"children":[{"tag":"num","attrib":{"value":"3213"},"text":"§ 3213.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seeds and reports from Department of Agriculture","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Seeds and agricultural reports emanating from the Department of Agriculture may be mailed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9679bd8-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3213/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as penalty mail by the Secretary of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9679bd9-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3213/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the 90-day period immediately following the expiration of their terms of office, as franked mail by Members of Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9679bda-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/754"},"text":"84 Stat. 754","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/69/s5/b"},"text":"Pub. L. 97–69, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-10-26"},"text":"Oct. 26, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1043"},"text":"95 Stat. 1043","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote"