{"tag":"section","attrib":{"id":"idb969e5fe-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3218"},"text":null,"children":[{"tag":"num","attrib":{"value":"3218"},"text":"§ 3218.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Franked mail for survivors of Members of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Upon the death of a Member of Congress during his term of office, the surviving spouse of such Member (or, if there is no surviving spouse, a member of the immediate family of the Member designated by the Secretary of the Senate or the Clerk of the House of Representatives, as appropriate, in accordance with rules and procedures established by the Secretary or the Clerk) may send, for a period not to exceed 180 days after his death, as franked mail, nonpolitical correspondence relating to the death of the Member.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb969e5ff-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/755"},"text":"84 Stat. 755","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/191/s11"},"text":"Pub. L. 93–191, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-18"},"text":"Dec. 18, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/746"},"text":"87 Stat. 746","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/69/s6/b"},"text":"Pub. L. 97–69, § 6(b)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1981-10-26"},"text":"Oct. 26, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1043"},"text":"95 Stat. 1043","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb969e600-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb969e601-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb969e602-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/69"},"text":"Pub. L. 97–69","children":[],"tail":" substituted “survivors” for “surviving spouses” in section catchline and, in text, inserted “(or, if there is no surviving spouse, a member of the immediate family of the Member designated by the Secretary of the Senate or the Clerk of the House of Representatives, as appropriate, in accordance with rules and procedures established by the Secretary or the Clerk)” after “such Member”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/191"},"text":"Pub. L. 93–191","children":[],"tail":" inserted “nonpolitical” before “correspondence”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb969e603-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb969e604-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1973 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"h