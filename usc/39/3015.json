{"tag":"section","attrib":{"id":"idb962ba85-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3015"},"text":null,"children":[{"tag":"num","attrib":{"value":"3015"},"text":"§ 3015.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonmailable plant pests and injurious animals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb962ba86-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3015/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Injurious Animals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any injurious animal, the importation or interstate shipment of which is prohibited pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s42"},"text":"section 42 of title 18","children":[],"tail":", constitutes nonmailable matter."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb962ba87-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3015/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plant Pests","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any plant pest, the movement of which is prohibited pursuant to section 103 or 104 of the Federal Plant Pest Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s150bb"},"text":"7 U.S.C. 150bb","children":[],"tail":" or 150cc),"},{"tag":"ref","attrib":{"idref":"fn002008"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002008"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" constitutes nonmailable matter."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb962ba88-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3015/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any plant, article, or matter, the importation or interstate shipment of which is prohibited pursuant to the Act of ","children":[{"tag":"date","attrib":{"date":"1912-08-20"},"text":"August 20, 1912","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/37/315"},"text":"37 Stat. 315","children":[],"tail":", chapter 308; "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s151"},"text":"7 U.S.C. 151","children":[],"tail":" et seq.) (commonly known as the “Plant Quarantine Act”),"},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" constitutes nonmailable matter."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb962ba89-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3015/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Illegally Taken Fish, Wildlife, or Plants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any fish, wildlife, or plant, the conveyance of which is prohibited pursuant to section 3 of the Lacey Act Amendments of 1981 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3372"},"text":"16 U.S.C. 3372","children":[],"tail":"), constitutes nonmailable matter."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb962ba8a-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/393/tVI/s631/d/1"},"text":"Pub. L. 102–393, title VI, § 631(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1776"},"text":"106 Stat. 1776","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb962ba8b-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb962ba8c-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb962ba8d-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 103 and 104 of the Federal Plant Pest Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s150bb"},"text":"7 U.S.C. 150bb","children":[],"tail":", 150cc), referred to in subsec. (b), were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/106/224/tIV/s438/a/2"},"text":"Pub. L. 106–224, title IV, § 438(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/454"},"text":"114 Stat. 454","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Plant Quarantine Act, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1912-08-20/ch308"},"text":"act Aug. 20, 1912, ch. 308","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/315"},"text":"37 Stat. 315","children":[],"tail":", which was classified generally to chapter 8 (§ 151 et seq.) of Title 7, Agriculture, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/106/224/tIV/s438/a/1"},"text":"Pub. L. 106–224, title IV, § 438(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/454"},"text":"114 Stat. 454","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb962ba8e-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idb962ba8f-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/393/tVI/s631/e"},"text":"Pub. L. 102–393, title VI, § 631(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1776"},"text":"106 Stat. 1776","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/393/tVI/s631/e"},"text":"“This section [enacting this section and provisions set out below] may be cited as the ‘Alien Species Prevention and Enforcement Act of 1992’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb962ba90-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Alien Species Prevention and Enforcement in Hawaii","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/393/tVI/s631/a"},"text":"Pub. L. 102–393, title VI, § 631(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1774"},"text":"106 Stat. 1774","children":[],"tail":", 1776, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/393/tVI/s631/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pests in the Mails.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraph (2), the Secretary of Agriculture shall hereafter operate a program, under terms and conditions acceptable to the Postal Service, to protect Hawaii from the introduction of prohibited plants, plant pests, and injurious animals that may be contained in mail received in Hawaii, except that this subsection shall not apply to mail that originates and is intended for delivery outside the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Memorandum of understanding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purpose of carrying out the program operated under paragraph (1), the Secretary of Agriculture shall enter into a memorandum of understanding or other agreement with the Secretary of the Interior relating to prohibited plants, plant pests, or injurious animals under the jurisdiction of the Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remedial action","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, pursuant to the program, mail is found to contain a prohibited plant, plant pest, or injurious animal, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a record of the prohibited plant, plant pest, or injurious animal found in the mail;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take appropriate action to prevent the introduction of the prohibited material into Hawaii; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine whether the facts and circumstances warrant seeking prosecution under a law prohibiting the conveyance of a plant, plant pest, or injurious animal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Injurious animal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘injurious animal’ means an animal the importation or interstate shipment of which is prohibited by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s42"},"text":"section 42 of title 18","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plant","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘plant’ means a plant from any class of plants, or any other article or matter, the importation or interstate shipment of which is prohibited under the Act of ","children":[{"tag":"date","attrib":{"date":"1912-08-20"},"text":"August 20, 1912","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/37/315"},"text":"37 Stat. 315","children":[],"tail":", chapter 308; "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s151"},"text":"7 U.S.C. 151","children":[],"tail":" et seq.) (commonly known as the ‘Plant Quarantine Act’)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plant pest","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘plant pest’ means any organism or substance the importation or interstate shipment of which is prohibited under the Federal Plant Pest Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s150aa"},"text":"7 U.S.C. 150aa","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperative Agreements With Hawaii To Enforce Certain Agricultural Quarantine Laws.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement between secretary of agriculture and hawaii.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":"], the Secretary of Agriculture shall offer to enter into a cooperative agreement with the State of Hawaii for a 2-year period to enforce in the State—"}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Act of ","children":[{"tag":"date","attrib":{"date":"1912-08-20"},"text":"August 20, 1912","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/37/315"},"text":"37 Stat. 315","children":[],"tail":", chapter 308; "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s151"},"text":"7 U.S.C. 151","children":[],"tail":" et seq.) (commonly known as the ‘Plant Quarantine Act’);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Plant Pest Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s150aa"},"text":"7 U.S.C. 150aa","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the matter under the heading ‘","children":[{"tag":"inline","attrib":{},"text":"Enforcement of the plant-quarantine Act","children":[],"tail":":’ of the Act of "},{"tag":"date","attrib":{"date":"1915-03-04"},"text":"March 4, 1915","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/38/1113"},"text":"38 Stat. 1113","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s166"},"text":"7 U.S.C. 166","children":[],"tail":" [7760]) (commonly known as the ‘Terminal Inspection Act’)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inspection of plants and plant products","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The cooperative agreement shall establish a specific procedure for the submission and approval of the names of plants and plant products that the State of Hawaii elects to inspect under the provision of law referred to in subparagraph (A)(iii).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out this paragraph under the authority provided by—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 102 of the Department of Agriculture Organic Act of 1944 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s147a"},"text":"7 U.S.C. 147a","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/act/1884-05-29/s3"},"text":"section 3 of the Act of May 29, 1884","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/23/32"},"text":"23 Stat. 32","children":[],"tail":", chapter 60; "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s114"},"text":"21 U.S.C. 114","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 11 of the Department of Agriculture Organic Act of 1956 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s114a"},"text":"7 U.S.C. 114a","children":[],"tail":") [probably means section 11 of act "},{"tag":"date","attrib":{"date":"1884-05-29"},"text":"May 29, 1884","children":[],"tail":", as added by the Department of Agriculture Organic Act of 1944, which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s114a"},"text":"21 U.S.C. 114a","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement between secretary of the interior and hawaii.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":"], the Secretary of the Interior shall offer to enter into a cooperative agreement with the State of Hawaii for a 2-year period to enforce in the State the Lacey Act Amendments of 1981 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3371"},"text":"16 U.S.C. 3371","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall use to carry out this paragraph the authority provided under section 3 of the Fish and Wildlife Improvement Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s742"},"text":"16 U.S.C. 742","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement between postal service and hawaii.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of enactment of this Act, the Postal Service shall offer to enter into a cooperative agreement with the State of Hawaii for a 2-year period to enforce in the State, under terms and conditions acceptable to the Postal Service and in compliance with postal regulations, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/574"},"text":"Public Law 100–574","children":[],"tail":" [enacting "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s3014"},"text":"section 3014 of this title","children":[],"tail":", sections 1716B and 1716C of Title 18, Crimes and Criminal Procedure, and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s3014"},"text":"section 3014 of this title","children":[],"tail":"] and the amendments made by such Public Law."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Postal Service shall use to carry out this paragraph the authority provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3014"},"text":"section 3014 of title 39","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperative programs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any program conducted jointly by the State of Hawaii and any Federal agency under this subsection that in any way affects the mail or the postal system of the United States shall comply with postal regulations and shall be conducted under terms and conditions acceptable to the Postal Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extension of agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A cooperative agreement entered into under this subsection may be extended by mutual consent of the parties to the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Information Program on Prohibitions Against Shipment or Transportation of Plant Pests and Injurious Animals.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Postal Service, the Secretary of the Interior, and the Secretary of Agriculture shall jointly establish a public information program to inform the public on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prohibitions against the shipment or transportation of plants, plants [sic] pests, and injurious animals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consequences of violating Federal laws designed to prevent the introduction of alien species into the State of Hawaii and other areas of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Methods","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out paragraph (1), the Postal Service and Secretaries may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use public service announcements, mail, and other forms of distributing information, dial-up information services, and such other methods as will effectively communicate the information described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with State and private organizations to carry out the program established under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Study","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the program established under subsection (a) commences, the Secretary of Agriculture, in cooperation with the Secretary of the Interior, the Postal Service, and the State of Hawaii, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct 