{"tag":"section","attrib":{"id":"idb943c052-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s102"},"text":null,"children":[{"tag":"num","attrib":{"value":"102"},"text":"§ 102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this title—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb943c053-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Postal Service” means the United States Postal Service established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s201"},"text":"section 201 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb943c054-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Board of Governors”, and “Board”, unless the context otherwise requires, mean the Board of Governors established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s202"},"text":"section 202 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb943c055-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Governors” means the 9 members of the Board of Governors appointed by the President, by and with the advice and consent of the Senate, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s202/a"},"text":"section 202(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb943c056-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s102/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Inspector General” means the Inspector General appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s202/e"},"text":"section 202(e) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb943c057-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s102/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “postal service” refers to the delivery of letters, printed matter, or mailable packages, including acceptance, collection, sorting, transportation, or other functions ancillary thereto;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb943c058-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s102/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “product” means a postal service with a distinct cost or market characteristic for which a rate or rates are, or may reasonably be, applied;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb943c059-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s102/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “rates”, as used with respect to products, includes fees for postal services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb943c05a-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s102/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “market-dominant product” or “product in the market-dominant category of mail” means a product subject to subchapter I of chapter 36;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb943c05b-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s102/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “competitive product” or “product in the competitive category of mail” means a product subject to subchapter II of chapter 36; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb943c05c-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s102/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “year”, as used in chapter 36 (other than subchapters I and VI thereof), means a fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb943c05d-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/720"},"text":"84 Stat. 720","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/f/tVI/s662/a/2"},"text":"Pub. L. 104–208, div. A, title I, § 101(f) [title VI, § 662(a)(2)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-314"},"text":"110 Stat. 3009–314","children":[],"tail":", 3009–379; "},{"tag":"ref","attrib":{"href":"/us/pl/109/435/tI/s101"},"text":"Pub. L. 109–435, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3199"},"text":"120 Stat. 3199","children":[],"tail":".)