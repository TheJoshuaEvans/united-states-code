{"tag":"section","attrib":{"id":"idb952186a-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s603"},"text":null,"children":[{"tag":"num","attrib":{"value":"603"},"text":"§ 603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Searches authorized","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Postal Service may authorize any officer or employee of the Postal Service to make searches for mail matter transported in violation of law. When the authorized officer has reason to believe that mailable matter transported contrary to law may be found therein, he may open and search any—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb952186b-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s603/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vehicle passing, or having lately passed, from a place at which there is a post office of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb952186c-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s603/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" article being, or having lately been, in the vehicle; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb952186d-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s603/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" store or office, other than a dwelling house, used or occupied by a common carrier or transportation company, in which an article may be contained.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb952186e-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/727"},"text":"84 Stat. 727","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb952186f-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9521870-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9521871-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1971-07-01"},"text":"July 1, 1971","children":[],"tail":", pursuant to Resolution No. 71–9 of the Board of Governors. See "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
