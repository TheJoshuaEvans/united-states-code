{"tag":"section","attrib":{"id":"idb9463195-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s205"},"text":null,"children":[{"tag":"num","attrib":{"value":"205"},"text":"§ 205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures of the Board of Governors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9463196-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s205/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board shall direct and control the expenditures and review the practices and policies of the Postal Service, and perform other functions and duties prescribed by this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9463197-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s205/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Vacancies in the Board, as long as there are sufficient members to form a quorum, shall not impair the powers of the Board under this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9463198-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s205/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Board shall act upon majority vote of those members who are present, and any 6 members present shall constitute a quorum for the transaction of business by the Board, except—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9463199-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s205/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that in the appointment or removal of the Postmaster General, and in setting the compensation of the Postmaster General and Deputy Postmaster General, a favorable vote of an absolute majority of the Governors in office shall be required;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb946319a-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s205/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that in the appointment or removal of the Deputy Postmaster General, a favorable vote of an absolute majority of the Governors in office and the member serving as Postmaster General shall be required; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb946319b-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s205/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as otherwise provided in this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb946319c-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s205/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No officer or employee of the United States may serve concurrently as a Governor. A Governor may hold any other office or employment not inconsistent or in conflict with his duties, responsibilities, and powers as an officer of the Government of the United States in the Postal Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb946319d-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/721"},"text":"84 Stat. 721","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb946319e-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb946319f-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb94631a0-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsecs. (a) and (d) effective ","children":[{"tag":"date","attrib":{"date":"1971-07-01"},"text":"July 1, 1971","children":[],"tail":", pursuant to Resolution No. 71–9 of the Board of Governors, and subsecs. (b) and (c) effective "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
