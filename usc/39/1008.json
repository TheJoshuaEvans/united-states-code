{"tag":"section","attrib":{"id":"idb956d320-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s1008"},"text":null,"children":[{"tag":"num","attrib":{"value":"1008"},"text":"§ 1008.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary employees or carriers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb956d321-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s1008/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person temporarily employed to deliver mail is deemed an employee of the Postal Service and is subject to the provisions of chapter 83 of title 18 to the same extent as other employees of the Postal Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb956d322-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s1008/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person, when engaged in carrying mail under contract with the Postal Service, or employed by the Postal Service, is deemed a carrier or person entrusted with the mail and having custody thereof, within the meaning of sections 1701, 1708, and 2114 of title 18.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb956d323-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/732"},"text":"84 Stat. 732","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb956d324-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb956d325-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb956d326-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1971-07-01"},"text":"July 1, 1971","children":[],"tail":", pursuant to Resolution No. 71–9 of the Board of Governors. See "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
