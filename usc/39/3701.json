{"tag":"section","attrib":{"id":"idb97382b4-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3701"},"text":null,"children":[{"tag":"num","attrib":{"value":"3701"},"text":"§ 3701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purpose of this chapter is to enable the Postal Service to increase its net revenues through specific nonpostal products and services that are expressly authorized by this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb97382b5-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/108/tI/s103/a/1"},"text":"Pub. L. 117–108, title I, § 103(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-04-06"},"text":"Apr. 6, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1140"},"text":"136 Stat. 1140","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
