{"tag":"section","attrib":{"id":"idb971128a-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692"},"text":null,"children":[{"tag":"num","attrib":{"value":"3692"},"text":"§ 3692.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance targets and transparency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb971128b-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Performance Targets","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each year, to ensure that mail service for postal customers meets the service standards for market-dominant products, established under section 3691, the Postal Service shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb971128c-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 60 days after the beginning of the fiscal year in which they will apply, establish and provide to the Postal Regulatory Commission reasonable targets for performance for each product; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb971128d-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the previous fiscal year’s performance targets in its Annual Compliance Report to the Postal Regulatory Commission for evaluation of compliance for each product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb971128e-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Postal Regulatory Commission Determination of Certain Performance Information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after first receiving the performance targets under subsection (a)(1), the Postal Regulatory Commission shall provide to the Postal Service—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb971128f-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" requirements for the Postal Service to publish nationwide, regional, and local delivery area performance information in accordance with subsection (c)(2) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9711290-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with the organizational structure of the delivery network of the Postal Service (including at the District and Area organizational levels, or the functional equivalents, and, to the extent practicable, at the U.S. ZIP Code Area level);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9711291-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflect the most granular geographic level of performance information appropriate for the Postal Service to publish; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9711292-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes time period segments for the published geographic levels to satisfy the publishing requirements of subparagraphs (A) and (C) of subsection (c)(2); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9711293-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for any modifications to the Postal Service’s measurement systems necessary to measure and publish the performance information under subsection (c)(2) that the Postal Regulatory Commission deems relevant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9711294-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Performance Dashboard.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9711295-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Postal Service shall develop and maintain a publicly available Website with an interactive web-tool that provides performance information for market-dominant products that is updated on a weekly basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9711296-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Performance information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The performance information provided for a market-dominant product on the Website shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9711297-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of market-dominant product;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9711298-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performance information for different geographic areas, consistent with subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9711299-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performance information for different time periods, including annual, quarterly, monthly, and weekly segments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb971129a-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comparisons of performance information for market-dominant products to performance information for previous time periods to facilitate identification of performance trends; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb971129b-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the performance targets then in effect, and the performance targets for the previous fiscal year, as established under subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb971129c-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Comprehensibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Website shall include plain language descriptions of the elements required under paragraph (2) and information on the collection process, measurement methodology, completeness, accuracy, and validity of the performance information provided on the Website.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb971129d-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Address search functionality","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Website shall include functionality to enable a user to search for performance information by street address, ZIP Code, or post office box.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb971129e-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Format","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Postal Service shall make the performance information provided on the Website available—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb973829f-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in a manner that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb97382a0-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" presents the information required under paragraph (2) on an interactive dashboard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb97382a1-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is searchable and may be sorted and filtered by the elements described in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb97382a2-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the extent practicable, enables any person or entity to download in bulk—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb97382a3-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c/5/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such performance information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb97382a4-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c/5/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of a search by the elements described in paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb97382a5-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under an “open license” which has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3502"},"text":"section 3502 of title 44","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb97382a6-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as an “open Government data asset” and in a “machine-readable” format which have the meaning given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3502"},"text":"section 3502 of title 44","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97382a7-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Postal Service shall regularly consult with the Postal Regulatory Commission on appropriate features and information to be included on the Website.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97382a8-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public input","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Postal Service shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb97382a9-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solicit public input on the design and implementation of the Website; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb97382aa-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain a public feedback tool to ensure each feature of, and the information on, the Website is usable and understandable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97382ab-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Postal Service shall implement and make available to the public (and make any subsequent changes in accordance with subsection (b)) the Website not later than 60 days from the date on which the Postal Service receives the requirements and recommendations from the Postal Regulatory Commission under subsection (b), and shall continuously update such information on the Website as required by subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97382ac-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A link and plain language description of the Website shall be made available on any webpage where performance targets and measurements established under subsection (a)(1) are made available to the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97382ad-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Postal Service, the Postmaster General, or the Board, as applicable, shall reference the dashboard described in paragraph (5)(A)(i) in the Annual Performance Plan under section 2803, the Annual Performance Report under section 2804, and the Annual Report under section 2402.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97382ae-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb97382af-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Performance information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “performance information” means the objective external performance measurements established under section 3691(b)(1)(D).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb97382b0-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3692/c/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Website","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Website” means the website described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb97382b1-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/108/tII/s201/a"},"text":"Pub. L. 117–108, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-04-06"},"text":"Apr. 6, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1144"},"text":"136 Stat. 1144","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
