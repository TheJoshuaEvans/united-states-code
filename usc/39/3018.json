{"tag":"section","attrib":{"id":"idb9652ae8-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018"},"text":null,"children":[{"tag":"num","attrib":{"value":"3018"},"text":"§ 3018.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hazardous material","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9652ae9-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Postal Service shall prescribe regulations for the safe transportation of hazardous material in the mail.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9652aea-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No person may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9652aeb-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mail or cause to be mailed hazardous material that has been declared by statute or Postal Service regulation to be nonmailable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652aec-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mail or cause to be mailed hazardous material in violation of any statute or Postal Service regulation restricting the time, place, or manner in which hazardous material may be mailed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652aed-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" manufacture, distribute, or sell any container, packaging kit, or similar device that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9652aee-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is represented, marked, certified, or sold by such person for use in the mailing of hazardous material; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9652aef-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to conform with any statute or Postal Service regulation setting forth standards for a container, packaging kit, or similar device used for the mailing of hazardous material.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9652af0-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Penalty; Clean-Up Costs and Damages.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9652af1-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person who knowingly violates this section or a regulation prescribed under this section shall be liable for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9652af2-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a civil penalty of at least $250, but not more than $100,000, for each violation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9652af3-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of any clean-up associated with each violation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9652af4-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" damages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652af5-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Knowing action","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person acts knowingly for purposes of paragraph (1) when—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9652af6-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person has actual knowledge of the facts giving rise to the violation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9652af7-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reasonable person acting in the circumstances and exercising reasonable care would have had that knowledge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652af8-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Separate violations.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9652af9-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Violations over time","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A separate violation under this subsection occurs for each day hazardous material, mailed or caused to be mailed in noncompliance with this section, is in the mail.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9652afa-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Separate items","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A separate violation under this subsection occurs for each item containing hazardous material that is mailed or caused to be mailed in noncompliance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9652afb-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hearings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Postal Service may determine that a person has violated this section or a regulation prescribed under this section only after notice and an opportunity for a hearing. Proceedings under this section shall be conducted in accordance with section 3001(m).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9652afc-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the amount of a civil penalty for a violation of this section, the Postal Service shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9652afd-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature, circumstances, extent, and gravity of the violation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652afe-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the person who committed the violation, the degree of culpability, any history of prior violations, the ability to pay, and any effect on the ability to continue in business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652aff-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact on Postal Service operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652b00-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other matters that justice requires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9652b01-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Actions to Collect.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9652b02-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In accordance with section 409(d), a civil action may be commenced in an appropriate district court of the United States to collect a civil penalty, clean-up costs, and damages assessed under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652b03-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compromise","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Postal Service may compromise the amount of a civil penalty, clean-up costs, and damages assessed under subsection (c) before commencing a civil action with respect to such civil penalty, clean-up costs, and damages under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9652b04-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Judicial Penalties.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9652b05-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At the request of the Postal Service, the Attorney General may bring a civil action in an appropriate district court of the United States to enforce this section or a regulation prescribed under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652b06-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relief","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The court in a civil action under paragraph (1) may award appropriate relief, including a temporary or permanent injunction, civil penalties as determined in accordance with this section, or punitive damages.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652b07-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A civil action under this subsection shall be in lieu of civil penalties for the same violation under subsection (c)(1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9652b08-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deposit of Amounts Collected.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9652b09-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Postal service fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided under paragraph (2), amounts collected under subsection (c)(1)(B) and (C) shall be deposited into the Postal Service Fund under section 2003.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652b0a-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3018/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treasury","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts collected under subsection (c)(1)(A) and any punitive damages collected under subsection (c)(1)(C) shall be deposited into the Treasury of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9652b0b-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435/tX/s1008/b"},"text":"Pub. L. 109–435, title X, § 1008(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3259"},"text":"120 Stat. 3259","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
