{"tag":"section","attrib":{"id":"idb95dff35-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2902"},"text":null,"children":[{"tag":"num","attrib":{"value":"2902"},"text":"§ 2902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb95dff36-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2902/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Postal Service—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95dff37-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2902/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall maintain adequate inventory controls and accountability systems for postal property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95dff38-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2902/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall develop current and future workforce projections so as to have the capacity to assess the needs of the Postal Service workforce regarding the use of property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95dff39-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2902/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may develop a 5-year management template that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95dff3a-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2902/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes goals and policies that will lead to the reduction of excess property and underutilized property in the inventory of the Postal Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95dff3b-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2902/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopts workplace practices, configurations, and management techniques that can achieve increased levels of productivity and decrease the need for real property assets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95dff3c-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2902/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assesses leased space to identify space that is not fully used or occupied;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95dff3d-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2902/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develops recommendations on how to address excess capacity at Postal Service facilities without negatively impacting mail delivery; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95dff3e-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2902/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develops recommendations on ensuring the security of mail processing operations; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95dff3f-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2902/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the Postal Service develops a template under paragraph (3) shall, as part of that template and on a regular basis—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95dff40-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2902/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct an inventory of postal property that is real property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95dff41-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2902/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" publish a report that covers each property identified under subparagraph (A), similar to the USPS Owned Facilities Report and the USPS Leased Facilities Report, that includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb95dff42-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2902/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the Postal Service first occupied the property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95dff43-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2902/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the size of the property in square footage and acreage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95dff44-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2902/a/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the geographical location of the property, including an address and description;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95dff45-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2902/a/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the property is being utilized;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95dff46-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2902/a/4/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual annual operating costs associated with the property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95dff47-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2902/a/4/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total cost of capital expenditures associated with the property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95dff48-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2902/a/4/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of postal employees, contractor employees, and functions housed at the property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95dff49-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2902/a/4/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the mission of the Postal Service is dependent on the property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95dff4a-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2902/a/4/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated amount of capital expenditures projected to maintain and operate the property over each of the next 5 years after the date of enactment of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95dff4b-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2902/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in subsection (a)(4)(B) shall be construed to require the Postal Service to obtain an appraisal of postal property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb960704c-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/318/s4/a"},"text":"Pub. L. 114–318, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1613"},"text":"130 Stat. 1613","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb960704d-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb960704e-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb960704f-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this chapter, referred to in subsec. (a)(4)(B)(ix), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/318"},"text":"Pub. L. 114–318","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
