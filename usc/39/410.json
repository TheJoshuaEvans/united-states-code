{"tag":"section","attrib":{"id":"idb94d5d83-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s410"},"text":null,"children":[{"tag":"num","attrib":{"value":"410"},"text":"§ 410.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of other laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb94d5d84-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s410/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided by subsection (b) of this section, and except as otherwise provided in this title or insofar as such laws remain in force as rules or regulations of the Postal Service, no Federal law dealing with public or Federal contracts, property, works, officers, employees, budgets, or funds, including the provisions of chapters 5 and 7 of title 5, shall apply to the exercise of the powers of the Postal Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb94d5d85-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s410/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following provisions shall apply to the Postal Service:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb94d5d86-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s410/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 552 (public information), section 552a (records about individuals), section 552b (open meetings), section 3102 (employment of personal assistants for blind, deaf, or otherwise handicapped employees), section 3110 (restrictions on employment of relatives), section 3333 and chapters 72 (antidiscrimination; right to petition Congress) and 73 (suitability, security, and conduct of employees), section 5520 (withholding city income or employment taxes), and section 5532 ","children":[{"tag":"ref","attrib":{"idref":"fn002000"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002000"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" (dual pay) of title 5, except that no regulation issued under such chapters or section shall apply to the Postal Service unless expressly made applicable;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94d5d87-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s410/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all provisions of title 18 dealing with the Postal Service, the mails, and officers or employees of the Government of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94d5d88-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s410/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s107"},"text":"section 107 of title 20","children":[],"tail":" (known as the Randolph-Sheppard Act, relating to vending machines operated by the blind);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94d5d89-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s410/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the following provisions of title 40:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb94d5d8a-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s410/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 3114–3116, 3118, 3131, 3133, and 3141–3147; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb94d5d8b-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s410/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapters 37 and 173;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94d5d8c-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s410/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapters 65 and 67 of title 41;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94d5d8d-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s410/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 2000d, 2000d–1—2000d–4 of title 42 (title VI, the Civil Rights Act of 1964);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94d5d8e-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s410/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 19 of the Occupational Safety and Health Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s668"},"text":"29 U.S.C. 668","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94d5d8f-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s410/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of the Act of ","children":[{"tag":"date","attrib":{"date":"1968-08-12"},"text":"August 12, 1968","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4151–415"},"text":"42 U.S.C. 4151–415","children":[],"tail":"6);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94d5d90-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s410/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 39 of title 31;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94d5d91-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s410/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 4 of title 5; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94d5d92-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s410/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5520a"},"text":"section 5520a of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb94d5d93-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s410/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subsection (b)(1) of this section shall not require the disclosure of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb94d5d94-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s410/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name or address, past or present, of any postal patron;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94d5d95-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s410/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information of a commercial nature, including trade secrets, whether or not obtained from a person outside the Postal Service, which under good business practice would not be publicly disclosed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94d5d96-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s410/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information prepared for use in connection with the negotiation of collective-bargaining agreements under chapter 12 of this title or minutes of, or notes kept during, negotiating sessions conducted under such chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94d5d97-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s410/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information prepared for use in connection with proceedings under chapter 36 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94d5d98-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s410/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reports and memoranda of consultants or independent contractors except to the extent that they would be required to be disclosed if prepared within the Postal Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94d5d99-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s410/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigatory files, whether or not considered closed, compiled for law enforcement purposes except to the extent available by law to a party other than the Postal Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb94d5d9a-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s410/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb94d5d9b-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s410/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A lease agreement by the Postal Service for rent of net interior space in excess of 6,500 square feet in any building or facility, or part of a building or facility, to be occupied for purposes of the Postal Service shall include a provision that all laborers and mechanics employed in the construction, modification, alteration, repair, painting, decoration, or other improvement of the building or space covered by the agreement, or improvement at the site of such building or facility, shall be paid wages at not less than those prevailing for similar work in the locality as determined by the Secretary of Labor under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3142"},"text":"section 3142 of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94d5d9c-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s410/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority and functions of the Secretary of Labor with respect to labor standards enforcement under Reorganization Plan numbered 14 of 1950 (title 5, appendix), and regulations for contractors and subcontractors under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3145"},"text":"section 3145 of title 40","children":[],"tail":", shall apply to the work under paragraph (1) of this subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94d5d9d-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s410/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (2) of this subsection shall not be construed to give the Secretary of Labor authority to direct the cancellation of the lease agreement referred to in paragraph (1) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb94d5d9e-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/725"},"text":"84 Stat. 725","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/656/s8/a"},"text":"Pub. L. 91–656, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-08"},"text":"Jan. 8, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1955"},"text":"84 Stat. 1955","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/340/s2"},"text":"Pub. L. 93–340, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-07-10"},"text":"July 10, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/294"},"text":"88 Stat. 294","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/82/tI/s101"},"text":"Pub. L. 94–82, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-08-09"},"text":"Aug. 9, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/419"},"text":"89 Stat. 419","children":[],"tail":"; "},{"tag":"ref","attrib"