ail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3850"},"text":"124 Stat. 3850","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/63"},"text":"Pub. L. 117–286, § 4(b)(63)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4350"},"text":"136 Stat. 4350","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb94d5d9f-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb94d5da0-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb94d5da1-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5532"},"text":"Section 5532 of title 5","children":[],"tail":", referred to in subsec. (b)(1), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVI/s651/a/1"},"text":"Pub. L. 106–65, div. A, title VI, § 651(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/664"},"text":"113 Stat. 664","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s107"},"text":"Section 107 of title 20","children":[],"tail":", known as the Randolph-Sheppard Act, referred to in subsec. (b)(3), is section 1 of "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-20/ch638"},"text":"act June 20, 1936, ch. 638","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1559"},"text":"49 Stat. 1559","children":[],"tail":". The act of "},{"tag":"date","attrib":{"date":"1936-06-20"},"text":"June 20, 1936","children":[],"tail":", known as the Randolph-Sheppard Act and also popularly known as the Randolph-Sheppard Vending Stand Act, is classified generally to chapter 6A (§ 107 et seq.) of Title 20, Education. For complete classification of this Act to the Code, see Short Title notes set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s107"},"text":"section 107 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Civil Rights Act of 1964, referred to in subsec. (b)(6), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/352"},"text":"Pub. L. 88–352","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-02"},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/241"},"text":"78 Stat. 241","children":[],"tail":". Title VI of the Civil Rights Act of 1964 is classified generally to subchapter V (§ 2000d et seq.) of chapter 21 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000a"},"text":"section 2000a of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 19 of the Occupational Safety and Health Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s668"},"text":"29 U.S.C. 668","children":[],"tail":"), referred to in subsec. (b)(7), is "},{"tag":"ref","attrib":{"href":"/us/pl/91/596/s19"},"text":"section 19 of Pub. L. 91–596","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-29"},"text":"Dec. 29, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1609"},"text":"84 Stat. 1609","children":[],"tail":", which enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s668"},"text":"section 668 of Title 29","children":[],"tail":", Labor, and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s7902"},"text":"section 7902 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provisions of the Act of ","children":[{"tag":"date","attrib":{"date":"1968-08-12"},"text":"August 12, 1968","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4151–415"},"text":"42 U.S.C. 4151–415","children":[],"tail":"6), referred to in subsec. (b)(8), probably means "},{"tag":"ref","attrib":{"href":"/us/pl/90/480"},"text":"Pub. L. 90–480","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-12"},"text":"Aug. 12, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/718"},"text":"82 Stat. 718","children":[],"tail":", as amended, popularly known as the Architectural Barriers Act of 1968, which is classified generally to chapter 51 (§ 4151 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4151"},"text":"section 4151 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reorganization Plan numbered 14 of 1950 (title 5, appendix), referred to in subsec. (d)(2), is Reorg. Plan No. 14 of 1950, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3176, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1267"},"text":"64 Stat. 1267","children":[],"tail":", which is set out in the Appendix to Title 5."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb94d5da2-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","