{"tag":"section","attrib":{"id":"idb95944c1-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2003"},"text":null,"children":[{"tag":"num","attrib":{"value":"2003"},"text":"§ 2003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" The Postal Service Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb95944c2-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2003/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established in the Treasury of the United States a revolving fund to be called the Postal Service Fund which shall be available to the Postal Service without fiscal-year limitation to carry out the purposes, functions, and powers authorized by this title (other than any of the purposes, functions, or powers for which the Competitive Products Fund is available).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95944c3-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2003/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as otherwise provided in section 2011, there shall be deposited in the Fund, subject to withdrawal by check by the Postal Service—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95944c4-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2003/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revenues from postal and nonpostal services rendered by the Postal Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95944c5-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2003/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts received from obligations issued by the Postal Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95944c6-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2003/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts appropriated for the use of the Postal Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95944c7-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2003/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest which may be earned on investments of the Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95944c8-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2003/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other receipts of the Postal Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95944c9-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2003/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the balance in the Post Office Department Fund established under former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s2202"},"text":"section 2202 of title 39","children":[],"tail":" as of the commencement of operations of the Postal Service;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95944ca-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2003/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts (including proceeds from the sale of forfeited items) from any civil forfeiture conducted by the Postal Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95944cb-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2003/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any transfers from the Secretary of the Treasury from the Department of the Treasury Forfeiture Fund which shall be available to the Postmaster General only for Federal law enforcement related purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95944cc-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2003/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amounts collected under section 3018.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95944cd-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2003/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Postal Service determines that the moneys of the Fund are in excess of current needs, it may request the investment of such amounts as it deems advisable by the Secretary of the Treasury in obligations of, or obligations guaranteed by, the Government of the United States, and, with the approval of the Secretary, in such other obligations or securities as it deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95944ce-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2003/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With the approval of the Secretary of the Treasury, the Postal Service may deposit moneys of the Fund in any Federal Reserve bank, any depository for public funds, or in such other places and in such manner as the Postal Service and the Secretary may mutually agree.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95944cf-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2003/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95944d0-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2003/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Fund shall be available for the payment of (A) all expenses incurred by the Postal Service in carrying out its functions as provided by law, subject to the same limitation as set forth in the parenthetical matter under subsection (a); (B) all expenses of the Postal Regulatory Commission, pursuant to section 504(d); and (C) all expenses of the Office of Inspector General, subject to the availability of amounts appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s415/f"},"text":"section 415(f) of title 5","children":[],"tail":". The Postmaster General shall transfer from the Fund to the Secretary of the Treasury for deposit in the Department of the Treasury Forfeiture Fund amounts appropriate to reflect the degree of participation of Department of the Treasury law enforcement organizations (described in "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s9705/n"},"text":"section 9705(n) of title 31","children":[],"tail":") in the law enforcement effort resulting in the forfeiture pursuant to laws enforced or administered by the Postal Service. Neither the Fund nor any of the funds credited to it shall be subject to apportionment under the provisions of subchapter II of chapter 15 of title 31."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95944d1-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2003/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds appropriated to the Postal Service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s2401"},"text":"section 2401 of this title","children":[],"tail":" shall be apportioned as provided in this paragraph. From the total amounts appropriated to the Postal Service for any fiscal year under the authorizations contained in "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s2401"},"text":"section 2401 of this title","children":[],"tail":", the Secretary of the Treasury shall make available to the Postal Service 25 percent of such amount at the beginning of each quarter of such fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95944d2-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2003/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of this section, any amounts appropriated to the Postal Service under subsection (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s2401"},"text":"section 2401 of this title","children":[],"tail":" and deposited into the Fund shall be expended by the Postal Service only for the purposes provided in such subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95944d3-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2003/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any provision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8147"},"text":"section 8147 of title 5","children":[],"tail":", whenever the Secretary of Labor furnishes a statement to the Postal Service indicating an amount due from the Postal Service under subsection (b) of that section, the Postal Service shall make the deposit required pursuant to that statement (and any additional payment under subsection (c) of that section, to the extent that it relates to the period covered by such statement) not later than 30 days after the date on which such statement is so furnished. Any deposit (and any additional payment) which is subject to the preceding sentence shall, once made, remain available without fiscal year limitation."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95944d4-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2003/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Liabilities of the former Post Office Department to the Employees’ Compensation Fund (appropriations for which were authorized by former section 2004, as in effect before the effective date of this subsection) shall be liabilities of the Postal Service payable out of the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb95944d5-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/739"},"text":"84 Stat. 739","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/421/s2/c"},"text":"Pub. L. 94–421, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-24"},"text":"Sept. 24, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1304"},"text":"90 Stat. 1304","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXVII/s1725"},"text":"Pub. L. 97–35, title XVII, § 1725","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/760"},"text":"95 Stat. 760","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s3"},"text":"Pub. L. 97–258, § 3","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1), "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1066"},"text":"96 Stat. 1066","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/m/tII/s201/b"},"text":"Pub. L. 99–500, § 101(m) [title II, § 201(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-308"},"text":"100 Stat. 1783–308","children":[],"tail":", 1783–314, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/m/tII/s201/b"},"text":"Pub. L. 99–591, § 101(m) [title II, § 201(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-308"},"text":"100 Stat. 3341–308","children":[],"tail":", 3341–314; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6252"},"text":"Pub. L. 100–690, title VI, § 6252","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4362"},"text":"102 Stat. 4362","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tIV/s4004/a"},"text":"Pub. L. 101–239, title IV, § 4004(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2135"},"text":"103 Stat. 2135","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/393/tVI/s638/g"},"text":"Pub. L. 102–393, title VI, § 638(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1790"},"text":"106 Stat. 1790","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tVII/s7003/a/2/B"},"text":"Pub. L. 105–33, title VII, § 7003(a)(2)(B)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/663"},"text":"111 Stat. 663","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/435/tIV/s401/b/3"},"text":"Pub. L. 109–435, title IV, § 401(b)(3)","children":[],"tail":", title VI, § 603(c)(2), title X, § 1008(c)(1), "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3225"},"text":"120 Stat. 3225","children":[],"tail":", 3241, 3260; "},{"tag":"ref","attrib":{"href":"/us/pl/114/22/tI/s105/c/2/A/iii"},"text":"Pub. L. 114–22, title I, § 105(c)(2)(A)(iii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-05-29"},"text":"May 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/237"},"text":"129 Stat. 237","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/108/tII/s205/b/1"},"text":"Pub. L. 117–108, title II, § 205(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-04-06"},"text":"Apr. 6, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1148"},"text":"136 Stat. 1148","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/66"},"text":"Pub. L. 117–286, § 4(b)(66)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4350"},"text":"136 Stat. 4350","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7207/d/3"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7207(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1693"},"text":"139 Stat. 1693","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb95944d6-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb95944d7-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb95944d8-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s2202"},"text":"section 2202 of title 39","children":[],"tail":", referred to in subsec. (a)(6), means section 2202 of former Title 39, The Postal Service, prior to the general revision and reenactment of Title 39 by "},{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/719"},"text":"84 Stat. 719","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 2004, as in effect before the effective date of this subsection, referred to in subsec. (h), means ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s2004"},"text":"section 2004 of this title","children":[],"tail":", as in effect before "},{"tag":"date","attrib":{"date":"1997-10-01"},"text":"Oct. 1, 1997","children":[],"tail":". Section 2004 was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tVII/s7003/a/1"},"text":"Pub. L. 105–33, title VII, § 7003(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/663"},"text":"111 Stat. 663","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb95944d9-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":" is a corrected version of "},{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb95944da-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “9705(n)” for “9705("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s415/f"},"text":"section 415(f) of title 5","children":[],"tail":".” for “section 8G(f) of the Inspector General Act of 1978.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/108"},"text":"Pub. L. 117–108","children":[],"tail":", which directed amendment of subsec. (e) by substituting “(B) all expenses of the Postal Regulatory Commission, pursuant to section 504(d);” for “(B) all expenses of the Postal Regulatory Commission, subject to the availability of amounts appropriated under section 504(d);”, was executed to subsec. (e)(1) to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22"},"text":"Pub. L. 114–22","children":[],"tail":" substituted “section 9705("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")” for “section 9703(p)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435/s401/b/3/A"},"text":"Pub. L. 109–435, § 401(b)(3)(A)","children":[],"tail":", substituted “title (other than any of the purposes, functions, or powers for which the Competitive Products Fund is available)” for “title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435/s401/b/3/B"},"text":"Pub. L. 109–435, § 401(b)(3)(B)","children":[],"tail":", substituted “Except as otherwise provided in section 2011, there” for “There”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435/s1008/c/1"},"text":"Pub. L. 109–435, § 1008(c)(1)","children":[],"tail":", added par. (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435/s603/c/2"},"text":"Pub. L. 109–435, § 603(c)(2)","children":[],"tail":", substituted “The Fund shall be available for the payment of (A) all expenses incurred by the Postal Service in carrying out its functions as provided by law, subject to the same limitation as set forth in the parenthetical matter under subsection (a); (B) all expenses of the Postal Regulatory Commission, subject to the availability of amounts appropriated under section 504(d); and (C) all expenses of the Office of Inspector General, subject to the availability of amounts appropriated under section 8G(f) of the Inspector General Act of 1978.” for “The Fund shall be available for the payment of all expenses incurred by the Postal Service in carrying out its functions as provided by law and, subject to the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s3604"},"text":"section 3604 of this title","children":[],"tail":", all of the expenses of the Postal Rate Commission.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s7003/a/2/B"},"text":"Pub. L. 105–33, § 7003(a)(2)(B)","children":[],"tail":", substituted “section 2401” for “sections 2401 and 2004” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s7003/b"},"text":"Pub. L. 105–33, § 7003(b)","children":[],"tail":", added subsec. (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/393/s638/g/1"},"text":"Pub. L. 102–393, § 638(g)(1)","children":[],"tail":", added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/393/s638/g/2"},"text":"Pub. L. 102–393, § 638(g)(2)","children":[],"tail":", inserted after first sentence “The Postmaster General shall transfer from the Fund to the Secretary of the Treasury for deposit in the Department of the Treasury Forfeiture Fund amounts appropriate to reflect the degree of participation of Department of the Treasury law enforcement organizations (described in "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s9703/p"},"text":"section 9703(p) of title 31","children":[],"tail":") in the law enforcement effort resulting in the forfeiture pursuant to laws enforced or administered by the Postal Service.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" struck out “administrative” after “civil” and “under title 18” after “Service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/m/tII/s201/b/1"},"text":"Pub. L. 99–591, § 101(m) [title II, § 201(b)(1)–(3)]","children":[],"tail":", added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/m/tII/s201/b/4"},"text":"Pub. L. 99–591, § 101(m) [title II, § 201(b)(4)]","children":[],"tail":", substituted “as provided by law” for “under this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":" substituted “subchapter II of chapter 15 of title 31” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t31/s665"},"text":"section 665 of title 31","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" redesignated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/421"},"text":"Pub. L. 94–421","children":[],"tail":" added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb95944db-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb95944dc-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment; Savings Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435/s603/c/2"},"text":"section 603(c)(2) of Pub. L. 109–435","children":[],"tail":" applicable with respect to fiscal years beginning on or after "},{"tag":"date","attrib":{"date":"2008-10-01"},"text":"Oct. 1, 2008","children":[],"tail":", subject to savings provisions, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/435/s603/d"},"text":"section 603(d) of Pub. L. 109–435","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s504"},"text":"section 504 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb95944dd-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/tVII/s7003/c"},"text":"Pub. L. 105–33, title VII, § 7003(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/663"},"text":"111 Stat. 663","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/33/tVII/s7003/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section [amending this section and repealing ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s2004"},"text":"section 2004 of this title","children":[],"tail":"] and the amendments made by this section shall take effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":"] or "},{"tag":"date","attrib":{"date":"1997-10-01"},"text":"October 1, 1997","children":[],"tail":", whichever is later."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provisions relating to payments for fiscal year 1998.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amounts not yet paid","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No payment may be made to the Postal Service Fund, on or after the date of the enactment of this Act, pursuant to any appropriation for fiscal year 1998 authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s2004"},"text":"section 2004 of title 39","children":[],"tail":", United States Code (as in effect before the effective date of this section)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amounts paid","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If any payment to the Postal Service Fund is or has been made pursuant to an appropriation for fiscal year 1998 authorized by such section 2004, then, an amount equal to the amount of such payment shall be paid from such Fund into the Treasury as miscellaneous receipts before ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"October 1, 1998","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb95b8dce-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tIV/s4004/b"},"text":"Pub. L. 101–239, title IV, § 4004(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2135"},"text":"103 Stat. 2135","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/239/tIV/s4004/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1989-10-01"},"text":"October 1, 1989","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb95b8dcf-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXVII/s1727"},"text":"Pub. L. 97–35, title XVII, § 1727","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/761"},"text":"95 Stat. 761","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/35/tXVII/s1727"},"text":"“The provisions of this subtitle [subtitle B (§§ 1721–1727) of title XVII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":", amending this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s2401"},"text":"section 2401 of this title","children":[],"tail":" and enacting provisions set out as notes under sections 403, 2004, and 2401 of this title] (other than section 1726 and this section) shall take effect on "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"October 1, 1981","children":[],"tail":". The provisions of sections 1726 [enacting a provision set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s403"},"text":"section 403 of this title","children":[],"tail":"] and this section [enacting this provision] shall take effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb95b8dd0-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1971-07-01"},"text":"July 1, 1971","children":[],"tail":", pursuant to Resolution No. 71–9 of the Board of Governors. See "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb95b8dd1-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Contributions by United States Postal Service to Civil Service Retirement and Disability Fund","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tVI/s6002"},"text":"Pub. L. 100–203, title VI, § 6002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-276"},"text":"101 Stat. 1330–276","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/203/tVI/s6002"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Postal Service Escrow Fund","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established as a separate account in the United States Treasury, the ‘Postal Service Escrow Fund’. Such Fund shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have such amounts described under subsection (b)(2) deposited no later than ","children":[{"tag":"date","attrib":{"date":"1988-10-31"},"text":"October 31, 1988","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not be available for expenditures of any amounts therein during the existence of such Fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cease to exist on ","children":[{"tag":"date","attrib":{"date":"1989-10-01"},"text":"October 1, 1989","children":[],"tail":", and on such date all amounts deposited in such Fund under subsection (b)(2) shall be deposited in the Postal Service Fund established under "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s2003"},"text":"section 2003 of title 39","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deposit of Certain Savings in Certain Funds.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fiscal year 1988","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"From all funds available to the United States Postal Service in fiscal year 1988, the Postal Service shall deposit into the Civil Service Retirement and Disability Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8348"},"text":"section 8348 of title 5","children":[],"tail":", United States Code, an amount of $350,000,000 in fiscal year 1988, in addition to any amount deposited pursuant to subsection (h) of such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fiscal year 1989","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"From all funds available to the United States Postal Service in fiscal year 1989, the Postal Service shall deposit into the Postal Service Escrow Fund an amount of $465,000,000 no later than ","children":[{"tag":"date","attrib":{"date":"1988-10-31"},"text":"October 31, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Capital Limitations for Fiscal Years","children":[],"tail":" 1988 "},{"tag":"inline","attrib":{},"text":"and","children":[],"tail":" 1989.—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The United States Postal Service may not make any commitment or obligation to expend any monies deposited in the Postal Service Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s2003"},"text":"section 2003 of title 39","children":[],"tail":", United States Code, for the capital investment program—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in excess of $625,000,000 in fiscal year 1988; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in excess of $1,995,000,000 in fiscal year 1989.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Capital investment programs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purposes of paragraph (1) the term ‘capital investment program’ shall include all investments in long-term assets and capital investment expenditures (including direct and indirect costs associated with such investments and expenditures, such as obligations through contracts).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
