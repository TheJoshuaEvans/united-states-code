{"tag":"section","attrib":{"id":"idb969e606-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3219"},"text":null,"children":[{"tag":"num","attrib":{"value":"3219"},"text":"§ 3219.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mailgrams","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any Mailgram sent by the Vice President, a Member of or Member-elect to Congress, the Secretary of the Senate, the Sergeant at Arms of the Senate, an elected officer of the House of Representatives (other than a Member of the House), the Legislative Counsel of the House of Representatives or the Senate, the Law Revision Counsel of the House of Representatives, or the Senate Legal Counsel, and then delivered by the Postal Service, shall be considered as franked mail, subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3216/a/2"},"text":"section 3216(a)(2) of this title","children":[],"tail":", if such Mailgram contains matter of the kind authorized to be sent by that official as franked mail under "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s3210"},"text":"section 3210 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb969e607-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/191/s12/a"},"text":"Pub. L. 93–191, § 12(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-18"},"text":"Dec. 18, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/746"},"text":"87 Stat. 746","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/521/tVII/s714/c"},"text":"Pub. L. 95–521, title VII, § 714(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-26"},"text":"Oct. 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1884"},"text":"92 Stat. 1884","children":[],"tail":"; "},{"tag":"ref