{"tag":"section","attrib":{"id":"idb96ea1ab-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3651"},"text":null,"children":[{"tag":"num","attrib":{"value":"3651"},"text":"§ 3651.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports by the Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb96ea1ac-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3651/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Postal Regulatory Commission shall submit an annual report to the President and the Congress concerning the operations of the Commission under this title, including the extent to which regulations are achieving the objectives under sections 3622 and 3633, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96ea1ad-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3651/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Information.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96ea1ae-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3651/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the information required under subsection (a), each report under this section shall also include, with respect to the period covered by such report, an estimate of the costs incurred by the Postal Service in providing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb96ea1af-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3651/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" postal services to areas of the Nation where, in the judgment of the Postal Regulatory Commission, the Postal Service either would not provide services at all or would not provide such services in accordance with the requirements of this title if the Postal Service were not required to provide prompt, reliable, and efficient services to patrons in all areas and all communities, including as required under the first sentence of section 101(b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96ea1b0-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3651/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" free or reduced rates for postal services as required by this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96ea1b1-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3651/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other public services or activities which, in the judgment of the Postal Regulatory Commission, would not otherwise have been provided by the Postal Service but for the requirements of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96ea1b2-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3651/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Basis for estimates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission shall detail the basis for its estimates and the statutory requirements giving rise to the costs identified in each report under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96ea1b3-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3651/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information From Postal Service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Postal Service shall provide the Postal Regulatory Commission with such information as may, in the judgment of the Commission, be necessary in order for the Commission to prepare its reports under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb96ea1b4-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435/tII/s204/b"},"text":"Pub. L. 109–435, title II, § 204(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3211"},"text":"120 Stat. 3211","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
