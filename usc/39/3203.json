{"tag":"section","attrib":{"id":"idb9652b36-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3203"},"text":null,"children":[{"tag":"num","attrib":{"value":"3203"},"text":"§ 3203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Endorsements on penalty covers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9652b37-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in this section, penalty covers shall bear, over the words “Official Business” an endorsement showing the name of the department, bureau, or office from which, or officer from whom, it is transmitted. The penalty for the unlawful use of all penalty covers shall be printed thereon.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9652b38-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Postal Service shall prescribe the endorsement to be placed on covers mailed under clauses (1)(E), (2), and (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3202/a"},"text":"section 3202(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9652b39-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/752"},"text":"84 Stat. 752","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9652b3a-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9652b3b-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9652b3c-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1971-07-01"},"text":"July 1, 1971","children":[],"tail":", pursuant to Resolution No. 71–9 of the Board of Governors. See "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
