{"tag":"section","attrib":{"id":"idb95dff27-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2805"},"text":null,"children":[{"tag":"num","attrib":{"value":"2805"},"text":"§ 2805.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inherently Governmental functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The functions and activities of this chapter shall be considered to be inherently Governmental functions. The drafting of strategic plans, performance plans, and program performance reports under this section shall be performed only by employees of the Postal Service.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb95dff28-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/62/s7"},"text":"Pub. L. 103–62, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-03"},"text":"Aug. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/294"},"text":"107 Stat. 294","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
