{"tag":"section","attrib":{"id":"idb9652b3d-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3204"},"text":null,"children":[{"tag":"num","attrib":{"value":"3204"},"text":"§ 3204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on use of penalty mail","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9652b3e-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3204/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as otherwise provided in this section or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3220/a"},"text":"section 3220(a) of this title","children":[],"tail":", an officer, executive department, or independent establishment of the Government of the United States may not mail, as penalty mail, any article or document unless—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9652b3f-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3204/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a request therefor has been previously received by the department or establishment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652b40-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3204/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its mailings is required by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9652b41-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3204/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subsection (a) of this section does not prohibit the mailing, as penalty mail, by an officer, executive department, or independent agency of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9652b42-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3204/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enclosures reasonably related to the subject matter of official correspondence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652b43-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3204/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" informational releases relating to the census of the United States and authorized by title 13;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652b44-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3204/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" matter concerning the sale of Government securities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652b45-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3204/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forms, blanks, and copies of statutes, rules, regulations, instructions, administrative orders, and interpretations necessary in the administration of the department or establishment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652b46-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3204/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agricultural bulletins;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":