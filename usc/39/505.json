{"tag":"section","attrib":{"id":"idb9521847-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s505"},"text":null,"children":[{"tag":"num","attrib":{"value":"505"},"text":"§ 505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officer of the Postal Regulatory Commission representing the general public","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Postal Regulatory Commission shall designate an officer of the Postal Regulatory Commission in all public proceedings (such as developing rules, regulations, and procedures) who shall represent the interests of the general public.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9521848-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435/tVI/s601/a/4"},"text":"Pub. L. 109–435, title VI, § 601(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3239"},"text":"120 Stat. 3239","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
