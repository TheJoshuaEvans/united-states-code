{"tag":"section","attrib":{"id":"idb959446b-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s1206"},"text":null,"children":[{"tag":"num","attrib":{"value":"1206"},"text":"§ 1206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collective-bargaining agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb959446c-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s1206/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Collective-bargaining agreements between the Postal Service and bargaining representatives recognized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s1203"},"text":"section 1203 of this title","children":[],"tail":" shall be effective for not less than 2 years."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb959446d-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s1206/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Collective-bargaining agreements between the Postal Service and bargaining representatives recognized under section 1203 may include any procedures for resolution by the parties of grievances and adverse actions arising under the agreement, including procedures culminating in binding third-party arbitration, or the parties may adopt any such procedures by mutual agreement in the event of a dispute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb959446e-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s1206/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Postal Service and bargaining representatives recognized under section 1203 may by mutual agreement adopt procedures for the resolution of disputes or impasses arising in the negotiation of a collective-bargaining agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb959446f-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/735"},"text":"84 Stat. 735","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9594470-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9594471-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9594472-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1971-07-01"},"text":"July 1, 1971","children":[],"tail":", pursuant to Resolution No. 71–9 of the Board of Governors. See "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb9594473-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Use of Funds for Restructuring of Employee Compensation Practices","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/396/tIII/s303"},"text":"Pub. L. 98–396, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-22"},"text":"Aug. 22, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1422"},"text":"98 Stat. 1422","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/396/tIII/s303"},"text":"“None of the funds made available to the United States Postal Service under this Act [see Tables for classification] or any other Act may be used to restructure employee compensation practices as in effect under the most recently effective collective bargaining agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s1206"},"text":"section 1206 of title 39","children":[],"tail":", United States Code, except in accordance with the results of procedures set forth in section 1207 of such title.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
