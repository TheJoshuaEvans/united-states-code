{"tag":"section","attrib":{"id":"idb969e64c-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3403"},"text":null,"children":[{"tag":"num","attrib":{"value":"3403"},"text":"§ 3403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matter for blind and other handicapped persons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb969e64d-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3403/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The matter described in subsection (b) of this section (other than matter mailed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3404"},"text":"section 3404 of this title","children":[],"tail":") may be mailed free of postage, if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb969e64e-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3403/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the matter is for the use of the blind or other persons who cannot use or read conventionally printed material because of a physical impairment and who are certified by competent authority as unable to read normal reading material in accordance with the provisions of sections 135a and 135b of title 2;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb969e64f-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3403/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no charge, or rental, subscription, or other fee, is required for such matter or a charge, or rental, subscription, or other fee is required for such matter not in excess of the cost thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb969e650-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3403/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the matter may be opened by the Postal Service for inspection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb969e651-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3403/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the matter contains no advertising.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb969e652-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3403/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The free mailing privilege provided by subsection (a) of this section is extended to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb969e653-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3403/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reading matter and musical scores;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb969e654-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3403/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sound reproductions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb969e655-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3403/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paper, records, tapes, and other material for the production of reading matter, musical scores, or sound reproductions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb969e656-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3403/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reproducers or parts thereof, for sound reproductions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb969e657-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3403/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" braille writers, typewriters, educational or other materials or devices, or parts thereof, used for writing by, or specifically designed or adapted for use of, a blind person or a person having a physical impairment as described in subsection (a)(1) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb969e658-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/757"},"text":"84 Stat. 757","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb969e659-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb969e65a-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb969e65b-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1971-07-01"},"text":"July 1, 1971","children":[],"tail":", pursuant to Resolution No. 71–9 of the Board of Governors. See "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
