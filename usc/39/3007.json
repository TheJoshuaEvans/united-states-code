{"tag":"section","attrib":{"id":"idb962ba0b-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3007"},"text":null,"children":[{"tag":"num","attrib":{"value":"3007"},"text":"§ 3007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detention of mail for temporary periods","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb962ba0c-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3007/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb962ba0d-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3007/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In preparation for or during the pendency of proceedings under section 3005, the Postal Service may, under the provisions of section 409(d), apply to the district court in any district in which mail is sent or received as part of the alleged scheme, device, lottery, gift enterprise, sweepstakes, skill contest, or facsimile check or in any district in which the defendant is found, for a temporary restraining order and preliminary injunction under the procedural requirements of rule 65 of the Federal Rules of Civil Procedure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb962ba0e-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3007/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb962ba0f-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3007/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Upon a proper showing, the court shall enter an order which shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb962ba10-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3007/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain in effect during the pendency of the statutory proceedings, any judicial review of such proceedings, or any action to enforce orders issued under the proceedings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb962ba11-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3007/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct the detention by the postmaster, in any and all districts, of the defendant’s incoming mail and outgoing mail, which is the subject of the proceedings under section 3005.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb962ba12-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3007/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A proper showing under this paragraph shall require proof of a likelihood of success on the merits of the proceedings under section 3005.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb962ba13-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3007/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Mail detained under paragraph (2) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb962ba14-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3007/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be made available at the post office of mailing or delivery for examination by the defendant in the presence of a postal employee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb962ba15-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3007/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be delivered as addressed if such mail is not clearly shown to be the subject of proceedings under section 3005.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb962ba16-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3007/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No finding of the defendant’s intent to make a false representation or to conduct a lottery is required to support the issuance of an order under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb962ba17-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3007/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If any order is issued under subsection (a) and the proceedings under section 3005 are concluded with the issuance of an order under that section, any judicial review of the matter shall be in the district in which the order under subsection (a) was issued.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb962ba18-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3007/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not apply to mail addressed to publishers of newspapers and other periodical publications entitled to a periodical publication rate or to mail addressed to the agents of those publishers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb962ba19-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/747"},"text":"84 Stat. 747","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/168/tI/s105/a"},"text":"Pub. L. 106–168, title I, § 105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-12"},"text":"Dec. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1810"},"text":"113 Stat. 1810","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb962ba1a-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb962ba1b-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb962ba1c-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Rule 65 of the Federal Rules of Civil Procedure, referred to in subsec. (a)(1), is set out in the Appendix to Title 28, Judiciary and Judicial Procedure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb962ba1d-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/168"},"text":"Pub. L. 106–168","children":[],"tail":" added subsecs. (a) and (b), struck out former subsec. (a) which provided for injunctive relief and other orders by the district court in which the defendant gets his mail, and redesignated former subsec. (b) as (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb962ba1e-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb962ba1f-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/168"},"text":"Pub. L. 106–168","children":[],"tail":" effective 120 days after "},{"tag":"date","attrib":{"date":"1999-12-12"},"text":"Dec. 12, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/168/s111"},"text":"section 111 of Pub. L. 106–168","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb962ba20-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1971-07-01"},"text":"July 1, 1971","children":[],"tail":", pursuant to Resolution No. 71–9 of the Board of Governors. See "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
