{"tag":"section","attrib":{"id":"idb9679bc5-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3211"},"text":null,"children":[{"tag":"num","attrib":{"value":"3211"},"text":"§ 3211.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public documents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Vice President, Members of Congress, the Secretary of the Senate, the Sergeant at Arms of the Senate, each of the elected officers of the House of Representatives (other than a Member of the House) during the 90-day period immediately following the expiration of their respective terms of office, may send and receive as franked mail all public documents printed by order of Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9679bc6-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/754"},"text":"84 Stat. 754","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/191/s2"},"text":"Pub. L. 93–191, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-18"},"text":"Dec. 18, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/741"},"text":"87 Stat. 741","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/69/s5/a"},"text":"Pub. L. 97–69, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-10-26"},"text":"Oct. 26, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1043"},"text":"95 Stat. 1043","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9679bc7-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialN