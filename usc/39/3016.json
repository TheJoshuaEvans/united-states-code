{"tag":"section","attrib":{"id":"idb9652a91-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3016"},"text":null,"children":[{"tag":"num","attrib":{"value":"3016"},"text":"§ 3016.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative subpoenas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9652a92-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3016/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subpoena Authority.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9652a93-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3016/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Investigations.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9652a94-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3016/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any investigation conducted under section 3005(a), the Postmaster General may require by subpoena the production of any records (including books, papers, documents, and other tangible things which constitute or contain evidence) which the Postmaster General considers relevant or material to such investigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9652a95-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3016/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Condition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No subpoena shall be issued under this paragraph except in accordance with procedures, established by the Postal Service, requiring that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9652a96-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3016/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a specific case, with an individual or entity identified as the subject, be opened before a subpoena is requested;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9652a97-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3016/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate supervisory and legal review of a subpoena request be performed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9652a98-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3016/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delegation of subpoena approval authority be limited to the Postal Service’s General Counsel or a Deputy General Counsel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652a99-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3016/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statutory proceedings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any statutory proceeding conducted under section 3005(a), the Judicial Officer may require by subpoena the attendance and testimony of witnesses and the production of any records (including books, papers, documents, and other tangible things which constitute or contain evidence) which the Judicial Officer considers relevant or material to such proceeding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652a9a-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3016/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in paragraph (2) shall be considered to apply in any circumstance to which paragraph (1) applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9652a9b-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3016/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9652a9c-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3016/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service within the united states","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A subpoena issued under this section may be served by a person designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3061"},"text":"section 3061 of title 18","children":[],"tail":" at any place within the territorial jurisdiction of any court of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652a9d-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3016/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any such subpoena may be served upon any person who is not to be found within the territorial jurisdiction of any court of the United States, in such manner as the Federal Rules of Civil Procedure prescribe for service in a foreign country. To the extent that the courts of the United States may assert jurisdiction over such person consistent with due process, the United States District Court for the District of Columbia shall have the same jurisdiction to take any action respecting compliance with this section by such person that such court would have if such person were personally within the jurisdiction of such court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652a9e-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3016/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service on business persons","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Service of any such subpoena may be made upon a partnership, corporation, association, or other legal entity by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9652a9f-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3016/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delivering a duly executed copy thereof to any partner, executive officer, managing agent, or general agent thereof, or to any agent thereof authorized by appointment or by law to receive service of process on behalf of such partnership, corporation, association, or entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9652aa0-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3016/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delivering a duly executed copy thereof to the principal office or place of business of the partnership, corporation, association, or entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9652aa1-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3016/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" depositing such copy in the United States mails, by registered or certified mail, return receipt requested, duly addressed to such partnership, corporation, association, or entity at its principal office or place of business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652aa2-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3016/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service on natural persons","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Service of any subpoena may be made upon any natural person by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9652aa3-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3016/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delivering a duly executed copy to the person to be served; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9652aa4-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3016/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" depositing such copy in the United States mails, by registered or certified mail, return receipt requested, duly addressed to such person at his residence or principal office or place of business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652aa5-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3016/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Verified return","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A verified return by the individual serving any such subpoena setting forth the manner of such service shall be proof of such service. In the case of service by registered or certified mail, such return shall be accompanied by the return post office receipt of delivery of such subpoena.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9652aa6-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3016/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enforcement.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9652aa7-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3016/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whenever any person, partnership, corporation, association, or entity fails to comply with any subpoena duly served upon him, the Postmaster General may request that the Attorney General seek enforcement of the subpoena in the district court of the United States for any judicial district in which such person resides, is found, or transacts business, and serve upon such person a petition for an order of such court for the enforcement of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652aa8-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3016/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whenever any petition is filed in any district court of the United States under this section, such court shall have jurisdiction to hear and determine the matter so presented, and to enter such order or orders as may be required to carry into effect the provisions of this section. Any final order entered shall be subject to appeal under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1291"},"text":"section 1291 of title 28","children":[],"tail":", United States Code. Any disobedience of any final order entered under this section by any court may be punished as contempt."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9652aa9-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3016/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disclosure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any documentary material provided pursuant to any subpoena issued under this section shall be exempt from disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9652aaa-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/168/tI/s107/a"},"text":"Pub. L. 106–168, title I, § 107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-12"},"text":"Dec. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1812"},"text":"113 Stat. 1812","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9652aab-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9652aac-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9652aad-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Civil Procedure, referred to in subsec. (b)(2), are set out in the Appendix to Title 28, Judiciary and Judicial Procedure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9652aae-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9652aaf-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 120 days after ","children":[{"tag":"date","attrib":{"date":"1999-12-12"},"text":"Dec. 12, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/168/s111"},"text":"section 111 of Pub. L. 106–168","children":[],"tail":", set out as an Effective Date of 1999 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb9652ab0-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/168/tI/s107/b"},"text":"Pub. L. 106–168, title I, § 107(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-12"},"text":"Dec. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1813"},"text":"113 Stat. 1813","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/168/tI/s107/b"},"text":"“Not later than 120 days after the date of the enactment of this section [","children":[{"tag":"date","attrib":{"date":"1999-12-12"},"text":"Dec. 12, 1999","children":[],"tail":"], the Postal Service shall promulgate regulations setting out the procedures the Postal Service will use to implement the amendment made by subsection (a) [enacting this section].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
