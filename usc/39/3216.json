{"tag":"section","attrib":{"id":"idb969e5e1-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3216"},"text":null,"children":[{"tag":"num","attrib":{"value":"3216"},"text":"§ 3216.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement for franked mailings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb969e5e2-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3216/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The equivalent of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb969e5e3-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3216/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" postage on, and fees and charges in connection with, mail matter sent through the mails—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb969e5e4-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3216/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the franking privilege (other than under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3219"},"text":"section 3219 of this title","children":[],"tail":"), by the Vice President, Members of and Members-elect to Congress, the Secretary of the Senate, the Sergeant at Arms of the Senate, each of the elected officers of the House of Representatives (other than a Member of the House), the Legislative Counsels of the House of Representatives and the Senate, the Law Revision Counsel of the House of Representatives, and the Senate Legal Counsel; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb969e5e5-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3216/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the survivors of a Member of Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3218"},"text":"section 3218 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb969e5e6-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3216/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those portions of fees and charges to be paid for handling and delivery by the Postal Service of Mailgrams considered as franked mail under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3219"},"text":"section 3219 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be paid by appropriations for the official mail costs of the Senate and the House of Representatives for that purpose and then paid to the Postal Service as postal revenue. Except as to Mailgrams and except as provided by sections 733 and 907 of title 44, envelopes, wrappers, cards, or labels used to transmit franked mail shall bear, in the upper right-hand corner, the sender’s signature, or a fac­simile thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb969e5e7-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3216/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Postage on, and fees and charges in connection with, mail matter sent through the mails under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3214"},"text":"section 3214 of this title","children":[],"tail":" shall be paid each fiscal year, out of any appropriation made for that purpose, to the Postal Service as postal revenue in an amount equivalent to the postage, fees, and charges which would otherwise be payable on, or in connection with, such mail matter."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb969e5e8-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3216/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payment under subsection (a) or (b) of this section shall be deemed payment for all matter mailed under the frank and for all fees and charges due the Postal Service in connection therewith.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb969e5e9-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3216/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Money collected for matter improperly mailed under the franking privilege shall be deposited as miscellaneous receipts in the general fund of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb969e5ea-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3216/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb969e5eb-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3216/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than two weeks after the last day of each quarter of the fiscal year, or as soon as practicable thereafter, the Postmaster General shall send to the Chief Administrative Officer of the House of Representatives, the House Communications Standards Commission, the Secretary of the Senate, and the Senate Committee on Rules and Administration a report which shall contain a tabulation of the estimated number of pieces and costs of franked mail, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3201"},"text":"section 3201 of this title","children":[],"tail":", in each mail classification sent through the mail for that quarter and for the preceding quarters in the fiscal year, together with separate tabulations of the number of pieces and costs of such mail sent by the House and by the Senate."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb969e5ec-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3216/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two weeks after the close of the second quarter of the fiscal year, or as soon as practicable thereafter, the Postmaster General shall send to the Chief Administrative Officer of the House of Representatives, the House Communications Standards Commission, the Committee on House Oversight, the Secretary of the Senate, and the Senate Committee on Rules and Administration, a statement of the costs of postage on, and fees and charges in connection with, mail matter sent through the mails as described in paragraph (1) of this subsection for the preceding two quarters together with an estimate of such costs for the balance of the fiscal year. As soon as practicable after receipt of this statement, the House Communications Standards Commission, the Committee on House Oversight, and the Senate Committee on Rules and Administration shall consider promulgating such regulations for their respective Houses as may be necessary to ensure that total postage costs, as described in paragraph (1) of this subsection, will not exceed the amounts available for the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb969e5ed-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/754"},"text":"84 Stat. 754","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/51/s101"},"text":"Pub. L. 92–51, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-07-09"},"text":"July 9, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/132"},"text":"85 Stat. 132","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/191/s7"},"text":"Pub. L. 93–191, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-18"},"text":"Dec. 18, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/745"},"text":"87 Stat. 745","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/255/s2/a"},"text":"Pub. L. 93–255, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-03-27"},"text":"Mar. 27, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/52"},"text":"88 Stat. 52","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/521/tVII/s714/b"},"text":"Pub. L. 95–521, title VII, § 714(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-26"},"text":"Oct. 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1884"},"text":"92 Stat. 1884","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/69/s6/a"},"text":"Pub. L. 97–69, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-10-26"},"text":"Oct. 26, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1043"},"text":"95 Stat. 1043","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/263/s1/3"},"text":"Pub. L. 97–263, § 1(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-24"},"text":"Sept. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1132"},"text":"96 Stat. 1132","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/163/tIII"},"text":"Pub. L. 101–163, title III","children":[],"tail":", §§ 316(b), formerly § 316(c), 317, "},{"tag":"date","attrib":{"date":"1989-11-21"},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1067"},"text":"103 Stat. 1067","children":[],"tail":", renumbered § 316(b), "},{"tag":"ref","attrib":{"href":"/us/pl/101/520/tIII/s311/h/3/B"},"text":"Pub. L. 101–520, title III, § 311(h)(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2280"},"text":"104 Stat. 2280","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/90/tIII/s306"},"text":"Pub. L. 102–90, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/466"},"text":"105 Stat. 466","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s220"},"text":"Pub. L. 104–186, title II, § 220","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1748"},"text":"110 Stat. 1748","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dI/tI/s116/b/2/A/ii"},"text":"Pub. L. 116–260, div. I, title I, § 116(b)(2)(A)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1637"},"text":"134 Stat. 1637","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb969e5ee-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb969e5ef-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb969e5f0-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" substituted “House Communications Standards Commission” for “House Commission on Congressional Mailing Standards” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “Chief Administrative Officer of the House of Representatives” for “Clerk of the House” in pars. (1) and (2) and “House Oversight” for “House Administration” in two places in par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/90"},"text":"Pub. L. 102–90","children":[],"tail":" substituted “paragraph (1) of this subsection” for “subsection (1) of this section” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/520"},"text":"Pub. L. 101–520","children":[],"tail":" made technical amendment to "},{"tag":"ref","attrib":{"href":"/us/pl/101/163/s316/b"},"text":"Pub. L. 101–163, § 316(b)","children":[],"tail":". See 1989 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/163/s316/b"},"text":"Pub. L. 101–163, § 316(b)","children":[],"tail":", formerly § 316(c), as renumbered by "},{"tag":"ref","attrib":{"href":"/us/pl/101/520"},"text":"Pub. L. 101–520","children":[],"tail":", which directed substitution of “by appropriations for the official mail costs of the Senate and the House of Representatives” for “by a lump sum appropriation to the legislative branch” was executed by making the substitution for “by a lump-sum appropriation to the legislative branch” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/163/s317"},"text":"Pub. L. 101–163, § 317","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/263"},"text":"Pub. L. 97–263","children":[],"tail":" inserted reference to Law Revision Counsel of House of Representatives."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/69"},"text":"Pub. L. 97–69","children":[],"tail":" substituted “survivors” for “surviving spouse”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/521"},"text":"Pub. L. 95–521","children":[],"tail":" inserted reference to Senate Legal Counsel."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/255"},"text":"Pub. L. 93–255","children":[],"tail":" struck out “, and the printed words ‘Postage paid by Congress’ ” at end of last sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/191"},"text":"Pub. L. 93–191","children":[],"tail":" incorporated existing text in provisions designated as par. (1)(A) and (B), substituted in subpar. (a) reference to elected officers of House of Representatives (other than a Member of House) for former references to Clerk of House of Representatives and Sergeant at Arms of House of Representatives, included in subpar. (A) reference to Legislative Counsel of Senate, added par. (2) and provision for the sender’s signature, or facsimile thereof, and printed words “Postage paid by Congress” in upper right-hand corner on transmitted franked mail."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/191"},"text":"Pub. L. 93–191","children":[],"tail":" added subsec. (b). Former subsec. (b), which provided that the postage on mail matter sent through the mails under the franking privilege by former Presidents shall be paid by reimbursement of the postal revenues each fiscal year out of the general funds of the Treasury in an amount equivalent to the postage which would otherwise be payable on the mail matter, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/191"},"text":"Pub. L. 93–191","children":[],"tail":" added subsecs. (c) and (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1971—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/51"},"text":"Pub. L. 92–51","children":[],"tail":" inserted reference to Legislative Counsel of House of Representatives."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb969e5f1-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb969e5f2-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on House Oversight of House of Representatives changed to Committee on House Administration of House of Representatives by House Resolution No. 5, One Hundred Sixth Congress, ","children":[{"tag":"date","attrib":{"date":"1999-01-06"},"text":"Jan. 6, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb969e5f3-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" applicable with respect to communications disseminated on or after "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dI/s116/f"},"text":"section 116(f) of div. I of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s501"},"text":"section 501 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb969e5f4-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/163/tIII/s316/b"},"text":"Pub. L. 101–163, title III, § 316(b)","children":[],"tail":", formerly § 316(c), "},{"tag":"date","attrib":{"date":"1989-11-21"},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1067"},"text":"103 Stat. 1067","children":[],"tail":", renumbered § 316(b), "},{"tag":"ref","attrib":{"href":"/us/pl/101/520/tIII/s311/h/3/B"},"text":"Pub. L. 101–520, title III, § 311(h)(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2280"},"text":"104 Stat. 2280","children":[],"tail":", provided that the amendment made by that section is effective "},{"tag":"date","attrib":{"date":"1989-10-01"},"text":"Oct. 1, 1989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb969e5f5-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/521"},"text":"Pub. L. 95–521","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-01-03"},"text":"Jan. 3, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/521/s717"},"text":"section 717 of Pub. L. 95–521","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s288"},"text":"section 288 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb969e5f6-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1973 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/191"},"text":"Pub. L. 93–191","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1973-12-18"},"text":"Dec. 18, 1973","children":[],"tail":", except that subsec. (b) of this section effective "},{"tag":"date","attrib":{"date":"1972-12-27"},"text":"Dec. 27, 1972","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/191/s14"},"text":"section 14 of Pub. L. 93–191","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s3210"},"text":"section 3210 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb969e5f7-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1971-07-01"},"text":"July 1, 1971","children":[],"tail":", pursuant to Resolution No. 71–9 of the Board of Governors. See "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
