{"tag":"section","attrib":{"id":"idb96070da-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3002"},"text":null,"children":[{"tag":"num","attrib":{"value":"3002"},"text":"§ 3002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonmailable motor vehicle master keys","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb96070db-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3002/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b) of this section, any motor vehicle master key, any pattern, impression, or mold from which a motor vehicle master key may be made, or any advertisement for the sale of any such key, pattern, impression, or mold, is nonmailable matter and shall not be carried or delivered by mail.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96070dc-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3002/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Postal Service is authorized to make such exemptions from the provisions of subsection (a) of this section as it deems necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96070dd-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3002/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this section, “motor vehicle master key” means any key (other than the key furnished by the manufacturer with the motor vehicle, or the key furnished with a replacement lock, or any exact duplicate of such keys) designed to operate 2 or more motor vehicle ignition, door, or trunk locks of different combinations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb96070de-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/746"},"text":"84 Stat. 746","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb96070df-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb96070e0-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb96070e1-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1971-07-01"},"text":"July 1, 1971","children":[],"tail":", pursuant to Resolution No. 71–9 of the Board of Governors. See "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
