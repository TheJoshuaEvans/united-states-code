{"tag":"section","attrib":{"id":"idb9652b1f-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3202"},"text":null,"children":[{"tag":"num","attrib":{"value":"3202"},"text":"§ 3202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty mail","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9652b20-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to the limitations imposed by sections 3204 and 3207 of this title, there may be transmitted as penalty mail—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9652b21-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3202/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" official mail of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9652b22-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3202/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" officers of the Government of the United States other than Members of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9652b23-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3202/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Smithsonian Institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9652b24-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3202/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Pan American Union;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9652b25-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3202/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Pan American Sanitary Bureau; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9652b26-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3202/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Employment Service and the system of employment offices operated by it in conformity with the provisions of sections 49–49c, 49d, 49e–49k of title 29, and all State employment systems which receive funds appropriated under authority of those sections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652b27-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3202/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mail relating to naturalization to be sent to the Immigration and Naturalization Service by clerks of courts addressed to the Department of Justice or the Immigration and Naturalization Service, or any official thereof; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652b28-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3202/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mail relating to a collection of statistics, survey, or census authorized by title 13 and addressed to the Department of Commerce or a bureau or agency thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9652b29-2930-11f1-bc69-dbd19d1ebdf3","identif