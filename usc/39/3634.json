{"tag":"section","attrib":{"id":"idb96ea15c-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3634"},"text":null,"children":[{"tag":"num","attrib":{"value":"3634"},"text":"§ 3634.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assumed Federal income tax on competitive products income","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb96ea15d-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3634/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96ea15e-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3634/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “assumed Federal income tax on competitive products income” means the net income tax that would be imposed by chapter 1 of the Internal Revenue Code of 1986 on the Postal Service’s assumed taxable income from competitive products for the year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96ea15f-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3634/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “assumed taxable income from competitive products”, with respect to a year, refers to the amount representing what would be the taxable income of a corporation under the Internal Revenue Code of 1986 for the year, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb96ea160-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3634/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the only activities of such corporation were the activities of the Postal Service allocable under section 2011(h) to competitive products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96ea161-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3634/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the only assets held by such corporation were the assets of the Postal Service allocable under section 2011(h) to such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96ea162-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3634/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Computation and Transfer Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Postal Service shall, for each year beginning with the year in which occurs the deadline for the Postal Service’s first report to the Postal Regulatory Commission under section 3652(a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96ea163-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3634/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compute its assumed Federal income tax on competitive products income for such year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96ea164-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3634/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer from the Competitive Products Fund to the Postal Service Fund the amount of that assumed tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96ea165-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3634/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline for Transfers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any transfer required to be made under this section for a year shall be due on or before the January 15th next occurring after the close of such year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb96ea166-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435/tIV/s402"},"text":"Pub. L. 109–435, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3226"},"text":"120 Stat. 3226","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb96ea167-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb96ea168-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb96ea169-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Internal Revenue Code of 1986, referred to in subsec. (a), is classified to Title 26, Internal Revenue Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
