{"tag":"section","attrib":{"id":"idb9652b56-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3206"},"text":null,"children":[{"tag":"num","attrib":{"value":"3206"},"text":"§ 3206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement for penalty mail service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9652b57-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3206/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b) of this section, executive departments and agencies, independent establishments of the Government of the United States, and Government corporations concerned, shall transfer to the Postal Service as postal revenue out of any appropriations or funds available to them, as a necessary expense of the appropriations or funds and of the activities concerned, the equivalent amount of postage due, as determined by the Postal Service, for matter sent in the mails by or to them as penalty mail under authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3202"},"text":"section 3202 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9652b58-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3206/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Agriculture shall transfer to the Postal Service as postal revenues out of any appropriations made to it for that purpose the equivalent amount of postage, as determined by the Postal Service, for penalty mailings under clauses (1)(F) and (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3202/a"},"text":"section 3202(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9652b59-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3206/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of State shall transfer to the Postal Service as postal revenues out of any appropriations made to it for that purpose the equivalent amount of postage, as determined by the Postal Service, for penalty mailings under clause (1)(C) and (D) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3202/a"},"text":"section 3202(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9652b5a-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/753"},"text":"84 Stat. 753","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/191/s9"},"text":"Pub. L. 93–191, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-18"},"text":"Dec. 18, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/745"},"text":"87 Stat. 745","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/553/s105/e"},"text":"Pub. L. 94–553, § 105(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-19"},"text":"Oct. 19, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2599"},"text":"90 Stat. 2599","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9652b5b-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9652b5c-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tai