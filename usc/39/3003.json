{"tag":"section","attrib":{"id":"idb96070ed-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3003"},"text":null,"children":[{"tag":"num","attrib":{"value":"3003"},"text":"§ 3003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mail bearing a fictitious name or address","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb96070ee-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3003/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Upon evidence satisfactory to the Postal Service that any person is using a fictitious, false, or assumed name, title, or address in conducting, promoting, or carrying on or assisting therein, by means of the postal services of the United States, an activity in violation of sections 1302, 1341, and 1342 of title 18, it may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96070ef-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3003/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withhold mail so addressed from delivery; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96070f0-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3003/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the party claiming the mail to furnish proof to it of the claimant’s identity and right to receive the mail.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96070f1-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3003/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Postal Service may issue an order directing that mail, covered by subsection (a) of this section, be forwarded to a dead letter office as fictitious matter, or be returned to the sender when—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96070f2-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3003/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the party claiming the mail fails to furnish proof of his identity and right to receive the mail; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96070f3-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3003/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Postal Service determines that the mail is addressed to a fictitious, false, or assumed name, title, or address.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb96070f4-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/746"},"text":"84 Stat. 746","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb96070f5-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb96070f6-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb96070f7-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1971-07-01"},"text":"July 1, 1971","children":[],"tail":", pursuant to Resolution No. 71–9 of the Board of Governors. See "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
