{"tag":"section","attrib":{"id":"idb95dfeb0-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2601"},"text":null,"children":[{"tag":"num","attrib":{"value":"2601"},"text":"§ 2601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection and adjustment of debts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb95dfeb1-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2601/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Postal Service—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95dfeb2-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2601/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall collect debts due the Postal Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95dfeb3-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2601/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall collect and remit fines, penalties, and forfeitures arising out of matters affecting the Postal Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95dfeb4-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2601/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may adjust, pay, or credit the account of a postmaster or of an enlisted person of an Armed Force performing postal duties, for any loss of Postal Service funds, papers, postage, or other stamped stock or accountable paper; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95dfeb5-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2601/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may prescribe penalties for failure to render accounts.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Postal Service may refer any matter, which is uncollectable through administrative action, to the Government Accountability Office for collection. This subsection does not affect the authority of the Attorney General in cases in which judicial proceedings are instituted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95dfeb6-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2601/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In all cases of disability or alleged liability for any sum of money by way of damages or otherwise, under any provision of law in relation to the officers, employees, operations, or business of the Postal Service, the Postal Service shall determine whether the interests of the Postal Service probably require the exercise of its powers over the same. Upon the determination, the Postal Service on such terms as it deems just and expedient, may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95dfeb7-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2601/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remove the disability; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95dfeb8-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2601/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compromise, release, or discharge the claim for such sum of money and damages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb95dfeb9-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/744"},"text":"84 Stat. 744","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb95dfeba-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb95dfebb-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb95dfebc-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office” in concluding provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb95dfebd-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb95dfebe-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1971-07-01"},"text":"July 1, 1971","children":[],"tail":", pursuant to Resolution No. 71–9 of the Board of Governors. See "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
