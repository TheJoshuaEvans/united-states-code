{"tag":"section","attrib":{"id":"idb94631b9-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s401"},"text":null,"children":[{"tag":"num","attrib":{"value":"401"},"text":"§ 401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General powers of the Postal Service","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Subject to the provisions of section 404a, the Postal Service shall have the following general powers:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb94631ba-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s401/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to sue and be sued in its official name;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94631bb-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s401/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to adopt, amend, and repeal such rules and regulations, not inconsistent with this title, as may be necessary in the execution of its functions under this title and such other functions as may be assigned to the Postal Service under any provisions of law outside of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94631bc-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s401/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enter into and perform contracts, execute instruments, and determine the character of, and necessity for, its expenditures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94631bd-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s401/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine and keep its own system of accounts and the forms and contents of its contracts and other business documents, except as otherwise provided in this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94631be-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s401/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire, in any lawful manner, such personal or real property, or any interest therein, as it deems necessary or convenient in the transaction of its business; to hold, maintain, sell, lease, or otherwise dispose of such property or any interest therein; and to provide services in connection therewith and charges therefor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94631bf-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s401/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to construct, operate, lease, and maintain buildings, facilities, equipment, and other improvements on any property owned or controlled by it, including, without limitation, any property or interest therein transferred to it under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s2002"},"text":"section 2002 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94631c0-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s401/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accept gifts or donations of services or property, real or personal, as it deems, necessary or convenient in the transaction of its business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94631c1-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s401/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to settle and compromise claims by or against it;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94631c2-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s401/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to exercise, in the name of the United States, the right of eminent domain for the furtherance of its official purposes; and to have the priority of the United States with respect to the payment of debts out of bankrupt, insolvent, and decedents’ estates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94631c3-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s401/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to have all other powers incidental, necessary, or appropriate to the carrying on of its functions or the exercise of its specific powers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb94631c4-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/722"},"text":"84 Stat. 722","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/435/tIV/s403/b/1"},"text":"Pub. L. 109–435, title IV, § 403(b)(1)","children":[],"tail":", title V, § 504, "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3227"},"text":"120 Stat. 3227","children":[],"tail":", 3235.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb94631c5-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb94631c6-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb94631c7-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435/s403/b/1"},"text":"Pub. L. 109–435, § 403(b)(1)","children":[],"tail":", substituted “Subject to the provisions of section 404a, the” for “The” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435/s504"},"text":"Pub. L. 109–435, § 504","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “to adopt, amend, and repeal such rules and regulations as it deems necessary to accomplish the objectives of this title;”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb94631c8-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb94631c9-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Pars. (1) and (3) to (10) effective ","children":[{"tag":"date","attrib":{"date":"1971-07-01"},"text":"July 1, 1971","children":[],"tail":", pursuant to Resolution No. 71–9 of the Board of Governors and par. (2) effective "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb94631ca-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb94631cb-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Emergency Preparedness Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For assignment of certain emergency preparedness functions to the Postmaster General, see Parts 1, 2, and 26 of Ex. Ord. No. 12656, ","children":[{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", 53 F.R. 47491, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5195"},"text":"section 5195 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"idb94631cc-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Executive Order No. 13975","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 13975, ","children":[{"tag":"date","attrib":{"date":"2021-01-14"},"text":"Jan. 14, 2021","children":[],"tail":", 86 F.R. 6547, which encouraged Buy American policies for the United States Postal Service, was revoked by Ex. Ord. No. 14005, § 14(a), "},{"tag":"date","attrib":{"date":"2021-01-25"},"text":"Jan. 25, 2021","children":[],"tail":", 86 F.R. 7478, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s8301"},"text":"section 8301 of Title 41","children":[],"tail":", Public Contracts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
