{"tag":"section","attrib":{"id":"idb973830c-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s5005"},"text":null,"children":[{"tag":"num","attrib":{"value":"5005"},"text":"§ 5005.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mail transportation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb973830d-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s5005/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Postal Service may obtain mail transportation service—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb973830e-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s5005/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from air carriers as provided in chapter 54 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb973830f-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s5005/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from water carriers as provided in chapter 56 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9738310-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s5005/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by contract from any person or carrier for surface and water transportation under such terms and conditions as it deems appropriate, subject to the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9738311-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s5005/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9738312-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s5005/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Contracts for the transportation of mail procured under subsection (a)(3) of this section shall be for periods not in excess of 4 years (or such longer period of time as may be determined by the Postal Service to be advisable or appropriate) and shall be entered into only after advertising a sufficient time previously for proposals. The Postal Service, with the consent of the holder of any such contract, may adjust the compensation allowed under that contract for increased or decreased costs resulting from changed conditions occurring during the term of the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9738313-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s5005/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A contract under subsection (a)(3) of this section may be renewed at the existing rate by mutual agreement between the contractor or subcontractor and the Postal Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9738314-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s5005/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any contract between the Postal Service and any carrier or person for the transportation of mail shall be available for inspection in the office of the Postal Service and either the Surface Transportation Board or the Secretary of Transportation if for the carriage of mail in foreign air transportation (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40102/a"},"text":"section 40102(a) of title 49","children":[],"tail":"), as appropriate, and in post offices on the post roads involved as determined by the Postal Service, at least 15 days prior to the effective date of the contract."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9738315-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s5005/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Postal Service, in determining whether to obtain transportation of mail by contract under subsection (a)(3) of this section or by Government motor vehicle, shall use the mode of transportation which best serves the public interest, due consideration being given to the cost of the transportation service under each mode.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9738316-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/767"},"text":"84 Stat. 767","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/286"},"text":"Pub. L. 92–286","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-05-01"},"text":"May 1, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/133"},"text":"86 Stat. 133","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/443/s9/g/2"},"text":"Pub. L. 98–443, § 9(g)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-04"},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1707"},"text":"98 Stat. 1707","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s5/k/2"},"text":"Pub. L. 103–272, § 5(k)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1375"},"text":"108 Stat. 1375","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/tIII/s307/1"},"text":"Pub. L. 104–88, title III, § 307(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/945"},"text":"109 Stat. 945","children":[],"tail":", 946; "},{"tag":"ref","attrib":{"href":"/us/pl/109/435/tX/s1002/a/2"},"text":"Pub. L. 109–435, title X, § 1002(a)(2)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3254"},"text":"120 Stat. 3254","children":[],"tail":", 3255.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9738317-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9738318-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9738319-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435/s1002/a/2/A"},"text":"Pub. L. 109–435, § 1002(a)(2)(A)","children":[],"tail":", struck out par. (1), which related to common carriers by rail and motor vehicle or persons as provided in chapter 52, redesignated pars. (2) to (4) as (1) to (3), respectively, and, in par. (3), struck out “(as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s5201/6"},"text":"section 5201(6) of this title","children":[],"tail":")” after “any person”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435/s1002/a/2/B"},"text":"Pub. L. 109–435, § 1002(a)(2)(B)","children":[],"tail":", (b)(1), substituted “(a)(3)” for “(a)(4)” in pars. (1) and (2) and “(or such longer period of time as may be determined by the Postal Service to be advisable or appropriate)” for “(or where the Postal Service determines that special conditions or the use of special equipment warrants, not in excess of 6 years)” in par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435/s1002/a/2/C"},"text":"Pub. L. 109–435, § 1002(a)(2)(C)","children":[],"tail":", substituted “by contract under subsection (a)(3) of this section or” for “by carrier or person under subsection (a)(1) of this section, by contract under subsection (a)(4) of this section, or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/s307/1"},"text":"Pub. L. 104–88, § 307(1)","children":[],"tail":", substituted “5201(6)” for “5201(7)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/s307/2"},"text":"Pub. L. 104–88, § 307(2)","children":[],"tail":", substituted “Surface Transportation Board” for “Interstate Commerce Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Pub. L. 103–272","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t49/s40102/a"},"text":"section 40102(a) of title 49","children":[],"tail":"” for “section 101 of the Federal Aviation Act of 1958”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/443"},"text":"Pub. L. 98–443","children":[],"tail":" substituted “Secretary of Transportation if for the carriage of mail in foreign air transportation (as defined in section 101 of the Federal Aviation Act of 1958)” for “Civil Aeronautics Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/286"},"text":"Pub. L. 92–286","children":[],"tail":" substituted “contractor or subcontractor” for “holder”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb973831a-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb973831b-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of Title 49","children":[],"tail":", Transportation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb973831c-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/443"},"text":"Pub. L. 98–443","children":[],"tail":" effective "},{"t