{"tag":"section","attrib":{"id":"idb97382bf-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3703"},"text":null,"children":[{"tag":"num","attrib":{"value":"3703"},"text":"§ 3703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Postal Service program for State governments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb97382c0-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this title, the Postal Service may establish a program to enter into agreements with an agency of any State government, local government, or tribal government to provide property or nonpostal services to the public on behalf of such agencies for non-commercial purposes, but only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb97382c1-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3703/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such property or nonpostal services—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb97382c2-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3703/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide enhanced value to the public, such as by lowering the cost or raising the quality of such services or by making such services more accessible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb97382c3-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3703/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" do not interfere with or detract from the value of postal services, including by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb97382c4-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3703/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" harming the cost and efficiency of postal services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb97382c5-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3703/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unreasonably restricting access to postal retail service, such as customer waiting time and access to parking; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97382c6-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3703/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such agreements provide a net contribution to the Postal Service, defined as reimbursement that covers at least 100 percent of the costs attributable to all property and nonpostal services provided under each relevant agreement in each year, except that agreements determined to be substantially similar by the Postal Service with the concurrence of the Postal Regulatory Commission shall be reviewed based on their collective revenue and costs attributable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb97382c7-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Notice","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not more than 90 days after offering a service under the program, the Postal Service shall make available to the public on its website—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb97382c8-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3703/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agreement with the agency regarding such service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97382c9-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3703/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a business plan that describes the specific property or nonpostal service to be provided, the enhanced value to the public, and terms of reimbursement to the Postal Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb97382ca-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Postal Service may not establish the program under subsection (a) unless the Governors of the Postal Service approve such program by a recorded vote that is publicly disclosed on the Postal Service website with a majority of the Governors then in office voting for approval.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb97382cb-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3703/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Confidential Information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (b) shall not be construed as requiring the Postal Service to disclose to the public any information—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb97382cc-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3703/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" described in section 410(c); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97382cd-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3703/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exempt from public disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b"},"text":"section 552(b) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb97382ce-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/108/tI/s103/a/1"},"text":"Pub. L. 117–108, title I, § 103(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-04-06"},"text":"Apr. 6, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1141"},"text":"136 Stat. 1141","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
