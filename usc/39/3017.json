{"tag":"section","attrib":{"id":"idb9652ab1-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017"},"text":null,"children":[{"tag":"num","attrib":{"value":"3017"},"text":"§ 3017.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonmailable skill contests or sweepstakes matter; notification to prohibit mailings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9652ab2-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9652ab3-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “promoter” means any person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9652ab4-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" originates and mails any skill contest or sweepstakes, except for any matter described in section 3001(k)(4); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9652ab5-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" originates and causes to be mailed any skill contest or sweepstakes, except for any matter described in section 3001(k)(4);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652ab6-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “removal request” means a request stating that an individual elects to have the name and address of such individual excluded from any list used by a promoter for mailing skill contests or sweepstakes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652ab7-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “skill contest”, “sweepstakes”, and “clearly and conspicuously displayed” have the same meanings as given them in section 3001(k); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652ab8-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “duly authorized person”, as used in connection with an individual, means a conservator or guardian of, or person granted power of attorney by, such individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9652ab9-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonmailable Matter.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9652aba-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Matter otherwise legally acceptable in the mails described in paragraph (2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9652abb-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is nonmailable matter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9652abc-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be carried or delivered by mail; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9652abd-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be disposed of as the Postal Service directs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652abe-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonmailable matter described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Matter described in this paragraph is any matter that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9652abf-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a skill contest or sweepstakes, except for any matter described in section 3001(k)(4); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9652ac0-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9652ac1-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is addressed to an individual who made an election to be excluded from lists under subsection (d); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9652ac2-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not comply with subsection (c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9652ac3-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements of Promoters.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9652ac4-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to individuals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any promoter who mails a skill contest or sweepstakes shall provide with each mailing a statement that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9652ac5-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is clearly and conspicuously displayed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9652ac6-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the address or toll-free telephone number of the notification system established under paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9652ac7-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" states that the notification system may be used to prohibit the mailing of all skill contests or sweepstakes by that promoter to such individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652ac8-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification system","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any promoter that mails or causes to be mailed a skill contest or sweepstakes shall establish and maintain a notification system that provides for any individual (or other duly authorized person) to notify the system of the individual’s election to have the name and address of the individual excluded from all lists of names and addresses used by that promoter to mail any skill contest or sweepstakes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9652ac9-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Election To Be Excluded From Lists.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9652aca-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual (or other duly authorized person) may elect to exclude the name and address of that individual from all lists of names and addresses used by a promoter of skill contests or sweepstakes by submitting a removal request to the notification system established under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652acb-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Response after submitting removal request to the notification system","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 calendar days after a promoter receives a removal request pursuant to an election under paragraph (1), the promoter shall exclude the individual’s name and address from all lists of names and addresses used by that promoter to select recipients for any skill contest or sweepstakes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652acc-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effectiveness of election","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An election under paragraph (1) shall remain in effect, unless an individual (or other duly authorized person) notifies the promoter in writing that such individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9652acd-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has changed the election; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9652ace-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elects to receive skill contest or sweepstakes mailings from that promoter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9652acf-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Private Right of Action.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9652ad0-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual who receives one or more mailings in violation of subsection (d) may, if otherwise permitted by the laws or rules of court of a State, bring in an appropriate court of that State—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9652ad1-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an action to enjoin such violation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9652ad2-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an action to recover for actual monetary loss from such a violation, or to receive $500 in damages for each such violation, whichever is greater; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9652ad3-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" both such actions.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"It shall be an affirmative defense in any action brought under this subsection that the defendant has established and implemented, with due care, reasonable practices and procedures to effectively prevent mailings in violation of subsection (d). If the court finds that the defendant willfully or knowingly violated subsection (d), the court may, in its discretion, increase the amount of the award to an amount equal to not more than 3 times the amount available under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652ad4-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Action allowable based on other sufficient notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A mailing sent in violation of section 3001(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") shall be actionable under this subsection, but only if such an action would not also be available under paragraph (1) (as a violation of subsection (d)) based on the same mailing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9652ad5-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Promoter Nonliability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A promoter shall not be subject to civil liability for the exclusion of an individual’s name or address from any list maintained by that promoter for mailing skill contests or sweepstakes, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9652ad6-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a removal request is received by the promoter’s notification system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652ad7-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the promoter has a good faith belief that the request is from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9652ad8-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual whose name and address is to be excluded; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9652ad9-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another duly authorized person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9652ada-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Commercial Use of Lists.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9652adb-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9652adc-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No person may provide any information (including the sale or rental of any name or address) derived from a list described in subparagraph (B) to another person for commercial use.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9652add-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lists","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A list referred to under subparagraph (A) is any list of names and addresses (or other related information) compiled from individuals who exercise an election under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652ade-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person who violates paragraph (1) shall be assessed a civil penalty by the Postal Service not to exceed $2,000,000 per violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9652adf-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Penalties.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9652ae0-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any promoter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9652ae1-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who recklessly mails nonmailable matter in violation of subsection (b) shall be liable to the United States in an amount of $10,000 per violation for each mailing to an individual of nonmailable matter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9652ae2-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who fails to comply with the requirements of subsection (c)(2) shall be liable to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9652ae3-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3017/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enforcement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Postal Service shall, in accordance with the same procedures as set forth in section 3012(b), provide for the assessment of civil penalties under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9652ae4-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/168/tI/s108/a"},"text":"Pub. L. 106–168, title I, § 108(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-12"},"text":"Dec. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1814"},"text":"113 Stat. 1814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9652ae5-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9652ae6-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9652ae7-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/168/tI/s108/c"},"text":"Pub. L. 106–168, title I, § 108(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-12"},"text":"Dec. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1816"},"text":"113 Stat. 1816","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/168/tI/s108/c"},"text":"“This section [enacting this section] shall take effect 1 year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1999-12-12"},"text":"Dec. 12, 1999","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
