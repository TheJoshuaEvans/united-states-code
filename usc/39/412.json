{"tag":"section","attrib":{"id":"idb94d5db6-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s412"},"text":null,"children":[{"tag":"num","attrib":{"value":"412"},"text":"§ 412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondisclosure of lists of names and addresses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb94d5db7-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s412/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as specifically provided by subsection (b) or other law, no officer or employee of the Postal Service shall make available to the public by any means or for any purpose any mailing or other list of names or addresses (past or present) of postal patrons or other persons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb94d5db8-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s412/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Postal Service shall provide to the Secretary of Commerce for use by the Bureau of the Census such address information, address-related information, and point of postal delivery information, including postal delivery codes, as may be determined by the Secretary to be appropriate for any census or survey being conducted by the Bureau of the Census. The provision of such information under this subsection shall be in accordance with such mutually agreeable terms and conditions, including reimbursability, as the Postal Service and the Secretary of Commerce shall deem appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb94d5db9-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/727"},"text":"84 Stat. 727","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/430/s4"},"text":"Pub. L. 103–430, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4394"},"text":"108 Stat. 4394","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb94d5dba-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb94d5dbb-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb94d5dbc-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/430"},"text":"Pub. L. 103–430","children":[],"tail":" substituted “(a) Except as specifically provided by subsection (b) or other law,” for “Except as specifically provided by law,” and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb94fa6ad-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb94fa6ae-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1971-07-01"},"text":"July 1, 1971","children":[],"tail":", pursuant to Resolution No. 71–9 of the Board of Governors. See "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
