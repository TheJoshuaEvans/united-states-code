{"tag":"section","attrib":{"id":"idb9711254-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3685"},"text":null,"children":[{"tag":"num","attrib":{"value":"3685"},"text":"§ 3685.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing of information relating to periodical publications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9711255-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3685/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each owner of a publication having periodical publication mail privileges shall furnish to the Postal Service at least once a year, and shall publish in such publication once a year, information in such form and detail and at such time as the Postal Service may require with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9711256-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3685/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity of the editor, managing editor, publishers, and owners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9711257-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3685/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity of the corporation and stockholders thereof, if the publication is owned by a corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9711258-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3685/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity of known bondholders, mortgagees, and other security holders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9711259-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3685/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent and nature of the circulation of the publication, including, but not limited to, the number of copies distributed, the methods of distribution, and the extent to which such circulation is paid in whole or in part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb971125a-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3685/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Postal Service may deem necessary to determine whether the publication meets the standards for periodical publication mail privileges.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Postal Service shall not require the names of persons owning less than 1 percent of the total amount of stocks, bonds, mortgages, or other securities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb971125b-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3685/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each publication having such mail privileges shall furnish to the Postal Service information in such form and detail, and at such times, as the Postal Service requires to determine whether the publication continues to qualify for such privileges.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb971125c-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3685/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Postal Service shall make appropriate rules and regulations to carry out the purposes of this section, including provision for suspension or revocation of periodical publication mail privileges for failure to furnish the required information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb971125d-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/765"},"text":"84 Stat. 765","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb971125e-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb971125f-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9711260-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1971-01-20"},"text":"Jan. 20, 1971","children":[],"tail":", pursuant to Resolution No. 71–10 of the Board of Governors. See "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
