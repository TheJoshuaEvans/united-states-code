{"tag":"section","attrib":{"id":"idb971122b-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3681"},"text":null,"children":[{"tag":"num","attrib":{"value":"3681"},"text":"§ 3681.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No mailer may be reimbursed for any amount paid under any rate or fee which, after such payment, is determined to have been unlawful after proceedings in accordance with the provisions of sections 3662 through 3664 of this title, or is superseded by a lower rate or fee established under subchapter II of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb971122c-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/764"},"text":"84 Stat. 764","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/435/tX/s1010/a"},"text":"Pub. L. 109–435, title X, § 1010(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3261"},"text":"120 Stat. 3261","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb971122d-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb971122e-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb971122f-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":