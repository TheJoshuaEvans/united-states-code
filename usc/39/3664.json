{"tag":"section","attrib":{"id":"idb9711225-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3664"},"text":null,"children":[{"tag":"num","attrib":{"value":"3664"},"text":"§ 3664.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The several district courts have jurisdiction specifically to enforce, and to enjoin and restrain the Postal Service from violating, any order issued by the Postal Regulatory Commission.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9711226-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435/tII/s205"},"text":"Pub. L. 109–435, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3217"},"text":"120 Stat. 3217","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
