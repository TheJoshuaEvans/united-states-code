{"tag":"section","attrib":{"id":"idb95dff2e-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2901"},"text":null,"children":[{"tag":"num","attrib":{"value":"2901"},"text":"§ 2901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95dff2f-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2901/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Excess property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “excess property” means any postal property that the Postal Service determines is not required to meet the needs or responsibilities of the Postal Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95dff30-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2901/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Postal property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “postal property” means any property owned or leased by the Postal Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95dff31-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2901/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Underutilized property","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “underutilized property” means a portion or the entirety of any real property that is postal property, including any improvements, that is used—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95dff32-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2901/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" irregularly or intermittently by the Postal Service for program purposes of the Postal Service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95dff33-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2901/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for program purposes that can be satisfied only with a portion of the property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb95dff34-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/318/s4/a"},"text":"Pub. L. 114–318, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1613"},"text":"130 Stat. 1613","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
