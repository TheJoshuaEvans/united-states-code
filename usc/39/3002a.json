{"tag":"section","attrib":{"id":"idb96070e2-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3002a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3002a"},"text":"§ 3002a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonmailability of locksmithing devices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb96070e3-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3002a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any locksmithing device is nonmailable mail, shall not be carried or delivered by mail, and shall be disposed of as the Postal Service directs, unless such device is mailed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96070e4-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3002a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a lock manufacturer or distributor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96070e5-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3002a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a bona fide locksmith;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96070e6-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3002a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a bona fide repossessor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96070e7-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3002a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a motor vehicle manufacturer or dealer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96070e8-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3002a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of this section, “locksmithing device” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96070e9-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3002a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a device or tool (other than a key) designed to manipulate the tumblers in a lock into the unlocked position through the keyway of such lock;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96070ea-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3002a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a device or tool (other than a key or a device or tool under paragraph (1)) designed for the unauthorized opening or bypassing of a lock or similar security device; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96070eb-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3002a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a device or tool designed for making an impression of a key or similar security device to duplicate such key or device.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb96070ec-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7090/a"},"text":"Pub. L. 100–690, title VII, § 7090(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4409"},"text":"102 Stat. 4409","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
