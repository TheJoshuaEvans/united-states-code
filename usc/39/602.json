{"tag":"section","attrib":{"id":"idb9521860-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s602"},"text":null,"children":[{"tag":"num","attrib":{"value":"602"},"text":"§ 602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign letters out of the mails","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9521861-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s602/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s601"},"text":"section 601 of this title","children":[],"tail":", the master of a vessel departing from the United States for foreign ports may not receive on board or transport any letter which originated in the United States that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9521862-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s602/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not been regularly received from a United States post office; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9521863-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s602/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not relate to the cargo of the vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9521864-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s602/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The officer of the port empowered to grant clearances shall require from the master of such a vessel, as a condition of clearance, an oath that he does not have under his care or control, and will not receive or transport, any letter contrary to the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9521865-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s602/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1699"},"text":"section 1699 of title 18","children":[],"tail":", the master of a vessel arriving at a port of the United States carrying letters not regularly in the mails shall deposit them in the post office at the port of arrival."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9521866-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/727"},"text":"84 Stat. 727","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9521867-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9521868-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9521869-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1971-07-01"},"text":"July 1, 1971","children":[],"tail":", pursuant to Resolution No. 71–9 of the Board of Governors. See "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
