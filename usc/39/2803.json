{"tag":"section","attrib":{"id":"idb95dff00-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2803"},"text":null,"children":[{"tag":"num","attrib":{"value":"2803"},"text":"§ 2803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb95dff01-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2803/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Postal Service shall prepare an annual performance plan covering each program activity set forth in the Postal Service budget, which shall be included in the comprehensive statement presented under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s2401/e"},"text":"section 2401(e) of this title","children":[],"tail":". Such plan shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95dff02-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2803/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish performance goals to define the level of performance to be achieved by a program activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95dff03-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2803/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" express such goals in an objective, quantifiable, and measurable form unless an alternative form is used under subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95dff04-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2803/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" briefly describe the operational processes, skills and technology, and the human, capital, information, or other resources required to meet the performance goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95dff05-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2803/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish performance indicators to be used in measuring or assessing the relevant outputs, service levels, and outcomes of each program activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95dff06-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2803/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a basis for comparing actual program results with the established performance goals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95dff07-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2803/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the means to be used to verify and validate measured values.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95dff08-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2803/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Postal Service determines that it is not feasible to express the performance goals for a particular program activity in an objective, quantifiable, and measurable form, the Postal Service may use an alternative form. Such alternative form shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95dff09-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2803/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include separate descriptive statements of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95dff0a-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2803/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a minimally effective program, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95dff0b-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2803/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a successful program,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"with sufficient precision and in such terms that would allow for an accurate, independent determination of whether the program activity’s performance meets the criteria of either description; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95dff0c-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2803/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state why it is infeasible or impractical to express a performance goal in any form for the program activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95dff0d-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2803/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In preparing a comprehensive and informative plan under this section, the Postal Service may aggregate, disaggregate, or consolidate program activities, except that any aggregation or consolidation may not omit or minimize the significance of any program activity constituting a major function or operation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95dff0e-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2803/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Postal Service may prepare a non-public annex to its plan covering program activities or parts of program activities relating to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95dff0f-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2803/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the avoidance of interference with criminal prosecution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95dff10-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2803/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" matters otherwise exempt from public disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s410/c"},"text":"section 410(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb95dff11-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/62/s7"},"text":"Pub. L. 103–62, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-03"},"text":"Aug. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/293"},"text":"107 Stat. 293","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/435/tX/s1010/d/2"},"text":"Pub. L. 109–435, title X, § 1010(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3261"},"text":"120 Stat. 3261","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb95dff12-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb95dff13-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb95dff14-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435"},"text":"Pub. L. 109–435","children":[],"tail":" substituted “section 2401(e)” for “section 2401(g)” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
