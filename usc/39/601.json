{"tag":"section","attrib":{"id":"idb952184b-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s601"},"text":null,"children":[{"tag":"num","attrib":{"value":"601"},"text":"§ 601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Letters carried out of the mail","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb952184c-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s601/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A letter may be carried out of the mails when—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb952184d-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s601/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is enclosed in an envelope;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb952184e-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s601/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of postage which would have been charged on the letter if it had been sent by mail is paid by stamps, or postage meter stamps, on the envelope;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb952184f-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s601/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the envelope is properly addressed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9521850-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s601/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the envelope is so sealed that the letter cannot be taken from it without defacing the envelope;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9521851-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s601/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any stamps on the envelope are canceled in ink by the sender; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9521852-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s601/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the letter, of its transmission or receipt by the carrier is endorsed on the envelope in ink.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9521853-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s601/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A letter may also be carried out of the mails when—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9521854-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s601/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount paid for the private carriage of the letter is at least the amount equal to 6 times the rate then currently charged for the 1st ounce of a single-piece first class letter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9521855-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s601/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the letter weighs at least 12½ ounces; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9521856-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s601/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such carriage is within the scope of services described by regulations of the United States Postal Service (including, in particular, sections 310.1 and 320.2–320.8 of title 39 of the Code of Federal Regulations, as in effect on ","children":[{"tag":"date","attrib":{"date":"2005-07-01"},"text":"July 1, 2005","children":[],"tail":") that purport to permit private carriage by suspension of the operation of this section (as then in effect)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9521857-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s601/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any regulations necessary to carry out this section shall be promulgated by the Postal Regulatory Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9521858-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/727"},"text":"84 Stat. 727","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/435/tV/s503/a"},"text":"Pub. L. 109–435, title V, § 503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3234"},"text":"120 Stat. 3234","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9521859-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb952185a-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb952185b-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435"},"text":"Pub. L. 109–435","children":[],"tail":" added subsecs. (b) and (c) and struck out former subsec. (b) which read as follows: “The Postal Service may suspend the operation of any part of this section upon any mail route where the public interest requires the suspension.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb952185c-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb952185d-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435/tV/s503/b"},"text":"Pub. L. 109–435, title V, § 503(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3235"},"text":"120 Stat. 3235","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/435/tV/s503/b"},"text":"“This section [amending this section] shall take effect on the date as of which the regulations promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3633"},"text":"section 3633 of title 39","children":[],"tail":", United States Code (as amended by section 202) take effect ["},{"tag":"date","attrib":{"date":"2007-12-10"},"text":"Dec. 10, 2007","children":[],"tail":", 72 F.R. 63662, 64155].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb952185e-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1971-07-01"},"text":"July 1, 1971","children":[],"tail":", pursuant to Resolution No. 71–9 of the Board of Governors. See "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb952185f-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study of Private Carriage of Mail: Reports to President and Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375/s7"},"text":"Pub. L. 91–375, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/783"},"text":"84 Stat. 783","children":[],"tail":", required the Board of Governors of the United States Postal Service to make a study of the restrictions on the private carriage of letters and packets and to submit a report and recommendations for modernization to the President and to the Congress within 2 years after the effective date of this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375/s7"},"text":"section 7 of Pub. L. 91–375","children":[],"tail":" effective within 1 year after "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", on date established therefor by the Board of Governors and published by it in the Federal Register, see "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
