{"tag":"section","attrib":{"id":"idb9487b0c-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s405"},"text":null,"children":[{"tag":"num","attrib":{"value":"405"},"text":"§ 405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Printing of illustrations of United States postage stamps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9487b0d-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s405/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When requested by the Postal Service, the Director of the Government Publishing Office shall print, as a public document for sale by the Superintendent of Documents, illustrations in black and white or in color of postage stamps of the United States, together with such descriptive, historical, and philatelic information with regard to the stamps as the Postal Service deems suitable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9487b0e-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s405/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s505"},"text":"section 505 of title 44","children":[],"tail":", stereotype or electrotype plates, or duplicates thereof, used in the publications authorized to be printed by this section may not be sold or otherwise disposed of."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9487b0f-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/724"},"text":"84 Stat. 724","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/d"},"text":"Pub. L. 113–235, div. H, title I, § 1301(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9487b10-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9487b11-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb9487b12-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Director of the Government Publishing Office” substituted for “Public Printer” in subsec. (a) on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/d"},"text":"section 1301(d) of Pub. L. 113–235","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s301"},"text":"section 301 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9487b13-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1971-07-01"},"text":"July 1, 1971","children":[],"tail":", pursuant to Resolution No. 71–9 of the Board of Governors. See "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
