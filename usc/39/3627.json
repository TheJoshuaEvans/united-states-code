{"tag":"section","attrib":{"id":"idb96ea123-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3627"},"text":null,"children":[{"tag":"num","attrib":{"value":"3627"},"text":"§ 3627.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjusting free rates","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If Congress fails to appropriate an amount authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s2401/c"},"text":"section 2401(c) of this title","children":[],"tail":" for any class of mail sent free of postage under section 3217 or 3403–3406 "},{"tag":"ref","attrib":{"idref":"fn002010"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002010"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “of this title,”."}],"tail":" the rate for that class may be adjusted in accordance with the provisions of this subchapter so that the increased revenues received from the users of such class will equal the amount for that class that the Congress was to appropriate."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb96ea124-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/763"},"text":"84 Stat. 763","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/593/s11/b"},"text":"Pub. L. 95–593, § 11(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-04"},"text":"Nov. 4, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2538"},"text":"92 Stat. 2538","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/410/tII/s201/b/3"},"text":"Pub. L. 99–41