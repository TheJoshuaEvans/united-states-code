ote","attrib":{"topic":"effectiveDateOfAmendment","id":"idb96ea12a-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/410"},"text":"Pub. L. 99–410","children":[],"tail":" applicable with respect to elections taking place after "},{"tag":"date","attrib":{"date":"1987-12-31"},"text":"Dec. 31, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/410/s204"},"text":"section 204 of Pub. L. 99–410","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s20301"},"text":"section 20301 of Title 52","children":[],"tail":", Voting and Elections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
