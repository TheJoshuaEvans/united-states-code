{"tag":"section","attrib":{"id":"idb95dfee6-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2801"},"text":null,"children":[{"tag":"num","attrib":{"value":"2801"},"text":"§ 2801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95dfee7-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2801/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “outcome measure” refers to an assessment of the results of a program activity compared to its intended purpose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95dfee8-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2801/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “output measure” refers to the tabulation, calculation, or recording of activity or effort and can be expressed in a quantitative or qualitative manner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95dfee9-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2801/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “performance goal” means a target level of performance expressed as a tangible, measurable objective, against which actual achievement shall be compared, including a goal expressed as a quantitative standard, value, or rate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95dfeea-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2801/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “performance indicator” refers to a particular value or characteristic used to measure output or outcome;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95dfeeb-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2801/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “program activity” means a specific activity related to the mission of the Postal Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95dfeec-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2801/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “program evaluation” means an assessment, through objective measurement and systematic analysis, of the manner and extent to which Postal Service programs achieve intended objectives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb95dfeed-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/62/s7"},"text":"Pub. L. 103–62, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-03"},"text":"Aug. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/292"},"text":"107 Stat. 292","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb95dfeee-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb95dfeef-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb95dfef0-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"No provision or amendment made by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/62"},"text":"Pub. L. 103–62","children":[],"tail":" to be construed as creating any right, privilege, benefit, or entitlement for any person who is not an officer or employee of the United States acting in such capacity, and no person not an officer or employee of the United States acting in such capacity to have standing to file any civil action in any court of the United States to enforce any provision or amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/103/62"},"text":"Pub. L. 103–62","children":[],"tail":", or to be construed as superseding any statutory requirement, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/62/s10"},"text":"section 10 of Pub. L. 103–62","children":[],"tail":", set out as a Construction of 1993 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1101"},"text":"section 1101 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
