{"tag":"section","attrib":{"id":"idb9679be9-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3215"},"text":null,"children":[{"tag":"num","attrib":{"value":"3215"},"text":"§ 3215.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lending or permitting use of frank unlawful","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A person entitled to use a frank may not lend it or permit its use by any committee, organization, or association, or permit its use by any person for the benefit or use of any committee, organization, or association. This section does not apply to any standing, select, special, or joint committee, or subcommittee thereof, or commission, of the Senate, House of Representatives, or Congress, composed of Members of Congress, or to the Democratic caucus or the Republican conference of the House of Representatives or of the Senate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9679bea-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/754"},"text":"84 Stat. 754","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/191/s10"},"text":"Pub. L. 93–191, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-18"},"text":"Dec. 18, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/746"},"text":"87 Stat. 746","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9679beb-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9679bec-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9679bed-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1973—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/191"},"text":"Pub. L. 93–191","children":[],"tail":" substituted provision for nonapplication of section to “any standing, select, special, or joint committee, or subcommittee thereof, or commission, of the Senate, House of Representatives, or Congress, composed of Members of Congress, or to the Democratic caucus or the Republican conference of the House of Representatives or of the Senate” for such nonapplication to “any committee composed of Members of Congress”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9679bee-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9679bef-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1973 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/191"},"text":"Pub. L. 93–191","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1973-12-18"},"text":"Dec. 18, 1973","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/191/s14"},"text":"section 14 of Pub. L. 93–191","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s3210"},"text":"section 3210 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","att