{"tag":"section","attrib":{"id":"idb95b8e20-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2009a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009a"},"text":"§ 2009a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budgetary treatment of the Postal Service Fund","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the receipts and disbursements of the Postal Service Fund, including disbursements for administrative expenses incurred in connection with the Fund—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95b8e21-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2009a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall not be included in the totals of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95b8e22-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2009a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the budget of the United States Government as submitted by the President, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95b8e23-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2009a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional budget (including allocations of budget authority and outlays provided therein);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95b8e24-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2009a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be exempt from any general budget limitation imposed by statute on expenditures and net lending (budget outlays) of the United States Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95b8e25-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2009a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be exempt from any order issued under part C of the Balanced Budget and Emergency Deficit Control Act of 1985, and shall not be counted for purposes of calculating the deficit under section 3(6) of the Congressional Budget and Impoundment Control Act of 1974 for purposes of comparison with the maximum deficit amount under the Balanced Budget and Emergency Deficit Control Act of 1985 nor counted in calculating the excess deficit for purposes of sections 251 and 252 ","children":[{"tag":"ref","attrib":{"idref":"fn002003"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002003"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Balanced Budget and Emergency Deficit Control Act of 1985, for any fiscal year."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb95b8e26-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tIV/s4001/a/1"},"text":"Pub. L. 101–239, title IV, § 4001(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2133"},"text":"103 Stat. 2133","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb95b8e27-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb95b8e28-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb95b8e29-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Balanced Budget and Emergency Deficit Control Act of 1985, referred to in par. (3), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/177"},"text":"Pub. L. 99–177","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-12"},"text":"Dec. 12, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1038"},"text":"99 Stat. 1038","children":[],"tail":". Part C of the Act is classified generally to subchapter I (§ 900 et seq.) of chapter 20 of Title 2, The Congress. Sections 251 and 252 of the Act are classified to sections 901 and 902, respectively, of Title 2, and were amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXIII/s13101/a"},"text":"Pub. L. 101–508, title XIII, § 13101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-577"},"text":"104 Stat. 1388–577","children":[],"tail":", 1388–581. Section 251 of the Act was further amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/112/25/tI/s101"},"text":"Pub. L. 112–25, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-08-02"},"text":"Aug. 2, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/241"},"text":"125 Stat. 241","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s900"},"text":"section 900 of Title 2","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3(6) of the Congressional Budget and Impoundment Control Act of 1974, referred to in par. (3), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s622/6"},"text":"section 622(6) of Title 2","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb95b8e2a-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb95b8e2b-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tIV/s4001/c"},"text":"Pub. L. 101–239, title IV, § 4001(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2133"},"text":"103 Stat. 2133","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/239/tIV/s4001/c"},"text":"“The amendments made by this section [enacting this section] shall apply with respect to budgets for fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"1989-09-30"},"text":"September 30, 1989","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb95b8e2c-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tIV/s4001/b"},"text":"Pub. L. 101–239, title IV, § 4001(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2133"},"text":"103 Stat. 2133","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/239/tIV/s4001/b"},"text":"“Nothing in any amendment made by subsection (a) [enacting this section] shall be considered to diminish the oversight responsibilities or authority of the Congress under law, rule, or regulation with respect to the budget and operations of the United States Postal Service.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
