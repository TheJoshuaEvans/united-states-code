{"tag":"section","attrib":{"id":"idb95dfedb-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2605"},"text":null,"children":[{"tag":"num","attrib":{"value":"2605"},"text":"§ 2605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suits to recover wrongful or fraudulent payments","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Postal Service shall request the Attorney General to bring a suit to recover with interest any payment made from moneys of, or credit granted by, the Postal Service as a result of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95dfedc-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2605/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mistake;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95dfedd-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2605/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fraudulent representations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95dfede-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2605/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collusion; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95dfedf-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2605/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" misconduct of an officer or employee of the Postal Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb95dfee0-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375