{"tag":"section","attrib":{"id":"idb96ea139-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3631"},"text":null,"children":[{"tag":"num","attrib":{"value":"3631"},"text":"§ 3631.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability; definitions and updates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb96ea13a-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3631/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subchapter shall apply with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96ea13b-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3631/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" priority mail;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96ea13c-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3631/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expedited mail;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96ea13d-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3631/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bulk parcel post;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96ea13e-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3631/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bulk international mail; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96ea13f-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3631/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mailgrams;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"subject to subsection (d) and any changes the Postal Regulatory Commission may make under section 3642.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96ea140-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3631/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this subchapter, the term “costs attributable”, as used with respect to a product, means the direct and indirect postal costs attributable to such product through reliably identified causal relationships.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96ea141-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3631/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Mail matter referred to in subsection (a) shall, for purposes of this subchapter, be considered to have the meaning given to such mail matter under the mail classification schedule.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb96ea142-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435/tII/s202"},"text":"Pub. L. 109–435, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3205"},"text":"120 Stat. 3205","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
