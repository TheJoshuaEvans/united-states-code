mendment","id":"idb9414f4a-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/241/s1"},"text":"Pub. L. 105–241, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-09-28"},"text":"Sept. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1572"},"text":"112 Stat. 1572","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/241/s1"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s415"},"text":"section 415 of this title","children":[],"tail":" and amending sections 404 and 3622 of this title, "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s7902"},"text":"section 7902 of Title 5","children":[],"tail":", Government Organization and Employees, and sections 652 and 668 of Title 29, Labor] may be cited as the ‘Postal Employees Safety Enhancement Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb9414f4b-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/41/s1"},"text":"Pub. L. 105–41, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-13"},"text":"Aug. 13, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1119"},"text":"111 Stat. 1119","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/41/s1"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s414"},"text":"section 414 of this title","children":[],"tail":" and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s414"},"text":"section 414 of this title","children":[],"tail":"] may be cited as the ‘Stamp Out Breast Cancer Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb943c04c-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/123/tVII/s701/a"},"text":"Pub. L. 103–123, title VII, § 701(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-10-28"},"text":"Oct. 28, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1267"},"text":"107 Stat. 1267","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/123/tVII/s701/a"},"text":"“This title [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3642"},"text":"section 3642 of this title","children":[],"tail":", amending sections 410, 2401, 3202, 3601, 3625 to 3627, and 3683 of this title, and enacting provisions set out as notes under sections 2401, 3621, 3626, and 3683 of this title] may be cited as the ‘Revenue Forgone Reform Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb943c04d-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/421/s1"},"text":"Pub. L. 94–421, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-24"},"text":"Sept. 24, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1303"},"text":"90 Stat. 1303","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/421/s1"},"text":"“That this Act [amending sections 404, 2003, 2401, 3601, 3604, 3622, 3623, 3624, 3626, 3641, and 3683 of this title, and enacting provisions set out as notes under sections 404, 3601, 3624, 3641, and 3661 of this title] may be cited as the ‘Postal Reorganization Act Amendments of 1976’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idb943c04e-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375/s1"},"text":"Pub. L. 91–375, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/719"},"text":"84 Stat. 719","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/375/s1"},"text":"“That this Act [revising this title, enacting sections 1735 to 1737 of Title 18, Crimes and Criminal Procedure, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s356"},"text":"section 356 of Title 2","children":[],"tail":", The Congress, "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s19"},"text":"section 19 of Title 3","children":[],"tail":", The President, sections 101, 104, 2104, 2105, 3104, 3304a, 4301, 5102, 5303, 5304, 5312, 5314 to 5316, 5541, 6301, 6323, 7101, and 8344 of Title 5, Government Organization and Employees, sections 24 seventh par., 1701d–3, and 1701e of Title 12, Banks and Banking, "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s637"},"text":"section 637 of Title 15","children":[],"tail":", Commerce and Trade, section 460"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–1 of Title 16, Conservation, section 8 of former Title 17, Copyrights, sections 12, 440, 441, 500, 501, 612, 876, 877, 1114, 1303, 1341, 1342, 1463, 1696, 1699, 1703, 1704, 1707, 1709 to 1713, 1715, 1716, 1716A, 1717, 1718, 1721 to 1725, 1729, 1730, 1733, and 3061 of Title 18, "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s611"},"text":"section 611 of Title 22","children":[],"tail":", Foreign Relations and Intercourse, sections 72 fifth par., 129, and 724a of former Title 31, Money and Finance, sections 356, 474, 615, 723, and 724 of former Title 40, Public Buildings, Property, and Works, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2942"},"text":"section 2942 of Title 42","children":[],"tail":", The Public Health and Welfare, repealing "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3327"},"text":"section 3327 of Title 5","children":[],"tail":" and section 1028 of former Title 31, and enacting provisions set out as notes under this section and sections 201, 601, 1001, 1003, 1201, 2002, 2004, 3010, and 3621 of this title] may be cited as the ‘Postal Reorganization Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"separability","id":"idb943c04f-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Severability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/108/tIII/s301"},"text":"Pub. L. 117–108, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-04-06"},"text":"Apr. 6, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1153"},"text":"136 Stat. 1153","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/108/tIII/s301"},"text":"“If any provision of this Act [see Tables for classification] or any amendment made by this Act, or the application of a provision of this Act or an amendment made by this Act to any person or circumstance, is held to be unconstitutional, the remainder of this Act, and the application of the provisions to any person or circumstance, shall not be affected by the holding.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb943c050-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/108/tII/s202/b"},"text":"Pub. L. 117–108, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-04-06"},"text":"Apr. 6, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1147"},"text":"136 Stat. 1147","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/108/tII/s202/b"},"text":"“Nothing in subsection (a) [amending this section] or the amendment made by such subsection is intended to alter or amend the requirements of chapters 20 or 36 of title 39, United States Code, and related implementing regulations, including provisions relating to costing, accounting, or rates.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb943c051-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"COVID–19 Funding for the United States Postal Service","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tVI/s6001"},"text":"Pub. L. 116–136, div. A, title VI, § 6001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/504"},"text":"134 Stat. 504","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/tVIII/s801"},"text":"Pub. L. 116–260, div. N, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2119"},"text":"134 Stat. 2119","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dN/tVIII/s801"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘COVID–19 emergency’ means the emergency involving Federal primary responsibility determined to exist by the President under section 501(b) of the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5191/b"},"text":"42 U.S.C. 5191(b)","children":[],"tail":") with respect to the Coronavirus Disease 2019 (COVID–19); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘Postal Service’ means the United States Postal Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Borrowing Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s2005"},"text":"section 2005 of title 39","children":[],"tail":", United States Code, or any other provision of law, if the Postal Service determines that, due to the COVID–19 emergency, the Postal Service will not be able to fund operating expenses without borrowing money—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Postal Service may borrow money from the Treasury in an amount not to exceed $10,000,000,000—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be used for such operating expenses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which may not be used to pay any outstanding debt of the Postal Service; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Treasury may lend up to the amount described in paragraph (1) at the request of the Postal Service, upon terms and conditions mutually agreed upon by the Secretary and the Postal Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Repayment Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, including subsection (b) of this section, or any agreement entered into between the Secretary of the Treasury and the Postal Service under that subsection, the Postal Service shall not be required to repay the amounts borrowed under that subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prioritization of Delivery for Medical Purposes During COVID–","children":[],"tail":"19"},{"tag":"inline","attrib":{},"text":" Emergency","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, during the COVID–19 emergency, the Postal Service—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall prioritize delivery of postal products for medical purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may establish temporary delivery points, in such form and manner as the Postal Service determines necessary, to protect employees of the Postal Service and individuals receiving deliveries from the Postal Service.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
