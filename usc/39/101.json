t’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb9414f45-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dJ/tIII/s301/a"},"text":"Pub. L. 108–447, div. J, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3350"},"text":"118 Stat. 3350","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/447/dJ/tIII/s301/a"},"text":"“This title [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s5402"},"text":"section 5402 of this title","children":[],"tail":"] may be cited as the ‘Rural Air Service Improvement Act of 2004’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb9414f46-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/86/s1"},"text":"Pub. L. 108–86, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-09-30"},"text":"Sept. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1052"},"text":"117 Stat. 1052","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/86/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s1004"},"text":"section 1004 of this title","children":[],"tail":" and enacting provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s1004"},"text":"section 1004 of this title","children":[],"tail":"] may be cited as the ‘Postmasters Equity Act of 2003’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb9414f47-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/206/tIII/s3002/a"},"text":"Pub. L. 107–206, title III, § 3002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-02"},"text":"Aug. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/910"},"text":"116 Stat. 910","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/206/tIII/s3002/a"},"text":"“This title [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s5402"},"text":"section 5402 of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2703"},"text":"section 2703 of Title 19","children":[],"tail":", Customs Duties, "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1626"},"text":"section 1626 of Title 43","children":[],"tail":", Public Lands, and "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s41901"},"text":"section 41901 of Title 49","children":[],"tail":", Transportation, and enacting provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s5402"},"text":"section 5402 of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t1/s112"},"text":"section 112 of Title 1","children":[],"tail":", General Provisions, and sections 2703 and 3203 of Title 19] may be cited as the ‘Rural Service Improvement Act of 2002’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb9414f48-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2001 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"tex