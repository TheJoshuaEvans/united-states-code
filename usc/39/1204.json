{"tag":"section","attrib":{"id":"idb956d35a-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s1204"},"text":null,"children":[{"tag":"num","attrib":{"value":"1204"},"text":"§ 1204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elections","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb956d35b-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s1204/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All elections authorized under this chapter shall be conducted under the supervision of the National Labor Relations Board, or persons designated by it, and shall be by secret ballot. Each employee eligible to vote shall be provided the opportunity to choose the labor organization he wishes to represent him, from among those on the ballot, or “no union”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb956d35c-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s1204/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any election where none of the choices on the ballot receives a majority, a runoff shall be conducted, the ballot providing for a selection between the 2 choices receiving the largest and second largest number of valid votes cast in the election. In the event of a tie vote, additional runoff elections shall be conducted until one of the choices has received a majority of the votes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb956d35d-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s1204/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No election shall be held in any bargaining unit within which, in the preceding 12-month period, a valid election has been held.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb956d35e-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/735"},"text":"84 Stat. 735","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb956d35f-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb956d360-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9594461-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1971-07-01"},"text":"July 1, 1971","children":[],"tail":", pursuant to Resolution No. 71–9 of the Board of Governors. See "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
