{"tag":"section","attrib":{"id":"idb952181e-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s503"},"text":null,"children":[{"tag":"num","attrib":{"value":"503"},"text":"§ 503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules; regulations; procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Postal Regulatory Commission shall promulgate rules and regulations and establish procedures, subject to chapters 5 and 7 of title 5, and take any other action they deem necessary and proper to carry out their functions and obligations to the Government of the United States and the people as prescribed under this title. Such rules, regulations, procedures, and actions shall not be subject to any change or supervision by the Postal Service.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb952181f-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/759"},"text":"84 Stat. 759","children":[],"tail":", § 3603; renumbered § 503 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/435/tVI"},"text":"Pub. L. 109–435, title VI","children":[],"tail":", §§ 601(a)(3), 604(a), title X, 1010(c)(1), "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3239"},"text":"120 Stat. 3239","children":[],"tail":", 3241, 3261.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9521820-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9521821-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9521822-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435/s1010/c/1"},"text":"Pub. L. 109–435, § 1010(c)(1)","children":[],"tail":", substituted “this title” for “this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435/s604/a"},"text":"Pub. L. 109–435, § 604(a)","children":[],"tail":", substituted “Postal Regulatory Commission” for “Postal Rate Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435/s601/a/3"},"text":"Pub. L. 109–435, § 601(a)(3)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s3603"},"text":"section 3603 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
