{"tag":"section","attrib":{"id":"idb95dfed0-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s2603"},"text":null,"children":[{"tag":"num","attrib":{"value":"2603"},"text":"§ 2603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Settlement of claims for damages caused by the Postal Service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When the Postal Service finds a claim for damage to persons or property resulting from the operation of the Postal Service to be a proper charge against the United States, and it is not cognizable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2672"},"text":"section 2672 of title 28","children":[],"tail":", it may adjust and settle the claim."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb95dfed1-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/745"},"text":"84 Stat. 745","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb95dfed2-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb95dfed3-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb95dfed4-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1971-07-01"},"text":"July 1, 1971","children":[],"tail":", pursuant to Resolution No. 71–9 of the Board of Governors. See "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb95dfed5-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Charge Against Postal Revenues for Settlement of Claims for Damages and for Losses Resulting From Unavoidable Casualty","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/57/tII/s201"},"text":"Pub. L. 89–57, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-30"},"text":"June 30, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/200"},"text":"79 Stat. 200","children":[],"tail":", provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/57/tII/s201"},"text":"“That hereafter settlement of claims, pursuant to law, current and prior fiscal years, for damages, and for losses resulting from unavoidable casualty shall be paid from postal revenues.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
