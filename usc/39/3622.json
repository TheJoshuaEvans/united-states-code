{"tag":"section","attrib":{"id":"idb96c568e-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622"},"text":null,"children":[{"tag":"num","attrib":{"value":"3622"},"text":"§ 3622.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modern rate regulation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb96c568f-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority Generally","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Postal Regulatory Commission shall, within 18 months after the date of enactment of this section, by regulation establish (and may from time to time thereafter by regulation revise) a modern system for regulating rates and classes for market-dominant products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96c5690-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Objectives","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such system shall be designed to achieve the following objectives, each of which shall be applied in conjunction with the others:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96c5691-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To maximize incentives to reduce costs and increase efficiency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96c5692-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To create predictability and stability in rates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96c5693-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To maintain high quality service standards established under section 3691.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96c5694-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To allow the Postal Service pricing flexibility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96c5695-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To assure adequate revenues, including retained earnings, to maintain financial stability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96c5696-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To reduce the administrative burden and increase the transparency of the ratemaking process.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96c5697-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To enhance mail security and deter terrorism.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96c5698-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To establish and maintain a just and reasonable schedule for rates and classifications, however the objective under this paragraph shall not be construed to prohibit the Postal Service from making changes of unequal magnitude within, between, or among classes of mail.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96c5699-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To allocate the total institutional costs of the Postal Service appropriately between market-dominant and competitive products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96c569a-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Factors","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing or revising such system, the Postal Regulatory Commission shall take into account—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96c569b-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of the mail service actually provided each class or type of mail service to both the sender and the recipient, including but not limited to the collection, mode of transportation, and priority of delivery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96c569c-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirement that each class of mail or type of mail service bear the direct and indirect postal costs attributable to each class or type of mail service through reliably identified causal relationships plus that portion of all other costs of the Postal Service reasonably assignable to such class or type;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96c569d-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of rate increases upon the general public, business mail users, and enterprises in the private sector of the economy engaged in the delivery of mail matter other than letters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96c569e-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the available alternative means of sending and receiving letters and other mail matter at reasonable costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96c569f-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree of preparation of mail for delivery into the postal system performed by the mailer and its effect upon reducing costs to the Postal Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96c56a0-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" simplicity of structure for the entire schedule and simple, identifiable relationships between the rates or fees charged the various classes of mail for postal services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96c56a1-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the importance of pricing flexibility to encourage increased mail volume and operational efficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96c56a2-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relative value to the people of the kinds of mail matter entered into the postal system and the desirability and justification for special classifications and services of mail;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96c56a3-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the importance of providing classifications with extremely high degrees of reliability and speed of delivery and of providing those that do not require high degrees of reliability and speed of delivery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96c56a4-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the desirability of special classifications for both postal users and the Postal Service in accordance with the policies of this title, including agreements between the Postal Service and postal users, when available on public and reasonable terms to similarly situated mailers, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb96c56a5-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/c/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" either—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb96c56a6-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/c/10/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the net financial position of the Postal Service through reducing Postal Service costs or increasing the overall contribution to the institutional costs of the Postal Service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb96c56a7-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/c/10/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance the performance of mail preparation, processing, transportation, or other functions; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96c56a8-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/c/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do not cause unreasonable harm to the marketplace.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96c56a9-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the educational, cultural, scientific, and informational value to the recipient of mail matter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96c56aa-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/c/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for the Postal Service to increase its efficiency and reduce its costs, including infrastructure costs, to help maintain high quality, affordable postal services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96c56ab-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/c/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value to the Postal Service and postal users of promoting intelligent mail and of secure, sender-identified mail; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96c56ac-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/c/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the policies of this title as well as such other factors as the Commission determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96c56ad-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96c56ae-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The system for regulating rates and classes for market-dominant products shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb96c56af-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include an annual limitation on the percentage changes in rates to be set by the Postal Regulatory Commission that will be equal to the change in the Consumer Price Index for All Urban Consumers unadjusted for seasonal variation over the most recent available 12-month period preceding the date the Postal Service files notice of its intention to increase rates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96c56b0-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a schedule whereby rates, when necessary and appropriate, would change at regular intervals by predictable amounts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96c56b1-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 45 days before the implementation of any adjustment in rates under this section, including adjustments made under subsection (c)(10)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb96c56b2-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/d/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the Postal Service to provide public notice of the adjustment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb96c56b3-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/d/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an opportunity for review by the Postal Regulatory Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb96c56b4-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/d/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the Postal Regulatory Commission to notify the Postal Service of any noncompliance of the adjustment with the limitation under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb96c56b5-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/d/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the Postal Service to respond to the notice provided under clause (iii) and describe the actions to be taken to comply with the limitation under subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96c56b6-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish procedures whereby the Postal Service may adjust rates not in excess of the annual limitations under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96c56b7-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding any limitation set under subparagraphs (A) and (C), and provided there is not sufficient unused rate authority under paragraph (2)(C), establish procedures whereby rates may be adjusted on an expedited basis due to either extraordinary or exceptional circumstances, provided that the Commission determines, after notice and opportunity for a public hearing and comment, and within 90 days after any request by the Postal Service, that such adjustment is reasonable and equitable and necessary to enable the Postal Service, under best practices of honest, efficient, and economical management, to maintain and continue the development of postal services of the kind and quality adapted to the needs of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96c56b8-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb96c56b9-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Classes of mail","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided under subparagraph (C), the annual limitations under paragraph (1)(A) shall apply to a class of mail, as defined in the Domestic Mail Classification Schedule as in effect on the date of enactment of the Postal Accountability and Enhancement Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96c56ba-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rounding of rates and fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this subsection shall preclude the Postal Service from rounding rates and fees to the nearest whole integer, if the effect of such rounding does not cause the overall rate increase for any class to exceed the Consumer Price Index for All Urban Consumers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96c56bb-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of unused rate authority.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idb96c56bc-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subparagraph, the term “unused rate adjustment authority” means the difference between—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb96c56bd-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/d/2/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maximum amount of a rate adjustment that the Postal Service is authorized to make in any year subject to the annual limitation under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb96c56be-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/d/2/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the rate adjustment the Postal Service actually makes in that year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb96c56bf-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to clause (iii), the Postal Service may use any unused rate adjustment authority for any of the 5 years following the year such authority occurred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb96c56c0-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/d/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In exercising the authority under clause (ii) in any year, the Postal Service—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb96c56c1-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/d/2/C/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may use unused rate adjustment authority from more than 1 year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb96c56c2-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/d/2/C/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may use any part of the unused rate adjustment authority from any year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb96c56c3-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/d/2/C/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall use the unused rate adjustment authority from the earliest year such authority first occurred and then each following year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb96c56c4-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/d/2/C/iii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any class or service, may not exceed the annual limitation under paragraph (1) by more than 2 percentage points.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96c56c5-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Ten years after the date of enactment of the Postal Accountability and Enhancement Act and as appropriate thereafter, the Commission shall review the system for regulating rates and classes for market-dominant products established under this section to determine if the system is achieving the objectives in subsection (b), taking into account the factors in subsection (c). If the Commission determines, after notice and opportunity for public comment, that the system is not achieving the objectives in subsection (b), taking into account the factors in subsection (c), the Commission may, by regulation, make such modification or adopt such alternative system for regulating rates and classes for market-dominant products as necessary to achieve the objectives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96c56c6-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Workshare Discounts.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96c56c7-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the term “workshare discount” refers to rate discounts provided to mailers for the presorting, prebarcoding, handling, or transportation of mail, as further defined by the Postal Regulatory Commission under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96c56c8-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Postal Regulatory Commission shall ensure that such discounts do not exceed the cost that the Postal Service avoids as a result of workshare activity, unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb96c56c9-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the discount is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb96c56ca-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" associated with a new postal service, a change to an existing postal service, or with a new work share initiative related to an existing postal service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb96c56cb-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary to induce mailer behavior that furthers the economically efficient operation of the Postal Service and the portion of the discount in excess of the cost that the Postal Service avoids as a result of the workshare activity will be phased out over a limited period of time;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96c56cc-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the amount of the discount above costs avoided—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb96c56cd-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is necessary to mitigate rate shock; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb96c56ce-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be phased out over time;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96c56cf-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the discount is provided in connection with subclasses of mail consisting exclusively of mail matter of educational, cultural, scientific, or informational value; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96c56d0-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduction or elimination of the discount would impede the efficient operation of the Postal Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96c56d1-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subsection shall require that a work share discount be reduced or eliminated if the reduction or elimination of the discount would—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb96c56d2-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lead to a loss of volume in the affected category or subclass of mail and reduce the aggregate contribution to the institutional costs of the Postal Service from the category or subclass subject to the discount below what it otherwise would have been if the discount had not been reduced or eliminated; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96c56d3-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" result in a further increase in the rates paid by mailers not able to take advantage of the discount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96c56d4-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever the Postal Service establishes a workshare discount rate, the Postal Service shall, at the time it publishes the workshare discount rate, submit to the Postal Regulatory Commission a detailed report that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb96c56d5-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explains the Postal Service’s reasons for establishing the rate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96c56d6-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sets forth the data, economic analyses, and other information relied on by the Postal Service to justify the rate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96c56d7-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/e/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certifies that the discount will not adversely affect rates or services provided to users of postal services who do not take advantage of the discount rate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96c56d8-2930-11f1-bc69-dbd19d1ebdf3","identifier":"/us/usc/t39/s3622/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transition Rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the 1-year period beginning on the date of enactment of this section, rates and classes for market-dominant products shall remain subject to modification in accordance with the provisions of this chapter and section 407, as such provisions were last in effect before the date of enactment of this section. Proceedings initiated to consider a request for a recommended decision filed by the Postal Service during that 1-year period shall be completed in accordance with subchapter II of chapter 36 of this title and implementing regulations, as in effect before the date of enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb96c56d9-2930-11f1-bc69-dbd19d1ebdf3"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435/tII/s201/a"},"text":"Pub. L. 109–435, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3201"},"text":"120 Stat. 3201","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb96c56da-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb96c56db-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb96c56dc-2930-11f1-bc69-dbd19d1ebdf3"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section and the date of enactment of the Postal Accountability and Enhancement Act, referred to in subsecs. (a), (d)(2)(A), (3), and (f), are the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435"},"text":"Pub. L. 109–435","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb96c56dd-2930-11f1-bc69-dbd19d1ebdf3"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3622, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/760"},"text":"84 Stat. 760","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/421/s10"},"text":"Pub. L. 94–421, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-24"},"text":"Sept. 24, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1311"},"text":"90 Stat. 1311","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/241/s5"},"text":"Pub. L. 105–241, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-09-28"},"text":"Sept. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1573"},"text":"112 Stat. 1573","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/384/s1/a"},"text":"Pub. L. 106–384, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-27"},"text":"Oct. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1460"},"text":"114 Stat. 1460","children":[],"tail":", related to rates and fees, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/109/435/tII/s201/a"},"text":"Pub. L. 109–435, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3200"},"text":"120 Stat. 3200","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
