{"tag":"section","attrib":{"id":"id7ca58240-76cd-11f0-b8ae-e369934592a4","identifier":"/us/usc/t9/s401"},"text":null,"children":[{"tag":"num","attrib":{"value":"401"},"text":"§ 401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ca58241-76cd-11f0-b8ae-e369934592a4","identifier":"/us/usc/t9/s401/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Predispute arbitration agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “predispute arbitration agreement” means any agreement to arbitrate a dispute that had not yet arisen at the time of the making of the agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ca58242-76cd-11f0-b8ae-e369934592a4","identifier":"/us/usc/t9/s401/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Predispute joint-action waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “predispute joint-action waiver” means an agreement, whether or not part of a predispute arbitration agreement, that would prohibit, or waive the right of, one of the parties to the agreement to participate in a joint, class, or collective action in a judicial, arbitral, administrative, or other forum, concerning a dispute that has not yet arisen at the time of the making of the agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ca58243-76cd-11f0-b8ae-e369934592a4","identifier":"/us/usc/t9/s401/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sexual assault dispute","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “sexual assault dispute” means a dispute involving a nonconsensual sexual act or sexual contact, as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2246"},"text":"section 2246 of title 18","children":[],"tail":" or similar applicable Tribal or State law, including when the victim lacks capacity to consent."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ca58244-76cd-11f0-b8ae-e369934592a4","identifier":"/us/usc/t9/s401/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sexual harassment dispute","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “sexual harassment dispute” means a dispute relating to conduct that is alleged to constitute sexual harassment under applicable Federal, Tribal, or State law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ca58245-76cd-11f0-b8ae-e369934592a4"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/90/s2/a"},"text":"Pub. L. 117–90, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-03"},"text":"Mar. 3, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/26"},"text":"136 Stat. 26","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7ca58246-76cd-11f0-b8ae-e369934592a4"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7ca58247-76cd-11f0-b8ae-e369934592a4"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7ca58248-76cd-11f0-b8ae-e369934592a4"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/90/s3"},"text":"Pub. L. 117–90, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-03"},"text":"Mar. 3, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/28"},"text":"136 Stat. 28","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/90/s3"},"text":"“This Act [see Short Title of 2022 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t9/s1"},"text":"section 1 of this title","children":[],"tail":"], and the amendments made by this Act, shall apply with respect to any dispute or claim that arises or accrues on or after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-03-03"},"text":"Mar. 3, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
