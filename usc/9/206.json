{"tag":"section","attrib":{"id":"id7ca581fb-76cd-11f0-b8ae-e369934592a4","identifier":"/us/usc/t9/s206"},"text":null,"children":[{"tag":"num","attrib":{"value":"206"},"text":"§ 206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Order to compel arbitration; appointment of arbitrators","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A court having jurisdiction under this chapter may direct that arbitration be held in accordance with the agreement at any place therein provided for, whether that place is within or without the United States. Such court may also appoint arbitrators in accordance with the provisions of the agreement.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7ca581fc-76cd-11f0-b8ae-e369934592a4"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/368/s1"},"text":"Pub. L. 91–368, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-07-31"},"text":"July 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/693"},"text":"84 Stat. 693","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7ca581fd-76cd-11f0-b8ae-e369934592a4"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7ca581fe-76cd-11f0-b8ae-e369934592a4"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7ca581ff-76cd-11f0-b8ae-e369934592a4"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the entry into force of the Convention on Recognition and Enforcement of Foreign Arbitral Awards with respect to the United States (","children":[{"tag":"date","attrib":{"date":"1970-12-29"},"text":"Dec. 29, 1970","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/91/368/s4"},"text":"section 4 of Pub. L. 91–368","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t9/s201"},"text":"section 201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
