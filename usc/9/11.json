{"tag":"section","attrib":{"id":"id7ca310ad-76cd-11f0-b8ae-e369934592a4","identifier":"/us/usc/t9/s11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"§ 11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Same; modification or correction; grounds; order","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In either of the following cases the United States court in and for the district wherein the award was made may make an order modifying or correcting the award upon the application of any party to the arbitration—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7ca310ae-76cd-11f0-b8ae-e369934592a4","identifier":"/us/usc/t9/s11/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Where there was an evident material miscalculation of figures or an evident material mistake in the description of any person, thing, or property referred to in the award.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ca310af-76cd-11f0-b8ae-e369934592a4","identifier":"/us/usc/t9/s11/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Where the arbitrators have awarded upon a matter not submitted to them, unless it is a matter not affecting the merits of the decision upon the matter submitted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ca310b0-76cd-11f0-b8ae-e369934592a4","identifier":"/us/usc/t9/s11/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Where the award is imperfect in matter of form not affecting the merits of the controversy.","children":[{"tag":"p","attrib":{},"text":"The order may modify and correct the award, so as to effect the intent thereof and promote justice between the parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ca310b1-76cd-11f0-b8ae-e369934592a4"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-30/ch392"},"text":"July 30, 1947, ch. 392","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/673"},"text":"61 Stat. 673","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7ca310b2-76cd-11f0-b8ae-e369934592a4"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"derivation","id":"id7ca310b3-76cd-11f0-b8ae-e369934592a4"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Derivation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1925-02-12/ch213/s11"},"text":"Act Feb. 12, 1925, ch. 213, § 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/885"},"text":"43 Stat. 885","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
