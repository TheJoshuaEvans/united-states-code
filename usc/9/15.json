{"tag":"section","attrib":{"id":"id7ca310c5-76cd-11f0-b8ae-e369934592a4","identifier":"/us/usc/t9/s15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"§ 15.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability of the Act of State doctrine","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Enforcement of arbitral agreements, confirmation of arbitral awards, and execution upon judgments based on orders confirming such awards shall not be refused on the basis of the Act of State doctrine.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7ca310c6-76cd-11f0-b8ae-e369934592a4"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/669/s1"},"text":"Pub. L. 100–669, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-16"},"text":"Nov. 16, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3969"},"text":"102 Stat. 3969","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7ca310c7-76cd-11f0-b8ae-e369934592a4"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7ca310c8-76cd-11f0-b8ae-e369934592a4"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7ca310c9-76cd-11f0-b8ae-e369934592a4"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t9/s15"},"text":"section 15 of this title","children":[],"tail":" was renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t9/s16"},"text":"section 16 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"