{"tag":"section","attrib":{"id":"id7ca310ec-76cd-11f0-b8ae-e369934592a4","identifier":"/us/usc/t9/s203"},"text":null,"children":[{"tag":"num","attrib":{"value":"203"},"text":"§ 203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction; amount in controversy","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An action or proceeding falling under the Convention shall be deemed to arise under the laws and treaties of the United States. The district courts of the United States (including the courts enumerated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s460"},"text":"section 460 of title 28","children":[],"tail":") shall have original jurisdiction over such an action or proceeding, regardless of the amount in controversy."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7ca581ed-76cd-11f0-b8ae-e369934592a4"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/368/s1"},"text":"Pub. L. 91–368, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-07-31"},"text":"July 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/692"},"text":"84 Stat. 692","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7ca581ee-76cd-11f0-b8ae-e369934592a4"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7ca581ef-76cd-11f0-b8ae-e369934592a4"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7ca581f0-76cd-11f0-b8ae-e369934592a4"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the entry into force of the Convention on Recognition and Enforcement of Foreign Arbitral Awards with respect to the United States (","children":[{"tag":"date","attrib":{"date":"1970-12-29"},"text":"Dec. 29, 1970","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/91/368/s4"},"text":"section 4 of Pub. L. 91–368","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t9/s201"},"text":"section 201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
