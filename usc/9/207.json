{"tag":"section","attrib":{"id":"id7ca58200-76cd-11f0-b8ae-e369934592a4","identifier":"/us/usc/t9/s207"},"text":null,"children":[{"tag":"num","attrib":{"value":"207"},"text":"§ 207.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award of arbitrators; confirmation; jurisdiction; proceeding","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Within three years after an arbitral award falling under the Convention is made, any party to the arbitration may apply to any court having jurisdiction under this chapter for an order confirming the award as against any other party to the arbitration. The court shall confirm the award unless it finds one of the grounds for refusal or deferral of recognition or enforcement of the award specified in the said Convention.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7ca58201-76cd-11f0-b8ae-e369934592a4"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/368/s1"},"text":"Pub. L. 91–368, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-07-31"},"text":"July 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/693"},"text":"84 Stat. 693","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7ca58202-76cd-11f0-b8ae-e369934592a4"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7ca58203-76cd-11f0-b8ae-e369934592a4"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7ca58204-76cd-11f0-b8ae-e369934592a4"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the entry into force of the Convention on Recognition and Enforcement of Foreign Arbitral Awards with respect to the United States (","children":[{"tag":"date","attrib":{"date":"1970-12-29"},"text":"Dec. 29, 1970","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/91/368/s4"},"text":"section 4 of Pub. L. 91–368","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t9/s201"},"text":"section 201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
