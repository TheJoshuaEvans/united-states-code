{"tag":"section","attrib":{"id":"id7ca58228-76cd-11f0-b8ae-e369934592a4","identifier":"/us/usc/t9/s305"},"text":null,"children":[{"tag":"num","attrib":{"value":"305"},"text":"§ 305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship between the Inter-American Convention and the Convention on the Recognition and Enforcement of Foreign Arbitral Awards of ","children":[{"tag":"date","attrib":{"date":"1958-06-10"},"text":"June 10, 1958","children":[],"tail":null}],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"When the requirements for application of both the Inter-American Convention and the Convention on the Recognition and Enforcement of Foreign Arbitral Awards of ","children":[{"tag":"date","attrib":{"date":"1958-06-10"},"text":"June 10, 1958","children":[],"tail":", are met, determination as to which Convention applies shall, unless otherwise expressly agreed, be made as follows:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ca58229-76cd-11f0-b8ae-e369934592a4","identifier":"/us/usc/t9/s305/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a majority of the parties to the arbitration agreement are citizens of a State or States that have ratified or acceded to the Inter-American Convention and are member States of the Organization of American States, the Inter-American Convention shall apply.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ca5822a-76cd-11f0-b8ae-e369934592a4","identifier":"/us/usc/t9/s305/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In all other cases the Convention on the Recognition and Enforcement of Foreign Arbitral Awards of ","children":[{"tag":"date","attrib":{"date":"1958-06-10"},"text":"June 10, 1958","children":[],"tail":", shall apply."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ca5822b-76cd-11f0-b8ae-e369934592a4"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/369/s1"},"text":"Pub. L. 101–369, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-15"},"text":"Aug. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/449"},"text":"104 Stat. 449","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7ca5822c-76cd-11f0-b8ae-e369934592a4"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7ca5822d-76cd-11f0-b8ae-e369934592a4"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7ca5822e-76cd-11f0-b8ae-e369934592a4"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the entry into force of the Inter-American Convention on International Commercial Arbitration of ","children":[{"tag":"date","attrib":{"date":"1975-01-30"},"text":"January 30, 1975","children":[],"tail":", with respect to the United States ("},{"tag":"date","attrib":{"date":"1990-10-27"},"text":"Oct. 27, 1990","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/101/369/s3"},"text":"section 3 of Pub. L. 101–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t9/s301"},"text":"section 301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
