{"tag":"section","attrib":{"id":"id7ca5821c-76cd-11f0-b8ae-e369934592a4","identifier":"/us/usc/t9/s303"},"text":null,"children":[{"tag":"num","attrib":{"value":"303"},"text":"§ 303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Order to compel arbitration; appointment of arbitrators; locale","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7ca5821d-76cd-11f0-b8ae-e369934592a4","identifier":"/us/usc/t9/s303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A court having jurisdiction under this chapter may direct that arbitration be held in accordance with the agreement at any place therein provided for, whether that place is within or without the United States. The court may also appoint arbitrators in accordance with the provisions of the agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ca5821e-76cd-11f0-b8ae-e369934592a4","identifier":"/us/usc/t9/s303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the event the agreement does not make provision for the place of arbitration or the appointment of arbitrators, the court shall direct that the arbitration shall be held and the arbitrators be appointed in accordance with Article 3 of the Inter-American Convention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ca5821f-76cd-11f0-b8ae-e369934592a4"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/369/s1"},"text":"Pub. L. 101–369, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-15"},"text":"Aug. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/448"},"text":"104 Stat. 448","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7ca58220-76cd-11f0-b8ae-e369934592a4"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7ca58221-76cd-11f0-b8ae-e369934592a4"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7ca58222-76cd-11f0-b8ae-e369934592a4"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the entry into force of the Inter-American Convention on International Commercial Arbitration of ","children":[{"tag":"date","attrib":{"date":"1975-01-30"},"text":"January 30, 1975","children":[],"tail":", with respect to the United States ("},{"tag":"date","attrib":{"date":"1990-10-27"},"text":"Oct. 27, 1990","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/101/369/s3"},"text":"section 3 of Pub. L. 101–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t9/s301"},"text":"section 301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
