{"tag":"section","attrib":{"id":"id7ca5822f-76cd-11f0-b8ae-e369934592a4","identifier":"/us/usc/t9/s306"},"text":null,"children":[{"tag":"num","attrib":{"value":"306"},"text":"§ 306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable rules of Inter-American Commercial Arbitration Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7ca58230-76cd-11f0-b8ae-e369934592a4","identifier":"/us/usc/t9/s306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this chapter the rules of procedure of the Inter-American Commercial Arbitration Commission referred to in Article 3 of the Inter-American Convention shall, subject to subsection (b) of this section, be those rules as promulgated by the Commission on ","children":[{"tag":"date","attrib":{"date":"1988-07-01"},"text":"July 1, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ca58231-76cd-11f0-b8ae-e369934592a4","identifier":"/us/usc/t9/s306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the event the rules of procedure of the Inter-American Commercial Arbitration Commission are modified or amended in accordance with the procedures for amendment of the rules of that Commission, the Secretary of State, by regulation in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":", consistent with the aims and purposes of this Convention, may prescribe that such modifications or amendments shall be effective for purposes of this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ca58232-76cd-11f0-b8ae-e369934592a4"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/369/s1"},"text":"Pub. L. 101–369, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-15"},"text":"Aug. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/449"},"text":"104 Stat. 449","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7ca58233-76cd-11f0-b8ae-e369934592a4"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7ca58234-76cd-11f0-b8ae-e369934592a4"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7ca58235-76cd-11f0-b8ae-e369934592a4"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the entry into force of the Inter-American Convention on International Commercial Arbitration of ","children":[{"tag":"date","attrib":{"date":"1975-01-30"},"text":"January 30, 1975","children":[],"tail":", with respect to the United States ("},{"tag":"date","attrib":{"date":"1990-10-27"},"text":"Oct. 27, 1990","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/101/369/s3"},"text":"section 3 of Pub. L. 101–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t9/s301"},"text":"section 301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
