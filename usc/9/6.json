{"tag":"section","attrib":{"id":"id7ca0c79e-76cd-11f0-b8ae-e369934592a4","identifier":"/us/usc/t9/s6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"§ 6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application heard as motion","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any application to the court hereunder shall be made and heard in the manner provided by law for the making and hearing of motions, except as otherwise herein expressly provided.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7ca0c79f-76cd-11f0-b8ae-e369934592a4"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-30/ch392"},"text":"July 30, 1947, ch. 392","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/671"},"text":"61 Stat. 671","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7ca0c7a0-76cd-11f0-b8ae-e369934592a4"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"derivation","id":"id7ca0c7a1-76cd-11f0-b8ae-e369934592a4"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Derivation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1925-02-12/ch213/s6"},"text":"Act Feb. 12, 1925, ch. 213, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/884"},"text":"43 Stat. 884","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
