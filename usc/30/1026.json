{"tag":"section","attrib":{"id":"id602f32c9-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026"},"text":null,"children":[{"tag":"num","attrib":{"value":"1026"},"text":"§ 1026.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Significant thermal features","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id602f32ca-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Units of National Park System","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id602f32cb-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall maintain a list of significant thermal features, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1001/f"},"text":"section 1001(f) of this title","children":[],"tail":", within units of the National Park System, including but not limited to the following units:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id602f32cc-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mount Rainier National Park.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602f32cd-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Crater Lake National Park.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602f32ce-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Yellowstone National Park.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602f32cf-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" John D. Rockefeller, Jr. Memorial Parkway.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602f32d0-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Bering Land Bridge National Preserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602f32d1-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Gates of the Arctic National Park and Preserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602f32d2-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Katmai National Park.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602f32d3-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Aniakchak National Monument and Preserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602f32d4-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/a/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Wrangell-St. Elias National Park and Preserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602f32d5-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/a/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lake Clark National Park and Preserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602f32d6-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/a/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hot Springs National Park.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602f32d7-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/a/1/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Big Bend National Park (including that portion of the Rio Grande National Wild Scenic River within the boundaries of Big Bend National Park).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602f32d8-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/a/1/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lassen Volcanic National Park.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602f32d9-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/a/1/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hawaiʻi Volcanoes National Park.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602f32da-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/a/1/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Haleakala̅ National Park.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602f32db-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/a/1/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lake Mead National Recreation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602f32dc-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may, after notice and public comment, add significant thermal features within units of the National Park System to the significant thermal features list.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602f32dd-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall consider the following criteria in determining the significance of thermal features:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id602f32de-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Size, extent and uniqueness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602f32df-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Scientific and geologic significance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602f32e0-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which such features remain in a natural, undisturbed condition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602f32e1-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Significance of thermal features to the authorized purposes for which the National Park System unit was established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id602f32e2-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id602f32e3-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall maintain a monitoring program for significant thermal features within units of the National Park System.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602f32e4-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As part of the monitoring program required by paragraph (1), the Secretary shall establish a research program to collect and assess data on the geothermal resources within units of the National Park System with significant thermal features. Such program shall be carried out by the National Park Service in cooperation with the U.S. Geological Survey and shall begin with the collection and assessment of data for significant thermal features near current or proposed geothermal development and shall also include such features near areas of potential geothermal development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id602f32e5-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lease application; adverse effect","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id602f32e6-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon receipt of an application for a lease under this chapter, the Secretary shall determine on the basis of scientific evidence if exploration, development or utilization of the lands subject to the lease application is reasonably likely to result in a significant adverse effect on a significant thermal feature within a unit of the National Park System. Such determination shall be subject to notice and public comment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602f32e7-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary determines that the exploration, development or utilization of the land subject to the lease application is reasonably likely to result in a significant adverse effect on a significant thermal feature within a unit of the National Park System, the Secretary shall not issue such lease.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602f32e8-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall not issue any lease under this chapter for those lands, or portions thereof, which are the subject of a determination made pursuant to subparagraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id602f32e9-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lease stipulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to all leases or drilling permits issued, extended, renewed or modified under this chapter, the Secretary shall include stipulations in such leases and permits necessary to protect significant thermal features within units of the National Park System where the Secretary determines that, based on scientific evidence, the exploration, development or utilization of the land subject to the lease or drilling permit is reasonably likely to adversely affect any such significant thermal feature. Stipulations shall include, but not be limited to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id602f32ea-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requiring the lessee to reinject geothermal fluids into the rock formations from which they originate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602f32eb-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requiring the lessee to report annually to the Secretary on activities taken on the lease;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602f32ec-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requiring the lessee to continuously monitor geothermal resources production and injection wells; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602f32ed-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requiring the lessee to suspend activity on the lease if the Secretary determines that ongoing exploration, development or utilization activities are having a significant adverse effect on a significant thermal feature within a unit of the National Park System until such time as the significant adverse effect is eliminated. The stipulation shall provide for the termination of the lease by the Secretary if the significant adverse effect cannot be eliminated within a reasonable period of time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id602f32ee-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lands administered by Department of Agriculture","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall consider the effects on significant thermal features within units of the National Park System in determining whether to consent to leasing under this chapter on national forest lands or other lands administered by the Department of Agriculture available for leasing under this chapter, including public, withdrawn, and acquired lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id602f32ef-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1026/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall affect the ban on leasing under this chapter with respect to the Island Park Geothermal Area, as designated by the map in the “Final Environmental Impact Statement of the Island Park Geothermal Area” (","children":[{"tag":"date","attrib":{"date":"1980-01-15"},"text":"January 15, 1980","children":[],"tail":", p. XI), and provided for in "},{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Public Law 98–473","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id602f32f0-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/581/s28"},"text":"Pub. L. 91–581, § 28","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/443/s6"},"text":"Pub. L. 100–443, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-22"},"text":"Sept. 22, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1769"},"text":"102 Stat. 1769","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/510/s3/a/2"},"text":"Pub. L. 106–510, § 3(a)(2)","children":[],"tail":", (b)(2), "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2363"},"text":"114 Stat. 2363","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tII/s236/1"},"text":"Pub. L. 109–58, title II, § 236(1)","children":[],"tail":", (26), "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/671"},"text":"119 Stat. 671","children":[],"tail":", 673.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id602f32f1-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id602f32f2-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id602f32f3-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Public Law 98–473","children":[],"tail":", referred to in subsec. (f), is "},{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1837"},"text":"98 Stat. 1837","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id602f32f4-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s236/26"},"text":"Pub. L. 109–58, § 236(26)","children":[],"tail":", inserted section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s236/1"},"text":"Pub. L. 109–58, § 236(1)","children":[],"tail":", substituted “geothermal resources” for “geothermal steam and associated geothermal resources”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(1)(N). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/510/s3/a/2"},"text":"Pub. L. 106–510, § 3(a)(2)","children":[],"tail":", substituted “Hawaiʻi Volcanoes National Park” for “Hawaii Volcanoes National Park”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(O). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/510/s3/b/2"},"text":"Pub. L. 106–510, § 3(b)(2)","children":[],"tail":", substituted “Haleakala̅ National Park” for “Haleakala National Park”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id602f32f5-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id602f32f6-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Corwin Springs Known Geothermal Resource Area Study","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/443/s8"},"text":"Pub. L. 100–443, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-22"},"text":"Sept. 22, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1771"},"text":"102 Stat. 1771","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/443/s8"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Geological Survey, in consultation with the National Park Service, shall conduct a study on the impact of present and potential geothermal development in the vicinity of Yellowstone National Park on the thermal features within the park. The area to be studied shall be the lands within the Corwin Springs Known Geothermal Resource Area as designated in the ","children":[{"tag":"date","attrib":{"date":"1975-07-22"},"text":"July 22, 1975","children":[],"tail":", Federal Register (Fed. Reg. Vol. 40, No. 141). The study shall be transmitted to Congress no later than "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"December 1, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any production from existing geothermal wells or any development of new geothermal wells or other facilities related to geothermal production is prohibited in the Corwin Springs Known Geothermal Resource Area until 180 days after the receipt by Congress of the study provided for in subsection (a) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not issue, extend, renew or modify any geothermal lease or drilling permit pursuant to the Geothermal Steam Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1001–102"},"text":"30 U.S.C. 1001–102","children":[],"tail":"5) in the Corwin Springs Known Geothermal Resource Area until 180 days after the receipt by Congress of the study provided for in section 8(a) of this Act. This section shall not be construed as requiring such leasing activities subsequent to the 180 days after study submittal."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary determines that geothermal drilling and related activities within the area studied pursuant to subsection (a) of this section may adversely affect the thermal features of Yellowstone National Park, the Secretary shall include in the study required under subsection (a) of this section recommendations regarding the acquisition of the geothermal rights necessary to protect such thermal resources and features.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
