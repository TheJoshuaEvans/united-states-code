{"tag":"section","attrib":{"id":"id604971dc-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1278"},"text":null,"children":[{"tag":"num","attrib":{"value":"1278"},"text":"§ 1278.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surface mining operations not subject to this chapter","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The provisions of this chapter shall not apply to any of the following activities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id604971dd-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1278/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extraction of coal by a landowner for his own noncommercial use from land owned or leased by him; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id604971de-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1278/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extraction of coal as an incidental part of Federal, State or local government-financed highway or other construction under regulations established by the regulatory authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id604971df-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/87/tV/s528"},"text":"Pub. L. 95–87, title V, § 528","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"Aug. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/514"},"text":"91 Stat. 514","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/34/tII/s201/a"},"text":"Pub. L. 100–34, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-05-07"},"text":"May 7, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/300"},"text":"101 Stat. 300","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id604971e0-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id604971e1-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id604971e2-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/34"},"text":"Pub. L. 100–34","children":[],"tail":" inserted “and” after “him;” in par. (1), redesignated par. (3) as (2), and struck out former par. (2) which read as follows: “the extraction of coal for commercial purposes where the surface mining operation affects two acres or less; and”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id604971e3-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id604971e4-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/34/tII/s201/b"},"text":"Pub. L. 100–34, title II, § 201(b)","children":[],"tail":"–(e), "},{"tag":"date","attrib":{"date":"1987-05-07"},"text":"May 7, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/300"},"text":"101 Stat. 300","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/34/tII/s201/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date for New Operations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [amending this section] shall take effect on the date 30 days after the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1987-05-07"},"text":"May 7, 1987","children":[],"tail":"] with respect to each operator commencing surface coal mining operations on or after such date."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date for Existing Operations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section shall take effect on the date 6 months after the enactment of this Act with respect to each operator commencing surface coal mining operations pursuant to an authorization under State law before the date 30 days after the enactment of this Act. Nothing in this Act [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1232"},"text":"section 1232 of this title","children":[],"tail":"] shall preclude reclamation activities pursuant to State law or regulations at the site of any surface coal mine which was exempt from the Surface Mining Control and Reclamation Act of 1977 ["},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1201"},"text":"30 U.S.C. 1201","children":[],"tail":" et seq.] under section 528(2) of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1278/2"},"text":"30 U.S.C. 1278(2)","children":[],"tail":"], as in effect before the enactment of this Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect on State Law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the extent that any provision of a State law, or of a State regulation, adopted pursuant to the exception under section 528(2) of the Surface Mining Control and Reclamation Act of 1977 as in effect before the enactment of this Act, is inconsistent with the amendments made by this section, such provision shall be of no further force and effect after the effective date of such amendments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, the term ‘surface coal mining operations’ has the meaning provided by section 701(28) of the Surface Mining Control and Reclamation Act of 1977 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1291/28"},"text":"30 U.S.C. 1291(28)","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
