{"tag":"section","attrib":{"id":"id602596c0-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s944"},"text":null,"children":[{"tag":"num","attrib":{"value":"944"},"text":"§ 944.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of reasons for denial of claim","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any individual whose claim for benefits under this subchapter is denied shall receive from the Secretary a written statement of the reasons for denial of such claim, and a summary of the administrative hearing record or, upon good cause shown, a copy of any transcript thereof.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id602596c1-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/173/tIV/s434"},"text":"Pub. L. 91–173, title IV, § 434","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/239/s14"},"text":"Pub. L. 95–239, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-03-01"},"text":"Mar. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/103"},"text":"92 Stat. 103","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id602596c2-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id602596c3-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id602596c4-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":