{"tag":"section","attrib":{"id":"id604245a3-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1262"},"text":null,"children":[{"tag":"num","attrib":{"value":"1262"},"text":"§ 1262.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coal exploration permits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id604245a4-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1262/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations; contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State or Federal program shall include a requirement that coal exploration operations which substantially disturb the natural land surface be conducted in accordance with exploration regulations issued by the regulatory authority. Such regulations shall include, at a minimum (1) the requirement that prior to conducting any exploration under this section, any person must file with the regulatory authority notice of intention to explore and such notice shall include a description of the exploration area and the period of supposed exploration and (2) provisions for reclamation in accordance with the performance standards in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1265"},"text":"section 1265 of this title","children":[],"tail":" of all lands disturbed in exploration, including excavations, roads, drill holes, and the removal of necessary facilities and equipment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id604245a5-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1262/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidential information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Information submitted to the regulatory authority pursuant to this subsection as confidential concerning trade secrets or privileged commercial or financial information which relates to the competitive rights of the person or entity intended to explore the described area shall not be available for public examination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id604245a6-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1262/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who conducts any coal exploration activities which substantially disturb the natural land surface in violation of this section or regulations issued pursuant thereto shall be subject to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1268"},"text":"section 1268 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id604245a7-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1262/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on removal of coal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No operator shall remove more than two hundred and fifty tons of coal pursuant to an exploration permit without the specific written approval of the regulatory authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id604245a8-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1262/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law governing exploration of Federal lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Coal exploration on Federal lands shall be governed by section 4 of the Federal Coal Leasing Amendments Act of 1975 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/90/1085"},"text":"90 Stat. 1085","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id604245a9-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/87/tV/s512"},"text":"Pub. L. 95–87, title V, § 512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"Aug. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/483"},"text":"91 Stat. 483","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id604245aa-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id604245ab-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id604245ac-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 4 of the Federal Coal Leasing Amendments Act of 1975 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/90/1085"},"text":"90 Stat. 1085","children":[],"tail":"), referred to in subsec. (e), is "},{"tag":"ref","attrib":{"href":"/us/pl/94/377/s4"},"text":"section 4 of Pub. L. 94–377","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-08-04"},"text":"Aug. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1085"},"text":"90 Stat. 1085","children":[],"tail":", redesignated the Federal Coal Leasing Amendments Act of 1976, which amended "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s201/b"},"text":"section 201(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
