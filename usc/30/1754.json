{"tag":"section","attrib":{"id":"id6063b14d-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1754"},"text":null,"children":[{"tag":"num","attrib":{"value":"1754"},"text":"§ 1754.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Effective ","children":[{"tag":"date","attrib":{"date":"1983-10-01"},"text":"October 1, 1983","children":[],"tail":", there are hereby authorized to be appropriated such sums as may be necessary to carry out the provisions of this chapter, including such sums as may be necessary for the cooperative agreements, contracts, and delegations authorized by this chapter: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That nothing in this chapter shall be construed to affect or impair any authority to enter into contracts or make payments under any other provision of law."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6063b14e-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/451/tIII/s306"},"text":"Pub. L. 97–451, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2462"},"text":"96 Stat. 2462","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
