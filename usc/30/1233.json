{"tag":"section","attrib":{"id":"id6038a90a-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1233"},"text":null,"children":[{"tag":"num","attrib":{"value":"1233"},"text":"§ 1233.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objectives of fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6038a90b-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1233/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Expenditure of moneys from the fund on lands and water eligible pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1234"},"text":"section 1234 of this title","children":[],"tail":" for the purposes of this subchapter, except as provided for under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1240a"},"text":"section 1240a of this title","children":[],"tail":", shall reflect the following priorities in the order stated:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6038a90c-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1233/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6038a90d-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1233/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection; ","children":[{"tag":"ref","attrib":{"idref":"fn002066"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002066"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" of public health, safety, and property from extreme danger of adverse effects of coal mining practices;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6038a90e-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1233/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the restoration of land and water resources and the environment that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6038a90f-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1233/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have been degraded by the adverse effects of coal mining practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6038a910-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1233/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are adjacent to a site that has been or will be remediated under subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6038a911-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1233/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6038a912-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1233/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection of public health and safety from adverse effects of coal mining practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6038a913-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1233/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the restoration of land and water resources and the environment that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6038a914-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1233/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have been degraded by the adverse effects of coal mining practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6038a915-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1233/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are adjacent to a site that has been or will be remediated under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6038a916-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1233/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the restoration of land and water resources and the environment previously degraded by adverse effects of coal mining practices including measures for the conservation and development of soil, water (excluding channelization), woodland, fish and wildlife, recreation resources, and agricultural productivity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6038a917-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1233/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water supply restoration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6038a918-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1233/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any State or Indian tribe not certified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1240a/a"},"text":"section 1240a(a) of this title","children":[],"tail":" may expend funds allocated to such State or Indian tribe in any year through the grants made available under paragraphs (1) and (5) of "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1232/g"},"text":"section 1232(g) of this title","children":[],"tail":" for the purpose of protecting, repairing, replacing, constructing, or enhancing facilities relating to water supply, including water distribution facilities and treatment plants, to replace water supplies adversely affected by coal mining practices."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6038a919-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1233/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the adverse effect on water supplies referred to in this subsection occurred both prior to and after ","children":[{"tag":"date","attrib":{"date":"1977-08-03"},"text":"August 3, 1977","children":[],"tail":", or as the case may be, the dates (and under the criteria) set forth under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1232/g/4/B"},"text":"section 1232(g)(4)(B) of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1234"},"text":"section 1234 of this title","children":[],"tail":" shall not be construed to prohibit a State or Indian tribe referred to in paragraph (1) from using funds referred to in such paragraph for the purposes of this subsection if the State or Indian tribe determines that such adverse effects occurred predominantly prior to "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"August 3, 1977","children":[],"tail":", or as the case may be, the dates (and under the criteria) set forth under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1232/g/4/B"},"text":"section 1232(g)(4)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6038a91a-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1233/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inventory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of assisting in the planning and evaluation of reclamation projects pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1235"},"text":"section 1235 of this title","children":[],"tail":", and assisting in making the certification referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1240a/a"},"text":"section 1240a(a) of this title","children":[],"tail":", the Secretary shall maintain an inventory of eligible lands and waters pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1234"},"text":"section 1234 of this title","children":[],"tail":" which meet the priorities stated in paragraphs (1) and (2) of subsection (a). Under standardized procedures established by the Secretary, States and Indian tribes with approved abandoned mine reclamation programs pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1235"},"text":"section 1235 of this title","children":[],"tail":" may offer amendments, subject to the approval of the Secretary, to update the inventory as it applies to eligible lands and waters under the jurisdiction of such States or tribes. The Secretary shall provide such States and tribes with the financial and technical assistance necessary for the purpose of making inventory amendments. The Secretary shall compile and maintain an inventory for States and Indian lands in the case when a State or Indian tribe does not have an approved abandoned mine reclamation program pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1235"},"text":"section 1235 of this title","children":[],"tail":". On a regular basis, but not less than annually, the projects completed under this subchapter shall be so noted on the inventory under standardized procedures established by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6038a91b-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/87/tIV/s403"},"text":"Pub. L. 95–87, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"Aug. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/458"},"text":"91 Stat. 458","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tVI/s6005"},"text":"Pub. L. 101–508, title VI, § 6005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-294"},"text":"104 Stat. 1388–294","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXV/s2504/c/2"},"text":"Pub. L. 102–486, title XXV, § 2504(c)(2)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3105"},"text":"106 Stat. 3105","children":[],"tail":", 3106; "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/dC/tII/s203"},"text":"Pub. L. 109–432, div. C, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3015"},"text":"120 Stat. 3015","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6038a91c-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6038a91d-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6038a91e-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/s203/1/A"},"text":"Pub. L. 109–432, § 203(1)(A)","children":[],"tail":", designated existing provisions as subpar. (A), inserted semicolon after “protection”, struck out “general welfare,” after “safety,”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/s203/1/B"},"text":"Pub. L. 109–432, § 203(1)(B)","children":[],"tail":", designated existing provisions as subpar. (A), substituted “health and safety” for “health, safety, and general welfare”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/s203/1/C"},"text":"Pub. L. 109–432, § 203(1)(C)","children":[],"tail":", which directed that a period be substituted for the semicolon at end, could not be executed because a period already appeared at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/s203/1/D"},"text":"Pub. L. 109–432, § 203(1)(D)","children":[],"tail":", struck out pars. (4) and (5) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) the protection, repair, replacement, construction, or enhancement of public facilities such as utilities, roads, recreation, and conservation facilities adversely affected by coal mining practices;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) the development of publicly owned land adversely affected by coal mining practices including land acquired as provided in this subchapter for recreation and historic purposes, conservation, and reclamation purposes and open space benefits.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/s203/2/A"},"text":"Pub. L. 109–432, § 203(2)(A)","children":[],"tail":", substituted “Water supply restoration” for “Utilities and other facilities” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/s203/2/B"},"text":"Pub. L. 109–432, § 203(2)(B)","children":[],"tail":", struck out “up to 30 percent of the” before “funds”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/s203/3"},"text":"Pub. L. 109–432, § 203(3)","children":[],"tail":", inserted “, subject to the approval of the Secretary,” after “amendments” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(4) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/s2504/c/2"},"text":"Pub. L. 102–486, § 2504(c)(2)","children":[],"tail":", redesignated pars. (5) and (6) as (4) and (5), respectively, and struck out former par. (4) which read as follows: “research and demonstration projects relating to the development of surface mining reclamation and water quality control program methods and techniques;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/s2504/e"},"text":"Pub. L. 102–486, § 2504(e)","children":[],"tail":", inserted “, or as the case may be, the dates (and under the criteria) set forth under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1232/g/4/B"},"text":"section 1232(g)(4)(B) of this title","children":[],"tail":"” after “1977” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading and “, except as provided for under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1240a"},"text":"section 1240a of this title","children":[],"tail":",” after “subchapter”, and added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6038a91f-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6038a920-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1991-10-01"},"text":"Oct. 1, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s6014"},"text":"section 6014 of Pub. L. 101–508","children":[],"tail":" set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1231"},"text":"section 1231 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
