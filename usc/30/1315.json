{"tag":"section","attrib":{"id":"id604e2ced-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1315"},"text":null,"children":[{"tag":"num","attrib":{"value":"1315"},"text":"§ 1315.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Council on Coal Research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id604e2cee-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1315/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established an Advisory Council on Coal Research which shall be composed of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id604e2cef-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1315/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Energy, who shall be Chairman;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id604e2cf0-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1315/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the United States Bureau of Mines of the Department of the Interior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id604e2cf1-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1315/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President of the National Academy of Sciences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id604e2cf2-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1315/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President of the National Academy of Engineering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id604e2cf3-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1315/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the United States Geological Survey; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id604e2cf4-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1315/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" six members appointed by the Secretary of Energy from among individuals who, by virtue of experience or training, are knowledgeable in the field of coal research and mining, and who are representatives of institutions of higher education, industrial users of coal and coal-derived fuels, the coal industry, mine workers, nonindustrial consumer groups, and institutions concerned with the preservation of the environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id604e2cf5-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1315/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Furnishing advice to Secretary of Energy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Council shall advise the Secretary of Energy with respect to the general administration of this subchapter, and furnish such additional advice as he may request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id604e2cf6-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1315/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report to President; transmittal to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Council shall make an annual report of its findings and recommendations (including recommendations for changes in the provisions of this subchapter) to the President not later than December 31 of each calendar year. The President shall transmit each such report to the Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id604e2cf7-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1315/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and travel expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id604e2cf8-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1315/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Council who are not regular officers or employees of the United States Government shall, while serving on business of the Council, be entitled to receive compensation at rates fixed by the Secretary of Energy but not exceeding the daily rate prescribed for GS-18 of the General Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":" and while so serving away from their homes or regular places of business, they may be allowed travel expenses, including per diem in lieu of subsistence, as authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":" for persons in the Government service employed intermittently."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id604e2cf9-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1315/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Council who are officers or employees of the Government shall be reimbursed for travel, subsistence, and other necessary expenses incurred by them in carrying out their duties on the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id604e2cfa-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1315/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternate members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever a member of the Council appointed under clauses (1) through (5) is unable to attend a meeting, that member shall appoint an appropriate alternate to represent him for that meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id604e2cfb-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/87/tVIII/s805"},"text":"Pub. L. 95–87, title VIII, § 805","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"Aug. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/528"},"text":"91 Stat. 528","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/617/tVI/s604/c"},"text":"Pub. L. 95–617, title VI, § 604(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3167"},"text":"92 Stat. 3167","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/285/s10/b"},"text":"Pub. L. 102–285, § 10(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-18"},"text":"May 18, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/172"},"text":"106 Stat. 172","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id604e2cfc-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id604e2cfd-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id604e2cfe-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617"},"text":"Pub. L. 95–617","children":[],"tail":" substituted “Secretary of Energy” for “Administrator” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id604e2cff-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id604e2d00-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“United States Bureau of Mines” substituted for “Bureau of Mines” in subsec. (a)(2) pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/285/s10/b"},"text":"section 10(b) of Pub. L. 102–285","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1"},"text":"section 1 of this title","children":[],"tail":". For provisions relating to closure and transfer of functions of the United States Bureau of Mines, see Transfer of Functions note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id604e2d01-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions in subsec. (c) of this section relating to requirement that the President transmit each annual report to Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and page 153 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id604e2d02-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Committees","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory committees established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a committee established by the President or an officer of the Federal Government, such committee is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a committee established by the Congress, its duration is otherwise provided for by law. See "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"section 1013 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id604e2d03-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References in Other Laws to GS–16, 17, or 18 Pay Rates","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References in laws to the rates of pay for GS–16, 17, or 18, or to maximum rates of pay under the General Schedule, to be considered references to rates payable under specified sections of Title 5, Government Organization and Employees, see section 529 [title I, § 101(c)(1)] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
