{"tag":"section","attrib":{"id":"id604e2cb1-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1309"},"text":null,"children":[{"tag":"num","attrib":{"value":"1309"},"text":"§ 1309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification and training of blasters","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In accordance with this chapter, the Secretary of the Interior (or the approved State regulatory authority as provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1253"},"text":"section 1253 of this title","children":[],"tail":") shall promulgate regulations requiring the training, examination, and certification of persons engaging in or directly responsible for blasting or use of explosives in surface coal mining operations."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id604e2cb2-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/87/tVII/s719"},"text":"Pub. L. 95–87, title VII, § 719","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"Aug. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/526"},"text":"91 Stat. 526","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
