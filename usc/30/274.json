{"tag":"section","attrib":{"id":"id5ffd269d-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s274"},"text":null,"children":[{"tag":"num","attrib":{"value":"274"},"text":"§ 274.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lands containing coal or other minerals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Prospecting permits or leases may be issued in the discretion of the Secretary of the Interior under the provisions of this subchapter for deposits of sulphur in public lands also containing coal or other minerals on condition that such other deposits be reserved to the United States for disposal under applicable laws.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5ffd269e-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-04-17/ch158/s4"},"text":"Apr. 17, 1926, ch. 158, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/302"},"text":"44 Stat. 302","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5ffd269f-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5ffd26a0-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5ffd26a1-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-02-25/ch85"},"text":"act Feb. 25, 1920, ch. 85","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/437"},"text":"41 Stat. 437","children":[],"tail":", known as the Mineral Leasing Act, which comprises this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
