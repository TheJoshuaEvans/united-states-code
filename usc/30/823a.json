{"tag":"section","attrib":{"id":"id6014f460-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s823a"},"text":null,"children":[{"tag":"num","attrib":{"value":"823a"},"text":"§ 823a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal office in District of Columbia; proceedings held elsewhere","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The principal office of the Commission shall be in the District of Columbia. Whenever the Commission deems that convenience of the public or the parties may be promoted, or delay or expense may be minimized, it may hold hearings or conduct other proceedings at any other place.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6014f461-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/164/tIII/s302/d"},"text":"Pub. L. 95–164, title III, § 302(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-09"},"text":"Nov. 9, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1320"},"text":"91 Stat. 1320","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6014f462-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6014f463-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6014f464-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/164"},"text":"Pub. L. 95–164","children":[],"tail":", known as the Federal Mine Safety and Health Amendments Act of 1977, and not as part of "},{"tag":"ref","attrib":{"href":"/us/pl/91/173"},"text":"Pub. L. 91–173","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/742"},"text":"83 Stat. 742","children":[],"tail":", known as the Federal Mine Safety and Health Act of 1977 which comprises this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6014f465-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id6014f466-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 120 days after ","children":[{"tag":"date","attrib":{"date":"1977-11-09"},"text":"Nov. 9, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/164/s307"},"text":"section 307 of Pub. L. 95–164","children":[],"tail":", set out as an Effective Date of 1977 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
