{"tag":"section","attrib":{"id":"id604e2ca4-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1308a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1308a"},"text":"§ 1308a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of civil penalty funds to reclaim lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In fiscal year 2009 and thereafter, the Secretary of the Interior, pursuant to regulations, may use directly or through grants to States, moneys collected for civil penalties assessed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1268"},"text":"section 1268 of this title","children":[],"tail":", to reclaim lands adversely affected by coal mining practices after "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"August 3, 1977","children":[],"tail":", to remain available until expended."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id604e2ca5-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/8/dE/tI"},"text":"Pub. L. 111–8, div. E, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-11"},"text":"Mar. 11, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/712"},"text":"123 Stat. 712","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id604e2ca6-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id604e2ca7-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id604e2ca8-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Department of the Interior, Environment, and Related Agencies Appropriations Act, 2009, and also as part of the Omnibus Appropriations Act, 2009, and not as part of the Surface Mining Control and Reclamation Act of 1977 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
