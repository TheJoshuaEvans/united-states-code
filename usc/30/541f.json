{"tag":"section","attrib":{"id":"id60069bdd-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s541f"},"text":null,"children":[{"tag":"num","attrib":{"value":"541f"},"text":"§ 541f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disbursement of moneys","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All moneys received under the provisions of this chapter shall be paid into the Treasury of the United States and distributed in the same manner as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s191"},"text":"section 191 of this title","children":[],"tail":" and sections 437, 438, and 439 "},{"tag":"ref","attrib":{"idref":"fn002029"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002029"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 48."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id60069bde-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-11/ch795/s7"},"text":"Aug. 11, 1955, ch. 795, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/681"},"text":"69 Stat. 681","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id60069bdf-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id60069be0-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id60069be1-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text