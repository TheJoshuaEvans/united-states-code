{"tag":"section","attrib":{"id":"id5fdbbbae-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s28j"},"text":null,"children":[{"tag":"num","attrib":{"value":"28j"},"text":"§ 28j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5fdbbbaf-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s28j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Land Policy and Management Act requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in sections 28f to 28k of this title shall change or modify the requirements of section 314(b) of the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1744/b"},"text":"43 U.S.C. 1744(b)","children":[],"tail":"), or the requirements of section 314(c) of the Federal Land Policy and Management Act of 1976 ("},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1744/c"},"text":"43 U.S.C. 1744(c)","children":[],"tail":") related to filings required by section 314(b), and such requirements shall remain in effect with respect to claims, and mill or tunnel sites for which fees are required to be paid under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5fdbbbb0-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s28j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5fdbbbb1-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s28j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fee adjustments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5fdbbbb2-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s28j/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Interior shall adjust the fees required by sections 28f to 28k of this title to reflect changes in the Consumer Price Index published by the Bureau of Labor Statistics of the Department of Labor every 5 years after ","children":[{"tag":"date","attrib":{"date":"1993-08-10"},"text":"August 10, 1993","children":[],"tail":", or more frequently if the Secretary determines an adjustment to be reasonable."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5fdbbbb3-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s28j/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall provide claimants notice of any adjustment made under this subsection not later than July 1 of any year in which the adjustment is made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5fdbbbb4-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s28j/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A fee adjustment under this subsection shall begin to apply the first assessment year which begins after adjustment is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5fdbbbb5-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tX/s10105"},"text":"Pub. L. 103–66, title X, § 10105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/406"},"text":"107 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5fdbbbb6-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5fdbbbb7-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5fdbbbb8-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s10105"},"text":"section 10105 of Pub. L. 103–66","children":[],"tail":". Subsec. (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/s10105"},"text":"section 10105 of Pub. L. 103–66","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s28"},"text":"section 28 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5fdbbbb9-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"similarProvisions","id":"id5fdbbbba-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Similar Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Similar provisions were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/381/tI"},"text":"Pub. L. 102–381, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-05"},"text":"Oct. 5, 1992","children":[],"tail"