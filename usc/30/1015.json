{"tag":"section","attrib":{"id":"id602cc26f-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1015"},"text":null,"children":[{"tag":"num","attrib":{"value":"1015"},"text":"§ 1015.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for lessees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Leases under this chapter may be issued only to citizens of the United States, associations of such citizens, corporations organized under the laws of the United States or of any State or the District of Columbia, or governmental units, including, without limitation, municipalities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id602cc270-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/581/s16"},"text":"Pub. L. 91–581, § 16","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1571"},"text":"84 Stat. 1571","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tII/s236/16"},"text":"Pub. L. 109–58, title II, § 236(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/672"},"text":"119 Stat. 672","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id602cc271-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id602cc272-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id602cc273-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading