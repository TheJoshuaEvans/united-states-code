{"tag":"section","attrib":{"id":"id5fde05df-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s36"},"text":null,"children":[{"tag":"num","attrib":{"value":"36"},"text":"§ 36.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subdivisions of 10-acre tracts; maximum of placer locations; homestead claims of agricultural lands; sale of improvements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Legal subdivisions of forty acres may be subdivided into ten-acre tracts; and two or more persons, or associations of persons, having contiguous claims of any size, although such claims may be less than ten acres each, may make joint entry thereof; but no location of a placer claim, made after the 9th day of July 1870, shall exceed one hundred and sixty acres for any one person or association of persons, which location shall conform to the United States surveys; and nothing in this section contained shall defeat or impair any bona fide homestead claim upon agricultural lands, or authorize the sale of the improvements of any bona fide settler to any purchaser.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fde05e0-3a70-11f1-83b4-f01f82055b58"},"text":"(R.S. § 2330; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1891-03-03/ch561/s4"},"text":"Mar. 3, 1891, ch. 561, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/1097"},"text":"26 Stat. 1097","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5fde05e1-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5fde05e2-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5fde05e3-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2330 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1870-07-09/ch235/s12"},"text":"act July 9, 1870, ch. 235, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/16/217"},"text":"16 Stat. 217","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5fde05e4-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5fde05e5-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Submerged Lands Act","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions of this section as not amended, modified or repealed by the Submerged Lands Act, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1303"},"text":"section 1303 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
