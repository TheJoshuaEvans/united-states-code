{"tag":"section","attrib":{"id":"id60069bf1-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s553"},"text":null,"children":[{"tag":"num","attrib":{"value":"553"},"text":"§ 553.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Secretary; surveys, research, etc.; proj­ects","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Interior, in order to effectuate the policy declared in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s551"},"text":"section 551 of this title","children":[],"tail":", is hereby authorized—"}],"tail":null},{"tag":"subsection","attrib":{"id":"id60069bf2-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s553/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct surveys, investigations, and research relating to the causes and extent of outcrop and underground fires in coal formations and the methods for control or extinguishment of such fires; to publish the results of any such surveys, investigations, and researches; and to disseminate information concerning such method; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id60069bf3-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s553/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to plan and execute projects for control or extinguishment of fires in coal formations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id60069bf4-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-31/ch1156/s3"},"text":"Aug. 31, 1954, ch. 1156, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1009"},"text":"68 Stat. 1009","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
