{"tag":"section","attrib":{"id":"id60234c2f-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s932a"},"text":null,"children":[{"tag":"num","attrib":{"value":"932a"},"text":"§ 932a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of qualified individuals to hear and determine claims for benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Qualified individuals appointed by the Secretary of Labor may hear and determine claims for benefits under part B or part C of title IV of the Federal Coal Mine Health and Safety Act of 1969 ","children":[{"tag":"ref","attrib":{"idref":"fn002045"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002045"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t30/s921"},"text":"30 U.S.C. 921","children":[],"tail":" et seq., 931 et seq.] and under section 415 of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t30/s925"},"text":"30 U.S.C. 925","children":[],"tail":"]. For purposes of this section, the term “qualified individual” means such an individual, regardless of whether that individual is a hearing examiner appointed under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3105"},"text":"section 3105 of title 5","children":[],"tail":". Nothing in this section shall be deemed to imply that there is or is not in effect any authority for such individuals to hear and determine such claims under any provision of law other than this section."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id60234c30-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/504"},"text":"Pub. L. 94–504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-15"},"text":"Oct. 15, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2428"},"text":"90 Stat. 2428","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/275/s2/b/5"},"text":"Pub. L. 107–275, § 2(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1926"},"text":"116 Stat. 1926","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id60234c31-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id60234c32-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id60234c33-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Coal Mine Health and Safety Act of 1969, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/173"},"text":"Pub. L. 91–173","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/742"},"text":"83 Stat. 742","children":[],"tail":", which was renamed the Federal Mine Safety and Health Act of 1977 by "},{"tag":"ref","attrib":{"href":"/us/pl/95/164/tI/s101"},"text":"Pub. L. 95–164, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-09"},"text":"Nov. 9, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1290"},"text":"91 Stat. 1290","children":[],"tail":". Parts B and C of title IV of the Federal Mine Safety and Health Act of 1977 are classified generally to part B (§ 921 et seq.) of this subchapter and to this part (§ 931 et seq.), respectively. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s801"},"text":"section 801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id60234c34-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Federal Mine Safety and Health Act of 1977 which comprises this chapter or the Black Lung Benefits Act which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id60234c35-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/275"},"text":"Pub. L. 107–275","children":[],"tail":" substituted “under part B or part C” for “under part C”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id60234c36-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id60234c37-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/275"},"text":"Pub. L. 107–275","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/275/s4"},"text":"section 4 of Pub. L. 107–275","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s902"},"text":"section 902 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id60234c38-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Extension of Adjudication Period Through March 1, 1979","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/239/s7/i"},"text":"Pub. L. 95–239, § 7(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-03-01"},"text":"Mar. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/100"},"text":"92 Stat. 100","children":[],"tail":", authorized individuals appointed to hear and determine claims for benefits under this part and under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s925"},"text":"section 925 of this title","children":[],"tail":" pursuant to this section, notwithstanding the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s932/a"},"text":"section 932(a) of this title","children":[],"tail":", to continue to adjudicate such claims during the one-year period following "},{"tag":"date","attrib":{"date":"1978-03-01"},"text":"Mar. 1, 1978","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
