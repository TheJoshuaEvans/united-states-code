{"tag":"section","attrib":{"id":"id6019afa2-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s870"},"text":null,"children":[{"tag":"num","attrib":{"value":"870"},"text":"§ 870.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trolley wires and trolley feeder wires","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6019afa3-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s870/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intervals for cutoff switches","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Trolley wires and trolley feeder wires shall be provided with cutout switches at intervals of not more than 2,000 feet and near the beginning of all branch lines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6019afa4-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s870/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overcurrent protection devices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Trolley wires and trolley feeder wires shall be provided with overcurrent protection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6019afa5-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s870/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location of wires","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Trolley wires and trolley feeder wires, high-voltage cables and transformers shall not be located inby the last open crosscut and shall be kept at least 150 feet from pillar workings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6019afa6-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s870/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adequate insulation and guard devices; promulgation of safety guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Trolley wires, trolley feeder wires, and bare signal wires shall be insulated adequately where they pass through doors and stoppings, and where they cross other power wires and cables. Trolley wires and trolley feeder wires shall be guarded adequately (1) at all points where men are required to work or pass regularly under the wires; (2) on both sides of all doors and stoppings; and (3) at man-trip stations. The Secretary or his authorized representatives shall specify other conditions where trolley wires and trolley feeder wires shall be adequately protected to prevent contact by any person, or shall require the use of improved methods to prevent such contact. Temporary guards shall be provided where trackmen and other persons work in proximity to trolley wires and trolley feeder wires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6019afa7-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/173/tIII/s310"},"text":"Pub. L. 91–173, title III, § 310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/783"},"text":"83 Stat. 783","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6019afa8-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6019afa9-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id6019afaa-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section operative 90 days after ","children":[{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", except to the extent an earlier date is specifically provided for in "},{"tag":"ref","attrib":{"href":"/us/pl/91/173"},"text":"Pub. L. 91–173","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/173/s509"},"text":"section 509 of Pub. L. 91–173","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
