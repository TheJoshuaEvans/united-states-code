{"tag":"section","attrib":{"id":"id602806f4-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s952"},"text":null,"children":[{"tag":"num","attrib":{"value":"952"},"text":"§ 952.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id602806f5-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s952/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs for operators, agents, and miners","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall expand programs for the education and training of operators and agents thereof, and miners in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id602806f6-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s952/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recognition, avoidance, and prevention of accidents or unsafe or unhealthful working conditions in coal or other mines; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602806f7-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s952/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the use of flame safety lamps, permissible methane detectors, and other means approved by the Secretary for detecting methane and other explosive gases accurately.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id602806f8-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s952/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance to operators","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, to the greatest extent possible, provide technical assistance to operators in meeting the requirements of this chapter and in further improving the health and safety conditions and practices in coal or other mines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id602806f9-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s952/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Mine Health and Safety Academy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id602806fa-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s952/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Mine Health and Safety Academy shall be maintained as an agency of the Department of Labor. The Academy shall be responsible for the training of mine safety and health inspectors under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s954"},"text":"section 954 of this title","children":[],"tail":", and in training of technical support personnel of the Mine Safety and Health Administration established under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s557a"},"text":"section 557a of title 29","children":[],"tail":"; and for any other training programs for mine inspectors, mining personnel, or other persons as the Secretary of Labor shall designate. In performing this function, the Academy shall have the authority to enter into cooperative educational and training agreements with educational institutions, State governments, labor organizations, and mine operators and related industries. Such training shall be conducted by the Academy in accordance with curriculum needs and assignment of instructional personnel established by the user."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602806fb-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s952/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/38/tI/s100"},"text":"Pub. L. 96–38, title I, § 100","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-25"},"text":"July 25, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/111"},"text":"93 Stat. 111","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602806fc-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s952/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Interior shall conduct his safety research responsibilities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s951"},"text":"section 951 of this title","children":[],"tail":" in coordination with the Secretary of Labor, and the Secretaries of Labor and the Interior are authorized to enter into contractual or other agreements for the performance of such safety related research."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id602806fd-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/173/tV/s502"},"text":"Pub. L. 91–173, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/800"},"text":"83 Stat. 800","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/164/tIII/s303/b"},"text":"Pub. L. 95–164, title III, § 303(b)","children":[],"tail":", (h), "},{"tag":"date","attrib":{"date":"1977-11-09"},"text":"Nov. 9, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1320"},"text":"91 Stat. 1320","children":[],"tail":", 1321; "},{"tag":"ref","attrib":{"href":"/us/pl/96/38/tI/s100"},"text":"Pub. L. 96–38, title I, § 100","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-25"},"text":"July 25, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/111"},"text":"93 Stat. 111","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id602806fe-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id602806ff-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id60280700-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/173"},"text":"Pub. L. 91–173","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/742"},"text":"83 Stat. 742","children":[],"tail":", known as the Federal Mine Safety and Health Act of 1977, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s801"},"text":"section 801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id60280701-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1979—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/38"},"text":"Pub. L. 96–38","children":[],"tail":" substituted “Department of Labor” for “Department of the Interior” and “Secretary of Labor” for “Secretaries of Labor and the Interior”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/38"},"text":"Pub. L. 96–38","children":[],"tail":" struck out par. (2) which directed that the National Mine Health and Safety Academy use the facilities and personnel of the Department of the Interior and that the Secretary of the Interior appoint or assign to the Academy necessary officers and employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/164/s303/b"},"text":"Pub. L. 95–164, § 303(b)","children":[],"tail":", inserted references to mines other than coal mines."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/164/s303/h"},"text":"Pub. L. 95–164, § 303(h)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id60280702-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id60280703-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1977 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/164"},"text":"Pub. L. 95–164","children":[],"tail":" effective 120 days after "},{"tag":"date","attrib":{"date":"1977-11-09"},"text":"Nov. 9, 1977","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/164/s307"},"text":"section 307 of Pub. L. 95–164","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
