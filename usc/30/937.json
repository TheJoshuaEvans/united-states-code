{"tag":"section","attrib":{"id":"id6025966d-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s937"},"text":null,"children":[{"tag":"num","attrib":{"value":"937"},"text":"§ 937.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts and grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6025966e-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s937/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction, purchase, and operation of fixed-site and mobile clinical facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services is authorized to enter into contracts with, and make grants to, public and private agencies and organizations and individuals for the construction, purchase, and operation of fixed-site and mobile clinical facilities for the analysis, examination, and treatment of respiratory and pulmonary impairments in active and inactive coal miners. The Secretary shall coordinate the making of such contracts and grants with the Appalachian Regional Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6025966f-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s937/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services shall initiate research within the National Institute for Occupational Safety and Health, and is authorized to make research grants to public and private agencies and organizations and individuals for the purpose of devising simple and effective tests to measure, detect, and treat respiratory and pulmonary impairments in active and inactive coal miners. Any grant made pursuant to this subsection shall be conditioned upon all information, uses, products, processes, patents, and other developments resulting from such research being available to the general public, except to the extent of such exceptions and limitations as the Secretary of Health and Human Services may deem necessary in the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id60259670-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s937/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby authorized to be appropriated for the purpose of subsection (a) of this section $10,000,000 for each fiscal year. There are hereby authorized to be appropriated for the purposes of subsection (b) of this section such sums as are necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id60259671-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/173/tIV/s427"},"text":"Pub. L. 91–173, title IV, § 427","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/303/s5/6"},"text":"Pub. L. 92–303, § 5(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-05-19"},"text":"May 19, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/155"},"text":"86 Stat. 155","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/239/s9"},"text":"Pub. L. 95–239, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-03-01"},"text":"Mar. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/100"},"text":"92 Stat. 100","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id60259672-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id60259673-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id60259674-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/239"},"text":"Pub. L. 95–239","children":[],"tail":" substituted “$10,000,000 for each fiscal year” for “$10,000,000 for each of the fiscal years ending "},{"tag":"date","attrib":{"date":"1973-06-30"},"text":"June 30, 1973","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-06-30"},"text":"June 30, 1974","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1975-06-30"},"text":"June 30, 1975","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id60259675-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id60259676-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Health and Human Services” substituted for “Secretary of Health, Education, and Welfare” in subsecs. (a) and (b) pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":" which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id60259677-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/239"},"text":"Pub. L. 95–239","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1978-03-01"},"text":"Mar. 1, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/239/s20/a"},"text":"section 20(a) of Pub. L. 95–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s901"},"text":"section 901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
