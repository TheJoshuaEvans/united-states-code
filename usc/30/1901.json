er":"/us/usc/t30/s1901/6/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of this section and sections 1902 through 1905 of this title only, methane hydrate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6065fa7a-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1901/6/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" other marine resources that are not—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6065fa7b-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1901/6/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oil and gas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6065fa7c-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1901/6/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fisheries; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6065fa7d-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1901/6/H/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marine mammals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fa7e-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1901/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “methane hydrate” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6065fa7f-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1901/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a methane clathrate that is in the form of a methane-water ice-like crystalline material and is stable and occurs naturally in deep-ocean and permafrost areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6065fa80-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1901/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other natural gas hydrates found in association with deep-ocean and permafrost deposits of methane hydrate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fa81-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1901/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6065fa82-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/631/tII/s201"},"text":"Pub. L. 91–631, title II, § 201","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/325/s2/3"},"text":"Pub. L. 104–325, § 2(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3994"},"text":"110 Stat. 3994","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/193/s4"},"text":"Pub. L. 106–193, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-02"},"text":"May 2, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/236"},"text":"114 Stat. 236","children":[],"tail":".)"}],"tail":"\n"},{"tag":"n