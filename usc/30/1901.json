":"quotedContent","attrib":{"origin":"/us/pl/104/325/s1"},"text":"“This Act [enacting this chapter] may be cited as the ‘Marine Mineral Resources Research Act of 1996’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
