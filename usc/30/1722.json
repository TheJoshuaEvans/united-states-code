{"tag":"section","attrib":{"id":"id60613f81-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1722"},"text":null,"children":[{"tag":"num","attrib":{"value":"1722"},"text":"§ 1722.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunction and specific enforcement authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id60613f82-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1722/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil action by Attorney General","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to any other remedy under this chapter or any mineral leasing law, the Attorney General of the United States or his designee may bring a civil action in a district court of the United States, which shall have jurisdiction over such actions—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id60613f83-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1722/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to restrain any violation of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id60613f84-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1722/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to compel the taking of any action required by or under this chapter or any mineral leasing law of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id60613f85-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1722/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venue","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A civil action described in subsection (a) may be brought only in the United States district court for the judicial district wherein the act, omission, or transaction constituting a violation under this chapter or any other mineral leasing law occurred, or wherein the defendant is found or transacts business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id60613f86-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/451/tI/s112"},"text":"Pub. L. 97–451, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2456"},"text":"96 Stat. 2456","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
