{"tag":"section","attrib":{"id":"id603b19cb-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1244"},"text":null,"children":[{"tag":"num","attrib":{"value":"1244"},"text":"§ 1244.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remining incentives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id603b19cc-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1244/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this chapter, the Secretary may, after opportunity for public comment, promulgate regulations that describe conditions under which amounts in the fund may be used to provide incentives to promote remining of eligible land under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1234"},"text":"section 1234 of this title","children":[],"tail":" in a manner that leverages the use of amounts from the fund to achieve more reclamation with respect to the eligible land than would be achieved without the incentives."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id603b19cd-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1244/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any regulations promulgated under subsection (a) shall specify that the incentives shall apply only if the Secretary determines, with the concurrence of the State regulatory authority referred to in subchapter V, that, without the incentives, the eligible land would not be likely to be remined and reclaimed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id603b19ce-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1244/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentives","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id603b19cf-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1244/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Incentives that may be considered for inclusion in the regulations promulgated under subsection (a) include, but are not limited to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id603b19d0-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1244/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a rebate or waiver of the reclamation fees required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1232/a"},"text":"section 1232(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id603b19d1-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1244/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of amounts in the fund to provide financial assurance for remining operations in lieu of all or a portion of the performance bonds required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1259"},"text":"section 1259 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id603b19d2-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1244/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id603b19d3-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1244/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A rebate or waiver under paragraph (1)(A) shall be used only for operations that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id603b19d4-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1244/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remove or reprocess abandoned coal mine waste; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id603b19d5-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1244/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct remining activities that meet the priorities specified in paragraph (1) or (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1233/a"},"text":"section 1233(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id603b19d6-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1244/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a rebate or waiver provided as an incentive under paragraph (1)(A) to remine or reclaim eligible land shall not exceed the estimated cost of reclaiming the eligible land under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id603b19d7-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/87/tIV/s415"},"text":"Pub. L. 95–87, title IV, § 415","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/dC/tII/s207"},"text":"Pub. L. 109–432, div. C, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3018"},"text":"120 Stat. 3018","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
