{"tag":"section","attrib":{"id":"id602f329e-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1019"},"text":null,"children":[{"tag":"num","attrib":{"value":"1019"},"text":"§ 1019.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal of moneys from sales, bonuses, rentals, and royalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id602f329f-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1019/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except with respect to lands in the State of Alaska, all monies received by the United States from sales, bonuses, rentals, and royalties under this chapter shall be paid into the Treasury of the United States. Of amounts deposited under this subsection, subject to the provisions of subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s191"},"text":"section 191 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1004/a/2"},"text":"section 1004(a)(2) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id602f32a0-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1019/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent shall be paid to the State within the boundaries of which the leased lands or geothermal resources are or were located; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602f32a1-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1019/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 percent shall be paid to the county within the boundaries of which the leased lands or geothermal resources are or were located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id602f32a2-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1019/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts paid to a State or county under subsection (a) shall be used consistent with the terms of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s191"},"text":"section 191 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id602f32a3-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/581/s20"},"text":"Pub. L. 91–581, § 20","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1572"},"text":"84 Stat. 1572","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/443/s5/a"},"text":"Pub. L. 100–443, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-22"},"text":"Sept. 22, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1768"},"text":"102 Stat. 1768","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tX/s10202/b"},"text":"Pub. L. 103–66, title X, § 10202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/408"},"text":"107 Stat. 408","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tII/s224/b"},"text":"Pub. L. 109–58, title II, § 224(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/663"},"text":"119 Stat. 663","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id602f32a4-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id602f32a5-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id602f32a6-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":" inserted section catchline and amended text generally. Prior to amendment, text read as follows: “Subject to the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s191/b"},"text":"section 191(b) of this title","children":[],"tail":", all moneys received from the sales, bonuses, royalties and rentals under the provisions of this chapter, including the payments referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1005/i"},"text":"section 1005(i) of this title","children":[],"tail":", shall be disposed of in the same manner as such moneys received pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s191"},"text":"section 191 of this title","children":[],"tail":" or pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s355"},"text":"section 355 of this title","children":[],"tail":", as the case may be.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" substituted “Subject to the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s191/b"},"text":"section 191(b) of this title","children":[],"tail":", all moneys” for “All moneys”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/443"},"text":"Pub. L. 100–443","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “All moneys received under this chapter from public lands under the jurisdiction of the Secretary shall be disposed of in the same manner as moneys received from the sale of public lands. Moneys received under this chapter from other lands shall be disposed of in the same manner as other receipts from such lands.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
