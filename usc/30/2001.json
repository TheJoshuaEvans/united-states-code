{"tag":"section","attrib":{"id":"id6065fadf-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2001"},"text":null,"children":[{"tag":"num","attrib":{"value":"2001"},"text":"§ 2001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6065fae0-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2001/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in order to promote energy independence and meet the increasing demand for energy, the United States will require a diversified portfolio of substantially increased quantities of electricity, natural gas, and transportation fuels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fae1-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2001/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" according to the report submitted to Congress by the National Research Council entitled “Charting the Future of Methane Hydrate Research in the United States”, the total United States resources of gas hydrates have been estimated to be on the order of 200,000 trillion cubic feet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fae2-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2001/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" according to the report of the National Commission on Energy Policy entitled “Ending the Energy Stalemate—A Bipartisan Strategy to Meet America’s Energy Challenge”, and dated December 2004, the United States may be endowed with over one-fourth of the methane hydrate deposits in the world;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fae3-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2001/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" according to the Energy Information Administration, a shortfall in natural gas supply from conventional and unconventional sources is expected to occur in or about 2020; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fae4-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2001/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Academy of Sciences states that methane hydrate may have the potential to alleviate the projected shortfall in the natural gas supply.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6065fae5-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/193/s2"},"text":"Pub. L. 106–193, § 2","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s968/a"},"text":"Pub. L. 109–58, title IX, § 968(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/894"},"text":"119 Stat. 894","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6065fae6-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6065fae7-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6065fae8-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/193/s2"},"text":"section 2 of Pub. L. 106–193","children":[],"tail":" was set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1902"},"text":"section 1902 of this title","children":[],"tail":" prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/106/193"},"text":"Pub. L. 106–193","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6065fae9-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id6065faea-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/193/s1"},"text":"Pub. L. 106–193, § 1","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s968/a"},"text":"Pub. L. 109–58, title IX, § 968(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/894"},"text":"119 Stat. 894","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/58/tIX/s968/a"},"text":"“This Act [enacting this chapter] may be cited as the ‘Methane Hydrate Research and Development Act of 2000’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6065faeb-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reclassification","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s968/b"},"text":"Pub. L. 109–58, title IX, § 968(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/898"},"text":"119 Stat. 898","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/58/tIX/s968/b"},"text":"“The Law Revision Counsel shall reclassify the Methane Hydrate Research and Development Act of 2000 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1902"},"text":"30 U.S.C. 1902","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/106/193"},"text":"Public Law 106–193","children":[],"tail":") to a new chapter at the end of title 30, United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
