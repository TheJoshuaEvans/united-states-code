{"tag":"section","attrib":{"id":"id5fd48ffb-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s4d"},"text":null,"children":[{"tag":"num","attrib":{"value":"4d"},"text":"§ 4d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plants, machinery, and equipment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The United States Bureau of Mines is further authorized, under the general direction of the Secretary of the Interior, to erect such plants, construct and purchase such machinery and equipment, and to take such other steps as it may deem necessary and proper to effectuate the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s4c"},"text":"section 4c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fd48ffc-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-15/ch397/s2"},"text":"May 15, 1936, ch. 397, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1275"},"text":"49 Stat. 1275","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/285/s10/b"},"text":"Pub. L. 102–285, § 10(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-18"},"text":"May 18, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/172"},"text":"106 Stat. 172","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5fd48ffd-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5fd48ffe-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id5fd48fff-3a70-11f1-83b4-f01f8