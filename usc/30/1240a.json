ate":"1980-12-11"},"text":"Dec. 11, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2767"},"text":"94 Stat. 2767","children":[],"tail":", as amended, which is classified principally to chapter 103 (§ 9601 et seq.) of Title 42. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9601"},"text":"section 9601 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id603b19b6-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/87/s411"},"text":"section 411 of Pub. L. 95–87","children":[],"tail":" was renumbered section 412 and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1241"},"text":"section 1241 of this title","children":[],"tail":", prior to being omitted from the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id603b19b7-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (h)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s43001/1"},"text":"Pub. L. 114–94, § 43001(1)","children":[],"tail":", designated existing provisions as cl. (i), inserted heading, and added cl. (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s43001/2"},"text":"Pub. L. 114–94, § 43001(2)","children":[],"tail":", struck out pars. (5) and (6) which related to limitation on annual payments and supplemental funding, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (h)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/40"},"tex