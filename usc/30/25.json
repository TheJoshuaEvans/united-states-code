{"tag":"section","attrib":{"id":"id5fd94a56-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s25"},"text":null,"children":[{"tag":"num","attrib":{"value":"25"},"text":"§ 25.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affidavit of citizenship","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Applicants for mineral patents, if residing beyond the limits of the district wherein the claim is situated, may make any oath or affidavit required for proof of citizenship before the clerk of any court of record or before any notary public of any State or Territory.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fd94a57-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1882-04-26/ch106/s2"},"text":"Apr. 26, 1882, ch. 106, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/22/49"},"text":"22 Stat. 49","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
