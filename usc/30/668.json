{"tag":"section","attrib":{"id":"id60090dc2-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s668"},"text":null,"children":[{"tag":"num","attrib":{"value":"668"},"text":"§ 668.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id60090dc3-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s668/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal year beginning ","children":[{"tag":"date","attrib":{"date":"1960-07-01"},"text":"July 1, 1960","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby authorized to be appropriated, out of any money in the Treasury not otherwise appropriated, to remain available until expended, not to exceed $2,000,000 to be used to carry out the purposes of this chapter for the fiscal year beginning ","children":[{"tag":"date","attrib":{"date":"1960-07-01"},"text":"July 1, 1960","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id60090dc4-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s668/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"1961-06-30"},"text":"June 30, 1961","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated for each fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"1961-06-30"},"text":"June 30, 1961","children":[],"tail":", such sums as may be necessary to carry out the purposes of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id60090dc5-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s668/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of sums","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sums appropriated to carry out the purposes of this chapter shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id60090dc6-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/599/s5"},"text":"Pub. L. 86–599, § 5","children":[],"tail":", formerly § 8, "},{"tag":"date","attrib":{"date":"1960-07-07"},"text":"July 7, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/337"},"text":"74 Stat. 337","children":[],"tail":"; renumbered § 5, "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tX/s1009/a/1/D"},"text":"Pub. L. 109–58, title X, § 1009(a)(1)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/934"},"text":"119 Stat. 934","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id60090dc7-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id60090dc8-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id60090dc9-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/599/s5"},"text":"section 5 of Pub. L. 86–599","children":[],"tail":" was renumbered section 3 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s665"},"text":"section 665 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
