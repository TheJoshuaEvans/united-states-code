{"tag":"section","attrib":{"id":"id5fe07698-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s72"},"text":null,"children":[{"tag":"num","attrib":{"value":"72"},"text":"§ 72.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference right of coal mine entry; acreage limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person or association of persons severally qualified, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s71"},"text":"section 71 of this title","children":[],"tail":", who have opened and improved, or shall open and improve, any coal mine or mines upon the public lands, and shall be in actual possession of the same, shall be entitled to a preference right of entry, under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s71"},"text":"section 71 of this title","children":[],"tail":", of the mines so opened and improved: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That when any association of not less than four persons, severally qualified as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s71"},"text":"section 71 of this title","children":[],"tail":", shall have expended not less than $5,000 in working and improving any such mine or mines, such association may enter not exceeding six hundred and forty acres, including such mining improvements."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fe07699-3a70-11f1-83b4-f01f82055b58"},"text":"(R.S. § 2348.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5fe0769a-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5fe0769b-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5fe0769c-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2348 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1873-03-03/ch279/s2"},"text":"act Mar. 3, 1873, ch. 279, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/17/607"},"text":"17 Stat. 607","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id5fe0769d-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5fe0769e-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Indian Lands Excepted","children":[],"tail":null},{"tag":"p","attrib":{},"text":"See note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s71"},"text":"section 71 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
