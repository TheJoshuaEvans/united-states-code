{"tag":"section","attrib":{"id":"id5fe2e83e-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s171"},"text":null,"children":[{"tag":"num","attrib":{"value":"171"},"text":"§ 171.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal as agricultural lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in chapter 3A of this title, all public lands within the State of Alabama, whether mineral or otherwise, shall be subject to disposal only as agricultural lands. All lands which had been reported to the General Land Office prior to ","children":[{"tag":"date","attrib":{"date":"1883-03-03"},"text":"March 3, 1883","children":[],"tail":", as containing coal and iron shall first be offered at public sale."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fe2e83f-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1883-03-03/ch118"},"text":"Mar. 3, 1883, ch. 118","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/22/487"},"text":"22 Stat. 487","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1920-02-25/ch85/s1"},"text":"Feb. 25, 1920, ch. 85, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/437"},"text":"41 Stat. 437","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5fe2e840-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5fe2e841-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5fe2e842-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from act ","children":[{"tag":"date","attrib":{"date":"1883-03-03"},"text":"Mar. 3, 1883","children":[],"tail":", which contained an additional provision relating to pending homesteads, which was omitted because of its temporary nature."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5fe2e843-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1920—The exception clause was inserted at beginning of this section because of act ","children":[{"tag":"date","attrib":{"date":"1920-02-25"},"text":"Feb. 25, 1920","children":[],"tail":", which provided that deposits of coal, phosphate, sodium, oil, oil shale, or gas, and lands containing such deposits owned by the United States, shall be subject to disposition in the form and manner provided by such act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id5fe2e844-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id5fe2e845-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"General Land Office abolished and functions transferred to Bureau of Land Management by Reorg. Plan No. 3 of 1946, § 403, eff. ","children":[{"tag":"date","attrib":{"date":"1946-07-16"},"text":"July 16, 1946","children":[],"tail":", 11 F.R. 7876, "},{"tag":"ref","attrib":{"href":"/us/stat/60/1100"},"text":"60 Stat. 1100","children":[],"tail":", and regulations thereunder. See note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1"},"text":"section 1 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
