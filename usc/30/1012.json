{"tag":"section","attrib":{"id":"id602cc25a-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1012"},"text":null,"children":[{"tag":"num","attrib":{"value":"1012"},"text":"§ 1012.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver, suspension, or reduction of rental or royalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may waive, suspend, or reduce the rental or royalty for any lease or portion thereof in the interests of conservation and to encourage the greatest ultimate recovery of geothermal resources, if he determines that this is necessary to promote development or that the lease cannot be successfully operated under the lease terms.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id602cc25b-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/581/s13"},"text":"Pub. L. 91–581, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1570"},"text":"84 Stat. 1570","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tII/s236/13"},"text":"Pub. L. 109–58, title II, § 236(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/672"},"text":"119 Stat. 672","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id602cc25c-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id602cc25d-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments"