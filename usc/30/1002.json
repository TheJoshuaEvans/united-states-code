{"tag":"section","attrib":{"id":"id602a50ba-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1002"},"text":null,"children":[{"tag":"num","attrib":{"value":"1002"},"text":"§ 1002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lands subject to geothermal leasing","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Subject to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1014"},"text":"section 1014 of this title","children":[],"tail":", the Secretary of the Interior may issue leases for the development and utilization of geothermal resources (1) in lands administered by him, including public, withdrawn, and acquired lands, (2) in any national forest or other lands administered by the Department of Agriculture through the Forest Service, including public, withdrawn, and acquired lands, and (3) in lands which have been conveyed by the United States subject to a reservation to the United States of the geothermal resources therein."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id602a50bb-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/581/s3"},"text":"Pub. L. 91–581, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1566"},"text":"84 Stat. 1566","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tII/s236/1"},"text":"Pub. L. 109–58, title II, § 236(1)","children":[],"tail":", (6), "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/671"},"text":"119 Stat. 671","children":[],"tail":", 672.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id602a50bc-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id602a50bd-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id602a50be-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":" inserted section catchline and substituted “geothermal resources” for “geothermal steam and associated geothermal resources” in two places in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
