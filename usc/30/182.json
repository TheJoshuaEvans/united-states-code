{"tag":"section","attrib":{"id":"id5fe53151-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s182"},"text":null,"children":[{"tag":"num","attrib":{"value":"182"},"text":"§ 182.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lands disposed of with reservation of deposits of coal, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of this chapter shall also apply to all deposits of coal, phosphate, sodium, oil, oil shale, gilsonite (including all vein-type solid hydrocarbons), or gas in the lands of the United States, which lands may have been or may be disposed of under laws reserving to the United States such deposits, with the right to prospect for, mine, and remove the same, subject to such conditions as are or may hereafter be provided by such laws reserving such deposits.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fe53152-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-02-25/ch85/s34"},"text":"Feb. 25, 1920, ch. 85, § 34","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/450"},"text":"41 Stat. 450","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/705/s7/a"},"text":"Pub. L. 86–705, § 7(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-02"},"text":"Sept. 2, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/790"},"text":"74 Stat. 790","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/78/s1/1"},"text":"Pub. L. 97–78, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-11-16"},"text":"Nov. 16, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1070"},"text":"95 Stat. 1070","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5fe53153-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5fe53154-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5fe53155-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/78"},"text":"Pub. L. 97–78","children":[],"tail":" substituted “gilsonite (including all vein-type solid hydrocarbons),” for “native asphalt, solid and semisolid bitumen, and bituminous rock (including oil-impregnated rock or sands from which oil is recoverable only by special treatment after the deposit is mined or quarried)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/705"},"text":"Pub. L. 86–705","children":[],"tail":" included native asphalt, solid and semisolid bitumen, and bituminous rock."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
