{"tag":"section","attrib":{"id":"id602f32c4-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1025"},"text":null,"children":[{"tag":"num","attrib":{"value":"1025"},"text":"§ 1025.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal reservation of certain mineral rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The United States reserves the ownership of and the right to extract under such rules and regulations as the Secretary may prescribe oil, hydrocarbon gas, and helium from all geothermal resources produced from lands leased under this chapter in accordance with presently applicable laws: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That whenever the right to extract oil, hydrocarbon gas, and helium from geothermal resources produced from such lands is exercised pursuant to this section, it shall be exercised so as to cause no substantial interference with the production of geothermal resources from such lands."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id602f32c5-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/581/s27"},"text":"Pub. L. 91–581, § 27","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1574"},"text":"84 Stat. 1574","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tII/s236/1"},"text":"Pub. L. 109–58, title II, § 236(1)","children":[],"tail":", (25), "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/671"},"text":"119 Stat. 671","children":[],"tail":", 673.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id602f32c6-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id602f32c7-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id602f32c8-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":" inserted section catchline and substituted “geothermal resources” for “geothermal steam and associated geothermal resources” wherever appearing in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
