{"tag":"section","attrib":{"id":"id6063b154-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1756"},"text":null,"children":[{"tag":"num","attrib":{"value":"1756"},"text":"§ 1756.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expanded royalty obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any lessee is liable for royalty payments on oil or gas lost or wasted from a lease site when such loss or waste is due to negligence on the part of the operator of the lease, or due to the failure to comply with any rule or regulation, order or citation issued under this chapter or any mineral leasing law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6063b155-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/451/tIII/s308"},"text":"Pub. L. 97–451, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2462"},"text":"96 Stat. 2462","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
