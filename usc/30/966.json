{"tag":"section","attrib":{"id":"id602a509c-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s966"},"text":null,"children":[{"tag":"num","attrib":{"value":"966"},"text":"§ 966.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention of fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Mine Safety and Health Administration may retain up to $2,499,000 in this fiscal year and each fiscal year thereafter from fees collected for the approval and certification of equipment, materials, and explosives for use in mines, and may utilize such sums for such activities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id602a509d-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/76/dH/tI"},"text":"Pub. L. 113–76, div. H, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-01-17"},"text":"Jan. 17, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/357"},"text":"128 Stat. 357","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id602a509e-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id602a509f-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id602a50a0-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This fiscal year, referred to in text, is fiscal year 2014.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id602a50a1-3a70-11f1-83b4-f01f82055b58"},"text":null,"children