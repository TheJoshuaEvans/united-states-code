{"tag":"section","attrib":{"id":"id5fff70de-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s306"},"text":null,"children":[{"tag":"num","attrib":{"value":"306"},"text":"§ 306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized and directed to adopt rules and regulations governing the exercise of the discretion and authority conferred by this chapter, which rules and regulations shall constitute a part of any application or lease hereunder.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fff70df-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-05-21/ch307/s6"},"text":"May 21, 1930, ch. 307, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/374"},"text":"46 Stat. 374","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
