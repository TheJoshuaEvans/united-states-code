{"tag":"section","attrib":{"id":"id5fd70112-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"§ 7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees for tests or investigations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For tests or investigations authorized by the Secretary of the Interior under the provisions of sections 1, 3, and 5 to 7 of this title, except those performed for the Government of the United States or State governments within the United States, a fee sufficient in each case to compensate the United States Bureau of Mines for the entire cost of the services rendered shall be charged, according to a schedule prepared by the Director of the United States Bureau of Mines and approved by the Secretary of the Interior, who shall prescribe rules and regulations under which such tests and investigations may be made. All moneys received from such sources shall be paid into the Treasury to the credit of miscellaneous receipts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fd70113-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1910-05-16/ch240/s5"},"text":"May 16, 1910, ch. 240, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/370"},"text":"36 Stat. 370","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1913-02-25/ch72/s5"},"text":"Feb. 25, 1913, ch. 72, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/682"},"text":"37 Stat. 682","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1932-06-30/ch314"},"text":"June 30, 1932, ch. 314","children":[],"tail":", pt. II, title III, § 311, "},{"tag":"ref","attrib":{"href":"/us/stat/47/410"},"text":"47 Stat. 410","children":[],"tail":"; Ex. Ord. No. 4239, "},{"tag":"date","attrib":{"date":"1935-06-04"},"text":"June 4, 1935","children":[],"tail":"; Ex. Ord. No. 6611, "},{"tag":"date","attrib":{"date":"1934-02-22"},"text":"Feb. 22, 1934","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/285/s10/b"},"text":"Pub. L. 102–285, § 10(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-18"},"text":"May 18, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/172"},"text":"106 Stat. 172","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5fd70114-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5fd70115-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5fd70116-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1932—Act ","children":[{"tag":"date","attrib":{"date":"1932-06-30"},"text":"June 30, 1932","children":[],"tail":", substituted “Secretary of Commerce” for “Secretary of the Interior” and changed a reasonable fee to be charged to a fee sufficient to compensate for entire cost of services rendered."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5fd70117-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id5fd70118-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“United States Bureau of Mines” substituted in text for “Bureau of Mines” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/285/s10/b"},"text":"section 10(b) of Pub. L. 102–285","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1"},"text":"section 1 of this title","children":[],"tail":". For provisions relating to closure and transfer of functions of the United States Bureau of Mines, see Transfer of Functions note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5fd70119-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1932 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by act ","children":[{"tag":"date","attrib":{"date":"1932-06-30"},"text":"June 30, 1932","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1932-07-01"},"text":"July 1, 1932","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/act/1932-06-30/ch314"},"text":"act June 30, 1932, ch. 314","children":[],"tail":", pt. II, title III, § 314, "},{"tag":"ref","attrib":{"href":"/us/stat/47/411"},"text":"47 Stat. 411","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
