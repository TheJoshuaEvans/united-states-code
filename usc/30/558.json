{"tag":"section","attrib":{"id":"id60069c0c-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s558"},"text":null,"children":[{"tag":"num","attrib":{"value":"558"},"text":"§ 558.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated such sums,","children":[{"tag":"ref","attrib":{"idref":"fn002030"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002030"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" as may be necessary to carry out the provisions and purposes of this chapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id60069c0d-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-31/ch1156/s8"},"text":"Aug. 31, 1954, ch. 1156, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1011"},"text":"68 Stat. 1011","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXV/s2504/d/3"},"text":"Pub. L. 102–486, title XXV, § 2504(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3106"},"text":"106 Stat. 3106","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id60069c0e-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id60069c0f-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id