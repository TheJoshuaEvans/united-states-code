{"tag":"section","attrib":{"id":"id6065fa98-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903"},"text":null,"children":[{"tag":"num","attrib":{"value":"1903"},"text":"§ 1903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants, contracts, and cooperative agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6065fa99-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance and coordination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6065fa9a-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall award grants or contracts to, or enter into cooperative agreements with, eligible entities to support research for the development or utilization of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6065fa9b-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods, equipment, systems, and components necessary for the identification, assessment, and exploration of marine mineral resources in an environmentally responsible manner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6065fa9c-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods of detecting, monitoring, and predicting the presence of adverse environmental effects in the marine environment and remediating the environmental effects of marine mineral resource exploration, development, and production; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6065fa9d-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education and training material in marine mineral research and resource management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fa9e-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing for contracts or cooperative agreements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6065fa9f-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B)(ii), the Federal share of the cost of a contract or cooperative agreement carried out under this subsection shall not be greater than 80 percent of the total cost of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6065faa0-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The remaining non-Federal share of the cost of a project carried out under this section may be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6065faa1-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the form of cash or in-kind contributions, or both; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6065faa2-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comprised of funds made available under other Federal programs, except that non-Federal funds shall be used to defray at least 10 percent of the total cost of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6065faa3-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1996-10-19"},"text":"October 19, 1996","children":[],"tail":", the Secretary shall establish, after consultation with other Federal agencies, terms and conditions under which Federal funding will be provided under this subsection that are consistent with the Agreement on Subsidies and Countervailing Measures referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d/12"},"text":"section 3511(d)(12) of title 19","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6065faa4-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6065faa5-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity shall not be eligible to receive a grant or contract, or participate in a cooperative agreement, under subsection (a) unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6065faa6-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entity submits a proposal to the Secretary at such time, in such manner, and accompanied by such information as the Secretary may reasonably require; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6065faa7-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposal has been evaluated by a competitive review panel under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065faa8-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive review panels","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6065faa9-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A competitive review panel shall be chaired by the Secretary or by the Secretary’s designee and shall be composed of members who meet the following criteria:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6065faaa-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members shall be appointed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6065faab-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Experience","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 50 percent of the members shall represent or be employed by private marine resource companies that are involved in exploration of the marine environment or development of marine mineral resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6065faac-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"None of the members may have an interest in a grant, contract, or cooperative agreement being evaluated by the panel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6065faad-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A review panel member who is not otherwise a Federal employee shall receive no compensation for performing duties under this section, except that, while engaged in the performance of duties away from the home or regular place of business of the member, the member may be allowed travel expenses, including per diem in lieu of subsistence, in the same manner as a person employed intermittently in the Government service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065faae-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A competitive review panel shall base an evaluation of a proposal on criteria developed by the Secretary that shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6065faaf-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the merits of the proposal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6065fab0-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the research methodology and costs of the proposal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6065fab1-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capability of the entity submitting the proposal and any other participating entity to perform the proposed work and provide in-kind contributions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6065fab2-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of matching funds provided by the entity submitting the proposal or provided by other Federal, State, or private entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6065fab3-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of collaboration with other Federal, State, or private entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6065fab4-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a noncommercial entity, the existence of a cooperative agreement with a commercial entity that provides for collaboration in the proposed research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6065fab5-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the proposal promotes responsible environmental stewardship; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6065fab6-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/b/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other factors as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6065fab7-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6065fab8-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 10 percent of the amount made available to carry out this section during a fiscal year may be used by the Secretary for expenses associated with administration of the program authorized by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fab9-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"None of the funds made available under this section may be used for the construction of a new building or the acquisition, expansion, remodeling, or alteration of an existing building (including site grading and improvement and architect fees).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6065faba-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that receives a grant or contract or enters into a cooperative agreement under this section shall submit an annual progress report and a final technical report to the Secretary that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6065fabb-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes project activities, implications of the project, the significance of the project to marine mineral research, identification, assessment, and exploration, and potential commercial and economic benefits and effects of the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fabc-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1903/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an annual progress report, includes a project plan for the subsequent year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6065fabd-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/631/tII/s203"},"text":"Pub. L. 91–631, title II, § 203","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/325/s2/3"},"text":"Pub. L. 104–325, § 2(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3995"},"text":"110 Stat. 3995","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6065fabe-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6065fabf-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6065fac0-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"1996-10-19"},"text":"October 19, 1996","children":[],"tail":", referred to in subsec. (a)(2)(C), was in the original “the date of enactment of this Act”, which was translated as meaning the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/104/135"},"text":"Pub. L. 104–135","children":[],"tail":", which enacted this chapter, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
