{"tag":"section","attrib":{"id":"id6033edb9-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1228"},"text":null,"children":[{"tag":"num","attrib":{"value":"1228"},"text":"§ 1228.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency cooperation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The President shall, by such means as he deems appropriate, clarify agency responsibility for Federal mining and mineral resources research and provide for interagency coordination of such research, including the research authorized by this subchapter. Such coordination shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6033edba-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1228/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuing review of the adequacy of the Government-wide program in mining and mineral resources research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6033edbb-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1228/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification and elimination of duplication and overlap between agency programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6033edbc-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1228/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of technical needs in various mining and mineral resources research categories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6033edbd-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1228/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations with respect to allocation of technical effort among Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6033edbe-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1228/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review of technical manpower needs, and findings concerning management policies to improve the quality of the Government-wide research effort; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6033edbf-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1228/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions to facilitate interagency communication at management levels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6033edc0-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/409/s8"},"text":"Pub. L. 98–409, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-29"},"text":"Aug. 29, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1540"},"text":"98 Stat. 1540","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6033edc1-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6033edc2-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6033edc3-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Mining and Mineral Resources Research Institute Act of 1984, and not as part of the Surface Mining Control and Reclamation Act of 1977 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6033edc4-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1228, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/87/tIII/s308"},"text":"Pub. L. 95–87, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"Aug. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/455"},"text":"91 Stat. 455","children":[],"tail":", contained provisions similar to this section covering fiscal years 1978 through 1984."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
