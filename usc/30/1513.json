{"tag":"section","attrib":{"id":"id6057a2df-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1513"},"text":null,"children":[{"tag":"num","attrib":{"value":"1513"},"text":"§ 1513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan interest rates; repayment periods","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6057a2e0-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1513/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each loan made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1511"},"text":"section 1511 of this title","children":[],"tail":" shall bear interest at a discount or interest rate equal to the rate in effect (at the time the loan is made) for water resources planning projects under section 80 of the Water Resources Development Act of 1974 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962/d"},"text":"42 U.S.C. 1962(d)","children":[],"tail":"–17(a))."},{"tag":"ref","attrib":{"idref":"fn002099"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002099"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Should be “("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962d–17/a"},"text":"42 U.S.C. 1962d–17(a)","children":[],"tail":").”"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6057a2e1-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1513/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each such loan shall be for a term which the Secretary deems appropriate, except that no loan term shall exceed twenty years beyond the date on which production of energy or geothermal energy resources begins from the reservoir involved. If revenues are inadequate (as determined by the Secretary) to fully repay the principal and accrued interest within twenty years after production begins, any remaining unpaid amounts shall be forgiven.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6057a2e2-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294/tVI/s613"},"text":"Pub. L. 96–294, title VI, § 613","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/764"},"text":"94 Stat. 764","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
