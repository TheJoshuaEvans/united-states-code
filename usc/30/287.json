{"tag":"section","attrib":{"id":"id5fff70c5-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s287"},"text":null,"children":[{"tag":"num","attrib":{"value":"287"},"text":"§ 287.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of prospecting permits","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any prospecting permit issued under this subchapter may be extended by the Secretary of the Interior for a period not exceeding two years, upon a showing of satisfactory cause.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fff70c6-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-02-07/ch66/s7"},"text":"Feb. 7, 1927, ch. 66, § 7","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1932-05-07/ch174"},"text":"May 7, 1932, ch. 174","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/151"},"text":"47 Stat. 151","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5fff70c7-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5fff70c8-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5fff70c9-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-02-25/ch85"},"text":"act Feb. 25, 1920, ch. 85","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/437"},"text":"41 Stat. 437","children":[],"tail":", known as the Mineral Leasing Act, which comprises this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
