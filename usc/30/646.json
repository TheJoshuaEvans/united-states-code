{"tag":"section","attrib":{"id":"id60090d99-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s646"},"text":null,"children":[{"tag":"num","attrib":{"value":"646"},"text":"§ 646.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated, from any funds in the Treasury not otherwise appropriated, such sums as may be necessary to carry out the provisions of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id60090d9a-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/701/s6"},"text":"Pub. L. 85–701, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-21"},"text":"Aug. 21, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/701"},"text":"72 Stat. 701","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
