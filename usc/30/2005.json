{"tag":"section","attrib":{"id":"id6065fb31-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2005"},"text":null,"children":[{"tag":"num","attrib":{"value":"2005"},"text":"§ 2005.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports and studies for Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide to the Committee on Science of the House of Representatives and the Committee on Energy and Natural Resources of the Senate copies of any report or study that the Department of Energy prepares at the direction of any committee of Congress relating to the methane hydrate research and development program implemented under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6065fb32-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/193/s6"},"text":"Pub. L. 106–193, § 6","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s968/a"},"text":"Pub. L. 109–58, title IX, § 968(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/898"},"text":"119 Stat. 898","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6065fb33-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6065fb34-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6065fb35-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/193/s6"},"text":"section 6 of Pub. L. 106–193","children":[],"tail":" was set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1902"},"text":"section 1902 of this title","children":[],"tail":" prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/106/193"},"text":"Pub. L. 106–193","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6065fb36-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id6065fb37-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Science of House of Representatives changed to Committee on Science and Technology of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":". Committee on Science and Technology of House of Representatives changed to Committee on Science, Space, and Technology of House of Representatives by House Resolution No. 5, One Hundred Twelfth Congress, "},{"tag":"date","attrib":{"date":"2011-01-05"},"text":"Jan. 5, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
