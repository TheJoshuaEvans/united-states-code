{"tag":"section","attrib":{"id":"id5feece1f-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s190"},"text":null,"children":[{"tag":"num","attrib":{"value":"190"},"text":"§ 190.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oath; requirement; form; blanks","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All statements, representations, or reports required by the Secretary of the Interior under this chapter shall be upon oath, unless otherwise specified by him, and in such form and upon such blanks as the Secretary of the Interior may require.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5feece20-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-02-25/ch85/s33"},"text":"Feb. 25, 1920, ch. 85, § 33","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/450"},"text":"41 Stat. 450","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
