{"tag":"section","attrib":{"id":"id5fe2e7d1-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s84"},"text":null,"children":[{"tag":"num","attrib":{"value":"84"},"text":"§ 84.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications for entry","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person desiring to make entry under the homestead laws or the desert-land law, any State desiring to make selection under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s641"},"text":"section 641 of title 43","children":[],"tail":", and the Secretary of the Interior in withdrawing under the Reclamation Act lands classified as coal lands, or valuable for coal, with a view of securing or passing title to the same in accordance with the provisions of said Acts, shall state in the application for entry, selection, or notice of withdrawal that the same is made in accordance with and subject to the provisions and reservations of sections 83 to 85 of this title."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fe2e7d2-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1910-06-22/ch318/s2"},"text":"June 22, 1910, ch. 318, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/584"},"text":"36 Stat. 584","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5fe2e7d3-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5fe2e7d4-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5fe2e7d5-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Reclamation Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1902-06-17/ch1093"},"text":"act June 17, 1902, ch. 1093","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/388"},"text":"32 Stat. 388","children":[],"tail":", which is classified generally to chapter 12 (§ 371 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s371"},"text":"section 371 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5fe2e7d6-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5fe2e7d7-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Supplemental Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"See note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s83"},"text":"section 83 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
