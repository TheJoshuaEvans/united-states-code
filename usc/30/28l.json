{"tag":"section","attrib":{"id":"id5fdbbbc0-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s28l"},"text":null,"children":[{"tag":"num","attrib":{"value":"28l"},"text":"§ 28l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of mining law administration fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In fiscal year 2009 and each fiscal year thereafter, the Bureau of Land Management shall collect from mining claim holders the mining claim maintenance fees and location fees; such fees shall be collected in the same manner as authorized by sections 28f and 28g of this title only to the extent provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fdbbbc1-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/8/dE/tI"},"text":"Pub. L. 111–8, div. E, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-11"},"text":"Mar. 11, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/704"},"text":"123 Stat. 704","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/88/dA/tI"},"text":"Pub. L. 111–88, div. A, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2907"},"text":"123 Stat. 2907","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5fdbbbc2-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5fdbbbc3-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5fdbbbc4-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/88"},"text":"Pub. L. 111–88","children":[],"tail":" substituted “from mining claim holders the mining claim maintenance fees and location” for “mining law administration” and struck out “those” before “authorized”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
