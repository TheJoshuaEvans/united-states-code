{"tag":"section","attrib":{"id":"id5fd49008-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"§ 5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports of investigations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the United States Bureau of Mines shall prepare and publish, subject to the direction of the Secretary of the Interior, under the appropriations made from time to time by Congress, reports of inquiries and investigations, with appropriate recommendations of the bureau, concerning the nature, causes, and prevention of accidents, and the improvement of conditions, methods, and equipment, with special reference to health, safety, and prevention of waste in the mining, quarrying, metallurgical, and other mineral industries; the use of explosives and electricity, safety methods and appliances, and rescue and first-aid work in said industries; the causes and prevention of mine fires; and other subjects included under the provisions of sections 1, 3, and 5 to 7 of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fd49009-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1910-05-16/ch240/s3"},"text":"May 16, 1910, ch. 240, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/370"},"text":"36 Stat. 370","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1913-02-25/ch72/s3"},"text":"Feb. 25, 1913, ch. 72, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/681"},"text":"37 Stat. 681","children":[],"tail":"; Ex. Ord. No. 4239, "},{"tag":"date","attrib":{"date":"1925-06-04"},"text":"June 4, 1925","children":[],"tail":"; Ex. Ord. No. 6611, "},{"tag":"date","attrib":{"date":"1934-02-22"},"text":"Feb. 22, 1934","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/285/s10/b"},"text":"Pub. L. 102–285, § 10(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-18"},"text":"May 18, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/172"},"text":"106 Stat. 172","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5fd4900a-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5fd4900b-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id5fd4900c-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“United States Bureau of Mines” substituted in text for “Bureau of Mines” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/285/s10/b"},"text":"section 10(b) of Pub. L. 102–285","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1"},"text":"section 1 of this title","children":[],"tail":". For provisions relating to closure and transfer of functions of the United States Bureau of Mines, see Transfer of Functions note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
