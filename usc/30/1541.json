{"tag":"section","attrib":{"id":"id6057a317-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1541"},"text":null,"children":[{"tag":"num","attrib":{"value":"1541"},"text":"§ 1541.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of geothermal energy in Federal facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The option of using geothermal energy or geothermal energy resources shall be considered fully in any new Federal building, facility, or installation which is located in a geothermal resource area as designated by the Secretary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6057a318-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294/tVI/s642"},"text":"Pub. L. 96–294, title VI, § 642","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/769"},"text":"94 Stat. 769","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
