text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/223/dC/s202/a"},"text":"Pub. L. 114–223, div. C, § 202(a)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/115/30"},"text":"Pub. L. 115–30","children":[],"tail":", par. (2), "},{"tag":"date","attrib":{"date":"2017-04-28"},"text":"Apr. 28, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/134"},"text":"131 Stat. 134","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/30"},"text":"“This section [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1232"},"text":"section 1232 of this title","children":[],"tail":"] may be cited as the ‘Further Continued Health Benefits for Miners Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id602f333d-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/223/dC/s167/a"},"text":"Pub. L. 114–223, div. C, § 167(a)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/114/254/dA/s101/3"},"text":"Pub. L. 114–254, div. A, § 101(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-10"},"text":"Dec. 10, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1009"},"text":"130 Stat. 1009","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/254/dA/s101/3"},"text":"“This section [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1232"},"text":"section 1232 of this title","children":[],"tail":"] may be cited as the ‘Continued Health Benefits for Miners Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id602f333e-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/dC/tII/s200"},"text":"Pub. L. 109–432, div. C, title II, § 200","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3006"},"text":"120 Stat. 3006","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/432/dC/tII/s200"},"text":"“This title [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1244"},"text":"section 1244 of this title","children":[],"tail":", amending sections 1231 to 1233, 1236, 1238, 1240a, 1260, 1300, and 1302 of this title and sections 9701, 9702, 9704 to 9707, 9711, 9712, and 9721 of Title 26, Internal Revenue Code, and enacting provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1232"},"text":"section 1232 of this title","children":[],"tail":" and sections 9701, 9704, and 9712 of Title 26] may be cited as the ‘Surface Mining Control and Reclamation Act Amendments of 2006’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id602f333f-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1990 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tVI/s6001"},"text":"Pub. L. 101–508, title VI, § 6001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-289"},"text":"104 Stat. 1388–289","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/508/tVI/s6001"},"text":"“This subtitle [subtitle A (§§ 6001–6014) of title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":", enacting "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1240a"},"text":"section 1240a of this title","children":[],"tail":", amending sections 1231 to 1237, 1239, 1257, and 1302 of this title, and enacting provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1231"},"text":"section 1231 of this title","children":[],"tail":"] may be cited as the ‘Abandoned Mine Reclamation Act of 1990’.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/498/s1"},"text":"Pub. L. 101–498, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-02"},"text":"Nov. 2, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1207"},"text":"104 Stat. 1207","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/498/s1"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1230a"},"text":"section 1230a of this title","children":[],"tail":"] may be cited as the ‘Strategic and Critical Minerals Act of 1990’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id602f3340-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/483/s13"},"text":"Pub. L. 100–483, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-12"},"text":"Oct. 12, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2341"},"text":"102 Stat. 2341","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/483/s13"},"text":"“This Act [amending sections 1221, 1222, 1224, 1226, 1229, and 1230 of this title and enacting provisions set out as notes under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1229"},"text":"section 1229 of this title","children":[],"tail":"] may be cited as the Mining and Mineral Resources Research Institute Amendments of 1988.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id602f3341-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/87/s1"},"text":"Pub. L. 95–87, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"Aug. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/445"},"text":"91 Stat. 445","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/87/s1"},"text":"“That this Act [enacting this chapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1114"},"text":"section 1114 of Title 18","children":[],"tail":", Crimes and Criminal Procedure] may be cited as the ‘Surface Mining Control and Reclamation Act of 1977’.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/409/s11"},"text":"Pub. L. 98–409, § 11","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/100/483/s12"},"text":"Pub. L. 100–483, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-12"},"text":"Oct. 12, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2341"},"text":"102 Stat. 2341","children":[],"tail":"; amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/312/s1/b"},"text":"Pub. L. 104–312, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3819"},"text":"110 Stat. 3819","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/312/s1/b"},"text":"“This Act [enacting subchapter III of this chapter] may be cited as the ‘Mining and Mineral Resources Institutes Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
