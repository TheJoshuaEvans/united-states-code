{"tag":"section","attrib":{"id":"id60042bbc-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s531"},"text":null,"children":[{"tag":"num","attrib":{"value":"531"},"text":"§ 531.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of United States officials","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to waive, amend, or repeal the requirement of any provision of any law for approval of any official of the United States whose approval prior to prospecting, exploring, or mining would be required.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id60042bbd-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-13/ch730/s12"},"text":"Aug. 13, 1954, ch. 730, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/717"},"text":"68 Stat. 717","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
