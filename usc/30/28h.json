{"tag":"section","attrib":{"id":"id5fdbbb9f-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s28h"},"text":null,"children":[{"tag":"num","attrib":{"value":"28h"},"text":"§ 28h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Co-ownership","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The co-ownership provisions of the Mining Law of 1872 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s28"},"text":"30 U.S.C. 28","children":[],"tail":") "},{"tag":"ref","attrib":{"idref":"fn002002"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002002"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall remain in effect, except that in applying such provisions, the annual claim maintenance fee required under this Act shall, where applicable, replace applicable assessment requirements and expenditures."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fdbbba0-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tX/s10103"},"text":"Pub. L. 103–66, title X, § 10103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/406"},"text":"107 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5fdbbba1-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5fdbbba2-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5fdbbba3-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Mining Law of 1872 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s28"},"text":"30 U.S.C. 28","children":[],"tail":"), referred to in text, probably means "},{"tag":"ref","attrib":{"href":"/us/act/1872-05-10/ch152"},"text":"act May 10, 1872, ch. 152","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/17/91"},"text":"17 Stat. 91","children":[],"tail":". That act was incorporated into the Revised Statutes as R.S. §§ 2319 to 2328, 2331, 2333 to 2337, and 2344, which are classified to sections 22 to 24, 26 to 28, 29, 30, 33 to 35, 37, 39 to 42, and 47 of this title. For complete classification of R.S. §§ 2319 to 2328, 2331, 2333 to 2337, and 2344 to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/312"},"text":"107 Stat. 312","children":[],"tail":", known as the Omnibus Budget Reconciliation Act of 1993. The annual claim maintenance fee required under this Act probably refers to the fee required under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s28f"},"text":"section 28f of this title","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5fdbbba4-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"similarProvisions","id":"id5fdbbba5-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Similar Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Similar provisions were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/381/tI"},"text":"Pub. L. 102–381, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-05"},"text":"Oct. 5, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1378"},"text":"106 Stat. 1378","children":[],"tail":", 1379."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
