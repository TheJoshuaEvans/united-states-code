{"tag":"section","attrib":{"id":"id600b56d9-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s708"},"text":null,"children":[{"tag":"num","attrib":{"value":"708"},"text":"§ 708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignments; succession","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Rights and privileges to qualify as an applicant under this chapter shall not be assignable, but may pass through devise or descent.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id600b56da-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/851/s8"},"text":"Pub. L. 87–851, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-23"},"text":"Oct. 23, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1128"},"text":"76 Stat. 1128","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
