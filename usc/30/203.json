{"tag":"section","attrib":{"id":"id5ff389ef-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s203"},"text":null,"children":[{"tag":"num","attrib":{"value":"203"},"text":"§ 203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional lands or deposits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5ff389f0-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5ff389f1-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s203/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (3), on a finding by the Secretary under paragraph (2), any person, association, or corporation holding a lease of coal lands or coal deposits under the provisions of this chapter may with the approval of the Secretary of the Interior,","children":[{"tag":"ref","attrib":{"idref":"fn002014"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002014"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" secure modifications of the original coal lease by including additional coal lands or coal deposits contiguous or cornering to those embraced in the lease."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ff389f2-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s203/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A finding referred to in paragraph (1) is a finding by the Secretary that the modifications—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5ff389f3-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s203/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would be in the interest of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ff389f4-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s203/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would not displace a competitive interest in the lands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ff389f5-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s203/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would not include lands or deposits that can be developed as part of another potential or existing operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ff389f6-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s203/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In no case shall the total area added by modifications to an existing coal lease under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5ff389f7-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s203/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exceed 960 acres; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ff389f8-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s203/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" add acreage larger than that in the original lease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5ff389f9-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe terms and conditions which shall be consistent with this chapter and applicable to all of the acreage in such modified lease except that nothing in this section shall require the Secretary to apply the production or mining plan requirements of sections 202a(2) and 207(c) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5ff389fa-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s203/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Royalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The minimum royalty provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s207/a"},"text":"section 207(a) of this title","children":[],"tail":" shall not apply to any lands covered by this modified lease prior to a modification until the term of the original lease or extension thereof which became effective prior to the effective date of this Act has expired."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5ff389fb-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-02-25/ch85/s3"},"text":"Feb. 25, 1920, ch. 85, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/439"},"text":"41 Stat. 439","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/377/s13/b"},"text":"Pub. L. 94–377, § 13(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-08-04"},"text":"Aug. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1090"},"text":"90 Stat. 1090","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/554/s3"},"text":"Pub. L. 95–554, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-30"},"text":"Oct. 30, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2074"},"text":"92 Stat. 2074","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIV/s432"},"text":"Pub. L. 109–58, title IV, § 432","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/760"},"text":"119 Stat. 760","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5ff389fc-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5ff389fd-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5ff389fe-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 202a(2) and 207(c) of this title, referred to in subsec. (b), was in the original “section 2(d)(2) and 7(c) of this Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s201/d/2"},"text":"30 U.S.C. 201(d)(2)","children":[],"tail":" and 207(c))”, and was translated as sections 202a(2) and 207(c) of this title to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The effective date of this Act, referred to in subsec. (c), probably means the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/554"},"text":"Pub. L. 95–554","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1978-10-30"},"text":"Oct. 30, 1978","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5ff389ff-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":" designated first sentence as par. (1) of subsec. (a), substituted “Except as provided in paragraph (3), on a finding by the Secretary under paragraph (2), any person” for “Any person” and “secure modifications of the original coal lease by including additional coal lands or coal deposits contiguous or cornering to those embraced in the lease” for “upon a finding by him that it would be in the interest of the United States, secure modifications of the original coal lease by including additional coal lands or coal deposits contiguous or cornering to those embraced in such lease, but in no event shall the total area added by such modifications to an existing coal lease exceed one hundred sixty acres, or add acreage larger than that in the original lease”, added pars. (2) and (3), and designated second and third sentences as subsecs. (b) and (c), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/554"},"text":"Pub. L. 95–554","children":[],"tail":" authorized modification of leases to include coal lands or coal deposits cornering to those embraced in the leases and inserted provision respecting application of production or mining plan requirements of sections 202a(2) and 207(c) and minimum royalty provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s207/a"},"text":"section 207(a) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/377"},"text":"Pub. L. 94–377","children":[],"tail":" struck out the advantage to the lessee as one of the conditions for modification of the original lease, substituted provision prohibiting the addition of total area in excess of 160 acres or adding acreage larger than that in the original lease for provision limiting the total area embraced in such modified lease to an aggregate of 2560 acres, and inserted provision authorizing the Secretary to prescribe terms and conditions consistent with this chapter which shall be applicable to the total acreage in the modified lease."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5ff38a00-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5ff38a01-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":" applicable with respect to any coal lease issued before, on, or after "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/s438"},"text":"section 438 of Pub. L. 109–58","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s201"},"text":"section 201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"id5ff38a02-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/377/s13/b"},"text":"Pub. L. 94–377, § 13(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-08-04"},"text":"Aug. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1090"},"text":"90 Stat. 1090","children":[],"tail":", provided that the amendment made by that section is subject to valid existing rights."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
