{"tag":"section","attrib":{"id":"id602cc246-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1008"},"text":null,"children":[{"tag":"num","attrib":{"value":"1008"},"text":"§ 1008.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Byproducts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If the production, use, or conversion of geothermal steam is susceptible of producing a valuable byproduct or byproducts, including commercially demineralized water for beneficial uses in accordance with applicable State water laws, the Secretary shall require substantial beneficial production or use thereof unless, in individual circumstances he modifies or waives this requirement in the interest of conservation of natural resources or for other reasons satisfactory to him. However, the production or use of such byproducts shall be subject to the rights of the holders of preexisting leases, claims, or permits covering the same land or the same minerals, if any.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id602cc247-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/581/s9"},"text":"Pub. L. 91–581, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1570"},"text":"84 Stat. 1570","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tII/s236/9"},"text":"Pub. L. 109–58, title II, § 236(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/672"},"text":"119 Stat. 672","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id602cc248-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id602cc249-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id602cc24a-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":" inserted section catchline."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
