{"tag":"section","attrib":{"id":"id605558bb-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1472"},"text":null,"children":[{"tag":"num","attrib":{"value":"1472"},"text":"§ 1472.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deep Seabed Revenue Sharing Trust Fund; establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id605558bc-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1472/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creation of Trust Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a trust fund to be known as the “Deep Seabed Revenue Sharing Trust Fund” (hereinafter in this section referred to as the “Trust Fund”), consisting of such amounts as may be appropriated or credited to the Trust Fund as provided in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id605558bd-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1472/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer to Trust Fund of amounts equivalent to certain taxes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id605558be-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1472/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are hereby appropriated to the Trust Fund amounts determined by the Secretary of the Treasury to be equivalent to the amounts of the taxes received in the Treasury under section 4495 ","children":[{"tag":"ref","attrib":{"idref":"fn002096"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002096"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 26."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id605558bf-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1472/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of transfer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amounts appropriated by paragraph (1) shall be transferred at least quarterly from the general fund of the Treasury to the Trust Fund on the basis of estimates made by the Secretary of the Treasury of the amounts referred to in paragraph (1) received in the Treasury. Proper adjustments shall be made in the amounts subsequently transferred to the extent prior estimates were in excess of or less than the amount required to be transferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id605558c0-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1472/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management of Trust Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id605558c1-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1472/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be the duty of the Secretary of the Treasury to hold the Trust Fund, and to report to the Congress for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1980-09-30"},"text":"September 30, 1980","children":[],"tail":", and each fiscal year thereafter on the financial condition and the results of the operations of the Trust Fund during the preceding year and on its expected condition and operations during the fiscal year and the next five fiscal years after the fiscal year. Such report shall be printed as a House document of the session of the Congress to which the report is made."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id605558c2-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1472/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id605558c3-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1472/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be the duty of the Secretary of the Treasury to invest such portion of the Trust Fund as is not, in his judgment, required to meet current withdrawals. Such investments may be made only in interest-bearing obligations of the United States. For such purpose, such obligations may be acquired (i) on original issue at the issue price, or (ii) by purchase of outstanding obligations at the market price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id605558c4-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1472/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any obligation acquired by the Trust Fund may be sold by the Secretary at the market price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id605558c5-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1472/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest on certain proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The interest on, and the proceeds from the sale or redemption of, any obligations held in the Trust Fund shall be credited to and form a part of the Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id605558c6-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1472/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures from Trust Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an international deep seabed treaty is ratified by and in effect with respect to the United States on or before the date ten years after ","children":[{"tag":"date","attrib":{"date":"1980-06-28"},"text":"June 28, 1980","children":[],"tail":", amounts in the Trust Fund shall be available, as provided by appropriations Acts, for making contributions required under such treaty for purposes of the sharing among nations of the revenues from deep seabed mining. Nothing in this subsection shall be deemed to authorize any program or other activity not otherwise authorized by law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id605558c7-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1472/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an international deep seabed treaty is not in effect with respect to the United States on or before the date ten years after ","children":[{"tag":"date","attrib":{"date":"1980-06-28"},"text":"June 28, 1980","children":[],"tail":", amounts in the Trust Fund shall be available for such purposes as Congress may hereafter provide by law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id605558c8-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1472/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International deep seabed treaty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “international deep seabed treaty” has the meaning given to such term by section 4498(b) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of title 26."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id605558c9-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/283/tIV/s403"},"text":"Pub. L. 96–283, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-28"},"text":"June 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/584"},"text":"94 Stat. 584","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id605558ca-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"referencesInText","id":"id605558cb-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 4495 and 4498 of title 26, referred to in subsecs. (b)(1) and (f), were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXIV/s1432/b/1"},"text":"Pub. L. 105–34, title XIV, § 1432(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1050"},"text":"111 Stat. 1050","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id605558cc-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/283"},"text":"Pub. L. 96–283","children":[],"tail":", and not as part of title III of "},{"tag":"ref","attrib":{"href":"/us/pl/96/283"},"text":"Pub. L. 96–283","children":[],"tail":", which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id605558cd-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”, which for purposes of codification was translated as “title 26” thus requiring no change in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id605558ce-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions in subsec. (c)(1) of this section relating to the duty of the Secretary of the Treasury to report annually to Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and page 143 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
