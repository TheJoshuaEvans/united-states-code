{"tag":"section","attrib":{"id":"id5fe0769f-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s73"},"text":null,"children":[{"tag":"num","attrib":{"value":"73"},"text":"§ 73.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presentation of claims","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All claims under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s72"},"text":"section 72 of this title","children":[],"tail":" must be presented to the register of the proper land district within sixty days after the date of actual possession and the commencement of improvements on the land, by the filing of a declaratory statement therefor; but when the township plat is not on file at the date of such improvement, filing must be made within sixty days from the receipt of such plat at the district office."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fe076a0-3a70-11f1-83b4-f01f82055b58"},"text":"(R.S. § 2349.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5fe076a1-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5fe076a2-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5fe076a3-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2349 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1873-03-03/ch279/s3"},"text":"act Mar. 3, 1873, ch. 279, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/17/607"},"text":"17 Stat. 607","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id5fe076a4-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id5fe076a5-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Office of register of district land office abolished and all functions of register transferred to Secretary of the Interior, or to officers and agencies of Department of the Interior as Secretary may designate, by Reorg. Plan No. 3 of 1946, § 403, eff. ","children":[{"tag":"date","attrib":{"date":"1946-07-16"},"text":"July 16, 1946","children":[],"tail":", 11 F.R. 7876, "},{"tag":"ref","attrib":{"href":"/us/stat/60/1100"},"text":"60 Stat. 1100","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"See also note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5fe076a6-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Indian Lands Excepted","children":[],"tail":null},{"tag":"p","attrib":{},"text":"See note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s71"},"text":"section 71 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
