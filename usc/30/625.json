{"tag":"section","attrib":{"id":"id60090d81-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s625"},"text":null,"children":[{"tag":"num","attrib":{"value":"625"},"text":"§ 625.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of unspecified use","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provisions of this chapter, all mining claims and mill sites or mineral rights located under the terms of this chapter or otherwise contained on the public lands as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s621"},"text":"section 621 of this title","children":[],"tail":" shall be used only for the purposes specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s621"},"text":"section 621 of this title","children":[],"tail":" and no facility or activity shall be erected or conducted thereon for other purposes."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id60090d82-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-11/ch797/s6"},"text":"Aug. 11, 1955, ch. 797, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/683"},"text":"69 Stat. 683","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
