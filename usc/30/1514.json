{"tag":"section","attrib":{"id":"id6057a2e3-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1514"},"text":null,"children":[{"tag":"num","attrib":{"value":"1514"},"text":"§ 1514.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No new loans shall be made under this subchapter after ","children":[{"tag":"date","attrib":{"date":"1986-09-30"},"text":"September 30, 1986","children":[],"tail":". Amounts repaid on or before "},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"September 30, 1986","children":[],"tail":", on loans theretofore made under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1511"},"text":"section 1511 of this title","children":[],"tail":" shall be deposited in the Geothermal Resources Development Fund for purposes of this subchapter. Amounts repaid after that date on loans theretofore made under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1511"},"text":"section 1511 of this title","children":[],"tail":", and amounts deposited in the Fund for purposes of this subchapter which remain in the Fund after that date and are not required to secure outstanding obligations under this subchapter, shall be deposited into the United States Treasury as miscellaneous receipts."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6057a2e4-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294/tVI/s614"},"text":"Pub. L. 96–294, title VI, § 614","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/764"},"text":"94 Stat. 764","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
