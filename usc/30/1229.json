{"tag":"section","attrib":{"id":"id6033edc5-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1229"},"text":null,"children":[{"tag":"num","attrib":{"value":"1229"},"text":"§ 1229.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committee on Mining and Mineral Resources Research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6033edc6-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1229/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment; composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall appoint a Committee on Mining and Mineral Resources Research composed of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6033edc7-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1229/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary of the Interior responsible for minerals and mining research, or his delegate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6033edc8-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1229/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director, United States Bureau of Mines, or his delegate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6033edc9-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1229/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director, United States Geological Survey, or his delegate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6033edca-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1229/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the National Science Foundation, or his delegate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6033edcb-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1229/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President, National Academy of Sciences, or his delegate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6033edcc-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1229/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President, National Academy of Engineering, or his delegate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6033edcd-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1229/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 7 other persons who are knowledgeable in the fields of mining and mineral resources research, including two university administrators involved in the conduct of programs authorized by this subchapter, 3 representatives from the mining industry, a working miner, and a representative from the conservation community. In making these 7 appointments, the Secretary shall consult with interested groups.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6033edce-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1229/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation and recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall consult with, and make recommendations to, the Secretary on all matters relating to mining and mineral resources research and the determinations that are required to be made under this subchapter. The Secretary shall consult with, and consider recommendations of, such Committee in such matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6033edcf-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1229/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation, travel, subsistence and related expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Committee members, other than officers or employees of Federal, State, or local governments, shall be, for each day (including traveltime) during which they are performing Committee business, paid at a rate fixed by the Secretary but not ","children":[{"tag":"ref","attrib":{"idref":"fn002060"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002060"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “in”."}],"tail":" excess of the daily equivalent of the maximum rate of pay for grade GS–18 of the General Schedule under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":", and shall be fully reimbursed for travel, subsistence, and related expenses."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6033edd0-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1229/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairmanship of Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall be jointly chaired by the Assistant Secretary of the Interior responsible for minerals and mining and a person to be elected by the Committee from among the members referred to in paragraphs (5), (6), and (7) of subsection (a) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6033edd1-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1229/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National plan for research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall develop a national plan for research in mining and mineral resources, considering ongoing efforts in the universities, the Federal Government, and the private sector, and shall formulate and recommend a program to implement the plan utilizing resources provided for under this subchapter. The Committee shall submit such plan to the Secretary, the President, and the Congress on or before ","children":[{"tag":"date","attrib":{"date":"1986-03-01"},"text":"March 1, 1986","children":[],"tail":", and shall submit an annual update of such plan by January 15 of each calendar year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6033edd2-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1229/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1009"},"text":"Section 1009 of title 5","children":[],"tail":" shall not apply to the Committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6033edd3-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/409/s9"},"text":"Pub. L. 98–409, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-29"},"text":"Aug. 29, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1540"},"text":"98 Stat. 1540","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/483"},"text":"Pub. L. 100–483","children":[],"tail":", §§ 8, 9, "},{"tag":"date","attrib":{"date":"1988-10-12"},"text":"Oct. 12, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2340"},"text":"102 Stat. 2340","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/285/s10/b"},"text":"Pub. L. 102–285, § 10(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-18"},"text":"May 18, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/172"},"text":"106 Stat. 172","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/193"},"text":"Pub. L. 117–286, § 4(a)(193)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4327"},"text":"136 Stat. 4327","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6033edd4-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6033edd5-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6033edd6-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Mining and Mineral Resources Institutes Act, and not as part of the Surface Mining Control and Reclamation Act of 1977 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6033edd7-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1229, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/87/tIII/s309"},"text":"Pub. L. 95–87, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"Aug. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/455"},"text":"91 Stat. 455","children":[],"tail":", contained provisions similar to this section covering fiscal years 1978 through 1984."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6033edd8-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1009"},"text":"Section 1009 of title 5","children":[],"tail":"” for “Section 10 of the Federal Advisory Committee Act (5 U.S.C. App.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/483/s8"},"text":"Pub. L. 100–483, § 8","children":[],"tail":", substituted “7 other persons” for “six other persons”, “this subchapter, 3” for “section 301 of the Surface Mining Control and Reclamation Act of 1977, two”, and “7 appointments” for “six appointments”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/483/s9"},"text":"Pub. L. 100–483, § 9","children":[],"tail":", substituted “submit an annual update of such plan by January 15 of each calendar year” for “update the plan annually thereafter”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6033edd9-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id6033edda-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“United States Bureau of Mines” substituted for “Bureau of Mines” in subsec. (a)(2) pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/285/s10/b"},"text":"section 10(b) of Pub. L. 102–285","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1"},"text":"section 1 of this title","children":[],"tail":". For provisions relating to closure and transfer of functions of the United States Bureau of Mines, see Transfer of Functions note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6033eddb-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions in subsec. (e) of this section relating to the requirement to submit annual updates of the national plan to Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and page 157 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6033eddc-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References in Other Laws to GS–16, 17, or 18 Pay Rates","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References in laws to the rates of pay for GS–16, 17, or 18, or to maximum rates of pay under the General Schedule, to be considered references to rates payable under specified sections of Title 5, Government Organization and Employees, see section 529 [title I, § 101(c)(1)] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6033eddd-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reports","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/483/s11"},"text":"Pub. L. 100–483, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-12"},"text":"Oct. 12, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2341"},"text":"102 Stat. 2341","children":[],"tail":", directed Committee on Mining and Mineral Resources Research to submit a report to Congress by "},{"tag":"date","attrib":{"date":"1992-01-15"},"text":"Jan. 15, 1992","children":[],"tail":", on programs established under this subchapter, including reviews of activities of the institutes and generic mineral technology centers established under this subchapter, each institute’s and center’s eligibility pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1230"},"text":"section 1230 of this title","children":[],"tail":", and recommendations on establishing new generic mineral technology centers, as well as phasing out or consolidating existing centers, and further directed Committee to submit to Congress, by "},{"tag":"date","attrib":{"date":"1990-01-15"},"text":"Jan. 15, 1990","children":[],"tail":", a proposal to establish a Generic Mineral Technology Center on Strategic and Critical Minerals."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
