{"tag":"section","attrib":{"id":"id60317d9f-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1225"},"text":null,"children":[{"tag":"num","attrib":{"value":"1225"},"text":"§ 1225.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on colleges and universities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to impair or modify the legal relationship existing between any of the colleges or universities under whose direction an institute is established and the government of the State in which it is located, and nothing in this subchapter shall in any way be construed to authorize Federal control or direction of education at any college or university.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id60317da0-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/409/s5"},"text":"Pub. L. 98–409, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-29"},"text":"Aug. 29, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1539"},"text":"98 Stat. 1539","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id60317da1-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id60317da2-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id60317da3-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Mining and Mineral Resources Research Institute Act of 1984, and not as part of the Surface Mining Control and Reclamation Act of 1977 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id60317da4-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1225, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/87/tIII/s305"},"text":"Pub. L. 95–87, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"Aug. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/454"},"text":"91 Stat. 454","children":[],"tail":", contained provisions similar to this section covering fiscal years 1978 through 1984."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
