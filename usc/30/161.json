{"tag":"section","attrib":{"id":"id5fe2e835-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s161"},"text":null,"children":[{"tag":"num","attrib":{"value":"161"},"text":"§ 161.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entry of building-stone lands; previous law unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person authorized to enter lands under the mining laws of the United States may enter lands that are chiefly valuable for building stone under the provisions of the law in relation to placer mineral claims. Lands reserved for the benefit of the public schools or donated to any State shall not be subject to entry under this section. Nothing contained in this section shall be construed to repeal ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s471"},"text":"section 471 of title 16","children":[],"tail":" relating to the establishment of national forests."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fe2e836-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1892-08-04/ch375"},"text":"Aug. 4, 1892, ch. 375","children":[],"tail":", §§ 1, 3, "},{"tag":"ref","attrib":{"href":"/us/stat/27/348"},"text":"27 Stat. 348","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5fe2e837-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5fe2e838-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5fe2e839-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s471"},"text":"Section 471 of title 16","children":[],"tail":", referred to in text, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/94/579/tVII/s704/a"},"text":"Pub. L. 94–579, title VII, § 704(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2792"},"text":"90 Stat. 2792","children":[],"tail":", effective on and after "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5fe2e83a-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"First two sentences of this section are from section 1 and last sentence of this section is from section 3 of act ","children":[{"tag":"date","attrib":{"date":"1892-08-04"},"text":"Aug. 4, 1892","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
