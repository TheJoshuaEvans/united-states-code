{"tag":"section","attrib":{"id":"id6063b144-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1753"},"text":null,"children":[{"tag":"num","attrib":{"value":"1753"},"text":"§ 1753.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to other laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6063b145-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1753/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental nature of chapter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The penalties and authorities provided in this chapter are supplemental to, and not in derogation of, any penalties or authorities contained in any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6063b146-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1753/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of Secretary related to minerals on Federal and Indian lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to reduce the responsibilities of the Secretary to ensure prompt and proper collection of revenues from coal, uranium and other energy and nonenergy minerals on Federal and Indian lands, or to restrain the Secretary from entering into cooperative agreements or other appropriate arrangements with States and Indian tribes to share royalty management responsibilities and activities for such minerals under existing authorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6063b147-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1753/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority and responsibilities of Inspector General and Comptroller General unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to enlarge, diminish, or otherwise affect the authority or responsibility of the Inspector General of the Department of the Interior or of the Comptroller General of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6063b148-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1753/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lands and land interests entrusted to Tennessee Valley Authority unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No provision of this chapter impairs or affects lands and interests in land entrusted to the Tennessee Valley Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6063b149-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/451/tIII/s304"},"text":"Pub. L. 97–451, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2461"},"text":"96 Stat. 2461","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/362/tIX/s901/j/2"},"text":"Pub. L. 105–362, title IX, § 901(j)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-10"},"text":"Nov. 10, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3290"},"text":"112 Stat. 3290","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6063b14a-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6063b14b-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6063b14c-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/362"},"text":"Pub. L. 105–362","children":[],"tail":" substituted “Nothing” for “Except as expressly provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1752/b"},"text":"section 1752(b) of this title","children":[],"tail":", nothing”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
