{"tag":"section","attrib":{"id":"id60259682-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s939"},"text":null,"children":[{"tag":"num","attrib":{"value":"939"},"text":"§ 939.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary of Labor such sums as may be necessary to carry out his responsibilities under this subchapter. Such sums shall remain available until expended.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id60259683-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/173/tIV/s429"},"text":"Pub. L. 91–173, title IV, § 429","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/303/s5/8"},"text":"Pub. L. 92–303, § 5(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-05-19"},"text":"May 19, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/156"},"text":"86 Stat. 156","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
