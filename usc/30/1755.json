{"tag":"section","attrib":{"id":"id6063b14f-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1755"},"text":null,"children":[{"tag":"num","attrib":{"value":"1755"},"text":"§ 1755.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statute of limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except in the case of fraud, any action to recover penalties under this chapter shall be barred unless the action is commenced within 6 years after the date of the act or omission which is the basis for the action.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6063b150-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/451/tIII/s307"},"text":"Pub. L. 97–451, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2462"},"text":"96 Stat. 2462","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6063b151-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6063b152-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6063b153-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section no longer applicable with respect to Federal lands, but applicability of section to Indian leases not affected, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/185/s8/a"},"text":"section 8(a) of Pub. L. 104–185","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1732"},"text":"section 1732 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
