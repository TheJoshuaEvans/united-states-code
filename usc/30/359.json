{"tag":"section","attrib":{"id":"id5fff711d-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s359"},"text":null,"children":[{"tag":"num","attrib":{"value":"359"},"text":"§ 359.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to prescribe such rules and regulations as are necessary and appropriate to carry out the purposes of this chapter, which rules and regulations shall be the same as those prescribed under the mineral leasing laws to the extent that they are applicable.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fff711e-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-08-07/ch513/s10"},"text":"Aug. 7, 1947, ch. 513, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/915"},"text":"61 Stat. 915","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5fff711f-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5fff7120-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5fff7121-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of “mineral leasing laws”, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s351"},"text":"section 351 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5fff7122-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id5fff7123-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of Secretary of the Interior to promulgate regulations under this chapter relating to fostering of competition for Federal leases, implementation of alternative bidding systems authorized for award of Federal leases, establishment of diligence requirements for operations conducted on Federal leases, setting of rates for production of Federal leases, and specifying of procedures, terms, and conditions for acquisition and disposition of Federal royalty interests taken in kind, transferred to Secretary of Energy by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7152/b"},"text":"section 7152(b) of Title 42","children":[],"tail":", The Public Health and Welfare. "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7152/b"},"text":"Section 7152(b) of Title 42","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/97/100/tII/s201"},"text":"Pub. L. 97–100, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-23"},"text":"Dec. 23, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1407"},"text":"95 Stat. 1407","children":[],"tail":", and functions of Secretary of Energy returned to Secretary of the Interior. See House Report No. 97–315, pp. 25, 26, "},{"tag":"date","attrib":{"date":"1981-11-05"},"text":"Nov. 5, 1981","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
