{"tag":"section","attrib":{"id":"id5fe076b6-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s76"},"text":null,"children":[{"tag":"num","attrib":{"value":"76"},"text":"§ 76.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of rights upon coal lands; sale of certain mining lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in sections 71 to 75 of this title shall be construed to destroy or impair any rights which may have attached prior to the third day of March, 1873, or to authorize the sale of lands valuable for mines of gold, silver, or copper.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fe076b7-3a70-11f1-83b4-f01f82055b58"},"text":"(R.S. § 2352.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5fe076b8-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5fe076b9-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5fe076ba-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2352 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1873-03-03/ch279/s6"},"text":"act Mar. 3, 1873, ch. 279, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/17/608"},"text":"17 Stat. 608","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id5fe076bb-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Docum