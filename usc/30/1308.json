{"tag":"section","attrib":{"id":"id604e2ca2-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1308"},"text":null,"children":[{"tag":"num","attrib":{"value":"1308"},"text":"§ 1308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this chapter, no authority to make payments under this chapter shall be effective except to such extent or in such amounts as are provided in advance in appropriation Acts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id604e2ca3-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/87/tVII/s718"},"text":"Pub. L. 95–87, title VII, § 718","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"Aug. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/526"},"text":"91 Stat. 526","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
