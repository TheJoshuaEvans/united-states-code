{"tag":"section","attrib":{"id":"id5fe076a7-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s74"},"text":null,"children":[{"tag":"num","attrib":{"value":"74"},"text":"§ 74.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of coal land entries; other entries upon noncompliance with conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Sections 71 to 73 of this title shall be held to authorize only one entry by the same person or association of persons; and no association of persons any member of which shall have taken the benefit of such sections, either as an individual or as a member of any other association, shall enter or hold any other lands under the provisions thereof; and no member of any association which shall have taken the benefit of such sections shall enter or hold any other lands under their provisions; and all persons claiming under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s72"},"text":"section 72 of this title","children":[],"tail":" shall be required to prove their respective rights and pay for the lands filed upon within one year from the time prescribed for filing their respective claims; and upon failure to file the proper notice, or to pay for the land within the required period, the same shall be subject to entry by any other qualified applicant."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fe076a8-3a70-11f1-83b4-f01f82055b58"},"text":"(R.S. § 2350.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5fe076a9-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5fe076aa-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{