{"tag":"section","attrib":{"id":"id5ff1185f-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s192b"},"text":null,"children":[{"tag":"num","attrib":{"value":"192b"},"text":"§ 192b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of sections 192a to 192c of this title shall apply to all existing contracts for the purchase of Government royalty oil entered into after ","children":[{"tag":"date","attrib":{"date":"1946-07-13"},"text":"July 13, 1946","children":[],"tail":", and prior to "},{"tag":"date","attrib":{"date":"1949-09-01"},"text":"September 1, 1949","children":[],"tail":", irrespective of whether a determination of preference status was made in connection with the award of such contracts, but shall not apply to any such contract which subsequent to its award has been transferred, through the acquisition of stock interests or other transactions, to the ownership or control of a refinery ineligible for a preference under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s192"},"text":"section 192 of this title","children":[],"tail":", and the regulations in force thereunder at the time of such transfer."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5ff11860-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-09-01/ch529/s2"},"text":"Sept. 1, 1949, ch. 529, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/682"},"text":"63 Stat. 682","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5ff11861-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5ff11862-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5ff11863-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-02-25/ch85"},"text":"act Feb. 25, 1920, ch. 85","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/437"},"text":"41 Stat. 437","children":[],"tail":", known as the Mineral Leasing Act, which comprises this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
