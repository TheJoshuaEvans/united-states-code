{"tag":"section","attrib":{"id":"id60090d85-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s641"},"text":null,"children":[{"tag":"num","attrib":{"value":"641"},"text":"§ 641.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and maintenance of program for exploration; financial assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is hereby authorized and directed, in order to provide for discovery of additional domestic mineral reserves, to establish and maintain a program for exploration by private industry within the United States, its Territories and possessions for such minerals, excluding organic fuels, as he shall from time to time designate, and to provide Federal financial assistance on a participating basis for that purpose.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id60090d86-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/701/s1"},"text":"Pub. L. 85–701, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-21"},"text":"Aug. 21, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/700"},"text":"72 Stat. 700","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id60090d87-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id60090d88-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id60090d89-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Declaration of Policy","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The recital clause of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/701"},"text":"Pub. L. 85–701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-21"},"text":"Aug. 21, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/700"},"text":"72 Stat. 700","children":[],"tail":", which preceded section 1, provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/85/701"},"text":"“That it is declared to be the policy of the Congress to stimulate exploration for minerals within the United States, its Territories and possessions.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
