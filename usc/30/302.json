{"tag":"section","attrib":{"id":"id5fff70d6-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s302"},"text":null,"children":[{"tag":"num","attrib":{"value":"302"},"text":"§ 302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment of lease; subletting","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The right conferred by this chapter may, subject to the approval of the Secretary of the Interior, be assigned or sublet by the owner thereof to any corporation, firm, association, or individual.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fff70d7-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-05-21/ch307/s2"},"text":"May 21, 1930, ch. 307, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/373"},"text":"46 Stat. 373","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
