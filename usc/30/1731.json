{"tag":"section","attrib":{"id":"id6063b0e0-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1731"},"text":null,"children":[{"tag":"num","attrib":{"value":"1731"},"text":"§ 1731.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of subchapter","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This subchapter shall apply only with respect to oil and gas leases on Federal lands or Indian lands. Nothing in this subchapter shall be construed to apply to any lease on the Outer Continental Shelf.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6063b0e1-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/451/tII/s201"},"text":"Pub. L. 97–451, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2457"},"text":"96 Stat. 2457","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
