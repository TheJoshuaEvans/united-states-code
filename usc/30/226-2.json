{"tag":"section","attrib":{"id":"id5ffab5dd-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s226–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"226–2"},"text":"§ 226–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations for filing oil and gas contests","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No action contesting a decision of the Secretary involving any oil and gas lease shall be maintained unless such action is commenced or taken within ninety days after the final decision of the Secretary relating to such matter. No such action contesting such a decision of the Secretary rendered prior to ","children":[{"tag":"date","attrib":{"date":"1960-09-02"},"text":"September 2, 1960","children":[],"tail":" shall be maintained unless the same be commenced or taken within ninety days after "},{"tag":"date","attrib":{"date":"1960-09-02"},"text":"September 2, 1960","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5ffab5de-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-02-25/ch85/s42"},"text":"Feb. 25, 1920, ch. 85, § 42","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/86/705/s5"},"text":"Pub. L. 86–705, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-02"},"text":"Sept. 2, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/790"},"text":"74 Stat. 790","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
