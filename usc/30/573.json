{"tag":"section","attrib":{"id":"id60069c23-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s573"},"text":null,"children":[{"tag":"num","attrib":{"value":"573"},"text":"§ 573.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement by Commonwealth for Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commonwealth shall furnish to the Secretary of the Interior a statement with respect to the project showing work done, the status of the project, expenditures and amounts obligated, at such times and in such detail as the Secretary of the Interior shall require for the purposes of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id60069c24-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-15/ch369/s3"},"text":"July 15, 1955, ch. 369, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/353"},"text":"69 Stat. 353","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
