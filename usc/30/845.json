{"tag":"section","attrib":{"id":"id60173dd4-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s845"},"text":null,"children":[{"tag":"num","attrib":{"value":"845"},"text":"§ 845.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dust standards in presence of quartz","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In coal mining operations where the concentration of respirable dust in the mine atmosphere of any working place contains more than 5 per centum quartz, the Secretary of Health and Human Services shall prescribe an appropriate formula for determining the applicable respirable dust standard under this subchapter for such working place and the Secretary shall apply such formula in carrying out his duties under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id60173dd5-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/173/tII/s205"},"text":"Pub. L. 91–173, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/765"},"text":"83 Stat. 765","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id60173dd6-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id60173dd7-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id60173dd8-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Health and Human Services” substituted in text for “Secretary of Health, Education, and Welfare” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":" which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id60173dd9-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section operative six months after ","children":[{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", except to the extent an earlier date is specifically provided for in "},{"tag":"ref","attrib":{"href":"/us/pl/91/173"},"text":"Pub. L. 91–173","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/173/s509"},"text":"section 509 of Pub. L. 91–173","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
