{"tag":"section","attrib":{"id":"id6033eded-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1230a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1230a"},"text":"§ 1230a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategic Resources Generic Mineral Technology Center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6033edee-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1230a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of ","children":[{"tag":"ref","attrib":{"idref":"fn002061"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002061"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “of the”."}],"tail":" Interior is authorized and directed to establish a Strategic Resources Mineral Technology Center (hereinafter referred to as the “center”) for the purpose of improving existing, and developing new, technologies that will decrease the dependence of the United States on supplies of strategic and critical minerals."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6033edef-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1230a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The center shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6033edf0-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1230a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for studies and technology development in the areas of mineral extraction and refining processes, product substitution and conservation of mineral resources through recycling and advanced processing and fabrication methods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6033edf1-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1230a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify new deposits of strategic and critical mineral resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6033edf2-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1230a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the transfer of information, studies, and technologies developed by the center to the private sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6033edf3-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1230a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish the center referred to in subsection (a) at a university that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6033edf4-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1230a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not currently host a generic mineral technology center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6033edf5-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1230a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has established advanced degree programs in geology and geological engineering, and metallurgical and mining engineering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6033edf6-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1230a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has expertise in materials and advanced processing research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6033edf7-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1230a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located west of the 100th meridian.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6033edf8-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1230a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated such sums as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6033edf9-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/409/s12"},"text":"Pub. L. 98–409, § 12","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/498/s2"},"text":"Pub. L. 101–498, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-02"},"text":"Nov. 2, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1207"},"text":"104 Stat. 1207","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6033edfa-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6033edfb-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6033edfc-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Mining and Mineral Resources Research Institute Act of 1984, and not as part of the Surface Mining Control and Reclamation Act of 1977 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
