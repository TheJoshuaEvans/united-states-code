dren":[{"tag":"ref","attrib":{"href":"/us/stat/83/742"},"text":"83 Stat. 742","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t30/s801"},"text":"30 U.S.C. 801","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id604bbc17-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1292/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/stat/79/903"},"text":"79 Stat. 903","children":[],"tail":"), as amended ["},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"33 U.S.C. 1251","children":[],"tail":" et seq.], the State laws enacted pursuant thereto, or other Federal laws relating to preservation of water quality."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id604bbc18-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1292/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Clean Air Act, as amended [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"42 U.S.C. 7401","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id604bbc19-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1292/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Solid Waste Disposal Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6901"},"text":"42 U.S.C. 6901","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id604bbc1a-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1292/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Refuse Act of 1899 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s407"},"text":"33 U.S.C. 407","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id604bbc1b-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1292/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Fish and Wildlife Coordination Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s661–666c"},"text":"16 U.S.C. 661–666c","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id604bbc1c-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1292/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Mineral Leasing Act of 1920, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s181"},"text":"30 U.S.C. 181","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id604bbc1d-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1292/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on authority of Secretary or heads of other Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall affect in any way the authority of the Secretary or the heads of other Federal agencies under other provisions of law to include in any lease, license, permit, contract, or other instrument such conditions as may be appropriate to regulate surface coal mining and reclamation operations on land under their jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id604bbc1e-3a70-11f1-83b4-f01