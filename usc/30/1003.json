{"tag":"section","attrib":{"id":"id602a50c5-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1003"},"text":null,"children":[{"tag":"num","attrib":{"value":"1003"},"text":"§ 1003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leasing procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id602a50c6-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1003/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nominations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall accept nominations of land to be leased at any time from qualified companies and individuals under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id602a50c7-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1003/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive lease sale required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id602a50c8-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1003/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise specifically provided by this chapter, all land to be leased that is not subject to leasing under subsection (c) shall be leased as provided in this subsection to the highest responsible qualified bidder, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602a50c9-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1003/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive lease sales","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall hold a competitive lease sale at least once every 2 years for land in a State that has nominations pending under subsection (a) if the land is otherwise available for leasing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602a50ca-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1003/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lands subject to mining claims","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Lands that are subject to a mining claim for which a plan of operations has been approved by the relevant Federal land management agency may be available for noncompetitive leasing under this section to the mining claim holder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602a50cb-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1003/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land subject to oil and gas lease","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Land under an oil and gas lease issued pursuant to the Mineral Leasing Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s181"},"text":"30 U.S.C. 181","children":[],"tail":" et seq.) or the Mineral Leasing Act for Acquired Lands ("},{"tag":"ref","attrib":{"href":"/us/usc/t30/s351"},"text":"30 U.S.C. 351","children":[],"tail":" et seq.) that is subject to an approved application for permit to drill and from which oil and gas production is occurring may be available for noncompetitive leasing under subsection (c) by the holder of the oil and gas lease—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id602a50cc-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1003/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a determination that geothermal energy will be produced from a well producing or capable of producing oil and gas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602a50cd-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1003/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for the coproduction of geothermal energy with oil and gas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id602a50ce-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1003/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncompetitive leasing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make available for a period of 2 years for noncompetitive leasing any tract for which a competitive lease sale is held, but for which the Secretary does not receive any bids in a competitive lease sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id602a50cf-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1003/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pending lease applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id602a50d0-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1003/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be a priority for the Secretary, and for the Secretary of Agriculture with respect to National Forest Systems land, to ensure timely completion of administrative actions, including amendments to applicable forest plans and resource management plans, necessary to process applications for geothermal leasing pending on ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn002054"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002054"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Codification note below."}],"tail":" All future forest plans and resource management plans for areas with high geothermal resource potential shall consider geothermal leasing and development."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602a50d1-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1003/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application described in paragraph (1) and any lease issued pursuant to the application—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id602a50d2-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1003/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subparagraph (B), shall be subject to this section as in effect on the day before ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602a50d3-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1003/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the election of the applicant, shall be subject to this section as in effect on ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id602a50d4-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1003/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leases sold as a block","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If information is available to the Secretary indicating a geothermal resource that could be produced as 1 unit can reasonably be expected to underlie more than 1 parcel to be offered in a competitive lease sale, the parcels for such a resource may be offered for bidding as a block in the competitive lease sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id602a50d5-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1003/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leasing for direct use of geothermal resources","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsection (b), the Secretary may identify areas in which the land to be leased under this chapter exclusively for direct use of geothermal resources, without sale for purposes other than commercial generation of electricity, may be leased to any qualified applicant that first applies for such a lease under regulations issued by the Secretary, if the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id602a50d6-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1003/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publishes a notice of the land proposed for leasing not later than 90 days before the date of the issuance of the lease;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602a50d7-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1003/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not receive during the 90-day period beginning on the date of the publication any nomination to include the land concerned in the next competitive lease sale; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602a50d8-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1003/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines there is no competitive interest in the geothermal resources in the land to be leased.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id602a50d9-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1003/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area subject to lease for direct use","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id602a50da-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1003/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), a geothermal lease for the direct use of geothermal resources shall cover not more than the quantity of acreage determined by the Secretary to be reasonably necessary for the proposed use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602a50db-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1003/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The quantity of acreage covered by the lease shall not exceed the limitations established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1006"},"text":"section 1006 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id602a50dc-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/581/s4"},"text":"Pub. L. 91–581, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1566"},"text":"84 Stat. 1566","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tII"},"text":"Pub. L. 109–58, title II","children":[],"tail":", §§ 222, 223(b), "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/660"},"text":"119 Stat. 660","children":[],"tail":", 662; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIII/s3105"},"text":"Pub. L. 116–260, div. Z, title III, § 3105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2516"},"text":"134 Stat. 2516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id602a50dd-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id602a50de-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id602a50df-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Mineral Leasing Act, referred to in subsec. (b)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-02-25/ch85"},"text":"act Feb. 25, 1920, ch. 85","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/437"},"text":"41 Stat. 437","children":[],"tail":", which is classified generally to chapter 3A (§ 181 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s181"},"text":"section 181 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Mineral Leasing Act for Acquired Lands, referred to in subsec. (b)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-08-07/ch513"},"text":"act Aug. 7, 1947, ch. 513","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/913"},"text":"61 Stat. 913","children":[],"tail":", which is classified generally to chapter 7 (§ 351 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s351"},"text":"section 351 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id602a50e0-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", referred to in subsec. (d)(1), was in the original “the date of enactment of this subsection” which was translated as meaning the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":", which amended this section generally, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id602a50e1-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s222"},"text":"Pub. L. 109–58, § 222","children":[],"tail":", inserted section catchline and amended text generally. Prior to amendment, text related to competitive bidding requirements, conversion of prior leases to geothermal leases, conflicting land interests, conversion of prior applications, acreage limitation, regulations, and time for payment."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s223/b"},"text":"Pub. L. 109–58, § 223(b)","children":[],"tail":", added subsecs. (f) and (g)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
