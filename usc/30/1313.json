{"tag":"section","attrib":{"id":"id604e2ce2-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1313"},"text":null,"children":[{"tag":"num","attrib":{"value":"1313"},"text":"§ 1313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id604e2ce3-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1313/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No institutions of higher education may receive more than $4,000,000 for the construction of its coal research laboratory, including initially installed fixed equipment, nor may it receive more than $1,500,000 for initially installed movable equipment, nor may it receive more than $500,000 for new program startup expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id604e2ce4-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1313/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No institution of higher education may receive more than $1,500,000 per year from the Federal Government for operating expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id604e2ce5-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/87/tVIII/s803"},"text":"Pub. L. 95–87, title VIII, § 803","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"Aug. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/528"},"text":"91 Stat. 528","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
