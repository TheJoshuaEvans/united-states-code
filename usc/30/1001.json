{"tag":"section","attrib":{"id":"id602a50a6-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1001"},"text":null,"children":[{"tag":"num","attrib":{"value":"1001"},"text":"§ 1001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter, the term—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id602a50a7-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1001/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of the Interior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id602a50a8-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1001/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “geothermal lease” means a lease issued under authority of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id602a50a9-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1001/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “geothermal resources” means (i) all products of geothermal processes, embracing indigenous steam, hot water and hot brines; (ii) steam and other gases, hot water and hot brines resulting from water, gas, or other fluids artificially introduced into geothermal formations; (iii) heat or other associated energy found in geothermal formations; and (iv) any byproduct derived from them;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id602a50aa-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1001/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “byproduct” means any mineral or minerals (exclusive of oil, hydrocarbon gas, and helium) which are found in solution or in association with geothermal steam and which have a value of less than 75 per centum of the value of the geothermal steam or are not, because of quantity, quality, or technical difficulties in extraction and production, of sufficient value to warrant extraction and production by themselves;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id602a50ab-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1001/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “known geothermal resources area” means an area in which the geology, nearby discoveries, competitive interests, or other indicia would, in the opinion of the Secretary, engender a belief in men who are experienced in the subject matter that the prospects for extraction of geothermal steam or associated geothermal resources are good enough to warrant expenditures of money for that purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id602a50ac-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1001/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “Significant ","children":[{"tag":"ref","attrib":{"idref":"fn002052"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002052"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" thermal features within units of the National Park System” shall include, but not be limited to, the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id602a50ad-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1001/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Thermal features within units of the National Park System listed in Section ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" 1026(a)(1) of this title and designated as significant in the Federal Register notice of "},{"tag":"date","attrib":{"date":"1987-08-03"},"text":"August 3, 1987","children":[],"tail":" (Vol. 52, No. 148 Fed. Reg. 28790)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602a50ae-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1001/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Crater Lake National Park.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602a50af-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1001/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Thermal features within Big Bend National Park and Lake Mead National Recreation Area proposed as significant in the Federal Register notice of ","children":[{"tag":"date","attrib":{"date":"1987-02-13"},"text":"February 13, 1987","children":[],"tail":" (Vol. 52, No. 30 Fed. Reg. 4700)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602a50b0-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1001/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Thermal features within units of the National Park System added to the significant thermal features list pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1026/a/2"},"text":"section 1026(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id602a50b1-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1001/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “direct use” means utilization of geothermal resources for commercial, residential, agricultural, public facilities, or other energy needs other than the commercial production of electricity; and ","children":[{"tag":"ref","attrib":{"idref":"fn002053"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002053"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should end with a period instead of “; and”."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id602a50b2-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/581/s2"},"text":"Pub. L. 91–581, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1566"},"text":"84 Stat. 1566","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/443/s2/a"},"text":"Pub. L. 100–443, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-22"},"text":"Sept. 22, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1766"},"text":"102 Stat. 1766","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tII/s236/1"},"text":"Pub. L. 109–58, title II, § 236(1)","children":[],"tail":", (2), (5), "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/671"},"text":"119 Stat. 671","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id602a50b3-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id602a50