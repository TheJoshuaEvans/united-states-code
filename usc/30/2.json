{"tag":"section","attrib":{"id":"id5fd48fdb-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"§ 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance of duties in absence of director","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1916-07-01"},"text":"July 1, 1916","children":[],"tail":", in the absence of the Director of the United States Bureau of Mines the assistant director of said bureau shall perform the duties of the director during the latter’s absence, and in the absence of the Director and of the Assistant Director of the United States Bureau of Mines the Secretary of the Interior may designate some officer of said bureau to perform the duties of the director during his absence."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fd48fdc-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-07-01/ch209/s1"},"text":"July 1, 1916, ch. 209, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/303"},"text":"39 Stat. 303","children":[],"tail":"; Ex. Ord. No. 4239, "},{"tag":"date","attrib":{"date":"1925-06-04"},"text":"June 4, 1925","children":[],"tail":"; Ex. Ord. No. 6611, "},{"tag":"date","attrib":{"date":"1934-02-22"},"text":"Feb. 22, 1934","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/285/s10/b"},"text":"Pub. L. 102–285, § 10(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-18"},"text":"May 18, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/172"},"text":"106 Stat. 172","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5fd48fdd-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5fd48fde-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id5fd48fdf-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“United States Bureau of Mines” substituted in text for “Bureau of Mines” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/285/s10/b"},"text":"section 10(b) of Pub. L. 102–285","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1"},"text":"section 1 of this title","children":[],"tail":". For provisions relating to closure and transfer of functions of the United States Bureau of Mines, see Transfer of Functions note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
