{"tag":"section","attrib":{"id":"id604bbc75-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1302"},"text":null,"children":[{"tag":"num","attrib":{"value":"1302"},"text":"§ 1302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"There is authorized to be appropriated to the Secretary for the purposes of this chapter the following sums; and all such funds appropriated shall remain available until expended:","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id604bbc76-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the implementation and funding of sections 1252, 1273, and 1300 of this title, there are authorized to be appropriated to the Secretary of the Interior the sum of $10,000,000 for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1978-09-30"},"text":"September 30, 1978","children":[],"tail":", $25,000,000 for each of the two succeeding fiscal years, and in such fiscal years such additional amounts as may be necessary for increases in salary, pay, retirement, other employee benefits authorized by law, and other nondiscretionary costs."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id604bbc77-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the implementation and funding of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1257/c"},"text":"section 1257(c) of this title","children":[],"tail":", see the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1231/c/9"},"text":"section 1231(c)(9) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id604bbc78-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the implementation and funding of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1295"},"text":"section 1295 of this title","children":[],"tail":" and for the administrative and other purposes of this chapter, except as otherwise provided for in this chapter, authorization is provided for the sum of $20,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"September 30, 1978","children":[],"tail":", and $30,000,000 for each of the two succeeding fiscal years and such funds that are required thereafter."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id604bbc79-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1302/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order that the implementation of the requirements of this chapter may be initiated in a timely and orderly manner, the Secretary is authorized, subject to the approval of the appropriation Committees of the House and of the Senate, to utilize not to exceed $2,000,000 of the appropriations otherwise available to him for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1977-09-30"},"text":"September 30, 1977","children":[],"tail":", for the administration and other purposes of the chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id604bbc7a-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/87/tVII/s712"},"text":"Pub. L. 95–87, title VII, § 712","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"Aug. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/524"},"text":"91 Stat. 524","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/343/s1"},"text":"Pub. L. 95–343, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-08-11"},"text":"Aug. 11, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/473"},"text":"92 Stat. 473","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tVI/s6012/b"},"text":"Pub. L. 101–508, title VI, § 6012(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-298"},"text":"104 Stat. 1388–298","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/dC/tII/s201/b"},"text":"Pub. L. 109–432, div. C, title II, § 201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3008"},"text":"120 Stat. 3008","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id604bbc7b-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id604bbc7c-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id604bbc7d-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432"},"text":"Pub. L. 109–432","children":[],"tail":" substituted “1231(c)(9)” for “1231(c)(11)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “For the implementation and funding of "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1257/c"},"text":"section 1257(c) of this title","children":[],"tail":" there are authorized to be appropriated sums reserved by "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1231/b/1"},"text":"section 1231(b)(1) of this title","children":[],"tail":" for the purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1257/c"},"text":"section 1257(c) of this title","children":[],"tail":" and such additional sums as may be necessary (i) for the fiscal year ending "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"September 30, 1978","children":[],"tail":", to provide an amount not to exceed $10,000,000 to carry out the purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1257/c"},"text":"section 1257(c) of this title","children":[],"tail":" and (ii) for the fiscal years ending "},{"tag":"date","attrib":{"date":"1979-09-30"},"text":"September 30, 1979","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1980-09-30"},"text":"September 30, 1980","children":[],"tail":", to provide an amount not to exceed $25,000,000 to carry out the purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1257/c"},"text":"section 1257(c) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/343/s1/1"},"text":"Pub. L. 95–343, § 1(1)","children":[],"tail":", increased authorization from $10,000,000 to $25,000,000 for each of the two succeeding fiscal years, and inserted provisions authorizing such necessary additional amounts for increases in salary, etc."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/343/s1/2"},"text":"Pub. L. 95–343, § 1(2)","children":[],"tail":", substituted provisions authorizing appropriations of not to exceed $10,000,000 for fiscal year ending "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"Sept. 30, 1978","children":[],"tail":", and not to exceed $25,000,000 for each of fiscal years ending "},{"tag":"date","attrib":{"date":"1979-09-30"},"text":"Sept. 30, 1979","children":[],"tail":", and 1980, for provisions authorizing appropriations of not to exceed $10,000,000 and such additional amounts as are necessary for fiscal year ending "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"Sept. 30, 1978","children":[],"tail":", and for each fiscal year for a period of fifteen fiscal years thereafter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id604bbc7e-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id604bbc7f-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1991-10-01"},"text":"Oct. 1, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s6014"},"text":"section 6014 of Pub. L. 101–508","children":[],"tail":" set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1231"},"text":"section 1231 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id604bbc80-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Crediting Performance Bond Forfeitures","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tI"},"text":"Pub. L. 105–277, div. A, § 101(e) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–244, provided in part that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/277/dA/s101/e/tI"},"text":"“Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"31 U.S.C. 3302","children":[],"tail":", an additional amount shall be credited to this account, to remain available until expended, from performance bond forfeitures in fiscal year 1999 and thereafter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id604bbc81-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Cost-Based Fees for Products of Mine Map Repository","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tI"},"text":"Pub. L. 105–277, div. A, § 101(e) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–244, provided in part that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/277/dA/s101/e/tI"},"text":"“Beginning in fiscal year 1999 and thereafter, cost-based fees for the products of the Mine Map Repository shall be established (and revised as needed) in Federal Register Notices, and shall be collected and credited to this account, to be available until expended for the costs of administering this program.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
