{"tag":"section","attrib":{"id":"id6065fac1-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1904"},"text":null,"children":[{"tag":"num","attrib":{"value":"1904"},"text":"§ 1904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marine mineral research centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6065fac2-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1996-10-19"},"text":"October 19, 1996","children":[],"tail":", the Secretary shall designate 3 centers for marine mineral research and related activities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6065fac3-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concentration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"One center shall concentrate primarily on research in the continental shelf regions of the United States, 1 center shall concentrate primarily on research in deep seabed and near-shore environments of islands, and 1 center shall concentrate primarily on research in arctic and cold water regions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6065fac4-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1904/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In designating a center under this section, the Secretary shall give priority to a university that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6065fac5-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1904/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administers a federally funded center for marine minerals research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fac6-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1904/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" matriculates students for advanced degrees in marine geological sciences, nonenergy natural resources, and related fields of science and engineering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fac7-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1904/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a United States university with established programs and facilities that primarily focus on marine mineral resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fac8-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1904/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has engaged in collaboration and cooperation with industry, governmental agencies, and other universities in the field of marine mineral resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fac9-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1904/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has demonstrated significant engineering, development, and design experience in two or more of the following areas; ","children":[{"tag":"ref","attrib":{"idref":"fn002110"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002110"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The semicolon probably should be a colon."}],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6065faca-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1904/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seabed exploration systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6065facb-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1904/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marine mining systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6065facc-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1904/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marine mineral processing systems; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065facd-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1904/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been designated by the Secretary as a State Mining and Mineral Resources Research Institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6065face-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1904/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Center activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A center shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6065facf-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1904/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance to the Secretary concerning marine mineral resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fad0-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1904/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary on pertinent international activities in marine mineral resources development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fad1-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1904/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage in research, training, and education transfer associated with the characterization and utilization of marine mineral resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fad2-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1904/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the efficient identification, assessment, exploration, and management of marine mineral resources in an environmentally sound manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6065fad3-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1904/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In distributing funds to the centers designated under subsection (a), the Secretary shall, to the extent practicable, allocate an equal amount to each center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6065fad4-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1904/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6065fad5-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1904/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 5 percent of the amount made available to carry out this section during a fiscal year may be used by the Secretary for expenses associated with administration of the program authorized by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fad6-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1904/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"None of the funds made available under this section may be used for the construction of a new building or the acquisition, expansion, remodeling, or alteration of an existing building (including site grading and improvement and architect fees).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6065fad7-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/631/tII/s204"},"text":"Pub. L. 91–631, title II, § 204","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/325/s2/3"},"text":"Pub. L. 104–325, § 2(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3998"},"text":"110 Stat. 3998","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
