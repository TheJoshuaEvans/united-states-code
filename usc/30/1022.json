{"tag":"section","attrib":{"id":"id602f32b1-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1022"},"text":null,"children":[{"tag":"num","attrib":{"value":"1022"},"text":"§ 1022.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevention of waste; exclusivity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id602f32b2-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1022/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All leases under this chapter shall be subject to the condition that the lessee will, in conducting his exploration, development, and producing operations, use all reasonable precautions to prevent waste of geothermal resources developed in the lands leased.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id602f32b3-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1022/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rights to develop and utilize geothermal resources underlying lands owned by the United States may be acquired solely in accordance with the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id602f32b4-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/581/s23"},"text":"Pub. L. 91–581, § 23","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1573"},"text":"84 Stat. 1573","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tII/s236/1"},"text":"Pub. L. 109–58, title II, § 236(1)","children":[],"tail":", (21), "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/671"},"text":"119 Stat. 671","children":[],"tail":", 673.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id602f32b5-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id602f32b6-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id602f32b7-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":" inserted section catchline and substituted “geothermal resources” for “geothermal steam and associated geothermal resources” in subsecs. (a) and (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
