{"tag":"section","attrib":{"id":"id5fff70fd-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s353"},"text":null,"children":[{"tag":"num","attrib":{"value":"353"},"text":"§ 353.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of lands unaffected; reservation of mineral rights; sale subject to prior lease; naval petroleum reserves unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing herein contained shall be deemed or construed to (a) amend, modify, or change any existing law authorizing or requiring the sale of acquired lands, or (b) empower any commission, bureau, or agency of the Government to make a reservation of the minerals in the sale of any acquired land: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That any such sale or conveyance of lands shall be made by the agency having jurisdiction thereof, subject to any lease theretofore made, covering the mineral deposits underlying such lands: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That nothing in this chapter is intended, or shall be construed to affect in any manner any provision of chapter 869 of title 10."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fff70fe-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-08-07/ch513/s4"},"text":"Aug. 7, 1947, ch. 513, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/914"},"text":"61 Stat. 914","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s809/i/2"},"text":"Pub. L. 115–232, div. A, title VIII, § 809(i)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1843"},"text":"132 Stat. 1843","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5fff70ff-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5fff7100-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5fff7101-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “chapter 869 of title 10” for “the Act of "},{"tag":"date","attrib":{"date":"1938-06-30"},"text":"June 30, 1938","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/32/1252"},"text":"32 Stat. 1252","children":[],"tail":"), amending the Act of "},{"tag":"date","attrib":{"date":"1920-06-04"},"text":"June 4, 1920","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/41/813"},"text":"41 Stat. 813","children":[],"tail":")”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5fff7102-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5fff7103-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
