{"tag":"section","attrib":{"id":"id5ffab62a-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s236a"},"text":null,"children":[{"tag":"num","attrib":{"value":"236a"},"text":"§ 236a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lands in naval petroleum reserves and naval oil-shale reserves; effect of other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in sections 185, 221,","children":[{"tag":"ref","attrib":{"idref":"fn002022"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002022"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" 223, 223a,"},{"tag":"ref","attrib":{"idref":"fn002022"},"text":"1","children":[],"tail":" and 226 of this title and this section shall be construed as affecting any lands within the borders of the naval petroleum reserves and naval oil-shale reserves or agreements concerning operations thereunder or in relation to the same, but the Secretary of the Navy is hereby authorized, with the consent of the President, to enter into agreements such as those provided for under sections 184 and 226 of this title, which agreement shall not, unless expressed therein, operate to extend the terms of any lease affected thereby."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5ffab62b-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-21/ch599/s3"},"text":"Aug. 21, 1935, ch. 599, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/679"},"text":"49 Stat. 679","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5ffab62c-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5ffab62d-3a70-11f1-83b4-f01f82055b58"},"text":null,"childr