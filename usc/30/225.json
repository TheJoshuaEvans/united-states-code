{"tag":"section","attrib":{"id":"id5ff5fa76-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s225"},"text":null,"children":[{"tag":"num","attrib":{"value":"225"},"text":"§ 225.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condition of lease, forfeiture for violation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All leases of lands containing oil or gas, made or issued under the provisions of this chapter, shall be subject to the condition that the lessee will, in conducting his explorations and mining operations, use all reasonable precautions to prevent waste of oil or gas developed in the land, or the entrance of water through wells drilled by him to the oil sands or oil-bearing strata, to the destruction or injury of the oil deposits. Violations of the provisions of this section shall constitute grounds for the forfeiture of the lease, to be enforced as provided in this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5ff5fa77-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-02-25/ch85/s16"},"text":"Feb. 25, 1920, ch. 85, § 16","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/443"},"text":"41 Stat. 443","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-08-08/ch916/s2"},"text":"Aug. 8, 1946, ch. 916, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/951"},"text":"60 Stat. 951","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5ff5fa78-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5ff5fa79-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5ff5fa7a-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1946—Act ","children":[{"tag":"date","attrib":{"date":"1946-08-08"},"text":"Aug. 8, 1946","children":[],"tail":", omitted condition that no wells should be drilled within two hundred feet of boundaries of leased lands."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5ff5fa7b-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"id5ff5fa7c-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"See note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s181"},"text":"section 181 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5ff5fa7d-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Outer Continental Shelf; Terms and Conditions of Leases","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Terms and conditions of mineral leases on submerged lands of outer Continental Shelf, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1337"},"text":"section 1337 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
