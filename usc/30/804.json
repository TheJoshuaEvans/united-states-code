{"tag":"section","attrib":{"id":"id600b5736-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s804"},"text":null,"children":[{"tag":"num","attrib":{"value":"804"},"text":"§ 804.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim Compliance Panel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id600b5737-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s804/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is hereby established the Interim Compliance Panel, which shall be composed of five members as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id600b5738-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s804/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assistant Secretary of Labor for Labor Standards, Department of Labor, or his delegate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id600b5739-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s804/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Director of the National Institute of Standards and Technology, Department of Commerce, or his delegate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id600b573a-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s804/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Administrator of Consumer Protection and Environmental Health Service, Department of Health and Human Services, or his delegate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id600b573b-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s804/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Director of the United States Bureau of Mines, Department of the Interior, or his delegate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id600b573c-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s804/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Director of the National Science Foundation, or his delegate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id600b573d-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s804/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation; travel and subsistence expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Panel shall serve without compensation in addition to that received in their regular employment, but shall be entitled to reimbursement for travel, subsistence, and other necessary expenses incurred by them in the performance of duties vested in the Panel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id600b573e-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s804/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation of Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary of Health and Human Services, the Secretary of Commerce, the Secretary of the Interior, and the Secretary shall, upon request of the Panel, provide the Panel such personnel and other assistance as the Panel determines necessary to enable it to carry out its functions under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id600b573f-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s804/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum; voting; selection of chairman","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Three members of the Panel shall constitute a quorum for doing business. All decisions of the Panel shall be by majority vote. The chairman of the Panel shall be selected by the members from among the membership thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id600b5740-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s804/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of administrative law judges; provisions applicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Panel is authorized to appoint as many administrative law judges as are necessary for proceedings required to be conducted in accordance with the provisions of this chapter. The provisions applicable to administrative law judges appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3105"},"text":"section 3105 of title 5","children":[],"tail":" shall be applicable to administrative law judges appointed pursuant to this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id600b5741-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s804/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions; hearings; notice and review; termination; annual report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id600b5742-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s804/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It shall be the function of the Panel to carry out the duties imposed on it pursuant to this chapter and to provide an opportunity for a public hearing, after notice, at the request of an operator of the affected coal mine or the representative of the miners of such mine. Any operator or representative of miners aggrieved by a final decision of the Panel may file a petition for review of such decision under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s816"},"text":"section 816 of this title","children":[],"tail":". The provisions of this section shall terminate upon completion of the Panel’s functions as set forth under this chapter. Any hearing held pursuant to this subsection shall be of record and the Panel shall make findings of fact and shall issue a written decision incorporating its findings therein in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s554"},"text":"section 554 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id600b5743-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s804/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Panel shall make an annual report, in writing, to the Secretary for transmittal by him to the Congress concerning the achievement of its purposes, and any other relevant information (including any recommendations) which it deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id600b5744-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/173/s5"},"text":"Pub. L. 91–173, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/744"},"text":"83 Stat. 744","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/164/tI/s102/d"},"text":"Pub. L. 95–164, title I, § 102(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-09"},"text":"Nov. 9, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1291"},"text":"91 Stat. 1291","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/251/s2/a/9"},"text":"Pub. L. 95–251, § 2(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-03-27"},"text":"Mar. 27, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/183"},"text":"92 Stat. 183","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5115/c"},"text":"Pub. L. 100–418, title V, § 5115(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1433"},"text":"102 Stat. 1433","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/285/s10/b"},"text":"Pub. L. 102–285, § 10(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-18"},"text":"May 18, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/172"},"text":"106 Stat. 172","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id600b5745-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id600b5746-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id600b5747-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (c), (e), and (f)(1), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/173"},"text":"Pub. L. 91–173","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/742"},"text":"83 Stat. 742","children":[],"tail":", known as the Federal Mine Safety and Health Act of 1977, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s801"},"text":"section 801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id600dc848-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":" substituted “National Institute of Standards and Technology” for “Bureau of Standards”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/251"},"text":"Pub. L. 95–251","children":[],"tail":" substituted “administrative law judges” for “hearing examiners” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/164"},"text":"Pub. L. 95–164","children":[],"tail":" substituted “Secretary of the Interior” for “Secretary of Labor”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id600dc849-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id600dc84a-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“United States Bureau of Mines” substituted for “Bureau of Mines” in subsec. (a)(4) pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/285/s10/b"},"text":"section 10(b) of Pub. L. 102–285","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1"},"text":"section 1 of this title","children":[],"tail":". For provisions relating to closure and transfer of functions of the United States Bureau of Mines, see Transfer of Functions note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Department of Health and Human Services” substituted for “Department of Health, Education, and Welfare” in subsec. (a) and “Secretary of Health and Human Services” substituted for “Secretary of Health, Education, and Welfare” in subsec. (c) pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":" which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id600dc84b-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1977 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/164"},"text":"Pub. L. 95–164","children":[],"tail":" effective 120 days after "},{"tag":"date","attrib":{"date":"1977-11-09"},"text":"Nov. 9, 1977","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/164/s307"},"text":"section 307 of Pub. L. 95–164","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id600dc84c-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions in subsec. (f)(2) of this section relating to transmitting annual report to Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and page 114 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
