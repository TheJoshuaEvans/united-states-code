{"tag":"section","attrib":{"id":"id5fd70148-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"§ 21.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mineral lands reserved","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In all cases lands valuable for minerals shall be reserved from sale, except as otherwise expressly directed by law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fd70149-3a70-11f1-83b4-f01f82055b58"},"text":"(R.S. § 2318.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5fd7014a-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5fd7014b-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5fd7014c-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2318 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1866-07-04/ch166/s5"},"text":"act July 4, 1866, ch. 166, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/14/86"},"text":"14 Stat. 86","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
