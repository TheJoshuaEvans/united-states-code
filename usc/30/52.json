{"tag":"section","attrib":{"id":"id5fe0767a-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s52"},"text":null,"children":[{"tag":"num","attrib":{"value":"52"},"text":"§ 52.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Patents or homesteads subject to vested and accrued water rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All patents granted, or homesteads allowed, shall be subject to any vested and accrued water rights, or rights to ditches and reservoirs used in connection with such water rights,","children":[{"tag":"ref","attrib":{"idref":"fn002005"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002005"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Repeal; Savings Provision note below."}],"tail":" as may have been acquired under or recognized by "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s51"},"text":"section 51 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fe0767b-3a70-11f1-83b4-f01f82055b58"},"text":"(R.S. § 2340; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1891-03-03/ch561/s4"},"text":"Mar. 3, 1891, ch. 561, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/1097"},"text":"26 Stat. 1097","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5fe0767c-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5fe0767d-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5fe0767e-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":