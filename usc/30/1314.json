{"tag":"section","attrib":{"id":"id604e2ce6-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1314"},"text":null,"children":[{"tag":"num","attrib":{"value":"1314"},"text":"§ 1314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments; Federal share of operating expenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id604e2ce7-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" From the amounts appropriated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1316"},"text":"section 1316 of this title","children":[],"tail":", the Secretary of Energy shall pay to each institution of higher education having an application approved under this subchapter an amount equal to the Federal share of the cost of carrying out that application. Such payments may be in installments, by way of reimbursement, or by way of advance with necessary adjustments on account of underpayments or overpayments."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id604e2ce8-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal share of operating expenses for any fiscal year shall not exceed 50 per centum of the cost of the operation of a coal research laboratory.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id604e2ce9-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/87/tVIII/s804"},"text":"Pub. L. 95–87, title VIII, § 804","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"Aug. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/528"},"text":"91 Stat. 528","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/617/tVI/s604/c"},"text":"Pub. L. 95–617, title VI, § 604(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3167"},"text":"92 Stat. 3167","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id604e2cea-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id604e2ceb-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id604e2cec-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617"},"text":"Pub. L. 95–617","children":[],"tail":" substituted “Secretary of Energy” for “Administrator” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
