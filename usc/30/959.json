{"tag":"section","attrib":{"id":"id6028074d-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s959"},"text":null,"children":[{"tag":"num","attrib":{"value":"959"},"text":"§ 959.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study of coordination of Federal and State activities; report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6028074e-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s959/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall make a study to determine the best manner to coordinate Federal and State activities in the field of coal or other mine health and safety so as to achieve (1) maximum health and safety protection for miners, (2) an avoidance of duplication of effort, (3) maximum effectiveness, (4) a reduction of delay to a minimum, and (5) most effective use of Federal inspectors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6028074f-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s959/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall make a report of the results of his study to the Congress as soon as practicable after ","children":[{"tag":"date","attrib":{"date":"1969-12-30"},"text":"December 30, 1969","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id60280750-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/173/tV/s512"},"text":"Pub. L. 91–173, title V, § 512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/804"},"text":"83 Stat. 804","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/164/tIII/s303/g"},"text":"Pub. L. 95–164, title III, § 303(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-09"},"text":"Nov. 9, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1321"},"text":"91 Stat. 1321","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id60280751-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id60280752-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id60280753-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1977—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/164"},"text":"Pub. L. 95–164","children":[],"tail":" inserted reference to mines other than coal mines."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id60280754-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id60280755-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1977 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/164"},"text":"Pub. L. 95–164","children":[],"tail":" effective 120 days after "},{"tag":"date","attrib":{"date":"1977-11-09"},"text":"Nov. 9, 1977","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"