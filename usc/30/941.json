{"tag":"section","attrib":{"id":"id6025968d-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s941"},"text":null,"children":[{"tag":"num","attrib":{"value":"941"},"text":"§ 941.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for false statements or representations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person who willfully makes any false or misleading statement or representation for the purpose of obtaining any benefit or payment under this subchapter shall be guilty of a misdemeanor and on conviction thereof shall be punished by a fine of not more than $1,000, or by imprisonment for not more than one year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6025968e-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/173/tIV/s431"},"text":"Pub. L. 91–173, title IV, § 431","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/303/s6"},"text":"Pub. L. 92–303, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-05-19"},"text":"May 19, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/156"},"text":"86 Stat. 156","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/239/s12/a"},"text":"Pub. L. 95–239, § 12(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-03-01"},"text":"Mar. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/101"},"text":"92 Stat. 101","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6025968f-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id60259690-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id60259691-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/239"},"text":"Pub. L. 95–239","children":[],"tail":" substituted provisions setting the penalty for making false or misleading statements or representations for the purpose of obtaining benefits or payments for provisions relating to the Secretary’s duty to disseminate to all persons who filed claims under this subchapter prior to "},{"tag":"date","attrib":{"date":"1972-05-19"},"text":"May 19, 1972","children":[],"tail":", information on the review provisions under the Black Lung Benefits Act of 1972."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id60259692-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id60259693-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/239"},"text":"Pub. L. 95–239","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1978-03-01"},"text":"Mar. 1, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/239/s20/a"},"text":"section 20(a) of Pub. L. 95–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s901"},"text":"section 901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
