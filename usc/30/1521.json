{"tag":"section","attrib":{"id":"id6057a2ea-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1521"},"text":null,"children":[{"tag":"num","attrib":{"value":"1521"},"text":"§ 1521.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservoir insurance program study","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct a detailed study of the need for and feasibility of establishing a reservoir insurance and reinsurance program incorporating the terms, conditions, and provisions set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1522"},"text":"section 1522 of this title","children":[],"tail":", and shall submit to the Congress within one year after "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", a report on the results of such study including his findings and recommendations with respect thereto."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6057a2eb-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294/tVI/s621"},"text":"Pub. L. 96–294, title VI, § 621","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/765"},"text":"94 Stat. 765","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
