{"tag":"section","attrib":{"id":"id5fe07665-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s49f"},"text":null,"children":[{"tag":"num","attrib":{"value":"49f"},"text":"§ 49f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees of recorders in Alaska for filing proofs of work and improvements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The recorders for the several divisions or districts of Alaska shall collect the sum of $1.50 as a fee for the filing, recording, and indexing annual proofs of work and improvements for each claim so recorded under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s49e"},"text":"section 49e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fe07666-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1907-03-02/ch2559/s2"},"text":"Mar. 2, 1907, ch. 2559, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/1243"},"text":"34 Stat. 1243","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5fe07667-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5fe07668-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5fe07669-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s385"},"text":"section 385 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail"