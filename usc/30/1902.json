{"tag":"section","attrib":{"id":"id6065fa88-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1902"},"text":null,"children":[{"tag":"num","attrib":{"value":"1902"},"text":"§ 1902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6065fa89-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1902/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish and carry out a program of research on marine mineral resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6065fa8a-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1902/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program goal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The goal of the program shall be to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6065fa8b-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1902/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote research, identification, assessment, and exploration of marine mineral resources in an environmentally responsible manner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fa8c-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1902/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in developing domestic technologies required for efficient and environmentally sound development of marine mineral resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fa8d-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1902/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate and promote the use of technologies developed with Federal assistance, and the use of available Federal assets, for research, identification, assessment, exploration, and development of marine mineral resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fa8e-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1902/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage academia and industry to conduct basic and applied research, on a joint basis, through grants, cooperative agreements, or contracts with the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6065fa8f-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1902/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6065fa90-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1902/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote and coordinate partnerships between industry, government, and academia to research, identify, assess, and explore marine mineral resources in an environmentally sound manner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fa91-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1902/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" undertake programs to develop the basic information necessary to the long-term national interest in marine mineral resources (including seabed mapping) and to ensure that data and information are accessible and widely disseminated as needed and appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fa92-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1902/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify, and promote cooperation among agency programs that are developing, technologies developed by other Federal programs that may hold promise for facilitating undersea applications related to marine mineral resources, including technologies related to vessels and other platforms, underwater vehicles, survey and mapping systems, remote power sources, data collection and transmission systems, and various seabed research systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fa93-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1902/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foster communication and coordination between Federal and State agencies, universities, and private entities concerning marine mineral research on seabeds of the continental shelf, ocean basins, and arctic and cold water areas.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In carrying out these responsibilities, the Secretary shall ensure the participation of non-Federal users of technologies and data related to marine mineral resources in planning and priority setting.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6065fa94-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/631/tII/s202"},"text":"Pub. L. 91–631, title II, § 202","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/325/s2/3"},"text":"Pub. L. 104–325, § 2(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3995"},"text":"110 Stat. 3995","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6065fa95-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6065fa96-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6065fa97-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Methane Hydrate Research and Development","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/193"},"text":"Pub. L. 106–193","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-02"},"text":"May 2, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/234"},"text":"114 Stat. 234","children":[],"tail":", known as the Methane Hydrate Research and Development Act of 2000, which was set out as a note under this section, was amended and transferred to chapter 32 (§ 2001 et seq.) of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s968"},"text":"Pub. L. 109–58, title IX, § 968","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/894"},"text":"119 Stat. 894","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
