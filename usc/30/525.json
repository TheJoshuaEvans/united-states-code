{"tag":"section","attrib":{"id":"id60042b9c-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s525"},"text":null,"children":[{"tag":"num","attrib":{"value":"525"},"text":"§ 525.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Future location of claims on mineral lands","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Subject to the conditions and provisions of this chapter, mining claims and millsites may hereafter be located under the mining laws of the United States on lands of the United States which at the time of location are—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id60042b9d-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s525/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" included in a permit or lease issued under the mineral leasing laws; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id60042b9e-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s525/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" covered by an application or offer for a permit or lease filed under the mineral leasing laws; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id60042b9f-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s525/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" known to be valuable for minerals subject to disposition under the mineral leasing laws;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to the same extent in all respects as if such lands were not so included or covered or known.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id60042ba0-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-13/ch730/s5"},"text":"Aug. 13, 1954, ch. 730, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/710"},"text":"68 Stat. 710","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
