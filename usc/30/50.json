{"tag":"section","attrib":{"id":"id5fe0766c-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s50"},"text":null,"children":[{"tag":"num","attrib":{"value":"50"},"text":"§ 50.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to States or corporations not to include mineral lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No act passed at the first session of the Thirty-eighth Congress, granting lands to States or corporations to aid in the construction of roads or for other purposes, or to extend the time of grants made prior to the 30th day of January 1865 shall be so construed as to embrace mineral lands, which in all cases are reserved exclusively to the United States, unless otherwise specially provided in the act or acts making the grant.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fe0766d-3a70-11f1-83b4-f01f82055b58"},"text":"(R.S. § 2346.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5fe0766e-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5fe0766f-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5fe07670-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The first session of the Thirty-eighth Congress, referred to in text, was begun ","children":[{"tag":"date","attrib":{"date":"1863-12-07"},"text":"Dec. 7, 1863","children":[],"tail":", and ended "},{"tag":"date","attrib":{"date":"1864-07-04"},"text":"July 4, 1864","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/13/1"},"text":"13 Stat. 1","children":[],"tail":" to 417, contain legislation passed at such session."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5fe07671-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2346 derived from Res. ","children":[{"tag":"date","attrib":{"date":"1865-01-30"},"text":"Jan. 30, 1865","children":[],"tail":", No. 10, "},{"tag":"ref","attrib":{"href":"/us/stat/13/567"},"text":"13 Stat. 567","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
