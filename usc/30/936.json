{"tag":"section","attrib":{"id":"id60259661-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s936"},"text":null,"children":[{"tag":"num","attrib":{"value":"936"},"text":"§ 936.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations and reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id60259662-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s936/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promulgation; applicability of section 553 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor and the Secretary of Health and Human Services are authorized to issue such regulations as each deems appropriate to carry out the provisions of this subchapter. Such regulations shall be issued in conformity with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":", notwithstanding subsection (a) thereof."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id60259663-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s936/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the end of fiscal year 2003 and each succeeding fiscal year, the Secretary of Labor shall submit to the Congress an annual report on the subject matter of this part and part B of this subchapter. Each such report shall be prepared and submitted to Congress in accordance with the requirement with respect to submission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s942"},"text":"section 942 of title 33","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id60259664-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s936/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with State workmen’s compensation laws; conflicts between State and Federal provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall relieve any operator of the duty to comply with any State workmen’s compensation law, except insofar as such State law is in conflict with the provisions of this subchapter and the Secretary by regulation, so prescribes. The provisions of any State workmen’s compensation law which provide greater benefits than the benefits payable under this subchapter shall not thereby be construed or held to be in conflict with the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id60259665-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/173/tIV/s426"},"text":"Pub. L. 91–173, title IV, § 426","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/798"},"text":"83 Stat. 798","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/303/s5/3"},"text":"Pub. L. 92–303, § 5(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-05-19"},"text":"May 19, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/155"},"text":"86 Stat. 155","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/296/tI/s108/i/3"},"text":"Pub. L. 103–296, title I, § 108(i)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-15"},"text":"Aug. 15, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1488"},"text":"108 Stat. 1488","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/tI/s1102/b/2"},"text":"Pub. L. 104–66, title I, § 1102(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/723"},"text":"109 Stat. 723","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/275/s2/b/4"},"text":"Pub. L. 107–275, § 2(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1926"},"text":"116 Stat. 1926","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id60259666-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id60259667-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id60259668-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s942"},"text":"Section 942 of title 33","children":[],"tail":", referred to in subsec. (b), was in the original “section 42 of the Longshore Harbor Worker’s Compensation Act” and was translated as reading “section 42 of the Longshore and Harbor Workers’ Compensation Act” to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id60259669-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/275/s2/b/4/A"},"text":"Pub. L. 107–275, § 2(b)(4)(A)","children":[],"tail":", struck out “, the Commissioner of Social Security,” after “The Secretary of Labor”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/275/s2/b/4/B"},"text":"Pub. L. 107–275, § 2(b)(4)(B)","children":[],"tail":", amended first sentence generally. Prior to amendment, first sentence read as follows: “At the end of each fiscal year, the Commissioner of Social Security shall submit to the Congress an annual report upon the subject matter of part B of this subchapter, and, after "},{"tag":"date","attrib":{"date":"1974-01-01"},"text":"January 1, 1974","children":[],"tail":", the Secretary of Labor shall also submit such a report upon the subject matter of this part.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66"},"text":"Pub. L. 104–66","children":[],"tail":" substituted “At the end of each fiscal year, the” for “Within 120 days following the convening of each session of Congress the” and inserted at end “Each such report shall be prepared and submitted to Congress in accordance with the requirement with respect to submission under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s942"},"text":"section 942 of title 33","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/296/s108/i/3/A"},"text":"Pub. L. 103–296, § 108(i)(3)(A)","children":[],"tail":", substituted “, the Commissioner of Social Security, and the Secretary of Health and Human Services” for “and the Secretary of Health, Education, and Welfare”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/296/s108/i/3/B"},"text":"Pub. L. 103–296, § 108(i)(3)(B)","children":[],"tail":", substituted “Commissioner of Social Security” for “Secretary of Health, Education, and Welfare”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/303"},"text":"Pub. L. 92–303","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1974-01-01"},"text":"January 1, 1974","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1973-01-01"},"text":"January 1, 1973","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6025966a-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6025966b-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/275"},"text":"Pub. L. 107–275","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/275/s4"},"text":"section 4 of Pub. L. 107–275","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s902"},"text":"section 902 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6025966c-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/296"},"text":"Pub. L. 103–296","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1995-03-31"},"text":"Mar. 31, 1995","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/296/s110/a"},"text":"section 110(a) of Pub. L. 103–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s401"},"text":"section 401 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
