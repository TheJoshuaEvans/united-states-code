{"tag":"section","attrib":{"id":"id604bbc29-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1294"},"text":null,"children":[{"tag":"num","attrib":{"value":"1294"},"text":"§ 1294.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person who shall, except as permitted by law, willfully resist, prevent, impede, or interfere with the Secretary or any of his agents in the performance of duties pursuant to this chapter shall be punished by a fine of not more than $5,000 or by imprisonment for not more than one year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id604bbc2a-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/87/tVII/s704"},"text":"Pub. L. 95–87, title VII, § 704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"Aug. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/520"},"text":"91 Stat. 520","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id604bbc2b-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id604bbc2c-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id604bbc2d-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/87/s704"},"text":"Section 704 of Pub. L. 95–87","children":[],"tail":" also amended "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1114"},"text":"section 1114 