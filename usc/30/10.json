{"tag":"section","attrib":{"id":"id5fd70126-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"§ 10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Headquarters of mine rescue cars; site for experimental work; leases and donations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to accept any suitable land or lands, buildings, or improvements that may be donated for the headquarters of mine rescue cars and construction of necessary railway sidings and housing for the same, or as the site of an experimental mine and plant for studying explosives, and to enter into leases for periods not exceeding ten years, subject to annual appropriations by Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fd70127-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-05/ch235/s1"},"text":"June 5, 1920, ch. 235, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/912"},"text":"41 Stat. 912","children":[],"tail":"; Ex. Ord. No. 6611, "},{"tag":"date","attrib":{"date":"1934-02-22"},"text":"Feb. 22, 1934","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5fd70128-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5fd70129-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id5fd7012a-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"See note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
