{"tag":"section","attrib":{"id":"id5feece5a-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s191b"},"text":null,"children":[{"tag":"num","attrib":{"value":"191b"},"text":"§ 191b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of unpaid and underpaid royalties and late payment interest owed by lessees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Beginning in fiscal year 1996 and thereafter, the Secretary shall take appropriate action to collect unpaid and underpaid royalties and late payment interest owed by Federal and Indian mineral lessees and other royalty payors on amounts received in settlement or other resolution of disputes under, and for partial or complete termination of, sales agreements for minerals from Federal and Indian leases.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5feece5b-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/tI/s101/c/tI"},"text":"Pub. L. 104–134, title I, § 101(c) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321-156"},"text":"110 Stat. 1321–156","children":[],"tail":", 1321–167; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/104/140/s1/a"},"text":"Pub. L. 104–140, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-02"},"text":"May 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1327"},"text":"110 Stat. 1327","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5feece5c-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5feece5d-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5feece5e-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-02-25/ch85"},"text":"act Feb. 25, 1920, ch. 85","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/437"},"text":"41 Stat. 437","children":[],"tail":", known as the Mineral Leasing Act, which comprises this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5feece5f-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"similarProvisions","id":"id5feece60-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Similar Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation act:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/332/tI"},"text":"Pub. L. 103–332, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-30"},"text":"Sept. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2508"},"text":"108 Stat. 2508","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
