{"tag":"section","attrib":{"id":"id605ece8f-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1701"},"text":null,"children":[{"tag":"num","attrib":{"value":"1701"},"text":"§ 1701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional statement of findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id605ece90-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id605ece91-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1701/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior should enforce effectively and uniformly existing regulations under the mineral leasing laws providing for the inspection of production activities on lease sites on Federal and Indian lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id605ece92-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1701/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the system of accounting with respect to royalties and other payments due and owing on oil and gas produced from such lease sites is archaic and inadequate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id605ece93-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1701/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is essential that the Secretary initiate procedures to improve methods of accounting for such royalties and payments and to provide for routine inspection of activities related to the production of oil and gas on such lease sites; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id605ece94-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1701/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary should aggressively carry out his trust responsibility in the administration of Indian oil and gas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id605ece95-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It is the purpose of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id605ece96-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1701/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to clarify, reaffirm, expand, and define the responsibilities and obligations of lessees, operators, and other persons involved in transportation or sale of oil and gas from the Federal and Indian lands and the Outer Continental Shelf;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id605ece97-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1701/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to clarify, reaffirm, expand and define the authorities and responsibilities of the Secretary of the Interior to implement and maintain a royalty management system for oil and gas leases on Federal lands, Indian lands, and the Outer Continental Shelf;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id605ece98-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1701/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require the development of enforcement practices that ensure the prompt and proper collection and disbursement of oil and gas revenues owed to the United States and Indian lessors and those inuring to the benefit of States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id605ece99-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1701/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fulfill the trust responsibility of the United States for the administration of Indian oil and gas resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id605ece9a-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1701/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to effectively utilize the capabilities of the States and Indian tribes in developing and maintaining an efficient and effective Federal royalty management system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id605ece9b-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/451/s2"},"text":"Pub. L. 97–451, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2448"},"text":"96 Stat. 2448","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id605ece9c-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id605ece9d-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id605ece9e-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/185/s11"},"text":"Pub. L. 104–185, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-13"},"text":"Aug. 13, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1717"},"text":"110 Stat. 1717","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/185/s11"},"text":"“Except as provided by section 115(h) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1724/h"},"text":"30 U.S.C. 1724(h)","children":[],"tail":"], section 111(h) ["},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1721/h"},"text":"30 U.S.C. 1721(h)","children":[],"tail":"], section 111(k)(5) ["},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1721/k/5"},"text":"30 U.S.C. 1721(k)(5)","children":[],"tail":"], and section 117 ["},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1726"},"text":"30 U.S.C. 1726","children":[],"tail":"] of the Federal Oil and Gas Royalty Management Act of 1982 (as added by this Act), this Act [see Short Title of 1996 Amendment note below], and the amendments made by this Act, shall apply with respect to the production of oil and gas after the first day of the month following the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1996-08-13"},"text":"Aug. 13, 1996","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id605ece9f-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/451/tIII/s305"},"text":"Pub. L. 97–451, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2461"},"text":"96 Stat. 2461","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/451/tIII/s305"},"text":"“The provisions of this Act [enacting this chapter, amending sections 188 and 191 of this title, and enacting provisions set out as notes under this section and sections 1714 and 1752 of this title] shall apply to oil and gas leases issued before, on, or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":"], except that in the case of a lease issued before such date, no provision of this Act or any rule or regulation prescribed under this Act shall alter the express and specific provisions of such a lease.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id605ecea0-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2024 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/81/s1"},"text":"Pub. L. 118–81, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-09-20"},"text":"Sept. 20, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1520"},"text":"138 Stat. 1520","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/81/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1721"},"text":"section 1721 of this title","children":[],"tail":"] may be cited as the ‘Royalty Resiliency Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id605ecea1-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/185/s1"},"text":"Pub. L. 104–185, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-13"},"text":"Aug. 13, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1700"},"text":"110 Stat. 1700","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/185/s1"},"text":"“This Act [enacting sections 1721a and 1724 to 1726 of this title, amending sections 1702, 1712, 1721, and 1735 of this title, repealing ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1339"},"text":"section 1339 of Title 43","children":[],"tail":", Public Lands, and enacting provisions set out as notes under this section, "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1732"},"text":"section 1732 of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1339"},"text":"section 1339 of Title 43","children":[],"tail":"] may be cited as the ‘Federal Oil and Gas Royalty Simplification and Fairness Act of 1996’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id605ecea2-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/451/s1"},"text":"Pub. L. 97–451, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2447"},"text":"96 Stat. 2447","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/451/s1"},"text":"“This Act [enacting this chapter, amending sections 188 and 191 of this title, and enacting provisions set out as notes under this section and sections 1714 and 1752 of this title] may be cited as the ‘Federal Oil and Gas Royalty Management Act of 1982’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id605ecea3-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/185/s9"},"text":"Pub. L. 104–185, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-13"},"text":"Aug. 13, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1717"},"text":"110 Stat. 1717","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/185/s9"},"text":"“The amendments made by this Act [see Short Title of 1996 Amendment note above] shall not apply with respect to Indian lands, and the provisions of the Federal Oil and Gas Royalty Management Act of 1982 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1701"},"text":"30 U.S.C. 1701","children":[],"tail":" et seq.] as in effect on the day before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1996-08-13"},"text":"Aug. 13, 1996","children":[],"tail":"] shall continue to apply after such date with respect to Indian lands.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/185/s10"},"text":"Pub. L. 104–185, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-13"},"text":"Aug. 13, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1717"},"text":"110 Stat. 1717","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/185/s10"},"text":"“This Act [see Short Title of 1996 Amendment note above] shall not apply to any privately owned minerals.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id605ecea4-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/185/s12"},"text":"Pub. L. 104–185, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-13"},"text":"Aug. 13, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1717"},"text":"110 Stat. 1717","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/185/s12"},"text":"“Nothing in this Act [see Short Title of 1996 Amendment note above] shall be construed to give a State a property right or interest in any Federal lease or land.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
