{"tag":"section","attrib":{"id":"id602a50e2-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004"},"text":null,"children":[{"tag":"num","attrib":{"value":"1004"},"text":"§ 1004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rents and royalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id602a50e3-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Geothermal leases shall provide for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id602a50e4-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a royalty on electricity produced using geothermal resources, other than direct use of geothermal resources, that shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id602a50e5-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 1 percent and not more than 2.5 percent of the gross proceeds from the sale of electricity produced from such resources during the first 10 years of production under the lease; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602a50e6-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 2 and not more than 5 percent of the gross proceeds from the sale of electricity produced from such resources during each year after such 10-year period;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602a50e7-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a royalty on any byproduct that is a mineral specified in the first section of the Mineral Leasing Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s181"},"text":"30 U.S.C. 181","children":[],"tail":"), and that is derived from production under the lease, at the rate of the royalty that applies under that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t30/s181"},"text":"30 U.S.C. 181","children":[],"tail":" et seq.] to production of the mineral under a lease under that Act; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602a50e8-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" payment in advance of an annual rental of not less than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id602a50e9-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each of the 1st through 10th years of the lease—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id602a50ea-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a lease awarded in a noncompetitive lease sale, $1 per acre or fraction thereof; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id602a50eb-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a lease awarded in a competitive lease sale, $2 per acre or fraction thereof for the 1st year and $3 per acre or fraction thereof for each of the 2nd through 10th years; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602a50ec-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each year after the 10th year of the lease, $5 per acre or fraction thereof; ","children":[{"tag":"ref","attrib":{"idref":"fn002055"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002055"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The semicolon probably should be a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id602a50ed-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct use","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id602a50ee-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsection (a)(1), the Secretary shall establish a schedule of fees, in lieu of royalties for geothermal resources, that a lessee or its affiliate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id602a50ef-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses for a purpose other than the commercial generation of electricity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602a50f0-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not sell.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602a50f1-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schedule of fees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The schedule of fees—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id602a50f2-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be based on the quantity or thermal content, or both, of geothermal resources used;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602a50f3-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall ensure a fair return to the United States for use of the resource; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602a50f4-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall encourage development of the resource.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602a50f5-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State, tribal, or local governments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State, tribal, or local government is the lessee and uses geothermal resources without sale and for public purposes other than commercial generation of electricity, the Secretary shall charge only a nominal fee for use of the resource.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602a50f6-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final regulation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In issuing any final regulation establishing a schedule of fees under this subsection, the Secretary shall seek—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id602a50f7-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide lessees with a simplified administrative system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602a50f8-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate development of direct use of geothermal resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602a50f9-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to contribute to sustainable economic development opportunities in the area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id602a50fa-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final regulation establishing royalty rates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In issuing any final regulation establishing royalty rates under this section, the Secretary shall seek—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id602a50fb-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide lessees a simplified administrative system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602a50fc-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage new development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602a50fd-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to achieve the same level of royalty revenues over a 10-year period as the regulation in effect on ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id602a50fe-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credits for in-kind payments of electricity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide to a lessee a credit against royalties owed under this chapter, in an amount equal to the value of electricity provided under contract to a State or county government that is entitled to a portion of such royalties under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1019"},"text":"section 1019 of this title","children":[],"tail":", section 35 of the Mineral Leasing Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t30/s191"},"text":"30 U.S.C. 191","children":[],"tail":"), except as otherwise provided by this section, or "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s355"},"text":"section 355 of this title","children":[],"tail":", if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id602a50ff-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary has approved in advance the contract between the lessee and the State or county government for such in-kind payments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602a5100-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contract establishes a specific methodology to determine the value of such credits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602a5101-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maximum credit will be equal to the royalty value owed to the State or county that is a party to the contract and the electricity received will serve as the royalty payment from the Federal Government to that entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id602a5102-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crediting of rental toward royalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any annual rental under this section that is paid with respect to a lease before the first day of the year for which the annual rental is owed shall be credited to the amount of royalty that is required to be paid under the lease for that year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id602a5103-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced royalties required for cessation of production","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id602a5104-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraphs (2) and (3), if, at any time after commercial production under a lease is achieved, production ceases for any reason, the lease shall remain in full force and effect for a period of not more than an aggregate number of 10 years beginning on the date production ceases, if, during the period in which production is ceased, the lessee pays royalties in advance at the monthly average rate at which the royalty was paid during the period of production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602a5105-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of any production royalty paid for any year shall be reduced (but not below 0) by the amount of any advanced royalties paid under the lease to the extent that the advance royalties have not been used to reduce production royalties for a prior year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602a5106-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply if the cessation in production is required or otherwise caused by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id602a5107-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602a5108-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Air Force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602a5109-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Army;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602a510a-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/f/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Navy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602a510b-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/f/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or a political subdivision of a State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id602a510c-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/f/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a force majeure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id602a510d-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of lease for failure to pay rental","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id602a510e-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall terminate any lease with respect to which rental is not paid in accordance with this chapter and the terms of the lease under which the rental is required, on the expiration of the 45-day period beginning on the date of the failure to pay the rental.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602a510f-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promptly notify a lessee that has not paid rental required under the lease that the lease will be terminated at the end of the period referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id602a5110-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1004/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reinstatement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A lease that would otherwise terminate under paragraph (1) shall not terminate under that paragraph if the lessee pays to the Secretary, before the end of the period referred to in paragraph (1), the amount of rental due plus a late fee equal to 10 percent of the amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id602a5111-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/581/s5"},"text":"Pub. L. 91–581, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1567"},"text":"84 Stat. 1567","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tII"},"text":"Pub. L. 109–58, title II","children":[],"tail":", §§ 223(a), 224(a), 228, 230, 232, 233, 236(7), "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/661"},"text":"119 Stat. 661","children":[],"tail":", 662, 667–670, 672.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id602a5112-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id602a5113-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id602a5114-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Mineral Leasing Act, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-02-25/ch85"},"text":"act Feb. 25, 1920, ch. 85","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/437"},"text":"41 Stat. 437","children":[],"tail":", which is classified generally to chapter 3A (§ 181 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s181"},"text":"section 181 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id602a5115-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":", §§ 223(a)(1)–(3), 224(a)(1), 228, 230(1)–(3), 233(a), 236(7), inserted section catchline, designated existing provisions as subsec. (a) and inserted heading, redesignated subpars. (1) and (2) of par. (c) as subpars. (A) and (B), respectively, redesignated pars. (a) to (d) as pars. (1) to (4), respectively, of subsec. (a), added new pars. (1) to (3) of subsec. (a) and struck out former pars. (1) to (4) of subsec. (a) which related to royalties for amount or value of steam or other form of heat energy, royalty for value of byproducts, payment of annual rental, and royalties in lieu of rentals."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s223/a/4"},"text":"Pub. L. 109–58, § 223(a)(4)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s224/a/2"},"text":"Pub. L. 109–58, § 224(a)(2)","children":[],"tail":", added subsecs. (c) and (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s230/4"},"text":"Pub. L. 109–58, § 230(4)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s232"},"text":"Pub. L. 109–58, § 232","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s233/b"},"text":"Pub. L. 109–58, § 233(b)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id602a5116-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id602a5117-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tII/s223/c"},"text":"Pub. L. 109–58, title II, § 223(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/662"},"text":"119 Stat. 662","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/58/tII/s223/c"},"text":"“The schedule of fees established under the amendment made by subsection (a)(4) [amending this section] shall apply with respect to payments under a lease converted under this subsection that are due and owing, and have been paid, on or after ","children":[{"tag":"date","attrib":{"date":"2003-07-16"},"text":"July 16, 2003","children":[],"tail":". This subsection shall not require the refund of royalties paid to a State under section 20 of the Geothermal Steam Act of 1970 ("},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1019"},"text":"30 U.S.C. 1019","children":[],"tail":") prior to the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id602a5118-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Incentives and Royalties for Existing Leases","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tII/s224/c"},"text":"Pub. L. 109–58, title II, § 224(c)","children":[],"tail":"–(e), "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/663"},"text":"119 Stat. 663","children":[],"tail":", 664, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/58/tII/s224/c"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Near-Term Production Incentive for Existing Leases.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding section 5(a) of the Geothermal Steam Act of 1970 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1004/a"},"text":"30 U.S.C. 1004(a)","children":[],"tail":"], the royalty required to be paid shall be 50 percent of the amount of the royalty otherwise required, on any lease issued before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":"] that does not convert to new royalty terms under subsection (e)—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to commercial production of energy from a facility that begins such production in the 6-year period beginning on the date of enactment of this Act; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on qualified expansion geothermal energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 4-","children":[{"tag":"inline","attrib":{},"text":"year application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) applies only to new commercial production of energy from a facility in the first 4 years of such production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Qualified Expansion Geothermal Energy","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1019"},"text":"section 1019 of this title","children":[],"tail":" and enacting provisions set out as a note under this section], the term ‘qualified expansion geothermal energy’ means geothermal energy produced from a generation facility for which—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the production is increased by more than 10 percent as a result of expansion of the facility carried out in the 6-year period beginning on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such production increase is greater than 10 percent of the average production by the facility during the 5-year period preceding the expansion of the facility (as such average is adjusted to reflect any trend in changes in production during that period).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Royalty Under Existing Leases.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any lessee under a lease issued under the Geothermal Steam Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1001"},"text":"30 U.S.C. 1001","children":[],"tail":" et seq.) before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":"] may, within the time period specified in paragraph (2), submit to the Secretary of the Interior a request to modify the terms of the lease relating to payment of royalties to provide—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a lease that meets the requirements of subsection (b) of section 5 of the Geothermal Steam Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1004"},"text":"30 U.S.C. 1004","children":[],"tail":") (as amended by section 223), that royalties be based on the schedule of fees established under that section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any other lease, that royalties be computed on a percentage of the gross proceeds from the sale of electricity, at a royalty rate that is expected to yield total royalty payments equivalent to payments that would have been received for comparable production under the royalty rate in effect for the lease before the date of enactment of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A request for a modification under paragraph (1) shall be submitted to the Secretary of the Interior by the date that is not later than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a lease for direct use, 18 months after the effective date of the schedule of fees established by the Secretary of the Interior under section 5 of the Geothermal Steam Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1004"},"text":"30 U.S.C. 1004","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any other lease, 18 months after the effective date of the final regulation issued under subsection (a) [amending this section].","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of modification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the lessee requests modification of a lease under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary of the Interior shall, within 180 days after the receipt of the request for modification, modify the lease to comply with—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a lease for direct use, the schedule of fees established by the Secretary under section 5 of the Geothermal Steam Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1004"},"text":"30 U.S.C. 1004","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any other lease, the royalty for the lease established under paragraph (1)(B); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the modification shall apply to any use of geothermal resources to which subsection (a) [amending this section] applies that occurs after the date of the modification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Interior shall consult with the State and local governments affected by any proposed changes in lease royalty terms under this subsection.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
