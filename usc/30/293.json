{"tag":"section","attrib":{"id":"id5fff70d0-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s293"},"text":null,"children":[{"tag":"num","attrib":{"value":"293"},"text":"§ 293.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Secretary of the Interior","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is hereby authorized to perform any and all acts and to make such rules and regulations as may be necessary and proper for the purpose of carrying this chapter into full force and effect.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fff70d1-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-06-08/ch503/s3"},"text":"June 8, 1926, ch. 503, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/710"},"text":"44 Stat. 710","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
