{"tag":"section","attrib":{"id":"id605ecf09-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1714"},"text":null,"children":[{"tag":"num","attrib":{"value":"1714"},"text":"§ 1714.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of royalty funds to Indian accounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Deposits of any royalty funds derived from the production of oil or gas from, or allocated to, Indian lands shall be made by the Secretary to the appropriate Indian account at the earliest practicable date after such funds are received by the Secretary but in no case later than the last business day of the month in which such funds are received.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id605ecf0a-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/451/tI/s104/b"},"text":"Pub. L. 97–451, title I, § 104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2452"},"text":"96 Stat. 2452","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id605ecf0b-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id605ecf0c-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id605ecf0d-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/451/tI/s104/c"},"text":"Pub. L. 97–451, title I, § 104(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2452"},"text":"96 Stat. 2452","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/451/tI/s104/c"},"text":"“The provisions of this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s191"},"text":"section 191 of this title","children":[],"tail":"] shall apply with respect to payments received by the Secretary after "},{"tag":"date","attrib":{"date":"1983-10-01"},"text":"October 1, 1983","children":[],"tail":", unless the Secretary, by rule, prescribes an earlier effective date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
