{"tag":"section","attrib":{"id":"id6065fafd-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003"},"text":null,"children":[{"tag":"num","attrib":{"value":"2003"},"text":"§ 2003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methane hydrate research and development program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6065fafe-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6065faff-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary, in consultation with the Secretary of Commerce, the Secretary of Defense, the Secretary of the Interior, and the Director, shall commence a program of methane hydrate research and development in accordance with this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fb00-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, the Secretary of Commerce, the Secretary of Defense, the Secretary of the Interior, and the Director shall designate individuals to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fb01-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The individual designated by the Secretary shall coordinate all activities within the Department of Energy relating to methane hydrate research and development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fb02-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The individuals designated under paragraph (2) shall meet not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", and not less frequently than every 180 days thereafter to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6065fb03-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the progress of the program under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6065fb04-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate interagency research and partnership efforts in carrying out the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6065fb05-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants, contracts, cooperative agreements, interagency funds transfer agreements, and field work proposals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6065fb06-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance and coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program of methane hydrate research and development authorized by this section, the Secretary may award grants to, or enter into contracts or cooperative agreements with, institutions of higher education, oceanographic institutions, and industrial enterprises to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6065fb07-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct basic and applied research to identify, explore, assess, and develop methane hydrate as a commercially viable source of energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6065fb08-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify methane hydrate resources through remote sensing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6065fb09-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire and reprocess seismic data suitable for characterizing methane hydrate accumulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6065fb0a-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in developing technologies required for efficient and environmentally sound development of methane hydrate resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6065fb0b-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote education and training in methane hydrate resource research and resource development through fellowships or other means for graduate education and training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6065fb0c-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct basic and applied research to assess and mitigate the environmental impact of hydrate degassing (including both natural degassing and degassing associated with commercial development);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6065fb0d-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop technologies to reduce the risks of drilling through methane hydrates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6065fb0e-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct exploratory drilling, well testing, and production testing operations on permafrost and non-permafrost gas hydrates in support of the activities authorized by this paragraph, including drilling of one or more full-scale production test wells.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fb0f-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive peer review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available under paragraph (1) shall be made available based on a competitive process using external scientific peer review of proposed research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6065fb10-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methane hydrates advisory panel","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6065fb11-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish an advisory panel (including the hiring of appropriate staff) consisting of representatives of industrial enterprises, institutions of higher education, oceanographic institutions, State agencies, and environmental organizations with knowledge and expertise in the natural gas hydrates field, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6065fb12-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in developing recommendations and broad programmatic priorities for the methane hydrate research and development program carried out under subsection (a)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6065fb13-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide scientific oversight for the methane hydrates program, including assessing progress toward program goals, evaluating program balance, and providing recommendations to enhance the quality of the program over time; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6065fb14-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", and at such later dates as the panel considers advisable, submit to Congress—"}],"tail":null},{"tag":"clause","attrib":{"id":"id6065fb15-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the methane hydrate research program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6065fb16-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the 5-year research plan of the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fb17-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflicts of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In appointing each member of the advisory panel established under paragraph (1), the Secretary shall ensure, to the maximum extent practicable, that the appointment of the member does not pose a conflict of interest with respect to the duties of the member under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fb18-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The advisory panel shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6065fb19-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold the initial meeting of the advisory panel not later than 180 days after the date of establishment of the advisory panel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6065fb1a-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet biennially thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fb1b-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The advisory panel shall coordinate activities of the advisory panel with program managers of the Department of Energy at appropriate National Laboratories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6065fb1c-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"None of the funds made available to carry out this section may be used for the construction of a new building or the acquisition, expansion, remodeling, or alteration of an existing building (including site grading and improvement and architect fees).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6065fb1d-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of the Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (b)(1), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6065fb1e-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate and develop partnerships among government, industrial enterprises, and institutions of higher education to research, identify, assess, and explore methane hydrate resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fb1f-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" undertake programs to develop basic information necessary for promoting long-term interest in methane hydrate resources as an energy source;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fb20-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the data and information developed through the program are accessible and widely disseminated as needed and appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fb21-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote cooperation among agencies that are developing technologies that may hold promise for methane hydrate resource development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fb22-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report annually to Congress on the results of actions taken to carry out this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6065fb23-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s2003/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure, to the maximum extent practicable, greater participation by the Department of Energy in international cooperative efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6065fb24-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/193/s4"},"text":"Pub. L. 106–193, § 4","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s968/a"},"text":"Pub. L. 109–58, title IX, § 968(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/895"},"text":"119 Stat. 895","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6065fb25-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6065fb26-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6065fb27-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/193/s4"},"text":"section 4 of Pub. L. 106–193","children":[],"tail":" was set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1902"},"text":"section 1902 of this title","children":[],"tail":" prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/106/193"},"text":"Pub. L. 106–193","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
