{"tag":"section","attrib":{"id":"id602cc250-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1010"},"text":null,"children":[{"tag":"num","attrib":{"value":"1010"},"text":"§ 1010.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of operations and production","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary, upon application by the lessee, may authorize the lessee to suspend operations and production on a producing lease and he may, on his own motion, in the interest of conservation suspend operations on any lease but in either case he may extend the lease term for the period of any suspension, and he may waive, suspend, or reduce the rental or royalty required in such lease.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id602cc251-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/581/s11"},"text":"Pub. L. 91–581, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1570"},"text":"84 Stat. 1570","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tII/s236/11"},"text":"Pub. L. 109–58, title II, § 236(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/672"},"text":"119 Stat. 672","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id602cc252-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id602cc253-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id602cc254-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":" inserted section catchline."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
