{"tag":"section","attrib":{"id":"id603b19c9-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1243"},"text":null,"children":[{"tag":"num","attrib":{"value":"1243"},"text":"§ 1243.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All departments, boards, commissioners, and agencies of the United States of America shall cooperate with the Secretary by providing technical expertise, personnel, equipment, materials, and supplies to implement and administer the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id603b19ca-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/87/tIV/s414"},"text":"Pub. L. 95–87, title IV, § 414","children":[],"tail":", formerly § 413, "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"Aug. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/467"},"text":"91 Stat. 467","children":[],"tail":", renumbered § 414, "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tVI/s6010/1"},"text":"Pub. L. 101–508, title VI, § 6010(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-296"},"text":"104 Stat. 1388–296","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
