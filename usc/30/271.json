{"tag":"section","attrib":{"id":"id5ffd268d-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s271"},"text":null,"children":[{"tag":"num","attrib":{"value":"271"},"text":"§ 271.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prospecting permits; lands included; acreage","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is hereby authorized and directed, under such rules and regulations as he may prescribe, to grant to any qualified applicant a prospecting permit which shall give the exclusive right to prospect for sulphur in lands belonging to the United States located in the States of Louisiana and New Mexico for a period of not exceeding two years: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the area to be included in such a permit shall be not exceeding six hundred and forty acres of land in reasonably compact form."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5ffd268e-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-04-17/ch158/s1"},"text":"Apr. 17, 1926, ch. 158, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/301"},"text":"44 Stat. 301","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1932-07-16/ch498"},"text":"July 16, 1932, ch. 498","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/701"},"text":"47 Stat. 701","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5ffd268f-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5ffd2690-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5ffd2691-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-02-25/ch85"},"text":"act Feb. 25, 1920, ch. 85","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/437"},"text":"41 Stat. 437","children":[],"tail":", known as the Mineral Leasing Act, which comprises this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5ffd2692-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1932—Act ","children":[{"tag":"date","attrib":{"date":"1932-07-16"},"text":"July 16, 1932","children":[],"tail":", substituted “States of Louisiana and New Mexico” for “State of Louisiana”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
