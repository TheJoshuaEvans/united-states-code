{"tag":"section","attrib":{"id":"id60090dba-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s666"},"text":null,"children":[{"tag":"num","attrib":{"value":"666"},"text":"§ 666.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public-availability requirement; national defense; patent agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No research shall be carried out, contracted for, sponsored, cosponsored, or authorized under authority of this chapter, unless all information, uses, products, processes, patents, and other developments resulting from such research will (with such exceptions and limitations, if any, as the Secretary may find to be necessary in the interest of national defense) be available to the general public. Whenever in the estimation of the Secretary the purposes of this chapter would be furthered through the use of patented processes or equipment, the Secretary is authorized to enter into such agreements as he deems necessary for the acquisition or use of such patents on reasonable terms and conditions.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id60090dbb-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/599/s4"},"text":"Pub. L. 86–599, § 4","children":[],"tail":", formerly § 6, "},{"tag":"date","attrib":{"date":"1960-07-07"},"text":"July 7, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/337"},"text":"74 Stat. 337","children":[],"tail":"; renumbered § 4, "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tX/s1009/a/1/D"},"text":"Pub. L. 109–58, title X, § 1009(a)(1)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/934"},"text":"119 Stat. 934","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id60090dbc-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id60090dbd-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id60090dbe-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/599/s4"},"text":"section 4 of Pub. L. 86–599","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s664"},"text":"section 664 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1009/a/1/C"},"text":"Pub. L. 109–58, § 1009(a)(1)(C)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
