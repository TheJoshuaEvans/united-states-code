{"tag":"section","attrib":{"id":"id5ffab630-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s236b"},"text":null,"children":[{"tag":"num","attrib":{"value":"236b"},"text":"§ 236b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing leases within naval petroleum reserves not affected","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this act shall be construed as affecting existing leases within the borders of the naval petroleum reserves, or agreements concerning operations thereunder or in relation thereto.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5ffab631-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-08/ch916/s13"},"text":"Aug. 8, 1946, ch. 916, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/958"},"text":"60 Stat. 958","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041/s53"},"text":"Aug. 10, 1956, ch. 1041, § 53","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/675"},"text":"70A Stat. 675","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5ffd2632-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5ffd2633-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5ffd2634-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-08/ch916"},"text":"act Aug. 8, 1946, ch. 916","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/950"},"text":"60 Stat. 950","children":[],"tail":", which is classified generally to sections 181, 184, 187a, 187b, 188, 193, 209, 225, 226, 226c to 226e, 236b, and 285 of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5ffd2635-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-02-25/ch85"},"text":"act Feb. 25, 1920, ch. 85","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/437"},"text":"41 Stat. 437","children":[],"tail":", known as the Mineral Leasing Act, which comprises this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5ffd2636-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1956—Act ","children":[{"tag":"date","attrib":{"date":"1956-08-10"},"text":"Aug. 10, 1956","children":[],"tail":", repealed the portion of this section after “thereto” which authorized the Secretary of the Navy, with the consent of the President, to enter into agreements such as those provided for in "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s236e"},"text":"section 236e of this title","children":[],"tail":", which agreements, should not, unless expressed therein, operate to extend the term of any lease affected thereby."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
