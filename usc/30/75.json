{"tag":"section","attrib":{"id":"id5fe076ae-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s75"},"text":null,"children":[{"tag":"num","attrib":{"value":"75"},"text":"§ 75.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflicting claims upon coal lands; rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In case of conflicting claims upon coal lands where the improvements shall be commenced, after the third day of March, 1873, priority of possession and improvement, followed by proper filing and continued good faith, shall determine the preference right to purchase. And also where improvements have already been made prior to the third day of March, 1873, division of the land claimed may be made by legal subdivisions, to include, as near as may be, the valuable improvements of the respective parties. The Director of the Bureau of Land Management is authorized to issue all needful rules and regulations for carrying into effect the provisions of this section and sections 71 to 74 of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fe076af-3a70-11f1-83b4-f01f82055b58"},"text":"(R.S. § 2351; 1946 Reorg. Plan No. 3, § 403, eff. ","children":[{"tag":"date","attrib":{"date":"1946-07-16"},"text":"July 16, 1946","children":[],"tail":", 11 F.R. 7876, "},{"tag":"ref","attrib":{"href":"/us/stat/60/1100"},"text":"60 Stat. 1100","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5fe076b0-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5fe076b1-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5fe076b2-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2351 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1873-03-03/ch279/s5"},"text":"act Mar. 3, 1873, ch. 279, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/17/608"},"text":"17 Stat. 608","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5fe076b3-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functi","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id5fe076b4-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documentsons","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"“Director of the Bureau of Land Management” substituted in text for “Commissioner of the General Land Office” on authority of Reorg. Plan No. 3 of 1946, § 403, set out in the Appendix to Title 5, Government Organization and Employees.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"See also note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5fe076b5-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Indian Lands Excepted","children":[],"tail":null},{"tag":"p","attrib":{},"text":"See note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s71"},"text":"section 71 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
