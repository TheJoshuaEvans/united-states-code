{"tag":"section","attrib":{"id":"id60259694-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s942"},"text":null,"children":[{"tag":"num","attrib":{"value":"942"},"text":"§ 942.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Miner benefit entitlement reports; penalty for failure or refusal to file","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id60259695-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s942/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may by regulation require employers to file reports concerning miners who may be or are entitled to benefits under this part, including the date of commencement and cessation of benefits and the amount of such benefits. Any such report shall not be evidence of any fact stated therein in any proceeding relating to death or total disability due to pneumoconiosis of any miner to which such report relates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id60259696-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s942/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any employer who fails or refuses to file any report required of such employer under this section shall be subject to a civil penalty of not more than $500 for each such failure or refusal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id60259697-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/173/tIV/s432"},"text":"Pub. L. 91–173, title IV, § 432","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/239/s12/b"},"text":"Pub. L. 95–239, § 12(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-03-01"},"text":"Mar. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/101"},"text":"92 Stat. 101","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id60259698-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id60259699-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id6025969a-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1978-03-01"},"text":"Mar. 1, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/239/s20/a"},"text":"section 20(a) of Pub. L. 95–239","children":[],"tail":", set out as an Effective Date of 1978 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s901"},"text":"section 901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
