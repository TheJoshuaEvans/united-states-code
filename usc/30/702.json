{"tag":"section","attrib":{"id":"id600b56c6-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s702"},"text":null,"children":[{"tag":"num","attrib":{"value":"702"},"text":"§ 702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Qualified applicant” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purposes of this chapter a qualified applicant is a residential occupant-owner, as of ","children":[{"tag":"date","attrib":{"date":"1962-10-23"},"text":"October 23, 1962","children":[],"tail":", of valuable improvements in an unpatented mining claim which constitute for him a principal place of residence and which he and his predecessors in interest were in possession of for not less than seven years prior to "},{"tag":"date","attrib":{"date":"1962-07-23"},"text":"July 23, 1962","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id600b56c7-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/851/s2"},"text":"Pub. L. 87–851, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-23"},"text":"Oct. 23, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1127"},"text":"76 Stat. 1127","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
