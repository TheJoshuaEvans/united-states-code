{"tag":"section","attrib":{"id":"id605558a4-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1467"},"text":null,"children":[{"tag":"num","attrib":{"value":"1467"},"text":"§ 1467.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of courts","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The district courts of the United States shall have exclusive jurisdiction over any case or controversy arising under the provisions of this chapter. These courts may, at any time—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id605558a5-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1467/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter restraining orders or prohibitions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id605558a6-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1467/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue warrants, process in rem, or other process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id605558a7-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1467/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe and accept satisfactory bonds or other security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id605558a8-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s1467/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take such other actions as are in the interest of justice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id605558a9-3a70-11f1-83b4-f01f82055b58"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/283/tIII/s307"},"text":"Pub. L. 96–283, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-28"},"text":"June 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/580"},"text":"94 Stat. 580","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
