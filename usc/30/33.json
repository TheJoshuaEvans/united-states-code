{"tag":"section","attrib":{"id":"id5fdbbbda-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s33"},"text":null,"children":[{"tag":"num","attrib":{"value":"33"},"text":"§ 33.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All patents for mining claims upon veins or lodes issued prior to ","children":[{"tag":"date","attrib":{"date":"1872-05-10"},"text":"May 10, 1872","children":[],"tail":", shall convey all the rights and privileges conferred by sections 21, 22 to 24, 26 to 28, 29, 30, 33 to 48, 50 to 52, 71 to 76 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s661"},"text":"section 661 of title 43","children":[],"tail":" where no adverse rights existed on the 10th day of May, 1872."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fdbbbdb-3a70-11f1-83b4-f01f82055b58"},"text":"(R.S. § 2328.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5fdbbbdc-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5fdbbbdd-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5fdbbbde-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 21, 22 to 24, 26 to 28, 29, 30, 33 to 48, 50 to 52, 71 to 76 of this title and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s661"},"text":"section 661 of title 43","children":[],"tail":", referred to in text, were in the original “this chapter”, meaning chapter 6 of title 32 of the Revised Statutes, consisting