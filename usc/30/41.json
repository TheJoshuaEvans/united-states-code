{"tag":"section","attrib":{"id":"id5fde0606-3a70-11f1-83b4-f01f82055b58","identifier":"/us/usc/t30/s41"},"text":null,"children":[{"tag":"num","attrib":{"value":"41"},"text":"§ 41.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intersecting or crossing veins","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Where two or more veins intersect or cross each other, priority of title shall govern, and such prior location shall be entitled to all ore or mineral contained within the space of intersection; but the subsequent location shall have the right-of-way through the space of intersection for the purposes of the convenient working of the mine. And where two or more veins unite, the oldest or prior location shall take the vein below the point of union, including all the space of intersection.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5fde0607-3a70-11f1-83b4-f01f82055b58"},"text":"(R.S. § 2336.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5fde0608-3a70-11f1-83b4-f01f82055b58"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5fde0609-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5fde060a-3a70-11f1-83b4-f01f82055b58"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2336 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1872-05-10/ch152/s14"},"text":"act May 10, 1872, ch. 152, § 14","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/17/96"},"text":"17 Stat. 96","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
