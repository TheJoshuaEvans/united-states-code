{"tag":"section","attrib":{"id":"id83d0245d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2303"},"text":null,"children":[{"tag":"num","attrib":{"value":"2303"},"text":"§ 2303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ethics safeguards related to contractor conflicts of interest","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83d0245e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “relevant acquisition function” means an acquisition function closely associated with inherently governmental functions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d0245f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policy on Personal Conflicts of Interest by Contractor Employees.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d02460-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Development and issuance of policy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall develop and issue a standard policy to prevent personal conflicts of interest by contractor employees performing relevant acquisition functions (including the development, award, and administration of Federal Government contracts) for or on behalf of a Federal agency or department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d02461-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements of policy","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The policy shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d02462-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2303/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" define “personal conflict of interest” as it relates to contractor employees performing relevant acquisition functions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d02463-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2303/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" require each contractor whose employees perform relevant acquisition functions to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83d02464-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2303/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and prevent personal conflicts of interest for the employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83d02465-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2303/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibit contractor employees who have access to non-public government information obtained while performing relevant acquisition functions from using the information for personal gain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83d02466-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2303/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report any personal conflict-of-interest violation by an employee to the applicable contracting officer or contracting officer’s representative as soon as it is identified;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83d02467-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2303/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain effective oversight to verify compliance with personal conflict-of-interest safeguards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83d02468-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2303/b/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have procedures in place to screen for potential conflicts of interest for all employees performing relevant acquisition functions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83d02469-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2303/b/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take appropriate disciplinary action in the case of employees who fail to comply with policies established pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d0246a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2303/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract clause.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d0246b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2303/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall develop a personal conflicts-of-interest clause or a set of clauses for inclusion in solicitations and contracts (and task or delivery orders) for the performance of relevant acquisition functions that sets forth—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83d0246c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2303/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the personal conflicts-of-interest policy developed under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83d0246d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2303/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contractor’s responsibilities under the policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d0246e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2303/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective date","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subparagraph (A) shall take effect 300 days after ","children":[{"tag":"date","attrib":{"date":"2008-10-14"},"text":"October 14, 2008","children":[],"tail":", and shall apply to—"}],"tail":null},{"tag":"clause","attrib":{"id":"id83d0246f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2303/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contracts entered into on or after that effective date; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83d02470-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2303/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" task or delivery orders awarded on or after that effective date, regardless of whether the contracts pursuant to which the task or delivery orders are awarded are entered before, on, or after ","children":[{"tag":"date","attrib":{"date":"2008-10-14"},"text":"October 14, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d02471-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2303/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d02472-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2303/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracts in excess of the simplified acquisition threshold","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection shall apply to any contract for an amount in excess of the simplified acquisition threshold (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s134"},"text":"section 134 of this title","children":[],"tail":") if the contract is for the performance of relevant acquisition functions."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d02473-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2303/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Partial applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If only a portion of a contract described in subparagraph (A) is for the performance of relevant acquisition functions, then this subsection applies only to that portion of the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d02474-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Best Practices","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall, in consultation with the Director of the Office of Government Ethics, develop and maintain a repository of best practices relating to the prevention and mitigation of organizational and personal conflicts of interest in Federal contracting.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83d02475-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3735"},"text":"124 Stat. 3735","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83d02476-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83d02477-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83d02478-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2303(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"no source.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2303(b), (c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:405c(a), (c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title VIII, § 841(a), (c), "},{"tag":"html:span","attrib":{},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/122/4537"},"text":"122 Stat. 4537","children":[],"tail":", 4539."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the words “relevant acquisition functions” are substituted for “acquisition functions closely associated with inherently governmental functions” because of subsection (a).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “Not later than 270 days after the date of the enactment of this Act” are omitted because of section 6(f) of the bill.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(4)(A), the words “Except as provided in subparagraph (B)” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id83d29479-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id83d2947a-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Preventing Organizational Conflicts of Interest in Federal Acquisition","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/324"},"text":"Pub. L. 117–324","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4439"},"text":"136 Stat. 4439","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/324"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“SECTION 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This Act may be cited as the ‘Preventing Organizational Conflicts of Interest in Federal Acquisition Act’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“SEC. 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" PREVENTING ORGANIZATIONAL CONFLICTS OF INTEREST IN FEDERAL ACQUISITION.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":"], the Federal Acquisition Regulatory Council shall revise the Federal Acquisition Regulation—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to provide and update—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" definitions related to specific types of organizational conflicts of interest, including unequal access to information, impaired objectivity, and biased ground rules;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" definitions, guidance, and illustrative examples related to relationships of contractors with public, private, domestic, and foreign entities that may cause contract support to be subject to potential organizational conflicts of interest, including undue influence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" illustrative examples of situations related to the potential organizational conflicts of interest identified under this paragraph, including an example of the awarding by a Federal regulatory agency of a contract for consulting services to a contractor if employees of the contractor performing work under such contract are permitted by the contractor to simultaneously perform work under a contract for a private sector client under the regulatory purview of such agency;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide executive agencies with solicitation provisions and contract clauses to avoid or mitigate organizational conflicts of interest, for agency use as needed, that require contractors to disclose information relevant to potential organizational conflicts of interest and limit future contracting with respect to potential conflicts of interest with the work to be performed under awarded contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to allow executive agencies to tailor such solicitation provisions and contract clauses as necessary to address risks associated with conflicts of interest and other considerations that may be unique to the executive agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to require executive agencies—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish or update as needed agency conflict of interest procedures to implement the revisions to the Federal Acquisition Regulation made under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to periodically assess and update such procedures as needed to address agency-specific conflict of interest issues; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to update the procedures set forth in section 9.506 of the Federal Acquisition Regulation to permit contracting officers to take into consideration professional standards and procedures to prevent organizational conflicts of interest to which an offeror or contractor is subject.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive Agency Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘executive agency’ has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s133"},"text":"section 133 of title 41","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id83d2947b-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Issuance of Standard Policy","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/f/1"},"text":"Pub. L. 111–350, § 6(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/350/s6/f/1"},"text":"“The requirement in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s2303/b/1"},"text":"section 2303(b)(1) of title 41","children":[],"tail":", United States Code, to issue a policy shall be done not later than 270 days after "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"October 14, 2008","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id83d2947c-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Review of Federal Acquisition Regulation Relating to Conflicts of Interest","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title VIII, § 841(b), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4539"},"text":"122 Stat. 4539","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/417"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 12 months after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":"], the Administrator for Federal Procurement Policy, in consultation with the Director of the Office of Government Ethics, shall review the Federal Acquisition Regulation to—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify contracting methods, types and services that raise heightened concerns for potential personal and organizational conflicts of interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" determine whether revisions to the Federal Acquisition Regulation are necessary to—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address personal conflicts of interest by contractor employees with respect to functions other than those described in subsection (a) [now ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s2303/b"},"text":"41 U.S.C. 2303(b)","children":[],"tail":"]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieve sufficiently rigorous, comprehensive, and uniform government-wide policies to prevent and mitigate organizational conflicts of interest in Federal contracting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulatory revisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Administrator determines pursuant to the review under paragraph (1)(B) that revisions to the Federal Acquisition Regulation are necessary, the Administrator shall work with the Federal Acquisition Regulatory Council to prescribe appropriate revisions to the regulations, including the development of appropriate contract clauses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2010-03-01"},"text":"March 1, 2010","children":[],"tail":", the Administrator shall submit to the Committees on Armed Services of the Senate and House of Representatives, the Committee on Homeland Security and Governmental Affairs in the Senate, and the Committee on Oversight and Government Reform [now Committee on Oversight and Accountability] of the House of Representatives a report setting forth such findings and determinations under subparagraphs (A) and (B) of paragraph (1), together with an assessment of any revisions to the Federal Acquisition Regulation that may be necessary.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
