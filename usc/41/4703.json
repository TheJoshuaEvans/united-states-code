{"tag":"section","attrib":{"id":"id83e818e3-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4703"},"text":null,"children":[{"tag":"num","attrib":{"value":"4703"},"text":"§ 4703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Validation of proprietary data restrictions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83e818e4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract That Provides for Delivery of Technical Data","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A contract for property or services entered into by an executive agency that provides for the delivery of technical data shall provide that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e818e5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4703/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contractor or subcontractor at any tier shall be prepared to furnish to the contracting officer a written justification for any restriction the contractor or subcontractor asserts on the right of the Federal Government to use the data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e818e6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4703/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contracting officer may review the validity of a restriction the contractor or subcontractor asserts under the contract on the right of the Federal Government to use technical data furnished to the Federal Government under the contract if the contracting officer determines that reasonable grounds exist to question the current validity of the asserted restriction and that the continued adherence to the asserted restriction by the Federal Government would make it impracticable to procure the item competitively at a later time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e818e7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Challenge of Restriction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If after a review the contracting officer determines that a challenge to the asserted restriction is warranted, the contracting officer shall provide written notice to the contractor or subcontractor asserting the restriction. The notice shall state—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e818e8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4703/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grounds for challenging the asserted restriction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e818e9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4703/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirement for a response within 60 days justifying the current validity of the asserted restriction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e818ea-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Time for Responses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a contractor or subcontractor asserting a restriction subject to this section submits to the contracting officer a written request showing the need for additional time to comply with the requirement to justify the current validity of the asserted restriction, the contracting officer shall provide appropriate additional time to adequately permit the justification to be submitted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e818eb-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4703/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multiple Challenges","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a party asserting a restriction receives notices of challenges to restrictions on technical data from more than one contracting officer, and notifies each contracting officer of the existence of more than one challenge, the contracting officer initiating the earliest challenge, after consultation with the party asserting the restriction and the other contracting officers, shall formulate a schedule of responses to each of the challenges that will afford the party asserting the restriction with an equitable opportunity to respond to each challenge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e818ec-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4703/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Decision on Validity of Asserted Restriction.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e818ed-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4703/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No response submitted","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The contracting officer shall issue a decision pertaining to the validity of the asserted restriction if the contractor or subcontractor does not submit a response under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e818ee-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4703/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Response submitted","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Within 60 days of receipt of a justification submitted in response to the notice provided pursuant to subsection (b), a contracting officer shall issue a decision or notify the party asserting the restriction of the time within which a decision will be issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e818ef-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4703/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Claim Deemed Claim Within Chapter","children":[],"tail":" 71.—"}],"tail":null},{"tag":"content","attrib":{},"text":"A claim pertaining to the validity of the asserted restriction that is submitted in writing to a contracting officer by a contractor or subcontractor at any tier is deemed to be a claim within the meaning of chapter 71 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e818f0-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4703/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Final Disposition of Challenge.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e818f1-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4703/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Challenge is sustained","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the contracting officer’s challenge to the restriction on the right of the Federal Government to use technical data is sustained on final disposition—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83e818f2-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4703/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the restriction is cancelled; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83e818f3-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4703/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the asserted restriction is found not to be substantially justified, the contractor or subcontractor, as appropriate, is liable to the Federal Government for payment of the cost to the Federal Government of reviewing the asserted restriction and the fees and other expenses (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2412/d/2/A"},"text":"section 2412(d)(2)(A) of title 28","children":[],"tail":") incurred by the Federal Government in challenging the asserted restriction, unless special circumstances would make the payment unjust."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e818f4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4703/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Challenge not sustained","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the contracting officer’s challenge to the restriction on the right of the Federal Government to use technical data is not sustained on final disposition, the Federal Government—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83e818f5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4703/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continues to be bound by the restriction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83e818f6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4703/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is liable for payment to the party asserting the restriction for fees and other expenses (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2412/d/2/A"},"text":"section 2412(d)(2)(A) of title 28","children":[],"tail":") incurred by the party asserting the restriction in defending the asserted restriction if the challenge by the Federal Government is found not to be made in good faith."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83e818f7-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3794"},"text":"124 Stat. 3794","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83e818f8-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83e818f9-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83e818fa-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4703(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:253d(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title III, § 303D, formerly § 303E, as added "},{"tag":"html:a","attrib":{"href":"/us/pl/98/577/tII/s203/a"},"text":"Pub. L. 98–577, title II, § 203(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/3071"},"text":"98 Stat. 3071","children":[],"tail":"; renumbered § 303D, "},{"tag":"html:a","attrib":{"href":"/us/pl/99/145/tXIII/s1304/c/4/A"},"text":"Pub. L. 99–145, title XIII, § 1304(c)(4)(A)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/99/742"},"text":"99 Stat. 742","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4703(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:253d(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4703(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:253d(c) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4703(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:253d(c) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4703(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:253d(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4703(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:253d(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4703(g)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:253d(f).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
