{"tag":"section","attrib":{"id":"id83e3372a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3905"},"text":null,"children":[{"tag":"num","attrib":{"value":"3905"},"text":"§ 3905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83e3372b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost-Plus-A-Percentage-Of-Cost Contracts Disallowed","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The cost-plus-a-percentage-of-cost system of contracting shall not be used.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e3372c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost-Plus-A-Fixed-Fee Contracts.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e3372d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3905/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraphs (2) and (3), the fee in a cost-plus-a-fixed-fee contract shall not exceed 10 percent of the estimated cost of the contract, not including the fee, as determined by the agency head at the time of entering into the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e3372e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3905/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Experimental, developmental, or research work","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The fee in a cost-plus-a-fixed-fee contract for experimental, developmental, or research work shall not exceed 15 percent of the estimated cost of the contract, not including the fee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e3372f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3905/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Architectural or engineering services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The fee in a cost-plus-a-fixed-fee contract for architectural or engineering services relating to any public works or utility project may include the contractor’s costs and shall not exceed 6 percent of the estimated cost, not including the fee, as determined by the agency head at the time of entering into the contract, of the project to which the fee applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e33730-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3905/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All cost and cost-plus-a-fixed-fee contracts shall provide for advance notification by the contractor to the procuring agency of any subcontract on a cost-plus-a-fixed-fee basis and of any fixed-price subcontract or purchase order which exceeds in dollar amount either the simplified acquisition threshold or 5 percent of the total estimated cost of the prime contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e33731-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3905/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Right To Audit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A procuring agency, through any authorized representative thereof, has the right to inspect the plans and to audit the books and records of a prime contractor or subcontractor engaged in the performance of a cost or cost-plus-a-fixed-fee contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83e33732-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3776"},"text":"124 Stat. 3776","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83e33733-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83e33734-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83e33735-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"t