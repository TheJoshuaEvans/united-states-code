{"tag":"section","attrib":{"id":"id83e81923-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706"},"text":null,"children":[{"tag":"num","attrib":{"value":"4706"},"text":"§ 4706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination of facilities and records of contractor","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83e81924-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “records” includes books, documents, accounting procedures and practices, and other data, regardless of type and regardless of whether the items are in written form, in the form of computer data, or in any other form.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e81925-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency Authority.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e81926-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inspection of plant and audit of records","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of an executive agency, acting through an authorized representative, may inspect the plant and audit the records of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83e81927-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contractor performing a cost-reimbursement, incentive, time-and-materials, labor-hour, or price-redeterminable contract, or any combination of those contracts, the executive agency makes under this division; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83e81928-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a subcontractor performing a cost-reimbursement, incentive, time-and-materials, labor-hour, or price-redeterminable subcontract, or any combination of those subcontracts, under a contract referred to in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e81929-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Examination of records","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of an executive agency, acting through an authorized representative, may, for the purpose of evaluating the accuracy, completeness, and currency of certified cost or pricing data required to be submitted pursuant to chapter 35 of this title with respect to a contract or subcontract, examine all records of the contractor or subcontractor related to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83e8192a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposal for the contract or subcontract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83e8192b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the discussions conducted on the proposal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83e8192c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pricing of the contract or subcontract; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83e8192d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performance of the contract or subcontract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e8192e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subpoena Power.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e8192f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to require the production of records","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Inspector General of an executive agency appointed under section 403 or 415 of title 5 or, on request of the head of an executive agency, the Director of the Defense Contract Audit Agency (or any successor agency) of the Department of Defense or the Inspector General of the General Services Administration may require by subpoena the production of records of a contractor, access to which is provided for that executive agency by subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e81930-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enforcement of subpoena","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A subpoena under paragraph (1), in the case of contumacy or refusal to obey, is enforceable by order of an appropriate United States district court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e81931-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority not delegable","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority provided by paragraph (1) may not be delegated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e81932-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the year following a year in which authority provided in paragraph (1) is exercised for an executive agency, the head of the executive agency shall submit to the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Oversight and Government Reform of the House of Representatives a report on the exercise of the authority during the preceding year and the reasons why the authority was exercised in any instance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e81933-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of Comptroller General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e81934-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), each contract awarded after using procedures other than sealed bid procedures shall provide that the Comptroller General and representatives of the Comptroller General may examine records of the contractor, or any of its subcontractors, that directly pertain to, and involve transactions relating to, the contract or subcontract and to interview any current employee regarding the transactions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e81935-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for foreign contractor or subcontractor","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) does not apply to a contract or subcontract with a foreign contractor or foreign subcontractor if the executive agency concerned determines, with the concurrence of the Comptroller General or the designee of the Comptroller General, that applying paragraph (1) to the contract or subcontract would not be in the public interest. The concurrence of the Comptroller General or the designee is not required when—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83e81936-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the contractor or subcontractor is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83e81937-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the government of a foreign country or an agency of that government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83e81938-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" precluded by the laws of the country involved from making its records available for examination; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83e81939-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the executive agency determines, after taking into account the price and availability of the property and services from United States sources, that the public interest would be best served by not applying paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e8193a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional records not required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) does not require a contractor or subcontractor to create or maintain a record that the contractor or subcontractor does not maintain in the ordinary course of business or pursuant to another law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e8193b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Audits Relating to Indirect Costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An executive agency may not perform an audit of indirect costs under a contract, subcontract, or modification before or after entering into the contract, subcontract, or modification when the contracting officer determines that the objectives of the audit can reasonably be met by accepting the results of an audit that was conducted by another department or agency of the Federal Government within one year preceding the date of the contracting officer’s determination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e8193c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expiration of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority of an executive agency under subsection (b) and the authority of the Comptroller General under subsection (d) shall expire 3 years after final payment under the contract or subcontract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e8193d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability to Certain Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not apply to the following contracts:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e8193e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Contracts for utility services at rates not exceeding those established to apply uniformly to the public, plus any applicable reasonable connection charge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e8193f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A contract or subcontract that is not greater than the simplified acquisition threshold.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e81940-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Electronic Form Allowed","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not preclude a contractor from duplicating or storing original records in electronic form.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e81941-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Original Records Not Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An executive agency shall not require a contractor or subcontractor to provide original records in an audit carried out pursuant to this section if the contractor or subcontractor provides photographic or electronic images of the original records and meets the following requirements:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83ea6232-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preservation procedures established","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The contractor or subcontractor has established procedures to ensure that the imaging process preserves the integrity, reliability, and security of the original records.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83ea6233-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Indexing system maintained","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The contractor or subcontractor maintains an effective indexing system to permit timely and convenient access to the imaged records.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83ea6234-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4706/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Original records retained","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The contractor or subcontractor retains the original records for a minimum of one year after imaging to permit periodic validation of the imaging systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83ea6235-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3797"},"text":"124 Stat. 3797","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/73"},"text":"Pub. L. 117–286, § 4(b)(73)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4351"},"text":"136 Stat. 4351","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83ea6236-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83ea6237-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83ea6238-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","