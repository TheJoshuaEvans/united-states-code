{"tag":"section","attrib":{"id":"id83cb695a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1907"},"text":null,"children":[{"tag":"num","attrib":{"value":"1907"},"text":"§ 1907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" List of laws inapplicable to procurements of commercially available off-the-shelf items","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83cb695b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1907/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusion in Federal Acquisition Regulation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83cb695c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1907/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Acquisition Regulation shall include a list of provisions of law that are inapplicable to contracts for the procurement of commercially available off-the-shelf items. A provision of law properly included on the list pursuant to paragraph (2) does not apply to contracts for the procurement of commercially available off-the-shelf items. This section does not render a provision of law not included on the list inapplicable to contracts for the procurement of commercially available off-the-shelf items.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cb695d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1907/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Laws to be included","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A provision of law described in subsection (b) shall be included on the list of inapplicable provisions of law required by paragraph (1) unless the Administrator makes a written determination that it would not be in the best interest of the Federal Government to exempt contracts for the procurement of commercially available off-the-shelf items from the applicability of the provision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cb695e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1907/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other authorities or responsibilities not affected","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not modify, supersede, impair, or restrict authorities or responsibilities under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83cb695f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1907/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 15 of the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s644"},"text":"15 U.S.C. 644","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cb6960-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1907/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" bid protest procedures developed under the authority of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83cb6961-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1907/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subchapter V of chapter 35 of title 31;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83cb6962-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1907/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3308"},"text":"section 3308 of title 10","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83cb6963-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1907/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 3706 and 3707 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83cb6964-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1907/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Law","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (a)(3), a provision of law referred to in subsection (a)(1) is a provision of law that the Administrator determines imposes Federal Government-unique policies, procedures, requirements, or restrictions for the procurement of property or services on persons whom the Federal Government has awarded contracts for the procurement of commercially available off-the-shelf items, except for a provision of law that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83cb6965-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1907/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for criminal or civil penalties; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cb6966-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1907/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifically refers to this section and provides that, notwithstanding this section, it shall be applicable to contracts for the procurement of commercially available off-the-shelf items.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83cb6967-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3724"},"text":"124 Stat. 3724","children":[],"tail":";"},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1702/h/8"},"text":"Pub. L. 117–81, div. A, title XVII, § 1702(h)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2158"},"text":"135 Stat. 2158","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83cb6968-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83cb6969-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83cb696a-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"t