{"tag":"section","attrib":{"id":"id83e5a7e6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4302"},"text":null,"children":[{"tag":"num","attrib":{"value":"4302"},"text":"§ 4302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment of threshold amount of covered contract","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Effective on October 1 of each year that is divisible by 5, the amount set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s4301/2"},"text":"section 4301(2) of this title","children":[],"tail":" shall be adjusted to the equivalent amount in constant fiscal year 1994 dollars. An adjusted amount that is not evenly divisible by $50,000 shall be rounded to the nearest multiple of $50,000. If an amount is evenly divisible by $25,000 but is not evenly divisible by $50,000, the amount shall be rounded to the next higher multiple of $50,000."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id83e5a7e7-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3784"},"text":"124 Stat. 3784","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83e5a7e8-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83e5a7e9-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83e5a7ea-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib