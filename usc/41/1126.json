{"tag":"section","attrib":{"id":"id83b85626-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1126"},"text":null,"children":[{"tag":"num","attrib":{"value":"1126"},"text":"§ 1126.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy regarding consideration of contractor past performance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83b85627-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1126/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall prescribe for executive agencies guidance regarding consideration of the past contract performance of offerors in awarding contracts. The guidance shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83bac728-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1126/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards for evaluating past performance with respect to cost (when appropriate), schedule, compliance with technical or functional specifications, and other relevant performance factors that facilitate consistent and fair evaluation by all executive agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bac729-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1126/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policies for the collection and maintenance of information on past contract performance that, to the maximum extent practicable, facilitate automated collection, maintenance, and dissemination of information and provide for ease of collection, maintenance, and dissemination of information by other methods, as necessary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bac72a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1126/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" policies for ensuring that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83bac72b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1126/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offerors are afforded an opportunity to submit relevant information on past contract performance, including performance under contracts entered into by the executive agency concerned, other departments and agencies of the Federal Government, agencies of State and local governments, and commercial customers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bac72c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1126/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information submitted by offerors is considered; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bac72d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1126/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period for which information on past performance of offerors may be maintained and considered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83bac72e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1126/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information Not Available","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If there is no information on past contract performance of an offeror or the information on past contract performance is not available, the offeror may not be evaluated favorably or unfavorably on the factor of past contract performance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83bac72f-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3689"},"text":"124 Stat. 3689","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83bac730-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83bac731-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83bac732-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1126(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:405(j)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/93/400/s6/j"},"text":"Pub. L. 93–400, § 6(j)","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/103/355/tI/s1091/b/2"},"text":"Pub. L. 103–355, title I, § 1091(b)(2)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/108/3272"},"text":"108 Stat. 3272","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1126(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:405(j)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id83bac733-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id83bac734-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inclusion of Data on Contractor Performance in Past Performance Databases for Executive Agency Source Selection Decisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tVIII/s853"},"text":"Pub. L. 112–239, div. A, title VIII, § 853","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1856"},"text":"126 Stat. 1856","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/239/dA/tVIII/s853"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Strategy Required","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":"], the Federal Acquisition Regulatory Council shall develop a strategy for ensuring that timely, accurate, and complete information on contractor performance is included in past performance databases used by executive agencies for making source selection decisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation with usdatl","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In developing the strategy required by this subsection, the Federal Acquisition Regulatory Council shall consult with the Under Secretary of Defense for Acquisition, Technology, and Logistics to ensure that the strategy is, to the extent practicable, consistent with the strategy developed by the Under Secretary pursuant to section 806 of the National Defense Authorization Act for Fiscal Year 2012 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Public Law 112–81","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/125/1487"},"text":"125 Stat. 1487","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2302"},"text":"10 U.S.C. 2302","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The strategy required by subsection (a) shall, at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish standards for the timeliness and completeness of past performance submissions for purposes of databases described in subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assign responsibility and management accountability for the completeness of past performance submissions for such purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that past performance submissions for such purposes are consistent with award fee evaluations in cases where such evaluations have been conducted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contractor Comments","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":"], the Federal Acquisition Regulation shall be revised to require the following:"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That affected contractors are provided, in a timely manner, information on contractor performance to be included in past performance databases in accordance with subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That such contractors are afforded up to 14 calendar days, from the date of delivery of the information provided in accordance with paragraph (1), to submit comments, rebuttals, or additional information pertaining to past performance for inclusion in such databases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That agency evaluations of contractor past performance, including any comments, rebuttals, or additional information submitted under paragraph (2), are included in the relevant past performance database not later than the date that is 14 days after the date of delivery of the information provided in accordance with paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to prohibit a contractor from submitting comments, rebuttals, or additional information pertaining to past performance after the period described in subsection (c)(2) has elapsed or to prohibit a contractor from challenging a past performance evaluation in accordance with applicable laws, regulations, or procedures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Comptroller General Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":"], the Comptroller General of the United States shall submit to the appropriate committees of Congress a report on the actions taken by the Federal Acquisition Regulatory Council pursuant to this section, including an assessment of the following:"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which the strategy required by subsection (a) is consistent with the strategy developed by the Under Secretary of Defense for Acquisition, Technology, and Logistics as described in subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which the actions of the Federal Acquisition Regulatory Council pursuant to this section have otherwise achieved the objectives of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term ‘appropriate committees of Congress’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services, the Committee on Foreign Relations, the Committee on Homeland Security and Governmental Affairs, and the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services, the Committee on Foreign Affairs, the Committee on Oversight and Government Reform [now Committee on Oversight and Accountability], and the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘executive agency’ has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s133"},"text":"section 133 of title 41","children":[],"tail":", United States Code, except that the term excludes the Department of Defense and the military departments."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘Federal Acquisition Regulatory Council’ means the Federal Acquisition Regulatory Council under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1302/a"},"text":"section 1302(a) of title 41","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id83bac735-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings Regarding Consideration of Past Contract Performance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355/tI/s1091/b/1"},"text":"Pub. L. 103–355, title I, § 1091(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3272"},"text":"108 Stat. 3272","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/355/tI/s1091/b/1"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress makes the following findings:","children":[],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Past contract performance of an offeror is one of the relevant factors that a contracting official of an executive agency should consider in awarding a contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is appropriate for a contracting official to consider past contract performance of an offeror as an indicator of the likelihood that the offeror will successfully perform a contract to be awarded by that official.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
