{"tag":"section","attrib":{"id":"id83d50648-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3102"},"text":null,"children":[{"tag":"num","attrib":{"value":"3102"},"text":"§ 3102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation and assignment of powers, functions, and responsibilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83d50649-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except to the extent expressly prohibited by another law, the head of an executive agency may delegate to another officer or official of that agency any power under this division.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d5064a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procurements For or With Another Agency","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (a), to facilitate the procurement of property and services covered by this division by an executive agency for another executive agency, and to facilitate joint procurement by executive agencies—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d5064b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of an executive agency may delegate functions and assign responsibilities relating to procurement to any officer or employee within the agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d5064c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the heads of 2 or more executive agencies, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1535"},"text":"section 1535 of title 31","children":[],"tail":" and regulations prescribed under section 1074 of the Federal Acquisition Streamlining Act of 1994 ("},{"tag":"ref","attrib":{"href":"/us/pl/103/355"},"text":"Public Law 103–355","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1535"},"text":"31 U.S.C. 1535","children":[],"tail":" note), may by agreement delegate procurement functions and assign procurement responsibilities from one executive agency to another of those executive agencies or to an officer or civilian employee of another of those executive agencies; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d5064d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3102/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the heads of 2 or more executive agencies may establish joint or combined offices to exercise procurement functions and responsibilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83d5064e-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3743"},"text":"124 Stat. 3743","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83d5064f-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83d50650-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83d50651-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3102","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:261.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title III, § 311, as added "},{"tag":"html:a","attrib":{"href":"/us/pl/103/355/tI/s1552"},"text":"Pub. L. 103–355, title I, § 1552","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/108/3299"},"text":"108 Stat. 3299","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
