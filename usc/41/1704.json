{"tag":"section","attrib":{"id":"id83c6adc2-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704"},"text":null,"children":[{"tag":"num","attrib":{"value":"1704"},"text":"§ 1704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning and policy-making for acquisition workforce","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83c6adc3-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83c6adc4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Associate Administrator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Associate Administrator” means the Associate Administrator for Acquisition Workforce Programs as designated by the Administrator pursuant to subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6adc5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chief Acquisition Officer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Chief Acquisition Officer” means a Chief Acquisition Officer for an executive agency appointed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1702"},"text":"section 1702 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c6adc6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Associate Administrator for Acquisition Workforce Programs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall designate a member of the Senior Executive Service as the Associate Administrator for Acquisition Workforce Programs. The Associate Administrator shall be chosen on the basis of demonstrated knowledge and expertise in acquisition, human capital, and management. The Associate Administrator shall be located in the Office of Federal Procurement Policy. The Associate Administrator shall be responsible for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83c6adc7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supervising the acquisition workforce training fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1703/i"},"text":"section 1703(i) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6adc8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing, in coordination with Chief Acquisition Officers and Chief Human Capital Officers, a strategic human capital plan for the acquisition workforce of the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6adc9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewing and providing input to individual agency acquisition workforce succession plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6adca-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommending to the Administrator and other senior government officials appropriate programs, policies, and practices to increase the quantity and quality of the Federal acquisition workforce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6adcb-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing workforce programs under subsections (f) through (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s1703"},"text":"section 1703 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6adcc-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out other functions that the Administrator may assign.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c6adcd-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisition and Contracting Training Programs Within Executive Agencies.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83c6adce-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chief Acquisition Officer authorities and responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the authority, direction, and control of the head of an executive agency, the Chief Acquisition Officer for that agency shall carry out all powers, functions, and duties of the head of the agency with respect to implementation of this subsection. The Chief Acquisition Officer shall ensure that the policies established by the head of the agency in accordance with this subsection are implemented throughout the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6adcf-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of each executive agency, after consultation with the Associate Administrator, shall establish and operate acquisition and contracting training programs. The programs shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83c6add0-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have curricula covering a broad range of acquisition and contracting disciplines corresponding to the specific acquisition and contracting needs of the agency involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6add1-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be developed and applied according to rigorous standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6add2-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be designed to maximize efficiency, through the use of self-paced courses, online courses, on-the-job training, and the use of remote instructors, wherever those features can be applied without reducing the effectiveness of the training or negatively affecting academic standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c6add3-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":" Government-wide Policies and Evaluation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall issue policies to promote the development of performance standards for training and uniform implementation of this section by executive agencies, with due regard for differences in program requirements among agencies that may be appropriate and warranted in view of the agency mission. The Administrator shall evaluate the implementation of the provisions of subsection (c) by executive agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c6add4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information on Acquisition and Contracting Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall ensure that the heads of executive agencies collect and maintain standardized information on the acquisition and contracting workforce related to the implementation of subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c6add5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisition Workforce Human Capital Succession Plan.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83c6add6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each Chief Acquisition Officer for an executive agency shall develop, in consultation with the Chief Human Capital Officer for the agency and the Associate Administrator, a succession plan consistent with the agency’s strategic human capital plan for the recruitment, development, and retention of the agency’s acquisition workforce, with a particular focus on warranted contracting officers and program managers of the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6add7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content of plan","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The acquisition workforce succession plan shall address—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83c6add8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruitment goals for personnel from procurement intern programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6add9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency’s acquisition workforce training needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6adda-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions to retain high performing acquisition professionals who possess critical relevant skills;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6addb-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruitment goals for personnel from the Federal Career Intern Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6addc-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruitment goals for personnel from the Presidential Management Fellows Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c6addd-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisition Workforce Development Strategic Plan.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83c6adde-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of this subsection is to authorize the preparation and completion of the Acquisition Workforce Development Strategic Plan, which is a plan for Federal agencies other than the Department of Defense to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83c6addf-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a specific and actionable 5-year plan to increase the size of the acquisition workforce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6ade0-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate a government-wide acquisition intern program for the Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6ade1-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Associate Administrator shall be responsible for the management, oversight, and administration of the Acquisition Workforce Development Strategic Plan in cooperation and consultation with the Office of Federal Procurement Policy and with the assistance of the Federal Acquisition Institute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6ade2-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Acquisition Workforce Development Strategic Plan shall include an examination of the following matters:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83c6ade3-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The variety and complexity of acquisitions conducted by each Federal agency covered by the plan, and the workforce needed to effectively carry out the acquisitions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6ade4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The development of a sustainable funding model to support efforts to hire, retain, and train an acquisition workforce of appropriate size and skill to effectively carry out the acquisition programs of the Federal agencies covered by the plan, including an examination of interagency funding methods and a discussion of how the model of the Defense Acquisition Workforce Development Fund could be applied to civilian agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6ade5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/g/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any strategic human capital planning necessary to hire, retain, and train an acquisition workforce of appropriate size and skill at each Federal agency covered by the plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6ade6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/g/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Methodologies that Federal agencies covered by the plan can use to project future acquisition workforce personnel hiring requirements, including an appropriate distribution of such personnel across each category of positions designated as acquisition workforce personnel under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1703/g"},"text":"section 1703(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6ade7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/g/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Government-wide training standards and certification requirements necessary to enhance the mobility and career opportunities of the Federal acquisition workforce within the Federal agencies covered by the plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6ade8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/g/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Associate Administrator recommends as part of the plan a growth in the acquisition workforce of the Federal agencies covered by the plan below 25 percent over the next 5 years, an examination of each of the matters specified in subparagraphs (A) to (E) in the context of a 5-year plan that increases the size of such acquisition workforce by not less than 25 percent, or an explanation why such a level of growth would not be in the best interest of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6ade9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline for completion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Acquisition Workforce Development Strategic Plan shall be completed not later than one year after ","children":[{"tag":"date","attrib":{"date":"2008-10-14"},"text":"October 14, 2008","children":[],"tail":", and in a fashion that allows for immediate implementation of its recommendations and guidelines."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6adea-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The acquisition workforce development strategic plan shall be funded from the acquisition workforce training fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1703/i"},"text":"section 1703(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c6adeb-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training in the Acquisition of Architect and Engineering Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall ensure that a sufficient number of Federal employees are trained in the acquisition of architect and engineering services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c6adec-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1704/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Utilization of Recruitment and Retention Authorities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator, in coordination with the Director of the Office of Personnel Management, shall encourage executive agencies to use existing authorities, including direct hire authority and tuition assistance programs, to recruit and retain acquisition personnel and consider recruiting acquisition personnel who may be retiring from the private sector, consistent with existing laws and regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83c6aded-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3706"},"text":"124 Stat. 3706","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/e/15"},"text":"Pub. L. 111–383, div. A, title X, § 1075(e)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4375"},"text":"124 Stat. 4375","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVIII/s864/a"},"text":"Pub. L. 112–81, div. A, title VIII, § 864(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1522"},"text":"125 Stat. 1522","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1076/a/14"},"text":"Pub. L. 112–239, div. A, title X, § 1076(a)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1948"},"text":"126 Stat. 1948","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83c6adee-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id83c6adef-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments Not Shown in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (g) of this section was derived from ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title VIII, § 869, "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4553"},"text":"122 Stat. 4553","children":[],"tail":", which was set out as a note under section 433a of former Title 41, Public Contracts, prior to being repealed and reenacted as subsec. (g) of this section by "},{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":", §§ 3, 7(b), "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3677"},"text":"124 Stat. 3677","children":[],"tail":", 3855. "},{"tag":"ref","attrib":{"href":"/us/pl/110/417/s869"},"text":"Section 869 of Pub. L. 110–417","children":[],"tail":" was amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/e/15"},"text":"Pub. L. 111–383, div. A, title X, § 1075(e)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4375"},"text":"124 Stat. 4375","children":[],"tail":". For applicability of that amendment to this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/a"},"text":"section 6(a) of Pub. L. 111–350","children":[],"tail":", set out as a Transitional and Savings Provisions note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s101"},"text":"section 101 of this title","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/110/417/s869"},"text":"Section 869 of Pub. L. 110–417","children":[],"tail":" was amended as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(1) in subsection (b), by striking “433(a)” and inserting “433a(a)”; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(2) in subsection (c)(4)—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(A) by striking “37(j)” and inserting “37(g)”; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(B) by striking “433(j)” and inserting “433(g)”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Such references did not appear in the text of subsec. (g) as enacted. See Historical and Revision Notes below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83c6adf0-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83c6adf1-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","