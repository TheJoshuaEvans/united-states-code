rib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1704(g)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:433a note.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title VIII, § 869, "},{"tag":"html:span","attrib":{},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/122/4553"},"text":"122 Stat. 4553","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1704(h), (i)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:433a(f), (g).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the definition of “executive agency” is omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f)(1), the words “Not later than 1 year after the date of the enactment of this Act” are omitted as obsolete.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (g)(2), the words “Associate Administrator” are substituted for “Associate Administrator for Acquisition Workforce Programs designated under section 855(a) of the National Defense Authorization Act for Fiscal Year 2008 (Public Law 110-181; ","children":[{"tag":"ref","attrib":{"href":"/us/stat/122/251"},"text":"122 Stat. 251","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s433/a"},"text":"41 U.S.C. 433(a)","children":[],"tail":")” because of subsection (a)(1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (g)(3)(D), the reference to “section 37(j) of the Office of Federal Procurement Policy Act” is changed to “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1703/g"},"text":"section 1703(g) of this title","children":[],"tail":"” to correct an error in the law."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id83c6adf2-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id83c6adf3-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1076/a/14"},"text":"Pub. L. 112–239, § 1076(a)(14)","children":[],"tail":", made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/s864/a/2"},"text":"Pub. L. 112–81, § 864(a)(2)","children":[],"tail":". See 2011 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s864/a/2"},"text":"Pub. L. 112–81, § 864(a)(2)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1076/a/14"},"text":"Pub. L. 112–239, § 1076(a)(14)","children":[],"tail":", substituted “The Associate Administrator shall be located in the Office of Federal Procurement Policy.” for “The Associate Administrator shall be located in the Federal Acquisition Institute (or its successor).” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s864/a/1"},"text":"Pub. L. 112–81, § 864(a)(1)","children":[],"tail":", inserted “The Associate Administrator shall be chosen on the basis of demonstrated knowledge and expertise in acquisition, human capital, and management.” after “Programs.” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s864/a/3"},"text":"Pub. L. 112–81, § 864(a)(3)","children":[],"tail":"–(5), added par. (5) and redesignated former par. (5) as (6)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id83c6adf4-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id83c6adf5-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1076/a"},"text":"Pub. L. 112–239, div. A, title X, § 1076(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1947"},"text":"126 Stat. 1947","children":[],"tail":", provided that the amendment made by section 1076(a)(14) is effective "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id83c6adf6-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Expansion of Training and Use of Information Technology Cadres","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tVIII/s835"},"text":"Pub. L. 113–291, div. A, title VIII, § 835","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3449"},"text":"128 Stat. 3449","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/291/dA/tVIII/s835"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purpose of this section is to ensure timely progress by Federal agencies toward developing, strengthening, and deploying information technology acquisition cadres consisting of personnel with highly specialized skills in information technology acquisition, including program and project managers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Strategic Planning.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator for Federal Procurement Policy, in consultation with the Administrator for E-Government and Information Technology, shall work with Federal agencies, other than the Department of Defense, to update their acquisition human capital plans that were developed pursuant to the ","children":[{"tag":"date","attrib":{"date":"2009-10-27"},"text":"October 27, 2009","children":[],"tail":", guidance issued by the Administrator for Federal Procurement Policy in furtherance of "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s1704/g"},"text":"section 1704(g) of title 41","children":[],"tail":", United States Code (originally enacted as section 869 of the Duncan Hunter National Defense Authorization Act for Fiscal Year 2009 ("},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Public Law 110–417","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/122/4553"},"text":"122 Stat. 4553","children":[],"tail":")), to address how the agencies are meeting their human capital requirements to support the timely and effective acquisition of information technology."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The updates required by paragraph (1) shall be submitted to the Administrator for Federal Procurement Policy and shall address, at a minimum, each Federal agency’s consideration or use of the following procedures:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development of an information technology acquisition cadre within the agency or use of memoranda of understanding with other agencies that have such cadres or personnel with experience relevant to the agency’s information technology acquisition needs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development of personnel assigned to information technology acquisitions, including cross-functional training of acquisition information technology and program personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Use of the specialized career path for information technology program managers as designated by the Office of Personnel Management and plans for strengthening information technology program management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Use of direct hire authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conduct of peer reviews.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"“(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Piloting of innovative approaches to information technology acquisition workforce development, such as industry-government rotations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Agency Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘Federal agency’ means each agency listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s901/b"},"text":"section 901(b) of title 31","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
