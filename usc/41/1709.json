{"tag":"section","attrib":{"id":"id83c8f763-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1709"},"text":null,"children":[{"tag":"num","attrib":{"value":"1709"},"text":"§ 1709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracting functions performed by Federal personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83c8f764-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Personnel","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Personnel referred to in subsection (b) are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83c8f765-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1709/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c8f766-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1709/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the armed forces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c8f767-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1709/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual assigned to a Federal agency pursuant to subchapter VI of chapter 33 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c8f768-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1709/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Payment for Advisory and Assistance Services","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No individual who is not an individual described in subsection (a) may be paid by an executive agency for services to conduct evaluations or analyses of any aspect of a proposal submitted for an acquisition unless personnel described in subsection (a) with adequate training and capabilities to perform the evaluations and analyses are not readily available in the agency or another Federal agency. When administering this subsection, the head of each executive agency shall determine in accordance with standards and procedures prescribed in the Federal Acquisition Regulation whether—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83c8f769-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1709/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sufficient number of personnel described in subsection (a) in the agency or another Federal agency are readily available to perform a particular evaluation or analysis for the head of the executive agency making the determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c8f76a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1709/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the readily available personnel have the training and capabilities necessary to perform the evaluation or analysis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c8f76b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1709/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain Relationship Not Affected","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not affect the relationship between the Federal Government and a Federally funded research and development center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83c8f76c-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3714"},"text":"124 Stat. 3714","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83c8f76d-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83c8f76e-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83c8f76f-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1709(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:419(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/93/400/s23"},"text":"Pub. L. 93–400, § 23","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/103/355/tVI/s6002/a"},"text":"Pub. L. 103–355, title VI, § 6002(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/108/3363"},"text":"108 Stat. 3363","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1709(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:419(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1709(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:419(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before paragraph (1), the words “Personnel referred to in subsection (b) are” are substituted for “For purposes of subsection (a) of this section, the personnel described in this subsection are as follows” to eliminate unnecessary words. In paragraph (3), the words “employee from State or local governments” are substituted for “person” for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id83c8f770-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Senate Revision Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"In subsec. (a)(3), “individual” substituted for “employee from State or local governments” by S. Amdt. 4726 (111th Cong.). See 156 Cong. Rec. 18682 (2010).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id83c8f771-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id83c8f772-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Requirement for Guidance and Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355/tVI/s6002/b"},"text":"Pub. L. 103–355, title VI, § 6002(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3363"},"text":"108 Stat. 3363","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/355/tVI/s6002/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Federal Acquisition Regulatory Council established by section 25(a) of the Office of Federal Procurement Policy Act ([former] ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s421/a"},"text":"41 U.S.C. 421(a)","children":[],"tail":") [now "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s1302/a"},"text":"41 U.S.C. 1302(a)","children":[],"tail":"] shall—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review part 37 of title 48 of the Code of Federal Regulations as it relates to the use of advisory and assistance services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide guidance and promulgate regulations regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" what actions Federal agencies are required to take to determine whether expertise is readily available within the Federal Government before contracting for advisory and technical services to conduct acquisitions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner in which personnel with expertise may be shared with agencies needing expertise for such acquisitions.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
