{"tag":"section","attrib":{"id":"id83bd10ce-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1311"},"text":null,"children":[{"tag":"num","attrib":{"value":"1311"},"text":"§ 1311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and membership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83bd10cf-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1311/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is in the executive branch a Chief Acquisition Officers Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83bd10d0-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1311/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":" Membership","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The members of the Council are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83bd10d1-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1311/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Deputy Director for Management of the Office of Management and Budget;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bd10d2-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1311/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bd10d3-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1311/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Under Secretary of Defense for Acquisition and Sustainment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bd10d4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1311/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chief acquisition officer of each executive agency that is required to have a chief acquisition officer under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1702"},"text":"section 1702 of this title","children":[],"tail":" and the senior procurement executive of each military department; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bd10d5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1311/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other senior agency officer of each executive agency, appointed by the head of the agency in consultation with the Chairman of the Council, who can effectively assist the Council in performing the functions set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1312/b"},"text":"section 1312(b) of this title","children":[],"tail":" and supporting the associated range of acquisition activities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83bd10d6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1311/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Leadership and Support.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83bd10d7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1311/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairman","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Deputy Director for Management of the Office of Management and Budget is the Chairman of the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bd10d8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1311/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vice chairman","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Vice Chairman of the Council shall be selected by the Council from among its members. The Vice Chairman serves for one year and may serve multiple terms.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bd10d9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1311/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Leader of activities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall lead the activities of the Council on behalf of the Deputy Director for Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bd10da-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1311/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Support","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of General Services shall provide administrative and other support for the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83bd10db-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3694"},"text":"124 Stat. 3694","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s902/89"},"text":"Pub. L. 116–92, div. A, title IX, § 902(89)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1554"},"text":"133 Stat. 1554","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83bd10dc-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83bd10dd-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83bd10de-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","