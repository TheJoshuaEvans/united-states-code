{"tag":"section","attrib":{"id":"id83de7be2-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3708"},"text":null,"children":[{"tag":"num","attrib":{"value":"3708"},"text":"§ 3708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83de7be3-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3708/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protest File.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83de7be4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3708/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment and access","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If, in the case of a solicitation for a contract issued by, or an award or proposed award of a contract by, the head of an executive agency, a protest is filed pursuant to the procedures in subchapter V of chapter 35 of title 31, and an actual or prospective offeror requests, a file of the protest shall be established by the procuring activity and reasonable access shall be provided to actual or prospective offerors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83de7be5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3708/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Redacted information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Information exempt from disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":" may be redacted in a file established pursuant to paragraph (1) unless an applicable protective order provides otherwise."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83de7be6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3708/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency Actions on Protests","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, in connection with a protest, the head of an executive agency determines that a solicitation, proposed award, or award does not comply with the requirements of law or regulation, the head of the executive agency may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83de7be7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3708/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take any action set out in subparagraphs (A) to (F) of subsection (b)(1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3554"},"text":"section 3554 of title 31","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83de7be8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3708/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay costs described in paragraph (1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3554/c"},"text":"section 3554(c) of title 31","children":[],"tail":" within the limits referred to in paragraph (2) of section 3554(c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83de7be9-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","c