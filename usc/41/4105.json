{"tag":"section","attrib":{"id":"id83e33794-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4105"},"text":null,"children":[{"tag":"num","attrib":{"value":"4105"},"text":"§ 4105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory and assistance services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83e33795-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “advisory and assistance services” has the same meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/g"},"text":"section 1105(g) of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e33796-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Award.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e33797-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the requirements of this section, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s4106"},"text":"section 4106 of this title","children":[],"tail":", and other applicable law, the head of an executive agency may enter into a task order contract for procurement of advisory and assistance services."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e33798-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Only under this section","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an executive agency may enter into a task order contract for advisory and assistance services only under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e33799-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract Period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The period of a task order contract entered into under this section, including all periods of extensions of the contract under options, modifications, or otherwise, may not exceed 5 years unless a longer period is specifically authorized in a law that is applicable to the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e3379a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4105/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content of Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The notice required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1708"},"text":"section 1708 of this title","children":[],"tail":" and section 8(e) of the Small Business Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/e"},"text":"15 U.S.C. 637(e)","children":[],"tail":") shall reasonably and fairly describe the general scope, magnitude, and duration of the proposed task order contract in a manner that would reasonably enable a potential offeror to decide whether to request the solicitation and consider submitting an offer."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e3379b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4105/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Content of Solicitation and Contract.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e3379c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4105/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Solicitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The solicitation shall include the information (regarding services) described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s4103/b"},"text":"section 4103(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e3379d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4105/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A task order contract entered into under this section shall contain the same information that is required by paragraph (1) to be included in the solicitation of offers for that contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e3379e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4105/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multiple Awards.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e3379f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4105/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to make multiple awards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On the basis of one solicitation, the head of an executive agency may award separate task order contracts under this section for the same or similar services to 2 or more sources if the solicitation states that the head of the executive agency has the option to do so.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e337a0-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4105/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content of solicitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a task order contract for advisory and assistance services to be entered into under this section, if the contract period is to exceed 3 years and the contract amount is estimated to exceed $10,000,000 (including all options), the solicitation shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83e337a1-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4105/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for a multiple award authorized under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83e337a2-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4105/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a statement that the head of the executive agency may also elect to award only one task order contract if the head of the executive agency determines in writing that only one of the offerors is capable of providing the services required at the level of quality required.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e337a3-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4105/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (2) does not apply in the case of a solicitation for which the head of the executive agency concerned determines in writing that, because the services required under the contract are unique or highly specialized, it is not practicable to award more than one contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e337a4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4105/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract Modifications.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e337a5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4105/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Increase in scope, period, or maximum value of contract only by modification of contract","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A task order may not increase the scope, period, or maximum value of the task order contract under which the order is issued. The scope, period, or maximum value of the contract may be increased only by modification of the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e337a6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4105/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of competitive procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Unless use of procedures other than competitive procedures is authorized by an exception in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3304/a"},"text":"section 3304(a) of this title","children":[],"tail":" and approved in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s3304/e"},"text":"section 3304(e) of this title","children":[],"tail":", competitive procedures shall be used for making such a modification."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e337a7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4105/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notice regarding the modification shall be provided in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1708"},"text":"section 1708 of this title","children":[],"tail":" and section 8(e) of the Small Business Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/e"},"text":"15 U.S.C. 637(e)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e337a8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4105/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract Extensions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e337a9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4105/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"When contract may be extended","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding the limitation on the contract period set forth in subsection (c) or in a solicitation or contract pursuant to subsection (f), a contract entered into by the head of an executive agency under this section may be extended on a sole-source basis for a period not exceeding 6 months if the head of the executive agency determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83e5a7aa-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4105/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the award of a follow-on contract has been delayed by circumstances that were not reasonably foreseeable at the time the initial contract was entered into; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83e5a7ab-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4105/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extension is necessary to ensure continuity of the receipt of services pending the award of, and commencement of performance under, the follow-on contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e5a7ac-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4105/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limit of one extension","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A task order contract may be extended under paragraph (1) only once and only in accordance with the limitations and requirements of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e5a7ad-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4105/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability to Certain Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not apply to a contract for the acquisition of property or services that includes acquisition of advisory and assistance services if the head of the executive agency entering into the contract determines that, under the contract, advisory and assistance services are necessarily incident to, and not a significant component of, the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83e5a7ae-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3780"},"text":"124 Stat. 3780","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83e5a7af-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83e5a7b0-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83e5a7b1-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail