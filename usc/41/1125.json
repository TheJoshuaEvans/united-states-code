{"tag":"section","attrib":{"id":"id83b8561d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1125"},"text":null,"children":[{"tag":"num","attrib":{"value":"1125"},"text":"§ 1125.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recipients of Federal grants or assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83b8561e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1125/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With due regard to applicable laws and the program activities of the executive agencies administering Federal programs of grants or assistance, the Administrator may prescribe Government-wide policies, regulations, procedures, and forms that the Administrator considers appropriate and that executive agencies shall follow in providing for the procurement, to the extent required under those programs, of property or services referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1121/c/1"},"text":"section 1121(c)(1) of this title","children":[],"tail":" by recipients of Federal grants or assistance under the programs."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83b8561f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1125/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) does not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83b85620-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1125/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit the Administrator to authorize procurement or supply support, either directly or indirectly, to a recipient of a Federal grant or assistance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83b85621-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1125/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize action by a recipient contrary to State and local law in the case of a program to provide a Federal grant or assistance to a State or political subdivision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83b85622-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3688"},"text":"124 Stat. 3688","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83b85623-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83b85624-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83b85625-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":