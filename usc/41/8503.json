{"tag":"section","attrib":{"id":"id83ffe626-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8503"},"text":null,"children":[{"tag":"num","attrib":{"value":"8503"},"text":"§ 8503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties and powers of the Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83ffe627-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procurement List.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83ffe628-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maintenance of list","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall maintain and publish in the Federal Register a procurement list. The list shall include the following products and services determined by the Committee to be suitable for the Federal Government to procure pursuant to this chapter:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83ffe629-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8503/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Products produced by a qualified nonprofit agency for the blind or by a qualified nonprofit agency for other severely disabled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83ffe62a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8503/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The services those agencies provide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83ffe62b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Changes to list","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee may, by rule made in accordance with the requirements of section 553(b) to (e) of title 5, add to and remove from the procurement list products so produced and services so provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83ffe62c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fair Market Price","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall determine the fair market price of products and services contained on the procurement list that are offered for sale to the Federal Government by a qualified nonprofit agency for the blind or a qualified nonprofit agency for other severely disabled. The Committee from time to time shall revise its price determinations with respect to those products and services in accordance with changing market conditions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83ffe62d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Central Nonprofit Agency or Agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall designate a central nonprofit agency or agencies to facilitate the distribution, by direct allocation, subcontract, or any other means, of orders of the Federal Government for products and services on the procurement list among qualified nonprofit agencies for the blind or qualified nonprofit agencies for other severely disabled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83ffe62e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8503/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83ffe62f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8503/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may prescribe regulations regarding specifications for products and services on the procurement list, the time of their delivery, and other matters as necessary to carry out this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83ffe630-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8503/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall prescribe regulations providing that when the Federal Government purchases products produced and offered for sale by qualified nonprofit agencies for the blind or qualified nonprofit agencies for other severely disabled, priority shall be given to products produced and offered for sale by qualified nonprofit agencies for the blind.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83ffe631-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8503/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Study and Evaluation of Activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall make a continuing study and evaluation of its activities under this chapter to ensure effective and efficient administration of this chapter. The Committee on its own or in cooperation with other public or nonprofit private agencies may study—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83ffe632-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8503/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" problems related to the employment of the blind and other severely disabled individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83ffe633-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8503/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and adaptation of production methods that would enable a greater utilization of the blind and other severely disabled individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83ffe634-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3836"},"text":"124 Stat. 3836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83ffe635-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83ffe636-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83ffe637-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8503(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:47(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1938-06-25/ch697/s2"},"text":"June 25, 1938, ch. 697, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/52/1196"},"text":"52 Stat. 1196","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/92/28/s1"},"text":"Pub. L. 92–28, § 1","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"June 23, 1971","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/85/79"},"text":"85 Stat. 79","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8503(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:47(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8503(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:47(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8503(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:47(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8503(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:47(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the text of 41:47(a)(1) (last sentence) is omitted as obsolete. The words “procurement list” are substituted for “(hereafter in sections 46 to 48c of this title referred to as the ‘procurement list’)” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(2), the text of 41:47(d)(2)(B) is omitted as obsolete.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
