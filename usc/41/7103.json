{"tag":"section","attrib":{"id":"id83f3ff9c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103"},"text":null,"children":[{"tag":"num","attrib":{"value":"7103"},"text":"§ 7103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decision by contracting officer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83f3ff9d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Claims Generally.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83f3ff9e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission of contractor’s claims to contracting officer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each claim by a contractor against the Federal Government relating to a contract shall be submitted to the contracting officer for a decision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f3ff9f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contractor’s claims in writing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each claim by a contractor against the Federal Government relating to a contract shall be in writing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f3ffa0-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracting officer to decide federal government’s claims","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each claim by the Federal Government against a contractor relating to a contract shall be the subject of a written decision by the contracting officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f3ffa1-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time for submitting claims.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83f3ffa2-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each claim by a contractor against the Federal Government relating to a contract and each claim by the Federal Government against a contractor relating to a contract shall be submitted within 6 years after the accrual of the claim.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83f3ffa3-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subparagraph (A) of this paragraph does not apply to a claim by the Federal Government against a contractor that is based on a claim by the contractor involving fraud.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f3ffa4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority of this subsection and subsections (c)(1), (d), and (e) does not extend to a claim or dispute for penalties or forfeitures prescribed by statute or regulation that another Federal agency is specifically authorized to administer, settle, or determine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83f3ffa5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification of Claims.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83f3ffa6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement generally","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For claims of more than $100,000 made by a contractor, the contractor shall certify that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83f3ffa7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the claim is made in good faith;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83f3ffa8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the supporting data are accurate and complete to the best of the contractor’s knowledge and belief;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83f3ffa9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount requested accurately reflects the contract adjustment for which the contractor believes the Federal Government is liable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83f3ffaa-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the certifier is authorized to certify the claim on behalf of the contractor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f3ffab-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Who may execute certification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The certification required by paragraph (1) may be executed by an individual authorized to bind the contractor with respect to the claim.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f3ffac-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Failure to certify or defective certification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contracting officer is not obligated to render a final decision on a claim of more than $100,000 that is not certified in accordance with paragraph (1) if, within 60 days after receipt of the claim, the contracting officer notifies the contractor in writing of the reasons why any attempted certification was found to be defective. A defect in the certification of a claim does not deprive a court or an agency board of jurisdiction over the claim. Prior to the entry of a final judgment by a court or a decision by an agency board, the court or agency board shall require a defective certification to be corrected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83f3ffad-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fraudulent Claims.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83f3ffae-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No authority to settle","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not authorize an agency head to settle, compromise, pay, or otherwise adjust any claim involving fraud.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f3ffaf-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liability of contractor","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a contractor is unable to support any part of the contractor’s claim and it is determined that the inability is attributable to a misrepresentation of fact or fraud by the contractor, then the contractor is liable to the Federal Government for an amount equal to the unsupported part of the claim plus all of the Federal Government’s costs attributable to reviewing the unsupported part of the claim. Liability under this paragraph shall be determined within 6 years of the commission of the misrepresentation of fact or fraud.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83f3ffb0-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Issuance of Decision","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The contracting officer shall issue a decision in writing and shall mail or otherwise furnish a copy of the decision to the contractor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83f3ffb1-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of Decision","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The contracting officer’s decision shall state the reasons for the decision reached and shall inform the contractor of the contractor’s rights as provided in this chapter. Specific findings of fact are not required. If made, specific findings of fact are not binding in any subsequent proceeding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83f3ffb2-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time for Issuance of Decision.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83f3ffb3-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Claim of $100,000 or less","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contracting officer shall issue a decision on any submitted claim of $100,000 or less within 60 days from the contracting officer’s receipt of a written request from the contractor that a decision be rendered within that period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f3ffb4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Claim of more than $100,000","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A contracting officer shall, within 60 days of receipt of a submitted certified claim over $100,000—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83f3ffb5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue a decision; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83f3ffb6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the contractor of the time within which a decision will be issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f3ffb7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General requirement of reasonableness","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The decision of a contracting officer on submitted claims shall be issued within a reasonable time, in accordance with regulations prescribed by the agency, taking into account such factors as the size and complexity of the claim and the adequacy of information in support of the claim provided by the contractor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f3ffb8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requesting tribunal to direct issuance within specified time period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contractor may request the tribunal concerned to direct a contracting officer to issue a decision in a specified period of time, as determined by the tribunal concerned, in the event of undue delay on the part of the contracting officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f3ffb9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Failure to issue decision within required time period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Failure by a contracting officer to issue a decision on a claim within the required time period is deemed to be a decision by the contracting officer denying the claim and authorizes an appeal or action on the claim as otherwise provided in this chapter. However, the tribunal concerned may, at its option, stay the proceedings of the appeal or action to obtain a decision by the contracting officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83f3ffba-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Finality of Decision Unless Appealed","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The contracting officer’s decision on a claim is final and conclusive and is not subject to review by any forum, tribunal, or Federal Government agency, unless an appeal or action is timely commenced as authorized by this chapter. This chapter does not prohibit an executive agency from including a clause in a Federal Government contract requiring that, pending final decision of an appeal, action, or final settlement, a contractor shall proceed diligently with performance of the contract in accordance with the contracting officer’s decision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83f3ffbb-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternative Means of Dispute Resolution.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83f3ffbc-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of this chapter, a contractor and a contracting officer may use any alternative means of dispute resolution under subchapter IV of chapter 5 of title 5, or other mutually agreeable procedures, for resolving claims. All provisions of subchapter IV of chapter 5 of title 5 apply to alternative means of dispute resolution under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f3ffbd-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification of claim","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The contractor shall certify the claim when required to do so under subsection (b)(1) or other law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f3ffbe-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rejecting request for alternative dispute resolution.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83f3ffbf-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracting officer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contracting officer who rejects a contractor’s request for alternative dispute resolution proceedings shall provide the contractor with a written explanation, citing one or more of the conditions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s572/b"},"text":"section 572(b) of title 5","children":[],"tail":" or other specific reasons that alternative dispute resolution procedures are inappropriate."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83f3ffc0-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7103/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contractor","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contractor that rejects an agency’s request for alternative dispute resolution proceedings shall inform the agency in writing of the contractor’s specific reasons for rejecting the request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83f3ffc1-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3817"},"text":"124 Stat. 3817","children":[],"tail":".)"}],"tail":"\n"},{"tag":"no