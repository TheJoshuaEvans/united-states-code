{"tag":"section","attrib":{"id":"id83f3ff75-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7101"},"text":null,"children":[{"tag":"num","attrib":{"value":"7101"},"text":"§ 7101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83f3ff76-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Administrator” means the Administrator for Federal Procurement Policy appointed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1102"},"text":"section 1102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f3ff77-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency board or agency board of contract appeals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “agency board” or “agency board of contract appeals” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83f3ff78-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7101/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Armed Services Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83f3ff79-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7101/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Civilian Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83f3ff7a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7101/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the board of contract appeals of the Tennessee Valley Authority; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83f3ff7b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7101/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Postal Service Board established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s7105/d/1"},"text":"section 7105(d)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f3ff7c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7101/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency head","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “agency head” means the head and any assistant head of an executive agency. The term may include the chief official of a principal division of an executive agency if the head of the executive agency so designates that chief official.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f3ff7d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7101/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Armed services board","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Armed Services Board” means the Armed Services Board of Contract Appeals established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s7105/a/1"},"text":"section 7105(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f3ff7e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7101/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civilian board","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Civilian Board” means the Civilian Board of Contract Appeals established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s7105/b/1"},"text":"section 7105(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f3ff7f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7101/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracting officer","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “contracting officer”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83f3ff80-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7101/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means an individual who, by appointment in accordance with applicable regulations, has the authority to make and administer contracts and to make determinations and findings with respect to contracts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib