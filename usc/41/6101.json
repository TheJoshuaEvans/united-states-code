tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6101(b)–(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:5.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3709; ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-08-02/ch744/s9/a"},"text":"Aug. 2, 1946, ch. 744, § 9(a)","children":[],"tail":", (c), "},{"tag":"html:a","attrib":{"href":"/us/stat/60/809"},"text":"60 Stat. 809","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title VI, § 602(f), formerly title V, § 502(e), "},{"tag":"html:a","attrib":{"href":"/us/stat/63/403"},"text":"63 Stat. 403","children":[],"tail":", renumbered title VI, § 602(f), "},{"tag":"html:a","attrib":{"href":"/us/act/1950-09-05/ch849"},"text":"Sept. 5, 1950, ch. 849","children":[],"tail":", §§ 6(a), (b), 8(c), "},{"tag":"html:a","attrib":{"href":"/us/stat/64/583"},"text":"64 Stat. 583","children":[],"tail":", 591; "},{"tag":"html:a","attrib":{"href":"/us/pl/85/800/s7"},"text":"Pub. L. 85–800, § 7","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 28, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/967"},"text":"72 Stat. 967","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/93/356/s1"},"text":"Pub. L. 93–356, § 1","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"July 25, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/390"},"text":"88 Stat. 390","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/98/191/s9/b"},"text":"Pub. L. 98–191, § 9(b)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 1, 1983","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/97/1332"},"text":"97 Stat. 1332","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before paragraph (1), the words “In this section” are substituted for “as used in this Act” as the probable intent of Congress. ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-02/s9/a"},"text":"Section 9(a) of the Act of August 2, 1946","children":[],"tail":" (ch. 744, "},{"tag":"ref","attrib":{"href":"/us/stat/60/809"},"text":"60 Stat. 809","children":[],"tail":") restated 41:5 generally and section 9(c) of the Act, an independent provision, was editorially added as the last paragraph of 41:5. The definitions which apply to “as used in this Act” are probably intended to apply also to 41:5 as restated by the Act. The definitions for “department” and “continental United States” are omitted because those terms do not appear in 41:5. In paragraph (1), the words “"},{"tag":"ref","attrib":{"href":"/us/usc/t31/s9104"},"text":"section 9104 of title 31","children":[],"tail":"” are substituted for “section 104 of the Government Corporation Control Act, approved "},{"tag":"date","attrib":{"date":"1945-12-06"},"text":"December 6, 1945","children":[],"tail":"” because of section 4(b) of Public Law. 97–258 (31 U.S.C. note prec. 101). In paragraphs (1) and (2), the word “includes” is substituted for “shall be construed to include” and for “shall be construed as including”, respectively, to eliminate unnecessary words."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “as authorized by section 29 of the Surplus Property Act of 1944 (50 U.S.C. App. 1638)” in section 3709 of the Revised Statutes are omitted because section 29 was repealed by section 602(a)(1) of the Federal Property and Administrative Services Act of 1949 (ch. 288, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/63/399"},"text":"63 Stat. 399","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
