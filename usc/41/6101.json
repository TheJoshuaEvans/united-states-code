{"tag":"section","attrib":{"id":"id83ecd410-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6101"},"text":null,"children":[{"tag":"num","attrib":{"value":"6101"},"text":"§ 6101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advertising requirement for Federal Government purchases and sales","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83ecd411-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83ecd412-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6101/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “appropriation” includes amounts made available by legislation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s9104"},"text":"section 9104 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83ecd413-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6101/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal government","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Federal Government” includes the government of the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83ecd414-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purchases.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83ecd415-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6101/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Unless otherwise provided in the appropriation concerned or other law, purchases and contracts for supplies or services for the Federal Government may be made or entered into only after advertising for proposals for a sufficient time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83ecd416-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6101/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations on applicability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) does not apply when—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83ecd417-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6101/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount involved in any one case does not exceed $25,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83ecd418-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6101/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public exigencies require the immediate delivery of articles or performance of services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83ecd419-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6101/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only one source of supply is available and the Federal Government purchasing or contracting officer so certifies; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83ecd41a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6101/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" services are required to be performed by a contractor in person and are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83ecd41b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6101/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of a technical and professional nature; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83ecd41c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6101/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under Federal Government supervision and paid for on a time basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83ecd41d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6101/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sales","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except when otherwise authorized by law or when the reasonable value involved in any one case does not exceed $500, sales and contracts of sale by the Federal Government are governed by the requirements of this section for advertising.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83ecd41e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6101/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application to Wholly Owned Government Corporations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For wholly owned Government corporations, this section applies only to administrative transactions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83ecd41f-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3801"},"text":"124 Stat. 3801","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83ecd420-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83ecd421-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83ecd422-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"