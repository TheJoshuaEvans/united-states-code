{"tag":"section","attrib":{"id":"id83f18ecc-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6504"},"text":null,"children":[{"tag":"num","attrib":{"value":"6504"},"text":"§ 6504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Three-year prohibition on new contracts in case of breach or violation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83f18ecd-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribution of List","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Comptroller General shall distribute to each agency of the United States a list containing the names of persons found by the Secretary to have breached or violated a representation or stipulation included in a contract under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6502"},"text":"section 6502 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83f18ece-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Three-Year Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Unless the Secretary recommends otherwise, a contract described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6502"},"text":"section 6502 of this title","children":[],"tail":" may not be awarded to a person named on the list under subsection (a), or to a firm, corporation, partnership, or association in which the person has a controlling interest, until 3 years have elapsed from the date of the determination by the Secretary that a breach or violation occurred."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83f18ecf-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3808"},"text":"124 Stat. 3808","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83f18ed0-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83f18ed1-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83f18ed2-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6504","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:37.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-30/ch881/s3"},"text":"June 30, 1936, ch. 881, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/49/2037"},"text":"49 Stat. 2037","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the words “or firms” are omitted because of the definition of “person” in 41:41, restated in section 6501 of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “or violated” are added for consistency in the chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “contract described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6502"},"text":"section 6502 of this title","children":[],"tail":"” are substituted for “contracts” to clarify the scope of the prohibition. The words “the date of the determination by the Secretary that a breach or violation occurred” are substituted for “the date the Secretary of Labor determines such breach to have occurred” to clarify that the three-year period begins with the date of the Secretary’s determination and not with the date of the breach or violation. The words “or violation” are added for consistency in the chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
