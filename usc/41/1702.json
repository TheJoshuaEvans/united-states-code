(1), (2)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:414(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/93/400/s16"},"text":"Pub. L. 93–400, § 16","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/98/191/s7"},"text":"Pub. L. 98–191, § 7","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 1, 1983","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/97/1330"},"text":"97 Stat. 1330","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/98/369/tVII/s2732/b/2"},"text":"Pub. L. 98–369, title VII, § 2732(b)(2)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/1199"},"text":"98 Stat. 1199","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/108/136/dA/tXIV/s1421/a/1"},"text":"Pub. L. 108–136, div. A, title XIV, § 1421(a)(1)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/117/1666"},"text":"117 Stat. 1666","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1702(b)(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:414(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1702(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:414(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id83c43d6b-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id83c43d6c-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (b)(3)(F) to (H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s849/a"},"text":"Pub. L. 112–239, § 849(a)","children":[],"tail":", added subpar. (F) and redesignated former subpars. (F) and (G) as (G) and (H), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s849/b"},"text":"Pub. L. 112–239, § 849(b)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
