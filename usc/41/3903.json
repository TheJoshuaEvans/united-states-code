{"tag":"section","attrib":{"id":"id83e33704-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3903"},"text":null,"children":[{"tag":"num","attrib":{"value":"3903"},"text":"§ 3903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiyear contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83e33705-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, a multiyear contract is a contract for the purchase of property or services for more than one, but not more than 5, program years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e33706-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Enter Into Contract","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An executive agency may enter into a multiyear contract for the acquisition of property or services if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e33707-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds are available and obligated for the contract, for the full period of the contract or for the first fiscal year in which the contract is in effect, and for the estimated costs associated with a necessary termination of the contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e33708-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the executive agency determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83e33709-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3903/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for the property or services is reasonably firm and continuing over the period of the contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83e3370a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3903/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a multiyear contract will serve the best interests of the Federal Government by encouraging full and open competition or promoting economy in administration, performance, and operation of the agency’s programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e3370b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination Clause","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A multiyear contract entered into under the authority of this section shall include a clause that provides that the contract shall be terminated if funds are not made available for the continuation of the contract in a fiscal year covered by the contract. Funds available for paying termination costs shall remain available for that purpose until the costs associated with termination of the contract are paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e3370c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3903/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cancellation Ceiling Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before a contract described in subsection (b) that contains a clause setting forth a cancellation ceiling in excess of $10,000,000 may be awarded, the executive agency shall give written notification of the proposed contract and of the proposed cancellation ceiling for that contract to Congress. The contract may not be awarded until the end of the 30-day period beginning on the date of the notification.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e3370d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3903/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contingency Clause for Appropriation of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A multiyear contract may provide that performance under the contract after the first year of the contract is contingent on the appropriation of funds and (if the contract does so provide) that a cancellation payment shall be made to the contractor if the funds are not appropriated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e3370e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3903/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Law Not Affected","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not modify or affect any other provision of law that authorizes multiyear contracts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83e3370f-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3774"},"text":"124 Stat. 3774","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83e33710-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83e33711-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83e33712-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3903(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:254c(d) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title III, § 304B, as added "},{"tag":"html:a","attrib":{"href":"/us/pl/103/355/tI/s1072"},"text":"Pub. L. 103–355, title I, § 1072","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/108/3270"},"text":"108 Stat. 3270","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3903(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:254c(a).","children":[],"tail":null}],"tail":null},{"t