{"tag":"section","attrib":{"id":"id83ffe67b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8704"},"text":null,"children":[{"tag":"num","attrib":{"value":"8704"},"text":"§ 8704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83ffe67c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To ascertain whether there has been a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s8702"},"text":"section 8702 of this title","children":[],"tail":" with respect to a prime contract, the Comptroller General and the inspector general of the contracting agency, or a representative of the contracting agency designated by the head of the agency if the agency does not have an inspector general, shall have access to and may inspect the facilities and audit the books and records, including electronic data or records, of a prime contractor or subcontractor under a prime contract awarded by the agency."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83ffe67d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not apply to a prime contract for the acquisition of commercial products or commercial services (as defined in sections 103 and 103a, respectively, of this title).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"i