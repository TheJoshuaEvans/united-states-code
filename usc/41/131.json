{"tag":"section","attrib":{"id":"id83b39b74-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s131"},"text":null,"children":[{"tag":"num","attrib":{"value":"131"},"text":"§ 131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In division B, the term “acquisition”—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83b39b75-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s131/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means the process of acquiring, with appropriated amounts, by contract for purchase or lease, property or services (including construction) that support the missions and goals of an executive agency, from the point at which the requirements of the executive agency are established in consultation with the chief acquisition officer of the executive agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83b39b76-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s131/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83b5e567-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s131/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the process of acquiring property or services that are already in existence, or that must be created, developed, demonstrated, and evaluated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83b5e568-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s131/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the description of requirements to satisfy agency needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83b5e569-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s131/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solicitation and selection of sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83b5e56a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s131/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award of contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83b5e56b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s131/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contract performance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83b5e56c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s131/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contract financing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83b5e56d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s131/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" management and measurement of contract performance through final delivery and payment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83b5e56e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s131/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null}