{"tag":"section","attrib":{"id":"id83ef1d74-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6306"},"text":null,"children":[{"tag":"num","attrib":{"value":"6306"},"text":"§ 6306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on Members of Congress making contracts with Federal Government","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83ef1d75-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Member of Congress may not enter into or benefit from a contract or agreement or any part of a contract or agreement with the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83ef1d76-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemptions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83ef1d77-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6306/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) does not apply to contracts that the Secretary of Agriculture may enter into with farmers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83ef1d78-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6306/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2