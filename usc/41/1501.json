{"tag":"section","attrib":{"id":"id83bf82bf-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501"},"text":null,"children":[{"tag":"num","attrib":{"value":"1501"},"text":"§ 1501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost Accounting Standards Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83bf82c0-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Organization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Cost Accounting Standards Board is an independent board in the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83bf82c1-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83bf82c2-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members, chairman, and appointment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall consist of 5 voting members and 2 nonvoting members.","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83bf82c3-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Voting members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"One voting member is the Administrator of Federal Procurement Policy, who serves as Chairman. The other 4 members, all of whom shall have experience in Federal Government contract cost accounting, are as follows:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83bf82c4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 2 representatives of the Federal Government, each of whom has substantial experience in administering and managing covered contracts—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id83bf82c5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/b/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one of whom is a representative of the Department of Defense appointed by the Secretary of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id83bf82c6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/b/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one of whom is an officer or employee of the General Services Administration appointed by the Administrator of General Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83bf82c7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 2 individuals from the private sector, each of whom is appointed by the Director of the Office of Management and Budget—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id83bf82c8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/b/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one of whom is a senior employee or retired senior employee of a Government contractor with substantial experience in the private sector involving administration and management of covered contracts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id83bf82c9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/b/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member of the accounting profession, with substantial experience as an accountant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bf82ca-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonvoting members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There may be up to 2 nonvoting members appointed by the Board from academia, a nonprofit organization, or a private entity with substantial experience in establishing financial accounting and reporting standards in compliance with Generally Accepted Accounting Principles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bf82cb-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term of office.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83bf82cc-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Length of term","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term of office of each member, other than the Administrator, is 4 years, which may be extended for an additional 4-year period by the individual who appointed such member under paragraph (1). The terms are staggered, with the terms of 2 members expiring in the same year, the term of another member expiring the next year, and the term of the last member expiring the year after that.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bf82cd-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Individual required to remain with appointing agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member appointed under paragraph (1)(A)(i) may not continue to serve after ceasing to be an officer or employee of the agency from which that member was appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bf82ce-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vacancy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vacancy on the Board shall be filled in the same manner in which the original appointment was made. A member appointed to fill a vacancy serves for the remainder of the term for which that member’s predecessor was appointed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bf82cf-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ineligibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Beginning on ","children":[{"tag":"date","attrib":{"date":"2028-01-01"},"text":"January 1, 2028","children":[],"tail":", an individual who is a member of an audit entity of an executive agency is not eligible to serve as a member of the Board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83bf82d0-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83bf82d1-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the cost accounting standards used by Federal contractors rely, to the maximum extent practicable, on commercial standards and accounting practices and systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bf82d2-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 180 days after the date of enactment of this paragraph, and biennially thereafter, review any cost accounting standards established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1502"},"text":"section 1502 of this title","children":[],"tail":" and eliminate or conform such standards, where practicable, to Generally Accepted Accounting Principles;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bf82d3-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annually review disputes involving such standards brought to the boards established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s7105"},"text":"section 7105 of this title","children":[],"tail":" or Federal courts, and consider whether greater clarity in such standards could avoid such disputes, and take necessary action to clarify or improve such standards if misinterpretation or lack of clarity in a standard was a primary component of such dispute; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bf82d4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that any action taken pursuant to paragraph (3) is not taken solely for the purpose of tailoring such standard to favor a party in the dispute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83bf82d5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board shall meet not less than once each quarter and shall publish in the Federal Register notice of each meeting and its agenda before such meeting is held.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83bf82d6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall annually submit a report to the congressional defense committees, the Committee on Oversight and Government Reform of the House of Representatives, and the Committee on Homeland Security and Governmental Affairs of the Senate describing the actions taken during the prior year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83bf82d7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conform the cost accounting standards established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1502"},"text":"section 1502 of this title","children":[],"tail":" with Generally Accepted Accounting Principles;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bf82d8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to minimize the burden on contractors while protecting the interests of the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bf82d9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" including a summary of rulemaking activities related to any changes to such standards and any associated timelines for such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83bf82da-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Senior Staff","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator, after consultation with the Board—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83bf82db-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" without regard to the provisions of title 5 governing appointments in the competitive service—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83bf82dc-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall appoint an executive secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bf82dd-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall appoint, or detail pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3341"},"text":"section 3341 of title 5","children":[],"tail":", not less than four additional staff members; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bf82de-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may pay those employees without regard to the provisions of chapter 51 and subchapter III of chapter 53 of title 5 relating to classification and General Schedule pay rates, except that those employees may not receive pay in excess of the maximum rate of basic pay payable for level IV of the Executive Schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83bf82df-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Staff","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may appoint, fix the compensation of, and remove additional employees of the Board under the applicable provisions of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83bf82e0-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Detailed and Temporary Personnel","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For service on advisory committees and task forces to assist the Board in carrying out its functions and responsibilities—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83bf82e1-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board, with the consent of the head of a Federal agency, may use, without reimbursement, personnel of that agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c1cbd2-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator, after consultation with the Board, may procure temporary and intermittent services of personnel under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109/b"},"text":"section 3109(b) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c1cbd3-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83c1cbd4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officers and employees of the government","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Members of the Board who are officers or employees of the Federal Government, and officers and employees of other agencies of the Federal Government who are used under subsection (h)(1), shall not receive additional compensation for services but shall continue to be compensated by the employing department or agency of the officer or employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c1cbd5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointees from private sector","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each member of the Board appointed from the private sector shall receive compensation at a rate not to exceed the daily equivalent of the rate for level IV of the Executive Schedule for each day (including travel time) in which the member is engaged in the actual performance of duties vested in the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c1cbd6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Temporary and intermittent personnel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual hired under subsection (h)(2) may receive compensation at a rate fixed by the Administrator, but not to exceed the daily equivalent of the rate for level V of the Executive Schedule for each day (including travel time) in which the individual is properly engaged in the actual performance of duties under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c1cbd7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Travel expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"While serving away from home or regular place of business, Board members and other individuals serving on an intermittent basis under this chapter shall be allowed travel expenses in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c1cbd8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1501/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Contract Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “covered contract” means a contract that is subject to the cost accounting standards issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1502"},"text":"section 1502 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83c1cbd9-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3695"},"text":"124 Stat. 3695","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s820/a/1"},"text":"Pub. L. 114–328, div. A, title VIII, § 820(a)(1)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2273"},"text":"130 Stat. 2273","children":[],"tail":", 2274; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVIII/s1806/b/1"},"text":"Pub. L. 119–60, div. A, title XVIII, § 1806(b)(1)","children":[],"tail":"–(6), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1237-1239"},"text":"139 Stat. 1237–1239","children":[],"tail":".)"}],"tail":