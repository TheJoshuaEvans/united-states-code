trib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1501(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:422(a)(1) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/93/400/s26/a"},"text":"Pub. L. 93–400, § 26(a)","children":[],"tail":"–(e), as added "},{"tag":"html:a","attrib":{"href":"/us/pl/100/679/s5/a"},"text":"Pub. L. 100–679, § 5(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 17, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/4058"},"text":"102 Stat. 4058","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1501(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:422(a)(1) (last sentence), (2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1501(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:422(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1501(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:422(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1501(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:422(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1501(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:422(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the text of 41:422(a)(2)(C) is omitted as obsolete.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2)(A), the last sentence is substituted for “of the initial members, two shall be appointed for terms of two years, one shall be appointed for a term of three years, and one shall be appointed for a term of four years” because the initial members have already been appointed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the reference to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of title 5","children":[],"tail":" is substituted for the reference to grade GS–18 of the General Schedule because of section 529 [title I, § 101(c)(1)] of the Treasury, Postal Service, and General Government Appropriations Act, 1991 ("},{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Public Law 101–509","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1442"},"text":"104 Stat. 1442","children":[],"tail":", 5:5376 note)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f)(1), the words “Except as otherwise provided in subsection (a) of this section” are omitted because 41:422(a) does not provide any relevant exception.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f)(2), the words “private sector” are substituted for “private life” for consistency with subsection (b)(1)(B) of the revised section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f)(3), the words “Executive Schedule” are substituted for “Federal Executive Salary Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5316"},"text":"section 5316 of title 5","children":[],"tail":"” for consistency and to eliminate unnecessary words."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id83c1cbdd-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Senate Revision Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"In subsec. (c)(2), “for level IV of the Executive Schedule” substituted for “under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of title 5","children":[],"tail":"” by S. Amdt. 4726 (111th Cong.). See 156 Cong. Rec. 18682 (2010)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id83c1cbde-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id83c1cbdf-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this paragraph, referred to in subsec. (c)(2), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Level IV of the Executive Schedule, referred to in subsec. (f)(2), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id83c1cbe0-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1806/b/1"},"text":"Pub. L. 119–60, § 1806(b)(1)","children":[],"tail":", substituted “Office of Management and Budget” for “Office of Federal Procurement Policy”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1806/b/2/A"},"text":"Pub. L. 119–60, § 1806(b)(2)(A)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) related to the configuration of the Cost Accounting Standards Board."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1806/b/2/B/i"},"text":"Pub. L. 119–60, § 1806(b)(2)(B)(i)","children":[],"tail":", inserted “, which may be extended for an additional 4-year period by the individual who appointed such member under paragraph (1)” after “4 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1806/b/2/B/ii"},"text":"Pub. L. 119–60, § 1806(b)(2)(B)(ii)","children":[],"tail":", substituted “paragraph (1)(A)(i)” for “paragraph (1)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1806/b/2/C"},"text":"Pub. L. 119–60, § 1806(b)(2)(C)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1806/b/3/A"},"text":"Pub. L. 119–60, § 1806(b)(3)(A)","children":[],"tail":", substituted “not later than 180 days after the date of enactment of this paragraph, and biennially thereafter, review any cost accounting standards established under "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s1502"},"text":"section 1502 of this title","children":[],"tail":" and eliminate or conform such standards” for “within one year after the date of enactment of this subsection, and on an ongoing basis thereafter, review any cost accounting standards established under "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s1502"},"text":"section 1502 of this title","children":[],"tail":" and conform such standards”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1806/b/3/B"},"text":"Pub. L. 119–60, § 1806(b)(3)(B)","children":[],"tail":", substituted “disputes, and take necessary action to clarify or improve such standards if misinterpretation or lack of clarity in a standard was a primary component of such dispute; and” for “disputes.”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1806/b/3/C"},"text":"Pub. L. 119–60, § 1806(b)(3)(C)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1806/b/4"},"text":"Pub. L. 119–60, § 1806(b)(4)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1806/b/5"},"text":"Pub. L. 119–60, § 1806(b)(5)","children":[],"tail":", substituted “shall appoint” for “may appoint” and “not less than four” for “two”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1806/b/6"},"text":"Pub. L. 119–60, § 1806(b)(6)","children":[],"tail":", added subsec. (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s820/a/1/A"},"text":"Pub. L. 114–328, § 820(a)(1)(A)","children":[],"tail":", inserted “and, if possible, is a representative of a public accounting firm” after “systems”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s820/a/1/C"},"text":"Pub. L. 114–328, § 820(a)(1)(C)","children":[],"tail":", added subsecs. (c) to (e). Former subsecs. (c) to (e) redesignated (f) to (h), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s820/a/1/B"},"text":"Pub. L. 114–328, § 820(a)(1)(B)","children":[],"tail":", (D), redesignated subsec. (c) as (f) and amended it generally. Prior to amendment, text read as follows: “The Administrator, after consultation with the Board, may—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) appoint an executive secretary and 2 additional staff members without regard to the provisions of title 5 governing appointments in the competitive service; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) pay those employees without regard to the provisions of chapter 51 and subchapter III of chapter 53 of title 5 relating to classification and General Schedule pay rates, except that those employees may not receive pay in excess of the maximum rate of basic pay payable for level IV of the Executive Schedule.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g) to (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s820/a/1/B"},"text":"Pub. L. 114–328, § 820(a)(1)(B)","children":[],"tail":", redesignated subsecs. (d) to (f) as (g) to (i), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s820/a/3/A"},"text":"Pub. L. 114–328, § 820(a)(3)(A)","children":[],"tail":", substituted “subsection (h)(1)” for “subsection (e)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s820/a/3/B"},"text":"Pub. L. 114–328, § 820(a)(3)(B)","children":[],"tail":", substituted “subsection (h)(2)” for “subsection (e)(2)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id83c1cbe1-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id83c1cbe2-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Oversight and Government Reform of House of Representatives changed to Committee on Oversight and Reform of House of Representatives by House Resolution No. 6, One Hundred Sixteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":". Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, "},{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id83c1cbe3-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s820/d"},"text":"Pub. L. 114–328, div. A, title VIII, § 820(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2276"},"text":"130 Stat. 2276","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/328/dA/tVIII/s820/d"},"text":"“The amendments made by this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s190"},"text":"section 190 of Title 10","children":[],"tail":", Armed Forces, and amending this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s1502"},"text":"section 1502 of this title","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"2018-10-01"},"text":"October 1, 2018","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id83c1cbe4-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVIII/s1806/b/7"},"text":"Pub. L. 119–60, div. A, title XVIII, § 1806(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1239"},"text":"139 Stat. 1239","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tXVIII/s1806/b/7"},"text":"“Not later than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"], the Director of the Office of Management and Budget, the Secretary of Defense, and the Administrator of General Services shall implement the amendments made by this subsection [amending this section], including making the appointments under "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s1501/b"},"text":"section 1501(b) of title 41","children":[],"tail":", United States Code, as amended by this subsection .”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id83c1cbe5-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Cooperation With the Comptroller General","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVIII/s1806/c"},"text":"Pub. L. 119–60, div. A, title XVIII, § 1806(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1239"},"text":"139 Stat. 1239","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tXVIII/s1806/c"},"text":"“The Secretary of Defense and the Cost Accounting Standards Board established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1501"},"text":"section 1501 of title 41","children":[],"tail":", United States Code (as amended by this section), shall cooperate in full and in a timely manner with the Comptroller General of the United States, including providing any analysis, briefings, or other information requested by the Comptroller General related to requirements of this section [amending this section and sections 1502 and 1503 of this title, and enacting provisions set out as notes under this section and sections 1502 and 1503 of this title] and the amendments made by this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
