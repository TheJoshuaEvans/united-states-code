{"tag":"section","attrib":{"id":"id83e33713-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3904"},"text":null,"children":[{"tag":"num","attrib":{"value":"3904"},"text":"§ 3904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract authority for severable services contracts and multiyear contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83e33714-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Comptroller General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Comptroller General may use available funds to enter into contracts for the procurement of severable services for a period that begins in one fiscal year and ends in the next fiscal year and to enter into multiyear contracts for the acquisition of property and nonaudit-related services to the same extent as executive agencies under sections 3902 and 3903 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e33715-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Library of Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Library of Congress may use available funds to enter into contracts for the lease or procurement of severable services for a period that begins in one fiscal year and ends in the next fiscal year and to enter into multiyear contracts for the acquisition of property and services pursuant to sections 3902 and 3903 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e33716-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3904/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chief Administrative Officer of the House of Representatives","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief Administrative Officer of the House of Representatives may enter into—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e33717-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3904/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contracts for the procurement of severable services for a period that begins in one fiscal year and ends in the next fiscal year to the same extent as the head of an executive agency under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3902"},"text":"section 3902 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e33718-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3904/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multiyear contracts for the acquisitions of property and nonaudit-related services to the same extent as executive agencies under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3903"},"text":"section 3903 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e33719-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3904/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional Budget Office","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Congressional Budget Office may use available funds to enter into contracts for the procurement of severable services for a period that begins in one fiscal year and ends in the next fiscal year and may enter into multiyear contracts for the acquisition of property and services to the same extent as executive agencies under the authority of sections 3902 and 3903 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e3371a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3904/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary and Sergeant at Arms and Doorkeeper of the Senate","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to regulations prescribed by the Committee on Rules and Administration of the Senate, the Secretary and the Sergeant at Arms and Doorkeeper of the Senate may enter into—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e3371b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3904/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contracts for the procurement of severable services for a period that begins in one fiscal year and ends in the next fiscal year to the same extent and under the same conditions as the head of an executive agency under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3902"},"text":"section 3902 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e3371c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3904/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multiyear contracts for the acquisition of property and services to the same extent and under the same conditions as executive agencies under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3903"},"text":"section 3903 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e3371d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3904/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Capitol Police","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The United States Capitol Police may enter into—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e3371e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3904/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contracts for the procurement of severable services for a period that begins in one fiscal year and ends in the next fiscal year to the same extent as the head of an executive agency under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3902"},"text":"section 3902 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e3371f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3904/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multiyear contracts for the acquisitions of property and nonaudit-related services to the same extent as executive agencies under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3903"},"text":"section 3903 of this title","children":[],"tail":"."}],"tai