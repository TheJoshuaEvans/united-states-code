{"tag":"section","attrib":{"id":"id83bac795-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1302"},"text":null,"children":[{"tag":"num","attrib":{"value":"1302"},"text":"§ 1302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and membership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83bac796-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is a Federal Acquisition Regulatory Council to assist in the direction and coordination of Government-wide procurement policy and Government-wide procurement regulatory activities in the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83bac797-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83bac798-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1302/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Makeup of council","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council consists of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83bac799-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1302/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bac79a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1302/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bac79b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1302/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of National Aeronautics and Space; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bac79c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1302/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of General Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bac79d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1302/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of other officials.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83bac79e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1302/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officials who may be designated","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding section 121(d)(1) and (2) of title 40, the officials specified in subparagraphs (B) to (D) of paragraph (1) may designate to serve on and attend meetings of the Council in place of that official—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83bac79f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1302/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the official assigned by statute with the responsibility for acquisition policy in each of their respective agencies or, in the case of the Secretary of Defense, an official at an organizational level not lower than an Assistant Secretary of Defense within the Office of the Under Secretary of Defense for Acquisition and Sustainment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83bac7a0-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1302/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if no official of that agency is assigned by statute with the responsibility for acquisition policy for that agency, the official designated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1702/c"},"text":"section 1702(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bac7a1-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1302/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No other official or employee may be designated to serve on the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83bac7a2-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3691"},"text":"124 Stat. 3691","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s902/88"},"text":"Pub. L. 116–92, div. A, title IX, § 902(88)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1554"},"text":"133 Stat. 1554","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83bac7a3-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83bac7a4-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83bac7a5-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1302(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:421(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/93/400/s25/a"},"text":"Pub. L. 93–400, § 25(a)","children":[],"tail":", (b), as added "},{"tag":"html:a","attrib":{"href":"/us/pl/100/679/s4"},"text":"Pub. L. 100–679, § 4","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 17, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/4056"},"text":"102 Stat. 4056","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/101/510/tVIII/s807"},"text":"Pub. L. 101–510, title VIII, § 807","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/1593"},"text":"104 Stat. 1593","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/104/106/tXLIII/s4322/a/2"},"text":"Pub. L. 104–106, title XLIII, § 4322(a)(2)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/677"},"text":"110 Stat. 677","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1302(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:421(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “(hereinafter in this section referred to as the ‘Council’)” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2)(A)(i), the words “Under Secretary of Defense for Acquisition, Technology, and Logistics” are substituted for “Under Secretary of Defense for Acquisition and Technology” because of section 911(a)(1) of the National Defense Authorization Act for Fiscal Year 2000 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Public Law 106–65","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/717"},"text":"113 Stat. 717","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s133"},"text":"10 U.S.C. 133","children":[],"tail":" note)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2)(A)(ii), the cross-reference to section 16(3) of the Office of Federal Procurement Policy Act (41:414(3)) is treated as a cross-reference to section 16(c) of the Act to reflect the amendment of section 16 by section 1421(a)(1) of the National Defense Authorization Act for Fiscal Year 2004 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Public Law 108–136","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1666"},"text":"117 Stat. 1666","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id83bac7a6-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id83bac7a7-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (b)(2)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “Under Secretary of Defense for Acquisition and Sustainment” for “Under Secretary of Defense for Acquisition, Technology, and Logistics”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id83bac7a8-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id83bac7a9-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Status of Director of Defense Procurement","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tVIII/s809"},"text":"Pub. L. 102–190, div. A, title VIII, § 809","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1423"},"text":"105 Stat. 1423","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tIX/s904/f"},"text":"Pub. L. 103–160, div. A, title IX, § 904(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1729"},"text":"107 Stat. 1729","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tIX/s911/a/1"},"text":"Pub. L. 106–65, div. A, title IX, § 911(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/717"},"text":"113 Stat. 717","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/65/dA/tIX/s911/a/1"},"text":"“For the purposes of the amendment made by section 807 of the National Defense Authorization Act for Fiscal Year 1991 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Public Law 101–510","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/104/1593"},"text":"104 Stat. 1593","children":[],"tail":") to section 25(b)(2) of the Office of Federal Procurement Policy Act ([former] "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s421/b/2"},"text":"41 U.S.C. 421(b)(2)","children":[],"tail":") [now "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s1302/b/2"},"text":"41 U.S.C. 1302(b)(2)","children":[],"tail":"], the Director of Defense Procurement of the Department of Defense shall be considered to be an official at an organizational level of an Assistant Secretary of Defense within the Office of the Under Secretary of Defense for Acquisition, Technology, and Logistics.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
