{"tag":"section","attrib":{"id":"id83dc0b37-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3503"},"text":null,"children":[{"tag":"num","attrib":{"value":"3503"},"text":"§ 3503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83dc0b38-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Submission of certified cost or pricing data shall not be required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3502"},"text":"section 3502 of this title","children":[],"tail":" in the case of a contract, a subcontract, or a modification of a contract or subcontract—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83dc0b39-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for which the price agreed on is based on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83dc0b3a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3503/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequate price competition; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83dc0b3b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3503/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prices set by law or regulation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83dc0b3c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the acquisition of a commercial product or a commercial service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83dc0b3d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3503/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an exceptional case when the head of the procuring activity, without delegation, determines that the requirements of this chapter may be waived and justifies in writing the reasons for the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83dc0b3e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Modifications of Contracts and Subcontracts for Commercial Products or Commercial Services","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a modification of a contract or subcontract for a commercial product or a commercial service that is not covered by the exception to the submission of certified cost or pricing data in paragraph (1) or (2) of subsection (a), submission of certified cost or pricing data shall not be required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3502"},"text":"section 3502 of this title","children":[],"tail":" if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83dc0b3f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contract or subcontract being modified is a contract or subcontract for which submission of certified cost or pricing data may not be required by reason of paragraph (1) or (2) of subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83dc0b40-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the modification would not change the contract or subcontract from a contract or subcontract for the acquisition of a commercial product or a commercial service to a contract or subcontract for the acquisition of an item other than a commercial product or a commercial service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83dc0b41-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3766"},"text":"124 Stat. 3766","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s836/b/12"},"text":"Pub. L. 115–232, div. A, title VIII, § 836(b)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1863"},"text":"132 Stat. 1863","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83dc0b42-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83dc0b43-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83dc0b44-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":