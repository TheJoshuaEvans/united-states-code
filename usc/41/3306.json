{},"text":"In subsection (f)(2), the words “Not later than 180 days after the date of the enactment of this Act, the Federal Acquisition Regulatory Council shall amend” are omitted as obsolete.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id83d9c052-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id83d9c053-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s836/b/9"},"text":"Pub. L. 115–232, § 836(b)(9)","children":[],"tail":", substituted “commercial products or commercial services” for “commercial items” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s876/1"},"text":"Pub. L. 115–232, § 876(1)","children":[],"tail":", inserted “except as provided in paragraph (3),” after subpar. designation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s876/2"},"text":"Pub. L. 115–232, § 876(2)","children":[],"tail":", added pars. (3) and (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id83d9c054-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id83d9c055-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag"