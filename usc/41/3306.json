{"tag":"section","attrib":{"id":"id83d7501b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306"},"text":null,"children":[{"tag":"num","attrib":{"value":"3306"},"text":"§ 3306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning and solicitation requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83d7501c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Planning and Specifications.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d7501d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preparing for procurement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In preparing for the procurement of property or services, an executive agency shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d7501e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify its needs and solicit bids or proposals in a manner designed to achieve full and open competition for the procurement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d7501f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use advance procurement planning and market research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d75020-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop specifications in the manner necessary to obtain full and open competition with due regard to the nature of the property or services to be acquired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d75021-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements of specifications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each solicitation under this division shall include specifications that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d75022-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with this division, permit full and open competition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d75023-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include restrictive provisions or conditions only to the extent necessary to satisfy the needs of the executive agency or as authorized by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d75024-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Types of specifications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of paragraphs (1) and (2), the type of specification included in a solicitation shall depend on the nature of the needs of the executive agency and the market available to satisfy those needs. Subject to those needs, specifications may be stated in terms of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d75025-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" function, so that a variety of products or services may qualify;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d75026-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performance, including specifications of the range of acceptable characteristics or of the minimum acceptable standards; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d75027-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" design requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d75028-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of Solicitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the specifications described in subsection (a), each solicitation for sealed bids or competitive proposals (other than for a procurement for commercial products or commercial services using special simplified procedures or a purchase for an amount not greater than the simplified acquisition threshold) shall at a minimum include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d75029-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a statement of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d7502a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all significant factors and significant subfactors that the executive agency reasonably expects to consider in evaluating sealed bids (including price) or competitive proposals (including cost or price, cost-related or price-related factors and subfactors, and noncost-related or nonprice-related factors and subfactors); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d7502b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relative importance assigned to each of those factors and subfactors; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d7502c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d7502d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of sealed bids—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83d7502e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement that sealed bids will be evaluated without discussions with the bidders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83d7502f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time and place for the opening of the sealed bids; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d75030-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of competitive proposals—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83d75031-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" either a statement that the proposals are intended to be evaluated with, and the award made after, discussions with the offerors, or a statement that the proposals are intended to be evaluated, and the award made, without discussions with the offerors (other than discussions conducted for the purpose of minor clarification) unless discussions are determined to be necessary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83d75032-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time and place for submission of proposals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d9c033-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evaluation Factors.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d9c034-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In prescribing the evaluation factors to be included in each solicitation for competitive proposals, an executive agency shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d9c035-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish clearly the relative importance assigned to the evaluation factors and subfactors, including the quality of the product or services to be provided (including technical capability, management capability, prior experience, and past performance of the offeror);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d9c036-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in paragraph (3), include cost or price to the Federal Government as an evaluation factor that must be considered in the evaluation of proposals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d9c037-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" except as provided in paragraph (3), disclose to offerors whether all evaluation factors other than cost or price, when combined, are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83d9c038-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significantly more important than cost or price;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83d9c039-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approximately equal in importance to cost or price; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83d9c03a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significantly less important than cost or price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d9c03b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restriction on implementing regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Regulations implementing paragraph (1)(C) may not define the terms “significantly more important” and “significantly less important” as specific numeric weights that would be applied uniformly to all solicitations or a class of solicitations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d9c03c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions for certain indefinite delivery, indefinite quantity multiple-award contracts and certain federal supply schedule contracts for services acquired on an hourly rate","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an executive agency issues a solicitation for one or more contracts for services to be acquired on an hourly rate basis under the authority of sections 4103 and 4106 of this title or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s152/3"},"text":"section 152(3) of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s501/b"},"text":"section 501(b) of title 40","children":[],"tail":" and the executive agency intends to make a contract award to each qualifying offeror and the contract or contracts will feature individually competed task or delivery orders based on hourly rates—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d9c03d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contracting officer need not consider price as an evaluation factor for contract award; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d9c03e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if, pursuant to subparagraph (A), price is not considered as an evaluation factor for contract award, cost or price to the Federal Government shall be considered in conjunction with the issuance pursuant to sections 4106(c) and 152(3) of this title of any task or delivery order under any contract resulting from the solicitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d9c03f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In paragraph (3), the term “qualifying offeror” means an offeror that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d9c040-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is determined to be a responsible source;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d9c041-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits a proposal that conforms to the requirements of the solicitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d9c042-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets all technical requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d9c043-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is otherwise eligible for award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d9c044-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Information in Solicitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not prohibit an executive agency from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d9c045-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing additional information in a solicitation, including numeric weights for all evaluation factors and subfactors on a case-by-case basis; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d9c046-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stating in a solicitation that award will be made to the offeror that meets the solicitation’s mandatory requirements at the lowest cost or price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d9c047-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Evaluation of Purchase Options","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An executive agency, in issuing a solicitation for a contract to be awarded using sealed bid procedures, may not include in the solicitation a clause providing for the evaluation of prices for options to purchase additional property or services under the contract unless the executive agency has determined that there is a reasonable likelihood that the options will be exercised.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d9c048-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Telecommuting for Federal Contractors.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d9c049-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the term “executive agency” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s133"},"text":"section 133 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d9c04a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal acquisition regulation to allow telecommuting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Acquisition Regulation issued in accordance with sections 1121(b) and 1303(a)(1) of this title shall permit telecommuting by employees of Federal Government contractors in the performance of contracts entered into with executive agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d9c04b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope of allowance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal Acquisition Regulation at a minimum shall provide that a solicitation for the acquisition of property or services may not set forth any requirement or evaluation criteria that would—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d9c04c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" render an offeror ineligible to enter into a contract on the basis of the inclusion of a plan of the offeror to allow the offeror’s employees to telecommute, unless the contracting officer concerned first determines that the requirements of the agency, including security requirements, cannot be met if telecommuting is allowed and documents in writing the basis for the determination; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d9c04d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3306/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce the scoring of an offer on the basis of the inclusion in the offer of a plan of the offeror to allow the offeror’s employees to telecommute, unless the contracting officer concerned first determines that the requirements of the agency, including security requirements, would be adversely impacted if telecommuting is allowed and documents in writing the basis for the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83d9c04e-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3752"},"text":"124 Stat. 3752","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 836(b)(9), 876, "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1861"},"text":"132 Stat. 1861","children":[],"tail":", 1907.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83d9c04f-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83d9c050-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83d9c051-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"