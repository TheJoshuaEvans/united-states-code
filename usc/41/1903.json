{"tag":"section","attrib":{"id":"id83cb6906-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1903"},"text":null,"children":[{"tag":"num","attrib":{"value":"1903"},"text":"§ 1903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special emergency procurement authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83cb6907-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The authorities provided in subsections (b) and (c) apply with respect to a procurement of property or services by or for an executive agency that the head of the executive agency determines are to be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83cb6908-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1903/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in support of a contingency operation (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a"},"text":"section 101(a) of title 10","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cb6909-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1903/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate the defense against or recovery from cyber, nuclear, biological, chemical, or radiological attack against the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cb690a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1903/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in support of a request from the Secretary of State or the Administrator of the United States Agency for International Development to facilitate the provision of international disaster assistance pursuant to chapter 9 of part I of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2292"},"text":"22 U.S.C. 2292","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cb690b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1903/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in support of an emergency or major disaster (as those terms are defined in section 102 of the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5122"},"text":"42 U.S.C. 5122","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83cb690c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Increased Thresholds and Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For a procurement to which this section applies under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83cb690d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the amount specified in section 1902(a), (d), and (e) of this title shall be deemed to be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83cb690e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1903/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $15,000 in the case of a contract to be awarded and performed, or purchase to be made, in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cb690f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1903/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $25,000 in the case of a contract to be awarded and performed, or purchase to be made, outside the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cb6910-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “simplified acquisition threshold” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83cb6911-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1903/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $750,000 in the case of a contract to be awarded and performed, or purchase to be made, in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cb6912-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1903/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,500,000 in the case of a contract to be awarded and performed, or purchase to be made, outside the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cb6913-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1903/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the $5,000,000 limitation in sections 1901(a)(2) and 3305(a)(2) of this title and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3205/a/2"},"text":"section 3205(a)(2) of title 10","children":[],"tail":" is deemed to be $10,000,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83cb6914-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Treat Property or Service as Commercial Product or Commercial Service.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83cb6915-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1903/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an executive agency carrying out a procurement of property or a service to which this section applies under subsection (a)(2) may treat the property or service as a commercial product or a commercial service for the purpose of carrying out the procurement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cb6916-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1903/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain contracts not exempt from standards or requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A contract in an amount of more than $15,000,000 that is awarded on a sole source basis for a product or service treated as a commercial product or a commercial service under paragraph (1) is not exempt from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83cb6917-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1903/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cost accounting standards prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1502"},"text":"section 1502 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cb6918-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1903/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cost or pricing data requirements (commonly referred to as truth in negotiating) under chapter 35 of this title and chapter 271 of title 10.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83cb6919-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3721"},"text":"124 Stat. 3721","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVIII/s816"},"text":"Pub. L. 114–92, div. A, title VIII, § 816","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/897"},"text":"129 Stat. 897","children":[],"tail":"; "},{"tag":"ref",