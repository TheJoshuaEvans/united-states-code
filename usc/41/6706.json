{"tag":"section","attrib":{"id":"id83f18f5d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6706"},"text":null,"children":[{"tag":"num","attrib":{"value":"6706"},"text":"§ 6706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Three-year prohibition on new contracts in case of violation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83f3ff5e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribution of List","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Comptroller General shall distribute to each agency of the Federal Government a list containing the names of persons or firms that a Federal agency or the Secretary has found to have violated this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83f3ff5f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Three-Year Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Unless the Secretary recommends otherwise because of unusual circumstances, a Federal Government contract may not be awarded to a person or firm named on the list under subsection (a), or to an entity in which the person or firm has a substantial interest, until 3 years have elapsed from the date of publication of the list. If the Secretary does not recommend otherwise because of unusual circumstances, the Secretary shall, not later than 90 days after a hearing examiner has made a finding of a violation of this chapter, forward to the Comptroller General the name of the person or firm found to have violated this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83f3ff60-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3814"},"text":"124 Stat. 3814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83f3ff61-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83f3ff62-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83f3ff63-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6706(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:354(a) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/286/s5/a"},"text":"Pub. L. 89–286, § 5(a)","children":[],"tail":" (1st sentence), "},{"tag":"html:span","attrib":{},"text":"Oct. 22, 1965","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/79/1035"},"text":"79 Stat. 1035","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6706(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:354(a) (2d–last sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/286/s5/a"},"text":"Pub. L. 89–286, § 5(a)","children":[],"tail":" (2d–last sentences), "},{"tag":"html:span","attrib":{},"text":"Oct. 22, 1965","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/79/1035"},"text":"79 Stat. 1035","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/92/473/s4"},"text":"Pub. L. 92–473, § 4","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 9, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/790"},"text":"86 Stat. 790","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “entity” is substituted for “firm, corporation, partnership, or association” to use a single broad term clarifying that the prohibition applies to any kind of organization in which the person or firm has a substantial interest. The words “containing the name of such persons or firms” are omitted as unnecessary. The word “person” is substituted for “individual” for consistency in the subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
