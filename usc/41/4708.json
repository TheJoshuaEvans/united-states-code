{"tag":"section","attrib":{"id":"id83ea6242-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4708"},"text":null,"children":[{"tag":"num","attrib":{"value":"4708"},"text":"§ 4708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of reimbursable indirect costs in cost-type research and development contracts with educational institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A cost-type research and development contract (including a grant) with a university, college, or other educational institution may provide for payment of reimbursable indirect costs on the basis of predetermined fixed-percentage rates applied to the total of the reimbursable direct costs incurred or to an element of the total of the reimbursable direct costs incurred.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id83ea6243-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3799"},"text":"124 Stat. 3799","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83ea6244-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83ea6245-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83ea6246-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","childr