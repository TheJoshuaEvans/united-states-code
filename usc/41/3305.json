{"tag":"section","attrib":{"id":"id83d7500b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3305"},"text":null,"children":[{"tag":"num","attrib":{"value":"3305"},"text":"§ 3305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Simplified procedures for small purchases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83d7500c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To promote efficiency and economy in contracting and to avoid unnecessary burdens for agencies and contractors, the Federal Acquisition Regulation shall provide for special simplified procedures for purchases of property and services for amounts—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d7500d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3305/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not greater than the simplified acquisition threshold; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d7500e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3305/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" greater than the simplified acquisition threshold but not greater than $5,000,000 for which the contracting officer reasonably expects, based on the nature of the property or services sought and on market research, that offers will include only commercial products or commercial services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d7500f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Leasehold Interests in Real Property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of General Services shall prescribe regulations that provide special simplified procedures for acquisitions of leasehold interests in real property at rental rates that do not exceed the simplified acquisition threshold. The rental rate under a multiyear lease does not exceed the simplified acquisition threshold if the average annual amount of the rent payable for the period of the lease does not exceed the simplified acquisition threshold.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d75010-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Dividing Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A proposed purchase or contract for an amount above the simplified acquisition threshold may not be divided into several purchases or contracts for lesser amounts to use the simplified procedures required by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d75011-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3305/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Promotion of Competition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In using the simplified procedures, an executive agency shall promote competition to the maximum extent practicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d75012-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3305/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance With Special Requirements of Federal Acquisition Regulation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An executive agency shall comply with the Federal Acquisition Regulation provisions referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1901/e"},"text":"section 1901(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83d75013-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3752"},"text":"124 Stat. 3752","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s836/b/8"},"text":"Pub. L. 115–232, div. A, title VIII, § 836(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1861"},"text":"132 Stat. 1861","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83d75014-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83d75015-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83d75016-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"