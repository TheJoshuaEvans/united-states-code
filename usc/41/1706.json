{"tag":"section","attrib":{"id":"id83c6ae15-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1706"},"text":null,"children":[{"tag":"num","attrib":{"value":"1706"},"text":"§ 1706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel evaluation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The head of each executive agency subject to division C shall ensure, with respect to the employees of that agency whose primary duties and responsibilities pertain to the award of contracts subject to the provisions of the Small Business and Federal Procurement Competition Enhancement Act of 1984 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/577"},"text":"Public Law 98–577","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3066"},"text":"98 Stat. 3066","children":[],"tail":"), that the performance appraisal system applicable to those employees affords appropriate recognition to, among other factors, efforts to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83c6ae16-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1706/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase competition and achieve cost savings through the elimination of procedures that unnecessarily inhibit full and open competition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6ae17-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1706/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" further the purposes of the Small Business and Federal Procurement Competition Enhancement Act of 1984 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/577"},"text":"Public Law 98–577","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3066"},"text":"98 Stat. 3066","children":[],"tail":") and the Defense Procurement Reform Act of 1984 ("},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXII"},"text":"Public Law 98–525, title XII","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2588"},"text":"98 Stat. 2588","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6ae18-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1706/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" further other objectives and purposes of the Federal acquisition system authorized by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83c6ae19-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3710"},"text":"124 Stat. 3710","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83c6ae1a-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83c6ae1b-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83c6ae1c-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":