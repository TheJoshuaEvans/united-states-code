{"tag":"section","attrib":{"id":"id83f6495e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8103"},"text":null,"children":[{"tag":"num","attrib":{"value":"8103"},"text":"§ 8103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drug-free workplace requirements for Federal grant recipients","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83f6495f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83f64960-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Persons other than individuals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person other than an individual shall not receive a grant from a Federal agency unless the person agrees to provide a drug-free workplace by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83f64961-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8103/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publishing a statement notifying employees that the unlawful manufacture, distribution, dispensation, possession, or use of a controlled substance is prohibited in the grantee’s workplace and specifying the actions that will be taken against employees for violations of the prohibition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83f64962-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8103/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establishing a drug-free awareness program to inform employees about—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83f64963-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8103/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dangers of drug abuse in the workplace;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83f64964-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8103/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grantee’s policy of maintaining a drug-free workplace;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83f64965-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8103/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" available drug counseling, rehabilitation, and employee assistance programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83f64966-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8103/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the penalties that may be imposed on employees for drug abuse violations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83f64967-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8103/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making it a requirement that each employee to be engaged in the performance of the grant be given a copy of the statement required by subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83f64968-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8103/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" notifying the employee in the statement required by subparagraph (A) that as a condition of employment in the grant the employee will—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83f64969-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8103/a/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" abide by the terms of the statement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83f6496a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8103/a/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the employer of any criminal drug statute conviction for a violation occurring in the workplace no later than 5 days after the conviction;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83f6496b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8103/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notifying the granting agency within 10 days after receiving notice under subparagraph (D)(ii) from an employee or otherwise receiving actual notice of a conviction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83f6496c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8103/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imposing a sanction on, or requiring the satisfactory participation in a drug abuse assistance or rehabilitation program by, any employee who is convicted, as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s8104"},"text":"section 8104 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83f6496d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8103/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making a good faith effort to continue to maintain a drug-free workplace through implementation of subparagraphs (A) to (F).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f6496e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Individuals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Federal agency shall not make a grant to an individual unless the individual agrees not to engage in the unlawful manufacture, distribution, dispensation, possession, or use of a controlled substance in conducting an activity with the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83f6496f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Suspension, Termination, or Debarment of Grantee.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83f64970-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grounds for suspension, termination, or debarment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Payment under a grant awarded by a Federal agency may be suspended and the grant may be terminated, and the grantee may be suspended or debarred, in accordance with the requirements of this section, if the head of the agency or the official designee of the head of the agency determines in writing that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83f64971-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8103/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grantee is violating, or has violated, the requirements of subparagraph (A), (B), (C), (D), (E), (F), or (G) of subsection (a)(1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83f64972-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8103/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of employees of the grantee who have been convicted of violations of criminal drug statutes for violations occurring in the workplace indicates that the grantee has failed to make a good faith effort to provide a drug-free workplace as required by subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f64973-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conduct of suspension, termination, and debarment proceedings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A suspension of payments, termination, or suspension or debarment proceeding subject to this subsection shall be conducted in accordance with applicable law, including Executive Order 12549 or any superseding executive order and any regulations prescribed to implement the law or executive order.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f64974-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8103/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of debarment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A grantee debarred by a final decision under this subsection is ineligible for award of a grant by a Federal agency, and for participation in a future grant by a Federal agency, for a period specified in the decision, not to exceed 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83f64975-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3828"},"text":"124 Stat. 3828","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83f64976-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83f64977-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83f64978-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8103","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:702.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/100/690/tV/s5153"},"text":"Pub. L. 100–690, title V, § 5153","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/4306"},"text":"102 Stat. 4306","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/105/85/dA/tVIII/s809"},"text":"Pub. L. 105–85, div. A, title VIII, § 809","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/111/1838"},"text":"111 Stat. 1838","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
