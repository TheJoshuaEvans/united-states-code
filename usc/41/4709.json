{"tag":"section","attrib":{"id":"id83ea6247-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4709"},"text":null,"children":[{"tag":"num","attrib":{"value":"4709"},"text":"§ 4709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of electronic commerce capability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83ea6248-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Role of Head of Executive Agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of each executive agency shall implement the electronic commerce capability required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s2301"},"text":"section 2301 of this title","children":[],"tail":". In implementing the capability, the head of an executive agency shall consult with the Administrator."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83ea6249-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4709/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Manager","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of each executive agency shall designate a program manager to implement the electronic commerce capability for the agency. The program manager reports directly to an official at a level not lower than the senior procurement executive designated for the agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1702/c"},"text":"section 1702(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83ea624a-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3800"},"text":"124 Stat. 3800","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83ea624b-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83ea624c-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83ea624d-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"