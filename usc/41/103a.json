{"tag":"section","attrib":{"id":"id83b39b03-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s103a"},"text":null,"children":[{"tag":"num","attrib":{"value":"103a"},"text":"§ 103a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial service","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subtitle, the term “commercial service” means any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83b39b04-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s103a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Installation services, maintenance services, repair services, training services, and other services if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83b39b05-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s103a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those services are procured for support of a commercial product, regardless of whether the services are provided by the same source or at the same time as the commercial product; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83b39b06-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s103a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the source of the services provides similar services contemporaneously to the general public under terms and conditions similar to those offered to the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83b39b07-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s103a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Services of a type offered and sold competitively, in substantial quantities, in the commercial marketplace—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83b39b08-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s103a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" based on established catalog or market prices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83b39b09-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s103a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for specific tasks performed or specific outcomes to be achieved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83b39b0a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s103a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under standard commercial terms and conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83b39b0b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s103a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A service described in paragraph (1) or (2), even though the service is transferred between or among separate divisions, subsidiaries, or affiliates of a contractor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83b39b0c-3a70-11f1-ab1a-a784e0a454e2"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s836/a/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 836(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1860"},"text":"132 Stat. 1860","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83b39b0d-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id83b39b0e-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id83b39b0f-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2020-01-01"},"text":"Jan. 1, 2020","children":[],"tail":", subject to a savings provision, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s836/h"},"text":"section 836(h) of Pub. L. 115–232","children":[],"tail":", set out as an Effective Date of 2018 Amendment; Savings Provision note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s453b"},"text":"section 453b of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
