{"tag":"section","attrib":{"id":"id83c1cc28-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1504"},"text":null,"children":[{"tag":"num","attrib":{"value":"1504"},"text":"§ 1504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other standards and regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83c1cc29-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Previously Existing Standards","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"All cost accounting standards, waivers, exemptions, interpretations, modifications, rules, and regulations prescribed by the Cost Accounting Standards Board under section 719 of the Defense Production Act of 1950 (50 U.S.C. App. 2168)— ","children":[{"tag":"ref","attrib":{"idref":"fn002004"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002004"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83c1cc2a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1504/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain in effect until amended, superseded, or rescinded by the Board under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c1cc2b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1504/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are subject to the provisions of this division in the same manner as if prescribed by the Board under this division.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c1cc2c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inconsistent Agency Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To ensure that a regulation or proposed regulation of an executive agency is not inconsistent with a cost accounting standard prescribed or amended under this chapter, the Administrator, under the authority in sections 1121, 1122(a) to (c)(1), 1125, 1126, 1130, 1131, and 2305 of this title, shall rescind or deny the promulgation of the inconsistent regulation or proposed regulation and take other appropriate action authorized under sections 1121, 1122(a) to (c)(1), 1125, 1126, 1130, 1131, and 2305.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c1cc2d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Costs Not Subject to Different Standards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Costs that are the subject of cost accounting standards prescribed under this chapter are not subject to regulations established by another executive agency that differ from those standards with respect to the measurement, assignment, and allocation of those costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83c1cc2e-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3699"},"text":"124 Stat. 3699","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83c1cc2f-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83c1cc30-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83c1cc31-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail