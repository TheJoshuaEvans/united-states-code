],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/95/563/s8/e"},"text":"Pub. L. 95–563, § 8(e)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/2386"},"text":"92 Stat. 2386","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “administrative law judges” are substituted for “hearing examiners” because of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/251/s3"},"text":"section 3 of Public Law 95–251","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3105"},"text":"5 U.S.C. 3105","children":[],"tail":" note). The words “Full-time members of agency boards serving as such on the effective date of this chapter shall be considered qualified” are omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the text of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s438"},"text":"41 U.S.C. 438","children":[],"tail":" (b)(1)(C) is omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e)(1)(B) and (C), the words “Postal Regulatory Commission” are substituted for “Postal Rate Commission” because of section 604(f) of the Postal Accountability and Enhancement Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435"},"text":"Public Law 109–435","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3242"},"text":"120 Stat. 3242","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s404"},"text":"39 U.S.C. 404","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id83f3fffa-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id83f3fffb-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 8 of the Contract Disputes Act, referred to in subsec. (b)(4)(B)(i), probably means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/563/s8"},"text":"section 8 of Pub. L. 95–563","children":[],"tail":", the Contract Disputes Act of 1978, which was classified to former "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s607"},"text":"section 607 of this title","children":[],"tail":" prior to being repealed and reenacted as subsecs. (a), (c) to (e), and (g) of this section by "},{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":", §§ 3, 7(b), "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3677"},"text":"124 Stat. 3677","children":[],"tail":", 3855."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Administrative False Claims Act, referred to in subsec. (e)(1)(E), is subtitle B of title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509"},"text":"Pub. L. 99–509","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1934"},"text":"100 Stat. 1934","children":[],"tail":", which is classified generally to chapter 38 (§ 3801 et seq.) of Title 31, Money and Finance. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3801"},"text":"section 3801 of Title 31","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id83f3fffc-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (e)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s5203/g/2/A"},"text":"Pub. L. 118–159, § 5203(g)(2)(A)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s5203/g/2/B"},"text":"Pub. L. 118–159, § 5203(g)(2)(B)","children":[],"tail":", inserted before period at end “or, in the event that a case is filed under chapter 38 of title 31, any relief that would be available to a litigant under that chapter”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
