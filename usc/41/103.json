{"tag":"section","attrib":{"id":"id83b129ee-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s103"},"text":null,"children":[{"tag":"num","attrib":{"value":"103"},"text":"§ 103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial product","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subtitle, the term “commercial product” means any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83b129ef-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s103/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A product, other than real property, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83b129f0-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s103/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is of a type customarily used by the general public or by nongovernmental entities for purposes other than governmental purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83b129f1-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s103/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been sold, leased, or licensed, or offered for sale, lease, or license, to the general public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83b129f2-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s103/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A product that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83b129f3-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s103/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evolved from a product described in paragraph (1) through advances in technology or performance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83b129f4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s103/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not yet available in the commercial marketplace but will be available in the commercial marketplace in time to satisfy the delivery requirements under a Federal Government solicitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83b129f5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s103/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A product that would satisfy the criteria in paragraph (1) or (2) were it not for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83b129f6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s103/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modifications of a type customarily available in the commercial marketplace; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83b129f7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s103/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minor modifications made to meet Federal Government requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83b129f8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s103/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any combination of products meeting the requirements of paragraph (1), (2), or (3) that are of a type customarily combined and sold in combination to the general public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83b129f9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s103/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A product, or combination of products, referred to in paragraphs (1) through (4), even though the product, or combination of products, is transferred between or among separate divisions, subsidiaries, or affiliates of a contractor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83b129fa-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s103/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A nondevelopmental item if the procuring agency determines, in accordance with conditions in the Federal Acquisition Regulation, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83b39afb-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s103/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the product was developed exclusively at private expense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83b39afc-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s103/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been sold in substantial quantities, on a competitive basis, to multiple State and local governments or to multiple foreign governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83b39afd-3a70-11f1-ab1a-a784e0a454e2"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s836/a/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 836(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1859"},"text":"132 Stat. 1859","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83b39afe-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id83b39aff-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id83b39b00-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 103, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3679"},"text":"124 Stat. 3679","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVIII/s847/a"},"text":"Pub. L. 115–91, div. A, title VIII, § 847(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1487"},"text":"131 Stat. 1487","children":[],"tail":", defined term “commercial item”, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s836/a/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 836(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1859"},"text":"132 Stat. 1859","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2020-01-01"},"text":"Jan. 1, 2020","children":[],"tail":". See Effective Date note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id83b39b01-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id83b39b02-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective, and repeal of former section 103 effective, on ","children":[{"tag":"date","attrib":{"date":"2020-01-01"},"text":"Jan. 1, 2020","children":[],"tail":", subject to a savings provision, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s836/h"},"text":"section 836(h) of Pub. L. 115–232","children":[],"tail":", set out as an Effective Date of 2018 Amendment; Savings Provision note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s453b"},"text":"section 453b of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
