{"tag":"section","attrib":{"id":"id83b85609-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1124"},"text":null,"children":[{"tag":"num","attrib":{"value":"1124"},"text":"§ 1124.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tests of innovative procurement methods and procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83b8560a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1124/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may develop innovative procurement methods and procedures to be tested by selected executive agencies. In developing a program to test innovative procurement methods and procedures under this subsection, the Administrator shall consult with the heads of executive agencies to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83b8560b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1124/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ascertain the need for and specify the objectives of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83b8560c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1124/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop the guidelines and procedures for carrying out the program and the criteria to be used in measuring the success of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83b8560d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1124/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the potential costs and benefits which may be derived from the innovative procurement methods and procedures tested under the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83b8560e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1124/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select the appropriate executive agencies or components of executive agencies to carry out the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83b8560f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1124/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the categories and types of products or services to be procured under the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83b85610-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1124/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop the methods to be used to analyze the results of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83b85611-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1124/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval of Executive Agencies Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A program to test innovative procurement methods and procedures may not be carried out unless approved by the heads of the executive agencies selected to carry out the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83b85612-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1124/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Request for Waiver of Law","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Administrator determines that it is necessary to waive the application of a provision of law to carry out a proposed program to test innovative procurement methods and procedures under subsection (a), the Administrator shall transmit notice of the proposed program to the Committee on Oversight and Government Reform of the House of Representatives and the Committee on Homeland Security and Governmental Affairs of the Senate and request that the Committees take the necessary action to provide that the provision of law does not apply with respect to the proposed program. The notification to Congress shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83b85613-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1124/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the proposed program (including the scope and purpose of the proposed program);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83b85614-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1124/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procedures to be followed in carrying out the proposed program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83b85615-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1124/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of law affected and the application of any provision of law that must be waived in order to carry out the proposed program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83b85616-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1124/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the executive agencies involved in carrying out the proposed program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83b85617-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3688"},"text":"124 Stat. 3688","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83b85618-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83b85619-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83b8561a-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1124(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:413(a) (1st, 2d sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/93/400/s15"},"text":"Pub. L. 93–400, § 15","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/98/191/s7"},"text":"Pub. L. 98–191, § 7","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 1, 1983","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/97/1329"},"text":"97 Stat. 1329","children":[],"tail":"; "},{"tag":"html:a","attrib