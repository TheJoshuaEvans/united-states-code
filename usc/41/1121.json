],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/97/1327"},"text":"97 Stat. 1327","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the text of 41:405a (1st sentence relating to promulgating a single, simplified, uniform Federal procurement regulation) is omitted as superseded by 41:405(a) because of section 11 of the Office of Federal Procurement Policy Act Amendments of 1979 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/83"},"text":"Public Law 96–83","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/652"},"text":"93 Stat. 652","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id83b855d4-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id83b855d5-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Supersedure of Inconsistent Statutory Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/83/s11"},"text":"Pub. L. 96–83, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-10"},"text":"Oct. 10, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/652"},"text":"93 Stat. 652","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/83/s11"},"text":"“The provisions of the Act [","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/400"},"text":"Pub. L. 93–400","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-30"},"text":"Aug. 30, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/796"},"text":"88 Stat. 796","children":[],"tail":", see this division (except sections 1123, 2303, 2304, and 2313)] as amended by this Act [see Short Title of 1979 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s101"},"text":"section 101 of this title","children":[],"tail":"] shall supersede the provisions of "},{"tag":"ref","attrib":{"href":"/us/act/1978-10-24/s222"},"text":"section 222 of the Act of October 24, 1978","children":[],"tail":", entitled ‘An Act to amend the Small Business Act and the Small Business Investment Act of 1958’ ([former] "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s405a"},"text":"41 U.S.C. 405a","children":[],"tail":") [now "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s1121/c/2"},"text":"41 U.S.C. 1121(c)(2)","children":[],"tail":", 1123] to the extent they are inconsistent therewith.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id83b855d6-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Federal Support for Enhancement of State and Local Anti-Terrorism Response Capabilities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tVIII/s803"},"text":"Pub. L. 108–136, div. A, title VIII, § 803","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1541"},"text":"117 Stat. 1541","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/136/dA/tVIII/s803"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procurements of Anti-Terrorism Technologies and Services by State and Local Governments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator for Federal Procurement Policy shall establish a program under which States and units of local government may procure through contracts entered into by the Department of Defense or the Department of Homeland Security anti-terrorism technologies or anti-terrorism services for the purpose of preventing, detecting, identifying, deterring, or recovering from acts of terrorism.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under the program, the Secretary of Defense and the Secretary of Homeland Security may, but shall not be required to, award contracts using the procedures established by the Administrator of General Services for the multiple awards schedule program of the General Services Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘State or local government’ has the meaning provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s502/c/3"},"text":"section 502(c)(3) of title 40","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id83b855d7-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Profit Methodology Study","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/679/s7"},"text":"Pub. L. 100–679, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-17"},"text":"Nov. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4068"},"text":"102 Stat. 4068","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/679/s7"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall conduct a study to develop a consistent methodology which executive agencies should use for measuring the profits earned by government contractors on procurements, other than procurements where the price is based on adequate price competition or on established catalog or market prices of commercial items sold in substantial quantities to the general public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contractors’ Financial Data","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The methodology developed under subsection (a) shall include adequate procedures for verifying and maintaining the confidentiality of contractors’ financial data.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
