":"html:a","attrib":{"href":"/us/pl/100/679/s3/a/2"},"text":"Pub. L. 100–679, § 3(a)(2)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 17, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/4055"},"text":"102 Stat. 4055","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/104/106/tXLIII/s4322/a/1"},"text":"Pub. L. 104–106, title XLIII, § 4322(a)(1)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/677"},"text":"110 Stat. 677","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1121(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:405(f).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/93/400/s6/f"},"text":"Pub. L. 93–400, § 6(f)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 30, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/797"},"text":"88 Stat. 797","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/96/83/s4"},"text":"Pub. L. 96–83, § 4","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 10, 1979","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/93/649"},"text":"93 Stat. 649","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/98/191/s5"},"text":"Pub. L. 98–191, § 5","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 1, 1983","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/9