{"tag":"section","attrib":{"id":"id83bd10e1-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1312"},"text":null,"children":[{"tag":"num","attrib":{"value":"1312"},"text":"§ 1312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83bd10e2-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Principal Forum","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief Acquisition Officers Council is the principal interagency forum for monitoring and improving the Federal acquisition system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83bd10e3-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall perform functions that include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83bd10e4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1312/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Develop recommendations for the Director of the Office of Management and Budget on Federal acquisition policies and requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bd10e5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1312/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Share experiences, ideas, best practices, and innovative approaches related to Federal acquisition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bd10e6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1312/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assist the Administrator in the identification, development, and coordination of multiagency projects and other innovative initiatives to improve Federal acquisition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bd10e7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1312/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promote effective business practices that ensure the timely delivery of best value products to the Federal Government and achieve appropriate public policy objectives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bd10e8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1312/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Further integrity, fairness, competition, openness, and efficiency in the Federal acquisition system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bd10e9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1312/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Work with the Office of Personnel Management to assess and address the hiring, training, and professional development needs of the Federal Government related to acquisition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bd10ea-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1312/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Work with the Administrator and the Federal Acquisition Regulatory Council to promote the business practices referred to in paragraph (4) and other results of the functions carried out under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83bd10eb-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3694"},"text":"124 Stat. 3694","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83bd10ec-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83bd10ed-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83bd10ee-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p",