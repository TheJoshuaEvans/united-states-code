{"tag":"section","attrib":{"id":"id83e33764-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4103"},"text":null,"children":[{"tag":"num","attrib":{"value":"4103"},"text":"§ 4103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83e33765-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Award","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the requirements of this section, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s4106"},"text":"section 4106 of this title","children":[],"tail":", and other applicable law, the head of an executive agency may enter into a task or delivery order contract for procurement of services or property."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e33766-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Solicitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The solicitation for a task or delivery order contract shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e33767-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period of the contract, including the number of options to extend the contract and the period for which the contract may be extended under each option;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e33768-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maximum quantity or dollar value of the services or property to be procured under the contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e33769-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4103/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of work, specifications, or other description that reasonably describes the general scope, nature, complexity, and purposes of the services or property to be procured under the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e3376a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Restriction on Use of Noncompetitive Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an executive agency may use procedures other than competitive procedures to enter into a task or delivery order contract under this section only if an exception in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3304/a"},"text":"section 3304(a) of this title","children":[],"tail":" applies to the contract and the use of those procedures is approved in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s3304/e"},"text":"section 3304(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e3376b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Single and Multiple Contract Awards.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e3376c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4103/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exercise of authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of an executive agency may exercise the authority provided in this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83e3376d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4103/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to award a single task or delivery order contract; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83e3376e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4103/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the solicitation states that the head of the executive agency has the option to do so, to award separate task or delivery order contracts for the same or similar services or property to 2 or more sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e3376f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4103/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination not required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No determination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3303"},"text":"section 3303 of this title","children":[],"tail":" is required for an award of multiple task or delivery order contracts under paragraph (1)(B)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e33770-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4103/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Single source award for task or delivery order contracts exceeding $100,000,000.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83e33771-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4103/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"When single awards are allowed","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No task or delivery order contract in an amount estimated to exceed $100,000,000 (including all options) may be awarded to a single source unless the head of the executive agency determines in writing that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83e33772-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4103/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the task or delivery orders expected under the contract are so integrally related that only a single source can reasonably perform the work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83e33773-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4103/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the contract provides only for firm, fixed price task orders or delivery orders for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id83e33774-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4103/d/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" products for which unit prices are established in the contract; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id83e33775-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4103/d/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services for which prices are established in the contract for the specific tasks to be performed;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83e33776-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4103/d/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only one source is qualified and capable of performing the work at a reasonable price to the Federal Government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83e33777-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4103/d/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because of exceptional circumstances, it is necessary in the public interest to award the contract to a single source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83e33778-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4103/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of the executive agency shall notify Congress within 30 days after any determination under subparagraph (A)(iv).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e33779-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4103/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Regulations implementing this subsection shall establish—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83e3377a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4103/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a preference for awarding, to the maximum extent practicable, multiple task or delivery order contracts for the same or similar services or property under paragraph (1)(B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83e3377b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4103/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" criteria for determining when award of multiple task or delivery order contracts would not be in the best interest of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e3377c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4103/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract Modifications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A task or delivery order may not increase the scope, period, or maximum value of the task or delivery order contract under which the order is issued. The scope, period, or maximum value of the contract may be increased only by modification of the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e3377d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4103/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability to Contracts for Advisory and Assistance Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise specifically provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s4105"},"text":"section 4105 of this title","children":[],"tail":", this section does not apply to a task or delivery order contract for the acquisition of advisory and assistance services (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/g"},"text":"section 1105(g) of title 31","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e3377e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4103/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Contracting Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section may be construed to limit or expand any authority of the head of an executive agency or the Administrator of General Services to enter into schedule, multiple award, or task or delivery order contracts under any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83e3377f-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3778"},"text":"124 Stat. 3778","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83e33780-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83e33781-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83e33782-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4103","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:253h.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title III, § 303H, as added "},{"tag":"html:a","attrib":{"href":"/us/pl/103/355/tI/s1054/a"},"text":"Pub. L. 103–355, title I, § 1054(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/108/3261"},"text":"108 Stat. 3261","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/110/181/tVIII/s843/b/1"},"text":"Pub. L. 110–181, title VIII, § 843(b)(1)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/122/238"},"text":"122 Stat. 238","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “(as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s253k"},"text":"section 253k of this title","children":[],"tail":")” are omitted as unnecessary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
