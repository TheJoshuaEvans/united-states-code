{"tag":"section","attrib":{"id":"id83ef1d9a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6310"},"text":null,"children":[{"tag":"num","attrib":{"value":"6310"},"text":"§ 6310.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for agencies to buy domestically made United States flags","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83ef1d9b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6310/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsections (b) through (d), funds appropriated or otherwise available to an agency may not be used for the procurement of any flag of the United States, unless such flag has been 100 percent manufactured in the United States from articles, materials, or supplies that have been grown or 100 percent produced or manufactured in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83ef1d9c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6310/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) does not apply to the extent that the head of the agency concerned determines that satisfactory quality and sufficient quantity of a flag described in such subsection cannot be procured as and when needed at United States market prices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83ef1d9d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6310/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for Certain Procurements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) does not apply to the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83ef1d9e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6310/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Procurements by vessels in foreign waters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83ef1d9f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6310/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Procurements for resale purposes in any military commissary, military exchange, or nonappropriated fund instrumentality operated by an agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83ef1da0-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6310/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Procurements for amounts less than the simplified acquisition threshold.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83ef1da1-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6310/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Presidential Waiver.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83ef1da2-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6310/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President may waive the requirement in subsection (a) if the President determines a waiver is necessary to comply with any trade agreement to which the United States is a party.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83ef1da3-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6310/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice of waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after granting a waiver under paragraph (1), the President shall publish a notice of the waiver in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83ef1da4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6310/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83ef1da5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6310/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “agency” has the meaning given the term “executive agency” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s102"},"text":"section 102 of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83ef1da6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6310/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Simplified acquisition threshold","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “simplified acquisition threshold” has the meaning given that term in section 134.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83ef1da7-3a70-11f1-ab1a-a784e0a454e2"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/74/s2/a/1"},"text":"Pub. L. 118–74, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-07-30"},"text":"July 30, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1505"},"text":"138 Stat. 1505","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83ef1da8-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id83ef1da9-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id83ef1daa-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/74/s2/b"},"text":"Pub. L. 118–74, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-07-30"},"text":"July 30, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1506"},"text":"138 Stat. 1506","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/74/s2/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6310"},"text":"Section 6310 of title 41","children":[],"tail":", United States Code, as added by subsection (a)(1), shall apply with respect to any contract entered into on or after the date that is 180 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2024-07-30"},"text":"July 30, 2024","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
