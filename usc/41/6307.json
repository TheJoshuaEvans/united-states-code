{"tag":"section","attrib":{"id":"id83ef1d81-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6307"},"text":null,"children":[{"tag":"num","attrib":{"value":"6307"},"text":"§ 6307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts with Federal Government-owned establishments and availability of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An order or contract placed with a Federal Government-owned establishment for work, material, or the manufacture of material pertaining to an approved project is deemed to be an obligation in the same manner that a similar order or contract placed with a commercial manufacturer or private contractor is an obligation. Appropriations remain available to pay an obligation to a Federal Government-owned establishment just as appropriations remain available to pay an obligation to a commercial manufacturer or private contractor.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id83ef1d82-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3806"},"text":"124 Stat. 3806","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83ef1d83-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83ef1d84-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83ef1d85-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"t