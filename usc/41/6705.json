":[{"tag":"html:span","attrib":{},"text":"6705(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:352(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “to other actions in accordance with this section” are added for clarity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
