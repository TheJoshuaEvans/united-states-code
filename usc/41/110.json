{"tag":"section","attrib":{"id":"id83b39b3f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s110"},"text":null,"children":[{"tag":"num","attrib":{"value":"110"},"text":"§ 110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondevelopmental item","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subtitle, the term “nondevelopmental item” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83b39b40-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s110/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a commercial product;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83b39b41-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s110/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a previously developed item of supply that is in use by a department or agency of the Federal Government, a State or local government, or a foreign government with which the United States has a mutual defense cooperation agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83b39b42-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s110/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an item of supply described in paragraph (1) or (2) that requires only minor modification or modification of the type customarily available in the commercial marketplace to meet the requirements of the procuring department or agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83b39b43-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s110/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":