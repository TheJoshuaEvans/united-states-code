{"tag":"section","attrib":{"id":"id83cb6937-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1905"},"text":null,"children":[{"tag":"num","attrib":{"value":"1905"},"text":"§ 1905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" List of laws inapplicable to contracts or subcontracts not greater than simplified acquisition threshold","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83cb6938-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “Council” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83cb6939-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusion in Federal Acquisition Regulation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83cb693a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1905/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Acquisition Regulation shall include a list of provisions of law that are inapplicable to contracts or subcontracts in amounts not greater than the simplified acquisition threshold. A provision of law properly included on the list pursuant to paragraph (2) does not apply to contracts or subcontracts in amounts not greater than the simplified acquisition threshold that are made by an executive agency. This section does not render a provision of law not included on the list inapplicable to contracts and subcontracts in amounts not greater than the simplified acquisition threshold.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cb693b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1905/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Laws enacted after ","children":[{"tag":"date","attrib":{"date":"1994-10-13"},"text":"october 13, 1994","children":[],"tail":null}],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A provision of law described in subsection (c) that is enacted after ","children":[{"tag":"date","attrib":{"date":"1994-10-13"},"text":"October 13, 1994","children":[],"tail":", shall be included on the list of inapplicable provisions of laws required by paragraph (1) unless the Council makes a written determination that it would not be in the best interest of the Federal Government to exempt contracts or subcontracts in amounts not greater than the simplified acquisition threshold from the applicability of the provision."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83cb693c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1905/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Law","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A provision of law referred to in subsection (b)(2) is a provision of law that the Council determines sets forth policies, procedures, requirements, or restrictions for the procurement of property or services by the Federal Government, except for a provision of law that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83cb693d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1905/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for criminal or civil penalties; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cb693e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1905/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifically refers to this section and provides that, notwithstanding this section, it shall be applicable to contracts or subcontracts in amounts not greater than the simplified acquisition threshold.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83cb693f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1905/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Petition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person may petition the Administrator to take appropriate action when a provision of law described in subsection (c) is not included on the list of inapplicable provisions of law as required by subsection (b) and the Council has not made a written determination pursuant to subsection (b)(2). The Administrator shall revise the Federal Acquisition Regulation to include the provision on the list of inapplicable provisions of law unless the Council makes a determination pursuant to subsection (b)(2) within 60 days after the petition is received.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83cb6940-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3722"},"text":"124 Stat. 3722","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83cb6941-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83cb6942-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83cb6943-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1905(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"no source.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1905(b)–(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:429.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/93/400/s33"},"text":"Pub. L. 93–400, § 33","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/103/355/tIV/s4101"},"text":"Pub. L. 103–355, title IV, § 4101","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/108/3339"},"text":"108 Stat. 3339","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
