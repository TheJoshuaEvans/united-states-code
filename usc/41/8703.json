{"tag":"section","attrib":{"id":"id83ffe668-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8703"},"text":null,"children":[{"tag":"num","attrib":{"value":"8703"},"text":"§ 8703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contractor responsibilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83ffe669-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements Included in Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each contracting agency shall include in each prime contract awarded by the agency a requirement that the prime contractor shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83ffe66a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8703/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have in place and follow reasonable procedures designed to prevent and detect violations of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s8702"},"text":"section 8702 of this title","children":[],"tail":" in its own operations and direct business relationships; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83ffe66b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8703/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate fully with a Federal Government agency investigating a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s8702"},"text":"section 8702 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83ffe66c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Full Cooperation Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsection (d), a prime contractor shall cooperate fully with a Federal Government agency investigating a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s8702"},"text":"section 8702 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83ffe66d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting Requirement.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83ffe66e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8703/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A prime contractor or subcontractor that has reasonable grounds to believe that a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s8702"},"text":"section 8702 of this title","children":[],"tail":" may have occurred shall promptly report the possible violation in writing to the inspector general of the contracting agency, the head of the contracting agency if the agency does not have an inspector general, or the Attorney General."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83ffe66f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8703/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Supplying information as favorable evidence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In an administrative or contractual action to suspend or debar a person who is eligible to enter into contracts with the Federal Government, evidence that the person has supplied information to the Federal Government pursuant to paragraph (1) is favorable evidence of the person’s responsibility for the purposes of Federal procurement laws and regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83ffe670-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8703/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability to Certain Prime Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) does not apply to a prime contract—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83ffe671-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8703/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is not greater than $100,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83ffe672-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8703/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the acquisition of commercial products or commercial services (as defined in sections 103 and 103a, respectively, of this title).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCr