{"tag":"section","attrib":{"id":"id83b39b56-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s113"},"text":null,"children":[{"tag":"num","attrib":{"value":"113"},"text":"§ 113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsible source","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subtitle, the term “responsible source” means a prospective contractor that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83b39b57-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s113/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has adequate financial resources to perform the contract or the ability to obtain those resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83b39b58-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s113/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is able to comply with the required or proposed delivery or performance schedule, taking into consideration all existing commercial and Government business commitments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83b39b59-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s113/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a satisfactory performance record;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83b39b5a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s113/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a satisfactory record of integrity and business ethics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83b39b5b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s113/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the necessary organization, experience, accounting and operational controls, and technical skills, or the ability to obtain the organization, experience, controls, and skills;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83b39b5c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s113/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the necessary production, construction, and technical equipment and facilities, or the ability to obtain the equipment and facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83b39b5d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s113/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is otherwise qualified and eligible to receive an award under applicable laws and regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83b39b5e-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3681"},"text":"124 Stat. 3681","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83b39b5f-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83b39b60-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83b39b61-3a70-11f1-ab1a-a78