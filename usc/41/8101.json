{"tag":"section","attrib":{"id":"id83f6492e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8101"},"text":null,"children":[{"tag":"num","attrib":{"value":"8101"},"text":"§ 8101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and construction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83f6492f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83f64930-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8101/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contractor","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “contractor” means the department, division, or other unit of a person responsible for the performance under the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f64931-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8101/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Controlled substance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “controlled substance” means a controlled substance in schedules I through V of section 202 of the Comprehensive Drug Abuse Prevention and Control Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s812"},"text":"21 U.S.C. 812","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f64932-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8101/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conviction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “conviction” means a finding of guilt (including a plea of nolo contendere), an imposition of sentence, or both, by a judicial body charged with the responsibility to determine violations of Federal or State criminal drug statutes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f64933-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8101/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criminal drug statute","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “criminal drug statute” means a criminal statute involving manufacture, distribution, dispensation, use, or possession of a controlled substance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f64934-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8101/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Drug-free workplace","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “drug-free workplace” means a site of an entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83f64935-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8101/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the performance of work done in connection with a specific contract or grant described in section 8102 or 8103 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83f64936-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8101/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at which employees of the entity are prohibited from engaging in the unlawful manufacture, distribution, dispensation, possession, or use of a controlled substance in accordance with the requirements of the Anti-Drug Abuse Act of 1988 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Public Law 100–690","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4181"},"text":"102 Stat. 4181","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f64937-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8101/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “employee” means the employee of a contractor or grantee directly engaged in the performance of work pursuant to the contract or grant described in section 8102 or 8103 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f64938-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8101/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Federal agency” means an agency as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/f"},"text":"section 552(f) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f64939-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8101/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grantee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “grantee” means the department, division, or other unit of a person responsible for the performance under the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83f6493a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This chapter does not require law enforcement agencies to comply with this chapter if the head of the agency determines it would be inappropriate in connection with the agency’s undercover operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83f6493b-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3826"},"text":"124 Stat. 3826","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83f6493c-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83f