{"tag":"section","attrib":{"id":"id83c8f7c5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1713"},"text":null,"children":[{"tag":"num","attrib":{"value":"1713"},"text":"§ 1713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement data","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83c8f7c6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1713/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83c8f7c7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1713/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualified hubzone small business concern","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “qualified HUBZone small business concern” has the meaning given that term in section 31(b) of the Small Business Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c8f7c8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1713/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Small business concern owned and controlled by socially and economically disadvantaged individuals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “small business concern owned and controlled by socially and economically disadvantaged individuals” has the meaning given that term in section 8(d) of the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/d"},"text":"15 U.S.C. 637(d)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c8f7c9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1713/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Small business concern owned and controlled by women","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “small business concern owned and controlled by women” has the meaning given that term in section 8(d) of the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/d"},"text":"15 U.S.C. 637(d)","children":[],"tail":") and section 204 of the Women’s Business Ownership Act of 1988 ("},{"tag":"ref","attrib":{"href":"/us/pl/100/533"},"text":"Public Law 100–533","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2692"},"text":"102 Stat. 2692","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c8f7ca-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1713/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each Federal agency shall report to the Office of Federal Procurement Policy the number of qualified HUBZone small business concerns, the number of small businesses owned and controlled by women, and the number of small business concerns owned and controlled by socially and economically disadvantaged individuals, by gender, that are first time recipients of contracts from the agency. The Office shall take appropriate action to ascertain, for each fiscal year, the number of those small businesses that have newly entered the Federal market.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83c8f7cb-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3719"},"text":"124 Stat. 3719","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tXVII/s1701/a/4/F/ii"},"text":"Pub. L. 115–91, div. A, title XVII, § 1701(a)(4)(F)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1796"},"text":"131 Stat. 1796","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83c8f7cc-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83c8f7cd-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83c8f7ce-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{