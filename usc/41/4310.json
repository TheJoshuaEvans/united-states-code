{"tag":"section","attrib":{"id":"id83e5a860-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310"},"text":null,"children":[{"tag":"num","attrib":{"value":"4310"},"text":"§ 4310.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proceeding costs not allowable","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83e5a861-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e5a862-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Costs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “costs”, with respect to a proceeding, means all costs incurred by a contractor, subcontractor, or personal services contractor, whether before or after the commencement of the proceeding, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83e5a863-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative and clerical expenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83e5a864-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of legal services, including legal services performed by an employee of the contractor, subcontractor, or personal services contractor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83e5a865-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of the services of accountants and consultants retained by the contractor, subcontractor, or personal services contractor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83e5a866-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the pay of directors, officers, and employees of the contractor, subcontractor, or personal services contractor for time devoted by those directors, officers, and employees to the proceeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e5a867-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “penalty” does not include restitution, reimbursement, or compensatory damages.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e5a868-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proceeding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “proceeding” includes an investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e5a869-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this section, costs incurred by a contractor, subcontractor, or personal services contractor in connection with a criminal, civil, or administrative proceeding commenced by the Federal Government, by a State, or by a contractor, subcontractor, or personal services contractor or grantee employee submitting a complaint under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s4712"},"text":"section 4712 of this title","children":[],"tail":" are not allowable as reimbursable costs under a covered contract, subcontract, or personal services contract if the proceeding—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e5a86a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relates to a violation of, or failure to comply with, a Federal or State statute or regulation or to any other activity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s4712/a/1"},"text":"section 4712(a)(1) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e5a86b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" results in a disposition described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e8186c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Dispositions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A disposition referred to in subsection (b)(2) is any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e8186d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In a criminal proceeding, a conviction (including a conviction pursuant to a plea of nolo contendere) by reason of the violation or failure referred to in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e8186e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In a civil or administrative proceeding involving an allegation of fraud or similar misconduct, a determination of contractor, subcontractor, or personal services contractor liability on the basis of the violation or failure referred to in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e8186f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any civil or administrative proceeding, the imposition of a monetary penalty or an order to take corrective action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s4712"},"text":"section 4712 of this title","children":[],"tail":" by reason of the violation or failure referred to in subsection (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e81870-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A final decision to do any of the following, by reason of the violation or failure referred to in subsection (b):","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83e81871-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Debar or suspend the contractor, subcontractor, or personal services contractor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83e81872-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rescind or void the contract, subcontract, or personal services contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83e81873-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Terminate the contract, subcontract, or personal services contract for default.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e81874-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A disposition of the proceeding by consent or compromise if the disposition could have resulted in a disposition described in paragraph (1), (2), (3), or (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e81875-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Costs Allowed by Settlement Agreement in Proceeding Commenced by Federal Government","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a proceeding referred to in subsection (b) that is commenced by the Federal Government and is resolved by consent or compromise pursuant to an agreement entered into by a contractor, subcontractor, or personal services contractor and the Federal Government, the costs incurred by the contractor, subcontractor, or personal services contractor in connection with the proceeding that are otherwise not allowable as reimbursable costs under subsection (b) may be allowed to the extent specifically provided in that agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e81876-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Costs Specifically Authorized by Executive Agency in Proceeding Commenced by State","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a proceeding referred to in subsection (b) that is commenced by a State, the executive agency that awarded the covered contract, subcontract, or personal services contract involved in the proceeding may allow the costs incurred by the contractor, subcontractor, or personal services contractor in connection with the proceeding as reimbursable costs if the executive agency determines, in accordance with the Federal Acquisition Regulation, that the costs were incurred as a result of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e81877-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a specific term or condition of the contract, subcontract, or personal services contract; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e81878-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific written instructions of the executive agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e81879-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Allowable Costs.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e8187a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (3), costs incurred by a contractor, subcontractor, or personal services contractor in connection with a criminal, civil, or administrative proceeding commenced by the Federal Government or a State in connection with a covered contract, subcontract, or personal services contract may be allowed as reimbursable costs under the contract, subcontract, or personal services contract if the costs are not disallowable under subsection (b), but only to the extent provided in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e8187b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of allowable costs.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83e8187c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum amount allowed","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of the costs allowable under paragraph (1) in any case may not exceed the amount equal to 80 percent of the amount of the costs incurred, to the extent that the costs are determined to be otherwise allowable and allocable under the Federal Acquisition Regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83e8187d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content of regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Regulations issued for the purpose of subparagraph (A) shall provide for appropriate consideration of the complexity of procurement litigation, generally accepted principles governing the award of legal fees in civil actions involving the Federal Government as a party, and other factors as may be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e8187e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"When otherwise allowable costs are not allowable","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a proceeding referred to in paragraph (1), contractor, subcontractor, or personal services contractor costs otherwise allowable as reimbursable costs under this subsection are not allowable if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83e8187f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proceeding involves the same contractor, subcontractor, or personal services contractor misconduct alleged as the basis of another criminal, civil, or administrative proceeding; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83e81880-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4310/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of the other proceeding are not allowable under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83e81881-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3789"},"text":"124 Stat. 3789","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tVIII/s828/d"},"text":"Pub. L. 112–239, div. A, title VIII, § 828(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1841"},"text":"126 Stat. 1841","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/261/s1/b/2/A"},"text":"Pub. L. 114–261, § 1(b)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-14"},"text":"Dec. 14, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1362"},"text":"130 Stat. 1362","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83e81882-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83e81883-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83e81884-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"h