{"tag":"section","attrib":{"id":"id83f8ba79-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8104"},"text":null,"children":[{"tag":"num","attrib":{"value":"8104"},"text":"§ 8104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee sanctions and remedies","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Within 30 days after receiving notice from an employee of a conviction pursuant to section 8102(a)(1)(D)(ii) or 8103(a)(1)(D)(ii) of this title, a contractor or grantee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83f8ba7a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8104/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take appropriate personnel action against the employee, up to and including termination; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f8ba7b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8104/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the employee to satisfactorily participate in a drug abuse assistance or rehabilitation program approved for those purposes by a Federal, State, or local health, law enforcement, or other appropriate agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83f8ba7c-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3830"},"text":"124 Stat. 3830","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83f8ba7d-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{