"children":[{"tag":"html:span","attrib":{},"text":"6702(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:351(a) (words before par. (1) related to applicability).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/286/s2/a"},"text":"Pub. L. 89–286, § 2(a)","children":[],"tail":" (words before par. (1) related to applicability), "},{"tag":"html:span","attrib":{},"text":"Oct. 22, 1965","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/79/1034"},"text":"79 Stat. 1034","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/94/489/s1/a"},"text":"Pub. L. 94–489, § 1(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 13, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/2358"},"text":"90 Stat. 2358","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6702(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:356.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/286/s7"},"text":"Pub. L. 89–286, § 7","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 22, 1965","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/79/1035"},"text":"79 Stat. 1035","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “the Walsh-Healey Public Contracts Act (","children":[{"tag":"ref","attrib":{"href":"/us/stat/49/2036"},"text":"49 Stat. 2036","children":[],"tail":")”, which appear in "},{"tag":"ref","attrib":{"href":"/us/pl/89/286/s7/2"},"text":"section 7(2) of Public Law 89–286","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/79/1036"},"text":"79 Stat. 1036","children":[],"tail":"), are treated as a reference to the Act of "},{"tag":"date","attrib":{"date":"1936-06-30"},"text":"June 30, 1936","children":[],"tail":" (ch. 881, "},{"tag":"ref","attrib":{"href":"/us/stat/49/2036"},"text":"49 Stat. 2036","children":[],"tail":"), which was known as the Walsh-Healey Act and which was subsequently designated as the Walsh-Healey Act by "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-30/s12"},"text":"section 12 of the Act of June 30, 1936","children":[],"tail":", which was added by "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/s10005/f/5"},"text":"section 10005(f)(5) of Public Law 103–355","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/108/3409"},"text":"108 Stat. 3409","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(7), the words “United States Postal Service” are substituted for “Post Office Department” because of sections 4(a) and 6(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of the Postal Reorganization Act ("},{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Public Law 91–375","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/773"},"text":"84 Stat. 773","children":[],"tail":", 783, 39 U.S.C. note prec. 101, 201 note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id83f18f3b-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id83f18f3c-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Communications Act of 1934, referred to in subsec. (b)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"act June 19, 1934, ch. 652","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1064"},"text":"48 Stat. 1064","children":[],"tail":", which is classified principally to chapter 5 (§ 151 et seq.) of Title 47, Telecommunications. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s609"},"text":"section 609 of Title 47","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
