{"tag":"section","attrib":{"id":"id83f18f2a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6702"},"text":null,"children":[{"tag":"num","attrib":{"value":"6702"},"text":"§ 6702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts to which this chapter applies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83f18f2b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), this chapter applies to any contract or bid specification for a contract, whether negotiated or advertised, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83f18f2c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6702/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is made by the Federal Government or the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f18f2d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6702/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involves an amount exceeding $2,500; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f18f2e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6702/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has as its principal purpose the furnishing of services in the United States through the use of service employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83f18f2f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This chapter does not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83f18f30-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6702/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contract of the Federal Government or the District of Columbia for the construction, alteration, or repair, including painting and decorating, of public buildings or public works;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f18f31-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6702/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any work required to be done in accordance with chapter 65 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f18f32-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6702/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contract for the carriage of freight or personnel by vessel, airplane, bus, truck, express, railway line or oil or gas pipeline where published tariff rates are in effect;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f18f33-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6702/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contract for the furnishing of services by radio, telephone, telegraph, or cable companies, subject to the Communications Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s151"},"text":"47 U.S.C. 151","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f18f34-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6702/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contract for public utility services, including electric light and power, water, steam, and gas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f18f35-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6702/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employment contract providing for direct services to a Federal agency by an individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f18f36-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6702/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contract with the United States Postal Service, the principal purpose of which is the operation of postal contract stations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83f18f37-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3812"},"text":"124 Stat. 3812","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83f18f38-3a70-11f