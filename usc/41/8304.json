{"tag":"section","attrib":{"id":"id83fd75cb-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8304"},"text":null,"children":[{"tag":"num","attrib":{"value":"8304"},"text":"§ 8304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver rescission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83fd75cc-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Type of Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An agreement referred to in subsection (b) is a reciprocal defense procurement memorandum of understanding between the United States and a foreign country pursuant to which the Secretary of Defense has prospectively waived this chapter for certain products in that country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83fd75cd-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination by Secretary of Defense","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary of Defense, after consultation with the United States Trade Representative, determines that a foreign country that is party to an agreement described in subsection (a) has violated the agreement by discriminating against certain types of products produced in the United States that are covered by the agreement, the Secretary of Defense shall rescind the Secretary’s blanket waiver of this chapter with respect to those types of products produced in that country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83fd75ce-