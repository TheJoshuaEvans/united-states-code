{"tag":"section","attrib":{"id":"id83c8f7af-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1712"},"text":null,"children":[{"tag":"num","attrib":{"value":"1712"},"text":"§ 1712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Record requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83c8f7b0-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1712/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maintaining Records on Computer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each executive agency shall establish and maintain for 5 years a computer file, by fiscal year, containing unclassified records of all procurements greater than the simplified acquisition threshold in that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c8f7b1-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1712/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The record established under subsection (a) shall include, with respect to each procurement carried out using—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83c8f7b2-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1712/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" competitive procedures—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83c8f7b3-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1712/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of contract award;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c8f7b4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1712/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information identifying the source to whom the contract was awarded;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c8f7b5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1712/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the property or services the Federal Government obtains under the procurement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c8f7b6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1712/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total cost of the procurement; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c8f7b7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1712/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" procedures other than competitive procedures—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83c8f7b8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1712/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information described in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c8f7b9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1712/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reason under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3304/a"},"text":"section 3304(a) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3204/a"},"text":"section 3204(a) of title 10","children":[],"tail":" for using the procedures; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c8f7ba-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1712/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity of the organization or activity that conducted the procurement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c8f7bb-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1712/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Separate Record Category for Procurements Resulting in One Bid or Proposal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Information included in a record pursuant to subsection (b)(1) that relates to procurements resulting in the submission of a bid or proposal by only one responsible source shall be separately categorized from the information relating to other procurements included in the record. The record of that information shall be designated “noncompetitive procurements using competitive procedures”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c8f7bc-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1712/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transmission and Data Entry of Information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of each executive agency shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83c8f7bd-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1712/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the accuracy of the information included in the record established and maintained by the agency under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c8f7be-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1712/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transmit in a timely manner such information to the General Services Administration for entry into the Federal Procurement Data System referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1122/a/4"},"text":"section 1122(a)(4) of this title","children":[],"tail":", or any successor system."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83c8f7bf-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3718"},"text":"124 Stat. 3718","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1702/h/5"},"text":"Pub. L. 117–81, div. A, title XVII, § 1702(h)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2158"},"text":"135 Sta