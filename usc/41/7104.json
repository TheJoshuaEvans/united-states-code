{"tag":"section","attrib":{"id":"id83f3ffc5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7104"},"text":null,"children":[{"tag":"num","attrib":{"value":"7104"},"text":"§ 7104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contractor’s right of appeal from decision by contracting officer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83f3ffc6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appeal to Agency Board","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contractor, within 90 days from the date of receipt of a contracting officer’s decision under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s7103"},"text":"section 7103 of this title","children":[],"tail":", may appeal the decision to an agency board as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s7105"},"text":"section 7105 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83f3ffc7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bringing an Action De Novo in Federal Court.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83f3ffc8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), and in lieu of appealing the decision of a contracting officer under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s7103"},"text":"section 7103 of this title","children":[],"tail":" to an agency board, a contractor may bring an action directly on the claim in the United States Court of Federal Claims, notwithstanding any contract provision, regulation, or rule of law to the contrary."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f3ffc9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tennessee valley authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of an action against the Tennessee Valley Authority, the contractor may only bring an action directly on the claim in a district court of the United States pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1337"},"text":"section 1337 of title 28","children":[],"tail":", notwithstanding any contract provision, regulation, or rule of law to the contrary."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f3ffca-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7104/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time for filing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contractor shall file any action under paragraph (1) or (2) within 12 months from the date of receipt of a contracting officer’s decision under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s7103"},"text":"section 7103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f3ffcb-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7104/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"De novo","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An action under paragraph (1) or (2) shall proceed de novo in accordance with the rules of the appropriate court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83f3ffcc-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3820"},"text":"124 Stat. 3820","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83f3ffcd-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83f3ffce-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83f3ffcf-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7104(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:606.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/95/563/s7"},"text":"Pub. L. 95–563, § 7","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/2385"},"text":"92 Stat. 2385","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7104(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:609(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/95/563/s10/a"},"text":"Pub. L. 95–563, § 10(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/2388"},"text":"92 Stat. 2388","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/164/tI/s161/10"},"text":"Pub. L. 97–164, title I, § 161(10)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/49"},"text":"96 Stat. 49","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “of contract appeals” are omitted as unnecessary because of the definition of “agency board” in section 7101 of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “United States Court of Federal Claims” are substituted for “United States Claims Court” because of section 902(b)(1) of the Federal Courts Administration Act of 1992 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4516"},"text":"106 Stat. 4516","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"28 U.S.C. 171","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
