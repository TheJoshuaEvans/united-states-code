{"tag":"section","attrib":{"id":"id83dc0b19-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3502"},"text":null,"children":[{"tag":"num","attrib":{"value":"3502"},"text":"§ 3502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required cost or pricing data and certification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83dc0b1a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"When Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of an executive agency shall require offerors, contractors, and subcontractors to make cost or pricing data available as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83dc0b1b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offeror for prime contract","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An offeror for a prime contract under this division to be entered into using procedures other than sealed-bid procedures shall be required to submit cost or pricing data before the award of a contract if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83dc0b1c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3502/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a prime contract entered into after ","children":[{"tag":"date","attrib":{"date":"2018-06-30"},"text":"June 30, 2018","children":[],"tail":", the price of the contract to the Federal Government is expected to exceed $2,000,000; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83dc0b1d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3502/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a prime contract entered into on or before ","children":[{"tag":"date","attrib":{"date":"2018-06-30"},"text":"June 30, 2018","children":[],"tail":", the price of the contract to the Federal Government is expected to exceed $750,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83dc0b1e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contractor","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The contractor for a prime contract under this division shall be required to submit cost or pricing data before the pricing of a change or modification to the contract if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83dc0b1f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3502/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a change or modification made to a prime contract referred to in paragraph (1)(A), the price adjustment is expected to exceed $2,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83dc0b20-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3502/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a change or modification made to a prime contract that was entered into on or before ","children":[{"tag":"date","attrib":{"date":"2018-06-30"},"text":"June 30, 2018","children":[],"tail":", and that has been modified pursuant to subsection (f), the price adjustment is expected to exceed $750,000; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83dc0b21-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3502/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a change or modification not covered by subparagraph (A) or (B), the price adjustment is expected to exceed $750,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83dc0b22-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3502/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offeror for subcontract","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An offeror for a subcontract (at any tier) of a contract under this division shall be required to submit cost or pricing data before the award of the subcontract if the prime contractor and each higher-tier subcontractor have been required to make available cost or pricing data under this chapter and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83dc0b23-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3502/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a subcontract under a prime contract referred to in paragraph (1)(A), the price of the subcontract is expected to exceed $2,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83dc0b24-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3502/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a subcontract entered into under a prime contract that was entered into on or before ","children":[{"tag":"date","attrib":{"date":"2018-06-30"},"text":"June 30, 2018","children":[],"tail":", and that has been modified pursuant to subsection (f), the price of the subcontract is expected to exceed $2,000,000; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83dc0b25-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3502/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a subcontract not covered by subparagraph (A) or (B), the price of the subcontract is expected to exceed $750,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83dc0b26-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3502/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subcontractor","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The subcontractor for a subcontract covered by paragraph (3) shall be required to submit cost or pricing data before the pricing of a change or modification to the subcontract if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83dc0b27-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3502/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a change or modification to a subcontract referred to in paragraph (3)(A) or (B), the price adjustment is expected to exceed $2,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83dc0b28-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3502/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a change or modification to a subcontract referred to in paragraph (3)(C), the price adjustment is expected to exceed $750,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83dc0b29-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person required, as an offeror, contractor, or subcontractor, to submit cost or pricing data under subsection (a) (or required by the head of the procuring activity concerned to submit the data under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3504"},"text":"section 3504 of this title","children":[],"tail":") shall be required to certify that, to the best of the person’s knowledge and belief, the cost or pricing data submitted are accurate, complete, and current."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83dc0b2a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"To Whom Submitted","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Cost or pricing data required to be submitted under subsection (a) (or under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3504"},"text":"section 3504 of this title","children":[],"tail":"), and a certification required to be submitted under subsection (b), shall be submitted—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83dc0b2b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3502/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a submission by a prime contractor (or an offeror for a prime contract), to the contracting officer for the contract (or a designated representative of the contracting officer); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83dc0b2c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3502/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a submission by a subcontractor (or an offeror for a subcontract), to the prime contractor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83dc0b2d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3502/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of Chapter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3503"},"text":"section 3503 of this title","children":[],"tail":", this chapter applies to contracts entered into by the head of an executive agency on behalf of a foreign government."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83dc0b2e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3502/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subcontracts Not Affected by Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A waiver of requirements for submission of certified cost or pricing data that is granted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3503/a/3"},"text":"section 3503(a)(3) of this title","children":[],"tail":" in the case of a contract or subcontract does not waive the requirement under subsection (a)(3) of this section for submission of cost or pricing data in the case of subcontracts under that contract or subcontract unless the head of the procuring activity granting the waiver determines that the requirement under subsection (a)(3) of this section should be waived in the case of those subcontracts and justifies in writing the reason for the determination."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83dc0b2f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3502/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Modifications to Prior Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On the request of a contractor that was required to submit cost or pricing data under subsection (a) in connection with a prime contract entered into on or before ","children":[{"tag":"date","attrib":{"date":"2018-06-30"},"text":"June 30, 2018","children":[],"tail":", the head of the executive agency that entered into the contract shall modify the contract to reflect paragraphs (2)(B) and (3)(B) of subsection (a). All those modifications shall be made without requiring consideration."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83dc0b30-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3502/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adjustment of Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Effective on October 1 of each year that is divisible by 5, each amount set forth in subsection (a) shall be adjusted in accordance with section 1908.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83dc0b31-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3765"},"text":"124 Stat. 3765","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVIII/s811/a/2"},"text":"Pub. L. 115–91, div. A, title VIII, § 811(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1459"},"text":"131 Stat. 1459","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83dc0b32-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83dc0b33-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83dc0b34-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3502","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:254b(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title III, § 304A(a), as added "},{"tag":"html:a","attrib":{"href":"/us/pl/103/355/tI/s1251/a/2"},"text":"Pub. L. 103–355, title I, § 1251(a)(2)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/108/3278"},"text":"108 Stat. 3278","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/105/261/dA/tVIII/s805/b"},"text":"Pub. L. 105–261, div. A, title VIII, § 805(b)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/2083"},"text":"112 Stat. 2083","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id83dc0b35-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id83dc0b36-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s811/a/2/A/i"},"text":"Pub. L. 115–91, § 811(a)(2)(A)(i)","children":[],"tail":", (ii), substituted “"},{"tag":"date","attrib":{"date":"2018-06-30"},"text":"June 30, 2018","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"October 13, 1994","children":[],"tail":"” and “$750,000” for “$100,000” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(A), (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s811/a/2/A/iii"},"text":"Pub. L. 115–91, § 811(a)(2)(A)(iii)","children":[],"tail":", substituted “$2,000,000” for “$500,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s811/a/2/A/iv"},"text":"Pub. L. 115–91, § 811(a)(2)(A)(iv)","children":[],"tail":", substituted “$750,000” for “$500,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(A), (B), (4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s811/a/2/A/iii"},"text":"Pub. L. 115–91, § 811(a)(2)(A)(iii)","children":[],"tail":", substituted “$2,000,000” for “$500,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s811/a/2/B"},"text":"Pub. L. 115–91, § 811(a)(2)(B)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2018-06-30"},"text":"June 30, 2018","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"October 13, 1994","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s811/a/2/C"},"text":"Pub. L. 115–91, § 811(a)(2)(C)","children":[],"tail":", substituted “in accordance with section 1908.” for “to the amount that is equal to the fiscal year 1994 constant dollar value of the amount set forth. Any amount, as so adjusted, that is not evenly divisible by $50,000 shall be rounded to the nearest multiple of $50,000. In the case of an amount that is evenly divisible by $25,000 but not evenly divisible by $50,000, the amount shall be rounded to the next higher multiple of $50,000.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
