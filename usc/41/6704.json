{"tag":"section","attrib":{"id":"id83f18f4b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6704"},"text":null,"children":[{"tag":"num","attrib":{"value":"6704"},"text":"§ 6704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on minimum wage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83f18f4c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contractor that makes a contract with the Federal Government, the principal purpose of which is to furnish services through the use of service employees, and any subcontractor, may not pay less than the minimum wage specified under section 6(a)(1) of the Fair Labor Standards Act of 1938 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s206/a/1"},"text":"29 U.S.C. 206(a)(1)","children":[],"tail":") to an employee engaged in performing work on the contract."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83f18f4d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s6704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Violations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Sections 6705 to 6707(d) of this title are applicable to a violation of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83f18f4e-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","childr