{"tag":"section","attrib":{"id":"id83bf8291-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327"},"text":null,"children":[{"tag":"num","attrib":{"value":"1327"},"text":"§ 1327.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83bf8292-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b) and chapter 71 of this title, and notwithstanding any other provision of law, an action taken under section 1323 or 4713 of this title, or any action taken by an executive agency to implement such an action, shall not be subject to administrative review or judicial review, including bid protests before the Government Accountability Office or in any Federal court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83bf8293-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Petitions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83bf8294-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after a party is notified of an exclusion or removal order under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1323/c/6"},"text":"section 1323(c)(6) of this title","children":[],"tail":" or a covered procurement action under "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s4713"},"text":"section 4713 of this title","children":[],"tail":", the party may file a petition for judicial review in the United States Court of Appeals for the District of Columbia Circuit claiming that the issuance of the exclusion or removal order or covered procurement action is unlawful."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bf8295-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standard of review","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Court shall hold unlawful a covered action taken under sections 1323 or 4713 of this title, in response to a petition that the court finds to be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83bf8296-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arbitrary, capricious, an abuse of discretion, or otherwise not in accordance with law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bf8297-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contrary to constitutional right, power, privilege, or immunity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bf8298-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in excess of statutory jurisdiction, authority, or limitation, or short of statutory right;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bf8299-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lacking substantial support in the administrative record taken as a whole or in classified information submitted to the court under paragraph (3); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bf829a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not in accord with procedures required by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bf829b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusive jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The United States Court of Appeals for the District of Columbia Circuit shall have exclusive jurisdiction over claims arising under sections 1323(c)(5) or 4713 of this title against the United States, any United States department or agency, or any component or official of any such department or agency, subject to review by the Supreme Court of the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1254"},"text":"section 1254 of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bf829c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative record and procedures.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83bf829d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The procedures described in this paragraph shall apply to the review of a petition under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bf829e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative record.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"id83bf829f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filing of record","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The United States shall file with the court an administrative record, which shall consist of the information that the appropriate official relied upon in issuing an exclusion or removal order under section 1323(c)(5) or a covered procurement action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s4713"},"text":"section 4713 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83bf82a0-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unclassified, nonprivileged information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All unclassified information contained in the administrative record that is not otherwise privileged or subject to statutory protections shall be provided to the petitioner with appropriate protections for any privileged or confidential trade secrets and commercial or financial information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83bf82a1-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/b/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In camera and ex parte","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following information may be included in the administrative record and shall be submitted only to the court ex parte and in camera:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id83bf82a2-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/b/4/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Classified information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id83bf82a3-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/b/4/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sensitive security information, as defined by section 1520.5 of title 49, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id83bf82a4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/b/4/B/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Privileged law enforcement information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id83bf82a5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/b/4/B/iii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information obtained or derived from any activity authorized under the Foreign Intelligence Surveillance Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801"},"text":"50 U.S.C. 1801","children":[],"tail":" et seq.), except that, with respect to such information, subsections (c), (e), (f), (g), and (h) of section 106 ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1806"},"text":"50 U.S.C. 1806","children":[],"tail":"), subsections (d), (f), (g), (h), and (i) of section 305 ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1825"},"text":"50 U.S.C. 1825","children":[],"tail":"), subsections (c), (e), (f), (g), and (h) of section 405 ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1845"},"text":"50 U.S.C. 1845","children":[],"tail":"), and section 706 ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1881e"},"text":"50 U.S.C. 1881e","children":[],"tail":") of that Act shall not apply."}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id83bf82a6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/b/4/B/iii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information subject to privilege or protections under any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83bf82a7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/b/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Under seal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any information that is part of the administrative record filed ex parte and in camera under clause (iii), or cited by the court in any decision, shall be treated by the court consistent with the provisions of this subparagraph and shall remain under seal and preserved in the records of the court to be made available consistent with the above provisions in the event of further proceedings. In no event shall such information be released to the petitioner or as part of the public record.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83bf82a8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/b/4/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Return","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After the expiration of the time to seek further review, or the conclusion of further proceedings, the court shall return the administrative record, including any and all copies, to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bf82a9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusive remedy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A determination by the court under this subsection shall be the exclusive judicial remedy for any claim described in this section against the United States, any United States department or agency, or any component or official of any such department or agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bf82aa-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed as limiting, superseding, or preventing the invocation of, any privileges or defenses that are otherwise available at law or in equity to protect against the disclosure of information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83bf82ab-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “classified information”—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83bf82ac-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the meaning given that term in section 1(a) of the Classified Information Procedures Act (18 U.S.C. App.); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bf82ad-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83bf82ae-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any information or material that has been determined by the United States Government pursuant to an Executive order, statute, or regulation to require protection against unauthorized disclosure for reasons of national security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bf82af-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1327/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any restricted data, as defined in section 11 of the Atomic Energy Act of 1954 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2014"},"text":"42 U.S.C. 2014","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83bf82b0-3a70-11f1-ab1a-a784e0a454e2"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/390/tII/s202/a"},"text":"Pub. L. 115–390, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5185"},"text":"132 Stat. 5185","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83bf82b1-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id83bf82b2-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id83bf82b3-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Intelligence Surveillance Act of 1978, referred to in subsec. (b)(4)(B)(iii)(IV), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/511"},"text":"Pub. L. 95–511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-25"},"text":"Oct. 25, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1783"},"text":"92 Stat. 1783","children":[],"tail":", which is classified principally to chapter 36 (§ 1801 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801"},"text":"section 1801 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Classified Information Procedures Act, referred to in subsec. (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/456"},"text":"Pub. L. 96–456","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-15"},"text":"Oct. 15, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2025"},"text":"94 Stat. 2025","children":[],"tail":", which is set out in the Appendix to Title 18, Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id83bf82b4-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id83bf82b5-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", and applicable to contracts that are awarded before, on, or after that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/390/s202/c"},"text":"section 202(c) of Pub. L. 115–390","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s1321"},"text":"section 1321 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/390"},"text":"Pub. L. 115–390","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/390/s205"},"text":"section 205 of Pub. L. 115–390","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s1321"},"text":"section 1321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
