{"tag":"section","attrib":{"id":"id83fd7600-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502"},"text":null,"children":[{"tag":"num","attrib":{"value":"8502"},"text":"§ 8502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committee for Purchase From People Who Are Blind or Severely Disabled","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83fd7601-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is a Committee for Purchase From People Who Are Blind or Severely Disabled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83fd7602-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Composition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee consists of 15 members appointed by the President as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83fd7603-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" One officer or employee from each of the following, nominated by the head of the department or agency:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83fd7604-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83fd7605-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83fd7606-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83fd7607-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83fd7608-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83fd7609-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83fd760a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83fd760b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83fd760c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Justice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83fd760d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Labor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83fd760e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/b/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The General Services Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83fd760f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member from individuals who are not officers or employees of the Federal Government and who are conversant with the problems incident to the employment of the blind.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83fd7610-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member from individuals who are not officers or employees of the Federal Government and who are conversant with the problems incident to the employment of other severely disabled individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83fd7611-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member from individuals who are not officers or employees of the Federal Government and who represent blind individuals employed in qualified nonprofit agencies for the blind.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83fd7612-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member from individuals who are not officers or employees of the Federal Government and who represent severely disabled individuals (other than blind individuals) employed in qualified nonprofit agencies for other severely disabled individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83fd7613-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms of Office","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Members appointed under paragraph (2), (3), (4), or (5) of subsection (b) shall be appointed for terms of 5 years and may be reappointed if the member meets the qualifications prescribed by those paragraphs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83fd7614-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairman","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The members of the Committee shall elect one of the members to be Chairman.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83fd7615-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vacancy.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83fd7616-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Manner in which filled","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vacancy in the membership of the Committee shall be filled in the manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83fd7617-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unfulfilled term","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member appointed under paragraph (2), (3), (4), or (5) of subsection (b) to fill a vacancy occurring prior to the expiration of the term for which the predecessor was appointed shall be appointed only for the remainder of the term. The member may serve after the expiration of a term until a successor takes office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83fd7618-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pay and Travel Expenses.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83fd7619-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount to which members are entitled","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), members of the Committee are entitled to receive the daily equivalent of the maximum annual rate of basic pay payable for level IV of the Executive Schedule for each day (including travel-time) during which they perform services for the Committee. A member is entitled to travel expenses, including a per diem allowance instead of subsistence, as provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83ffe61a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officers or employees of the federal government","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Members who are officers or employees of the Federal Government may not receive additional pay because of their service on the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83ffe61b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":" (g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Staff.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83ffe61c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment and compensation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to rules the Committee may adopt and to chapters 33 and 51 and subchapter III of chapter 53 of title 5, the Chairman may appoint and fix the pay of personnel the Committee determines are necessary to assist it in carrying out this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83ffe61d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Personnel from other entities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On request of the Committee, the head of an entity of the Federal Government may detail, on a reimbursable basis, any personnel of the entity to the Committee to assist it in carrying out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83ffe61e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Obtaining Official Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee may secure directly from an entity of the Federal Government information necessary to enable it to carry out this chapter. On request of the Chairman, the head of the entity shall furnish the information to the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83ffe61f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative Support Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of General Services shall provide to the Committee, on a reimbursable basis, administrative support services the Committee requests.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83ffe620-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8502/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than December 31 of each year, the Committee shall transmit to the President a report that includes the names of the Committee members serving in the prior fiscal year, the dates of Committee meetings in that year, a description of the activities of the Committee under this chapter in that year, and any recommendations for changes in this chapter which the Committee determines are necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83ffe621-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3835"},"text":"124 Stat. 3835","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83ffe622-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83ffe623-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83ffe624-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"ta