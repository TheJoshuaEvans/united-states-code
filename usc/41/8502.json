8"},"text":"90 Stat. 378","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/102/54/s13/p"},"text":"Pub. L. 102–54, § 13(p)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/105/278"},"text":"105 Stat. 278","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/102/569/tIX/s911/a"},"text":"Pub. L. 102–569, title IX, § 911(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/4486"},"text":"106 Stat. 4486","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/103/73/tIII/s301"},"text":"Pub. L. 103–73, title III, § 301","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 11, 1993","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/107/736"},"text":"107 Stat. 736","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8502(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:46(d)(1), (2), (4).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8502(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:46(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail