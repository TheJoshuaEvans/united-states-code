ext":"Pub. L. 94–273, § 3(22)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Apr. 21, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/377"},"text":"90 Stat. 377","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8501(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:46(a) (words in parentheses before par. (1)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1938-06-25/ch697/s1/a"},"text":"June 25, 1938, ch. 697, § 1(a)","children":[],"tail":" (words in parentheses before par. (1)), "},{"tag":"html:a","attrib":{"href":"/us/stat/52/1196"},"text":"52 Stat. 1196","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/92/28/s1"},"text":"Pub. L. 92–28, § 1","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"June 23, 1971","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/85/77"},"text":"85 Stat. 77","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8501(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:48b(5).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8501(4)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:48b(7).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8501(5)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:48b(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8501(6)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:48b(4).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8501(7)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:48b(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8501(8)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:48b(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8501(9)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:48b(8).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this chapter, the word “disabled” is substituted for “handicapped” for consistency with the name of the Committee. The word “product” is substituted for “commodity” to reflect the current usage of the items produced in the Committee’s program.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the text of 41:48b(6) is omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (9), the words “the Northern Mariana Islands” are substituted for “the Trust Territory of the Pacific Islands” because the Trust Territory of the Pacific Islands terminated. See 48 U.S.C. note prec. 1681. However, section 502(a)(2) of the Covenant to Establish a Commonwealth of the Northern Mariana Islands in Political Union with the United States of America (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1801"},"text":"48 U.S.C. 1801","children":[],"tail":" note) provided that laws in existence on the effective date of section 502 that were applicable to Guam and that were of general application to the several States would apply to the Northern Mariana Islands. The Marshall Islands, Palau, and the Federated States of Micronesia are not included because although they were part of the Trust Territory of the Pacific Islands, they are independent entities and not part of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id83fd75fc-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id83fd75fd-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Contracting With Employers of Persons With Disabilities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tVIII/s856/a"},"text":"Pub. L. 109–364, div. A, title VIII, § 856(a)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2347"},"text":"120 Stat. 2347","children":[],"tail":", 2349, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/364/dA/tVIII/s856/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of Certain Laws.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of the randolph-sheppard act to contracts and subcontracts for military dining facility support services covered by javits-wagner-o’day act","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Randolph-Sheppard Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s107"},"text":"20 U.S.C. 107","children":[],"tail":" et seq.) does not apply to full food services, mess attendant services, or services supporting the operation of a military dining facility that, as of the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":"], were services on the procurement list established under section 2 of the Javits-Wagner-O’Day Act ([former] "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s47"},"text":"41 U.S.C. 47","children":[],"tail":") [now "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s8503"},"text":"41 U.S.C. 8503","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of the javits-wagner-o’day act to contracts for the operation of a military dining facility","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Javits-Wagner-O’Day Act ([former] ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s46"},"text":"41 U.S.C. 46","children":[],"tail":" et seq.) [now "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s8501"},"text":"41 U.S.C. 8501","children":[],"tail":" et seq.] does not apply at the prime contract level to any contract entered into by the Department of Defense as of the date of the enactment of this Act with a State licensing agency under the Randolph-Sheppard Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s107"},"text":"20 U.S.C. 107","children":[],"tail":" et seq.) for the operation of a military dining facility."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Javits-Wagner-O’Day Act [now ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s8501"},"text":"41 U.S.C. 8501","children":[],"tail":" et seq.] shall apply to any subcontract entered into by a Department of Defense contractor for full food services, mess attendant services, and other services supporting the operation of a military dining facility."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repeal of superseded law","children":[],"tail":".—"}],"tail":null},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id83fd75fe-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"p","attrib":{},"text":"[Repealed section 853(a), (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2021"},"text":"118 Stat. 2021","children":[],"tail":".]"}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘State licensing agency’ means any agency designated by the Secretary of Education under section 2(a)(5) of the Randolph-Sheppard Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s107a/a/5"},"text":"20 U.S.C. 107a(a)(5)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘military dining facility’ means a facility owned, operated, leased, or wholly controlled by the Department of Defense and used to provide dining services to members of the Armed Forces, including a cafeteria, military mess hall, military troop dining facility, or any similar dining facility operated for the purpose of providing meals to members of the Armed Forces.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id83fd75ff-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Statement of Policy and Report Concerning the Operation and Management of Certain Military Facilities Regarding the Blind or Severely Disabled","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVIII/s848/b"},"text":"Pub. L. 109–163, div. A, title VIII, § 848(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3395"},"text":"119 Stat. 3395","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/163/dA/tVIII/s848/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statement of Policy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense, the Secretary of Education, and the Chairman of the Committee for Purchase From People Who Are Blind or Severely Disabled shall jointly issue a statement of policy related to the implementation of the Randolph-Sheppard Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s107"},"text":"20 U.S.C. 107","children":[],"tail":" et seq.) and the Javits-Wagner-O’Day Act ([former] "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s48"},"text":"41 U.S.C. 48","children":[],"tail":" [46 et seq.]) [now "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s8501"},"text":"41 U.S.C. 8501","children":[],"tail":" et seq.] within the Department of Defense and the Department of Education. The joint statement of policy shall specifically address the application of those Acts to both operation and management of all or any part of a military mess hall, military troop dining facility, or any similar dining facility operated for the purpose of providing meals to members of the Armed Forces, and shall take into account and address, to the extent practicable, the positions acceptable to persons representing programs implemented under each Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2006-04-01"},"text":"April 1, 2006","children":[],"tail":", the Secretary of Defense, the Secretary of Education, and the Chairman of the Committee for Purchase From People Who Are Blind or Severely Disabled shall submit to the Committees on Armed Services of the Senate and the House of Representatives, the Committee on Health, Education, Labor and Pensions of the Senate, and the Committee on Education and the Workforce of the House of Representatives a report describing the joint statement of policy issued under subsection (b), with such findings and recommendations as the Secretaries consider appropriate.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
