{"tag":"section","attrib":{"id":"id83d294a3-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2308"},"text":null,"children":[{"tag":"num","attrib":{"value":"2308"},"text":"§ 2308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modular contracting for information technology","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83d294a4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2308/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the maximum extent practicable, the head of an executive agency should use modular contracting for an acquisition of a major system of information technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d294a5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2308/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Modular Contracting Described","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under modular contracting, an executive agency’s need for a system is satisfied in successive acquisitions of interoperable increments. Each increment complies with common or commercially accepted standards applicable to information technology so that the increments are compatible with other increments of information technology comprising the system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d294a6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2308/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provisions in Federal Acquisition Regulation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal Acquisition Regulation shall provide that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d294a7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2308/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" under the modular contracting process, an acquisition of a major system of information technology may be divided into several smaller acquisition increments that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d294a8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2308/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are easier to manage individually than would be one comprehensive acquisition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d294a9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2308/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address complex information technology objectives incrementally in order to enhance the likelihood of achieving workable solutions for attaining those objectives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d294aa-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2308/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for delivery, implementation, and testing of workable systems or solutions in discrete increments, each of which comprises a system or solution that is not dependent on a subsequent increment in order to perform its principal functions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d294ab-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2308/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an opportunity for subsequent increments of the acquisition to take advantage of any evolution in technology or needs that occurs during conduct of the earlier increments;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d294ac-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2308/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, a contract for an increment of an information technology acquisition should be awarded within 180 days after the solicitation is issued and, if the contract for that increment cannot be awarded within that period, the increment should be considered for cancellation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d294ad-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2308/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information technology provided for in a contract for acquisition of information technology should be delivered within 18 months after the solicitation resulting in award of the contract was issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83d294ae-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3737"},"text":"124 Stat. 3737","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83d294af-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83d294b0-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83d294b1-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2308","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:434.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/93/400/s38"},"text":"Pub. L. 93–400, § 38","children":[],"tail":", formerly § 35, as added "},{"tag":"html:a","attrib":{"href":"/us/pl/104/106/tLII/s5202/a"},"text":"Pub. L. 104–106, title LII, § 5202(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/690"},"text":"110 Stat. 690","children":[],"tail":"; renumbered § 38, "},{"tag":"html:a","attrib":{"href":"/us/pl/104/201/tX/s1074/d/1"},"text":"Pub. L. 104–201, title X, § 1074(d)(1)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/2660"},"text":"110 Stat. 2660","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
