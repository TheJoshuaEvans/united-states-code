{"tag":"section","attrib":{"id":"id83ffe693-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8706"},"text":null,"children":[{"tag":"num","attrib":{"value":"8706"},"text":"§ 8706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83ffe694-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal Government in a civil action may recover from a person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83ffe695-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8706/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that knowingly engages in conduct prohibited by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s8702"},"text":"section 8702 of this title","children":[],"tail":" a civil penalty equal to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83ffe696-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8706/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" twice the amount of each kickback involved in the violation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83ffe697-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8706/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $10,000 for each occurrence of prohibited conduct; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83ffe698-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8706/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose employee, subcontractor, or subcontractor employee violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s8702"},"text":"section 8702 of this title","children":[],"tail":" by providing, accepting, or charging a kickback a civil penalty equal to the amount of that kickback."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83ffe699-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statute of Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A civil action under this section must be brought within 6 years after the later of the date on which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83ffe69a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8706/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prohibited conduct establishing the cause of action occurred; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83ffe69b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8706/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Government first knew or should reasonably have known that the prohibited conduct had occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83ffe69c-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","at