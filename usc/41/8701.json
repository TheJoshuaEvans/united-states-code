{"tag":"section","attrib":{"id":"id83ffe64d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8701"},"text":null,"children":[{"tag":"num","attrib":{"value":"8701"},"text":"§ 8701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83ffe64e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8701/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracting agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “contracting agency”, when used with respect to a prime contractor, means a department, agency, or establishment of the Federal Government that enters into a prime contract with a prime contractor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83ffe64f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8701/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Kickback","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “kickback” means any money, fee, commission, credit, gift, gratuity, thing of value, or compensation of any kind that is provided to a prime contractor, prime contractor employee, subcontractor, or subcontractor employee to improperly obtain or reward favorable treatment in connection with a prime contract or a subcontract relating to a prime contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83ffe650-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8701/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Person","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “person” means a corporation, partnership, business association of any kind, trust, joint-stock company, or individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83ffe651-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8701/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prime contract","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “prime contract” means a contract or contractual action entered into by the Federal Government to obtain supplies, materials, equipment, or services of any kind.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83ffe652-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8701/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prime contractor","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “prime contractor” means a person that has entered into a prime contract with the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83ffe653-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8701/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prime contractor employee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “prime contractor employee” means an officer, partner, employee, or agent of a prime contractor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83ffe654-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8701/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subcontract","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “subcontract” means a contract or contractual action entered into by a prime contractor or subcontractor to obtain supplies, materials, equipment, or services of any kind under a prime contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83ffe655-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8701/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subcontractor","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “subcontractor”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83ffe656-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8701/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a person, other than the prime contractor, that offers to furnish or furnishes supplies, materials, equipment, or services of any kind under a prime contract or a subcontract entered into in connection with the prime contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83ffe657-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8701/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a person that offers to furnish or furnishes general supplies to the prime contractor or a higher tier subcontractor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83ffe658-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8701/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subcontractor employee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “subcontractor employee” means an officer, partner, employee, or agent of a subcontractor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83ffe659-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3838"},"text":"124 Stat. 3838","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83ffe65a-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83ffe65b-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83ffe65c-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8701","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:52.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-03-08/ch80/s2"},"text":"Mar. 8, 1946, ch. 80, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/37"},"text":"60 Stat. 37","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/86/695"},"text":"Pub. L. 86–695","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Sept. 2, 1960","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/74/740"},"text":"74 Stat. 740","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/99/634/s2/a"},"text":"Pub. L. 99–634, § 2(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 7, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/3523"},"text":"100 Stat. 3523","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the text of 41:52(3) is omitted because of the definition of “person” in 1:1.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (2), the words “directly or indirectly” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id83ffe65d-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Senate Revision Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Senate amendment 4726 (111th Cong.) added par. (3) and redesignated former pars. (3) to (8) as (4) to (9), respectively. See 156 Cong. Rec. 18683 (2010).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
