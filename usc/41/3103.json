{"tag":"section","attrib":{"id":"id83d50652-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3103"},"text":null,"children":[{"tag":"num","attrib":{"value":"3103"},"text":"§ 3103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83d50653-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional Policy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It is the policy of Congress that the head of each executive agency should achieve, on average, 90 percent of the cost, performance, and schedule goals established for major acquisition programs of the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d50654-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Goals.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d50655-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"By head of executive agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of each executive agency shall approve or define the cost, performance, and schedule goals for major acquisition programs of the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d50656-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"By chief financial officer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The chief financial officer of an executive agency shall evaluate the cost goals proposed for each major acquisition program of the agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d50657-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Identification of Noncompliant Programs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"When it is necessary to implement the policy set out in subsection (a), the head of an executive agency shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d50658-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine whether there is a continuing need for programs that are significantly behind schedule, over budget, or not in compliance with performance or capability requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d50659-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify suitable actions to be taken, including termination, with respect to those programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83d5065a-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3743"},"text":"124 Stat. 3743","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83d5065b-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83d5065c-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83d5065d-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3103","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:263.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title III, § 313, as added "},{"tag":"html:a","attrib":{"href":"/us/pl/103/355/tV/s5051/a"},"text":"Pub. L. 103–355, title V, § 5051(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/108/3351"},"text":"108 Stat. 3351","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/105/85/dA/tVIII/s851/a"},"text":"Pub. L. 105–85, div. A, title VIII, § 851(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/111/1851"},"text":"111 Stat. 1851","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
