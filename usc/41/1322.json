{"tag":"section","attrib":{"id":"id83bd1101-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1322"},"text":null,"children":[{"tag":"num","attrib":{"value":"1322"},"text":"§ 1322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Acquisition Security Council establishment and membership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83bd1102-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1322/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established in the executive branch a Federal Acquisition Security Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83bd1103-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1322/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83bd1104-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1322/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following agencies shall be represented on the Council:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83bd1105-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1322/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bd1106-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1322/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The General Services Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bd1107-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1322/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Homeland Security, including the Cybersecurity and Infrastructure Security Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bd1108-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1322/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of the Director of National Intelligence, including the National Counterintelligence and Security Center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bd1109-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1322/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Justice, including the Federal Bureau of Investigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bd110a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1322/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Defense, including the National Security Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bd110b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1322/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Commerce, including the National Institute of Standards and Technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bd110c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1322/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other executive agencies as determined by the Chairperson of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bd110d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1322/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lead representatives.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83bd110e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1322/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"id83bd110f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1322/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 45 days after the date of the enactment of the Federal Acquisition Supply Chain Security Act of 2018, the head of each agency represented on the Council shall designate a representative of that agency as the lead representative of the agency on the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83bd1110-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1322/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The representative of an agency designated under clause (i) shall have expertise in supply chain risk management, acquisitions, or information and communications technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bd1111-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1322/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The lead representative of an agency designated under subparagraph (A) shall ensure that appropriate personnel, including leadership and subject matter experts of the agency, are aware of the business of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83bd1112-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1322/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairperson.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83bd1113-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1322/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 45 days after the date of the enactment of the Federal Acquisition Supply Chain Security Act of 2018, the Director of the Office of Management and Budget shall designate a senior-level official from the Office of Management and Budget to serve as the Chairperson of the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bd1114-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1322/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chairperson shall perform functions that include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83bd1115-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1322/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsection (d), developing a schedule for meetings of the Council;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bd1116-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1322/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designating executive agencies to be represented on the Council under subsection (b)(1)(H);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bd1117-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1322/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the lead representative of each agency represented on the Council, developing a charter for the Council; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bd1118-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1322/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 7 days after completion of the charter, submitting the charter to the appropriate congressional committees and leadership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83bd1119-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1322/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council shall meet not later than 60 days after the date of the enactment of the Federal Acquisition Supply Chain Security Act of 2018 and not less frequently than quarterly thereafter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83bd111a-3a70-11f1-ab1a-a784e0a454e2"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/390/tII/s202/a"},"text":"Pub. L. 115–390, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5178"},"text":"132 Stat. 5178","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83bd111b-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id83bd111c-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id83bd111d-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Federal Acquisition Supply Chain Security Act of 2018, referred to in subsecs. (b)(2)(A)(i), (c)(1), and (d), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/390"},"text":"Pub. L. 115–390","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id83bd111e-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id83bd111f-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", and applicable to contracts that are awarded before, on, or after that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/390/s202/c"},"text":"section 202(c) of Pub. L. 115–390","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s1321"},"text":"section 1321 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/390"},"text":"Pub. L. 115–390","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/390/s205"},"text":"section 205 of Pub. L. 115–390","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s1321"},"text":"section 1321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
