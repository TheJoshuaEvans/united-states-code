{"tag":"section","attrib":{"id":"id83f6493f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8102"},"text":null,"children":[{"tag":"num","attrib":{"value":"8102"},"text":"§ 8102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drug-free workplace requirements for Federal contractors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83f64940-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83f64941-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Persons other than individuals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person other than an individual shall not be considered a responsible source (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s113"},"text":"section 113 of this title","children":[],"tail":") for the purposes of being awarded a contract for the procurement of any property or services of a value greater than the simplified acquisition threshold (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s134"},"text":"section 134 of this title","children":[],"tail":") by a Federal agency, other than a contract for the procurement of commercial products or commercial services (as defined in sections 103 and 103a, respectively, of this title), unless the person agrees to provide a drug-free workplace by—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83f64942-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8102/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publishing a statement notifying employees that the unlawful manufacture, distribution, dispensation, possession, or use of a controlled substance is prohibited in the person’s workplace and specifying the actions that will be taken against employees for violations of the prohibition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83f64943-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8102/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establishing a drug-free awareness program to inform employees about—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83f64944-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8102/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dangers of drug abuse in the workplace;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83f64945-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8102/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person’s policy of maintaining a drug-free workplace;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83f64946-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8102/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" available drug counseling, rehabilitation, and employee assistance programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83f64947-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8102/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the penalties that may be imposed on employees for drug abuse violations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83f64948-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8102/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making it a requirement that each employee to be engaged in the performance of the contract be given a copy of the statement required by subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83f64949-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8102/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" notifying the employee in the statement required by subparagraph (A) that as a condition of employment on the contract the employee will—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83f6494a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8102/a/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" abide by the terms of the statement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83f6494b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8102/a/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the employer of any criminal drug statute conviction for a violation occurring in the workplace no later than 5 days after the conviction;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83f6494c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8102/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notifying the contracting agency within 10 days after receiving notice under subparagraph (D)(ii) from an employee or otherwise receiving actual notice of a conviction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83f6494d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8102/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imposing a sanction on, or requiring the satisfactory participation in a drug abuse assistance or rehabilitation program by, any employee who is convicted, as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s8104"},"text":"section 8104 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83f6494e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8102/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making a good faith effort to continue to maintain a drug-free workplace through implementation of subparagraphs (A) to (F).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f6494f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Individuals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Federal agency shall not make a contract with an individual unless the individual agrees not to engage in the unlawful manufacture, distribution, dispensation, possession, or use of a controlled substance in the performance of the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83f64950-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Suspension, Termination, or Debarment of Contractor.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83f64951-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grounds for suspension, termination, or debarment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Payment under a contract awarded by a Federal agency may be suspended and the contract may be terminated, and the contractor or individual who made the contract with the agency may be suspended or debarred in accordance with the requirements of this section, if the head of the agency determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83f64952-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8102/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contractor is violating, or has violated, the requirements of subparagraph (A), (B), (C), (D), (E), or (F) of subsection (a)(1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83f64953-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8102/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of employees of the contractor who have been convicted of violations of criminal drug statutes for violations occurring in the workplace indicates that the contractor has failed to make a good faith effort to provide a drug-free workplace as required by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f64954-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conduct of suspension, termination, and debarment proceedings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contracting officer who determines in writing that cause for suspension of payments, termination, or suspension or debarment exists shall initiate an appropriate action, to be conducted by the agency concerned in accordance with the Federal Acquisition Regulation and applicable agency procedures. The Federal Acquisition Regulation shall be revised to include rules for conducting suspension and debarment proceedings under this subsection, including rules providing notice, opportunity to respond in writing or in person, and other procedures as may be necessary to provide a full and fair proceeding to a contractor or individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f64955-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8102/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of debarment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contractor or individual debarred by a final decision under this subsection is ineligible for award of a contract by a Federal agency, and for participation in a future procurement by a Federal agency, for a period specified in the decision, not to exceed 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83f64956-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3827"},"text":"124 Stat. 3827","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s836/b/20"},"text":"Pub. L. 115–232, div. A, title VIII, § 836(b)(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1864"},"text":"132 Stat. 1864","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83f64957-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83f64958-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83f64959-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8102","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:701.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/100/690/tV/s5152"},"text":"Pub. L. 100–690, title V, § 5152","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/4304"},"text":"102 Stat. 4304","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/103/355/tIV/s4104/d"},"text":"Pub. L. 103–355, title IV, § 4104(d)","children":[],"tail":", title VIII, § 8301(f), "},{"tag":"html:span","attrib":{},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/108/3342"},"text":"108 Stat. 3342","children":[],"tail":", 3397; "},{"tag":"html:a","attrib":{"href":"/us/pl/104/106/dD/tXLIII"},"text":"Pub. L. 104–106, div. D, title XLIII","children":[],"tail":", §§ 4301(a)(3), 4321(i)(13), "},{"tag":"html:span","attrib":{},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/656"},"text":"110 Stat. 656","children":[],"tail":", 677."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id83f6495a-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id83f6495b-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “commercial products or commercial services (as defined in sections 103 and 103a, respectively, of this title)” for “commercial items (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s103"},"text":"section 103 of this title","children":[],"tail":")” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id83f6495c-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id83f6495d-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2020-01-01"},"text":"Jan. 1, 2020","children":[],"tail":", subject to a savings provision, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s836/h"},"text":"section 836(h) of Pub. L. 115–232","children":[],"tail":", set out as an Effective Date of 2018 Amendment; Savings Provision note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s453b"},"text":"section 453b of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
