hildren":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id83bac749-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of Repeal","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/67"},"text":"Pub. L. 113–67","children":[],"tail":" applicable only with respect to costs of compensation incurred under contracts entered into on or after the date that is 180 days after "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/113/67/s702/c"},"text":"section 702(c) of Pub. L. 113–67","children":[],"tail":", set out as an Effective Date of 2013 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s4304"},"text":"section 4304 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66"},"text":"Pub. L. 113–66","children":[],"tail":" applicable with respect to costs of compensation incurred under contracts entered into on or after the date that is 180 days after "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/s811/d"},"text":"section 811(d) of Pub. L. 113–66","children":[],"tail":", set out as an Effective Date of 2013 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s4304"},"text":"section 4304 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id83bac74a-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Exclusive Applicability of Provisions Limiting Allowability of Compensation for Certain Contractor Personnel","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tVIII/s808/f"},"text":"Pub. L. 105–85, div. A, title VIII, § 808(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1838"},"text":"111 Stat. 1838","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/85/dA/tVIII/s808/f"},"text":"“Notwithstanding any other provision of law, no other limitation in law on the allowability of costs of compensation of senior executives under covered contracts shall apply to such costs of compensation incurred after ","children":[{"tag":"date","attrib":{"date":"1998-01-01"},"text":"January 1, 1998","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id83bac74b-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Definitions for Purposes of Section 808 of Pub. L. 105–85","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tVIII/s808/g"},"text":"Pub. L. 105–85, div. A, title VIII, § 808(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1838"},"text":"111 Stat. 1838","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tVIII/s804/c/2"},"text":"Pub. L. 105–261, div. A, title VIII, § 804(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2083"},"text":"112 Stat. 2083","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/261/dA/tVIII/s804/c/2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this section [see Tables for classification]:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘covered contract’ has the meaning given such term in section 2324(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of title 10, United States Code [see "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3741"},"text":"10 U.S.C. 3741","children":[],"tail":"], and section 306("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of the Federal Property and Administrative Services Act of 1949 ([former] "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s256"},"text":"41 U.S.C. 256","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")) [see "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s4301"},"text":"41 U.S.C. 4301","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms ‘compensation’ and ‘senior executives’ have the meanings given such terms in section 2324(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of title 10, United States Code [see "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3741"},"text":"10 U.S.C. 3741","children":[],"tail":" as to “compensation” and former "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2324"},"text":"10 U.S.C. 2324","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(5) as to “senior executives”], and section 306(m) of the Federal Property and Administrative Services Act of 1949 [see "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s4301"},"text":"41 U.S.C. 4301","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
