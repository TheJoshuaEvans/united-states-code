{"tag":"section","attrib":{"id":"id83d50663-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3105"},"text":null,"children":[{"tag":"num","attrib":{"value":"3105"},"text":"§ 3105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New contracts and grants and merit-based selection procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83d50664-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional Policy","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the policy of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d50665-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3105/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an executive agency should not be required by legislation to award—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d50666-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3105/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a new contract to a specific non-Federal Government entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d50667-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3105/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a new grant for research, development, test, or evaluation to a non-Federal Government entity; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d50668-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3105/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a program, project, or technology identified in legislation be procured or awarded through merit-based selection procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d50669-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"New Contract and New Grant Described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d5066a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contract is a new contract unless the work provided for in the contract is a continuation of the work performed by the specified entity under a prior contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d5066b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a grant is a new grant unless the work provided for in the grant is a continuation of the work performed by the specified entity under a prior grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d5066c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements for Awarding New Contract or New Grant","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A provision of law may not be construed as requiring a new contract or a new grant to be awarded to a specified non-Federal Government entity unless the provision of law specifically—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d5066d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3105/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refers to this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d5066e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3105/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the particular non-Federal Government entity involved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d5066f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3105/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" states that the award to that entity is required by the provision of law in contravention of the policy set forth in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d50670-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3105/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not apply to a contract or grant that calls on the National Academy of Sciences to investigate, examine, or experiment on a subject of science or art of significance to an executive agency and to report on those matters to Congress or an agency of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83d50671-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3744"},"text":"124 Stat. 3744","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83d50672-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83d50673-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83d50674-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","childre