{"tag":"section","attrib":{"id":"id83dc0b9f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3702"},"text":null,"children":[{"tag":"num","attrib":{"value":"3702"},"text":"§ 3702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sealed bids","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83dc0ba0-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Opening of Bids","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Sealed bids shall be opened publicly at the time and place stated in the solicitation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83dc0ba1-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria for Awarding Contract","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The executive agency shall evaluate the bids in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3701/a"},"text":"section 3701(a) of this title","children":[],"tail":" without discussions with the bidders and, except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s3701/b"},"text":"section 3701(b) of this title","children":[],"tail":", shall award a contract with reasonable promptness to the responsible source whose bid conforms to the solicitation and is most advantageous to the Federal Government, considering only price and the other price-related factors included in the solicitation."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83dc0ba2-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice of Award","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The award of a contract shall be made by transmitting, in writing or by electronic means, notice of the award to the successful bidder. Within 3 days after the date of contract award, the executive agency shall notify, in writing or by electronic means, each bidder not awarded the contract that the contract has been awarded.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83dc0ba3-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3770"},"text":"124 Stat. 3770","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83dc0ba4-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83dc0ba5-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83dc0ba6-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Not