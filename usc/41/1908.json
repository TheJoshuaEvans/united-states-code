r” because of 29:551.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id83cb6991-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id83cb6992-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Trade Agreements Act of 1979, referred to in subsec. (b)(2)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39"},"text":"Pub. L. 96–39","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/144"},"text":"93 Stat. 144","children":[],"tail":". Title III of the Act is classified generally to subchapter I (§ 2511 et seq.) of chapter 13 of Title 19, Customs Duties. For complete classification of this Act to the Code, see References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2501"},"text":"section 2501 of Title 19","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of the enactment of this subparagraph, referred to in subsec. (b)(2)(D), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id83cb6993-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" substituted “chapters 67 and 83” for “chapter 67”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s861/a"},"text":"Pub. L. 117–81, § 861(a)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s861/b"},"text":"Pub. L. 117–81, § 861(b)","children":[],"tail":", struck out second period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" inserted before period at end “and shall apply, in the case of the procurement of property or services by contract, to a contract, and any subcontract at any tier under the contract, in effect on that date without regard to the date of award of the contract or subcontract.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s817/1"},"text":"Pub. L. 114–92, § 817(1)","children":[],"tail":", substituted “as calculated under paragraph (1)” for “on the day before the adjustment” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(D) to (G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s817/2"},"text":"Pub. L. 114–92, § 817(2)","children":[],"tail":", (3), added subpars. (D) to (G) and struck out former subpar. (D) which read as follows: “$1,000,000 or more, to the nearest $500,000.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id83cb6994-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id83cb6995-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Adjustment for Inflation of Right-Hand Drive Passenger Sedans","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVIII/s814/b"},"text":"Pub. L. 112–81, div. A, title VIII, § 814(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1491"},"text":"125 Stat. 1491","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/81/dA/tVIII/s814/b"},"text":"“The Department of Defense representative to the Federal Acquisition Regulatory Council established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1302"},"text":"section 1302 of title 41","children":[],"tail":", United States Code, shall ensure that the threshold established in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2253"},"text":"section 2253 of title 10","children":[],"tail":", United States Code, for the acquisition of right-hand drive passenger sedans is included on the list of dollar thresholds that are subject to adjustment for inflation in accordance with the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s1908"},"text":"section 1908 of title 41","children":[],"tail":", United States Code, and is adjusted pursuant to such provision, as appropriate.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
