{"tag":"section","attrib":{"id":"id83cb696c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908"},"text":null,"children":[{"tag":"num","attrib":{"value":"1908"},"text":"§ 1908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inflation adjustment of acquisition-related dollar thresholds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83cb696d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “Council” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83cb696e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83cb696f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the requirement for adjustment under subsection (c) applies to a dollar threshold that is specified in law as a factor in defining the scope of the applicability of a policy, procedure, requirement, or restriction provided in that law to the procurement of property or services by an executive agency, as the Council determines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cb6970-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (c) does not apply to dollar thresholds—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83cb6971-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in chapters 67 and 83 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cb6972-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in sections 3141 to 3144, 3146, and 3147 of title 40;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cb6973-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Trade Representative establishes pursuant to title III of the Trade Agreements Act of 1979 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2511"},"text":"19 U.S.C. 2511","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cb6974-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in sections 3131 through 3134 of title 40, except any modification of any such dollar threshold made by regulation in effect on the date of the enactment of this subparagraph shall remain in effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cb6975-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to other inflation adjustment authorities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section supersedes the applicability of other provisions of law that provide for the adjustment of a dollar threshold that is adjustable under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83cb6976-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement for Periodic Adjustment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83cb6977-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Baseline constant dollar value","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (2), the baseline constant dollar value for a dollar threshold—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83cb6978-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in effect on ","children":[{"tag":"date","attrib":{"date":"2000-10-01"},"text":"October 1, 2000","children":[],"tail":", that was first specified in a law that took effect on or before "},{"tag":"date","attrib":{"date":"2000-10-01"},"text":"October 1, 2000","children":[],"tail":", is the "},{"tag":"date","attrib":{"date":"2000-10-01"},"text":"October 1, 2000","children":[],"tail":", constant dollar value of that dollar threshold; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cb6979-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specified in a law that takes effect after ","children":[{"tag":"date","attrib":{"date":"2000-10-01"},"text":"October 1, 2000","children":[],"tail":", is the constant dollar value of that threshold as of the effective date of that dollar threshold pursuant to that law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cb697a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adjustment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On October 1 of each year evenly divisible by 5, the Council shall adjust each acquisition-related dollar threshold provided by law, as described in subsection (b)(1), to the baseline constant dollar value of that threshold.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cb697b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusive means of adjustment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A dollar threshold adjustable under this section shall be adjusted only as provided in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83cb697c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council shall publish a notice of the adjusted dollar thresholds under this section in the Federal Register. The thresholds take effect on the date of publication and shall apply, in the case of the procurement of property or services by contract, to a contract, and any subcontract at any tier under the contract, in effect on that date without regard to the date of award of the contract or subcontract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83cb697d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Calculation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An adjustment under this section shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83cb697e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" calculated on the basis of changes in the Consumer Price Index for all-urban consumers published monthly by the Secretary of Labor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cb697f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" rounded, in the case of a dollar threshold that as calculated under paragraph (1) is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83cb6980-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" less than $10,000, to the nearest $500;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cb6981-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $10,000, but less than $100,000, to the nearest $5,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cb6982-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $100,000, but less than $1,000,000, to the nearest $50,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cb6983-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $1,000,000, but less than $10,000,000, to the nearest $500,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cb6984-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $10,000,000, but less than $100,000,000, to the nearest $5,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cb6985-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/e/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $100,000,000, but less than $1,000,000,000, to the nearest $50,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cb6986-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/e/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000,000 or more, to the nearest $500,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83cb6987-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Petition for Inclusion of Omitted Threshold.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83cb6988-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Petition submitted to administrator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person may request adjustment of a dollar threshold adjustable under this section that is not included in a notice of adjustment published under subsection (d) by submitting a petition for adjustment to the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cb6989-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions of administrator","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"On receipt of a petition for adjustment of a dollar threshold under paragraph (1), the Administrator—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83cb698a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall determine, in writing, whether the dollar threshold is required to be adjusted under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cb698b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on determining that it should be adjusted, shall publish in the Federal Register a revised notice of the adjustment dollar thresholds under this section that includes the adjustment of the dollar threshold covered by the petition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cb698c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1908/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective date of adjustment by petition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The adjustment of a dollar threshold pursuant to a petition under this subsection takes effect on the date the revised notice adding the adjustment under paragraph (2)(B) is published.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83cb698d-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3725"},"text":"124 Stat. 3725","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVIII/s817"},"text":"Pub. L. 114–92, div. A, title VIII, § 817","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/897"},"text":"129 Stat. 897","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVIII/s821"},"text":"Pub. L. 115–91, div. A, title VIII, § 821","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1464"},"text":"131 Stat. 1464","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dG/tIX/s70922/f"},"text":"Pub. L. 117–58, div. G, title IX, § 70922(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1305"},"text":"135 Stat. 1305","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tVIII/s861"},"text":"Pub. L. 117–81, div. A, title VIII, § 861","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1851