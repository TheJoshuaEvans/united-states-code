{"tag":"section","attrib":{"id":"id83e5a7d9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4301"},"text":null,"children":[{"tag":"num","attrib":{"value":"4301"},"text":"§ 4301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e5a7da-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “compensation”, for a fiscal year, means the total amount of wages, salary, bonuses, and deferred compensation for the fiscal year, whether paid, earned, or otherwise accruing, as recorded in an employer’s cost accounting records for the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e5a7db-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered contract","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “covered contract” means a contract for an amount in excess of $500,000 that is entered into by an executive agency, except that the term does not include a fixed-price contract without cost incentives or any firm fixed-price contract for the purchase of commercial products or commercial services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e5a7dc-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4301/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fiscal year","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “fiscal year” means a fiscal year established by a contractor for accounting purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e5a7dd-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4301/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Senior executive","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “senior executive”, with respect to a contractor, means the 5 most highly compensated employees in management positions at each home office and each segment of the contractor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83e5a7de-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3784"},"text":"124 Stat. 3784","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s836/b/17"},"text":"Pub. L. 115–232, div. A, title VIII, § 836(b)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1864"},"text":"132 Stat. 1864","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83e5a7df-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83e5a7e0-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib"