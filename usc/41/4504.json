{"tag":"section","attrib":{"id":"id83e818a4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4504"},"text":null,"children":[{"tag":"num","attrib":{"value":"4504"},"text":"§ 4504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions for progress payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83e818a5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment Commensurate With Work","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The executive agency shall ensure that a payment for work in progress (including materials, labor, and other items) under a contract of an executive agency that provides for those payments is commensurate with the work accomplished that meets standards established under the contract. The contractor shall provide information and evidence the executive agency determines is necessary to permit the executive agency to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e818a6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The executive agency shall ensure that progress payments referred to in subsection (a) are not made for more than 80 percent of the work accomplished under the contract as long as the executive agency has not made the contractual terms, specifications, and price definite.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e818a7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section applies to a contract in an amount greater than $25,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83e818a8-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3791"},"text":"124 Stat. 3791","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83e818a9-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83e818aa-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83e818ab-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"t