{"tag":"section","attrib":{"id":"id83d294d7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2312"},"text":null,"children":[{"tag":"num","attrib":{"value":"2312"},"text":"§ 2312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contingency Contracting Corps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83d294d8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “Corps” means the Contingency Contracting Corps established in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d294d9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of General Services, pursuant to policies established by the Office of Management and Budget, and in consultation with the Secretary of Defense and the Secretary of Homeland Security, shall establish a Government-wide Contingency Contracting Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d294da-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2312/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Function","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The members of the Corps shall be available for deployment in responding to an emergency or major disaster, or a contingency operation, both within or outside the continental United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d294db-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2312/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The authorities provided in this section apply with respect to any procurement of property or services by or for an executive agency that, as determined by the head of the executive agency, are to be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d294dc-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2312/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in support of a contingency operation as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a/13"},"text":"section 101(a)(13) of title 10","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d294dd-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2312/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to respond to an emergency or major disaster as defined in section 102 of the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5122"},"text":"42 U.S.C. 5122","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d294de-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2312/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Membership in the Corps shall be voluntary and open to all Federal employees and members of the Armed Forces who are members of the Federal acquisition workforce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d294df-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2312/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Education and Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of General Services may, in consultation with the Director of the Federal Acquisition Institute and the Chief Acquisition Officers Council, establish educational and training requirements for members of the Corps. Education and training carried out pursuant to the requirements shall be paid for from funds available in the acquisition workforce training fund established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1703/i"},"text":"section 1703(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d294e0-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2312/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Salary","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The salary for a member of the Corps shall be paid—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d294e1-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2312/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a member of the Armed Forces, out of funds available to the Armed Force concerned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d294e2-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2312/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a Federal employee, out of funds available to the employing agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d294e3-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2312/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Deploy the Corps.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d294e4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2312/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director of the Office of Management and Budget","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Office of Management and Budget shall have the authority, upon request by an executive agency, to determine when members of the Corps shall be deployed, with the concurrence of the head of the agency or agencies employing the members to be deployed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d294e5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2312/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary of Defense","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall preclude the Secretary of Defense or the Secretary’s designee from deploying members of the Armed Forces or civilian personnel of the Department of Defense in support of a contingency operation as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a/13"},"text":"section 101(a)(13) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d294e6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2312/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d294e7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2312/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of General Services shall provide to the Committee on Homeland Security and Governmental Affairs and the Committee on Armed Services of the Senate and the Committee on Oversight and Government Reform and the Committee on Armed Services of the House of Representatives an annual report on the status of the Corps as of September 30 of each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d294e8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2312/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each report under paragraph (1) shall include the number of members of the Corps, the total cost of operating the program, the number of deployments of members of the program, and the performance of members of the program in deployment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83d294e9-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3739"},"text":"124 Stat. 3739","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83d294ea-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83d294eb-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83d294ec-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"2312 (except subsection (a))","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:440.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/93/400/s44"},"text":"Pub. L. 93–400, § 44","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title VIII, § 870(a), "},{"tag":"html:span","attrib":{},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/122/4554"},"text":"122 Stat. 4554","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2312(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"no source.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id83d294ed-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id83d294ee-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Oversight and Government Reform of House of Representatives changed to Committee on Oversight and Reform of House of Representatives by House Resolution No. 6, One Hundred Sixteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":". Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, "},{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
