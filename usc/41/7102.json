{"tag":"section","attrib":{"id":"id83f3ff8d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7102"},"text":null,"children":[{"tag":"num","attrib":{"value":"7102"},"text":"§ 7102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of chapter","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83f3ff8e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive Agency Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Unless otherwise specifically provided in this chapter, this chapter applies to any express or implied contract (including those of the nonappropriated fund activities described in sections 1346 and 1491 of title 28) made by an executive agency for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83f3ff8f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procurement of property, other than real property in being;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f3ff90-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procurement of services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f3ff91-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7102/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procurement of construction, alteration, repair, or maintenance of real property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f3ff92-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7102/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disposal of personal property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83f3ff93-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tennessee Valley Authority Contracts.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83f3ff94-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to contracts of the Tennessee Valley Authority, this chapter applies only to contracts containing a clause that requires contract disputes to be resolved through an agency administrative process.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f3ff95-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of this chapter, this chapter does not apply to a contract of the Tennessee Valley Authority for the sale of fertilizer or electric power or related to the conduct or operation of the electric power system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83f3ff96-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign Government or International Organization Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If an agency head determines that applying this chapter would not be in the public interest, this chapter does not apply to a contract with a foreign government, an agency of a foreign government, an international organization, or a subsidiary body of an international organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83f3ff97-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7102/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maritime Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Appeals under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s7107/a"},"text":"section 7107(a) of this title","children":[],"tail":" and actions brought under sections 7104(b) and 7107(b) to (f) of this title, arising out of maritime contracts, are governed by chapter 309 or 311 of title 46, as applicable, to the extent that those chapters are not inconsistent with this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83f3ff98-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3817"},"text":"124 Stat. 3817","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83f3ff99-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83f3ff9a-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83f3ff9b-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib"