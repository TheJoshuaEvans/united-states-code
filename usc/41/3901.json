{"tag":"section","attrib":{"id":"id83e336eb-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3901"},"text":null,"children":[{"tag":"num","attrib":{"value":"3901"},"text":"§ 3901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts awarded using procedures other than sealed-bid procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83e336ec-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3901/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Types","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3905"},"text":"section 3905 of this title","children":[],"tail":", contracts awarded after using procedures other than sealed-bid procedures may be of any type which in the opinion of the agency head will promote the best interests of the Federal Government."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e336ed-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3901/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Warranty.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e336ee-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3901/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Every contract awarded after using procedures other than sealed-bid procedures shall contain a suitable warranty, as determined by the agency head, by the contractor that no person or selling agency has been employed or retained to solicit or secure the contract on an agreement or understanding for a commission, percentage, brokerage, or contingent fee, except for bona fide employees or bona fide established commercial or selling agencies the contractor maintains to secure business.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e336ef-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3901/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remedy for breach or violation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the breach or violation of the warranty, the Federal Government may annul the contract without liability or deduct from the contract price or consideration the full amount of the commission, percentage, brokerage, or contingent fee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e336f0-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3901/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) does not apply to a contract for an amount that is not greater than the simplified acquisition threshold or to a contract for the acquisition of commercial products or commercial services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83e336f1-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3774"},"text":"124 Stat. 3774","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s836/b/16"},"text":"Pub. L. 115–232, div. A, title VIII, § 836(b)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1864"},"text":"132 Stat. 1864","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83e336f2-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83e336f3-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83e336f4-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3901","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:254(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title III, § 304(a), "},{"tag":"html:a","attrib":{"href":"/us/stat/63/395"},"text":"63 Stat. 395","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/98/369/dB/tVII/s2714/a/3/A"},"text":"Pub. L. 98–369, div. B, title VII, § 2714(a)(3)(A)","children":[],"tail":", (B), "},{"tag":"html:span","attrib":{},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/1184"},"text":"98 Stat. 1184","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/103/355/tIV/s4103/c"},"text":"Pub. L. 103–355, title IV, § 4103(c)","children":[],"tail":", title VIII, § 8204(b), "},{"tag":"html:span","attrib":{},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/108/3341"},"text":"108 Stat. 3341","children":[],"tail":", 3396."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “in its discretion” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id83e336f5-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id83e336f6-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “commercial products or commercial services” for “commercial items”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id83e336f7-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id83e336f8-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2020-01-01"},"text":"Jan. 1, 2020","children":[],"tail":", subject to a savings provision, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s836/h"},"text":"section 836(h) of Pub. L. 115–232","children":[],"tail":", set out as an Effective Date of 2018 Amendment; Savings Provision note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s453b"},"text":"section 453b of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id83e336f9-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"id83e336fa-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Ex. Ord. No. 14208. Ending Procurement and Forced Use of Paper Straws","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 14208, ","children":[{"tag":"date","attrib":{"date":"2025-02-10"},"text":"Feb. 10, 2025","children":[],"tail":", 90 F.R. 9585, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States of America, it is hereby ordered:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Section","children":[],"tail":" 1. "},{"tag":"i","attrib":{},"text":"Policy","children":[],"tail":". An irrational campaign against plastic straws has resulted in major cities, States, and businesses banning the use or automatic inclusion of plastic straws with beverages. Plastic straws are often replaced by paper straws, which are nonfunctional, use chemicals that may carry risks to human health, are more expensive to produce than plastic straws, and often force users to use multiple straws. Additionally, paper straws sometimes come individually wrapped in plastic, undermining the environmental argument for their use."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"It is therefore the policy of the United States to end the use of paper straws.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec.","children":[],"tail":" 2. "},{"tag":"i","attrib":{},"text":"Purchases of Paper Straws by the Federal Government","children":[],"tail":". (a) The heads of executive departments and agencies (agencies) shall take all appropriate action to eliminate the procurement of paper straws and otherwise ensure that paper straws are no longer provided within agency buildings."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) Agencies shall take appropriate action to eliminate policies designed to disfavor plastic straws issued to further Executive Order 14057 of ","children":[{"tag":"date","attrib":{"date":"2021-12-08"},"text":"December 8, 2021","children":[],"tail":" (Catalyzing Clean Energy Industries and Jobs Through Federal Sustainability) [former "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" note], which I revoked on "},{"tag":"date","attrib":{"date":"2025-01-20"},"text":"January 20, 2025","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(c) Within 45 days of the date of this order [","children":[{"tag":"date","attrib":{"date":"2025-02-10"},"text":"Feb. 10, 2025","children":[],"tail":"], the Assistant to the President for Domestic Policy, in coordination with relevant agencies, shall issue a National Strategy to End the Use of Paper Straws. This strategy shall address:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(i) The elimination of all policies within the executive branch designed to disfavor plastic straws;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(ii) Contract policies and terms with entities, including States, that ban or penalize plastic straw purchase or use; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(iii) All other available tools to achieve the policy of this order nationwide.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec.","children":[],"tail":" 3. "},{"tag":"i","attrib":{},"text":"General Provisions","children":[],"tail":". (a) Nothing in this order shall be construed to impair or otherwise affect:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(i) the authority granted by law to an executive department, agency, or the head thereof; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(ii) the functions of the Director of the Office of Management and Budget relating to budgetary, administrative, or legislative proposals.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) This order shall be implemented consistent with applicable law and subject to the availability of appropriations.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(c) This order is not intended to, and does not, create any right or benefit, substantive or procedural, enforceable at law or in equity by any party against the United States, its departments, agencies, or entities, its officers, employees, or agents, or any other person.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Donald J. Trump.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
