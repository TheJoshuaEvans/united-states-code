{"tag":"section","attrib":{"id":"id83cdd9fe-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2104"},"text":null,"children":[{"tag":"num","attrib":{"value":"2104"},"text":"§ 2104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on former official’s acceptance of compensation from contractor","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83cdd9ff-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A former official of a Federal agency may not accept compensation from a contractor as an employee, officer, director, or consultant of the contractor within one year after the official—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83cdda00-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2104/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" served, when the contractor was selected or awarded a contract, as the procuring contracting officer, the source selection authority, a member of the source selection evaluation board, or the chief of a financial or technical evaluation team in a procurement in which that contractor was selected for award of a contract in excess of $10,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cdda01-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2104/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" served as the program manager, deputy program manager, or administrative contracting officer for a contract in excess of $10,000,000 awarded to that contractor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cdda02-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2104/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" personally made for the Federal agency a decision to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83cdda03-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2104/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award a contract, subcontract, modification of a contract or subcontract, or a task order or delivery order in excess of $10,000,000 to that contractor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cdda04-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2104/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish overhead or other rates applicable to one or more contracts for that contractor that are valued in excess of $10,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cdda05-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2104/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approve issuance of one or more contract payments in excess of $10,000,000 to that contractor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cdda06-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2104/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay or settle a claim in excess of $10,000,000 with that contractor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83cdda07-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"When Compensation May Be Accepted","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) does not prohibit a former official of a Federal agency from accepting compensation from a division or affiliate of a contractor that does not produce the same or similar products or services as the entity of the contractor that is responsible for the contract referred to in paragraph (1), (2), or (3) of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83cdda08-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementing Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Regulations implementing this section shall include procedures for an official or former official of a Federal agency to request advice from the appropriate designated agency ethics official regarding whether the official or former official is or would be precluded by this section from accepting compensation from a particular contractor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83cdda09-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Persons Subject to Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following are subject to the penalties and administrative actions set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s2105"},"text":"section 2105 of this title","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83cdda0a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2104/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A former official who knowingly accepts compensation in violation of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cdda0b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2104/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A contractor that provides compensation to a former official knowing that the official accepts the compensation in violation of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83cdda0c-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3729"},"text":"124 Stat. 3729","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83cdda0d-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83cdda0e-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83cdda0f-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2104(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:423(d)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/93/400/s