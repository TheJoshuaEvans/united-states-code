{"tag":"section","attrib":{"id":"id83e818fb-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4704"},"text":null,"children":[{"tag":"num","attrib":{"value":"4704"},"text":"§ 4704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of contractors limiting subcontractor sales directly to Federal Government","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83e818fc-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract Restrictions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each contract for the purchase of property or services made by an executive agency shall provide that the contractor will not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e818fd-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4704/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into an agreement with a subcontractor under the contract that has the effect of unreasonably restricting sales by the subcontractor directly to the Federal Government of any item or process (including computer software) made or furnished by the subcontractor under the contract (or any follow-on production contract); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e818fe-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4704/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise act to restrict unreasonably the ability of a subcontractor to make sales described in paragraph (1) to the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e818ff-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rights Under Law Preserved","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not prohibit a contractor from asserting rights it otherwise has under law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e81900-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability to Certain Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not apply to a contract for an amount that is not greater than the simplified acquisition threshold.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e81901-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4704/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability When Government Treated Similarly to Other Purchasers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An agreement between the contractor in a contract for the acquisition of commercial products or commercial services and a subcontractor under the contract that restricts sales by the subcontractor directly to persons other than the contractor may not be considered to unreasonably restrict sales by that subcontractor to the Federal Government in violation of the provision included in the contract pursuant to subsection (a) if the agreement does not result in the Federal Government being treated differently with regard to the restriction than any other prospective purchaser of the commercial products or commercial services from that subcontractor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83e81902-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3795"},"text":"124 Stat. 3795","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s836/b/19"},"text":"Pub. L. 115–232, div. A, title VIII, § 836(b)(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1864"},"text":"132 Stat. 1864","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83e81903-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83e81904-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83e81905-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"ta