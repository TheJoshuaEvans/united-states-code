{"tag":"section","attrib":{"id":"id83e33783-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4104"},"text":null,"children":[{"tag":"num","attrib":{"value":"4104"},"text":"§ 4104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance on use of task and delivery order contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83e33784-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidance in Federal Acquisition Regulation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Acquisition Regulation issued in accordance with sections 1121(b) and 1303(a)(1) of this title shall provide guidance to agencies on the appropriate use of task and delivery order contracts in accordance with this chapter and chapter 245 of title 10.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e33785-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content of Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations issued pursuant to subsection (a) at a minimum shall provide specific guidance on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e33786-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate use of Government-wide and other multiagency contracts entered into in accordance with this chapter and chapter 245 of title 10; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e33787-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" steps that agencies should take in entering into and administering multiple award task and delivery order contracts to ensure compliance with the requirement in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83e33788-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4104/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s11312"},"text":"section 11312 of title 40","children":[],"tail":" for capital planning and investment control in purchases of information technology products and services;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83e33789-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4104/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s4106/c"},"text":"section 4106(c) of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3406/c"},"text":"section 3406(c) of title 10","children":[],"tail":" to ensure that all contractors are afforded a fair opportunity to be considered for the award of task and delivery orders; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83e3378a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4104/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s4106/e"},"text":"section 4106(e) of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3406/e"},"text":"section 3406(e) of title 10","children":[],"tail":" for a statement of work in each task or delivery order issued that clearly specifies all tasks to be performed or property to be delivered under the order."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e3378b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Supply Schedules Program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator for Federal Procurement Policy shall consult with the Administrator of General Services to assess the effectiveness of the multiple awards schedule program of the General Services Administration referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s152/3"},"text":"section 152(3) of this title","children":[],"tail":" that is administered as the Federal Supply Schedules program. The assessment shall include examination of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83e3378c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4104/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the administration of the program by the Administrator of General Services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83e3378d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4104/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ordering and program practices followed by Federal customer agencies in using schedules established under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83e3378e-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3780"},"text":"124 Stat. 3780","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1702/h/14"},"text":"Pub. L. 117–81, div. A, title XVII, § 1702(h)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2158"},"text":"135 Stat. 2158","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83e3378f-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83e33790-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83e33791-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"h