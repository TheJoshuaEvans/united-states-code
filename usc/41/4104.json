n (a), the words “Not later than 180 days after the date of the enactment of this Act” and “be revised to” are omitted as obsolete.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “this chapter and sections 2304a to 2304d of title 10” are substituted for “the provisions of law referred to in that subsection” for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id83e33792-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id83e33793-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsecs. (a), (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1702/h/14/A"},"text":"Pub. L. 117–81, § 1702(h)(14)(A)","children":[],"tail":", (B)(i), substituted “chapter 245” for “sections 2304a to 2304d”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1702/h/14/B/ii"},"text":"Pub. L. 117–81, § 1702(h)(14)(B)(ii)","children":[],"tail":", substituted “section 3406(c)” for “section 2304c(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1702/h/14/B/iii"},"text":"Pub. L. 117–81, § 1702(h)(14)(B)(iii)","children":[],"tail":", substituted “section 3406(e)” for “section 2304c(c)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
