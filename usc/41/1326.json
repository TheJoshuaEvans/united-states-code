{"tag":"section","attrib":{"id":"id83bf827b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1326"},"text":null,"children":[{"tag":"num","attrib":{"value":"1326"},"text":"§ 1326.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for executive agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83bf827c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1326/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of each executive agency shall be responsible for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83bf827d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1326/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the supply chain risk posed by the acquisition and use of covered articles and avoiding, mitigating, accepting, or transferring that risk, as appropriate and consistent with the standards, guidelines, and practices identified by the Council under section 1323(a)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bf827e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1326/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritizing supply chain risk assessments conducted under paragraph (1) based on the criticality of the mission, system, component, service, or asset.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83bf827f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1326/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The responsibility for assessing supply chain risk described in subsection (a) includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83bf8280-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1326/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing an overall supply chain risk management strategy and implementation plan and policies and processes to guide and govern supply chain risk management activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bf8281-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1326/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrating supply chain risk management practices throughout the life cycle of the system, component, service, or asset;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bf8282-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1326/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limiting, avoiding, mitigating, accepting, or transferring any identified risk;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bf8283-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1326/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sharing relevant information with other executive agencies as determined appropriate by the Council in a manner consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1323/a"},"text":"section 1323(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bf8284-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1326/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reporting on progress and effectiveness of the agency’s supply chain risk management consistent with guidance issued by the Office of Management and Budget and the Council; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bf8285-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1326/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that all relevant information, including classified information, with respect to acquisitions of covered articles that may pose a supply chain risk, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1323/a"},"text":"section 1323(a) of this title","children":[],"tail":", is incorporated into existing processes of the agency for conducting assessments described in subsection (a) and ongoing management of acquisition programs, including any identification, investigation, mitigation, or remediation needs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83bf8286-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1326/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interagency Acquisitions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83bf8287-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1326/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), in the case of an interagency acquisition, subsection (a) shall be carried out by the head of the executive agency whose funds are being used to procure the covered article.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bf8288-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1326/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assisted acquisitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In an assisted acquisition, the parties to the acquisition shall determine, as part of the interagency agreement governing the acquisition, which agency is responsible for carrying out subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bf8289-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1326/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the terms “assisted acquisition” and “interagency acquisition” have the meanings given those terms in section 2.101 of title 48, Code of Federal Regulations (or any corresponding similar regulation or ruling).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83bf828a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1326/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Homeland Security may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83bf828b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1326/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist executive agencies in conducting risk assessments described in subsection (a) and implementing mitigation requirements for information and communications technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bf828c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1326/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide such additional guidance or tools as are necessary to support actions taken by executive agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83bf828d-3a70-11f1-ab1a-a784e0a454e2"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/390/tII/s202/a"},"text":"Pub. L. 115–390, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5184"},"text":"132 Stat. 5184","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83bf828e-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id83bf828f-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id83bf8290-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", and applicable to contracts that are awarded before, on, or after that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/390/s202/c"},"text":"section 202(c) of Pub. L. 115–390","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s1321"},"text":"section 1321 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/390"},"text":"Pub. L. 115–390","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/390/s205"},"text":"section 205 of Pub. L. 115–390","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s1321"},"text":"section 1321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
