{"tag":"section","attrib":{"id":"id83d74fb4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3303"},"text":null,"children":[{"tag":"num","attrib":{"value":"3303"},"text":"§ 3303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of particular source or restriction of solicitation to small business concerns","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83d74fb5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusion of Particular Source.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d74fb6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3303/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria for exclusion","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An executive agency may provide for the procurement of property or services covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3301"},"text":"section 3301 of this title","children":[],"tail":" using competitive procedures but excluding a particular source to establish or maintain an alternative source of supply for that property or service if the agency head determines that to do so would—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d74fb7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3303/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase or maintain competition and likely result in reduced overall cost for the procurement, or for an anticipated procurement, of the property or services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d74fb8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3303/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be in the interest of national defense in having a facility (or a producer, manufacturer, or other supplier) available for furnishing the property or service in case of a national emergency or industrial mobilization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d74fb9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3303/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be in the interest of national defense in establishing or maintaining an essential engineering, research, or development capability to be provided by an educational or other nonprofit institution or a Federally funded research and development center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d74fba-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3303/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the continuous availability of a reliable source of supply of the property or service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d74fbb-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3303/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfy projected needs for the property or service determined on the basis of a history of high demand for the property or service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d74fbc-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3303/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfy a critical need for medical, safety, or emergency supplies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d74fbd-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3303/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination for class disallowed","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A determination under paragraph (1) may not be made for a class of purchases or contracts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d74fbe-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusion of Other Than Small Business Concerns","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An executive agency may provide for the procurement of property or services covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3301"},"text":"section 3301 of this title","children":[],"tail":" using competitive procedures, but excluding other than small business concerns in furtherance of sections 9 and 15 of the Small Business Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s638"},"text":"15 U.S.C. 638","children":[],"tail":", 644)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d74fbf-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication of Justification and Approval Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contract awarded pursuant to the competitive procedures referred to in subsections (a) and (b) is not subject to the justification and approval required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3304/e/1"},"text":"section 3304(e)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83d74fc0-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3747"},"text":"124 Stat. 3747","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83d74fc1-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83d74fc2-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83d74fc3-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\