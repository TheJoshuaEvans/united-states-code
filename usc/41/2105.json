{"tag":"section","attrib":{"id":"id83d02400-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2105"},"text":null,"children":[{"tag":"num","attrib":{"value":"2105"},"text":"§ 2105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties and administrative actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83d02401-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criminal Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person that violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s2102"},"text":"section 2102 of this title","children":[],"tail":" to exchange information covered by "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s2102"},"text":"section 2102 of this title","children":[],"tail":" for anything of value or to obtain or give a person a competitive advantage in the award of a Federal agency procurement contract shall be fined under title 18, imprisoned for not more than 5 years, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d02402-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General may bring a civil action in an appropriate district court of the United States against a person that engages in conduct that violates section 2102, 2103, or 2104 of this title. On proof of that conduct by a preponderance of the evidence—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d02403-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual is liable to the Federal Government for a civil penalty of not more than $50,000 for each violation plus twice the amount of compensation that the individual received or offered for the prohibited conduct; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d02404-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization is liable to the Federal Government for a civil penalty of not more than $500,000 for each violation plus twice the amount of compensation that the organization received or offered for the prohibited conduct.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d02405-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative Actions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d02406-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2105/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Types of action that federal agency may take","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Federal agency that receives information that a contractor or a person has violated section 2102, 2103, or 2104 of this title shall consider taking one or more of the following actions, as appropriate:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d02407-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2105/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Canceling the Federal agency procurement, if a contract has not yet been awarded.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d02408-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2105/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Rescinding a contract with respect to which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83d02409-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2105/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contractor or someone acting for the contractor has been convicted for an offense punishable under subsection (a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83d0240a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2105/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of the agency that awarded the contract has determined, based on a preponderance of the evidence, that the contractor or a person acting for the contractor has engaged in conduct constituting the offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d0240b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2105/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Initiating a suspension or debarment proceeding for the protection of the Federal Government in accordance with procedures in the Federal Acquisition Regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d0240c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2105/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Initiating an adverse personnel action, pursuant to the procedures in chapter 75 of title 5 or other applicable law or regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d0240d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2105/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount government entitled to recover","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When a Federal agency rescinds a contract pursuant to paragraph (1)(B), the Federal Government is entitled to recover, in addition to any penalty prescribed by law, the amount expended under the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d0240e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2105/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Present responsibility affected by conduct","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of a suspension or debarment proceeding initiated pursuant to paragraph (1)(C), engaging in conduct constituting an offense under section 2102, 2103, or 2104 of this title affects the present responsibility of a Federal Government contractor or subcontractor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83d0240f-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3730"},"text":"124 Stat. 3730","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83d02410-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83d02411-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83d02412-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2105(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:423(e)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/93/400/s27/e"},"text":"Pub. L. 93–400, § 27(e)","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/100/679/s6/a"},"text":"Pub. L. 100–679, § 6(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 17, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/4063"},"text":"102 Stat. 4063","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/101/189/tVIII/s814/a"},"text":"Pub. L. 101–189, title VIII, § 814(a)","children":[],"tail":"–(d)(1), "},{"tag":"html:span","attrib":{},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/103/1495"},"text":"103 Stat. 1495","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/101/510/tXIV/s1484"},"text":"Pub. L. 101–510, title XIV, § 1484","children":[],"tail":"("},{"tag":"html:i","attrib":{},"text":"l","children":[],"tail":")(6), "},{"tag":"html:span","attrib":{},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/1720"},"text":"104 Stat. 1720","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/102/25/tVII/s705/i"},"text":"Pub. L. 102–25, title VII, § 705(i)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Apr. 6, 1991","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/105/121"},"text":"105 Stat. 121","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/103/355/tVIII/s8301/e"},"text":"Pub. L. 103–355, title VIII, § 8301(e)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/108/3397"},"text":"108 Stat. 3397","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/104/106/tXLIII/s4304/a"},"text":"Pub. L. 104–106, title XLIII, § 4304(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/661"},"text":"110 Stat. 661","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2105(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:423(e)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2105(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:423(e)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “violates” is substituted for “engages in conduct constituting a violation of” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “liable to the Federal Government for” are substituted for “subject to” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the words “has violated” are substituted for “has engaged in conduct constituting a violation of” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
