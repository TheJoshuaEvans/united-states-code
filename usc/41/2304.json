{"tag":"section","attrib":{"id":"id83d2947d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2304"},"text":null,"children":[{"tag":"num","attrib":{"value":"2304"},"text":"§ 2304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict of interest standards for consultants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83d2947e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content of Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall prescribe under this division Government-wide regulations that set forth—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d2947f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2304/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conflict of interest standards for persons who provide consulting services described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d29480-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2304/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures, including registration, certification, and enforcement requirements as may be appropriate, to promote compliance with the standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d29481-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Services Subject to Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Regulations required by subsection (a) apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d29482-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advisory and assistance services provided to the Federal Government to the extent necessary to identify and evaluate the potential for conflicts of interest that could be prejudicial to the interests of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d29483-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services related to support of the preparation or submission of bids and proposals for Federal contracts to the extent that inclusion of the services in the regulations is necessary to identify and evaluate the potential for conflicts of interest that could be prejudicial to the interests of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d29484-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2304/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other services related to Federal contracts as specified in the regulations prescribed under subsection (a) to the extent necessary to identify and evaluate the potential for conflicts of interest that could be prejudicial to the interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d29485-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Intelligence Activities Exemption.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d29486-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2304/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activities that may be exempt","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Intelligence activities as defined in section 3.4(e) of Executive Order No. 12333 or a comparable definitional section in any successor order may be exempt from the regulations required by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d29487-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2304/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of National Intelligence shall report to the Intelligence and Appropriations Committees of Congress each January 1, delineating the activities and organizations that have been exempted under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d29488-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2304/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Presidential Determination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before the regulations required by subsection (a) are prescribed, the President shall determine if prescribing the regulations will have a significantly adverse effect on the accomplishment of the mission of the Defense Department or another Federal agency. If the President determines that the regulations will have such an adverse effect, the President shall so report to the appropriate committees of the Senate and the House of Representatives, stating in full the reasons for the determination. If such a report is submitted, the requirement for the regulations shall be null and void.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83d29489-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3736"},"text":"124 Stat. 3736","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83d2948a-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83d2948b-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83d2948c-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2304(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:405b(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/100/463/tVIII/s8141"},"text":"Pub. L. 100–463, title VIII, § 8141","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 1, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/2270-47"},"text":"102 Stat. 2270–47","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2304(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:405b(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2304(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:405b(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2304(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:405b(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the text of 41:405b(c) is omitted as obsolete.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before paragraph (1), the words “The Administrator shall prescribe under this division Government-wide regulations” are substituted for “Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1988-10-01"},"text":"October 1, 1988","children":[],"tail":", the Administrator of the Office of Federal Procurement Policy shall issue a policy, and not later than 180 days thereafter Government-wide regulations shall be issued under the Office of Federal Procurement Policy Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s401"},"text":"41 U.S.C. 401","children":[],"tail":" et seq.)” to eliminate obsolete words."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before paragraph (1), the words “the following types of consulting services” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the words “Director of National Intelligence” are substituted for “Director of Central Intelligence” because of section 1081(a) of the Intelligence Reform and Terrorism Prevention Act of 2004 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Public Law 108–458","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s401"},"text":"50 U.S.C. 401","children":[],"tail":" note). The words “each January 1” are substituted for “no later than "},{"tag":"date","attrib":{"date":"1990-01-01"},"text":"January 1, 1990","children":[],"tail":", and annually thereafter to eliminate obsolete and unnecessary words. The words “exempted under paragraph (1)” are substituted for “exempted from the regulations required by subsection (a) of this section in accordance with the provisions of this subsection” to eliminate unnecessary words."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id83d2948d-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id83d2948e-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order 12333, referred to in subsec. (c)(1), is set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of Title 50","children":[],"tail":", War and National Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id83d2948f-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id83d29490-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Clarification of Waiver Authority for Organizational and Consultant Conflicts of Interest","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVIII/s881"},"text":"Pub. L. 118–159, div. A, title VIII, § 881","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2017"},"text":"138 Stat. 2017","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dA/tVIII/s881"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Section 9.503 of the Federal Acquisition Regulation shall be revised to require that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a request for a waiver under such section include a written justification for such waiver; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of a Federal agency may not delegate such waiver authority below the level of the deputy head of such agency.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
