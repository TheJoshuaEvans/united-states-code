{"tag":"section","attrib":{"id":"id83c6ae35-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708"},"text":null,"children":[{"tag":"num","attrib":{"value":"1708"},"text":"§ 1708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement notice","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83c6ae36-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83c6ae37-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an executive agency intending to solicit bids or proposals for a contract for property or services for a price expected to exceed $10,000, but not to exceed $25,000, shall post, for not less than 10 days, in a public place at the contracting office issuing the solicitation a notice of solicitation described in subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6ae38-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an executive agency shall publish a notice of solicitation described in subsection (c) if the agency intends to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83c6ae39-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solicit bids or proposals for a contract for property or services for a price expected to exceed $25,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6ae3a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" place an order, expected to exceed $25,000, under a basic agreement, basic ordering agreement, or similar arrangement; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6ae3b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an executive agency awarding a contract for property or services for a price exceeding $25,000, or placing an order exceeding $25,000 under a basic agreement, basic ordering agreement, or similar arrangement, shall furnish for publication a notice announcing the award or order if there is likely to be a subcontract under the contract or order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c6ae3c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemptions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83c6ae3d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A notice is not required under subsection (a) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83c6ae3e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the proposed procurement is for an amount not greater than the simplified acquisition threshold and is to be conducted by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83c6ae3f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using widespread electronic public notice of the solicitation in a form that allows convenient and universal user access through a single, Government-wide point of entry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83c6ae40-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permitting the public to respond to the solicitation electronically;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6ae41-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the notice would disclose the executive agency’s needs and disclosure would compromise national security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6ae42-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the proposed procurement would result from acceptance of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83c6ae43-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an unsolicited proposal that demonstrates a unique and innovative research concept and publication of a notice of the unsolicited research proposal would disclose the originality of thought or innovativeness of the proposal or would disclose proprietary information associated with the proposal; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83c6ae44-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proposal submitted under section 9 of the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s638"},"text":"15 U.S.C. 638","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6ae45-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procurement is made against an order placed under a requirements contract, a task order contract, or a delivery order contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6ae46-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procurement is made for perishable subsistence supplies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6ae47-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procurement is for utility services, other than telecommunication services, and only one source is available; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6ae48-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procurement is for the services of an expert for use in any litigation or dispute (including any reasonably foreseeable litigation or dispute) involving the Federal Government in a trial, hearing, or proceeding before a court, administrative tribunal, or agency, or in any part of an alternative dispute resolution process, whether or not the expert is expected to testify.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6ae49-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain procurements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements of subsection (a)(2) do not apply to a procurement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83c6ae4a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under conditions described in paragraph (2), (3), (4), (5), or (7) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3304/a"},"text":"section 3304(a) of this title","children":[],"tail":" or paragraph (2), (3), (4), (5), or (7) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3204/a"},"text":"section 3204(a) of title 10","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6ae4b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the head of the executive agency makes a determination in writing, after consultation with the Administrator and the Administrator of the Small Business Administration, that it is not appropriate or reasonable to publish a notice before issuing a solicitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6ae4c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation consistent with international agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1)(A) shall be implemented in a manner consistent with applicable international agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c6ae4d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of Notice","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each notice of solicitation required by paragraph (1) or (2) of subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83c6ae4e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an accurate description of the property or services to be contracted for, which description—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83c6ae4f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be unnecessarily restrictive of competition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6ae50-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include, as appropriate, the agency nomenclature, National Stock Number or other part number, and a brief description of the item’s form, fit, or function, physical dimensions, predominant material of manufacture, or similar information that will assist a prospective contractor to make an informed business judgment as to whether a copy of the solicitation should be requested;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6ae51-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provisions that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83c6ae52-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83c6ae53-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state whether the technical data required to respond to the solicitation will not be furnished as part of the solicitation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83c6ae54-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the source in the Federal Government, if any, from which the technical data may be obtained; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6ae55-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83c6ae56-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state whether an offeror or its product or service must meet a qualification requirement in order to be eligible for award; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83c6ae57-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if so, identify the office from which the qualification requirement may be obtained;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6ae58-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, business address, and telephone number of the contracting officer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6ae59-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement that all responsible sources may submit a bid, proposal, or quotation (as appropriate) that the agency shall consider;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6ae5a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a procurement using procedures other than competitive procedures, a statement of the reason justifying the use of those procedures and the identity of the intended source; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6ae5b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a contract in an amount estimated to be greater than $25,000 but not greater than the simplified acquisition threshold, or a contract for the procurement of commercial products or commercial services using special simplified procedures—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83c6ae5c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the procedures to be used in awarding the contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6ae5d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement specifying the periods for prospective offerors and the contracting officer to take the necessary preaward and award actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c6ae5e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Electronic Publication of Notice of Solicitation, Award, or Order","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A notice of solicitation, award, or order required to be published under subsection (a) shall be published by electronic means. The notice must be electronically accessible in a form that allows convenient and universal user access through the single Government-wide point of entry designated in the Federal Acquisition Regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c6ae5f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time Limitations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83c6ae60-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Issuing notice of solicitation and establishing deadline for submitting bids and proposals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An executive agency required by subsection (a)(2) to publish a notice of solicitation may not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83c6ae61-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue the solicitation earlier than 15 days after the date on which the notice is published; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6ae62-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a contract or order expected to be greater than the simplified acquisition threshold, establish a deadline for the submission of all bids or proposals in response to the notice required by subsection (a)(2) that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83c6ae63-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a solicitation for research and development, is earlier than 45 days after the date the notice required for a bid or proposal for a contract described in subsection (a)(2)(A) is published;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83c6ae64-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an order under a basic agreement, basic ordering agreement, or similar arrangement, is earlier than 30 days after the date the notice required for an order described in subsection (a)(2)(B) is published; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83c6ae65-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/e/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any other case, is earlier than 30 days after the date the solicitation is issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6ae66-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishing deadline when none provided by statute","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An executive agency shall establish a deadline for the submission of all bids or proposals in response to a solicitation for which a deadline is not provided by statute. Each deadline for the submission of offers shall afford potential offerors a reasonable opportunity to respond.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6ae67-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Flexible deadlines","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall prescribe regulations defining limited circumstances in which flexible deadlines can be used under paragraph (1) for the issuance of solicitations and the submission of bids or proposals for the procurement of commercial products or commercial services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c6ae68-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consideration of Certain Timely Received Offers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An executive agency intending to solicit offers for a contract for which a notice of solicitation is required to be posted under subsection (a)(1) shall ensure that contracting officers consider each responsive offer timely received from an offeror.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c6ae69-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1708/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Complete Solicitation Package and Payment of Fee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An executive agency shall make available to a business concern, or the authorized representative of a concern, the complete solicitation package for any on-going procurement announced pursuant to a notice of solicitation under subsection (a). An executive agency may require the payment of a fee, not exceeding the actual cost of duplication, for a copy of the package.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83c6ae6a-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3711"},"text":"124 Stat. 3711","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s836/b/3"},"text":"Pub. L. 115–232, div. A, title VIII, § 836(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1861"},"text":"132 Stat. 1861","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1702/h/4"},"text":"Pub. L. 117–81, div. A, title XVII, § 1702(h)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2158"},"text":"135 Stat. 2158","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83c6ae6b-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83c6ae6c-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83c6ae6d-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"