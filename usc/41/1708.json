:"41:416(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1708(b)(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"no source.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1708(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:416(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1708(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:416(a)(2), (7).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1708(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:416(a)(3), (5), (6).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1708(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:416(a)(4).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1708(g)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:416(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3), the words “under a basic agreement, basic ordering agreement, or similar arrangement” are substituted for “referred to in clause (A)(ii)” for clarity. The words “by the Secretary of Commerce” are omitted as obsolete. The Secretary of Commerce no longer has responsibility for publishing notices of awards or orders. See revision note for subsection (d).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the text of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s416/C/1/H"},"text":"41 U.S.C. 416(C)(1)(H)","children":[],"tail":" is omitted because the procurement authority of the Secretary of Homeland Security pursuant to the special procedures provided in section 833(c) of the Homeland Security Act of 2002 ("},{"tag":"ref","attrib":{"href":"/us/usc/t6/s339/c"},"text":"6 U.S.C. 339(c)","children":[],"tail":") expired on "},{"tag":"date","attrib":{"date":"2007-09-30"},"text":"September 30, 2007","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b)(3) is added because of section 850(e)(3) of the National Defense Authorization Act for Fiscal Year 1998 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Public Law 105–85","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1849"},"text":"111 Stat. 1849","children":[],"tail":", 15:637 note), which in part provided that the amendments made by section 850(e)(2), which amended 41:416(c)(1), be implemented in a manner consistent with applicable international agreements."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (d) is substituted for 41:416(a)(2) and (7) to eliminate unnecessary words. Federal Business Opportunities is the designated single point of universal electronic public access for publication of all procurement information and notices previously published by the Secretary of Commerce in the Commerce Business Daily. See 66 Fed. Reg. 27407, ","children":[{"tag":"date","attrib":{"date":"2001-05-16"},"text":"May 16, 2001","children":[],"tail":", 68 Fed. Reg. 56678, "},{"tag":"date","attrib":{"date":"2003-10-01"},"text":"October 1, 2003","children":[],"tail":", 48 CFR ch. 1, subch. B, part 5, and the special notice posted in CBDNet on "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"December 28, 2001","children":[],"tail":", and printed on "},{"tag":"date","attrib":{"date":"2002-01-02"},"text":"January 2, 2002","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e)(1)(B)(i), the words “required for a bid or proposal for a contract described in” are substituted for “required by” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e)(1)(B)(ii), the words “required for an order described in” are substituted for “required by” for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id83c8f75e-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id83c8f75f-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" substituted “section 3204(a)” for “section 2304(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsecs. (c)(6), (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “commercial products or commercial services” for “commercial items”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id83c8f760-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id83c8f761-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2020-01-01"},"text":"Jan. 1, 2020","children":[],"tail":", subject to a savings provision, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s836/h"},"text":"section 836(h) of Pub. L. 115–232","children":[],"tail":", set out as an Effective Date of 2018 Amendment; Savings Provision note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s453b"},"text":"section 453b of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id83c8f762-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability to Tennessee Valley Authority","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/577/tIII/s303/c"},"text":"Pub. L. 98–577, title III, § 303(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3079"},"text":"98 Stat. 3079","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/577/tIII/s303/c"},"text":"“The provisions of the amendments made by subsection (a) of this section [see Tables for classification] shall apply to the Tennessee Valley Authority only with respect to procurements to be paid from appropriated funds.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
