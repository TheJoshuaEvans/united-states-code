{"tag":"section","attrib":{"id":"id83f648fb-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7107"},"text":null,"children":[{"tag":"num","attrib":{"value":"7107"},"text":"§ 7107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review of agency board decisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83f648fc-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83f648fd-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7107/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The decision of an agency board is final, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83f648fe-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7107/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contractor may appeal the decision to the United States Court of Appeals for the Federal Circuit within 120 days from the date the contractor receives a copy of the decision; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83f648ff-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7107/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if an agency head determines that an appeal should be taken, the agency head, with the prior approval of the Attorney General, may transmit the decision to the United States Court of Appeals for the Federal Circuit for judicial review under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1295"},"text":"section 1295 of title 28","children":[],"tail":", within 120 days from the date the agency receives a copy of the decision."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f64900-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7107/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tennessee valley authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraph (1), a decision of the board of contract appeals of the Tennessee Valley Authority is final, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83f64901-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7107/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contractor may appeal the decision to a United States district court pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1337"},"text":"section 1337 of title 28","children":[],"tail":", within 120 days from the date the contractor receives a copy of the decision; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83f64902-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7107/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Tennessee Valley Authority may appeal the decision to a United States district court pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1337"},"text":"section 1337 of title 28","children":[],"tail":", within 120 days from the date of the decision."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f64903-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7107/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review of arbitration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An award by an arbitrator under this chapter shall be reviewed pursuant to sections 9 to 13 of title 9, except that the court may set aside or limit any award that is found to violate limitations imposed by Federal statute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83f64904-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Finality of Agency Board Decisions on Questions of Law and Fact","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any contract provision, regulation, or rule of law to the contrary, in an appeal by a contractor or the Federal Government from the decision of an agency board pursuant to subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83f64905-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7107/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the decision of the agency board on a question of law is not final or conclusive; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f64906-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7107/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the decision of the agency board on a question of fact is final and conclusive and may not be set aside unless the decision is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83f64907-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7107/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fraudulent, arbitrary, or capricious;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83f64908-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7107/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" so grossly erroneous as to necessarily imply bad faith; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83f64909-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7107/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not supported by substantial evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83f6490a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remand","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In an appeal by a contractor or the Federal Government from the decision of an agency board pursuant to subsection (a), the court may render an opinion and judgment and remand the case for further action by the agency board or by the executive agency as appropriate, with direction the court considers just and proper.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83f6490b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7107/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consolidation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If 2 or more actions arising from one contract are filed in the United States Court of Federal Claims and one or more agency boards, for the convenience of parties or witnesses or in the interest of justice, the United States Court of Federal Claims may order the consolidation of the actions in that court or transfer any actions to or among the agency boards involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83f6490c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7107/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Judgments as to Fewer Than All Claims or Parties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In an action filed pursuant to this chapter involving 2 or more claims, counterclaims, cross-claims, or third-party claims, and where a portion of one of the claims can be divided for purposes of decision or judgment, and in any action where multiple parties are involved, the court, whenever appropriate, may enter a judgment as to one or more but fewer than all of the claims or portions of claims or parties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83f6490d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7107/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advisory Opinions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83f6490e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7107/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whenever an action involving an issue described in paragraph (2) is pending in a district court of the United States, the district court may request an agency board to provide the court with an advisory opinion on the matters of contract interpretation under consideration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f6490f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7107/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicable issue","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An issue referred to in paragraph (1) is any issue that could be the proper subject of a final decision of a contracting officer appealable under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f64910-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7107/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Referral to agency board with jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A district court shall direct a request under paragraph (1) to the agency board having jurisdiction under this chapter to adjudicate appeals of contract claims under the contract being interpreted by the court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f64911-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7107/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timely response","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After receiving a request for an advisory opinion under paragraph (1), an agency board shall provide the advisory opinion in a timely manner to the district court making the request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83f64912-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3824"},"text":"124 Stat. 3824","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83f64913-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83f64914-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83f64915-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7107(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:607(g).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/95/563/s8/g"},"text":"Pub. L. 95–563, § 8(g)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/2387"},"text":"92 Stat. 2387","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/164/tI/s156"},"text":"Pub. L. 97–164, title I, § 156","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/47"},"text":"96 Stat. 47","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/101/552/s6/b"},"text":"Pub. L. 101–552, § 6(b)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/2746"},"text":"104 Stat. 2746","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7107(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:609(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/95/563/s10/b"},"text":"Pub. L. 95–563, § 10(b)","children":[],"tail":", (e), "},{"tag":"html:span","attrib":{},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/2388"},"text":"92 Stat. 2388","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7107(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:609(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/95/563/s10/c"},"text":"Pub. L. 95–563, § 10(c)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/2388"},"text":"92 Stat. 2388","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/164/tI/s157"},"text":"Pub. L. 97–164, title I, § 157","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/47"},"text":"96 Stat. 47","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7107(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:609(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/95/563/s10/d"},"text":"Pub. L. 95–563, § 10(d)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/2388"},"text":"92 Stat. 2388","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/164/tI/s160/a/15"},"text":"Pub. L. 97–164, title I, § 160(a)(15)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/48"},"text":"96 Stat. 48","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7107(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:609(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7107(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:609(f).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/95/563/s10/f"},"text":"Pub. L. 95–563, § 10(f)","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/103/355/tII/s2354"},"text":"Pub. L. 103–355, title II, § 2354","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/108/3323"},"text":"108 Stat. 3323","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1)(B), the words “may transmit” are substituted for “transmits” to correct the grammatical structure of the provision in accordance with the probable intent of Congress. The words “the decision” are substituted for “the decision of the board of contract appeals” and for “the board’s decision” to eliminate unnecessary words and for consistency with 41:607(g)(1)(A).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2)(B), the words “in any case” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “United States Court of Federal Claims” are substituted for “United States Claims Court” because of section 902(b)(1) of the Federal Courts Administration Act of 1992 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4516"},"text":"106 Stat. 4516","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"28 U.S.C. 171","children":[],"tail":" note)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f)(1), (3), and (4), the words “agency board” are substituted for “board of contract appeals” to eliminate unnecessary words and for consistency with the definition of “agency board” in section 7101 of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f)(1), the words “under consideration” are substituted for “at issue” to avoid potential confusion with the words “issue described in paragraph (2)”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
