{"tag":"section","attrib":{"id":"id83cb6922-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1904"},"text":null,"children":[{"tag":"num","attrib":{"value":"1904"},"text":"§ 1904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain transactions for defense against attack","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83cb6923-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83cb6924-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1904/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an executive agency that engages in basic research, applied research, advanced research, and development projects that are necessary to the responsibilities of the executive agency in the field of research and development and have the potential to facilitate defense against or recovery from terrorism or nuclear, biological, chemical, or radiological attack may exercise the same authority (subject to the same restrictions and conditions) with respect to the research and projects as the Secretary of Defense may exercise under section 2371 ","children":[{"tag":"ref","attrib":{"idref":"fn002006"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002006"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 10, except for subsections (b) and (f) of section 2371."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cb6925-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1904/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prototype projects","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an executive agency, under the authority of paragraph (1), may carry out prototype projects that meet the requirements of paragraph (1) in accordance with the requirements and conditions provided for carrying out prototype projects under section 845 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of the National Defense Authorization Act for Fiscal Year 1994 ("},{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Public Law 103–160","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2371"},"text":"10 U.S.C. 2371","children":[],"tail":" note), including that, to the maximum extent practicable, competitive procedures shall be used when entering into agreements to carry out projects under section 845(a) of that Act and that the period of authority to carry out projects under section 845(a) of that Act terminates as provided in section 845(i) of that Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cb6926-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1904/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of requirements and conditions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In applying the requirements and conditions of section 845 of that Act under this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83cb6927-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1904/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 845(c) of that Act shall apply with respect to prototype projects carried out under paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cb6928-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1904/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Office of Management and Budget shall perform the functions of the Secretary of Defense under section 845(d) of that Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cb6929-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1904/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability to selected executive agencies.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83cb692a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1904/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Office of management and budget","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an executive agency may exercise authority under this subsection for a project only if authorized by the Director of the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cb692b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1904/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Department of homeland security","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Authority under this subsection does not apply to the Secretary of Homeland Security while section 831 of the Homeland Security Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s391"},"text":"6 U.S.C. 391","children":[],"tail":") is in effect."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83cb692c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Office of Management and Budget shall prescribe regulations to carry out this section. No transaction may be conducted under the authority of this section before the regulations take effect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83cb692d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1904/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The annual report of the head of an executive agency that is required under section 2371(h) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of title 10, as applied to the head of the executive agency by subsection (a), shall be submitted to the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Oversight and Government Reform of the House of Representatives."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83cb692e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1904/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority to carry out transactions under subsection (a) terminates on ","children":[{"tag":"date","attrib":{"date":"2008-09-30"},"text":"September 30, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83cb692f-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3721"},"text":"124 Stat. 3721","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83cb6930-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83cb6931-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83cb6932-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1904","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:428a note.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/108/136/tXIV/s1441"},"text":"Pub. L. 108–136, title XIV, § 1441","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/117/1673"},"text":"117 Stat. 1673","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the reference to subsection (g) of section 845 of the National Defense Authorization Act for Fiscal Year 1994 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Public Law 103–160","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2371"},"text":"10 U.S.C. 2371","children":[],"tail":" note) is changed to subsection (i) because of section 847(c)(1) of the National Defense Authorization Act for Fiscal Year 2004 ("},{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Public Law 108–136","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1554"},"text":"117 Stat. 1554","children":[],"tail":"), which redesignated subsection (g) as subsection (h), and section 823(2) of the National Defense Authorization Act for Fiscal Year 2006 ("},{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Public Law 109–163","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3387"},"text":"119 Stat. 3387","children":[],"tail":"), which redesignated subsection (h) as subsection (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3)(A), the words “paragraph (2)” are substituted for “this paragraph” to correct the cross-reference.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(4)(A), the words “to use the authority for such project” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “Committee on Homeland Security and Governmental Affairs” are substituted for “Committee on Governmental Affairs” on authority of Senate Resolution No. 445 (108th Congress, ","children":[{"tag":"date","attrib":{"date":"2004-10-09"},"text":"October 9, 2004","children":[],"tail":"). The words “Committee on Oversight and Government Reform” are substituted for “Committee on Government Reform” on authority of Rule X(1)(m) of the Rules of the House of Representatives, adopted by House Resolution No. 6 (110th Congress, "},{"tag":"date","attrib":{"date":"2007-01-05"},"text":"January 5, 2007","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id83cb6933-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id83cb6934-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2371"},"text":"Section 2371 of title 10","children":[],"tail":", referred to in subsec. (a)(1), was renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4021"},"text":"section 4021 of title 10","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1841/b/1"},"text":"Pub. L. 116–283, § 1841(b)(1)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/u/2/B"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(u)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2151"},"text":"135 Stat. 2151","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 845 of the National Defense Authorization Act for Fiscal Year 1994 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Public Law 103–160","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2371"},"text":"10 U.S.C. 2371","children":[],"tail":" note), referred to in subsec. (a)(2), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVIII/s815/c"},"text":"Pub. L. 114–92, div. A, title VIII, § 815(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/896"},"text":"129 Stat. 896","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2371/h"},"text":"Section 2371(h) of title 10","children":[],"tail":", referred to in subsec. (c), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tX/s1071/f/20"},"text":"Pub. L. 113–291, div. A, title X, § 1071(f)(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3511"},"text":"128 Stat. 3511","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id83cb6935-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id83cb6936-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Oversight and Government Reform of House of Representatives changed to Committee on Oversight and Reform of House of Representatives by House Resolution No. 6, One Hundred Sixteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":". Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, "},{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
