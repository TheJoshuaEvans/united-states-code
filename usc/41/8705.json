{"tag":"section","attrib":{"id":"id83ffe686-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8705"},"text":null,"children":[{"tag":"num","attrib":{"value":"8705"},"text":"§ 8705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative offsets","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83ffe687-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “contracting officer” has the meaning given that term in chapter 71 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83ffe688-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offset Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contracting officer of a contracting agency may offset the amount of a kickback provided, accepted, or charged in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s8702"},"text":"section 8702 of this title","children":[],"tail":" against amounts the Federal Government owes the prime contractor under the prime contract to which the kickback relates."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83ffe689-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8705/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties of Prime Contractor.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83ffe68a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8705/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Withholding and paying over or retaining amounts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"On direction of a contracting officer of a contracting agency with respect to a prime contract, the prime contractor shall withhold from amounts owed to a subcontractor under a subcontract of the prime contract the amount of a kickback which was or may be offset against the prime contractor under subsection (b). The contracting officer may order that amounts withheld—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83ffe68b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8705/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be paid over to the contracting agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83ffe68c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8705/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be retained by the prime contractor if the Federal Government has already offset the amount against the prime contractor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83ffe68d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8705/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The prime contractor shall notify the contracting officer when an amount is withheld and retained under paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83ffe68e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s8705/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offset, Direction, or Order is Claim of Federal Government","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An offset under subsection (b) or a direction or order of a contracting officer under subsection (c) is a claim by the Federal Government for the purposes of chapter 71 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83ffe68f-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3840"},"text":"124 Stat. 3840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83ffe690-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83ffe691-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83ffe692-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","