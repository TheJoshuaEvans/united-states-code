{"tag":"section","attrib":{"id":"id83d74f8a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302"},"text":null,"children":[{"tag":"num","attrib":{"value":"3302"},"text":"§ 3302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for purchase of property and services pursuant to multiple award contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83d74f8b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d74f8c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":" The term “executive agency” has the same meaning given in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s133"},"text":"section 133 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d74f8d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Individual purchase","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “individual purchase” means a task order, delivery order, or other purchase.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d74f8e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multiple award contract","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “multiple award contract” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d74f8f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contract that is entered into by the Administrator of General Services under the multiple award schedule program referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3012/3"},"text":"section 3012(3) of title 10","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d74f90-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a multiple award task order contract that is entered into under the authority of chapter 245 of title 10 or chapter 41 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d74f91-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other indefinite delivery, indefinite quantity contract that is entered into by the head of an executive agency with 2 or more sources pursuant to the same solicitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d74f92-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sole source task or delivery order","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “sole source task or delivery order” means any order that does not follow the competitive procedures in paragraph (2) or (3) of subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d74f93-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Acquisition Regulation shall require enhanced competition in the purchase of property and services by all executive agencies pursuant to multiple award contracts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d74f94-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content of Regulations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d74f95-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations required by subsection (b) shall provide that each individual purchase of property or services in excess of the simplified acquisition threshold that is made under a multiple award contract shall be made on a competitive basis unless a contracting officer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d74f96-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" waives the requirement on the basis of a determination that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83d74f97-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one of the circumstances described in paragraphs (1) to (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s4106/c"},"text":"section 4106(c) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3406/c"},"text":"section 3406(c) of title 10","children":[],"tail":" applies to the individual purchase; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83d74f98-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a law expressly authorizes or requires that the purchase be made from a specified source; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d74f99-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" justifies the determination in writing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d74f9a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Competitive basis procedures","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, an individual purchase of property or services is made on a competitive basis only if it is made pursuant to procedures that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d74f9b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require fair notice of the intent to make that purchase (including a description of the work to be performed and the basis on which the selection will be made) to be provided to all contractors offering the property or services under the multiple award contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d74f9c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" afford all contractors responding to the notice a fair opportunity to make an offer and have that offer fairly considered by the official making the purchase.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d74f9d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception to notice requirement.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d74f9e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding paragraph (2), and subject to subparagraph (B), notice may be provided to fewer than all contractors offering the property or services under a multiple award contract as described in subsection (a)(3)(A) if notice is provided to as many contractors as practicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d74f9f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on exception","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A purchase may not be made pursuant to a notice that is provided to fewer than all contractors under subparagraph (A) unless—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83d74fa0-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offers were received from at least 3 qualified contractors; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83d74fa1-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contracting officer of the executive agency determines in writing that no additional qualified contractors were able to be identified despite reasonable efforts to do so.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d74fa2-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Notice Requirements Related to Sole Source Task or Delivery Orders.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d74fa3-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public notice required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal Acquisition Regulation shall require the head of each executive agency to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d74fa4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish on FedBizOpps notice of all sole source task or delivery orders in excess of the simplified acquisition threshold that are placed against multiple award contracts not later than 14 days after the orders are placed, except in the event of extraordinary circumstances or classified orders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d74fa5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disclose the determination required by subsection (c)(1) related to sole source task or delivery orders in excess of the simplified acquisition threshold placed against multiple award contracts through the same mechanism and to the same extent as the disclosure of documents containing a justification and approval required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3204/e/1"},"text":"section 3204(e)(1) of title 10","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s3304/e/1"},"text":"section 3304(e)(1) of this title","children":[],"tail":", except in the event of extraordinary circumstances or classified orders."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d74fa6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection does not require the public availability of information that is exempt from public disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b"},"text":"section 552(b) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d74fa7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The regulations required by subsection (b) shall apply to all individual purchases of property or services that are made under multiple award contracts on or after the effective date of the regulations, without regard to whether the multiple award contracts were entered into before, on, or after the effective date.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d74fa8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3302/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commercial Leasing Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The regulations required by subsection (b) shall not apply to individual purchases for commercial leasing services that are made on a no cost basis and made under a multiple award contract awarded in accordance with the requirements for full and open competition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83d74fa9-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3746"},"text":"124 Stat. 3746","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/e/14"},"text":"Pub. L. 111–383, div. A, title X, § 1075(e)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4375"},"text":"124 Stat. 4375","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVIII/s893/b"},"text":"Pub. L. 116–92, div. A, title VIII, § 893(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1540"},"text":"133 Stat. 1540","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1702/h/12"},"text":"Pub. L. 117–81, div. A, title XVII, § 1702(h)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2158"},"text":"135 Stat. 2158","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83d74faa-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id83d74fab-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendment Not Shown in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section was derived from ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title VIII, § 863(a)–(e), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4547"},"text":"122 Stat. 4547","children":[],"tail":", which was set out as a note under section 253h of former Title 41, Public Contracts, prior to being repealed and reenacted by "},{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":", §§ 3, 7(b), "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3677"},"text":"124 Stat. 3677","children":[],"tail":", 3855. "},{"tag":"ref","attrib":{"href":"/us/pl/110/417/s863/b/3/A"},"text":"Section 863(b)(3)(A) of Pub. L. 110–417","children":[],"tail":" was restated as subsec. (c)(3)(A) of this section and subsequently amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/e/14"},"text":"Pub. L. 111–383, div. A, title X, § 1075(e)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4375"},"text":"124 Stat. 4375","children":[],"tail":". For applicability of that amendment to this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/a"},"text":"section 6(a) of Pub. L. 111–350","children":[],"tail":", set out as a Transitional and Savings Provisions note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s101"},"text":"section 101 of this title","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/110/417/s863/b/3/A"},"text":"Section 863(b)(3)(A) of Pub. L. 110–417","children":[],"tail":" was amended by striking “subsection (d)(2)(A)” and inserting “subsection (d)(3)(A)”. Such reference did not appear in the text of subsec. (c)(3)(A) as enacted. See Historical and Revision Notes below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id83d74fac-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal of Subsection (f)","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVIII/s893/b/2"},"text":"Pub. L. 116–92, div. A, title VIII, § 893(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1540"},"text":"133 Stat. 1540","children":[],"tail":" provided that, effective "},{"tag":"date","attrib":{"date":"2025-12-31"},"text":"Dec. 31, 2025","children":[],"tail":", subsection (f) of this section is repealed. See 2019 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83d74fad-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83d74fae-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{}