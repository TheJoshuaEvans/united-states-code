tions 2304a to 2304d of title 10,” in subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1702/h/12/B"},"text":"Pub. L. 117–81, § 1702(h)(12)(B)","children":[],"tail":", substituted “section 3406(c)” for “section 2304c(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1702/h/12/C"},"text":"Pub. L. 117–81, § 1702(h)(12)(C)","children":[],"tail":", substituted “section 3204(e)(1)” for “section 2304(f)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s893/b/2"},"text":"Pub. L. 116–92, § 893(b)(2)","children":[],"tail":", struck out subsec. (f). Text read as follows: “The regulations required by subsection (b) shall not apply to individual purchases for commercial leasing services that are made on a no cost basis and made under a multiple award contract awarded in accordance with the requirements for full and open competition.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s893/b/1"},"text":"Pub. L. 116–92, § 893(b)(1)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id83d74fb1-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id83d74fb2-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVIII/s893/b/2"},"text":"Pub. L. 116–9