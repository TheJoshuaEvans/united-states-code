{"tag":"section","attrib":{"id":"id83f64916-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7108"},"text":null,"children":[{"tag":"num","attrib":{"value":"7108"},"text":"§ 7108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of claims","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83f64917-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Judgments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any judgment against the Federal Government on a claim under this chapter shall be paid promptly in accordance with the procedures provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1304"},"text":"section 1304 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83f64918-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monetary Awards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any monetary award to a contractor by an agency board shall be paid promptly in accordance with the procedures contained in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83f64919-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7108/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Payments made pursuant to subsections (a) and (b) shall be reimbursed to the fund provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1304"},"text":"section 1304 of title 31","children":[],"tail":" by the agency whose appropriations were used for the contract out of available amounts or by obtaining additional appropriations for purposes of reimbursement."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83f6491a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7108/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tennessee Valley Authority.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83f6491b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7108/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Judgments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsections (a) to (c), any judgment against the Tennessee Valley Authority on a claim under this chapter shall be paid promptly in accordance with section 9(b) of the Tennessee Valley Authority Act of 1933 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s831h/b"},"text":"16 U.S.C. 831h(b)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f6491c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7108/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monetary awards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsections (a) to (c), any monetary award to a contractor by the board of contract appeals of the Tennessee Valley Authority shall be paid in accordance with section 9(b) of the Tennessee Valley Authority Act of 1933 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s831h/b"},"text":"16 U.S.C. 831h(b)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83f6491d-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3825"},"text":"124 Stat. 3825","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83f6491e-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83f6491f-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83f64920-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"childre