ub. L. 99–145, title XIII, § 1304(c)(4)(A)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/99/742"},"text":"99 Stat. 742","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “or quantities” are omitted because of 1:1.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
