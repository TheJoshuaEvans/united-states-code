{"tag":"section","attrib":{"id":"id83d9c0d9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3310"},"text":null,"children":[{"tag":"num","attrib":{"value":"3310"},"text":"§ 3310.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quantities to order","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83d9c0da-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3310/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Factors Affecting Quantity To Order","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each executive agency shall procure supplies in a quantity that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d9c0db-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3310/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will result in the total cost and unit cost most advantageous to the Federal Government, where practicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d9c0dc-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3310/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not exceed the quantity reasonably expected to be required by the agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d9c0dd-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3310/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offeror’s Opinion of Quantity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each solicitation for a contract for supplies shall, if practicable, include a provision inviting each offeror responding to the solicitation to state an opinion on whether the quantity of supplies proposed to be procured is economically advantageous to the Federal Government and, if applicable, to recommend a quantity that would be more economically advantageous to the Federal Government. Each recommendation shall include a quotation of the total price and the unit price for supplies procured in each recommended quantity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83d9c0de-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3761"},"text":"124 Stat. 3761","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83d9c0df-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83d9c0e0-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83d9c0e1-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},