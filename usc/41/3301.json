{"tag":"section","attrib":{"id":"id83d50681-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3301"},"text":null,"children":[{"tag":"num","attrib":{"value":"3301"},"text":"§ 3301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full and open competition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83d50682-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in sections 3303, 3304(a), and 3305 of this title and except in the case of procurement procedures otherwise expressly authorized by statute, an executive agency in conducting a procurement for property or services shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d50683-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3301/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain full and open competition through the use of competitive procedures in accordance with the requirements of this division and the Federal Acquisition Regulation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d50684-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3301/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the competitive procedure or combination of competitive procedures that is best suited under the circumstances of the procurement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d50685-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate Competitive Procedures.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d50686-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3301/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of sealed bids","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the competitive procedures appropriate under the circumstance, an executive agency shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d50687-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3301/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" solicit sealed bids if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83d50688-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3301/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" time permits the solicitation, submission, and evaluation of sealed bids;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83d50689-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3301/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the award will be made on the basis of price and other price-related factors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83d5068a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3301/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is not necessary to conduct discussions with the responding sources about their bids; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83d5068b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3301/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a reasonable expectation of receiving more than one sealed bid; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d5068c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3301/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" request competitive proposals if sealed bids are not appropriate under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d5068d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3301/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sealed bid not required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1)(A) does not require the use of sealed-bid procedures in cases in which section 204(e) ","children":[{"tag":"ref","attrib":{"idref":"fn002007"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002007"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 23 applies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d74f7e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Efficient Fulfillment of Government Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Acquisition Regulation shall ensure that the requirement to obtain full and open competition is implemented in a manner that is consistent with the need to efficiently fulfill the Federal Government’s requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83d74f7f-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3745"},"text":"124 Stat. 3745","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83d74f80-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83d74f81-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83d74f82-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:t