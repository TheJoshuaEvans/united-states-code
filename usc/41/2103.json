{"tag":"section","attrib":{"id":"id83cdd9ee-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2103"},"text":null,"children":[{"tag":"num","attrib":{"value":"2103"},"text":"§ 2103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions required of procurement officers when contacted regarding non-Federal employment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83cdd9ef-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agency official participating personally and substantially in a Federal agency procurement for a contract in excess of the simplified acquisition threshold who contacts or is contacted by a person that is a bidder or offeror in that Federal agency procurement regarding possible non-Federal employment for that official shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83cdd9f0-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promptly report the contact in writing to the official’s supervisor and to the designated agency ethics official (or designee) of the agency in which the official is employed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cdd9f1-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83cdd9f2-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2103/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reject the possibility of non-Federal employment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cdd9f3-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2103/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" disqualify himself or herself from further personal and substantial participation in that Federal agency procurement until the agency authorizes the official to resume participation in the procurement, in accordance with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s208"},"text":"section 208 of title 18","children":[],"tail":" and applicable agency regulations on the grounds that—"}],"tail":null},{"tag":"clause","attrib":{"id":"id83cdd9f4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2103/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person is no longer a bidder or offeror in that Federal agency procurement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83cdd9f5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2103/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all discussions with the bidder or offeror regarding possible non-Federal employment have terminated without an agreement or arrangement for employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83cdd9f6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention of Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The agency shall retain each report required by this section for not less than 2 years following the submission of the report. The reports shall be made available to the public on request, except that any part of a report that is exempt from the disclosure requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":" under subsection (b)(1) of that section may be withheld from disclosure to the public."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83cdd9f7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Persons Subject to Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following are subject to the penalties and administrative actions set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s2105"},"text":"section 2105 of this title","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83cdd9f8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An official who knowingly fails to comply with the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cdd9f9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A bidder or offeror that engages in employment discussions with an official who is subject to the restrictions of this section, knowing that the official has not complied with paragraph (1) or (2) of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83cdd9fa-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3728"},"text":"124 Stat. 3728","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83cdd9fb-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83cdd9fc-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83cdd9fd-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},