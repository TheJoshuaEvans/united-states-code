{"tag":"section","attrib":{"id":"id83c6adf7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1705"},"text":null,"children":[{"tag":"num","attrib":{"value":"1705"},"text":"§ 1705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advocates for competition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83c6adf8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment and Designation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83c6adf9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1705/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each executive agency has an advocate for competition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6adfa-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1705/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of each executive agency shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83c6adfb-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1705/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate for the executive agency and for each procuring activity of the executive agency one officer or employee serving in a position authorized for the executive agency on ","children":[{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":" (other than the senior procurement executive designated pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s1702/c"},"text":"section 1702(c) of this title","children":[],"tail":") to serve as the advocate for competition;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6adfc-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1705/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not assign those officers or employees duties or responsibilities that are inconsistent with the duties and responsibilities of the advocates for competition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6adfd-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1705/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide those officers or employees with the staff or assistance necessary to carry out the duties and responsibilities of the advocate for competition, such as individuals who are specialists in engineering, technical operations, contract administration, financial management, supply management, and utilization of small and disadvantaged business concerns.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c6adfe-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties and Functions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The advocate for competition of an executive agency shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83c6adff-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1705/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be responsible for challenging barriers to, and promoting full and open competition in, the procurement of property and services by the executive agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6ae00-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1705/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the procurement activities of the executive agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6ae01-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1705/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify and report to the senior procurement executive of the executive agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83c6ae02-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1705/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunities and actions taken to achieve full and open competition in the procurement activities of the executive agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6ae03-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1705/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any condition or action which has the effect of unnecessarily restricting competition in the procurement actions of the executive agency;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6ae04-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1705/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prepare and transmit to the senior procurement executive an annual report describing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83c6ae05-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1705/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the advocate’s activities under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6ae06-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1705/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new initiatives required to increase competition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6ae07-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1705/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remaining barriers to full and open competition;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6ae08-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1705/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommend to the senior procurement executive—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83c6ae09-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1705/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" goals and the plans for increasing competition on a fiscal year basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6ae0a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1705/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a system of personal and organizational accountability for competition, which may include the use of recognition and awards to motivate program managers, contracting officers, and others in authority to promote competition in procurement programs; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6ae0b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1705/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe other ways in which the executive agency has emphasized competition in programs for procurement training and research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c6ae0c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1705/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The advocate for competition for each procuring activity is responsible for promoting full and open competition, promoting the acquisition of commercial products and commercial services, and challenging barriers to acquisition, including unnecessarily restrictive statements of need, unnecessarily detailed specifications, and unnecessarily burdensome contract clauses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83c6ae0d-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3709"},"text":"124 Stat. 3709","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s836/b/2"},"text":"Pub. L. 115–232, div. A, title VIII, § 836(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1861"},"text":"132 Stat. 1861","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83c6ae0e-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83c6ae0f-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83c6ae10-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","chi