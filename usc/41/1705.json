":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id83c6ae11-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id83c6ae12-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “commercial products and commercial services” for “commercial items”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id83c6ae13-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id83c6ae14-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2020-01-01"},"text":"Jan. 1, 2020","children":[],"tail":", subject to a savings provision, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s836/h"},"text":"section 836(h) of Pub. L. 115–232","children":[],"tail":", set out as an Effective Date of 2018 Amendment; Savings Provision note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s453b"},"text":"section 453b of Title 6","children":[],"tail":", Domestic Security.