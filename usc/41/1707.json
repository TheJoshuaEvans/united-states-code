{"tag":"section","attrib":{"id":"id83c6ae1f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1707"},"text":null,"children":[{"tag":"num","attrib":{"value":"1707"},"text":"§ 1707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of proposed regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83c6ae20-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Policies, Regulations, Procedures, and Forms.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83c6ae21-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1707/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required comment period","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (d), a procurement policy, regulation, procedure, or form (including an amendment or modification thereto) may not take effect until 60 days after it is published for public comment in the Federal Register pursuant to subsection (b) if it—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83c6ae22-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1707/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relates to the expenditure of appropriated funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6ae23-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1707/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83c6ae24-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1707/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a significant effect beyond the internal operating procedures of the agency issuing the policy, regulation, procedure, or form; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83c6ae25-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1707/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a significant cost or administrative impact on contractors or offerors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6ae26-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1707/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A policy, regulation, procedure, or form may take effect earlier than 60 days after the publication date when there are compelling circumstances for the earlier effective date, but the effective date may not be less than 30 days after the publication date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c6ae27-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1707/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication in Federal Register and Comment Period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (c), the head of the agency shall have published in the Federal Register a notice of the proposed procurement policy, regulation, procedure, or form and provide for a public comment period for receiving and considering the views of all interested parties on the proposal. The length of the comment period may not be less than 30 days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c6ae28-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1707/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of Notice","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notice of a proposed procurement policy, regulation, procedure, or form prepared for publication in the Federal Register shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83c6ae29-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1707/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the text of the proposal or, if it is impracticable to publish the full text of the proposal, a summary of the proposal and a statement specifying the name, address, and telephone number of the officer or employee of the executive agency from whom the full text may be obtained; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6ae2a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1707/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a request for interested parties to submit comments on the proposal and the name and address of the officer or employee of the Federal Government designated to receive the comments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c6ae2b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1707/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirements of subsections (a) and (b) may be waived by the officer authorized to issue a procurement policy, regulation, procedure, or form if urgent and compelling circumstances make compliance with the requirements impracticable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83c6ae2c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1707/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effectiveness of Policy, Regulation, Procedure, or Form.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83c6ae2d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1707/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Temporary basis","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A procurement policy, regulation, procedure, or form for which the requirements of subsections (a) and (b) are waived under subsection (d) is effective on a temporary basis if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83c6ae2e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1707/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a notice of the policy, regulation, procedure, or form is published in the Federal Register and includes a statement that the policy, regulation, procedure, or form is temporary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83c6ae2f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1707/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provision is made for a public comment period of 30 days beginning on the date on which the notice is published.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83c6ae30-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1707/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Final policy, regulation, procedure, or form","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After considering the comments received, the head of the agency waiving the requirements of subsections (a) and (b) under subsection (d) may issue the final procurement policy, regulation, procedure, or form.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83c6ae31-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3710"},"text":"124 Stat. 3710","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83c6ae32-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83c6ae33-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83c6ae34-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1707","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:418b.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/93/400/s22"},"text":"Pub. L. 93–400, § 22","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/98/577/tIII/s302/a"},"text":"Pub. L. 98–577, title III, § 302(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/3076"},"text":"98 Stat. 3076","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/103/355/tV/s5092"},"text":"Pub. L. 103–355, title V, § 5092","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/108/3362"},"text":"108 Stat. 3362","children":[],"tail":", as amended "},{"tag":"html:a","attrib":{"href":"/us/pl/104/106/tXLIII/s4321/a/9"},"text":"Pub. L. 104–106, title XLIII, § 4321(a)(9)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/671"},"text":"110 Stat. 671","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “Notwithstanding the preceding sentence” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
