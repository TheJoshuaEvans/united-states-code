{"tag":"section","attrib":{"id":"id83cdd9c1-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2101"},"text":null,"children":[{"tag":"num","attrib":{"value":"2101"},"text":"§ 2101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83cdd9c2-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracting officer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “contracting officer” means an individual who, by appointment in accordance with applicable regulations, has the authority to enter into a Federal agency procurement contract on behalf of the Government and to make determinations and findings with respect to the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cdd9c3-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contractor bid or proposal information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “contractor bid or proposal information” means any of the following information submitted to a Federal agency as part of, or in connection with, a bid or proposal to enter into a Federal agency procurement contract, if that information previously has not been made available to the public or disclosed publicly:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83cdd9c4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2101/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cost or pricing data (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3701"},"text":"section 3701 of title 10","children":[],"tail":" with respect to procurements subject to that section and "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s3501/a"},"text":"section 3501(a) of this title","children":[],"tail":" with respect to procurements subject to that section)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cdd9c5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2101/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indirect costs and direct labor rates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cdd9c6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2101/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Proprietary information about manufacturing processes, operations, or techniques marked by the contractor in accordance with applicable law or regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cdd9c7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2101/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information marked by the contractor as “contractor bid or proposal information”, in accordance with applicable law or regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cdd9c8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2101/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Federal agency” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s102"},"text":"section 102 of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cdd9c9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2101/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal agency procurement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Federal agency procurement” means the acquisition (by using competitive procedures and awarding a contract) of goods or services (including construction) from non-Federal sources by a Federal agency using appropriated funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cdd9ca-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2101/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Official","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “official” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83cdd9cb-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2101/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2104"},"text":"section 2104 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cdd9cc-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2101/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cdd9cd-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2101/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the uniformed services, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2101/3"},"text":"section 2101(3) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cdd9ce-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2101/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protest","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “protest” means a written objection by an interested party to the award or proposed award of a Federal agency procurement contract, pursuant to subchapter V of chapter 35 of title 31.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cdd9cf-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2101/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Source selection information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “source selection information” means any of the following information prepared for use by a Federal agency to evaluate a bid or proposal to enter into a Federal agency procurement contract, if that information previously has not been made available to the public or disclosed publicly:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83cdd9d0-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2101/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Bid prices submitted in response to a Federal agency solicitation for sealed bids, or lists of those bid prices before public bid opening.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cdd9d1-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2101/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Proposed costs or prices submitted in response to a Federal agency solicitation, or lists of those proposed costs or prices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cdd9d2-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2101/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Source selection plans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cdd9d3-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2101/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Technical evaluation plans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cdd9d4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2101/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Technical evaluations of proposals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cdd9d5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2101/7/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cost or price evaluations of proposals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cdd9d6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2101/7/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Competitive range determinations that identify proposals that have a reasonable chance of being selected for award of a contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cdd9d7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2101/7/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rankings of bids, proposals, or competitors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cdd9d8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2101/7/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reports and evaluations of source selection panels, boards, or advisory councils.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cdd9d9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2101/7/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other information marked as “source selection information” based on a case-by-case determination by the head of the agency, the head’s designee, or the contracting officer that its disclosure would jeopardize the integrity or successful completion of the Federal agency procurement to which the information relates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83cdd9da-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3727"},"text":"124 Stat. 3727","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1702/h/10"},"text":"Pub. L. 117–81, div. A, title XVII, § 1702(h)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2158"},"text":"135 Stat. 2158","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83cdd9db-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83cdd9dc-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83cdd9dd-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"