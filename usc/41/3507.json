{"tag":"section","attrib":{"id":"id83dc0b76-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3507"},"text":null,"children":[{"tag":"num","attrib":{"value":"3507"},"text":"§ 3507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest and penalties for certain overpayments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83dc0b77-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Federal Government makes an overpayment to a contractor under a contract with an executive agency subject to this chapter and the overpayment was due to the submission by the contractor of defective cost or pricing data, the contractor shall be liable to the Federal Government—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83dc0b78-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3507/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for interest on the amount of the overpayment, to be computed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83dc0b79-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3507/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the period beginning on the date the overpayment was made to the contractor and ending on the date the contractor repays the amount of the overpayment to the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83dc0b7a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3507/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the current rate prescribed by the Secretary of the Treasury under section 6621 of the Internal Revenue Code of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6621"},"text":"26 U.S.C. 6621","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83dc0b7b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3507/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the submission of the defective data was a knowing submission, for an additional amount equal to the amount of the overpayment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83dc0b7c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liability Not Affected by Refusal To Submit Certification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any liability under this section of a contractor that submits cost or pricing data but refuses to submit the certification required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3502/b"},"text":"section 3502(b) of this title","children":[],"tail":" with respect to the cost or pricing data is not affected by the refusal to submit the certification."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83dc0b7d-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3769"},"text":"124 Stat. 3769","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83dc0b7e-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83dc0b7f-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83dc0b80-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","chi