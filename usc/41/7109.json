{"tag":"section","attrib":{"id":"id83f64921-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7109"},"text":null,"children":[{"tag":"num","attrib":{"value":"7109"},"text":"§ 7109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83f64922-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83f64923-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7109/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Interest on an amount found due a contractor on a claim shall be paid to the contractor for the period beginning with the date the contracting officer receives the contractor’s claim, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s7103/a"},"text":"section 7103(a) of this title","children":[],"tail":", until the date of payment of the claim."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83f64924-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7109/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defective certification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On a claim for which the certification under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s7103/b/1"},"text":"section 7103(b)(1) of this title","children":[],"tail":" is found to be defective, any interest due under this section shall be paid for the period beginning with the date the contracting officer initially receives the contractor’s claim until the date of payment of the claim."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83f64925-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s7109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Interest shall accrue and be paid at a rate which the Secretary of the Treasury shall specify as applicable for each successive 6-month period. The rate shall be determined by the Secretary of the Treasury taking into consideration current private commercial rates of interest for new loans maturing in approximately 5 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83f64926-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3825"},"text":"124 Stat. 3825","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83f64927-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83f64928-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83f64929-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7109(a)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:611 (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/95/563/s12"},"text":"Pub. L. 95–563, § 12","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/2389"},"text":"92 Stat. 2389","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7109(a)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:611 note.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/102/572/tIX/s907/a/3"},"text":"Pub. L. 102–572, title IX, § 907(a)(3)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/4518"},"text":"106 Stat. 4518","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7109(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:611 (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “on or after the date of the enactment of this Act”, “the later of”, and “or the date of the enactment of this Act” are omitted as obsolete.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) is substituted for “The interest provided for in this section shall be paid at the rate established by the Secretary of the Treasury pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/41"},"text":"Public Law 92–41","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/85/97"},"text":"85 Stat. 97","children":[],"tail":") for the Renegotiation Board” to eliminate obsolete language and to codify the criteria under which the interest rate is computed. "},{"tag":"ref","attrib":{"href":"/us/act/1971-07-01/s2/a/3"},"text":"Section 2(a)(3) of the Act of July 1, 1971","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/92/41"},"text":"Pub. L. 92–41","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/97"},"text":"85 Stat. 97","children":[],"tail":"), amended section 105(b)(2) of the Renegotiation Act of 1951 ("},{"tag":"ref","attrib":{"href":"/us/act/1951-03-23/ch15"},"text":"Mar. 23, 1951, ch. 15","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/13"},"text":"65 Stat. 13","children":[],"tail":") by adding provisions substantially similar to those enacted here. However, the Renegotiation Act of 1951 ("},{"tag":"ref","attrib":{"href":"/us/act/1951-03-23/ch15"},"text":"Mar. 23, 1951, ch. 15","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/7"},"text":"65 Stat. 7","children":[],"tail":") was omitted from the Code pursuant to section 102(c)(1) of the Act ("},{"tag":"ref","attrib":{"href":"/us/stat/65/8"},"text":"65 Stat. 8","children":[],"tail":"), amended several times, the last being "},{"tag":"ref","attrib":{"href":"/us/pl/94/185"},"text":"Public Law 94–185","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/89/1061"},"text":"89 Stat. 1061","children":[],"tail":"), which provided that most provisions of that Act do not apply to receipts and accruals attributable to contract performance after "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"September 30, 1976","children":[],"tail":", and in view of the termination of the Renegotiation Board and the transfer of property and records of the Board to the Administrator of the General Services Administration on "},{"tag":"date","attrib":{"date":"1979-03-31"},"text":"March 31, 1979","children":[],"tail":", pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/95/431"},"text":"Public Law 95–431","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/92/1043"},"text":"92 Stat. 1043","children":[],"tail":"). Although the Renegotiation Board is no longer in existence, Federal agencies, including the General Services Administration, are required to use interest rates that are computed under the criteria set out in this subsection. See 31:3902(a) and the website of the Bureau of the Public Debt, available at http://www.publicdebt.treas.gov/opd/opdprmt2.htm. For an example of publication of rates under the criteria enacted here, see Federal Register, volume 67, number 247, page 78566, "},{"tag":"date","attrib":{"date":"2002-12-24"},"text":"December 24, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
