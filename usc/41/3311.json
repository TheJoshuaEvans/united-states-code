{"tag":"section","attrib":{"id":"id83d9c0e2-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311"},"text":null,"children":[{"tag":"num","attrib":{"value":"3311"},"text":"§ 3311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualification requirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83d9c0e3-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “qualification requirement” means a requirement for testing or other quality assurance demonstration that must be completed by an offeror before award of a contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d9c0e4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions Before Enforcing Qualification Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c), the head of an agency, before enforcing any qualification requirement, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d9c0e5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare a written justification stating the necessity for establishing the qualification requirement and specify why the qualification requirement must be demonstrated before contract award;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d9c0e6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify in writing and make available to a potential offeror on request all requirements that a prospective offeror, or its product, must satisfy to become qualified, with those requirements to be limited to those least restrictive to meet the purposes necessitating the establishment of the qualification requirement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d9c0e7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify an estimate of the cost of testing and evaluation likely to be incurred by a potential offeror to become qualified;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d9c0e8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that a potential offeror is provided, on request, a prompt opportunity to demonstrate at its own expense (except as provided in subsection (d)) its ability to meet the standards specified for qualification using—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d9c0e9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" qualified personnel and facilities—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83d9c0ea-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the agency concerned;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83d9c0eb-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of another agency obtained through interagency agreement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83d9c0ec-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/b/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under contract; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d9c0ed-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other methods approved by the agency (including use of approved testing and evaluation services not provided under contract to the agency);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d9c0ee-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if testing and evaluation services are provided under contract to the agency for the purposes of paragraph (4), provide to the extent possible that those services be provided by a contractor that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d9c0ef-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not expected to benefit from an absence of additional qualified sources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d9c0f0-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is required in the contract to adhere to any restriction on technical data asserted by the potential offeror seeking qualification; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d9c0f1-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that a potential offeror seeking qualification is promptly informed whether qualification is attained and, if not attained, is promptly furnished specific information about why qualification was not attained.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d9c0f2-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability, Waiver Authority, and Referral of Offers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d9c0f3-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (b) does not apply to a qualification requirement established by statute prior to ","children":[{"tag":"date","attrib":{"date":"1984-10-30"},"text":"October 30, 1984","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d9c0f4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver authority.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d9c0f5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission of determination of unreasonableness","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subparagraph (C), if it is unreasonable to specify the standards for qualification that a prospective offeror or its product must satisfy, a determination to that effect shall be submitted to the advocate for competition of the procuring activity responsible for the purchase of the item subject to the qualification requirement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d9c0f6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to grant waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After considering any comments of the advocate for competition reviewing the determination, the head of the procuring activity may waive the requirements of paragraphs (2) to (5) of subsection (b) for up to 2 years with respect to the item subject to the qualification requirement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d9c0f7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplicability to qualified products list","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Waiver authority under this paragraph does not apply with respect to a qualified products list.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d9c0f8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission and consideration of offer not to be denied","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A potential offeror may not be denied the opportunity to submit and have considered an offer for a contract solely because the potential offeror has not been identified as meeting a qualification requirement if the potential offeror can demonstrate to the satisfaction of the contracting officer that the potential offeror or its product meets the standards established for qualification or can meet those standards before the date specified for award of the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d9c0f9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Referral to small business administration not required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection does not require the referral of an offer to the Small Business Administration pursuant to section 8(b)(7) of the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/b/7"},"text":"15 U.S.C. 637(b)(7)","children":[],"tail":") if the basis for the referral is a challenge by the offeror to either the validity of the qualification requirement or the offeror’s compliance with that requirement."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d9c0fa-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delay of procurement not required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an agency need not delay a proposed procurement to comply with subsection (b) or to provide a potential offeror with an opportunity to demonstrate its ability to meet the standards specified for qualification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d9c0fb-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fewer Than","children":[],"tail":" 2 "},{"tag":"inline","attrib":{},"text":"Actual Manufacturers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d9c0fc-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Solicitation and testing of additional sources or products","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the number of qualified sources or qualified products available to compete actively for an anticipated future requirement is fewer than 2 actual manufacturers or the products of 2 actual manufacturers, respectively, the head of the agency concerned shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d9c0fd-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish notice periodically soliciting additional sources or products to seek qualification, unless the contracting officer determines that doing so would compromise national security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d9c0fe-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to paragraph (2), bear the cost of conducting the specified testing and evaluation (excluding the cost associated with producing the item or establishing the production, quality control, or other system to be tested and evaluated) for a small business concern or a product manufactured by a small business concern that has met the standards specified for qualification and that could reasonably be expected to compete for a contract for that requirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83dc0aef-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"When agency may bear cost","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of the agency concerned may bear the cost under paragraph (1)(B) only if the head of the agency determines that the additional qualified sources or products are likely to result in cost savings from increased competition for future requirements sufficient to offset (within a reasonable period of time considering the duration and dollar value of anticipated future requirements) the cost incurred by the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83dc0af0-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of the agency shall require a prospective contractor requesting the Federal Government to bear testing and evaluation costs under paragraph (1)(B) to certify its status as a small business concern under section 3 of the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632"},"text":"15 U.S.C. 632","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83dc0af1-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Examination and Revalidation of Qualification Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Within 7 years after the establishment of a qualification requirement, the need for the requirement shall be examined and the standards of the requirement revalidated in accordance with the requirements of subsection (b). This subsection does not apply in the case of a qualification requirement for which a waiver is in effect under subsection (c)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83dc0af2-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3311/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"When Enforcement of Qualification Requirement Not Allowed","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except in an emergency as determined by the head of the agency, after the head of the agency determines not to enforce a qualification requirement for a solicitation, the agency may not enforce the requirement unless the agency complies with the requirements of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83dc0af3-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3761"},"text":"124 Stat. 3761","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83dc0af4-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83dc0af5-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83dc0af6-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3311","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:253c.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title III, § 303C, formerly § 303D, as added "},{"tag":"html:a","attrib":{"href":"/us/pl/98/577/tII/s202/a"},"text":"Pub. L. 98–577, title II, § 202(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/3069"},"text":"98 Stat. 3069","children":[],"tail":"; renumbered § 303C, "},{"tag":"html:a","attrib":{"href":"/us/pl/99/145/tXIII/s1304/c/4/A"},"text":"Pub. L. 99–145, title XIII, § 1304(c)(4)(A)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/99/742"},"text":"99 Stat. 742","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(1)(A), the words “in the Commerce Business Daily” are omitted as obsolete. See revision note for section 1708(d) of the revised title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
