:"html:a","attrib":{"href":"/us/stat/122/63"},"text":"122 Stat. 63","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the heading for subsection (d) and in subsection (d)(2), the words “disabled people” are substituted for “handicapped persons” for consistency with chapter 85 of the revised title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
