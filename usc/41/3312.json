{"tag":"section","attrib":{"id":"id83dc0af7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3312"},"text":null,"children":[{"tag":"num","attrib":{"value":"3312"},"text":"§ 3312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Database on price trends of items and services under Federal contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83dc0af8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Database Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall establish and maintain a database of information on price trends for items and services under contracts with the Federal Government. The information in the database shall be designed to assist Federal acquisition officials in the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83dc0af9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3312/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Monitoring developments in price trends for items and services under contracts with the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83dc0afa-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3312/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conducting price or cost analyses for items and services under offers for contracts with the Federal Government, or otherwise conducting determinations of the reasonableness of prices for items and services under such offers, and addressing unjustified escalation in prices being paid by the Federal Government for items and services under contracts with the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83dc0afb-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83dc0afc-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3312/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The database under subsection (a) shall be available to executive agencies in the evaluation of offers for contracts with the Federal Government for items and services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83dc0afd-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s3312/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may satisfy the requirements of this section by complying with the requirements of section 892 ","children":[{"tag":"ref","attrib":{"idref":"fn002008"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002008"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Ike Skelton National Defense Authorization Act for Fiscal Year 2011 ("},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2306a"},"text":"10 U.S.C. 2306a","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83dc0afe-3a70-11f1-ab1a-a784e0a454e2"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tVIII/s851/a/1"},"text":"Pub. L. 112–239, div. A, title VIII, § 851(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1855"},"text":"126 Stat. 1855","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83dc0aff-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id83dc0b00-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id83dc0b01-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 892 of the Ike Skelton National Defense Authorization Act for Fiscal Year 2011, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s892"},"text":"section 892 of Pub. L. 111–383","children":[],"tail":", which was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2306a"},"text":"section 2306a of Title 10","children":[],"tail":", Armed Forces, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tX/s1073/f"},"text":"Pub. L. 114–92, div. A, title X, § 1073(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/996"},"text":"129 Stat. 996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id83dc0b02-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id83dc0b03-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Use of Elements of Department of Defense Pilot Project","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tVIII/s851/b"},"text":"Pub. L. 112–239, div. A, title VIII, § 851(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1855"},"text":"126 Stat. 1855","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/239/dA/tVIII/s851/b"},"text":"“In establishing the database required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3312"},"text":"section 3312 of title 41","children":[],"tail":", United States Code (as added by subsection (a)), the Administrator for Federal Procurement Policy shall use and incorporate appropriate elements of the pilot project on pricing being carried out by the Under Secretary of Defense for Acquisition, Technology, and Logistics pursuant to section 892 of the Ike Skelton National Defense Authorization Act for Fiscal Year 2011 ["},{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":"] ("},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2306a"},"text":"10 U.S.C. 2306a","children":[],"tail":" note) and the Better Buying Power initiative of the Secretary of Defense.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
