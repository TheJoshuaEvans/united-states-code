{"tag":"section","attrib":{"id":"id83cdd9e0-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2102"},"text":null,"children":[{"tag":"num","attrib":{"value":"2102"},"text":"§ 2102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions on disclosing and obtaining procurement information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83cdd9e1-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Disclosing Procurement Information.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83cdd9e2-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided by law, a person described in paragraph (3) shall not knowingly disclose contractor bid or proposal information or source selection information before the award of a Federal agency procurement contract to which the information relates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cdd9e3-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employee of private sector organization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to the restriction in paragraph (1), an employee of a private sector organization assigned to an agency under chapter 37 of title 5 shall not knowingly disclose contractor bid or proposal information or source selection information during the 3-year period after the employee’s assignment ends, except as provided by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83cdd9e4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2102/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) applies to a person that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83cdd9e5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2102/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83cdd9e6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2102/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a present or former official of the Federal Government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83cdd9e7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2102/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is acting or has acted for or on behalf of, or who is advising or has advised the Federal Government with respect to, a Federal agency procurement; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83cdd9e8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2102/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by virtue of that office, employment, or relationship has or had access to contractor bid or proposal information or source selection information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83cdd9e9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Obtaining Procurement Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided by law, a person shall not knowingly obtain contractor bid or proposal information or source selection information before the award of a Federal agency procurement contract to which the information relates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83cdd9ea-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3728"},"text":"124 Stat. 3728","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83cdd9eb-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83cdd9ec-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83cdd9ed-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[