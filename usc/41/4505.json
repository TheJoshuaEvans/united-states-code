{"tag":"section","attrib":{"id":"id83e818ac-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4505"},"text":null,"children":[{"tag":"num","attrib":{"value":"4505"},"text":"§ 4505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments for commercial products and commercial services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83e818ad-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms and Conditions for Payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s4501"},"text":"section 4501 of this title","children":[],"tail":" for commercial products or commercial services may be made under terms and conditions that the head of the executive agency determines are appropriate or customary in the commercial marketplace and are in the best interests of the Federal Government."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e818ae-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Security for Payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of the executive agency shall obtain adequate security for the payments. If the security is in the form of a lien in favor of the Federal Government, the lien is paramount to all other liens and is effective immediately on the first payment, without filing, notice, or other action by the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e818af-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4505/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Advance Payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Advance payments made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s4501"},"text":"section 4501 of this title","children":[],"tail":" for commercial products or commercial services may include payments, in a total amount not more than 15 percent of the contract price, in advance of any performance of work under the contract."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83e818b0-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s4505/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication of Certain Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The conditions of sections 4503 and 4504 of this title need not be applied if they would be inconsistent, as determined by the head of the executive agency, with commercial terms and conditions pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83e818b1-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3791"},"text":"124 Stat. 3791","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s836/b/18/A"},"text":"Pub. L. 115–232, div. A, title VIII, § 836(b)(18)(A)","children":[],"tail":", (B)(i), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1864"},"text":"132 Stat. 1864","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83e818b2-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83e818b3-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83e818b4-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}]