{"tag":"section","attrib":{"id":"id83bac767-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201"},"text":null,"children":[{"tag":"num","attrib":{"value":"1201"},"text":"§ 1201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Acquisition Institute","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83bac768-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established a Federal Acquisition Institute (FAI) in order to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83bac769-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foster and promote the development of a professional acquisition workforce Government-wide;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bac76a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote and coordinate Government-wide research and studies to improve the procurement process and the laws, policies, methods, regulations, procedures, and forms relating to acquisition by the executive agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bac76b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect data and analyze acquisition workforce data from the Office of Personnel Management, the heads of executive agencies, and, through periodic surveys, from individual employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bac76c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodically analyze acquisition career fields to identify critical competencies, duties, tasks, and related academic prerequisites, skills, and knowledge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bac76d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate and assist agencies in identifying and recruiting highly qualified candidates for acquisition fields;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bac76e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop instructional materials for acquisition personnel in coordination with private and public acquisition colleges and training facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bac76f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the effectiveness of training and career development programs for acquisition personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bac770-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the establishment and utilization of academic programs by colleges and universities in acquisition fields;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bac771-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate, to the extent requested by agencies, interagency intern and training programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bac772-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with other civilian agency acquisition training programs to leverage training supporting all members of the civilian agency acquisition workforce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bac773-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist civilian agencies with their acquisition and capital planning efforts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bac774-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform other career management or research functions as directed by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83bac775-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Budget Resources and Authority.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83bac776-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall recommend to the Administrator of General Services sufficient budget resources and authority for the Federal Acquisition Institute to support Government-wide training standards and certification requirements necessary to enhance the mobility and career opportunities of the Federal acquisition workforce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bac777-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisition workforce training fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the availability of funds, the Administrator of General Services shall provide the Federal Acquisition Institute with amounts from the acquisition workforce training fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1703/i"},"text":"section 1703(i) of this title","children":[],"tail":" sufficient to meet the annual budget for the Federal Acquisition Institute requested by the Administrator under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83bac778-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Acquisition Institute Board of Directors.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83bac779-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting to administrator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Acquisition Institute shall report through its Board of Directors directly to the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bac77a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Composition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board shall be composed of not more than 8 individuals from the Federal Government representing a mix of acquisition functional areas, all of whom shall be appointed by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bac77b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall provide general direction to the Federal Acquisition Institute to ensure that the Institute—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83bac77c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets its statutory requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bac77d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the needs of the Federal acquisition workforce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bac77e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implements appropriate programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bac77f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinates with appropriate organizations and groups that have an impact on the Federal acquisition workforce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bac780-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develops and implements plans to meet future challenges of the Federal acquisition workforce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83bac781-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" works closely with the Defense Acquisition University.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83bac782-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board shall make recommendations to the Administrator regarding the development and execution of the annual budget of the Federal Acquisition Institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83bac783-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Federal Acquisition Institute shall be appointed by, be subject to the direction and control of, and report directly to the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83bac784-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s1201/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall submit to the Committee on Homeland Security and Governmental Affairs and the Committee on Appropriations of the Senate and the Committee on Oversight and Government Reform and the Committee on Appropriations of the House of Representatives an annual report on the projected budget needs and expense plans of the Federal Acquisition Institute to fulfill its mandate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83bac785-3a70-11f1-ab1a-a784e0a454e2"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVIII/s864/b/1"},"text":"Pub. L. 112–81, div. A, title VIII, § 864(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1523"},"text":"125 Stat. 1523","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83bac786-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id83bac787-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id83bac788-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Oversight and Government Reform of House of Representatives changed to Committee on Oversight and Reform of House of Representatives by House Resolution No. 6, One Hundred Sixteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":". Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, "},{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id83bac789-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVIII/s864/e"},"text":"Pub. L. 112–81, div. A, title VIII, § 864(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1525"},"text":"125 Stat. 1525","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/81/dA/tVIII/s864/e"},"text":"“Nothing in this section [enacting this chapter and amending sections 1122, 1703, and 1704 of this title], or the amendments made by this section, shall be construed to preclude the Secretary of Defense from establishing acquisition workforce policies, procedures, training standards, and certification requirements for acquisition positions in the Department of Defense, as provided in chapter 87 of title 10, United States Code.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id83bac78a-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Training Course on Human Trafficking and Government Contracting","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/425/tI/s113"},"text":"Pub. L. 115–425, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-08"},"text":"Jan. 8, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5477"},"text":"132 Stat. 5477","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/425/tI/s113"},"text":"“Any curriculum, including any continuing education curriculum, for the acquisition workforce used by the Federal Acquisition Institute established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1201"},"text":"section 1201 of title 41","children":[],"tail":", United States Code, shall include at least 1 course, lasting at least 30 minutes, regarding the law and regulations relating to human trafficking and contracting with the Federal Government.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
