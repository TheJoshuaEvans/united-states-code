{"tag":"section","attrib":{"id":"id83d294ef-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313"},"text":null,"children":[{"tag":"num","attrib":{"value":"2313"},"text":"§ 2313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Database for Federal agency contract and grant officers and suspension and debarment officials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id83d294f0-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the authority, direction, and control of the Director of the Office of Management and Budget, the Administrator of General Services shall establish and maintain a database of information regarding the integrity and performance of certain persons awarded Federal agency contracts and grants for use by Federal agency officials having authority over contracts and grants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d294f1-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Persons Covered","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The database shall cover the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d294f2-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person awarded a Federal agency contract or grant in excess of $500,000, if any information described in subsection (c) exists with respect to the person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d294f3-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person awarded such other category or categories of Federal agency contract as the Federal Acquisition Regulation may provide, if any information described in subsection (c) exists with respect to the person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d294f4-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information Included","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a covered person, the database shall include information (in the form of a brief description) for the most recent 5-year period regarding the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d294f5-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each civil or criminal proceeding, or any administrative proceeding, in connection with the award or performance of a contract or grant with the Federal Government with respect to the person during the period to the extent that the proceeding results in the following dispositions:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d294f6-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In a criminal proceeding, a conviction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d294f7-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In a civil proceeding, a finding of fault and liability that results in the payment of a monetary fine, penalty, reimbursement, restitution, or damages of $5,000 or more.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d294f8-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In an administrative proceeding, a finding of fault and liability that results in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83d294f9-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment of a monetary fine or penalty of $5,000 or more; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83d294fa-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment of a reimbursement, restitution, or damages in excess of $100,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d294fb-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the maximum extent practicable and consistent with applicable laws and regulations, in a criminal, civil, or administrative proceeding, a disposition of the matter by consent or compromise with an acknowledgment of fault by the person if the proceeding could have led to any of the outcomes specified in subparagraph (A), (B), or (C).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d294fc-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In an administrative proceeding—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id83d294fd-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/c/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a final determination of contractor fault by the Secretary of Defense pursuant to section 823(d) of the National Defense Authorization Act for Fiscal Year 2010 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2302"},"text":"10 U.S.C. 2302","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Public Law 111–84","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id83d294fe-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/c/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a substantiated allegation, pursuant to section 1704(b) of the National Defense Authorization Act for Fiscal Year 2013, that the contractor, a subcontractor, or an agent of the contractor or subcontractor engaged in any of the activities described in section 106(g) of the Trafficking Victims Protection Act of 2000 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7104/g"},"text":"22 U.S.C. 7104(g)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d294ff-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each Federal contract and grant awarded to the person that was terminated in the period due to default.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d29500-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each Federal suspension and debarment of the person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d29501-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each Federal administrative agreement entered into by the person and the Federal Government in the period to resolve a suspension or debarment proceeding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d29502-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each final finding by a Federal official in the period that the person has been determined not to be a responsible source under paragraph (3) or (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s113"},"text":"section 113 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d29503-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other information that shall be provided for purposes of this section in the Federal Acquisition Regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d29504-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the maximum extent practicable, information similar to the information covered by paragraphs (1) to (4) in connection with the award or performance of a contract or grant with a State government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d29505-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whether the person is included on any of the following lists maintained by the Office of Foreign Assets Control of the Department of the Treasury:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d29506-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/c/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The specially designated nationals and blocked persons list (commonly known as the “SDN list”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d29507-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/c/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The sectoral sanctions identification list.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d29508-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/c/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The foreign sanctions evaders list.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d29509-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/c/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The list of persons sanctioned under the Iran Sanctions Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/172"},"text":"Public Law 104–172","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" note) that do not appear on the SDN list (commonly known as the “Non-SDN Iranian Sanctions Act list”)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d2950a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/c/8/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The list of foreign financial institutions subject to part 561 of title 31, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d2950b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements Relating to Database Information.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d2950c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Direct input and update","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of General Services shall design and maintain the database in a manner that allows the appropriate Federal agency officials to directly input and update information in the database relating to actions that the officials have taken with regard to contractors or grant recipients.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d2950d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timeliness and accuracy","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of General Services shall develop policies to require—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d2950e-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the timely and accurate input of information into the database;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d2950f-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the timely notification of any covered person when information relevant to the person is entered into the database; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d29510-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunities for any covered person to submit comments pertaining to information about the person for inclusion in the database.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d29511-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information on corporations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The information in the database on a person that is a corporation shall, to the extent practicable, include information on any parent, subsidiary, or successor entities to the corporation, and an identification of any beneficial owner of such corporation, in a manner designed to give the acquisition officials using the database a comprehensive understanding of the performance and integrity of the corporation in carrying out Federal contracts and grants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d29512-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d29513-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Beneficial ownership","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “beneficial ownership” has the meaning given under section 847 of the National Defense Authorization Act for Fiscal Year 2020 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Public Law 116–92","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/133/1505"},"text":"133 Stat. 1505","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2509"},"text":"10 U.S.C. 2509","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d29514-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Corporation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “corporation” means any corporation, company, limited liability company, limited partnership, business trust, business association, or other similar entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d29515-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Database.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d29516-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability to government officials","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of General Services shall ensure that the information in the database is available to appropriate acquisition officials of Federal agencies, other government officials as the Administrator of General Services determines appropriate, and, on request, the Chairman and Ranking Member of the committees of Congress having jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d29517-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review and assessment of data.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id83d29518-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before awarding a contract or grant in excess of the simplified acquisition threshold under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s134"},"text":"section 134 of this title","children":[],"tail":", the Federal agency official responsible for awarding the contract or grant shall review the database and consider all information in the database with regard to any offer or proposal, and in the case of a contract, shall consider other past performance information available with respect to the offeror in making any responsibility determination or past performance evaluation for the offeror."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id83d29519-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Documentation in contract file","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The contract file for each contract of a Federal agency in excess of the simplified acquisition threshold shall document the manner in which the material in the database was considered in any responsibility determination or past performance evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d2951a-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disclosure in Applications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal Acquisition Regulation shall require that persons with Federal agency contracts and grants valued in total greater than $10,000,000 shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id83d2951b-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Administrator of General Services, in a manner determined appropriate by the Administrator of General Services, the information subject to inclusion in the database as listed in subsection (c) current as of the date of submittal of the information under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id83d2951c-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" update the information submitted under paragraph (1) on a semiannual basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id83d2951d-3a70-11f1-ab1a-a784e0a454e2","identifier":"/us/usc/t41/s2313/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rulemaking","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of General Services shall prescribe regulations that may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id83d2951e-3a70-11f1-ab1a-a784e0a454e2"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s3"},"text":"Pub. L. 111–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3740"},"text":"124 Stat. 3740","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/212/tIII/s3010"},"text":"Pub. L. 111–212, title III, § 3010","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2340"},"text":"124 Stat. 2340","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tVIII/s834/d"},"text":"Pub. L. 111–383, div. A, title VIII, § 834(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4279"},"text":"124 Stat. 4279","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tVIII/s852"},"text":"Pub. L. 112–239, div. A, title VIII, § 852","children":[],"tail":", title XVII, § 1704(d)(2), "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1856"},"text":"126 Stat. 1856","children":[],"tail":", 2096; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tXII/s1270"},"text":"Pub. L. 113–291, div. A, title XII, § 1270","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3587"},"text":"128 Stat. 3587","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tVIII/s885"},"text":"Pub. L. 116–283, div. A, title VIII, § 885","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3791"},"text":"134 Stat. 3791","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id83d2951f-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id83d29520-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments Not Shown in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section was derived from section 417b of former Title 41, Public Contracts, which was amended by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/212/tIII/s3010"},"text":"Pub. L. 111–212, title III, § 3010","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2340"},"text":"124 Stat. 2340","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tVIII/s834/d"},"text":"Pub. L. 111–383, div. A, title VIII, § 834(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4279"},"text":"124 Stat. 4279","children":[],"tail":", prior to being repealed and reenacted as this section by "},{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":", §§ 3, 7(b), "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3677"},"text":"124 Stat. 3677","children":[],"tail":", 3855. For applicability of those amendments to this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/a"},"text":"section 6(a) of Pub. L. 111–350","children":[],"tail":", set out as a Transitional and Savings Provisions note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s101"},"text":"section 101 of this title","children":[],"tail":". Section 417b of former Title 41 was amended by adding at the end of subsec. (e)(1) the following: “In addition, the Administrator shall post all such information, excluding past performance reviews, on a publicly available Internet website.” and by adding at the end of subsec. (c)(1) the following new subparagraph:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"“(E) In an administrative proceeding, a final determination of contractor fault by the Secretary of Defense pursuant to section 823(d) of the National Defense Authorization Act for Fiscal Year 2010 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2302"},"text":"10 U.S.C. 2302","children":[],"tail":" note).”"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id83d29521-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id83d29522-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2313","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:417b.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title VIII, § 872, "},{"tag":"html:span","attrib":{},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/122/4555"},"text":"122 Stat. 4555","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “not later than one year after the date of the enactment of this Act” are omitted because of section 6(f) of the bill.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(7), the word “practicable” is substituted for “practical” to correct an error in the law.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f), the words “Not later than one year after the date of the enactment of this Act” are omitted because of section 6(f) of the bill. The words “shall require” are substituted for “shall be amended to require” to reflect the permanence of the provision.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f)(2), the words “the information submitted under paragraph (1)” are substituted for “such information” for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id83d29523-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id83d29524-3a70-11f1-ab1a-a784e0a454e2"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1704(b) of the National Defense Authorization Act for Fiscal Year 2013, referred to in subsec. (c)(1)(E)(ii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1704/b"},"text":"section 1704(b) of Pub. L. 112–239","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7104b/b"},"text":"section 7104b(b) of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id83d29525-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s885/1"},"text":"Pub. L. 116–283, § 885(1)","children":[],"tail":", inserted “, and an identification of any beneficial owner of such corporation,” after “to the corporation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s885/2"},"text":"Pub. L. 116–283, § 885(2)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (c)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1704/d/2"},"text":"Pub. L. 112–239, § 1704(d)(2)","children":[],"tail":", amended subpar. (E) generally. Prior to amendment, subpar. (E), as added by "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/s834/d"},"text":"Pub. L. 111–383, § 834(d)","children":[],"tail":", read as follows: “(E) In an administrative proceeding, a final determination of contractor fault by the Secretary of Defense pursuant to section 823(d) of the National Defense Authorization Act for Fiscal Year 2010 ("},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2302"},"text":"10 U.S.C. 2302","children":[],"tail":" note).” See Amendments Not Shown in Text note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s852"},"text":"Pub. L. 112–239, § 852","children":[],"tail":", added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id83d29526-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id83d29527-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Establishing Database","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/f/3"},"text":"Pub. L. 111–350, § 6(f)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3855"},"text":"124 Stat. 3855","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/350/s6/f/3"},"text":"“The requirement in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s2313/a"},"text":"section 2313(a) of title 41","children":[],"tail":", United States Code, to establish a database shall be done not later than one year after "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"October 14, 2008","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id83d29528-3a70-11f1-ab1a-a784e0a454e2"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Amending Federal Acquisition Regulation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/f/4"},"text":"Pub. L. 111–350, § 6(f)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3855"},"text":"124 Stat. 3855","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/350/s6/f/4"},"text":"“The Federal Acquisition Regulation shall be amended to meet the requirements of sections 2313(f), 3302(b) and (d), 4710(b), and 4711(b) of title 41, United States Code, not later than one year after ","children":[{"tag":"date","attrib":{"date":"2008-10-14"},"text":"October 14, 2008","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
