{"tag":"section","attrib":{"id":"id279446fa-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s54a"},"text":null,"children":[{"tag":"num","attrib":{"value":"54a"},"text":"§ 54a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain Federal and State regulations deemed statutory authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A regulation, standard, or requirement in force, or prescribed by the Secretary of Transportation under chapter 201 of title 49 or by a State agency that is participating in investigative and surveillance activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s20105"},"text":"section 20105 of title 49","children":[],"tail":", is deemed to be a statute under sections 53 and 54 of this title."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id279446fb-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1908-04-22/ch149/s4A"},"text":"Apr. 22, 1908, ch. 149, § 4A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s4/i"},"text":"Pub. L. 103–272, § 4(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1365"},"text":"108 Stat. 1365","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
