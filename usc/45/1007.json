{"tag":"section","attrib":{"id":"id27f13483-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1007"},"text":null,"children":[{"tag":"num","attrib":{"value":"1007"},"text":"§ 1007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id27f13484-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1007/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance received under employee protection agreement; waiver of other employee protection benefits; exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any employee who receives any assistance under an employee protection agreement entered into or benefit schedule prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s1005"},"text":"section 1005 of this title","children":[],"tail":" or any new career training assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1014"},"text":"section 1014 of this title","children":[],"tail":" shall be deemed to waive any employee protection benefits otherwise available to such employee under the Bankruptcy Act, subtitle IV of title 49 or any applicable contract or agreement (other than as provided in the agreement entered into in Washington, District of Columbia, on "},{"tag":"date","attrib":{"date":"1980-03-04"},"text":"March 4, 1980","children":[],"tail":", entitled “Labor Protective Agreement Between Railroads Parties Hereto Involved in Midwest Rail Restructuring and Employees of Such Railroads Represented by the Rail Labor Organizations Operating Through the Railway Labor Executives’ Association”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27f13485-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1007/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing of statement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any employee of the Rock Island Railroad who is entitled to receive assistance under this chapter shall, no later than 120 days after the effective date of any agreement entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s1005/a"},"text":"section 1005(a) of this title","children":[],"tail":" or of any benefit schedule prescribed under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1005/b"},"text":"section 1005(b) of this title","children":[],"tail":", as the case may be, file a statement with the Board indicating whether such employee elects to receive (1) assistance under this chapter; or (2) any employee protection benefits otherwise available to such employee under the Bankruptcy Act, subtitle IV of title 49, or any applicable contract or agreement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27f13486-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1007/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on priority, timing, etc., of employee protection payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With regard to any employee who elects benefits under subsection (b)(2) of this section, nothing in this chapter shall be deemed to determine or otherwise affect the priority, status, or timing of payment of, or the liability for any claim for, employee protection which might have existed in the absence of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27f13487-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1007/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on assistance eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An employee shall not be eligible to receive any assistance (other than moving expenses) under an employee protection agreement entered into or benefit schedule prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s1005"},"text":"section 1005 of this title","children":[],"tail":" or any new career training assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1014"},"text":"section 1014 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id27f13488-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1007/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during any period in which such employee is employed by any rail carrier providing temporary service over any lines of the Rock Island Railroad; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27f13489-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1007/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at any time after the date such employee receives an offer of employment, in his craft and for which such employee is qualified, from a rail carrier acquiring lines of the Rock Island Railroad.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27f1348a-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/254/tI/s108"},"text":"Pub. L. 96–254, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-05-30"},"text":"May 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/402"},"text":"94 Stat. 402","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/448/tVII/s701/b/2"},"text":"Pub. L. 96–448, title VII, § 701(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1960"},"text":"94 Stat. 1960","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/468/tII/s232"},"text":"Pub. L. 97–468, title II, § 232","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2547"},"text":"96 Stat. 2547","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27f1348b-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27f1348c-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id27f1348d-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Bankruptcy Act, referred to in subsecs. (a) and (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1898-07-01/ch541"},"text":"act July 1, 1898, ch. 541","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/544"},"text":"30 Stat. 544","children":[],"tail":", which was classified generally to former Title 11, Bankruptcy. The Act was repealed effective "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", §§ 401(a), 402(a), "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2682"},"text":"92 Stat. 2682","children":[],"tail":", section 101 of which enacted revised Title 11. For current provisions relating to railroad reorganization, see subchapter IV (§ 1161 et seq.) of chapter 11 of Title 11."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (b) and (c), was in the original “this title”, meaning title I (§ 101 et seq.) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/254"},"text":"Pub. L. 96–254","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-05-30"},"text":"May 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/399"},"text":"94 Stat. 399","children":[],"tail":", known as the Rock Island Railroad Transition and Employee Assistance Act, which is classified principally to this chapter. For complete classification of title I to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1001"},"text":"section 1001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id27f1348e-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/468/s232/1"},"text":"Pub. L. 97–468, § 232(1)","children":[],"tail":", substituted “entered into or benefit schedule prescribed” for “or arrangement entered into”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/468/s232/2"},"text":"Pub. L. 97–468, § 232(2)","children":[],"tail":", substituted “120 days after the effective date of any agreement entered into under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1005/a"},"text":"section 1005(a) of this title","children":[],"tail":" or of any benefit schedule prescribed under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1005/b"},"text":"section 1005(b) of this title","children":[],"tail":", as the case may be” for “"},{"tag":"date","attrib":{"date":"1981-04-01"},"text":"April 1, 1981","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/468/s232/1"},"text":"Pub. L. 97–468, § 232(1)","children":[],"tail":", substituted “entered into or benefit schedule prescribed” for “or arrangement entered into”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/448"},"text":"Pub. L. 96–448","children":[],"tail":" inserted reference to the agreement entered into in Washington on "},{"tag":"date","attrib":{"date":"1980-03-04"},"text":"Mar. 4, 1980","children":[],"tail":", and included the title of the agreement."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id27f1348f-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id27f13490-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/448"},"text":"Pub. L. 96–448","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/448/s710/d"},"text":"section 710(d) of Pub. L. 96–448","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s1170"},"text":"section 1170 