{"tag":"section","attrib":{"id":"id27ea0841-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s794"},"text":null,"children":[{"tag":"num","attrib":{"value":"794"},"text":"§ 794.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax payments to States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id27ea0842-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s794/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, no railroad in reorganization shall withhold from any State, or any political subdivision thereof, the payment of the portion of any tax owed by such railroad to such State or subdivision, which portion has been collected by such railroad from any tenant thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27ea0843-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s794/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any railroad which violates the provisions of subsection (a) of this section by withholding any portion of a tax referred to in such subsection shall be fined not more than $10,000 for each such violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27ea0844-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/236/tVI/s605"},"text":"Pub. L. 93–236, title VI, § 605","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/5/s9"},"text":"Pub. L. 94–5, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-02-28"},"text":"Feb. 28, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/9"},"text":"89 Stat. 9","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
