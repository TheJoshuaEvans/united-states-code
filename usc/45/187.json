{"tag":"section","attrib":{"id":"id279dbd0b-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s187"},"text":null,"children":[{"tag":"num","attrib":{"value":"187"},"text":"§ 187.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any provision of this subchapter or application thereof to any person or circumstance is held invalid, the remainder of such sections and the application of such provision to other persons or circumstances shall not be affected thereby.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id279dbd0c-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-05-20/ch347/s207"},"text":"May 20, 1926, ch. 347, § 207","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1936-04-10/ch166"},"text":"Apr. 10, 1936, ch. 166","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1191"},"text":"49 Stat. 1191","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
