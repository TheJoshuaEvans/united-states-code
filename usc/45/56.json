{"tag":"section","attrib":{"id":"id279446fe-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s56"},"text":null,"children":[{"tag":"num","attrib":{"value":"56"},"text":"§ 56.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions; limitation; concurrent jurisdiction of courts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No action shall be maintained under this chapter unless commenced within three years from the day the cause of action accrued.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Under this chapter an action may be brought in a district court of the United States, in the district of the residence of the defendant, or in which the cause of action arose, or in which the defendant shall be doing business at the time of commencing such action. The jurisdiction of the courts of the United States under this chapter shall be concurrent with that of the courts of the several States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id279446ff-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1908-04-22/ch149/s6"},"text":"Apr. 22, 1908, ch. 149, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/66"},"text":"35 Stat. 66","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1910-04-05/ch143/s1"},"text":"Apr. 5, 1910, ch. 143, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/291"},"text":"36 Stat. 291","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s291"},"text":"Mar. 3, 1911, ch. 231, § 291","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1167"},"text":"36 Stat. 1167","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1939-08-11/ch685/s2"},"text":"Aug. 11, 1939, ch. 685, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1404"},"text":"53 Stat. 1404","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646/s18"},"text":"June 25, 1948, ch. 646, § 18","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/989"},"text":"62 Stat. 989","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27944700-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27944701-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id27944702-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The first par. of this section is from act ","children":[{"tag":"date","attrib":{"date":"1908-04-22"},"text":"Apr. 22, 1908","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The second par. of this section is from act ","children":[{"tag":"date","attrib":{"date":"1910-04-05"},"text":"Apr. 5, 1910","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id27944703-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1948—Act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", struck out provision in last sentence relating to removal of actions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1939—Act ","children":[{"tag":"date","attrib":{"date":"1939-08-11"},"text":"Aug. 11, 1939","children":[],"tail":", changed limitation in first sentence from two to three years."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id27944704-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id27944705-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“District court” substituted in text for “circuit court” to conform to act ","children":[{"tag":"date","attrib":{"date":"1911-03-03"},"text":"Mar. 3, 1911","children":[],"tail":", which transferred powers and duties of circuit courts to district courts."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id27944706-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1948 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646/s38"},"text":"Act June 25, 1948, ch. 646, § 38","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/992"},"text":"62 Stat. 992","children":[],"tail":", provided that the amendment made by that act is effective "},{"tag":"date","attrib":{"date":"1948-09-01"},"text":"Sept. 1, 1948","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
