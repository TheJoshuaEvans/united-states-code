{"tag":"section","attrib":{"id":"id279dbcd3-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s161"},"text":null,"children":[{"tag":"num","attrib":{"value":"161"},"text":"§ 161.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of partial invalidity of chapter","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any provision of this chapter, or the application thereof to any person or circumstance, is held invalid, the remainder of the chapter, and the application of such provision to other persons or circumstances, shall not be affected thereby.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id279dbcd4-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-05-20/ch347/s11"},"text":"May 20, 1926, ch. 347, § 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/587"},"text":"44 Stat. 587","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id279dbcd5-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id279dbcd6-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"separability","id":"id279dbcd7-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Separability; Repeal of Inconsistent Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-21/ch691/s8"},"text":"Act June 21, 1934, ch. 691, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1197"},"text":"48 Stat. 1197","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1934-06-21/ch691/s8"},"text":"“If any section, subsection, sentence, clause, or phrase of this Act [amending sections 151 to 158, 160, and 162 of this title] is for any reason held to be unconstitutional, such decision shall not affect the validity of the remaining portions of this Act. All Acts or parts of Acts inconsistent with the provisions of this Act are hereby repealed.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
