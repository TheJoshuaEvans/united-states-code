{"tag":"section","attrib":{"id":"id27f3a4f4-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1102"},"text":null,"children":[{"tag":"num","attrib":{"value":"1102"},"text":"§ 1102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is therefore declared to be the purpose of the Congress in this subtitle to provide for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id27f3a4f5-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the removal by a date certain of the Federal Government’s obligation to subsidize the freight operations of Conrail;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27f3a4f6-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer of Conrail commuter service responsibilities to one or more entities whose principal purpose is the provision of commuter service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27f3a4f7-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an orderly return of Conrail freight service to the private sector.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27f3a4f8-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXI/s1133"},"text":"Pub. L. 97–35, title XI, § 1133","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/644"},"text":"95 Stat. 644","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27f3a4f9-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27f3a4fa-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id27f3a4fb-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subtitle, referred to in text, is subtitle E (§§ 1131–1169) of title XI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/643"},"text":"95 Stat. 643","children":[],"tail":", known as the Northeast Rail Service Act of 1981. For complete classification of this subtitle to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1101"},"text":"section 1101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
