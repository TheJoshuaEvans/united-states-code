{"tag":"section","attrib":{"id":"id27f134af-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1014"},"text":null,"children":[{"tag":"num","attrib":{"value":"1014"},"text":"§ 1014.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New career training assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id27f134b0-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1014/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An employee who elects to receive a separation allowance under an employee protection agreement entered into or a benefit schedule prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s1005"},"text":"section 1005 of this title","children":[],"tail":" may, if so provided under such agreement or benefit schedule, receive from the Board reasonable expenses for training in qualified institutions for new career opportunities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27f134b1-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1014/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions for assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for assistance under this section, an employee—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id27f134b2-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1014/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" must first exhaust any Federal educational benefits available to such employee under any existing program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27f134b3-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1014/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" must begin his course of training within 2 years following the date of such employee’s separation from employment with the Rock Island Railroad.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27f134b4-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1014/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of reasonable expenses by Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Reasonable expenses for assistance under this section shall be determined by the Board on the basis of an application therefor filed by an employee with the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27f134b5-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1014/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance prohibited after ","children":[{"tag":"date","attrib":{"date":"1984-04-01"},"text":"April 1, 1984","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No assistance may be provided under this section after ","children":[{"tag":"date","attrib":{"date":"1984-04-01"},"text":"April 1, 1984","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27f134b6-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1014/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id27f134b7-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1014/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “expenses” means actual, reasonable expenses paid for room, board, tuition, fees, or educational material in an amount not to exceed $3,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27f134b8-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1014/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “qualified institution” means an educational institution accredited for payment by the Veterans’ Administration under chapter 36 of title 38, or a State-accredited institution which has been in existence for not less than 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27f134b9-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/254/tI/s119/a"},"text":"Pub. L. 96–254, title I, § 119(a)","children":[],"tail":"–(e), "},{"tag":"date","attrib":{"date":"1980-05-30"},"text":"May 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/408"},"text":"94 Stat. 408","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/468/tII/s233"},"text":"Pub. L. 97–468, title II, § 233","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2547"},"text":"96 Stat. 2547","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27f134ba-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27f134bb-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id27f134bc-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of subsecs. (a) to (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/254/s119"},"text":"section 119 of Pub. L. 96–254","children":[],"tail":". Subsec. (f) of section 119 amended "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s911"},"text":"section 911 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id27f134bd-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/468"},"text":"Pub. L. 97–468","children":[],"tail":" substituted “under an employee protection agreement entered into or a benefit schedule prescribed under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1005"},"text":"section 1005 of this title","children":[],"tail":" may, if so provided under such agreement or benefit schedule,” for “from the Rock Island Railroad under an employee protection agreement or arrangement entered into under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1005"},"text":"section 1005 of this title","children":[],"tail":" may”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id27f134be-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id27f134bf-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to Veterans’ Administration deemed to refer to Department of Veterans Affairs pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/527/s10"},"text":"section 10 of Pub. L. 100–527","children":[],"tail":", set out as a Department of Veterans Affairs Act note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s301"},"text":"section 301 of Title 38","children":[],"tail":", Veterans’ Benefits."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
