{"tag":"section","attrib":{"id":"id27f134a0-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1011"},"text":null,"children":[{"tag":"num","attrib":{"value":"1011"},"text":"§ 1011.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Railroad Retirement Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id27f134a1-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1011/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board may prescribe such regulations as may be necessary to carry out its duties under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27f134a2-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1011/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out its duties under this chapter, the Board may exercise such of the powers, duties, and remedies provided in subsections (a), (b), and (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s362"},"text":"section 362 of this title","children":[],"tail":" as are not inconsistent with the provisions of this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27f134a3-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/254/tI/s114"},"text":"Pub. L. 96–254, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-05-30"},"text":"May 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/405"},"text":"94 Stat. 405","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27f134a4-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27f134a5-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id27f134a6-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title I (§ 101 et seq.) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/254"},"text":"Pub. L. 96–254","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-05-30"},"text":"May 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/399"},"text":"94 Stat. 399","children":[],"tail":", known as the Rock Island Railroad Transition and Employee Assistance Act, which is classified principally to this chapter. For complete classification of title I to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1001"},"text":"section 1001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
