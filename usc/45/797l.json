{"tag":"section","attrib":{"id":"id27ec79b7-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797l"},"text":null,"children":[{"tag":"num","attrib":{"value":"797l"},"text":"§ 797l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Class II railroads receiving Federal assistance","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Surface Transportation Board shall impose no labor protection conditions in approving an application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s10902"},"text":"section 10902 of title 49","children":[],"tail":" when the application involves a Class II rail carrier which—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id27ec79b8-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is headquartered in a State, and operates in at least one State, with a population of less than 1,000,000 persons, as determined by the 1990 census; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27ec79b9-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has, as of ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"January 1, 1996","children":[],"tail":", been a recipient of repayable Federal Railroad Administration assistance in excess of $5,000,000."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27ec79ba-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/236/tVII/s713"},"text":"Pub. L. 93–236, title VII, § 713","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/tIII/s327/5/A"},"text":"Pub. L. 104–88, title III, § 327(5)(A)","children":[],"tail":", formerly § 32