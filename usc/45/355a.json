{"tag":"section","attrib":{"id":"id27c89d6f-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s355a"},"text":null,"children":[{"tag":"num","attrib":{"value":"355a"},"text":"§ 355a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of claims for benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever there is duly tendered to the Board, by any person, any claim for unemployment compensation pursuant to the Railroad Unemployment Insurance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s351"},"text":"45 U.S.C. 351","children":[],"tail":" et seq.], such claim shall be accepted by the Board without delay and appropriate administrative action for the allowance or disallowance of such claim shall be taken by the Board at the earliest practicable time."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id27c89d70-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-06-29/ch477"},"text":"June 29, 1956, ch. 477","children":[],"tail":", title V, § 501, "},{"tag":"ref","attrib":{"href":"/us/stat/70/437"},"text":"70 Stat. 437","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27c89d71-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27c89d72-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id27c89d73-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Railroad Unemployment Insurance Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch680"},"text":"act June 25, 1938, ch. 680","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1094"},"text":"52 Stat. 1094","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s367"},"text":"section 367 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id27c89d74-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of act ","children":[{"tag":"date","attrib":{"date":"1956-06-29"},"text":"June 29, 1956","children":[],"tail":", popularly known as the Departments of Labor, and Health, Education, and Welfare, Appropriation Act, 1957, and not as a part of the Railroad Unemployment Insurance Act which comprises this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id27c89d75-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation act: ","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-01/ch437"},"text":"Aug. 1, 1955, ch. 437","children":[],"tail":", title V, § 501, "},{"tag":"ref","attrib":{"href":"/us/stat/69/411"},"text":"69 Stat. 411","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
