{"tag":"section","attrib":{"id":"id27f1346b-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1005"},"text":null,"children":[{"tag":"num","attrib":{"value":"1005"},"text":"§ 1005.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee protection agreement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id27f1346c-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1005/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization; time for agreement; use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary and the representatives of the various classes and crafts of employees of the Rock Island Railroad shall, not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1983-01-14"},"text":"January 14, 1983","children":[],"tail":", enter into an agreement providing protection for employees of the Rock Island Railroad who are adversely affected as a result of a reduction in service by such Railroad. Such agreement may provide for the use of funds described in subsection (c) of this section for the following purposes:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id27f1346d-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1005/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsistence allowances to employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27f1346e-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1005/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Moving expenses for employees who must make a change in residence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27f1346f-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1005/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Retraining expenses for employees who are seeking employment in new areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27f13470-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1005/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Separation allowances for employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27f13471-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1005/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Health and welfare insurance premiums.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27f13472-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1005/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other purposes as may be agreed upon by the parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27f13473-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1005/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to reach agreement; benefit schedule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the parties are unable to reach agreement within the time period specified in subsection (a) of this section, the Secretary shall, within 30 days after the expiration of such time period, prescribe a schedule of benefits for employee protection not inconsistent with the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27f13474-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1005/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any agreement entered into under subsection (a) of this section, and any benefit schedule prescribed under subsection (b) of this section, shall not require the expenditure of funds in excess of amounts authorized to be appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s727/f/1/C"},"text":"section 727(f)(1)(C) of this title","children":[],"tail":", nor shall any individual employee receive benefits in excess of $20,000 under such agreement or benefit schedule. No benefits or assistance may be provided under any agreement entered into or benefit schedule prescribed under this section after "},{"tag":"date","attrib":{"date":"1984-04-01"},"text":"April 1, 1984","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27f13475-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1005/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of funds; promulgation of regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall, in such manner as it shall prescribe by regulation, administer the distribution of funds under any agreement entered into or benefit schedule prescribed under this section, and shall determine the amount for which each employee is eligible under such agreement or benefit schedule. Such regulation shall include procedures to resolve by final and binding arbitration any dispute over an employee’s eligibility or claim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27f13476-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/254/tI/s106"},"text":"Pub. L. 96–254, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-05-30"},"text":"May 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/401"},"text":"94 Stat. 401","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/448/tVII/s701/b/1"},"text":"Pub. L. 96–448, title VII, § 701(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1959"},"text":"94 Stat. 1959","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/468/tII/s231"},"text":"Pub. L. 97–468, title II, § 231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2546"},"text":"96 Stat. 2546","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27f13477-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27f13478-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id27f13479-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b), was in the original “this Act”, which probably was meant to be a reference to “this title”, meaning title I (§ 101 et seq.) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/254"},"text":"Pub. L. 96–254","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-05-30"},"text":"May 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/399"},"text":"94 Stat. 399","children":[],"tail":", as amended, known as the Rock Island Railroad Transition and Employee Assistance Act, which is classified principally to this chapter. For complete classification of title I to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1001"},"text":"section 1001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id27f1347a-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior to the general amendment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/254/s106"},"text":"section 106 of Pub. L. 96–254","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/97/468"},"text":"Pub. L. 97–468","children":[],"tail":", section was comprised of subsecs. (a) to (e) of "},{"tag":"ref","attrib":{"href":"/us/pl/96/254/s106"},"text":"section 106 of Pub. L. 96–254","children":[],"tail":", and subsec. (f) of section 106 amended "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s231f/b/7"},"text":"section 231f(b)(7) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id27f1347b-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/468"},"text":"Pub. L. 97–468","children":[],"tail":" substituted provisions relating to an agreement between the Secretary and the employees for provisions relating to an agreement between the Rock Island Railroad and the employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/468"},"text":"Pub. L. 97–468","children":[],"tail":" substituted provisions relating to the prescription of benefits by the Secretary if no agreement is reached with the employees, for provisions relating to imposition of agreement by the Interstate Commerce Commission if none was reached between the Rock Island Railroad and the employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/468"},"text":"Pub. L. 97–468","children":[],"tail":" added subsec. (c). Former subsec. (c), which related to direction to the bankruptcy trustee to carry out the agreement between the Rock Island Railroad and the employees, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/468"},"text":"Pub. L. 97–468","children":[],"tail":" added subsec. (d). Former subsec. (d), which prescribed conditions for appeals from orders of the Commission or bankruptcy court, limiting them to the Seventh Circuit Court of Appeals, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/468"},"text":"Pub. L. 97–468","children":[],"tail":" struck out subsec. (e) which related to prescription of regulations by the Board for the filing and payment of benefits and allowances."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/448"},"text":"Pub. L. 96–448","children":[],"tail":" substituted “5 days after "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"October 14, 1980","children":[],"tail":"” for “10 days after "},{"tag":"date","attrib":{"date":"1980-05-30"},"text":"May 30, 1980","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/448"},"text":"Pub. L. 96–448","children":[],"tail":" substituted “5 days after "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"October 14, 1980","children":[],"tail":"” for “10 days after "},{"tag":"date","attrib":{"date":"1980-05-30"},"text":"May 30, 1980","children":[],"tail":"” and “15 days after "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"October 14, 1980","children":[],"tail":"” for “30 days after "},{"tag":"date","attrib":{"date":"1980-05-30"},"text":"May 30, 1980","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/448"},"text":"Pub. L. 96–448","children":[],"tail":" reenacted subsec. (c) without change."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/448"},"text":"Pub. L. 96–448","children":[],"tail":" substituted provision that any order of the Commission or bankruptcy court be appealed only to the United States Court of Appeals for the Seventh Circuit for provision that an order of the Commission not be stayed by the Commission or any other court, an order by the bankruptcy court not be stayed by any other court, appeals of Commission or bankruptcy court orders only be made to the court of appeals of the United States having jurisdiction to review decisions and orders of the bankruptcy court, and no determinations of the court of appeals be review in any other court."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/448"},"text":"Pub. L. 96–448","children":[],"tail":" reenacted subsec. (e) without change."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id27f1347c-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id27f1347d-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/448"},"text":"Pub. L. 96–448","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/448/s710/d"},"text":"section 710(d) of Pub. L. 96–448","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s1170"},"text":"section 1170 of Title 11","children":[],"tail":", Bankruptcy."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
