{"tag":"section","attrib":{"id":"id279dbcdd-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s163"},"text":null,"children":[{"tag":"num","attrib":{"value":"163"},"text":"§ 163.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repeal of prior legislation; exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Chapters 6 and 7 of this title, providing for mediation, conciliation, and arbitration, and all Acts and parts of Acts in conflict with the provisions of this chapter are repealed, except that the members, secretary, officers, employees, and agents of the Railroad Labor Board, in office on ","children":[{"tag":"date","attrib":{"date":"1926-05-20"},"text":"May 20, 1926","children":[],"tail":", shall receive their salaries for a period of 30 days from such date, in the same manner as though this chapter had not been passed."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id279dbcde-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-05-20/ch347/s14"},"text":"May 20, 1926, ch. 347, § 14","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/587"},"text":"44 Stat. 587","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id279dbcdf-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id279dbce0-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id279dbce1-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Chapters 6 and 7 of this title, referred to in text, were in the original references to the act of ","children":[{"tag":"date","attrib":{"date":"1913-07-15"},"text":"July 15, 1913","children":[],"tail":", and title III of the Transportation Act, 1920, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
