{"tag":"section","attrib":{"id":"id27bf278c-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s231v"},"text":null,"children":[{"tag":"num","attrib":{"value":"231v"},"text":"§ 231v.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation and certification of account benefit ratios","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id27bf278d-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s231v/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial computation and certification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On or before ","children":[{"tag":"date","attrib":{"date":"2003-11-01"},"text":"November 1, 2003","children":[],"tail":", the Railroad Retirement Board shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id27bf278e-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s231v/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compute the account benefits ratios for each of the most recent 10 preceding fiscal years, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27bf278f-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s231v/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify the account benefits ratios for each such fiscal year to the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27bf2790-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s231v/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computations and certifications after 2003","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On or before November 1 of each year after 2003, the Railroad Retirement Board shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id27bf2791-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s231v/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compute the account benefits ratio for the fiscal year ending in such year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27bf2792-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s231v/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify the account benefits ratio for such fiscal year to the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27bf2793-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s231v/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the term “account benefits ratio” has the meaning given that term in section 3241(c) of the Internal Revenue Code of 1986 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s3241/c"},"text":"26 U.S.C. 3241(c)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27bf2794-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-29/ch812/s23"},"text":"Aug. 29, 1935, ch. 812, § 23","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/90/tI/s108/b"},"text":"Pub. L. 107–90, title I, § 108(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-21"},"text":"Dec. 21, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/890"},"text":"115 Stat. 890","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27bf2795-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27bf2796-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id27bf2797-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 231v, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-29/ch812/s23"},"text":"act Aug. 29, 1935, ch. 812, § 23","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1983-08-12"},"text":"Aug. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/98/76/tIV/s418"},"text":"Pub. L. 98–76, title IV, § 418","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/438"},"text":"97 Stat. 438","children":[],"tail":", provided that for purposes of Inspector General Act of 1978, the Railroad Retirement Board is an “establishment” and the Chairman of such Board the “head of the establishment”, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/504/tI"},"text":"Pub. L. 100–504, title I","children":[],"tail":", §§ 102(e)(3), 113, "},{"tag":"date","attrib":{"date":"1988-10-18"},"text":"Oct. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2517"},"text":"102 Stat. 2517","children":[],"tail":", 2530, effective 180 days after "},{"tag":"date","attrib":{"date":"1988-10-18"},"text":"Oct. 18, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
