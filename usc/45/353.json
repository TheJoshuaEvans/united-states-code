{"tag":"section","attrib":{"id":"id27c6532d-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s353"},"text":null,"children":[{"tag":"num","attrib":{"value":"353"},"text":"§ 353.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying condition","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An employee shall be a “qualified employee” if the Board finds that his compensation with respect to the base year will have been not less than 2.5 times the monthly compensation base for months in such base year as computed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s351/i"},"text":"section 351(i) of this title","children":[],"tail":", and, if such employee has had no compensation prior to such year, that he will have had compensation with respect to each of not less than five months in such year."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id27c6532e-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch680/s3"},"text":"June 25, 1938, ch. 680, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1097"},"text":"52 Stat. 1097","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1939-06-20/ch227/s10"},"text":"June 20, 1939, ch. 227, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/845"},"text":"53 Stat. 845","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1940-10-10/ch842/s13"},"text":"Oct. 10, 1940, ch. 842, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/1097"},"text":"54 Stat. 1097","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-07-31/ch709/s308"},"text":"July 31, 1946, ch. 709, § 308","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/737"},"text":"60 Stat. 737","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1952-05-15/ch290/s2"},"text":"May 15, 1952, ch. 290, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/73"},"text":"66 Stat. 73","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-31/ch1164"},"text":"Aug. 31, 1954, ch. 1164","children":[],"tail":", pt. III, § 303, "},{"tag":"ref","attrib":{"href":"/us/stat/68/1041"},"text":"68 Stat. 1041","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/28"},"text":"Pub. L. 86–28","children":[],"tail":", pt. III, § 304, "},{"tag":"date","attrib":{"date":"1959-05-19"},"text":"May 19, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/31"},"text":"73 Stat. 31","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/133/tIII/s301/a"},"text":"Pub. L. 88–133, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-10-05"},"text":"Oct. 5, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/222"},"text":"77 Stat. 222","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/257/tII/s203"},"text":"Pub. L. 90–257, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-02-15"},"text":"Feb. 15, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/24"},"text":"82 Stat. 24","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/92/tI/s1/f"},"text":"Pub. L. 94–92, title I, § 1(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-08-09"},"text":"Aug. 9, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/463"},"text":"89 Stat. 463","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/76/tIV/s411/a/2"},"text":"Pub. L. 98–76, title IV, § 411(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-12"},"text":"Aug. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/436"},"text":"97 Stat. 436","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVII/s7202/a"},"text":"Pub. L. 100–647, title VII, § 7202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3776"},"text":"102 Stat. 3776","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27c6532f-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27c65330-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id27c65331-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" inserted “with respect to the base year” after “his compensation” and substituted “2.5 times the monthly compensation base for months in such base year as computed under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s351/i"},"text":"section 351(i) of this title","children":[],"tail":"” for “$1,500 with respect to the base year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/76"},"text":"Pub. L. 98–76","children":[],"tail":" substituted “$1,500” for “$1,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/92"},"text":"Pub. L. 94–92","children":[],"tail":" substituted “five” for “seven” months."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/257"},"text":"Pub. L. 90–257","children":[],"tail":" substituted “$1,000” for “$750”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1963—","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/133"},"text":"Pub. L. 88–133","children":[],"tail":" increased from $500 to $750 the amount of compensation in a base year required to qualify for benefits and provided that if employee has had no compensation prior to such year he will have had compensation with respect to each of not less than 7 months in such year."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/28"},"text":"Pub. L. 86–28","children":[],"tail":" substituted “$500” for “$400”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Act ","children":[{"tag":"date","attrib":{"date":"1954-08-31"},"text":"Aug. 31, 1954","children":[],"tail":", substituted “$400” for “$300”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1952—Act ","children":[{"tag":"date","attrib":{"date":"1952-05-15"},"text":"May 15, 1952","children":[],"tail":", substituted “$300” for “$150” to conform to the new table of daily benefit rates as set out in "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s352"},"text":"section 352 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1946—Act ","children":[{"tag":"date","attrib":{"date":"1946-07-31"},"text":"July 31, 1946","children":[],"tail":", changed section to relate to compensation paid instead of compensation earned during a year."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1940—Act ","children":[{"tag":"date","attrib":{"date":"1940-10-10"},"text":"Oct. 10, 1940","children":[],"tail":", reorganized structure by striking out designations for subsecs. “(a)” and “(b)” and, as so restructured, provisions of former subsec. (a) became entire section and defined “qualified employee” and provisions of former subsec. (b), which related to the employee’s waiting period, were omitted."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1939—Subsec. (b). Act ","children":[{"tag":"date","attrib":{"date":"1939-06-20"},"text":"June 20, 1939","children":[],"tail":", substituted provisions relating to half-months as the waiting period, for provisions relating to fifteen consecutive days of unemployment or two half months."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id27c65332-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id27c65333-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVII/s7202/b"},"text":"Pub. L. 100–647, title VII, § 7202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3776"},"text":"102 Stat. 3776","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tVII/s7202/b"},"text":"“The amendments made by this section [amending this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id27c65334-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/76"},"text":"Pub. L. 98–76","children":[],"tail":" applicable to compensation paid for services rendered after "},{"tag":"date","attrib":{"d