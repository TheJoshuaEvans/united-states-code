{"tag":"section","attrib":{"id":"id27d23ace-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s404"},"text":null,"children":[{"tag":"num","attrib":{"value":"404"},"text":"§ 404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary increase in employers’ contribution rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding the provisions of section 358(a)2 ","children":[{"tag":"ref","attrib":{"idref":"fn002032"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002032"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, the rate of contribution required to be paid under the Railroad Unemployment Insurance Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t45/s351"},"text":"45 U.S.C. 351","children":[],"tail":" et seq.] by every employer as defined in such Act shall be 4 per centum with respect to compensation as defined in such Act, paid after "},{"tag":"date","attrib":{"date":"1961-12-31"},"text":"December 31, 1961","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1964-01-01"},"text":"January 1, 1964","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id27d23acf-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/7/s5"},"text":"Pub. L. 87–7, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-03-24"},"text":"Mar. 24, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/17"},"text":"75 Stat. 17","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27d23ad0-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27d23ad1-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"hea