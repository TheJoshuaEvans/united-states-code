{"tag":"section","attrib":{"id":"id27f13438-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1001"},"text":null,"children":[{"tag":"num","attrib":{"value":"1001"},"text":"§ 1001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress hereby finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id27f13439-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1001/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uninterrupted continuation of services over Rock Island lines is dependent on adequate employee protection provisions covering Rock Island Railroad employees who are not hired by other railroads;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27f1343a-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1001/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for those Rock Island Railroad employees not hired by other rail carriers, there is no other practicable means of obtaining funds to meet the necessary costs of such employee protection that are assumed by the Rock Island Railroad;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27f1343b-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1001/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cessation of necessary operations of the Rock Island Railroad would have serious repercussions on the economies of the States in which such railroad principally operates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27f1343c-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1001/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" premature cessation of services over lines which are the subject of pending purchase application would result in harm to the shipping public and could imperil continuation of vital commuter service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27f1343d-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/254/tI/s102"},"text":"Pub. L. 96–254, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-05-30"},"text":"May 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/399"},"text":"94 Stat. 399","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27f1343e-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id27f1343f-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id27f13440-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/254/tI/s101"},"text":"Pub. L. 96–254, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-05-30"},"text":"May 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/399"},"text":"94 Stat. 399","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/254/tI/s101"},"text":"“This title [enacting this chapter, amending sections 231f, 726, 825, 902, 911, 913, and 916 of this title, and enacting provisions set out as a note under this section] may be cited as the ‘Rock Island Railroad Transition and Employee Assistance Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"id27f13441-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/254/tI/s125"},"text":"Pub. L. 96–254, title I, § 125","children":[],"tail":", formerly § 124, "},{"tag":"date","attrib":{"date":"1980-05-30"},"text":"May 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/409"},"text":"94 Stat. 409","children":[],"tail":"; renumbered § 125, "},{"tag":"ref","attrib":{"href":"/us/pl/96/448/tVII/s701/a/1"},"text":"Pub. L. 96–448, title VII, § 701(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1959"},"text":"94 Stat. 1959","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/448/tVII/s701/a/1"},"text":"“If any provision of this title [see Short Title note above] or the application thereof to any person or circumstance is held invalid, the remainder of this title and the application of such provision to other persons or circumstances shall not be affected thereby.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
