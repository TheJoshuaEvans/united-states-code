,"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id27f1345d-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s21301/j/3/F/i"},"text":"Pub. L. 117–58, § 21301(j)(3)(F)(i)","children":[],"tail":", substituted “chapter 224 of title 49” for “title V of the Railroad Revitalization and Regulatory Reform Act of 1976 ("},{"tag":"ref","attrib":{"href":"/us/usc/t45/s821"},"text":"45 U.S.C. 821","children":[],"tail":" et seq.)” and struck out “and "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s916/b"},"text":"section 916(b) of this title","children":[],"tail":"” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s21301/j/3/F/ii"},"text":"Pub. L. 117–58, § 21301(j)(3)(F)(ii)","children":[],"tail":", substituted “chapter 224 of title 49, including section 22404 of such title,” for “title V of the Railroad Revitalization and Regulatory Reform Act of 1976, and section 516 of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t45/s836"},"text":"45 U.S.C. 836","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" substituted “the provisions of "},{"tag":"ref","attrib":{"href":"/us/pl/96/131"},"text":"Public Law 96–131","children":[],"tail":"” for “the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s11125"},"text":"section 11125 of title 49","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/pl/96/131"},"text":"Public Law 96–131","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id27f1345e-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id27f1345f-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of Title 49","children":[],"tail":", Transportation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id27f13460-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Interstate Commerce Commission and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Interstate Commerce Commission abolished and functions of Commission transferred, except as otherwise provided in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", to Surface Transportation Board effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1302"},"text":"section 1302 of Title 49","children":[],"tail":", Transportation, and "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s101"},"text":"section 101 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of Title 49","children":[],"tail":". References to Interstate Commerce Commission deemed to refer to Surface Transportation Board, a member or employee of the Board, or Secretary of Transportation, as appropriate, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s205"},"text":"section 205 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of Title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
