{"tag":"section","attrib":{"id":"id27f13494-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1009"},"text":null,"children":[{"tag":"num","attrib":{"value":"1009"},"text":"§ 1009.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited proceedings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id27f13495-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1009/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall give all proceedings involving the Rock Island Railroad preference over all other pending proceedings related to rail carriers and make all of its decisions at the earliest practicable time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27f13496-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1009/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall, within 100 days of the filing of an application (or such shorter period as the court may set) pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s915"},"text":"section 915 of this title","children":[],"tail":", reach a decision on all proceedings filed after "},{"tag":"date","attrib":{"date":"1980-01-01"},"text":"January 1, 1980","children":[],"tail":", which involve a sale, transfer or lease of any line of the Rock Island Railroad to a solvent carrier."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27f13497-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/254/tI/s111"},"text":"Pub. L. 96–254, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-05-30"},"text":"May 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/404"},"text":"94 Stat. 404","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27f13498-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id27f13499-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id27f1349a-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Interstate Commerce Commission and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Interstate Commerce Commission abolished and functions of Commission transferred, except as otherwise provided in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", to Surface Transportation Board effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1302"},"text":"section 1302 of Title 49","children":[],"tail":", Transportation, and "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s101"},"text":"section 101 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of Title 49","children":[],"tail":". References to Interstate Commerce Commission deemed to refer to Surface Transportation Board, a member or employee of the Board, or Secretary of Transportation, as appropriate, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s205"},"text":"section 205 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of Title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
