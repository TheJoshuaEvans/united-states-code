{"tag":"section","attrib":{"id":"id27fad152-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1214"},"text":null,"children":[{"tag":"num","attrib":{"value":"1214"},"text":"§ 1214.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any provision of this chapter or the application thereof to any person or circumstance is held invalid, the remainder of this chapter and the application of such provision to other persons or circumstances shall not be affected thereby.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id27fad153-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/468/tVI/s616"},"text":"Pub. L. 97–468, title VI, § 616","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2578"},"text":"96 Stat. 2578","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
