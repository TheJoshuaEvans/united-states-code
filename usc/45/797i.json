{"tag":"section","attrib":{"id":"id27ec799f-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797i"},"text":null,"children":[{"tag":"num","attrib":{"value":"797i"},"text":"§ 797i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id27ec79a0-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The liability of the United States under an agreement entered into or benefit schedule prescribed under section 797 ","children":[{"tag":"ref","attrib":{"idref":"fn002067"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002067"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title or for payment of a termination allowance under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s797a"},"text":"section 797a of this title","children":[],"tail":" shall be limited to amounts appropriated under section 797"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" "},{"tag":"ref","attrib":{"idref":"fn002067"},"text":"1","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27ec79a1-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" The Corporation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id27ec79a2-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Corporation, Amtrak Commuter, and commuter authorities shall incur no liability under an agreement entered into or benefit schedule prescribed under section 797 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title or for the payment of a termination allowance under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s797a"},"text":"section 797a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27ec79a3-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, until ","children":[{"tag":"date","attrib":{"date":"1984-04-01"},"text":"April 1, 1984","children":[],"tail":", the Corporation shall have no liability for employee protection in the event of a sale of any asset to a purchaser, and such purchaser shall assume the liability for the application of employee protection conditions imposed by the Commission for all employees adversely affected by such sale."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27ec79a4-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/236/tVII/s710"},"text":"Pub. L. 93–236, title VII, § 710","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXI/s1143/a"},"text":"Pub. L. 97–35, title XI, § 1143(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/667"},"text":"95 Stat. 667","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27ec79a5-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27ec79a6-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id27ec79a7-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s797"},"text":"Section 797 of this title","children":[],"tail":", referred to in subsecs. (a) and (b)(1), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/99/509/tIV/s4024/c"},"text":"Pub. L. 99–509, title IV, § 4024(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1904"},"text":"100 Stat. 1904","children":[],"tail":", effective on the sale date ("},{"tag":"date","attrib":{"date":"1987-04-02"},"text":"Apr. 2, 1987","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 797","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title, referred to in subsec. (a), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/99/509/tIV/s4033/a/2"},"text":"Pub. L. 99–509, title IV, § 4033(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1908"},"text":"100 Stat. 1908","children":[],"tail":", and a new section 797"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title was subsequently added by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s327/5"},"text":"Pub. L. 104–88, § 327(5)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id27ec79a8-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id27ec79a9-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Interstate Commerce Commission and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Interstate Commerce Commission abolished and functions of Commission transferred, except as otherwise provided in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", to Surface Transportation Board effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1302"},"text":"section 1302 of Title 49","children":[],"tail":", Transportation, and "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s101"},"text":"section 101 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of Title 49","children":[],"tail":". References to Interstate Commerce Commission deemed to refer to Surface Transportation Board, a member or employee of the Board, or Secretary of Transportation, as appropriate, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s205"},"text":"section 205 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of Title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
