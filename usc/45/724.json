{"tag":"section","attrib":{"id":"id27de211e-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s724"},"text":null,"children":[{"tag":"num","attrib":{"value":"724"},"text":"§ 724.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id27de211f-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s724/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary for purposes of preparing the reports and exercising other functions to be performed by him under this chapter such sums as are necessary, not to exceed $12,500,000, to remain available until expended. There are authorized to be appropriated to the Secretary such sums as may be necessary to discharge the obligations of the United States arising under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s743/c/5"},"text":"section 743(c)(5) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27de2120-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s724/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Commission for the use of the Office in carrying out its functions under this chapter such sums as are necessary, not to exceed $7,000,000, to remain available until expended. The budget for the Office shall be submitted by the Commission directly to the Congress and shall not be subject to review of any kind by any other agency or official of the United States. Moneys appropriated for the Office shall not be withheld by any agency or official of the United States or used by the Commission for any purpose other than the use of the Office. No part of any other moneys appropriated to the Commission shall be withheld by any other agency or official of the United States to offset any moneys appropriated pursuant to this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27de2121-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s724/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Association","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Association for purposes of carrying out its administrative expenses under this chapter not to exceed $13,000,000 for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1982-09-30"},"text":"September 30, 1982","children":[],"tail":", and not to exceed $4,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1983-09-30"},"text":"September 30, 1983","children":[],"tail":". Sums appropriated under this subsection are authorized to remain available until expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27de2122-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/236/tII/s214"},"text":"Pub. L. 93–236, title II, § 214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-01-02"},"text":"Jan. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/1003"},"text":"87 Stat. 1003","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/488/s1/c"},"text":"Pub. L. 93–488, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date"