{"tag":"section","attrib":{"id":"id27fad227-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1345"},"text":null,"children":[{"tag":"num","attrib":{"value":"1345"},"text":"§ 1345.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall affect any obligation of the Corporation to carry out its transportation contracts and equipment leases, equipment trusts, and conditional sales agreements, in accordance with their terms.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id27fad228-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tIV/s4037"},"text":"Pub. L. 99–509, title IV, § 4037","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1909"},"text":"100 Stat. 1909","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
