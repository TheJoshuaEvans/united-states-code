{"tag":"section","attrib":{"id":"id27f1342f-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s921"},"text":null,"children":[{"tag":"num","attrib":{"value":"921"},"text":"§ 921.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Rail Public Counsel","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Office of Rail Public Counsel may appear and be heard in the case in the bankruptcy court involving the reorganization of the Milwaukee Railroad, for purposes of representing affected shippers, localities, and municipalities with respect to the proposed abandonment of any line of the Milwaukee Railroad.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id27f13430-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/101/s25"},"text":"Pub. L. 96–101, § 25","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-11-04"},"text":"Nov. 4, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/747"},"text":"93 Stat. 747","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
