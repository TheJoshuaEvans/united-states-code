{"tag":"section","attrib":{"id":"id27f3a53d-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1108"},"text":null,"children":[{"tag":"num","attrib":{"value":"1108"},"text":"§ 1108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concerted economic action","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id27f3a53e-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strikes interfering with rail freight service of Conrail","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person engaging in concerted economic action over disputes with Amtrak Commuter or any commuter authority shall not be entitled to engage in any strike against, or otherwise to induce any employee of, Conrail, where an effect thereof is to interfere with rail freight service provided by Conrail.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27f3a53f-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strikes interfering with Amtrak Commuter’s rail passenger service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person engaging in concerted economic action over disputes arising out of freight operations provided by Conrail shall not be entitled to engage in any strike against, or otherwise to induce any employee of, Amtrak Commuter or any commuter authority, where an effect thereof is to interfere with rail passenger service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27f3a540-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1108/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Railway Labor Act deemed violated","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any concerted action in violation of this section shall be deemed to be a violation of the Railway Labor Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s151"},"text":"45 U.S.C. 151","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27f3a541-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXI/s1158"},"text":"Pub. L. 97–35, title XI, § 1158","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/682"},"text":"95 Stat. 682","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27f3a542-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27f3a543-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id27f3a544-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Railway Labor Act, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-05-20/ch347"},"text":"act May 20, 1926, ch. 347","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/577"},"text":"44 Stat. 577","children":[],"tail":", which is classified principally to chapter 8 (§ 151 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s151"},"text":"section 151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
