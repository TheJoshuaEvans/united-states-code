{"tag":"section","attrib":{"id":"id27ea0862-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797c"},"text":null,"children":[{"tag":"num","attrib":{"value":"797c"},"text":"§ 797c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Central register of railroad employment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id27ea0863-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Register","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id27ea0864-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Railroad Retirement Board (hereafter in this section referred to as the “Board”) shall prepare and maintain a register of persons separated from railroad employment after at least one year of completed service with a railroad who have declared their current availability for employment in the railroad industry. The register shall be subdivided by class and craft of prior employment and shall be updated periodically to reflect current availability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27ea0865-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each entry in the register shall include, or provide access to, basic information concerning the individual’s experience and qualifications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27ea0866-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board shall place at the top of the register those former railroad employees entitled to priority under applicable provisions of law, including this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27ea0867-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporation employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as is practicable after ","children":[{"tag":"date","attrib":{"date":"1981-08-13"},"text":"August 13, 1981","children":[],"tail":", the Corporation shall provide to the Board the names of its former employees who elect to appear on the register and who have not been offered employment with acquiring railroads."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27ea0868-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancy notices; warning; civil penalty","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id27ea0869-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each railroad shall timely file with the Board a notice of vacancy with respect to any position for which the railroad intends to accept applications from persons other than current employees of that carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27ea086a-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id27ea086b-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797c/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As soon as the Board becomes aware of any failure on the part of a railroad to comply with paragraph (1), the Board shall issue a warning to such railroad of its potential liability under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id27ea086c-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797c/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any railroad failing to comply with paragraph (1) of this subsection after being warned by the Board under subparagraph (A) shall be liable for a civil penalty in the amount of $500 for each subsequent vacancy with respect to which such railroad has so failed to comply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27ea086d-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Placement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall, through distribution of copies of the central register (or portions thereof) to railroads and representatives of classes or crafts of employees and through publication of employment information derived from vacancy notices filed with the Board, promote the placement of former railroad employees possessing requisite skills and experience in appropriate positions with other railroads.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27ea086e-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to its responsibilities under subsections (a) through (d) of this section, the Board shall facilitate the filing of employment applications with respect to current vacancies in the industry by former railroad employees entitled to priority under applicable provisions of law, including this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27ea086f-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expiration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section shall cease to be effective on the expiration of the 6-year period beginning on ","children":[{"tag":"date","attrib":{"date":"1981-08-13"},"text":"August 13, 1981","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27ea0870-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797c/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resolution of disputes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any dispute, grievance, or claim arising under this section, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s797b"},"text":"section 797b of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s907"},"text":"section 907 of this title","children":[],"tail":", or "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1004"},"text":"section 1004 of this title","children":[],"tail":" shall be subject to resolution in accordance with the following procedures:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id27ea0871-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797c/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any employee with such a dispute, grievance, or claim may petition the Board to review and investigate the dispute, grievance, or claim.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27ea0872-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797c/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board shall investigate the dispute, grievance, or claim, and if it concludes that the employee’s rights under this section, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s797b"},"text":"section 797b of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s907"},"text":"section 907 of this title","children":[],"tail":", or "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1004"},"text":"section 1004 of this title","children":[],"tail":" may have been violated, the dispute, grievance, or claim shall be subject to resolution in accordance with the procedures set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s153"},"text":"section 153 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27ea0873-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797c/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of any violation of this section, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s797b"},"text":"section 797b of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s907"},"text":"section 907 of this title","children":[],"tail":", or "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1004"},"text":"section 1004 of this title","children":[],"tail":", the Adjustment Board (or any division or delegate thereof) or any other board of adjustment created under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s153"},"text":"section 153 of this title","children":[],"tail":" shall, where appropriate, award such relief, including back pay, as may be necessary to enforce the employee’s rights."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27ea0874-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/236/tVII/s704"},"text":"Pub. L. 93–236, title VII, § 704","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXI/s1143/a"},"text":"Pub. L. 97–35, title XI, § 1143(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/663"},"text":"95 Stat. 663","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/468/tII/s235"},"text":"Pub. L. 97–468, title II, § 235","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2547"},"text":"96 Stat. 2547","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tIV/s4011/a"},"text":"Pub. L. 99–272, title IV, § 4011(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/108"},"text":"100 Stat. 108","children":[],"tail":", 109.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27ea0875-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27ea0876-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id27ea0877-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/s4011/a"},"text":"Pub. L. 99–272, § 4011(a)","children":[],"tail":", designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/s4011/b"},"text":"Pub. L. 99–272, § 4011(b)","children":[],"tail":", substituted “6-year” for “4-year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/468/s235/a"},"text":"Pub. L. 97–468, § 235(a)","children":[],"tail":", substituted “4-year” for “3-year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/468/s235/b"},"text":"Pub. L. 97–468, § 235(b)","children":[],"tail":", substituted “this section, "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s797b"},"text":"section 797b of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s907"},"text":"section 907 of this title","children":[],"tail":", or "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1004"},"text":"section 1004 of this title","children":[],"tail":"” for “this section or "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s797b"},"text":"section 797b of this title","children":[],"tail":"” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id27ea0878-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id27ea0879-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/tIV/s4011/d"},"text":"Pub. L. 99–272, title IV, § 4011(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/109"},"text":"100 Stat. 109","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/272/tIV/s4011/d"},"text":"“The amendments made by subsections (a) and (c) [amending this section and enacting provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s797b"},"text":"section 797b of this title","children":[],"tail":"] shall take effect on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":"], and the amendment made by subsection (b) [amending this section] shall be effective as of "},{"tag":"date","attrib":{"date":"1985-08-01"},"text":"August 1, 1985","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
