{"tag":"section","attrib":{"id":"id27d23ac1-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s402"},"text":null,"children":[{"tag":"num","attrib":{"value":"402"},"text":"§ 402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange of information between Secretary of Labor and Railroad Retirement Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor, upon request, shall furnish the Railroad Retirement Board information deemed necessary by such Board for the administration of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s401"},"text":"section 401 of this title","children":[],"tail":", and such Board, upon request, shall furnish the Secretary of Labor information deemed necessary by the Secretary for the administration of the Temporary Extended Unemployment Compensation Act of 1961."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id27d23ac2-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/7/s3"},"text":"Pub. L. 87–7, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-03-24"},"text":"Mar. 24, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/17"},"text":"75 Stat. 17","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27d23ac3-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27d23ac4-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id27d23ac5-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Temporary Extended Unemployment Compensation Act of 1961, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/6"},"text":"Pub. L. 87–6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-03-24"},"text":"Mar. 24, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/8"},"text":"75 Stat. 8","children":[],"tail":", which enacted sections 1105 and 1400"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" to 1400v of Title 42, The Public Health and Welfare, amended sections 3301 and 3302 of Title 26, Internal Revenue Code, and enacted provisions set out as notes under sections 1101 and 1400"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of Title 42. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
