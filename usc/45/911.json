{"tag":"section","attrib":{"id":"id27eec3bd-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s911"},"text":null,"children":[{"tag":"num","attrib":{"value":"911"},"text":"§ 911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New career training assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id27eec3be-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s911/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any employee who elects to receive a separation allowance from the Milwaukee Railroad under an employee protection agreement entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s908"},"text":"section 908 of this title","children":[],"tail":" shall be entitled to receive from the Board expenses for training in qualified institutions for new career opportunities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27eec3bf-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s911/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement of training as condition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be entitled for assistance under this section, an employee must begin his course of training within two years following the date of his separation from employment with the Milwaukee Railroad.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27eec3c0-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s911/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing of application; Board determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Entitlement to expenses for assistance under this section shall be determined by the Board on the basis of an application therefor filed by an employee with the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27eec3c1-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s911/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance prohibited after ","children":[{"tag":"date","attrib":{"date":"1984-04-01"},"text":"April 1, 1984","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No assistance may be provided under this section after ","children":[{"tag":"date","attrib":{"date":"1984-04-01"},"text":"April 1, 1984","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27eec3c2-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s911/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id27eec3c3-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s911/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “expenses” means actual expenses paid for room, board, tuition, fees, or educational material in an amount not to exceed $3,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27eec3c4-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s911/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “qualified institution” means an educational institution accredited for payment by the Veterans’ Administration under chapter 36 of title 38, or a State-accredited institution which has been in existence for not less than two years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27eec3c5-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/101/s12"},"text":"Pub. L. 96–101, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-11-04"},"text":"Nov. 4, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/743"},"text":"93 Stat. 743","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/254/tI/s119/f"},"text":"Pub. L. 96–254, title I, § 119(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-05-30"},"text":"May 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/408"},"text":"94 Stat. 408","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27eec3c6-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27eec3c7-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id27eec3c8-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/254"},"text":"Pub. L. 96–254","children":[],"tail":" inserted reference to State-accredited institutions which have been in existence for not less than two years."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id27eec3c9-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id27eec3ca-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to Veterans’ Administration deemed to refer to Department of Veterans Affairs pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/527/s10"},"text":"section 10 of Pub. L. 100–527","children":[],"tail":", set out as a Department of Veterans Affairs Act note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s301"},"text":"section 301 of Title 38","children":[],"tail":", Veterans’ Benefits."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
