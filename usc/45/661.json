{"tag":"section","attrib":{"id":"id27d4844f-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s661"},"text":null,"children":[{"tag":"num","attrib":{"value":"661"},"text":"§ 661.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id27d48450-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s661/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27d48451-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s661/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Board” means the Surface Transportation Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27d48452-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s661/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Railroad” means any rail carrier subject to part A of subtitle IV of title 49.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27d48453-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s661/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Certificate” means certificates issued by trustees of a railroad pursuant to subsection 77(c)(3) of the Bankruptcy Act, as amended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27d48454-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/663/s2"},"text":"Pub. L. 91–663, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-08"},"text":"Jan. 8, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1975"},"text":"84 Stat. 1975","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/tIII/s325/1"},"text":"Pub. L. 104–88, title III, § 325(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/951"},"text":"109 Stat. 951","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27d48455-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27d48456-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id27d48457-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 77(c)(3) of the Bankruptcy Act, referred to in par. (4), was classified to section 205(c)(3) of former Title 11, Bankruptcy. The Bankruptcy Act (","children":[{"tag":"ref","attrib":{"href":"/us/act/1898-07-01/ch541"},"text":"act July 1, 1898, ch. 541","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/544"},"text":"30 Stat. 544","children":[],"tail":") was repealed effective "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", §§ 401(a), 402(a), "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2682"},"text":"92 Stat. 2682","children":[],"tail":", section 101 of which enacted revised Title 11. For current provisions relating to railroad reorganization, see subchapter IV (§ 1161 et seq.) of chapter 11 of Title 11."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id27d48458-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1995—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/s325/1/A"},"text":"Pub. L. 104–88, § 325(1)(A)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows: “ ‘Commission’ means the Interstate Commerce Commission.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/s325/1/B"},"text":"Pub. L. 104–88, § 325(1)(B)","children":[],"tail":", substituted “rail carrier subject to part A of subtitle IV of title 49” for “common carrier by railroad subject to part I of the Interstate Commerce Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1–27"},"text":"49 U.S.C. 1–27","children":[],"tail":")”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id27d48459-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id27d4845a-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of Title 49","children":[],"tail":", Transportation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id27d4845b-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/663/s1"},"text":"Pub. L. 91–663, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-08"},"text":"Jan. 8, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1975"},"text":"84 Stat. 1975","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/663/s1"},"text":"“That this Act [enacting this chapter] may be cited as the ‘Emergency Rail Services Act of 1970’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
