{"tag":"section","attrib":{"id":"id27c89d7e-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s357"},"text":null,"children":[{"tag":"num","attrib":{"value":"357"},"text":"§ 357.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Free transportation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall not be unlawful for carriers to furnish free transportation to employees qualified for benefits or serving waiting periods under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id27c89d7f-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch680/s7"},"text":"June 25, 1938, ch. 680, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1102"},"text":"52 Stat. 1102","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27c89d80-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27c89d81-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id27c89d82-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch680"},"text":"act June 25, 1938, ch. 680","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1094"},"text":"52 Stat. 1094","children":[],"tail":", which enacted this chapter and amended sections 503 and 1104 and former "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1107"},"text":"section 1107 of Title 42","children":[],"tail":", The Public Health and Welfare. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s367"},"text":"section 367 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
