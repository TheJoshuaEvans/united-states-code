{"tag":"section","attrib":{"id":"id27e092a6-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s728"},"text":null,"children":[{"tag":"num","attrib":{"value":"728"},"text":"§ 728.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id27e092a7-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s728/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Progress and evaluation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id27e092a8-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s728/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Association shall prepare and submit to Congress periodic reports on the progress of the Secretary in carrying out the provisions of subchapters II, III, and IV ","children":[{"tag":"ref","attrib":{"idref":"fn002052"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002052"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27e092a9-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s728/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reports submitted under paragraph (1) of this subsection shall also include an evaluation of the performance of the Corporation in order to keep the Congress informed as to matters which may affect the quality of rail service in the Northeast and which may affect the security of Federal funds invested in the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27e092aa-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s728/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id27e092ab-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s728/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Association shall prepare and submit to Congress a final report on the transfer agreements which the Secretary is required to transmit to Congress under section 767 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title. Such report shall be submitted on the same date as the Secretary’s transmittal of such agreements to Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27e092ac-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s728/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The report submitted under paragraph (1) of this subsection shall include an evaluation of the effect of the transfer agreements on rail service in the Northeast, railroad employees, the economy of the Region, other railroads in the Northeast and elsewhere, and any other matter which the Association considers appropriate. Such report shall also include recommendations with respect to approval, disapproval, or modification of the transfer agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27e092ad-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/236/tII/s218"},"text":"Pub. L. 93–236, title II, § 218","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXI/s1150/a"},"text":"Pub. L. 97–35, title XI, § 1150(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/675"},"text":"95 Stat. 675","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27e092ae-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27e092af-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id27e092b0-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapter IV of this chapter, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s767"},"text":"section 767 of this title","children":[],"tail":", referred to in subsecs. (a)(1) and (b)(1), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/99/509/tIV/s4033/a/1"},"text":"Pub. L. 99–509, title IV, § 4033(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1908"},"text":"100 Stat. 1908","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id27e092b1-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id27e092b2-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":n