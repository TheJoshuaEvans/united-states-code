{"tag":"section","attrib":{"id":"id27ec798e-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797g"},"text":null,"children":[{"tag":"num","attrib":{"value":"797g"},"text":"§ 797g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New collective-bargaining agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id27ec798f-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the effective date of any conveyance pursuant to the provisions of this chapter, the representatives of the various classes or crafts of employees of a railroad in reorganization involved in a conveyance and representatives of the Corporation shall commence negotiation of a new single collective bargaining agreement for each class and craft of employees covering the rate of pay, rules, and working conditions of employees who are the employees of the Corporation. Such collective bargaining agreement shall include appropriate provisions concerning rates of pay, rules, and working conditions, but shall not, before ","children":[{"tag":"date","attrib":{"date":"1984-04-01"},"text":"April 1, 1984","children":[],"tail":", include any provisions for job stabilization which may exceed or conflict with those established herein. Negotiations with respect to such single collective bargaining agreement, and any successor thereto, shall be conducted systemwide."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27ec7990-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id27ec7991-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any procedure for finally determining the components of the first single collective bargaining agreement for any class or craft, agreed upon before ","children":[{"tag":"date","attrib":{"date":"1981-08-13"},"text":"August 13, 1981","children":[],"tail":", shall be completed no later than 45 days after "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"August 13, 1981","children":[],"tail":". Such agreed upon procedure shall be deemed to satisfy the requirements of sections 157 and 158 of this title. The National Mediation Board shall appoint any person as provided for by such agreements."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27ec7992-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section shall be construed to require the parties to enter into a new single collective bargaining agreement if the agreement between the parties in effect immediately prior to ","children":[{"tag":"date","attrib":{"date":"1981-08-13"},"text":"August 13, 1981","children":[],"tail":", complied with section 774(d) "},{"tag":"ref","attrib":{"idref":"fn002066"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002066"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title as in effect immediately prior to such date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27ec7993-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Railway Labor Act notices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Employees of the Corporation may not serve notices under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s156"},"text":"section 156 of this title","children":[],"tail":" for the purpose of negotiating job stabilization or other protective agreements with the Corporation until after "},{"tag":"date","attrib":{"date":"1984-04-01"},"text":"April 1, 1984","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27ec7994-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/236/tVII/s708"},"text":"Pub. L. 93–236, title VII, § 708","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXI/s1143/a"},"text":"Pub. L. 97–35, title XI, § 1143(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/665"},"text":"95 Stat. 665","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27ec7995-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27ec7996-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id27ec7997-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s774"},"text":"Section 774 of this title","children":[],"tail":", referred to in subsec. (b)(2), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXI/s1144/a/1"},"text":"Pub. L. 97–35, title XI, § 1144(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/669"},"text":"95 Stat. 669","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
