{"tag":"section","attrib":{"id":"id27e2dbec-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s742"},"text":null,"children":[{"tag":"num","attrib":{"value":"742"},"text":"§ 742.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers and duties of Corporation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Corporation shall have all of the powers and is subject to all of the duties vested in it under this chapter, in addition to the powers conferred upon it under the laws of the State or States in which it is incorporated and the powers of a railroad in any State in which it operates. The Corporation is authorized and directed to—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id27e2dbed-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s742/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire rail properties designated in the final system plan to be transferred or conveyed to it;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27e2dbee-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s742/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate rail service over such rail properties except as provided under sections 744(e) and 791(d)(3) of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27e2dbef-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s742/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rehabilitate, improve, and modernize such rail properties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27e2dbf0-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s742/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain adequate and efficient rail services.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"So long as 50 per centum or more, as determined by the Secretary of the Treasury, of the outstanding indebtedness of the Corporation consists of obligations of the Association or other debts owing to or guaranteed by the United States, the Corporation shall not engage in activities which are not related to transportation.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27e2dbf1-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/236/tIII/s302"},"text":"Pub. L. 93–236, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-01-02"},"text":"Jan. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/1005"},"text":"87 Stat. 1005","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27e2dbf2-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id27e2dbf3-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id27e2dbf4-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of United States Railway Association and Transfer of Functions and Securities","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s1341"},"text":"section 1341 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
