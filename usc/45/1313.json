{"tag":"section","attrib":{"id":"id27fad1af-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1313"},"text":null,"children":[{"tag":"num","attrib":{"value":"1313"},"text":"§ 1313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id27fad1b0-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1313/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment banking firm fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Transportation, in consultation with the Secretary of the Treasury, shall agree to pay to investment banking firms and other persons participating with such firms in the public offering the absolute minimum amount in fees necessary to carry out the public offering.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27fad1b1-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1313/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs of public offering","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All costs of the public offering payable by the Secretary of Transportation shall be paid from the proceeds of the public offering.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27fad1b2-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tIV/s4013"},"text":"Pub. L. 99–509, title IV, § 4013","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1897"},"text":"100 Stat. 1897","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
