{"tag":"section","attrib":{"id":"id2796917a-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s151a"},"text":null,"children":[{"tag":"num","attrib":{"value":"151a"},"text":"§ 151a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purposes of the chapter are: (1) To avoid any interruption to commerce or to the operation of any carrier engaged therein; (2) to forbid any limitation upon freedom of association among employees or any denial, as a condition of employment or otherwise, of the right of employees to join a labor organization; (3) to provide for the complete independence of carriers and of employees in the matter of self-organization to carry out the purposes of this chapter; (4) to provide for the prompt and orderly settlement of all disputes concerning rates of pay, rules, or working conditions; (5) to provide for the prompt and orderly settlement of all disputes growing out of grievances or out of the interpretation or application of agreements covering rates of pay, rules, or working conditions.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id2796917b-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-05-20/ch347/s2"},"text":"May 20, 1926, ch. 347, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/577"},"text":"44 Stat. 577","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1934-06-21/ch691/s2"},"text":"June 21, 1934, ch. 691, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1186"},"text":"48 Stat. 1186","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2796917c-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2796917d-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id2796917e-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of the first sentence of section 2 of act ","children":[{"tag":"date","attrib":{"date":"1926-05-20"},"text":"May 20, 1926","children":[],"tail":", as added in the general amendment of section 2 by act "},{"tag":"date","attrib":{"date":"1934-06-21"},"text":"June 21, 1934","children":[],"tail":". The remainder of section 2 of act "},{"tag":"date","attrib":{"date":"1926-05-20"},"text":"May 20, 1926","children":[],"tail":", is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s152"},"text":"section 152 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2796917f-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1934—Act ","children":[{"tag":"date","attrib":{"date":"1934-06-21"},"text":"June 21, 1934","children":[],"tail":", amended section 2 of act "},{"tag":"date","attrib":{"date":"1926-05-20"},"text":"May 20, 1926","children":[],"tail":", generally, adding the text of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
