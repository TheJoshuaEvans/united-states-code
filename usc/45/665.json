{"tag":"section","attrib":{"id":"id27d4847f-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s665"},"text":null,"children":[{"tag":"num","attrib":{"value":"665"},"text":"§ 665.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of services and facilities of Federal departments and agencies; reimbursement; consultation with Board; coordination of activities with Federal departments and agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id27d48480-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s665/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out the provisions of this chapter the Secretary may use available services and facilities of other departments, agencies, and instrumentalities of the Federal Government with their consent and on a reimbursable basis, and shall consult with the Board in carrying out the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27d48481-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s665/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Departments, agencies, and instrumentalities of the Federal Government shall exercise their powers, duties, and functions in such manner as will assist in carrying out the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27d48482-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/663/s6"},"text":"Pub. L. 91–663, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-08"},"text":"Jan. 8, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1977"},"text":"84 Stat. 1977","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/tIII/s325/3"},"text":"Pub. L. 104–88, title III, § 325(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/951"},"text":"109 Stat. 951","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27d48483-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27d48484-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id27d48485-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1995—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" substituted “Board” for “Interstate Commerce Commission”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id27d48486-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id27d48487-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of Title 49","children":[],"tail":", Transportation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
