"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXIII/s13302"},"text":"Pub. L. 99–272, title XIII, § 13302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/327"},"text":"100 Stat. 327","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVII/s7103/b/1"},"text":"Pub. L. 100–647, title VII, § 7103(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3770"},"text":"102 Stat. 3770","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27cd7f37-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27cd7f38-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id27cd7f39-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s358/g"},"text":"Section 358(g) of this title","children":[],"tail":", referred to in subsec. (a), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s358/j"},"text":"section 358(j) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVII/s7102/d/1"},"text":"Pub. L. 100–647, title VII, § 7102(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3769"},"text":"102 Stat. 3769","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a), (b), and (d), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch680"},"text":"act June 25, 1938, ch. 680","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1094"},"text":"52 Stat. 1094","children":[],"tail":", which enacted this chapter and amended sections 503 and 1104 and former "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1107"},"text":"section 1107 of Title 42","children":[],"tail":", The Public Health and Welfare. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s367"},"text":"section 367 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id27cd7f3a-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 10(e)–(g) of act ","children":[{"tag":"date","attrib":{"date":"1938-06-25"},"text":"June 25, 1938","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1104"},"text":"section 1104 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id27cd7f3b-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" substituted “0.65” for “0.5”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272"},"text":"Pub. L. 99–272","children":[],"tail":" struck out at end “No transfer shall be made under this subsection from Railroad Retirement Account after "},{"tag":"date","attrib":{"date":"1985-12-19"},"text":"December 19, 1985","children":[],"tail":", and no such transfer shall be made on or before "},{"tag":"date","attrib":{"date":"1985-12-19"},"text":"December 19, 1985","children":[],"tail":", for purposes of paying benefits and refunds due after such date.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/189"},"text":"Pub. L. 99–189","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1985-12-19"},"text":"December 19, 1985","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1985-12-18"},"text":"December 18, 1985","children":[],"tail":"” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/181"},"text":"Pub. L. 99–181","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1985-12-18"},"text":"December 18, 1985","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1985-12-14"},"text":"December 14, 1985","children":[],"tail":"” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/155"},"text":"Pub. L. 99–155","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1985-12-14"},"text":"December 14, 1985","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1985-11-14"},"text":"November 14, 1985","children":[],"tail":"” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/107"},"text":"Pub. L. 99–107","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1985-11-14"},"text":"November 14, 1985","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1985-09-30"},"text":"September 30, 1985","children":[],"tail":"” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/76"},"text":"Pub. L. 98–76","children":[],"tail":" inserted provisions that no transfer shall be made under this subsection from Railroad Retirement Account after "},{"tag":"date","attrib":{"date":"1985-09-30"},"text":"September 30, 1985","children":[],"tail":", and no such transfer shall be made on or before "},{"tag":"date","attrib":{"date":"1985-09-30"},"text":"September 30, 1985","children":[],"tail":", for purposes of paying benefits and refunds due after such date."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (a)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/92/s1/i/1"},"text":"Pub. L. 94–92, § 1(i)(1)","children":[],"tail":", substituted “0.5” for “0.25”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/92/s1/i/2"},"text":"Pub. L. 94–92, § 1(i)(2)","children":[],"tail":", struck out “and pursuant to subsection (h)[e] of this section”. Congress probably intended to strike out internal reference to subsec. (e) of this section in view of repeal of subsection by "},{"tag":"ref","attrib":{"href":"/us/pl/93/445/s403"},"text":"section 403 of Pub. L. 93–445","children":[],"tail":" and it being last subsection of section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/445"},"text":"Pub. L. 93–445","children":[],"tail":" repealed subsec. (e) which was added by "},{"tag":"ref","attrib":{"href":"/us/pl/90/257"},"text":"Pub. L. 90–257","children":[],"tail":" as subsec. (h) and redesignated (e) for purposes of codification, and which provided for annual adjustment of account and transfer of funds from Railroad Retirement Account."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (a)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/257"},"text":"Pub. L. 90–257","children":[],"tail":" inserted reference to amounts transferred or paid into account pursuant to subsec. (e) of this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/257"},"text":"Pub. L. 90–257","children":[],"tail":" added subsec. (e) which was subsec. (h) in original and was redesignated (e) for purposes of codification."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/700"},"text":"Pub. L. 89–700","children":[],"tail":" substituted “0.25 per centum” for “0.2 per centum”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1963—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/133"},"text":"Pub. L. 88–133","children":[],"tail":" substituted “a rate for each fiscal year equal to the average rate of interest borne by all special obligations held by the Railroad Retirement Account on the last day of the preceding fiscal year, rounded to the nearest multiple of one-eighth of 1 per centum” for “the rate of 3 per centum per annum.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/28"},"text":"Pub. L. 86–28","children":[],"tail":" substituted provisions authorizing Board to request transfer and retransfer of funds for provisions which directed Secretary of the Treasury to advance not more than $25,000,000 for purpose of paying benefits."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1948—Subsec. (a)(i). Act ","children":[{"ta