{"tag":"section","attrib":{"id":"id27f13419-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s918"},"text":null,"children":[{"tag":"num","attrib":{"value":"918"},"text":"§ 918.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Railroad Retirement Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id27f1341a-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s918/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board may prescribe such regulations as may be necessary to carry out its duties under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27f1341b-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s918/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out its duties under this chapter, the Board may exercise such of the powers, duties, and remedies provided in subsections (a), (b), and (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s362"},"text":"section 362 of this title","children":[],"tail":" as are not inconsistent with the provisions of this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27f1341c-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/101/s20"},"text":"Pub. L. 96–101, § 20","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-11-04"},"text":"Nov. 4, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/746"},"text":"93 Stat. 746","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
