{"tag":"section","attrib":{"id":"id27944707-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s57"},"text":null,"children":[{"tag":"num","attrib":{"value":"57"},"text":"§ 57.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Who included in term “common carrier”","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The term “common carrier” as used in this chapter shall include the receiver or receivers or other persons or corporations charged with the duty of the management and operation of the business of a common carrier.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id27944708-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1908-04-22/ch149/s7"},"text":"Apr. 22, 1908, ch. 149, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/66"},"text":"35 Stat. 66","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
