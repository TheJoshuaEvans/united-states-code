{"tag":"section","attrib":{"id":"id27fad1c7-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1322"},"text":null,"children":[{"tag":"num","attrib":{"value":"1322"},"text":"§ 1322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ownership limitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id27fad1c8-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1322/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id27fad1c9-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1322/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During a period of 3 years beginning on the sale date, no person, directly or indirectly, may acquire or hold securities representing more than 10 percent of the total votes of all outstanding voting securities of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27fad1ca-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1322/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This subsection shall not apply—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id27fad1cb-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1322/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the employee stock ownership plan (or successor plans) of the Corporation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id27fad1cc-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1322/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Secretary of Transportation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id27fad1cd-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1322/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a railroad as described under subsection (b),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id27fad1ce-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1322/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to underwriting syndicates holding shares for resale, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id27fad1cf-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1322/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of shares beneficially held for others, to commercial banks, broker-dealers, clearing corporations, or other nominees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27fad1d0-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1322/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Railroads","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id27fad1d1-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1322/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During a period of 1 year beginning on the sale date, no railroad may purchase or hold, directly or indirectly, more than 10 percent of any class of stock of the Corporation. During such period, no railroad may file an application with the Commission for a merger or consolidation with the Corporation or the acquisition of control of the Corporation under section 11344 ","children":[{"tag":"ref","attrib":{"idref":"fn002091"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002091"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 49."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27fad1d2-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1322/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During a period of 3 years beginning on the sale date, any railroad which purchases or holds any stock of the Corporation shall vote such stock in the same proportion as all other common stock of the Corporation is voted. After the expiration of 1 year after the sale date, the preceding sentence shall not apply to any railroad with respect to which the Commission has approved an application for a merger or consolidation with the Corporation or the acquisition of control of the Corporation under section 11344 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of title 49."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27fad1d3-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1322/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As used in this subsection, the term “railroad” means a class I railroad as determined by the Commission under the definition in effect on ","children":[{"tag":"date","attrib":{"date":"1986-10-21"},"text":"October 21, 1986","children":[],"tail":", and includes any entity controlling, controlled by, or under common control with any railroad (other than the Corporation or its subsidiaries)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27fad1d4-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tIV/s4022"},"text":"Pub. L. 99–509, title IV, § 4022","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1900"},"text":"100 Stat. 1900","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27fad1d5-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27fad1d6-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id27fad1d7-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s11344"},"text":"Section 11344 of title 49","children":[],"tail":", referred to in subsec. (b)(1), (2), was omitted in the general amendment of subtitle IV of Title 49, Transportation, by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/804"},"text":"109 Stat. 804","children":[],"tail":". Provisions similar to those in section 11344 are contained in sections 11324 and 14303 of Title 49."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id27fad1d8-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id27fad1d9-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Interstate Commerce Commission and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Interstate Commerce Commission abolished and functions of Commission transferred, except as otherwise provided in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", to Surface Transportation Board effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1302"},"text":"section 1302 of Title 49","children":[],"tail":", Transportation, and "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s101"},"text":"section 101 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of Title 49","children":[],"tail":". References to Interstate Commerce Commission deemed to refer to Surface Transportation Board, a member or employee of the Board, or Secretary of Transportation, as appropriate, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s205"},"text":"section 205 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of Title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
