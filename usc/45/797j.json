{"tag":"section","attrib":{"id":"id27ec79aa-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797j"},"text":null,"children":[{"tag":"num","attrib":{"value":"797j"},"text":"§ 797j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No State may adopt or continue in force any law, rule, regulation, order, or standard requiring the Corporation to employ any specified number of persons to perform any particular task, function, or operation, or requiring the Corporation to pay protective benefits to employees, and no State in the Region may adopt or continue in force any such law, rule, regulation, order, or standard with respect to any railroad in the Region.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id27ec79ab-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/236/tVII/s711"},"text":"Pub. L. 93–236, title VII, § 711","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXI/s1143/a"},"text":"Pub. L. 97–35, title XI, § 1143(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/667"},"text":"95 Stat. 667","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s7/b"},"text":"Pub. L. 103–272, § 7(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1379"},"text":"108 Stat. 1379","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27ec79ac-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27ec79ad-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id27ec79ae-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Pub. L. 103–272","children":[],"tail":" struck out “, the National Railroad Passenger Corporation, or the Amtrak Commuter Services Corporation” before “to employ any”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
