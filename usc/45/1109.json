{"tag":"section","attrib":{"id":"id27f3a545-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1109"},"text":null,"children":[{"tag":"num","attrib":{"value":"1109"},"text":"§ 1109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effectuation of cost reductions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any cost reductions resulting from the provisions of or the amendments made by this subtitle shall not be used to limit the maximum level of any rate charged by Conrail for the provision of rail service, to limit the amount of any increase in any such rate (including rates maintained jointly by Conrail and other rail carriers), or to limit a surcharge or cancellation otherwise lawful under chapter 107 ","children":[{"tag":"ref","attrib":{"idref":"fn002076"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002076"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 49."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id27f3a546-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXI/s1159"},"text":"Pub. L. 97–35, title XI, § 1159","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/682"},"text":"95 Stat. 682","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27f3a547-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27f3a548-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id27f3a549-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subtitle, referred to in text, is subtitle E (§§ 1131–1169) of title XI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/643"},"text":"95 Stat. 643","children":[],"tail":", known as the Northeast Rail Service Act of 1981. For complete classification of this subtitle to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1101"},"text":"section 1101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Chapter 107 of title 49, referred to in text, was omitted and a new chapter 107 enacted in the general amendment of subtitle IV of Title 49, Transportation, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/804"},"text":"109 Stat. 804","children":[],"tail":", 809."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
