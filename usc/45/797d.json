{"tag":"section","attrib":{"id":"id27ea087a-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797d"},"text":null,"children":[{"tag":"num","attrib":{"value":"797d"},"text":"§ 797d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election and treatment of benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id27ea087b-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id27ea087c-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any employee who accepts any benefits under an agreement entered into under section 797 ","children":[{"tag":"ref","attrib":{"idref":"fn002064"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002064"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title or a termination allowance under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s797a"},"text":"section 797a of this title","children":[],"tail":", shall, except as provided in paragraph (2) of this subsection, be deemed to waive any employee protection benefits otherwise available under any other provision of law or any contract or agreement in effect on "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"August 13, 1981","children":[],"tail":", except benefits under sections 797b and 797c of this title, and shall be deemed to waive any cause of action for any alleged loss of benefits resulting from the provisions of or the amendments made by the Northeast Rail Service Act of 1981."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"i