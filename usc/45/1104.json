{"tag":"section","attrib":{"id":"id27f3a50d-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1104"},"text":null,"children":[{"tag":"num","attrib":{"value":"1104"},"text":"§ 1104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subtitle, unless the context otherwise requires, the term:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id27f3a50e-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1104/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Amtrak” means the National Railroad Passenger Corporation created under chapter 243 of title 49.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27f3a50f-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1104/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Commission” means the Interstate Commerce Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27f3a510-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1104/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Commuter authority” means any State, local, or regional authority, corporation, or other entity established for purposes of providing commuter service, and includes the Metropolitan Transportation Authority, the Connecticut Department of Transportation, the Maryland Department of Transportation, the Southeastern Pennsylvania Transportation Authority, the New Jersey Transit Corporation, the Massachusetts Bay Transportation Authority, the Port Authority Trans-Hudson Corporation, any successor agencies, and any entity created by one or more such agencies for the purpose of operating, or contracting for the operation of, commuter service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27f3a511-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1104/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Commuter service” means short-haul rail passenger service operated in metropolitan and suburban areas, whether within or across the geographical boundaries of a State, usually characterized by reduced fare, multiple-ride, and commutation tickets, and by morning and evening peak period operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27f3a512-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1104/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Conrail” means the Consolidated Rail Corporation created under title III of the Regional Rail Reorganization Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s741"},"text":"45 U.S.C. 741","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27f3a513-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1104/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Rail carrier” means a common carrier engaged in interstate or foreign commerce by rail subject to subtitle IV of title 49.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27f3a514-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1104/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27f3a515-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1104/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Special court” means the judicial panel established under section 209(b)(1) of the Regional Rail Reorganization Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s719/b/1"},"text":"45 U.S.C. 719(b)(1)","children":[],"tail":") or, with respect to any proceedings that arise or continue after the panel is abolished pursuant to section 209(b)(2) of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t45/s719/b/2"},"text":"45 U.S.C. 719(b)(2)","children":[],"tail":"], the United States District Court for the District of Columbia."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27f3a516-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXI/s1135/a"},"text":"Pub. L. 97–35, title XI, § 1135(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/645"},"text":"95 Stat. 645","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/317/tVI/s605/c/3"},"text":"Pub. L. 104–317, title VI, § 605(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3859"},"text":"110 Stat. 3859","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27f3a517-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27f3a518-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id27f3a519-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subtitle, referred to in text, is subtitle E (§§ 1131–1169) of title XI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/643"},"text":"95 Stat. 643","children":[],"tail":", known as the Northeast Rail Service Act of 1981. For complete classification of this subtitle to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1101"},"text":"section 1101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Regional Rail Reorganization Act of 1973, referred to in par. (5), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/236"},"text":"Pub. L. 93–236","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-01-02"},"text":"Jan. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/985"},"text":"87 Stat. 985","children":[],"tail":". Title III of the Regional Rail Reorganization Act of 1973 is classified generally to subchapter III (§ 741 et seq.) of chapter 16 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s701"},"text":"section 701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id27f3a51a-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In par. (1), “chapter 243 of title 49” substituted for “title III of the Rail Passenger Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s541"},"text":"45 U.S.C. 541","children":[],"tail":" et seq.)” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s6/b"},"text":"Pub. L. 103–272, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1378"},"text":"108 Stat. 1378","children":[],"tail":", the first section of which enacted subtitles II, III, and V to X of Title 49, Transportation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id27f3a51b-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/317"},"text":"Pub. L. 104–317","children":[],"tail":" amended par. generally. Prior to amendment, par. read as follows: “ ‘Special court’ means the judicial panel established under section 209 of the Regional Rail Reorganization Act of 1973 ("},{"tag":"ref","attrib":{"href":"/us/usc/t45/s719"},"text":"45 U.S.C. 719","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id27f3a51c-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id27f3a51d-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/317"},"text":"Pub. L. 104–317","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", and except as otherwise provided, applicable proceedings that arise or continue after such effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/317/s605/e"},"text":"section 605(e) of Pub. L. 104–317","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s719"},"text":"section 719 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id27f3a51e-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Interstate Commerce Commission and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Interstate Commerce Commission abolished and functions of Commission transferred, except as otherwise provided in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", to Surface Transportation Board effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1302"},"text":"section 1302 of Title 49","children":[],"tail":", Transportation, and "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s101"},"text":"section 101 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of Title 49","children":[],"tail":". References to Interstate Commerce Commission deemed to refer to Surface Transportation Board, a member or employee of the Board, or Secretary of Transportation, as appropriate, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s205"},"text":"section 205 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of Title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
