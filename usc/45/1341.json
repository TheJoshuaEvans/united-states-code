{"tag":"section","attrib":{"id":"id27fad208-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1341"},"text":null,"children":[{"tag":"num","attrib":{"value":"1341"},"text":"§ 1341.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abolition of United States Railway Association","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id27fad209-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1341/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abolition and termination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id27fad20a-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1341/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Effective ","children":[{"tag":"date","attrib":{"date":"1987-04-01"},"text":"April 1, 1987","children":[],"tail":", the United States Railway Association is abolished."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27fad20b-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1341/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On ","children":[{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":", all powers, duties, rights, and obligations of such association relating to the Corporation under the Regional Rail Reorganization Act of 1973 ("},{"tag":"ref","attrib":{"href":"/us/usc/t45/s701"},"text":"45 U.S.C. 701","children":[],"tail":" et seq.) shall be transferred to the Secretary of Transportation."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27fad20c-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1341/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The sole function of the United States Railway Association after ","children":[{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":", shall be the termination of its affairs and the liquidation of its assets."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27fad20d-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1341/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of securities and responsibilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id27fad20e-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1341/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any securities of the Corporation held by the United States Railway Association shall, upon ","children":[{"tag":"ref","attrib":{"idref":"fn002093"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002093"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “on”."}],"tail":" "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"October 21, 1986","children":[],"tail":", be transferred to the Secretary of Transportation."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27fad20f-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1341/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If, on the date the United States Railway Association is abolished under subsection (a), such association shall not have completed the termination of its affairs and the liquidation of its assets, the duty of completing such winding up of its affairs and liquidation shall be transferred to the Secretary of Transportation, who for such purposes shall succeed to all remaining powers, duties, rights, and obligations of such association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27fad210-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1341/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financing agreement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id27fad211-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1341/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On ","children":[{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":", the Amended and Restated Financing Agreement, dated "},{"tag":"date","attrib":{"date":"1979-05-10"},"text":"May 10, 1979","children":[],"tail":", between the United States Railway Association and the Corporation, together with any and all rights and obligations of or on behalf of any person with respect to such agreement, shall terminate and be of no further force or effect, except for those provisions specifying terms and conditions for payments made to the United States with respect to debentures, preferred stock, and contingent interest notes."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27fad212-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1341/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Effective as of the sale date, those provisions of the Financing Agreement referred to in paragraph (1) shall terminate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27fad213-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tIV/s4031"},"text":"Pub. L. 99–509, title IV, § 4031","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1906"},"text":"100 Stat. 1906","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27fad214-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27fad215-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id27fad216-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Regional Rail Reorganization Act of 1973, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/236"},"text":"Pub. L. 93–236","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-01-02"},"text":"Jan. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/985"},"text":"87 Stat. 985","children":[],"tail":", which is classified principally to chapter 16 (§ 701 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s701"},"text":"section 701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
