{"tag":"section","attrib":{"id":"id27f13442-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1002"},"text":null,"children":[{"tag":"num","attrib":{"value":"1002"},"text":"§ 1002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id27f13443-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1002/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “bankruptcy court” means the court having jurisdiction over the reorganization of the Rock Island Railroad;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27f13444-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1002/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Board” means the Railroad Retirement Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27f13445-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1002/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Commission” means the Interstate Commerce Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27f13446-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1002/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “employee” includes any employee of the Rock Island Railroad as of ","children":[{"tag":"date","attrib":{"date":"1979-08-01"},"text":"August 1, 1979","children":[],"tail":", but does not include any individual serving as president, vice-president, secretary, treasurer, comptroller, counsel, member of the board of directors, or any other person performing such functions;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27f13447-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1002/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Rock Island Railroad” means the Chicago, Rock Island and Pacific Railroad Company, the estate of such Company in its reorganization proceeding, or the trustee appointed in such proceeding; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27f13448-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1002/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27f13449-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/254/tI/s103"},"text":"Pub. L. 96–254, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-05-30"},"text":"May 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/399"},"text":"94 Stat. 399","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/448/tVII/s701/b/3"},"text":"Pub. L. 96–448, title VII, § 701(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1960"},"text":"94 Stat. 1960","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27f1344a-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27f1344b-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id27f1344c-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title I (§ 101 et seq.) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/254"},"text":"Pub. L. 96–254","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-05-30"},"text":"May 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/399"},"text":"94 Stat. 399","children":[],"tail":", known as the Rock Island Railroad Transition and Employee Assistance Act, which is classified principally to this chapter. For complete classification of title I to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1001"},"text":"section 1001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id27f1344d-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/448"},"text":"Pub. L. 96–448","children":[],"tail":" inserted “, the estate of such Company in its reorganization proceeding, or the trustee appointed in such proceeding” after “Railroad Company”. The amendment was executed by inserting amendatory text preceding the semicolon instead of the period at end of par. (5) as directed to reflect the probable intent of Congress, in view of par. (5) being enacted without a closing period."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id27f1344e-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id27f1344f-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/448"},"text":"Pub. L. 96–448","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/448/s710/d"},"text":"section 710(d) of Pub. L. 96–448","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s1170"},"text":"section 1170 of Title 11","children":[],"tail":", Bankruptcy."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id27f13450-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Interstate Commerce Commission and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Interstate Commerce Commission abolished and functions of Commission transferred, except as otherwise provided in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", to Surface Transportation Board effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1302"},"text":"section 1302 of Title 49","children":[],"tail":", Transportation, and "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s101"},"text":"section 101 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of Title 49","children":[],"tail":". References to Interstate Commerce Commission deemed to refer to Surface Transportation Board, a member or employee of the Board, or Secretary of Transportation, as appropriate, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s205"},"text":"section 205 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of Title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
