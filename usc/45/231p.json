{"tag":"section","attrib":{"id":"id27bf2750-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s231p"},"text":null,"children":[{"tag":"num","attrib":{"value":"231p"},"text":"§ 231p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Free transportation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall not be unlawful for carriers by railroad subject to this subchapter to furnish free transportation to individuals receiving annuities under this subchapter in the same manner as such transportation is furnished to employees in their service.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id27bf2751-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-29/ch812/s17"},"text":"Aug. 29, 1935, ch. 812, § 17","children":[],"tail":", as restated "},{"tag":"ref","attrib":{"href":"/us/act/1937-06-24/ch382"},"text":"June 24, 1937, ch. 382","children":[],"tail":", pt. I, "},{"tag":"ref","attrib":{"href":"/us/stat/50/307"},"text":"50 Stat. 307","children":[],"tail":", as restated "},{"tag":"ref","attrib":{"href":"/us/pl/93/445/tI/s101"},"text":"Pub. L. 93–445, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-16"},"text":"Oct. 16, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1349"},"text":"88 Stat. 1349","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
