{"tag":"section","attrib":{"id":"id27f3a4d7-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1018"},"text":null,"children":[{"tag":"num","attrib":{"value":"1018"},"text":"§ 1018.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id27f3a4d8-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1018/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, any appeal from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id27f3a4d9-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1018/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any decision of the bankruptcy court with respect to the constitutionality of any provision of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27f3a4da-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1018/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any decision of the court having jurisdiction over the reorganization of the Milwaukee Railroad with respect to the constitutionality of the Milwaukee Railroad Restructuring Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s901"},"text":"45 U.S.C. 901","children":[],"tail":" et seq.),"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be taken to the United States Court of Appeals for the Seventh Circuit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27f3a4db-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1018/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appellate proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If appeals are taken from decisions described in subsection (a) of this section involving section 1005 or 1008 ","children":[{"tag":"ref","attrib":{"idref":"fn002074"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002074"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title or section 9 or 15 of the Milwaukee Railroad Restructuring Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t45/s908"},"text":"45 U.S.C. 908","children":[],"tail":" or 915], the court of appeals shall determine such appeals in a consolidated proceeding, sitting en banc."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27f3a4dc-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1018/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action in United States Court of Claims","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter or in the Milwaukee Railroad Restructuring Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s901"},"text":"45 U.S.C. 901","children":[],"tail":" et seq.) shall limit the right of any person to commence an action in the United States Court of Claims "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1491"},"text":"section 1491 of title 28","children":[],"tail":" (commonly referred to as the Tucker Act)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27f3a4dd-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/254/tI/s124"},"text":"Pub. L. 96–254, title I, § 124","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/448/tVII/s701/a/1"},"text":"Pub. L. 96–448, title VII, § 701(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1959"},"text":"94 Stat. 1959","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/620/tIV/s402/49"},"text":"Pub. L. 98–620, title IV, § 402(49)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3361"},"text":"98 Stat. 3361","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27f3a4de-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27f3a4df-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id27f3a4e0-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a)(1) and (c), was in the original “this title”, meaning title I (§ 101 et seq.) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/254"},"text":"Pub. L. 96–254","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-05-30"},"text":"May 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/399"},"text":"94 Stat. 399","children":[],"tail":", known as the Rock Island Railroad Transition and Employee Assistance Act, which is classified principally to this chapter. For complete classification of title I to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1001"},"text":"section 1001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Milwaukee Railroad Restructuring Act, referred to in subsecs. (a)(2) and (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/101"},"text":"Pub. L. 96–101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-11-04"},"text":"Nov. 4, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/736"},"text":"93 Stat. 736","children":[],"tail":", which is classified principally to chapter 18 (§ 901 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s901"},"text":"section 901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s1008"},"text":"Section 1008 of this title","children":[],"tail":", referred to in subsec. (b), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/97/468/tII/s234/a"},"text":"Pub. L. 97–468, title II, § 234(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2547"},"text":"96 Stat. 2547","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The United States Court of Claims, referred to in subsec. (c), and the United States Court of Customs and Patent Appeals were merged effective ","children":[{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":", into a new United States Court of Appeals for the Federal Circuit by "},{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/25"},"text":"96 Stat. 25","children":[],"tail":", which also created a United States Claims Court [now United States Court of Federal Claims] that inherited the trial jurisdiction of the Court of Claims. See sections 48, 171 et seq., 791 et seq., and 1491 et seq. of Title 28, Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id27f3a4e1-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620"},"text":"Pub. L. 98–620","children":[],"tail":" struck out provision requiring the court to render a final decision no later than 60 days after the filing of the last such appeal."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id27f3a4e2-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id27f3a4e3-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620"},"text":"Pub. L. 98–620","children":[],"tail":" not applicable to cases pending on "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/620/s403"},"text":"section 403 of Pub. L. 98–620","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1657"},"text":"section 1657 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id27f3a4e4-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/448/s710/d"},"text":"section 710(d) of Pub. L. 96–448","children":[],"tail":", set out as an Effective Date of 1980 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s1170"},"text":"section 1170 of Title 11","children":[],"tail":", Bankruptcy."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
