{"tag":"section","attrib":{"id":"id279dbccf-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s160a"},"text":null,"children":[{"tag":"num","attrib":{"value":"160a"},"text":"§ 160a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id279dbcd0-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s160a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Mediation Board shall have the authority from time to time to make, amend, and rescind, in the manner prescribed by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":", and after opportunity for a public hearing, such rules and regulations as may be necessary to carry out the provisions of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id279dbcd1-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s160a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of subsection (a) shall not apply to any rule or proposed rule to which the third sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553/b"},"text":"section 553(b) of title 5","children":[],"tail":" applies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id279dbcd2-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-05-20/ch347/s10A"},"text":"May 20, 1926, ch. 347, § 10A","children":[],"tail":", as added "},{"tag"