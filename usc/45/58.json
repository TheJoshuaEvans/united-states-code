{"tag":"section","attrib":{"id":"id27944709-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s58"},"text":null,"children":[{"tag":"num","attrib":{"value":"58"},"text":"§ 58.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duty or liability of common carriers and rights of employees under other acts not impaired","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be held to limit the duty or liability of common carriers or to impair the rights of their employees under any other Act or Acts of Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id2794470a-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1908-04-22/ch149/s8"},"text":"Apr. 22, 1908, ch. 149, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/66"},"text":"35 Stat. 66","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
