{"tag":"section","attrib":{"id":"id27e0928d-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s727"},"text":null,"children":[{"tag":"num","attrib":{"value":"727"},"text":"§ 727.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional purchases of Series A preferred stock","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id27e0928e-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s727/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal investment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the authority provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s726"},"text":"section 726 of this title","children":[],"tail":", the Association shall purchase shares of Series A preferred stock and accounts receivable of the Corporation after "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"August 13, 1981","children":[],"tail":", in amounts not to exceed a total of $137,000,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27e0928f-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s727/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accounts receivable","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id27e09290-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s727/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any further purchase under this section or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s726"},"text":"section 726 of this title","children":[],"tail":" the Association shall purchase accounts receivable of the Corporation attributable to the dispute over the right-of-way related costs described in section 1111 "},{"tag":"ref","attrib":{"idref":"fn002051"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002051"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title until the Commission resolves such dispute under such section, and accounts receivable of the Corporation attributable to delays in reimbursement from commuter authorities."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27e09291-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s727/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" From funds provided under this section or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s726"},"text":"section 726 of this title","children":[],"tail":", the Association shall purchase Series A preferred stock of the Corporation, to the extent of losses on commuter service, in an amount not to exceed $15,000,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27e09292-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s727/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States and localities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall be exempt from liability for any State tax, except for any tax imposed by any political subdivision of a State applicable to any taxable period commencing before ","children":[{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27e09293-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s727/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debentures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Association shall return debentures to the Corporation in an amount equal to the value of the properties conveyed by the Corporation to Amtrak Commuter and any commuter authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27e09294-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s727/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights retained","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall retain the right to collect any accounts receivable attributable to delays in reimbursement from commuter authorities that are purchased by the Association under this section. No agency or instrumentality of the United States shall be required to collect such accounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27e09295-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s727/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id27e09296-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s727/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There is authorized to be appropriated not to exceed $262,000,000—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id27e09297-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s727/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of which not to exceed $137,000,000 shall be appropriated to the Association for purposes of purchasing securities and accounts receivable of the Corporation under this section, such sums to remain available until the Secretary transfers the Corporation under subchapter IV ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this chapter;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id27e09298-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s727/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of which not to exceed $75,000,000 shall be appropriated to the Secretary, to facilitate the transfer of rail commuter services from the Corporation to other operators, for distribution under the statutory provisions of section 1139(b) of the Northeast Rail Service Act of 1981;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id27e09299-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s727/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of which not to exceed $35,000,000 shall be appropriated to the Secretary to be allocated for employee protection under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s1005"},"text":"section 1005 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id27e0929a-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s727/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of which not to exceed $15,000,000 shall be appropriated to the Secretary to facilitate the transfer of rail commuter services from railroads that entered reorganization after calendar year 1974 to any commuter authority that was providing commuter service, operated by a railroad that entered reorganization after calendar year 1974, as of ","children":[{"tag":"date","attrib":{"date":"1979-01-01"},"text":"January 1, 1979","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27e0929b-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s727/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All sums received on account of the holding or disposition of any securities or accounts receivable referred to in paragraph (1)(A) of this subsection shall be deposited in the general fund of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id27e0929c-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s727/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount authorized to be appropriated under paragraph (1)(B) of this subsection shall be reduced, in an amount equal to any amounts reappropriated under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s726/g/2"},"text":"section 726(g)(2) of this title","children":[],"tail":", upon the date of enactment of any Act which reappropriates such amounts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27e0929d-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/236/tII/s217"},"text":"Pub. L. 93–236, title II, § 217","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXI/s1140/a"},"text":"Pub. L. 97–35, title XI, § 1140(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/653"},"text":"95 Stat. 653","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/468/tV/s504/c"},"text":"Pub. L. 97–468, title V, § 504(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2552"},"text":"96 Stat. 2552","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/509/tIV/s4033/b/2"},"text":"Pub. L. 99–509, title IV, § 4033(b)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1908"},"text":"100 Stat. 1908","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27e0929e-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27e0929f-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id27e092a0-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s1111"},"text":"Section 1111 of this title","children":[],"tail":", referred to in subsec. (b)(1), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/105/134/tIV/s408"},"text":"Pub. L. 105–134, title IV, § 408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-12-02"},"text":"Dec. 2, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2586"},"text":"111 Stat. 2586","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subchapter IV of this chapter, referred to in subsec. (f)(1)(A), was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tIV/s4033/a/1"},"text":"Pub. L. 99–509, title IV, § 4033(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1908"},"text":"100 Stat. 1908","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1139(b) of the Northeast Rail Service Act of 1981, referred to in subsec. (f)(1)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/s1139/b"},"text":"section 1139(b) of Pub. L. 97–35","children":[],"tail":", title XI, "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/652"},"text":"95 Stat. 652","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s744a"},"text":"section 744a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id27e092a1-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/s4033/b/2"},"text":"Pub. L. 99–509, § 4033(b)(2)","children":[],"tail":", substituted “applicable to any taxable period commencing before "},{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":"” for “, until the property of the Corporation is transferred by the Secretary under subchapter IV of this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/s4033/b/3"},"text":"Pub. L. 99–509, § 4033(b)(3)","children":[],"tail":", struck out “and shall collect” after “right to collect”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/468/s504/c/1"},"text":"Pub. L. 97–468, § 504(c)(1)","children":[],"tail":", substituted “$137,000,000” for “$262,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/468/s504/c/2"},"text":"Pub. L. 97–468, § 504(c)(2)","children":[],"tail":", designated existing provisions as pars. (1)(A) and (2), in (1)(A) as so designated, substituted $137,000,000 for $262,000,000 as limit of appropriations for purchase of securities and accounts receivable, and added pars. (1)(B) to (D) and (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id27e092a2-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id27e092a3-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s1169"},"text":"section 1169 of Pub. L. 97–35","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id27e092a4-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Interstate Commerce Commission and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Interstate Commerce Commission abolished and functions of Commission transferred, except as otherwise provided in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", to Surface Transportation Board effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1302"},"text":"section 1302 of Title 49","children":[],"tail":", Transportation, and "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s101"},"text":"section 101 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of Title 49","children":[],"tail":". References to Interstate Commerce Commission deemed to refer to Surface Transportation Board, a member or employee of the Board, or Secretary of Transportation, as appropriate, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s205"},"text":"section 205 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of Title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id27e092a5-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of United States Railway Association and Transfer of Functions and Securities","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s1341"},"text":"section 1341 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
