{"tag":"section","attrib":{"id":"id27bf274e-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s231o"},"text":null,"children":[{"tag":"num","attrib":{"value":"231o"},"text":"§ 231o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private pensions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be taken as restricting or discouraging payment by employers to retired employees of pensions or gratuities in addition to the annuities paid to such employees under this subchapter, nor shall this subchapter be taken as terminating any trust heretofore created for the payment of such pensions or gratuities. The annuity, except a supplemental annuity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s231a/b"},"text":"section 231a(b) of this title","children":[],"tail":", of an individual shall not be reduced on account of any pension or gratuity paid by an employer to such individual."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id27bf274f-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-29/ch812/s16"},"text":"Aug. 29, 1935, ch. 812, § 16","children":[],"tail":", as restated "},{"tag":"ref","attrib":{"href":"/us/act/1937-06-24/ch382"},"text":"June 24, 1937, ch. 382","children":[],"tail":", pt. I, "},{"tag":"ref","attrib":{"href":"/us/stat/50/307"},"text":"50 Stat. 307","children":[],"tail":", as restated "},{"tag":"ref","attrib":{"href":"/us/pl/93/445/tI/s101"},"text":"Pub. L. 93–445, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-16"},"text":"Oct. 16, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1349"},"text":"88 Stat. 1349","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
