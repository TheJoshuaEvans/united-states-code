{"tag":"section","attrib":{"id":"id27f86042-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1211"},"text":null,"children":[{"tag":"num","attrib":{"value":"1211"},"text":"§ 1211.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denali National Park and Preserve lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On the date of transfer to the State (pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s1203"},"text":"section 1203 of this title","children":[],"tail":") or other disposition (pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1210"},"text":"section 1210 of this title","children":[],"tail":"), that portion of rail properties of the Alaska Railroad within the Denali National Park and Preserve shall, subject to the exclusive-use easement granted pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1203/b/1/D"},"text":"section 1203(b)(1)(D) of this title","children":[],"tail":", be transferred to the Secretary of the Interior for administration as part of the Denali National Park and Preserve, except that a transferee under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1210"},"text":"section 1210 of this title","children":[],"tail":" shall receive the same interest as the State under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1203/b/1/D"},"text":"section 1203(b)(1)(D) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id27f86043-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/468/tVI/s612"},"text":"Pub. L. 97–468, title VI, § 612","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2576"},"text":"96 Stat. 2576","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
