{"tag":"section","attrib":{"id":"id27b7fbc0-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s231j"},"text":null,"children":[{"tag":"num","attrib":{"value":"231j"},"text":"§ 231j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of annuities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person awarded an annuity under this subchapter may decline to accept all or any part of such annuity by a waiver signed and filed with the Board. Such a waiver may be revoked in writing at any time, but no payment of the annuity waived shall be made covering the period during which such waiver was in effect. Such a waiver will have no effect on entitlement to, or the amount of, any other annuity or benefit.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id27b7fbc1-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-29/ch812/s11"},"text":"Aug. 29, 1935, ch. 812, § 11","children":[],"tail":", as restated "},{"tag":"ref","attrib":{"href":"/us/act/1937-06-24/ch382"},"text":"June 24, 1937, ch. 382","children":[],"tail":", pt. I, "},{"tag":"ref","attrib":{"href":"/us/stat/50/307"},"text":"50 Stat. 307","children":[],"tail":", as restated "},{"tag":"ref","attrib":{"href":"/us/pl/93/445/tI/s101"},"text":"Pub. L. 93–445, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-16"},"text":"Oct. 16, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1344"},"text":"88 Stat. 1344","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
