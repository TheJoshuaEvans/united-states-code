{"tag":"section","attrib":{"id":"id279dbce5-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s165"},"text":null,"children":[{"tag":"num","attrib":{"value":"165"},"text":"§ 165.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation and audit of Mediation Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id279dbce6-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s165/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation and audit of Mediation Board","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id279dbce7-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s165/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to promote economy, efficiency, and effectiveness in the administration of the programs, operations, and activities of the Mediation Board, the Comptroller General of the United States shall evaluate and audit the programs and expenditures of the Mediation Board. Such an evaluation and audit shall be conducted not less frequently than every 2 years, but may be conducted as determined necessary by the Comptroller General or the appropriate congressional committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id279dbce8-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s165/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility of Comptroller General","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the evaluation and audit required under paragraph (1), the Comptroller General shall evaluate and audit the programs, operations, and activities of the Mediation Board, including, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id279dbce9-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s165/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information management and security, including privacy protection of personally identifiable information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id279dbcea-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s165/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resource management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id279dbceb-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s165/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" workforce development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id279dbcec-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s165/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procurement and contracting planning, practices, and policies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id279dbced-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s165/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the Mediation Board follows leading practices in selected management areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id279dbcee-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s165/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the processes the Mediation Board follows to address challenges in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id279dbcef-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s165/a/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initial investigations of applications requesting that an organization or individual be certified as the representative of any craft or class of employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id279dbcf0-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s165/a/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining and certifying representatives of employees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id279dbcf1-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s165/a/2/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that the process occurs without interference, influence, or coercion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id279dbcf2-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s165/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immediate review of certification procedures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2012-02-14"},"text":"February 14, 2012","children":[],"tail":", the Comptroller General shall review the processes applied by the Mediation Board to certify or decertify representation of employees by a labor organization and make recommendations to the Board and appropriate congressional committees regarding actions that may be taken by the Board or Congress to ensure that the processes are fair and reasonable for all parties. Such review shall be conducted separately from any evaluation and audit under subsection (a) and shall include, at a minimum—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id279dbcf3-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s165/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the existing processes and changes to such processes that have occurred since the establishment of the Mediation Board and whether those changes are consistent with congressional intent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id279dbcf4-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s165/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the extent to which such processes are consistent with similar processes applied to other Federal or State agencies with jurisdiction over labor relations, and an evaluation of any justifications for any discrepancies between the processes of the Mediation Board and such similar Federal or State processes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id279dbcf5-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s165/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committee defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “appropriate congressional committees” means the Committee on Transportation and Infrastructure of the House of Representatives, the Committee on Commerce, Science, and Transportation of the Senate, and the Committee on Health, Education, Labor, and Pensions of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id279dbcf6-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-05-20/ch347/s15"},"text":"May 20, 1926, ch. 347, § 15","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/95/tX/s1004"},"text":"Pub. L. 112–95, title X, § 1004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/147"},"text":"126 Stat. 147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id279dbcf7-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id279dbcf8-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id279dbcf9-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Biannual GAO Audit","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/tII/s218"},"text":"Pub. L. 118–63, title II, § 218","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1057"},"text":"138 Stat. 1057","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/stat/138/1057"},"text":"“Any provision of the FAA Modernization and Reform Act of 2012 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95"},"text":"Public Law 112–95","children":[],"tail":") [see Short Title of 2012 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s40101"},"text":"section 40101 of Title 49","children":[],"tail":", Transportation], including any amendment made by such Act, that requires the Comptroller General [of the United States] to conduct an audit (including a recurring audit) shall have no force or effect.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
