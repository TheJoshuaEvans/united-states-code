{"tag":"section","attrib":{"id":"id27fad1fe-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1324"},"text":null,"children":[{"tag":"num","attrib":{"value":"1324"},"text":"§ 1324.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain enforcement relief","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id27fad1ff-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1324/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Transportation, with respect to any provision of section 1321 or 1322 of this title, and any person who suffers direct and substantial economic injury as a result of an alleged violation by the Corporation, with respect to the provisions of section 1321(a)(1) and (2) ","children":[{"tag":"ref","attrib":{"idref":"fn002092"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002092"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, and "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1322"},"text":"section 1322 of this title","children":[],"tail":", may bring an action to require compliance with such provision."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27fad200-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1324/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special court","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any action brought under this subchapter shall be brought before the special court established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s719"},"text":"section 719 of this title","children":[],"tail":". Such special court may limit the enforcement of a restriction under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1321"},"text":"section 1321 of this title","children":[],"tail":", if the effect of such restriction would be to substantially impair the continued viability of the Corporation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27fad201-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tIV/s4025"},"text":"Pub. L. 99–509, title IV, § 4025","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1905"},"text":"100 Stat. 1905","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27fad202-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27fad203-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id27fad204-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s1321/a/2"},"text":"Section 1321(a)(2) of this title","children":[],"tail":", referred to in subsec. (a), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/101/213/s2/b/3"},"text":"Pub. L. 101–213, § 2(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-11"},"text":"Dec. 11, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1843"},"text":"103 Stat. 1843","child