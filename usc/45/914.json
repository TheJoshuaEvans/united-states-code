{"tag":"section","attrib":{"id":"id27eec3dd-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s914"},"text":null,"children":[{"tag":"num","attrib":{"value":"914"},"text":"§ 914.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligation guarantees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id27eec3de-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s914/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Transportation, under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s831"},"text":"section 831 of this title","children":[],"tail":", shall guarantee obligations of the Milwaukee Railroad for purposes of providing employee protection in accordance with the terms of the employee protection agreement entered into under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s908"},"text":"section 908 of this title","children":[],"tail":". Guarantees under this section shall be entered into without regard to the requirements of subsection (g) of "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s831"},"text":"section 831 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27eec3df-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s914/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligations as administrative expense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any obligation guaranteed pursuant to this section shall be treated as an administrative expense of the estate of the Milwaukee Railroad.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27eec3e0-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s914/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit on aggregate unpaid principal amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The aggregate unpaid principal amount of obligations which may be guaranteed by the Secretary pursuant to this section shall not exceed $75,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27eec3e1-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s914/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit on total liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total liability of the Milwaukee Railroad in connection with benefits and allowances provided under an employee protection agreement entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s908"},"text":"section 908 of this title","children":[],"tail":" shall not exceed $75,000,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27eec3e2-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s914/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of United States respecting section 908 agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except in connection with obligations guaranteed under this section, the United States shall incur no liability to employees in connection with any employee protection agreement entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s908"},"text":"section 908 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27eec3e3-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s914/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s22404"},"text":"section 22404 of title 49","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s22404"},"text":"Section 22404 of title 49","children":[],"tail":" shall not apply to any obligation guaranteed under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27eec3e4-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/101/s15"},"text":"Pub. L. 96–101, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-11-04"},"text":"Nov. 4, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/743"},"text":"93 Stat. 743","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/448/tVII/s701/a/3"},"text":"Pub. L. 96–448, title VII, § 701(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1959"},"text":"94 Stat. 1959","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tI/s21301/j/3/E"},"text":"Pub. L. 117–58, div. B, title I, § 21301(j)(3)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/692"},"text":"135 Stat. 692","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNot