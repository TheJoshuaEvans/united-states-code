{"tag":"section","attrib":{"id":"id27fad150-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s1213"},"text":null,"children":[{"tag":"num","attrib":{"value":"1213"},"text":"§ 1213.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict with other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of this chapter shall govern if there is any conflict between this chapter and any other law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id27fad151-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/468/tVI/s614"},"text":"Pub. L. 97–468, title VI, § 614","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2577"},"text":"96 Stat. 2577","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
