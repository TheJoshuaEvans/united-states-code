{"tag":"section","attrib":{"id":"id279dbd0d-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s188"},"text":null,"children":[{"tag":"num","attrib":{"value":"188"},"text":"§ 188.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated such sums as may be necessary for expenditure by the Mediation Board in carrying out the provisions of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id279dbd0e-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-05-20/ch347/s208"},"text":"May 20, 1926, ch. 347, § 208","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1936-04-10/ch166"},"text":"Apr. 10, 1936, ch. 166","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1191"},"text":"49 Stat. 1191","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
