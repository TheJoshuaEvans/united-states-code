{"tag":"section","attrib":{"id":"id27ec79af-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797k"},"text":null,"children":[{"tag":"num","attrib":{"value":"797k"},"text":"§ 797k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factfinding panel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id27ec79b0-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall enter into collective bargaining agreements with its employees which provide for the establishment of one or more advisory factfinding panels, chaired by a neutral expert in industrial relations, for purposes of recommending changes in operating practices and procedures which result in greater productivity to the maximum extent practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27ec79b1-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Mediation Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Mediation Board shall appoint public members to any panel established by an agreement entered into under this subparagraph, and shall perform such functions contained in the agreement as are consistent with the duties of such Board under the Railway Labor Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s151"},"text":"45 U.S.C. 151","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id27ec79b2-2a4a-11ef-83f3-c9aca8a7e419","identifier":"/us/usc/t45/s797k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The factfinding panel may, before making its report to the parties, provide mediation, concil­iation, and other assistance to the parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id27ec79b3-2a4a-11ef-83f3-c9aca8a7e419"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/236/tVII/s712"},"text":"Pub. L. 93–236, title VII, § 712","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXI/s1143/a"},"text":"Pub. L. 97–35, title XI, § 1143(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/668"},"text":"95 Stat. 668","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id27ec79b4-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id27ec79b5-2a4a-11ef-83f3-c9aca8a7e419"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id27ec79b6-2a4a-11ef-83f3-c9aca8a7e419"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Railway Labor Act, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-05-20/ch347"},"text":"act May 20, 1926, ch. 347","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/577"},"text":"44 Stat. 577","children":[],"tail":", which is classified principally to chapter 8 (§ 151 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s151"},"text":"section 151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
