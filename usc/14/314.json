{"tag":"section","attrib":{"id":"id568742a1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s314"},"text":null,"children":[{"tag":"num","attrib":{"value":"314"},"text":"§ 314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Captains of the port","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any officer, including any petty officer, may be designated by the Commandant as captain of the port or ports or adjacent high seas or waters over which the United States has jurisdiction, as the Commandant deems necessary to facilitate execution of Coast Guard duties.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id568742a2-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s104/c/1/A"},"text":"Pub. L. 115–282, title I, § 104(c)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4198"},"text":"132 Stat. 4198","children":[],"tail":", § 311; renumbered § 314, "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7201/b"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1675"},"text":"139 Stat. 1675","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id568742a3-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id568742a4-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id568742a5-2