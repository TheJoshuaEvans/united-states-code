{"tag":"section","attrib":{"id":"id56ab1f59-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1134"},"text":null,"children":[{"tag":"num","attrib":{"value":"1134"},"text":"§ 1134.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition, production, deployment, and support","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56ab1f5a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1134/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ab1f5b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1134/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure there is a stable and efficient production and support capability to develop an asset or capability for the Coast Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1f5c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1134/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct follow-on testing to confirm and monitor performance and correct deficiencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1f5d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1134/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct acceptance tests and trials prior to the delivery of each asset or system to ensure the delivered asset or system achieves full operational capability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ab1f5e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1134/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ab1f5f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1134/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" execute production contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1f60-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1134/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that delivered assets and capabilities meet operational cost and schedules requirements established in the acquisition program baseline;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1f61-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1134/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" validate manpower and training requirements to meet system needs to operate, maintain, support, and instruct the assets or capabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1f62-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1134/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare an acquisition project or program transition plan to enter into programmatic sustainment, operations, and support.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56ab1f63-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tIV/s402/a"},"text":"Pub. L. 111–281, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2947"},"text":"124 Stat. 2947","children":[],"tail":", § 574; renumbered § 1134, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s108/b"},"text":"Pub. L. 115–282, title I, § 108(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4208"},"text":"132 Stat. 4208","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56ab1f64-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56ab1f65-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56ab1f66-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s574"},"text":"section 574 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
