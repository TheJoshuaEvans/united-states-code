{"tag":"section","attrib":{"id":"id569a567d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s544"},"text":null,"children":[{"tag":"num","attrib":{"value":"544"},"text":"§ 544.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aids to maritime navigation; penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe and enforce necessary and reasonable rules and regulations, for the protection of maritime navigation, relative to the establishment, maintenance, and operation of lights and other signals on fixed and floating structures in or over waters subject to the jurisdiction of the United States and in the high seas for structures owned or operated by persons subject to the jurisdiction of the United States. Any owner or operator of such a structure, excluding an agency of the United States, who violates any of the rules or regulations prescribed hereunder, commits a misdemeanor and shall be punished, upon conviction thereof, by a fine of not exceeding $1,500 for each day which such violation continues.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id569a567e-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/501"},"text":"63 Stat. 501","children":[],"tail":", § 85; "},{"tag":"ref","attrib":{"href":"/us/act/1956-06-04/ch351/s1"},"text":"June 4, 1956, ch. 351, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/226"},"text":"70 Stat. 226","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/283/s1/2"},"text":"Pub. L. 93–283, § 1(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-14"},"text":"May 14, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/139"},"text":"88 Stat. 139","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/281/tII/s205/a/3"},"text":"Pub. L. 113–281, title II, § 205(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3025"},"text":"128 Stat. 3025","children":[],"tail":"; renumbered § 544, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s105/b"},"text":"Pub. L. 115–282, title I, § 105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4200"},"text":"132 Stat. 4200","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id569a567f-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id569a5680-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 33, U.S.C., 1946 ed., § 760 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1908-05-14/ch168/s5"},"text":"May 14, 1908, ch. 168, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/162"},"text":"35 Stat. 162","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id569a5681-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id569a5682-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 544 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2906"},"text":"section 2906 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id569a5683-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s85"},"text":"section 85 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281"},"text":"Pub. L. 113–281","children":[],"tail":" substituted “$1,500” for “$100”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/283"},"text":"Pub. L. 93–283","children":[],"tail":" struck out “on fixed structures” after “maritime navigation” in section catchline and in text substituted “fixed and floating structures in or over waters subject to the jurisdiction of the United States and in the high seas for structures owned or operated by persons subject to the jurisdiction of the United States” for “fixed structures in or over navigable waters of the United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1956—Act ","children":[{"tag":"date","attrib":{"date":"1956-06-04"},"text":"June 4, 1956","children":[],"tail":", amended section generally, vesting in Secretary rule-making authority, for the protection of maritime navigation, relative to the establishment, maintenance, and operation of lights and other signals on fixed structures in or over navigable waters of the United States, and excluding agencies of United States from its provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
