{"tag":"section","attrib":{"id":"id568742ad-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s316"},"text":null,"children":[{"tag":"num","attrib":{"value":"316"},"text":"§ 316.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commandant Advisory Judge Advocate","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There shall be in the Coast Guard a Commandant Advisory Judge Advocate who is a judge advocate in a grade of O-6. The Commandant Advisory Judge Advocate shall be assigned to the staff of the Commandant in the first regularly scheduled O-6 officer assignment panel to convene following the date of the enactment of the Coast Guard Authorization Act of 2025 and perform such duties relating to legal matters arising in the Coast Guard as such legal matters relate to the Commandant, as may be assigned.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id568742ae-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7201/e/6"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7201(e)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1679"},"text":"139 Stat. 1679","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id568742af-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id568742b0-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id568742b1-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Coast Guard Authorization Act of 2025, referred to in text, is the date of enactment of div. G of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id568742b2-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 316 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s334"},"text":"section 334 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
