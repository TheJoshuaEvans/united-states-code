{"tag":"section","attrib":{"id":"id56b49534-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2103"},"text":null,"children":[{"tag":"num","attrib":{"value":"2103"},"text":"§ 2103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number and distribution of commissioned officers on active duty promotion list","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56b49535-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Total Number.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56b49536-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The total number of Coast Guard commissioned officers on the active duty promotion list, excluding warrant officers, shall not exceed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56b49537-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2103/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 7,100 in fiscal year 2022;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56b49538-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2103/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 7,200 in fiscal year 2023;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56b49539-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2103/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 7,300 in fiscal year 2024; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56b4953a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2103/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 7,400 in fiscal year 2025 and each subsequent fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b4953b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Temporary increase","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding paragraph (1), the Commandant may temporarily increase the total number of commissioned officers permitted under such paragraph by up to 4 percent for not more than 60 days after the date of the commissioning of a Coast Guard Academy class.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b4953c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2103/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after exceeding the total number of commissioned officers permitted under paragraphs (1) and (2), and each 30 days thereafter until the total number of commissioned officers no longer exceeds the number of such officers permitted under paragraphs (1) and (2), the Commandant shall notify the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate of the number of officers on the active duty promotion list on the last day of the preceding 30-day period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b7053d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribution Percentages by Grade.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56b7053e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The total number of commissioned officers authorized by this section shall be distributed in grade in the following percentages: 0.375 percent for rear admiral; 0.375 percent for rear admiral (lower half); 6.0 percent for captain; 15.0 percent for commander; and 22.0 percent for lieutenant commander.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b7053f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Discretionary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe the percentages applicable to the grades of lieutenant, lieutenant (junior grade), and ensign.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b70540-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2103/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of secretary to reduce percentage","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56b70541-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2103/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may reduce, as the needs of the Coast Guard require, any of the percentages set forth in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56b70542-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2103/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall apply that total percentage reduction to any other lower grade or combination of lower grades.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b70543-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Computations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56b70544-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall compute, at least once each year, the total number of commissioned officers authorized to serve in each grade by applying the grade distribution percentages established by or under this section to the total number of commissioned officers listed on the current active duty promotion list.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b70545-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rounding fractions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (a), in making the computations under paragraph (1), any fraction shall be rounded to the nearest whole number.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b70546-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2103/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of officers serving outside coast guard","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The number of commissioned officers on the active duty promotion list below the rank of vice admiral serving with other Federal departments or agencies on a reimbursable basis or excluded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s324/d"},"text":"section 324(d) of title 49","children":[],"tail":" shall not be counted against the total number of commissioned officers authorized to serve in each grade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b70547-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Numbers; Temporary Increases","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The numbers resulting from computations under subsection (c) shall be, for all purposes, the authorized number in each grade; except that the authorized number for a grade is temporarily increased during the period between one computation and the next by the number of officers originally appointed in that grade during that period and the number of officers of that grade for whom vacancies exist in the next higher grade but whose promotion has been delayed for any reason.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b70548-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2103/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary to Prescribe Numbers for Certain Officers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe the number of officers authorized to be serving on active duty in each grade of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56b70549-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2103/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the permanent commissioned teaching staff of the Coast Guard Academy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b7054a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2103/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officers designated by the Secretary pursuant to this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b7054b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2103/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officers of the Reserve serving in connection with organizing, administering, recruiting, instructing, or training the reserve components.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56b7054c-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/497"},"text":"63 Stat. 497","children":[],"tail":", § 42; "},{"tag":"ref","attrib":{"href":"/us/act/1956-07-20/ch647/s2"},"text":"July 20, 1956, ch. 647, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/588"},"text":"70 Stat. 588","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/474/s1/2"},"text":"Pub. L. 86–474, § 1(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-05-14"},"text":"May 14, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/144"},"text":"74 Stat. 144","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/2"},"text":"Pub. L. 88–130, § 1(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/174"},"text":"77 Stat. 174","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/444/s1/2"},"text":"Pub. L. 89–444, § 1(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-06-09"},"text":"June 9, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/195"},"text":"80 Stat. 195","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/385"},"text":"Pub. L. 90–385","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-05"},"text":"July 5, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/293"},"text":"82 Stat. 293","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/451/s1/2"},"text":"Pub. L. 92–451, § 1(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-02"},"text":"Oct. 2, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/755"},"text":"86 Stat. 755","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/174/s1/2"},"text":"Pub. L. 93–174, § 1(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-05"},"text":"Dec. 5, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/692"},"text":"87 Stat. 692","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/23/s4"},"text":"Pub. L. 96–23, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-06-13"},"text":"June 13, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/68"},"text":"93 Stat. 68","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/417/s2/2"},"text":"Pub. L. 97–417, § 2(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-04"},"text":"Jan. 4, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2085"},"text":"96 Stat. 2085","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/449/s5/b"},"text":"Pub. L. 97–449, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2442"},"text":"96 Stat. 2442","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s25/a/1"},"text":"Pub. L. 98–557, § 25(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2872"},"text":"98 Stat. 2872","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tV/s514/c/1"},"text":"Pub. L. 99–145, title V, § 514(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/629"},"text":"99 Stat. 629","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/206/tII/s201"},"text":"Pub. L. 103–206, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2420"},"text":"107 Stat. 2420","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/293/tII/s214"},"text":"Pub. L. 108–293, title II, § 214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1037"},"text":"118 Stat. 1037","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tII/s204/a"},"text":"Pub. L. 111–281, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2910"},"text":"124 Stat. 2910","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/281/tII/s201"},"text":"Pub. L. 113–281, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3024"},"text":"128 Stat. 3024","children":[],"tail":"; renumbered § 2103, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s112/b"},"text":"Pub. L. 115–282, title I, § 112(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4216"},"text":"132 Stat. 4216","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8217, "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4653"},"text":"134 Stat. 4653","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXII/s11236/a"},"text":"Pub. L. 117–263, div. K, title CXII, § 11236(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4035"},"text":"136 Stat. 4035","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7221/c/2"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7221(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1700"},"text":"139 Stat. 1700","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56b7054d-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56b7054e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., § 6a (","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-23/ch301/s1"},"text":"July 23, 1947, ch. 301, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/409"},"text":"61 Stat. 409","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The only change is in phraseology in the second sentence, it being necessary to include the extra numbers authorized by the act of ","children":[{"tag":"date","attrib":{"date":"1947-07-23"},"text":"July 23, 1947","children":[],"tail":", in the figure given as the present number of extra numbers in the Coast Guard. 81st Congress, House Report No. 557."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56b7054f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56b70550-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" amended subsec. (e) generally. Prior to amendment, text read as follows: “The number of officers authorized to be serving on active duty in each grade of the permanent commissioned teaching staff of the Coast Guard Academy and of the Reserve serving in connection with organizing, administering, recruiting, instructing, or training the reserve components shall be prescribed by the Secretary.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, text read as follows: “The total number of Coast Guard commissioned officers on the active duty promotion list, excluding warrant officers, shall not exceed 6,900; except that the Commandant may temporarily increase that number by up to 2 percent for no more than 60 days following the date of the commissioning of a Coast Guard Academy class.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “vice admiral” for “rear admiral (lower half)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s42"},"text":"section 42 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281"},"text":"Pub. L. 113–281","children":[],"tail":" substituted “6,900” for “7,200”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":" amended section generally. Prior to amendment, section consisted of subsecs. (a) to (e) relating to number and distribution of commissioned officers."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293/s214/1"},"text":"Pub. L. 108–293, § 214(1)","children":[],"tail":", substituted “6,700 in each fiscal year 2004, 2005, and 2006” for “6,200”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293/s214/2"},"text":"Pub. L. 108–293, § 214(2)","children":[],"tail":", substituted “commander 15.0; lieutenant commander 22.0” for “commander 12.0; lieutenant commander 18.0”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/206"},"text":"Pub. L. 103–206","children":[],"tail":" substituted “6,200” for “6,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" substituted “rear admiral (lower half)” for “commodore”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557"},"text":"Pub. L. 98–557","children":[],"tail":" substituted “0.375” for “.375” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/417"},"text":"Pub. L. 97–417","children":[],"tail":" substituted “.375; commodore .375;” for “0.75;” after “rear admiral”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/449"},"text":"Pub. L. 97–449","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t49/s324/d"},"text":"section 324(d) of title 49","children":[],"tail":"” for “section 9(d)(1) of the Department of Transportation Act ("},{"tag":"ref","attrib":{"href":"/us/stat/80/944"},"text":"80 Stat. 944","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1657"},"text":"49 U.S.C. 1657","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/23"},"text":"Pub. L. 96–23","children":[],"tail":" substituted “6,000” for “five thousand”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/174"},"text":"Pub. L. 93–174","children":[],"tail":" substituted “Coast Guard Academy and of the” for “Coast Guard Academy, of the” and struck out “, and of the Women’s Reserve” after “training and reserve components”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/451"},"text":"Pub. L. 92–451","children":[],"tail":" inserted provision that officers excluded under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1657/d/1"},"text":"section 1657(d)(1) of Title 49","children":[],"tail":" shall not be counted in determining authorized strengths."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/385"},"text":"Pub. L. 90–385","children":[],"tail":" substituted “five thousand” for “four thousand”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/444"},"text":"Pub. L. 89–444","children":[],"tail":" substituted “four thousand” for “three thousand five hundred”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1963—","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/130"},"text":"Pub. L. 88–130","children":[],"tail":" specified percentage of distribution of commissioned officers from rear admiral to lieutenant commander, authorized Secretary to prescribe percentages for lieutenant, lieutenant (junior grade), and ensign, required number in each grade to be computed by applying the applicable percentage to the total number of officers serving on active duty on the date the computation is made, provided that officers not on the active duty promotion list, officers serving as extra numbers in grade, and officers serving with other departments or agencies on a reimbursable basis shall not be counted in determining authorized strengths and that the number of officers authorized to be serving on active duty in each grade of the permanent commissioned teaching staff of the Coast Guard Academy, of the Reserve, and of the Women’s Reserve shall be prescribed by the Secretary, and struck out provisions which included in the number of commissioned officers the extra numbers in grade which increase the authorized number of line officers upon separation or retirement of the person holding such number, and the members of the permanent commissioned teaching staff of the Coast Guard Academy, distributed commissioned officers in grades in the same percentages as prescribed for the Navy, determined authorized number of officers in the various grades by the actual number on active duty, including permanent, temporary, and reserve officers, but not including extra numbers in the Coast Guard at the date of making the computation, and which provided that no officer be reduced in permanent grade or pay or removed from the active list as a result of any computation of the number of officers in grade."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/474"},"text":"Pub. L. 86–474","children":[],"tail":" substituted “three thousand five hundred” for “three thousand”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1956—Act ","children":[{"tag":"date","attrib":{"date":"1956-07-20"},"text":"July 20, 1956","children":[],"tail":", substituted “three thousand” for “two thousand two hundred and fifty” and inserted “except that the authorized number for a grade is temporarily increased during the period between one computation and the next by the number of officers originally appointed in that grade during that period and the number of officers of that grade for whom vacancies exist in the next higher grade but whose promotion has been delayed for any reason”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56b70551-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id56b70552-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1972 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/451"},"text":"Pub. L. 92–451","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1972-10-02"},"text":"Oct. 2, 1972","children":[],"tail":", except that continuation boards may not be held until one year thereafter, see "},{"tag":"ref","attrib":{"href":"/us/pl/92/451/s3"},"text":"section 3 of Pub. L. 92–451","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s2151"},"text":"section 2151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
