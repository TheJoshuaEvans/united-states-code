{"tag":"section","attrib":{"id":"id56a8ad81-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1106"},"text":null,"children":[{"tag":"num","attrib":{"value":"1106"},"text":"§ 1106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required contract terms","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56a8ad82-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant shall ensure that a contract awarded or a delivery order or task order issued for an acquisition of a capability or an asset with an expected service life of 10 or more years and with a total acquisition cost that is equal to or exceeds $10,000,000—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a8ad83-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1106/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides that all certifications for an end-state capability or asset under such contract, delivery order, or task order, respectively, will be conducted by the Commandant or an independent third party, and that self-certification by a contractor or subcontractor is not allowed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8ad84-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1106/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides that the Commandant shall maintain the authority to establish, approve, and maintain technical requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8ad85-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1106/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires that any measurement of contractor and subcontractor performance be based on the status of all work performed, including the extent to which the work performed met all performance, cost, and schedule requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8ad86-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1106/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifies that, for the acquisition or upgrade of air, surface, or shore capabilities and assets for which compliance with TEMPEST certification is a requirement, the standard for determining such compliance will be the air, surface, or shore standard then used by the Department of the Navy for that type of capability or asset; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8ad87-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1106/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any contract awarded to acquire an Offshore Patrol Cutter, includes provisions specifying the service life, fatigue life, and days underway in general Atlantic and North Pacific Sea conditions, maximum range, and maximum speed the cutter will be built to achieve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a8ad88-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibited Provisions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a8ad89-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1106/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall ensure that any contract awarded or delivery order or task order issued by the Coast Guard does not include any provision allowing for equitable adjustment that is not consistent with the Federal Acquisition Regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8ad8a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1106/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extension of program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A contract, contract modification, or award term extending a contract with a lead systems integrator—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56a8ad8b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1106/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not include any minimum requirements for the purchase of a given or determinable number of specific capabilities or assets; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a8ad8c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1106/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be reviewed by an independent third party with expertise in acquisition management, and the results of that review shall be submitted to the appropriate congressional committees at least 60 days prior to the award of the contract, contract modification, or award term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a8ad8d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Integrated Product Teams","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Integrated product teams, and all teams that oversee integrated product teams, shall be chaired by officers, members, or employees of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a8ad8e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1106/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Technical Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall maintain or designate the technical authority to establish, approve, and maintain technical requirements. Any such designation shall be made in writing and may not be delegated to the authority of the Chief Acquisition Officer established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s308"},"text":"section 308 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56a8ad8f-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tIV/s402/a"},"text":"Pub. L. 111–281, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2936"},"text":"124 Stat. 2936","children":[],"tail":", § 565; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/330/s1/4"},"text":"Pub. L. 111–330, § 1(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3569"},"text":"124 Stat. 3569","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3533/f"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3533(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2321"},"text":"132 Stat. 2321","children":[],"tail":"; renumbered § 1106 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 108(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4208"},"text":"132 Stat. 4208","children":[],"tail":", 4240.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56a8ad90-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56a8ad91-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56a8ad92-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s108/b"},"text":"Pub. L. 115–282, § 108(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s565"},"text":"section 565 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s3533/f/1"},"text":"Pub. L. 115–232, § 3533(f)(1)","children":[],"tail":", struck out “awarded or issued by the Coast Guard after the date of enactment of the Coast Guard Authorization Act of 2010” after “$10,000,000” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s3533/f/2"},"text":"Pub. L. 115–232, § 3533(f)(2)","children":[],"tail":", struck out “after the date of enactment of the Coast Guard Authorization Act of 2010” after “Coast Guard”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 308” for “section 56”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/330"},"text":"Pub. L. 111–330","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/s402/a"},"text":"Pub. L. 111–281, § 402(a)","children":[],"tail":", which enacted this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56a8ad93-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id56a8ad94-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/330/s1"},"t