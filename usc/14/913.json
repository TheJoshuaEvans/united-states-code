{"tag":"section","attrib":{"id":"id56a3f2ee-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s913"},"text":null,"children":[{"tag":"num","attrib":{"value":"913"},"text":"§ 913.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Turnkey selection procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56a3f2ef-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s913/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Use","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may use one-step turnkey selection procedures for the purpose of entering into contracts for construction projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a3f2f0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s913/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a3f2f1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s913/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “one-step turnkey selection procedures” means procedures used for the selection of a contractor on the basis of price and other evaluation criteria to perform, in accordance with the provisions of a firm fixed-price contract, both the design and construction of a facility using performance specifications supplied by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a3f2f2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s913/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “construction” includes the construction, procurement, development, conversion, or extension of any facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a3f2f3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s913/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “facility” means a building, structure, or other improvement to real property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56a3f2f4-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241/tII/s205/a"},"text":"Pub. L. 109–241, title II, § 205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/521"},"text":"120 Stat. 521","children":[],"tail":", § 677; renumbered § 913, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s107/b"},"text":"Pub. L. 115–282, title I, § 107(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4205"},"text":"132 Stat. 4205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56a3f2f5-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56a3f2f6-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56a3f2f7-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s677"},"text":"section 677 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
