{"tag":"section","attrib":{"id":"id56a8ad95-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1107"},"text":null,"children":[{"tag":"num","attrib":{"value":"1107"},"text":"§ 1107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of major acquisition program contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56a8ad96-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s1105/a/2"},"text":"section 1105(a)(2) of this title","children":[],"tail":" and section 2304 "},{"tag":"ref","attrib":{"idref":"fn002021"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002021"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 10, and subject to subsections (b) and (c) of this section, the Secretary may acquire additional units procured under a Coast Guard major acquisition program contract, by extension of such contract without competition, if the Director of the Cost Analysis Division of the Department of Homeland Security determines that the costs that would be saved through award of a new contract in accordance with such sections would not exceed the costs of such an award."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a8ad97-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Number of Additional Units","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The number of additional units acquired under a contract extension under this section may not exceed the number of additional units for which such determination is made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a8ad98-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of Costs Upon Request","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Cost Analysis Division of the Department of Homeland Security shall, at the request of the Secretary, determine for purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a8ad99-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1107/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs that would be saved through award of a new major acquisition program contract in accordance with section 1105(a)(2) for the acquisition of a number of additional units specified by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8ad9a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1107/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of such award, including the costs that would be incurred due to acquisition schedule delays and asset design changes associated with such award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a8ad9b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1107/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Number of Extensions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contract may be extended under this section more than once.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56a8ad9c-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s899/b/1/E"},"text":"Pub. L. 114–328, div. A, title VIII, § 899(b)(1)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2334"},"text":"130 Stat. 2334","children":[],"tail":", § 579; renumbered § 1107 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 108(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4208"},"text":"132 Stat. 4208","children":[],"tail":", 4240.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56a8ad9d-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56a8ad9e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id56a8ad9f-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2304"},"text":"Section 2304 of this title","children":[],"tail":", referred to in subsec. (a), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII"},"text":"Pub. L. 116–283, div. A, title XVIII","children":[],"tail":", §§ 1801(d), 1881(a), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4151"},"text":"134 Stat. 4151","children":[],"tail":", 4293, effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law. Subsecs. (a) to ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of section 2304 were transferred to various provisions in chapter 221 of this title, with the same effective date and conditions, by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1811/c/2"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1811(c)(2)","children":[],"tail":"–(5), (d)(2)–(9), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4165-4170"},"text":"134 Stat. 4165–4170","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56a8ada0-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s108/b"},"text":"Pub. L. 115–282, § 108(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s579"},"text":"section 579 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 1105(a)(2)” for “section 564(a)(2)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"ta