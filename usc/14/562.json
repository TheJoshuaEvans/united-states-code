{"tag":"section","attrib":{"id":"id569cc6ef-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s562"},"text":null,"children":[{"tag":"num","attrib":{"value":"562"},"text":"§ 562.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals and waivers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Except for the Commandant, any individual adjudicating an appeal or waiver of a decision regarding marine safety, including inspection or manning and threats to the environment, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id569cc6f0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s562/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a qualified specialist with the training, experience, and qualifications in marine safety to effectively judge the facts and circumstances involved in the appeal and make a judgment regarding the merits of the appeal; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569cc6f1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s562/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" have a senior staff member who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id569cc6f2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s562/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the requirements of paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id569cc6f3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s562/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actively advises the individual adjudicating the appeal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id569cc6f4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s562/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" concurs in writing on the decision on appeal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id569cc6f5-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tV/s524/a"},"text":"Pub. L. 111–281, title V, § 524(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2958"},"text":"124 Stat. 2958","children":[],"tail":", § 102; renumbered § 101, "},{"tag":"ref","attrib":{"href":"/us/pl/111/330/s1/6/A"},"text":"Pub. L. 111–330, § 1(6)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3569"},"text":"124 Stat. 3569","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3531/c/2"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3531(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2320"},"text":"132 Stat. 2320","children":[],"tail":"; renumbered § 562, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s105/b"},"text":"Pub. L. 115–282, title I, § 105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4200"},"text":"132 Stat. 4200","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id569cc6f6-2930-11f1-a4c1-c531e6569a02"},"text"