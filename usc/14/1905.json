{"tag":"section","attrib":{"id":"id56b22328-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1905"},"text":null,"children":[{"tag":"num","attrib":{"value":"1905"},"text":"§ 1905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coast Guard Academy minority outreach team program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56b22329-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established within the Coast Guard Academy a minority outreach team program (in this section referred to as the “Program”) under which officers, including minority officers and officers from territories and other possessions of the United States, who are Academy graduates may volunteer their time to recruit minority students and strengthen cadet retention through mentorship of cadets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b2232a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":", the Commandant, in consultation with Program volunteers and Academy alumni that participated in prior programs at the Academy similar to the Program, shall appoint a permanent civilian position at the Academy to administer the Program by, among other things—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56b2232b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1905/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" overseeing administration of the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b2232c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1905/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serving as a resource to volunteers and outside stakeholders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b2232d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1905/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advising Academy leadership on recruitment and retention efforts based on recommendations from volunteers and outside stakeholders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b2232e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1905/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing strategic goals and performance metrics for the Program with input from active volunteers and Academy leadership; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b2232f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1905/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reporting annually to the Commandant on academic year and performance outcomes of the goals for the Program before the end of each academic year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56b22330-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8275(a), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4685"},"text":"134 Stat. 4685","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
