{"tag":"section","attrib":{"id":"id56b705b3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2115"},"text":null,"children":[{"tag":"num","attrib":{"value":"2115"},"text":"§ 2115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection boards; information to be furnished boards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56b705b4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2115/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall furnish the appropriate selection board convened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2106"},"text":"section 2106 of this title","children":[],"tail":" with—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56b705b5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2115/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of officers that the board may recommend for promotion to the next higher grade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b705b6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2115/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the names and records of all officers who are eligible for consideration for promotion to the grade to which the board will recommend officers for promotion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b705b7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2115/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an eligible officer considered for promotion to a rank above lieutenant, any credible information of an adverse nature, including any substantiated adverse finding or conclusion from an officially documented investigation or inquiry and any information placed in the personnel service record of the officer under section 1745(a) of the National Defense Authorization Act for Fiscal Year 2014 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66"},"text":"Public Law 113–66","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1561"},"text":"10 U.S.C. 1561","children":[],"tail":" note), shall be furnished to the selection board in accordance with standards and procedures set out in the regulations prescribed by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b705b8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2115/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provision of Direction and Guidance.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56b705b9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2115/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In addition to the information provided pursuant to subsection (a), the Secretary may furnish the selection board—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56b705ba-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2115/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific direction relating to the needs of the Coast Guard for officers having particular skills, including direction relating to the need for a minimum number of officers with particular skills within a specialty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56b705bb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2115/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other guidance that the Secretary believes may be necessary to enable the board to properly perform its functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56b705bc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2115/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Selections made based on the direction and guidance provided under this subsection shall not exceed the maximum percentage of officers who may be selected from below the announced promotion zone at any given selection board convened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2106"},"text":"section 2106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56b705bd-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/10/C"},"text":"Pub. L. 88–130, § 1(10)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/180"},"text":"77 Stat. 180","children":[],"tail":", § 258; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/444/s1/17"},"text":"Pub. L. 89–444, § 1(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-06-09"},"text":"June 9, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/196"},"text":"80 Stat. 196","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tII/s212"},"text":"Pub. L. 104–324, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3915"},"text":"110 Stat. 3915","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tII/s212/2"},"text":"Pub. L. 111–281, title II, § 212(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2914"},"text":"124 Stat. 2914","children":[],"tail":"; renumbered § 2115 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 112(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4216"},"text":"132 Stat. 4216","children":[],"tail":", 4240; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXII/s11245/a"},"text":"Pub. L. 117–263, div. K, title CXII, § 11245(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4043"},"text":"136 Stat. 4043","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56b705be-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56b705bf-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56b705c0-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s112/b"},"text":"Pub. L. 115–282, § 112(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s258"},"text":"section 258 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 2106” for “section 251” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 2106” for “section 251”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, substituted “with—” for “with:” in introductory provisions, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Cl. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Pub. L. 104–324","children":[],"tail":" struck out “, with identification of those officers who are in the promotion zone” after “officers for promotion”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/444"},"text":"Pub. L. 89–444","children":[],"tail":" substituted “officers who are eligible for consideration for promotion to the grade to which the board will recommend officers for promotion” for “officers to be considered by the board” in cl. 2."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
