{"tag":"section","attrib":{"id":"id56ca1934-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2703"},"text":null,"children":[{"tag":"num","attrib":{"value":"2703"},"text":"§ 2703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contingent expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commandant may expend for contingencies of the Coast Guard a sum not to exceed $50,000 in any one fiscal year.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56ca1935-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/532"},"text":"63 Stat. 532","children":[],"tail":", § 476; "},{"tag":"ref","attrib":{"href":"/us/pl/108/293/tII/s219"},"text":"Pub. L. 108–293, title II, § 219","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1039"},"text":"118 Stat. 1039","children":[],"tail":"; renumbered § 2703, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s116/b"},"text":"Pub. L. 115–282, title I, § 116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4226"},"text":"132 Stat. 4226","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56ca1936-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56ca1937-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., § 15k (","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-04-20/ch75"},"text":"Apr. 20, 1939, ch. 75","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/582"},"text":"53 Stat. 582","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The limitation on the amount for such contingencies is increased, and the amount is made available to the Commandant rather than solely to the Superintendent of the Academy as now prescribed by law. The authorization is to cover expenditures incident to the offices of the Commandant and the Superintendent of the Academy. The intent is that the amount authorized will be administered in a manner similar to that now employed by the Superintendent of the Academy under the authority of 14 U.S.C., § 15k. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56ca1938-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id56ca1939-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2703 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s4903"},"text":"section 4903 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56ca193a-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s476"},"text":"section 476 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293"},"text":"Pub. L. 108–293","children":[],"tail":" substituted “$50,000” for “$7,500” and struck out at end “The Commandant may authorize the Superintendent of the Academy to expend not to exceed $2,500 of this amount for contingencies of the Academy.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
