{"tag":"section","attrib":{"id":"id5684f96b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s310"},"text":null,"children":[{"tag":"num","attrib":{"value":"310"},"text":"§ 310.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of Coast Guard Investigative Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5684f96c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s310/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There shall be a Director of the Coast Guard Investigative Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5684f96d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s310/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chain of Command","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Coast Guard Investigative Service shall report directly to and be under the general supervision of the Commandant, acting through the Vice Commandant of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5684f96e-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7201/e/5"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7201(e)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1679"},"text":"139 Stat. 1679","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5684f96f-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5684f970-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5684f971-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 310 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s313"},"text":"section 313 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 310, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/519"},"text":"63 Stat. 519","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1950-08-03/ch536/s12"},"text":"Aug. 3, 1950, ch. 536, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/407"},"text":"64 Stat. 407","children":[],"tail":", related to recall to active duty during war or national emergency of warrant officers, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/10/A"},"text":"Pub. L. 88–130, § 1(10)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/177"},"text":"77 Stat. 177","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
