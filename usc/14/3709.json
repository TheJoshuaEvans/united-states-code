{"tag":"section","attrib":{"id":"id56d5ff3c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3709"},"text":null,"children":[{"tag":"num","attrib":{"value":"3709"},"text":"§ 3709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve student aviation pilots; Reserve aviation pilots; appointments in commissioned grade","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56d5ff3d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations prescribed by the Secretary an enlisted member of the Reserve may be designated as a student aviation pilot.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d5ff3e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3709/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member who is not a qualified aviator may not be designated as a student aviation pilot unless the member agrees in writing to serve on active duty for a period of two years after successful completion of flight training, unless sooner released. A student aviation pilot may be released from active duty or discharged at any time as provided for in the regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d5ff3f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3709/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A student aviation pilot who is a qualified civilian aviator may be given a brief refresher course in flight training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d5ff40-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3709/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A student aviation pilot undergoing flight training is entitled to have uniforms and equipment provided at Government expense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d5ff41-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3709/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations prescribed by the Secretary, a student aviation pilot may be designated an aviation pilot upon the successful completion of flight training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d5ff42-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3709/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In time of peace, an aviation pilot obligated under subsection (b) to serve on active duty for two years may serve for an additional period of not more than two years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d5ff43-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3709/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An aviation pilot may be released from active duty or discharged at any time as provided for in the regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d5ff44-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3709/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If qualified under regulations prescribed by the Secretary, an aviation pilot may be appointed as an ensign in the Reserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56d5ff45-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/322/s1"},"text":"Pub. L. 96–322, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-04"},"text":"Aug. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1005"},"text":"94 Stat. 1005","children":[],"tail":", § 709; renumbered § 3709, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s118/b"},"text":"Pub. L. 115–282, title I, § 118(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4233"},"text":"132 Stat. 4233","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d5ff46-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56d5ff47-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id56d5ff48-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s758a"},"text":"section 758a of this title","children":[],"tail":" prior to the complete revision of former chapter 21 of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/96/322"},"text":"Pub. L. 96–322","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56d5ff49-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s709"},"text":"section 709 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
