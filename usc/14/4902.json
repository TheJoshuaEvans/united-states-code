{"tag":"section","attrib":{"id":"id56daba59-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4902"},"text":null,"children":[{"tag":"num","attrib":{"value":"4902"},"text":"§ 4902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorizations of appropriations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Funds are authorized to be appropriated for fiscal years 2026 and 2027 for necessary expenses of the Coast Guard as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56daba5a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4902/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56daba5b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4902/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the operation and maintenance of the Coast Guard, not otherwise provided for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56daba5c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4902/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $11,851,875,000 for fiscal year 2026; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56daba5d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4902/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $13,500,000,000 for fiscal year 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56daba5e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4902/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib"