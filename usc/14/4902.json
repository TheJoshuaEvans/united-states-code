":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $67,701,000 for fiscal year 2026; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56daba69-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4902/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $70,000,000 for fiscal year 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56daba6a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4902/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For retired pay, including the payment of obligations otherwise chargeable to lapsed appropriations for purposes of retired pay, payments under the Retired Serviceman’s Family Protection and Survivor Benefits Plans, payment for career status bonuses, payment of continuation pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s356"},"text":"section 356 of title 37","children":[],"tail":", concurrent receipts, combat-related special compensation, and payments for medical care of retired personnel and their dependents under chapter 55 of title 10—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56daba6b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4902/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,057,929,000 for fiscal year 2026; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56daba6c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s4902/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,215,000,000 for fi