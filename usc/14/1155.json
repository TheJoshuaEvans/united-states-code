{"tag":"section","attrib":{"id":"id56ad68ca-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1155"},"text":null,"children":[{"tag":"num","attrib":{"value":"1155"},"text":"§ 1155.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract termination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56ad68cb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1155/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ad68cc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1155/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before terminating a procurement or acquisition contract with a total value of more than $1,000,000, the Commandant of the Coast Guard shall notify each vendor under such contract and require the vendor to maintain all work product related to the contract until the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56ad68cd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1155/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 1 year after the date of the notification; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ad68ce-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1155/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date the Commandant notifies the vendor that maintenance of such work product is no longer required.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ad68cf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1155/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Work Product Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section the term “work product”—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ad68d0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1155/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means tangible and intangible items and information produced or possessed as a result of a contract referred to in subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ad68d1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1155/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56ad68d2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1155/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any completed end items;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ad68d3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1155/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any uncompleted end items; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ad68d4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1155/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any property in the contractor’s possession in which the United States Government has an interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ad68d5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1155/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vendor that fails to maintain work product as required under subsection (a) is liable to the United States for a civil penalty of not more than $25,000 for each day on which such work product is unavailable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ad68d6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1155/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ad68d7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1155/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), not later than 45 days after the end of each fiscal year the Commandant of the Coast Guard shall provide to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate a report detailing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56ad68d8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1155/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all Coast Guard contracts with a total value of more than $1,000,000 that were terminated in the fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ad68d9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1155/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all vendors who were notified under subsection (a)(1) in the fiscal year, and the date of such notification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ad68da-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1155/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all criminal, administrative, and other investigations regarding any contract with a total value of more than $1,000,000 that were initiated by the Coast Guard in the fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ad68db-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1155/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all criminal, administrative, and other investigations regarding contracts with a total value of more than $1,000,000 that were completed by the Coast Guard in the fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ad68dc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1155/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of costs incurred by the Coast Guard, including contract line items and termination costs, as a result of the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ad68dd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1155/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant is not required to provide a report under paragraph (1) for any fiscal year for which there is no responsive information as described in subparagraphs (A) through (E) of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56ad68de-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3523/a"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3523(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2315"},"text":"132 Stat. 2315","children":[],"tail":", § 657; renumbered § 1155, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s108/b"},"text":"Pub. L. 115–282, title I, § 108(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4208"},"text":"132 Stat. 4208","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56ad68df-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56ad68e0-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56ad68e1-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s657"},"text":"section 657 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
