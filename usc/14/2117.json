{"tag":"section","attrib":{"id":"id56b705cf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2117"},"text":null,"children":[{"tag":"num","attrib":{"value":"2117"},"text":"§ 2117.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection boards; reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56b705d0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2117/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each board convened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2106"},"text":"section 2106 of this title","children":[],"tail":" shall submit a report in writing, signed by all the members thereof, containing the names of the officers recommended for promotion and the names of those officers recommended to be advanced to the top of the list of selectees established by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s2121/a"},"text":"section 2121(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56b705d1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2117/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A board convened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2106"},"text":"section 2106 of this title","children":[],"tail":" shall certify that, in the opinion of at least a majority of the members if the board has five members, or in the opinion of at least two-thirds of the members if the board has more than five members, the officers recommended for promotion are the best qualified for promotion to meet the needs of the service (as noted in specific direction furnished the board by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s2115"},"text":"section 2115 of this title","children":