{"tag":"section","attrib":{"id":"id56ced2de-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2745"},"text":null,"children":[{"tag":"num","attrib":{"value":"2745"},"text":"§ 2745.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Replacement of medals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In those cases where a medal, or a bar, emblem, or insignia in lieu thereof, awarded pursuant to this chapter has been stolen, lost, destroyed, or rendered unfit for use without fault or neglect on the part of the individual to whom it was awarded, such medal, or bar, emblem, or insignia in lieu thereof, shall be replaced without charge, or, in the discretion of the Secretary, upon condition that the Government is reimbursed for the cost thereof.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56ced2df-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/537"},"text":"63 Stat. 537","children":[],"tail":", § 501; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tV/s553/d/2"},"text":"Pub. L. 107–107, div. A, title V, § 553(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1117"},"text":"115 Stat. 1117","children":[],"tail":"; renumbered § 2745, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s116/b"},"text":"Pub. L. 115–282, title I, § 116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4226"},"text":"132 Stat. 4226","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8505(a)(37), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4749"},"text":"134 Stat. 4749","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56ced2e0-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56ced2e1-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section provides for the replacement of medals. It follows the established practice of the other armed forces, but makes an additional provision that the Secretary in his discretion may charge for the replacement medals in some circumstances. (See title 10, U.S.C., 1946 ed., § 1416 and title 34, U.S.C., 1946 ed., § 359.) 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56ced2e2-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56ced2e3-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “individual” for “person”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s501"},"text":"section 501 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" inserted “stolen,” before “lost,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
