{"tag":"section","attrib":{"id":"id569f106b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s709"},"text":null,"children":[{"tag":"num","attrib":{"value":"709"},"text":"§ 709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maritime instruction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Coast Guard may, when so requested by proper authority, detail members for duty in connection with maritime instruction and training by the several States, Territories, the District of Columbia, and Puerto Rico, and when requested by the Maritime Administrator, detail individuals in the Coast Guard for duty in connection with maritime instruction and training by the United States. The service rendered by any individual so detailed shall be considered Coast Guard duty.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id569f106c-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/507"},"text":"63 Stat. 507","children":[],"tail":", § 148; "},{"tag":"ref","attrib":{"href":"/us/pl/97/31/s12/4"},"text":"Pub. L. 97–31, § 12(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-06"},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/154"},"text":"95 Stat. 154","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s15/a/3/D"},"text":"Pub. L. 98–557, § 15(a)(3)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2865"},"text":"98 Stat. 2865","children":[],"tail":"; renumbered § 709, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s106/b"},"text":"Pub. L. 115–282, title I, § 106(b)","children":[],"tail":", "},{"tag":"