{"tag":"section","attrib":{"id":"id56c07b0f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2303"},"text":null,"children":[{"tag":"num","attrib":{"value":"2303"},"text":"§ 2303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Enlisted members shall be advanced in rating by the Commandant under regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56c07b10-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/520"},"text":"63 Stat. 520","children":[],"tail":", § 352; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s15/a/3/C"},"text":"Pub. L. 98–557, § 15(a)(3)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2865"},"text":"98 Stat. 2865","children":[],"tail":"; renumbered § 2303, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s113/b"},"text":"Pub. L. 115–282, title I, § 113(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4221"},"text":"132 Stat. 4221","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56c07b11-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56c07b12-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Derived from title 14, U.S.C., 1946 ed., § 23 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1908-04-16/ch145/s8"},"text":"Apr. 16, 1908, ch. 145, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/62"},"text":"35 Stat. 62","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Inasmuch as all phases of promotion of enlisted men, except the points covered by title 14, U.S.C., 1946 ed., § 23, have been left to administrative control heretofore, and this has proved most satisfactory, the entire promotion of enlisted men is delegated to administrative control by this section. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56c07b13-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56c07b14-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s352"},"text":"section 352 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557"},"text":"Pub. L. 98–557","children":[],"tail":" substituted “Enlisted members” for “Enlisted men”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
