{"tag":"section","attrib":{"id":"id56c07b05-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2302"},"text":null,"children":[{"tag":"num","attrib":{"value":"2302"},"text":"§ 2302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enlistments; term, grade","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56c07b06-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations prescribed by the Secretary, the Commandant may enlist persons for the duration of their minority or a period of at least two years but not more than six years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c07b07-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe the grades or ratings for persons enlisting in the Regular Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56c07b08-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/520"},"text":"63 Stat. 520","children":[],"tail":", § 351; "},{"tag":"ref","attrib":{"href":"/us/act/1950-08-03/ch536/s16"},"text":"Aug. 3, 1950, ch. 536, § 16","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/407"},"text":"64 Stat. 407","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", §§ 8(a), 53, "},{"tag":"ref","attrib":{"href":"/us/stat/70A/620"},"text":"70A Stat. 620","children":[],"tail":", 679; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s15/a/3/F"},"text":"Pub. L. 98–557, § 15(a)(3)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2865"},"text":"98 Stat. 2865","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/293/tII/s203"},"text":"Pub. L. 108–293, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1032"},"text":"118 Stat. 1032","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3533/h"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3533(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2321"},"text":"132 Stat. 2321","children":[],"tail":"; renumbered § 2302, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s113/b"},"text":"Pub. L. 115–282, title I, § 113(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4221"},"text":"132 Stat. 4221","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56c07b09-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56c07b0a-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56c07b0b-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1949 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., §§ 35, 35a, 206 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1906-05-26/ch2556/s1"},"text":"May 26, 1906, ch. 2556, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/200"},"text":"34 Stat. 200","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1915-01-28/ch20/s1"},"text":"Jan. 28, 1915, ch. 20, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/800"},"text":"38 Stat. 800","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1924-04-21/ch130/s6"},"text":"Apr. 21, 1924, ch. 130, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/106"},"text":"43 Stat. 106","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1937-07-30/ch545/s1"},"text":"July 30, 1937, ch. 545, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/547"},"text":"50 Stat. 547","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1941-07-11/ch290/s8"},"text":"July 11, 1941, ch. 290, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/586"},"text":"55 Stat. 586","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1941-08-18/ch364/s3"},"text":"Aug. 18, 1941, ch. 364, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/629"},"text":"55 Stat. 629","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s35"},"text":"Section 35 of title 14","children":[],"tail":", U.S.C., 1946 ed., has been divided. The provisions of the first sentence of subsection (a) are placed in this section. The proviso of subsection (a) is covered in "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s367/b"},"text":"section 367(b) of this title","children":[],"tail":". Subsection (b) is placed in "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s365"},"text":"section 365 of this title","children":[],"tail":". Subsections (c) and (d) are placed in "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s367/a"},"text":"section 367(a) of this title","children":[],"tail":", except that part (3) of subsection (c) is covered by "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s366"},"text":"section 366 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s206"},"text":"Section 206 of title 14","children":[],"tail":", U.S.C., 1946 ed., has been divided. That part dealing with special temporary enlistments is incorporated in this section. That part dealing with temporary appointments of warrant officers is placed in "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s302"},"text":"section 302 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Certain additional details concerning the two types of enlistments are added; these details were previously covered in Coast Guard Regulations.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section makes provision for the enlistment of personnel in the Coast Guard. The first sentence grants the necessary authority to the Secretary, changes existing law in regard to the term of enlistment from “not to exceed four years” to “not to exceed six years”, and adds a provision for the enlistment of minors for their minority only, such provision being in accordance with existing law applicable to the Navy. The next three sentences establish and define the two types of enlistments that are now in effect in the Coast Guard, setting forth the basic difference in the two types. The last sentence continues a provision to the effect that original enlistments in the Coast Guard shall be temporary. This section is a combination of existing law and regulations in regard to enlistments, with changes as noted above. See title 14, U.S.C., 1946 ed., § 35, and Coast Guard Regulations, sections 531 and 532. 81st Congress, House Report No. 557.","children":[],"tail":"\n"},{"tag":"html:table","attrib":{"width":"50%","id":"id56c07b0c-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1956 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"351","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"14:351.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"34:188 (as made applicable to Coast Guard by 34:189).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"34:189 (as applicable to 34:188).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-08-04/ch393/s1"},"text":"Aug. 4, 1949, ch. 393, § 1","children":[],"tail":" (351), "},{"tag":"html:a","attrib":{"href":"/us/stat/63/520"},"text":"63 Stat. 520","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1950-08-03/ch536/s16"},"text":"Aug. 3, 1950, ch. 536, § 16","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/407"},"text":"64 Stat. 407","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1945-10-06/ch393/s5"},"text":"Oct. 6, 1945, ch. 393, § 5","children":[],"tail":" (as made applicable to Coast Guard by § 13), 13 (as applicable to § 5); "},{"tag":"html:a","attrib":{"href":"/us/stat/59/539"},"text":"59 Stat. 539","children":[],"tail":", 542."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “notwithstanding any other provision of law” and “or reenlisted” are omitted as surplusage. ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s188"},"text":"34 U.S.C. 188","children":[],"tail":" (proviso) is omitted as executed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56c07b0d-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56c07b0e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s351"},"text":"section 351 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" inserted “the duration of their” before “minority”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293"},"text":"Pub. L. 108–293","children":[],"tail":" substituted “a period of at least two years but not more than six years.” for “terms of full years not exceeding six years.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557"},"text":"Pub. L. 98–557","children":[],"tail":" substituted reference to persons for reference to men."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1956—Act ","children":[{"tag":"date","attrib":{"date":"1956-08-10"},"text":"Aug. 10, 1956","children":[],"tail":", repealed and reenacted section by general amendment thereby designating existing provisions as subsec. (a) and adding subsec. (b), relating to grades or ratings of enlistees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1950—Act ","children":[{"tag":"date","attrib":{"date":"1950-08-03"},"text":"Aug. 3, 1950","children":[],"tail":", struck out references to two types of enlistments that were deemed necessary prior to the enactment of the Career Compensation Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
