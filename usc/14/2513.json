{"tag":"section","attrib":{"id":"id56c5362c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2513"},"text":null,"children":[{"tag":"num","attrib":{"value":"2513"},"text":"§ 2513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of length of service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In computing length of service of officers and enlisted personnel for any purpose all creditable service in the Army, Navy, Marine Corps, Air Force, Space Force, Coast Guard, Revenue Cutter Service, and Life Saving Service shall be included in addition to any other creditable service authorized by any other law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56c5362d-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/531"},"text":"63 Stat. 531","children":[],"tail":", § 467; renumbered § 2513, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s114/b"},"text":"Pub. L. 115–282, title I, § 114(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4223"},"text":"132 Stat. 4223","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s927/b/2"},"text":"Pub. L. 116–283, div. A, title IX, § 927(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3831"},"text":"134 Stat. 3831","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56c5362e-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56c5362f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., § 2 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1915-01-28/ch20/s3"},"text":"Jan. 28, 1915, ch. 20, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/801"},"text":"38 Stat. 801","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Air Force is added in the enumeration of services.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"That part referring to the operation of a station for part of a year is omitted.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56c53630-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56c53631-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" inserted “Space Force,” after “Air Force,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s467"},"text":"section 467 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
