{"tag":"section","attrib":{"id":"id56dab9ee-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3905"},"text":null,"children":[{"tag":"num","attrib":{"value":"3905"},"text":"§ 3905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disenrollment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Members of the Auxiliary may be disenrolled pursuant to applicable regulations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56dab9ef-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/555"},"text":"63 Stat. 555","children":[],"tail":", § 824; renumbered § 3905, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s119/b"},"text":"Pub. L. 115–282, title I, § 119(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4236"},"text":"132 Stat. 4236","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56dab9f0-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56dab9f1-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Experience has shown that it is desirable to have a statute definitely providing for separation of Auxiliarists from the organization. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56dab9f2-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Not