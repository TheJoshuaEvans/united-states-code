{"tag":"section","attrib":{"id":"id56c07b46-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2311"},"text":null,"children":[{"tag":"num","attrib":{"value":"2311"},"text":"§ 2311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retirement in cases where higher grade or rating has been held","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any enlisted member who is retired under any provision of section 2304, 2305, 2306, or 2307 of this title shall be retired from active service with the highest grade or rating held by him while on active duty in which, as determined by the Secretary, his performance of duty was satisfactory, but not lower than his permanent grade or rating.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56c07b47-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/522"},"text":"63 Stat. 522","children":[],"tail":", § 362; "},{"tag":"ref","attrib":{"href":"/us/act/1950-08-03/ch536/s21"},"text":"Aug. 3, 1950, ch. 536, § 21","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/407"},"text":"64 Stat. 407","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s2/9"},"text":"Pub. L. 97–295, § 2(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1302"},"text":"96 Stat. 1302","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s15/a/3/A"},"text":"Pub. L. 98–557, § 15(a)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2865"},"text":"98 Stat. 2865","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/348/tII/s205/b/8"},"text":"Pub. L. 99–348, title II, § 205(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-07-01"},"text":"July 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/700"},"text":"100 Stat. 700","children":[],"tail":"; renumbered § 2311 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 113(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4221"},"text":"132 Stat. 4221","children":[],"tail":", 4240.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56c07b48-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56c07b49-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 34, U.S.C., 1946 ed., § 3501(e) (","children":[{"tag":"ref","attrib":{"href":"/us/act/1941-07-24/ch320/s10"},"text":"July 24, 1941, ch. 320, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/605"},"text":"55 Stat. 605","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-02-21/ch34/s8/a"},"text":"Feb. 21, 1946, ch. 34, § 8(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/28"},"text":"60 Stat. 28","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The requirement that the higher grade or rating be held prior to ","children":[{"tag":"date","attrib":{"date":"1946-06-30"},"text":"June 30, 1946","children":[],"tail":", has been eliminated; this seems to be in line with the intent of Congress as expressed in "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-29/ch708/s303"},"text":"section 303 of the act of June 29, 1948, ch. 708","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/1081"},"text":"62 Stat. 1081","children":[],"tail":". The act of "},{"tag":"date","attrib":{"date":"1941-07-24"},"text":"July 24, 1941","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/605"},"text":"55 Stat. 605","children":[],"tail":", was enacted primarily for application to Navy personnel but it is made applicable to Coast Guard personnel by its own terms (see title 34, U.S.C., 1946 ed., § 350j(b)). 81st Congress, House Report No. 557."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56c07b4a-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56c07b4b-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 2304, 2305, 2306, or 2307” for “section 353, 354, 355, or 357”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s113/b"},"text":"Pub. L. 115–282, § 113(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s362"},"text":"section 362 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/348"},"text":"Pub. L. 99–348","children":[],"tail":" struck out “, with retired pay of the grade or rating with which retired” after “permanent grade or rating”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557"},"text":"Pub. L. 98–557","children":[],"tail":" substituted reference to enlisted member for reference to enlisted man."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295"},"text":"Pub. L. 97–295","children":[],"tail":" substituted “of this title” for “of this chapter” after “357”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1950—Act ","children":[{"tag":"date","attrib":{"date":"1950-08-03"},"text":"Aug. 3, 1950","children":[],"tail":", struck out reference to section 356."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
