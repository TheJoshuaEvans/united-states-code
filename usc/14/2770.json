{"tag":"section","attrib":{"id":"id56ced33f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2770"},"text":null,"children":[{"tag":"num","attrib":{"value":"2770"},"text":"§ 2770.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special instruction at universities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Coast Guard personnel may be assigned for special instruction at private or state colleges or universities, and their expenses, including tuition, books, laboratory equipment and fees, and school supplies, may be defrayed by the Coast Guard.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56ced340-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/531"},"text":"63 Stat. 531","children":[],"tail":", § 470; renumbered § 2770, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s116/b"},"text":"Pub. L. 115–282, title I, § 116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4226"},"text":"132 Stat. 4226","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56ced341-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56ced342-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on the following language contained in the Coast Guard appropriation act for 1949, “Pay and Allowances” and preceding years: ","children":[{"tag":"quotedContent","attrib":{},"text":"“Not to exceed $32,200 for cost of instruction of officers at non-Federal institutions, including books, laboratory equipment and fees, school supplies, and maintenance of students;”","children":[],"tail":"\n ("},{"tag":"ref","attrib":{"href":"/us/act/1948-06-19/ch558"},"text":"June 19, 1948, ch. 558","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/562"},"text":"62 Stat. 562","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The monetary limitation is removed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56ced343-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56ced344-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s470"},"text":"section 470 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56ced345-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id56ced346-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Expansion of Postgraduate Opportunities for Members of Coast Guard in Medical and Related Fields","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXIV/s11413/a"},"text":"Pub. L. 117–263, div. K, title CXIV, § 11413(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4120"},"text":"136 Stat. 4120","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dK/tCXIV/s11413/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant [of the Coast Guard] shall expand opportunities for members of the Coast Guard to secure postgraduate degrees in medical and related professional disciplines for the purpose of supporting Coast Guard clinics and operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of Law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Individuals who receive assistance pursuant to subsection (a) shall be subject to the service obligations required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2114"},"text":"section 2114 of title 10","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id56ced347-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Coast Guard Graduate Maritime Operations Education","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/tII/s213"},"text":"Pub. L. 114–120, title II, § 213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/42"},"text":"130 Stat. 42","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/120/tII/s213"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Not later than 1 year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":"], the Secretary of the department in which the Coast Guard is operating shall establish an education program, for members and employees of the Coast Guard, that—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offers a master’s degree in maritime operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is relevant to the professional development of such members and employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides resident and distant education options, including the ability to utilize both options; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the greatest extent practicable, is conducted using existing academic programs at an accredited public academic institution that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located near a significant number of Coast Guard, maritime, and other Department of Homeland Security law enforcement personnel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has an ability to simulate operations normally conducted at a command center.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
