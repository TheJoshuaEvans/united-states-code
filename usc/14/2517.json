{"tag":"section","attrib":{"id":"id56c5368f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2517"},"text":null,"children":[{"tag":"num","attrib":{"value":"2517"},"text":"§ 2517.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority for certain personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56c53690-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2517/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant may appoint, without regard to the provisions of subchapter I of chapter 33 (other than sections 3303 and 3328 of such chapter) of title 5, qualified candidates to any of the following positions in the competitive service (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2102"},"text":"section 2102 of title 5","children":[],"tail":") in the Coast Guard:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56c53691-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2517/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any category of medical or health professional positions within the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c53692-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2517/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any childcare services position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c53693-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2517/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any position in the Coast Guard housing office of a Coast Guard installation, the primary function of which is supervision of Coast Guard housing covered by subchapter III of chapter 29 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c53694-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2517/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any nonclinical specialist position the purpose of which is the integrated primary prevention of harmful behavior, including suicide, sexual assault, harassment, domestic abuse, and child abuse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c53695-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2517/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any special agent position of the Coast Guard Investigative Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c53696-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2517/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following positions at the Coast Guard Academy:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56c53697-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2517/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any civilian faculty member appointed under section 1941.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c53698-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2517/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A position involving the improvement of cadet health or well-being.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c53699-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2517/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall only appoint qualified candidates under the authority provided by subsections (a) and (b) ","children":[{"tag":"ref","attrib":{"idref":"fn002036"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002036"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" if the Commandant determines that there is a shortage of qualified candidates for the positions described in such subsection or a critical hiring need for such positions."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c5369a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2517/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefing Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of enactment of the Coast Guard Authorization Act of 2025, and annually thereafter for the following 5 years, the Commandant shall submit to the Committee on Commerce, Science, and Transportation and the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a written briefing which describes the use of the authority provided under this section on an annual basis, including the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56c5369b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2517/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of employees hired under the authority provided under this section within the year for which the briefing is provided.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c5369c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2517/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The positions and grades for which employees were hired.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c5369d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2517/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A justification for the Commandant’s determination that such positions involved a shortage of qualified candidates or a critical hiring need.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c5369e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2517/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of employees who were hired under the authority provided under this section who have separated from the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c5369f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2517/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Steps the Coast Guard has taken to engage with the Office of Personnel Management under subpart B of part 337 of title 5, Code of Federal Regulations, for positions for which the Commandant determines a direct hire authority remains necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c536a0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2517/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority provided under subsection (a) shall expire on ","children":[{"tag":"date","attrib":{"date":"2030-09-30"},"text":"September 30, 2030","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56c536a1-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7228/a"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7228(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1707"},"text":"139 Stat. 1707","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56c536a2-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56c536a3-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id56c536a4-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Coast Guard Authorization Act of 2025, referred to in subsec. (c), is the date of enactment of div. G of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
