{"tag":"section","attrib":{"id":"id56a63c70-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s942"},"text":null,"children":[{"tag":"num","attrib":{"value":"942"},"text":"§ 942.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public and commercial vessels and other watercraft; sale of fuel, supplies, and services","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary under such regulations as he may prescribe, may sell to public and commercial vessels and other watercraft, such fuel, supplies and furnish such services as may be required to meet the necessities of the vessel or watercraft if such vessel or watercraft is unable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a63c71-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s942/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to procure the fuel, supplies, or services from other sources at its present location; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63c72-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s942/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to proceed to the nearest port where they may be obtained without endangering the safety of the ship, the health and comfort of its personnel, or the safe condition of the property carried aboard.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Sales under this section shall be at such prices as the Secretary considers reasonable. Payment will be made on a cash basis or on such other basis as will reasonably assure prompt payment. Amounts received from such a sale shall, unless otherwise directed by another provision of law, be credited to the current appropriation concerned and are available for the same purposes as that appropriation.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56a63c73-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/159/s1"},"text":"Pub. L. 86–159, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-08-14"},"text":"Aug. 14, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/357"},"text":"73 Stat. 357","children":[],"tail":", § 654; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/444/s1/22"},"text":"Pub. L. 89–444, § 1(22)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-06-09"},"text":"June 9, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/197"},"text":"80 Stat. 197","children":[],"tail":"; renumbered § 942, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s107/b"},"text":"Pub. L. 115–282, title I, § 107(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4205"},"text":"132 Stat. 4205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56a63c74-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56a63c75-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56a63c76-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s654"},"text":"section 654 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/444"},"text":"Pub. L. 89–444","children":[],"tail":" inserted “Public and commercial vessels and other watercraft; sale of fuel, supplies, and services” in section catchline."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
