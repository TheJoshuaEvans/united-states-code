{"tag":"section","attrib":{"id":"id56cc6240-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2707"},"text":null,"children":[{"tag":"num","attrib":{"value":"2707"},"text":"§ 2707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of uniform","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of law relating to the protection of the uniform of the United States Army, Navy, or Marine Corps shall apply to the protection of the uniform of the Coast Guard, in the same manner, to the same extent, and under the same conditions.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56cc6241-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/533"},"text":"63 Stat. 533","children":[],"tail":", § 484; renumbered § 2707, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s116/b"},"text":"Pub. L. 115–282, title I, § 116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4226"},"text":"132 Stat. 4226","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56cc6242-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56cc6243-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., § 39 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-29/ch418/s1"},"text":"Aug. 29, 1916, ch. 418, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/649"},"text":"39 Stat. 649","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The assimilation is made in general terms, rather than by reference to the applicable section in title 10, U.S.C., 1946 ed. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56cc6244-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56cc6245-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s484"},"text":"section 484 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
