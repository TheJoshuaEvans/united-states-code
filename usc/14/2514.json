{"tag":"section","attrib":{"id":"id56c53632-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514"},"text":null,"children":[{"tag":"num","attrib":{"value":"2514"},"text":"§ 2514.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Career flexibility to enhance retention of members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56c53633-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Programs Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant may carry out a program under which members of the Coast Guard may be inactivated from active duty in order to meet personal or professional needs and returned to active duty at the end of such period of inactivation from active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c53634-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period of Inactivation From Active Duty; Effect of Inactivation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56c53635-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The period of inactivation from active duty under a program under this section of a member participating in the program shall be such period as the Commandant shall specify in the agreement of the member under subsection (c), except that such period may not exceed 3 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c53636-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusion from years of service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any service by a Reserve officer while participating in a program under this section shall be excluded from computation of the total years of service of that officer pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14706/a"},"text":"section 14706(a) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c53637-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusion from retirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any period of participation of a member in a program under this section shall not count toward—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56c53638-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligibility for retirement or transfer to the Ready Reserve under either chapter 841 or 1223 of title 10; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c53639-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" computation of retired or retainer pay under chapter 71 or 1223 of title 10.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c5363a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each member of the Coast Guard who participates in a program under this section shall enter into a written agreement with the Commandant under which that member shall agree as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56c5363b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To accept an appointment or enlist, as applicable, and serve in the Coast Guard Ready Reserve during the period of the inactivation of the member from active duty under the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c5363c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To undergo during the period of the inactivation of the member from active duty under the program such inactive service training as the Commandant shall require in order to ensure that the member retains proficiency, at a level determined by the Commandant to be sufficient, in the military skills, professional qualifications, and physical readiness of the member during the inactivation of the member from active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c5363d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Following completion of the period of the inactivation of the member from active duty under the program, to serve 30 days as a member of the Coast Guard on active duty for each month of the period of the inactivation of the member from active duty under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c5363e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions of Release","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall prescribe regulations specifying the guidelines regarding the conditions of release that must be considered and addressed in the agreement required by subsection (c). At a minimum, the Commandant shall prescribe the procedures and standards to be used to instruct a member on the obligations to be assumed by the member under paragraph (2) of such subsection while the member is released from active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c5363f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Order to Active Duty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under regulations prescribed by the Commandant, a member of the Coast Guard participating in a program under this section may, in the discretion of the Commandant, be required to terminate participation in the program and be ordered to active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c53640-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pay and Allowances.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56c53641-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Basic pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"During each month of participation in a program under this section, a member who participates in the program shall be paid basic pay in an amount equal to two-thirtieths of the amount of monthly basic pay to which the member would otherwise be entitled under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s204"},"text":"section 204 of title 37","children":[],"tail":" as a member of the uniformed services on active duty in the grade and years of service of the member when the member commences participation in the program."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c53642-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special or incentive pay or bonus.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56c53643-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member who participates in such a program shall not, while participating in the program, be paid any special or incentive pay or bonus to which the member is otherwise entitled under an agreement under chapter 5 of title 37 that is in force when the member commences participation in the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c53644-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Not treated as failure to perform services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The inactivation from active duty of a member participating in a program shall not be treated as a failure of the member to perform any period of service required of the member in connection with an agreement for a special or incentive pay or bonus under chapter 5 of title 37 that is in force when the member commences participation in the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c53645-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Return to active duty.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56c53646-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special or incentive pay or bonus","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraph (B), upon the return of a member to active duty after completion by the member of participation in a program—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56c53647-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/f/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any agreement entered into by the member under chapter 5 of title 37 for the payment of a special or incentive pay or bonus that was in force when the member commenced participation in the program shall be revived, with the term of such agreement after revival being the period of the agreement remaining to run when the member commenced participation in the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56c53648-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/f/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any special or incentive pay or bonus shall be payable to the member in accordance with the terms of the agreement concerned for the term specified in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c53649-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"id56c5364a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/f/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subparagraph (A) shall not apply to any special or incentive pay or bonus otherwise covered by such subparagraph with respect to a member if, at the time of the return of the member to active duty as described in that subparagraph—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id56c5364b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/f/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such pay or bonus is no longer authorized by law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id56c5364c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/f/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the member does not satisfy eligibility criteria for such pay or bonus as in effect at the time of the return of the member to active duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56c5364d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/f/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pay or bonus ceases being authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subparagraph (A) shall cease to apply to any special or incentive pay or bonus otherwise covered by such subparagraph with respect to a member if, during the term of the revived agreement of the member under subparagraph (A)(i), such pay or bonus ceases being authorized by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c5364e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member who is ineligible for payment of a special or incentive pay or bonus otherwise covered by this paragraph by reason of subparagraph (B)(i)(II) shall be subject to the requirements for repayment of such pay or bonus in accordance with the terms of the applicable agreement of the member under chapter 5 of title 37.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c5364f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/f/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required service is additional","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any service required of a member under an agreement covered by this paragraph after the member returns to active duty as described in subparagraph (A) shall be in addition to any service required of the member under an agreement under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c53650-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Travel and transportation allowance.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56c53651-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraph (B), a member who participates in a program is entitled, while participating in the program, to the travel and transportation allowances authorized by section 474 ","children":[{"tag":"ref","attrib":{"idref":"fn002035"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002035"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 37 for—"}],"tail":null},{"tag":"clause","attrib":{"id":"id56c53652-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/f/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" travel performed from the residence of the member, at the time of release from active duty to participate in the program, to the location in the United States designated by the member as the member’s residence during the period of participation in the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56c53653-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/f/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" travel performed to the residence of the member upon return to active duty at the end of the participation of the member in the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c53654-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Single residence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An allowance is payable under this paragraph only with respect to travel of a member to and from a single residence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c53655-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Leave balance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member who participates in a program is entitled to carry forward the leave balance existing as of the day on which the member begins participation and accumulated in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s701"},"text":"section 701 of title 10","children":[],"tail":", but not to exceed 60 days."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c53656-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Promotion.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56c53657-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officers.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56c53658-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer participating in a program under this section shall not, while participating in the program, be eligible for consideration for promotion under chapter 21 or 37 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c53659-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Return to duty","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon the return of an officer to active duty after completion by the officer of participation in a program—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56c5365a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/g/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commandant may adjust the date of rank of the officer in such manner as the Commandant may prescribe in regulations for purposes of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56c5365b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/g/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer shall be eligible for consideration for promotion when officers of the same grade and seniority are eligible for consideration for promotion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c5365c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enlisted members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An enlisted member participating in a program under this section shall not be eligible for consideration for advancement during the period that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56c5365d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" begins on the date of the inactivation of the member from active duty under the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c5365e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ends at such time after the return of the member to active duty under the program that the member is treatable as eligible for promotion by reason of time in grade and such other requirements as the Commandant shall prescribe in regulations for purposes of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c5365f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continued Entitlements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member participating in a program under this section shall, while participating in the program, be treated as a member of the Armed Forces on active duty for a period of more than 30 days for purposes of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56c53660-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entitlement of the member and of the dependents of the member to medical and dental care under the provisions of chapter 55 of title 10;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c53661-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retirement or separation for physical disability under the provisions of chapter 61 of title 10 and chapters 21 and 23 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c53662-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entitlement of the member and of the survivors of the member to all death benefits under subchapter II of chapter 75 of title 10;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c53663-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of all travel and transportation allowances to family members of a deceased member to attend the repatriation, burial, or memorial ceremony of a deceased member as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s453/f"},"text":"section 453(f) of title 37","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c53664-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligibility of the member for general benefits as provided in part II of title 38; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56c53665-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/h/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a victim of an alleged sex-related offense (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1044e/h"},"text":"section 1044e(h) of title 10","children":[],"tail":") to the maximum extent practicable, maintaining access to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56c53666-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/h/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coast Guard behavioral health resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c53667-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/h/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sexual assault prevention and response resources and programs of the Coast Guard; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56c53668-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2514/h/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coast Guard legal resources, including, to the extent practicable, special victims’ counsel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56c53669-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8204(a), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4645"},"text":"134 Stat. 4645","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7226"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7226","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1705"},"text":"139 Stat. 1705","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56c5366a-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56c5366b-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id56c5366c-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s474"},"text":"Section 474 of title 37","children":[],"tail":", referred to in subsec. (f)(4)(A), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tVI/s604/a"},"text":"Pub. L. 117–81, div. A, title VI, § 604(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1767"},"text":"135 Stat. 1767","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56c5366d-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7226/1"},"text":"Pub. L. 119–60, § 7226(1)","children":[],"tail":", substituted “30 days” for “2 months”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(3) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7226/2"},"text":"Pub. L. 119–60, § 7226(2)","children":[],"tail":", added pars. (3) to (6)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
