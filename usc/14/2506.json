{"tag":"section","attrib":{"id":"id56c2ecee-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2506"},"text":null,"children":[{"tag":"num","attrib":{"value":"2506"},"text":"§ 2506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of payment of retired pay of members who are absent from the United States to avoid prosecution","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Under procedures prescribed by the Secretary, the Secretary may suspend the payment of the retired pay of a member or former member during periods in which the member willfully remains outside the United States to avoid criminal prosecution or civil liability. The procedures shall address the types of criminal offenses and civil proceedings for which the procedures may be used, including the offenses specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8312"},"text":"section 8312 of title 5","children":[],"tail":", and the manner by which a member, upon the return of the member to the United States, may obtain retired pay withheld during the member’s absence."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56c2ecef-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/tIV/s444/a"},"text":"Pub. L. 107–295, title IV, § 444(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2132"},"text":"116 Stat. 2132","children":[],"tail":", § 424a; renumbered § 2506, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s114/b"},"text":"Pub. L. 115–282, title I, § 114(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4223"},"text":"132 Stat. 4223","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56c2ecf0-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56c2ecf1-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56c2ecf2-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s424a"},"text":"section 424a of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
