{"tag":"section","attrib":{"id":"id56a18282-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s905"},"text":null,"children":[{"tag":"num","attrib":{"value":"905"},"text":"§ 905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement authority for family housing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56a18283-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary is authorized—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a18284-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s905/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire, subject to the availability of appropriations sufficient to cover its full obligations, real property or interests therein by purchase, lease for a term not to exceed 5 years, or otherwise, for use as Coast Guard family housing units, including the acquisition of condominium units, which may include the obligation to pay maintenance, repair, and other condominium-related fees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a18285-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s905/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to dispose of by sale, lease, or otherwise, any real property or interest therein used for Coast Guard family housing units for adequate consideration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a18286-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a18287-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s905/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this section, a multiyear contract is a contract to lease Coast Guard family housing units for at least one, but not more than 5, fiscal years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a18288-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s905/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may enter into multiyear contracts under subsection (a) of this section whenever the Coast Guard finds that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56a18289-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s905/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of a contract will promote the efficiency of the Coast Guard family housing program and will result in reduced total costs under the contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a1828a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s905/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there are realistic estimates of both the cost of the contract and the anticipated cost avoidance through the use of a multiyear contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a1828b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s905/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A multiyear contract authorized under subsection (a) of this section shall contain cancellation and termination provisions to the extent necessary to protect the best interests of the United States, and may include consideration of both recurring and nonrecurring costs. The contract may provide for a cancellation payment to be made. Amounts that were originally obligated for the cost of the contract may be used for cancellation or termination costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56a1828c-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/206/tIII/s302/a"},"text":"Pub. L. 103–206, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2423"},"text":"107 Stat. 2423","children":[],"tail":", § 670; renumbered § 905, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s107/b"},"text":"Pub. L. 115–282, title I, § 107(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4205"},"text":"132 Stat. 4205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56a1828d-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56a1828e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56a1828f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s670"},"text":"section 670 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
