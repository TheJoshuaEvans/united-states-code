{"tag":"section","attrib":{"id":"id56a8add9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1111"},"text":null,"children":[{"tag":"num","attrib":{"value":"1111"},"text":"§ 1111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition workforce authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56a8adda-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expedited Hiring Authority.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a8addb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1111/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3304"},"text":"section 3304 of title 5","children":[],"tail":", the Commandant may—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56a8addc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1111/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate any category of acquisition positions within the Coast Guard as shortage category positions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a8addd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1111/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the authorities in such section to recruit and appoint highly qualified persons directly to positions so designated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8adde-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1111/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall include in reports under section 1102 information described in such section regarding positions designated under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a8addf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reemployment Authority.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a8ade0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1111/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), if an annuitant receiving an annuity from the Civil Service Retirement and Disability Fund becomes employed in any category of acquisition positions designated by the Commandant under subsection (a), the annuity of the annuitant so employed shall continue. The annuitant so reemployed shall not be considered an employee for purposes of subchapter III of chapter 83 or chapter 84 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a8ade1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1111/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56a8ade2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1111/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Election","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An annuitant retired under section 8336(d)(1) or 8414(b)(1)(A) of title 5, receiving an annuity from the Civil Service Retirement and Disability Fund, who becomes employed in any category of acquisition positions designated by the Commandant under subsection (a) after the date of the enactment of the Elijah E. Cummings Coast Guard Authorization Act of 2020, may elect to be subject to section 8344 or 8468 of such title (as the case may be).","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56a8ade3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1111/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An election for coverage under this subsection shall be filed not later than 90 days after the Commandant takes reasonable actions to notify an employee who may file an election.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56a8ade4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1111/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coverage","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If an employee files an election under this subsection, coverage shall be effective beginning on the first day of the first applicable pay period beginning on or after the date of the filing of the election.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a8ade5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1111/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) shall apply to an individual who is eligible to file an election under subparagraph (A) and does not file a timely election under clause (i) of such subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56a8ade6-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8219(a), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4655"},"text":"134 Stat. 4655","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56a8ade7-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56a8ade8-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id56a8ade9-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Elijah E. Cummings Coast Guard Authorization Act of 2020, referred to in subsec. (b)(2)(A), is the date of enactment of div. G of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
