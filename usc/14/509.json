{"tag":"section","attrib":{"id":"id56959a8d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509"},"text":null,"children":[{"tag":"num","attrib":{"value":"509"},"text":"§ 509.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Space-available travel on Coast Guard aircraft","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56959a8e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56959a8f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant may establish a program to provide transportation on Coast Guard aircraft on a space-available basis to the categories of eligible individuals described in subsection (c) (in this section referred to as the “program”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56959a90-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policy development","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date on which the program is established, the Commandant shall develop a policy for the operation of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56959a91-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operation of Program.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56959a92-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall operate the program in a budget-neutral manner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56959a93-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56959a94-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subparagraph (B), no additional funds may be used, or flight hours performed, for the purpose of providing transportation under the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56959a95-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"De minimis expenditures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant may make de minimis expenditures of resources required for the administrative aspects of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56959a96-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement not required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Eligible individuals described in subsection (c) shall not be required to reimburse the Coast Guard for travel provided under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56959a97-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Categories of Eligible Individuals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (d), the categories of eligible individuals described in this subsection are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56959a98-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the armed forces on active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56959a99-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Selected Reserve who hold a valid Uniformed Services Identification and Privilege Card.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56959a9a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Retired members of a regular or reserve component of the armed forces, including retired members of reserve components who, but for being under the eligibility age applicable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12731"},"text":"section 12731 of title 10","children":[],"tail":", would be eligible for retired pay under chapter 1223 of title 10."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56959a9b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subsection (f), veterans with a permanent service-connected disability rated as total.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56959a9c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such categories of dependents of individuals described in paragraphs (1) through (3) as the Commandant shall specify in the policy under subsection (a)(2), under such conditions and circumstances as the Commandant shall specify in such policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56959a9d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other categories of individuals as the Commandant considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56959a9e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In operating the program, the Commandant shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56959a9f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the sole discretion of the Commandant, establish an order of priority for transportation for categories of eligible individuals that is based on considerations of military necessity, humanitarian concerns, and enhancement of morale;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56959aa0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give priority in consideration of transportation to the demands of members of the armed forces in the regular components and in the reserve components on active duty and to the need to provide such members, and their dependents, a means of respite from such demands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56959aa1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement policies aimed at ensuring cost control (as required under subsection (b)) and the safety, security, and efficient processing of travelers, including limiting the benefit under the program to 1 or more categories of otherwise eligible individuals, as the Commandant considers necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56959aa2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transportation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56959aa3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsection (d)(1), in establishing space-available transportation priorities under the program, the Commandant shall provide transportation for an individual described in paragraph (2), and a single dependent of the individual if needed to accompany the individual, at a priority level in the same category as the priority level for an unaccompanied dependent over the age of 18 years traveling on environmental and morale leave.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56959aa4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Individuals covered","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (3), paragraph (1) applies with respect to an individual described in subsection (c)(3) who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56959aa5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resides in or is located in a Commonwealth or possession of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56959aa6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is referred by a military or civilian primary care provider located in that Commonwealth or possession to a specialty care provider for services to be provided outside of such Commonwealth or possession.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56959aa7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application to certain retired individuals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If an individual described in subsection (c)(3) is a retired member of a reserve component who is ineligible for retired pay under chapter 1223 of title 10 by reason of being under the eligibility age applicable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12731"},"text":"section 12731 of title 10","children":[],"tail":", paragraph (1) applies to the individual only if the individual is also enrolled in the TRICARE program for certain members of the Retired Reserve authorized under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1076e"},"text":"section 1076e of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56959aa8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Priority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The priority for space-available transportation required by this subsection applies with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56959aa9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the travel from the Commonwealth or possession of the United States to receive the specialty care services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56959aaa-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the return travel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56959aab-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Primary care provider and specialty care provider defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the terms “primary care provider” and “specialty care provider” refer to a medical or dental professional who provides health care services under chapter 55 of title 10.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56959aac-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations on Travel.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56959aad-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Travel may not be provided under this section to a veteran eligible for travel pursuant to paragraph (4) of subsection (c) in priority over any member eligible for travel under paragraph (1) of that subsection or any dependent of such a member eligible for travel under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56959aae-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of construction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (c)(4) may not be construed as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56959aaf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affecting or in any way imposing on the Coast Guard, any armed force, or any commercial entity with which the Coast Guard or an armed force contracts, an obligation or expectation that the Coast Guard or such armed force will retrofit or alter, in any way, military aircraft or commercial aircraft, or related equipment or facilities, used or leased by the Coast Guard or such armed force to accommodate passengers provided travel under such authority on account of disability; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56959ab0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preempting the authority of an aircraft commander to determine who boards the aircraft and any other matters in connection with safe operation of the aircraft.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56959ab1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s509/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of Section","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority to provide transportation under the program is in addition to any other authority under law to provide transportation on Coast Guard aircraft on a space-available basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56959ab2-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXII/s11231/a"},"text":"Pub. L. 117–263, div. K, title CXII, § 11231(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4030"},"text":"136 Stat. 4030","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56959ab3-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56959ab4-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id56959ab5-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 509 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2761"},"text":"section 2761 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
