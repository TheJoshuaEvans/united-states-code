{"tag":"section","attrib":{"id":"id56959a7d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s508"},"text":null,"children":[{"tag":"num","attrib":{"value":"508"},"text":"§ 508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coast Guard health-care professionals; licensure portability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56959a7e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law regarding the licensure of health-care providers, a health-care professional described in subsection (b) may practice the health profession or professions of the health-care professional at any location in any State, the District of Columbia, or a Commonwealth, territory, or possession of the United States, regardless of where such health-care professional or the patient is located, if the practice is within the scope of the authorized Federal duties of such health-care professional.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56959a7f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Described Individuals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A health-care professional described in this subsection is an individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56959a80-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s508/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56959a81-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s508/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the Coast Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56959a82-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s508/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a civilian employee of the Coast Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56959a83-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s508/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the Public Health Service who is assigned to the Coast Guard; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56959a84-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s508/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other health-care professional credentialed and privileged at a Federal health-care institution or location specially designated by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56959a85-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s508/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56959a86-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s508/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a current license to practice medicine, osteopathic medicine, dentistry, or another health profession; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56959a87-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s508/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is performing authorized duties for the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56959a88-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s508/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the terms “license” and “health-care professional” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1094/e"},"text":"section 1094(e) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56959a89-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tIII/s305/a"},"text":"Pub. L. 115–282, title III, § 305(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4245"},"text":"132 Stat. 4245","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56959a8a-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56959a8b-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id56959a8c-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 508 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2711"},"text":"section 2711 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
