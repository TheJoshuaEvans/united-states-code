{"tag":"section","attrib":{"id":"id56ab1f98-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1138"},"text":null,"children":[{"tag":"num","attrib":{"value":"1138"},"text":"§ 1138.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service life extension programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56ab1f99-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1138/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Requirements for a Level 1 or Level 2 acquisition project or program under sections 1131 through 1134 shall not apply to an acquisition by the Coast Guard that is a service life extension program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ab1f9a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1138/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service Life Extension Program Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “service life extension program” means a capital investment that is solely intended to extend the service life and address obsolescence of components or systems of a particular capability or asset.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56ab1f9b-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7212/a"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7212(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1693"},"text":"139 Stat. 1693","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
