{"tag":"section","attrib":{"id":"id56d84912-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3743"},"text":null,"children":[{"tag":"num","attrib":{"value":"3743"},"text":"§ 3743.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for promotion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56d84913-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3743/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), a Reserve officer is eligible for consideration for promotion and for promotion under this subchapter if that officer is in an active status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d84914-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3743/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Reserve officer who has been considered but not recommended for retention in an active status by a board convened under subsection 3752(a) ","children":[{"tag":"ref","attrib":{"idref":"fn002047"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002047"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section 3752(a)”."}],"tail":" of this title is not eligible for consideration for promotion."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d84915-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3743/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Request for Exclusion.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d84916-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3743/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant may provide that an officer may, upon the officer’s request and with the approval of the Commandant, be excluded from consideration by a selection board convened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s3740/b"},"text":"section 3740(b) of this title","children":[],"tail":" to consider officers for promotion to the next higher grade."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d84917-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3743/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval of request","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant shall approve a request under paragraph (1) only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56d84918-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3743/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis for the request is to allow an officer to complete a broadening assignment, advanced education, another assignment of significant value to the Coast Guard, a career progression requirement delayed by the assignment or education, or a qualifying personal or professional circumstance, as determined by the Commandant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d84919-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3743/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commandant determines the exclusion from consideration is in the best interest of the Coast Guard; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56d8491a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3743/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer has not previously failed of selection for promotion to the grade for which the officer requests the exclusion from consideration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56d8491b-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/322/s1"},"text":"Pub. L. 96–322, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-04"},"text":"Aug. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1011"},"text":"94 Stat. 1011","children":[],"tail":", § 732; renumbered § 3743 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 118(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4233"},"text":"132 Stat. 4233","children":[],"tail":", 4240; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8202(b), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4643"},"text":"134 Stat. 4643","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d8491c-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56d8491d-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id56d8491e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s774"},"text":"section 774 of this title","children":[],"tail":" prior to the complete revision of former chapter 21 of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/96/322"},"text":"Pub. L. 96–322","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56d8491f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “A Reserve officer is eligible for consideration for promotion and for promotion under this subchapter, if that officer is in an active status. A Reserve officer who has been considered but not recommended for retention in an active status by a board convened under sub"},{"tag":"ref","attrib":{"href":"/us/usc/t14/s3752/a"},"text":"section 3752(a) of this title","children":[],"tail":", is not eligible for consideration for promotion.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “subsection 3752(a)” for “subsection 741(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s118/b"},"text":"Pub. L. 115–282, § 118(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s732"},"text":"section 732 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
