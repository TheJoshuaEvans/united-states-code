{"tag":"section","attrib":{"id":"id56be31a2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2158"},"text":null,"children":[{"tag":"num","attrib":{"value":"2158"},"text":"§ 2158.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of records of officers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe, by regulation, procedures to review the record of any officer of the Regular Coast Guard to determine whether he shall be required to show cause for his retention on active duty—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56be31a3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2158/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because his performance of duty has fallen below the standards prescribed by the Secretary, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56be31a4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2158/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because of moral dereliction, professional dereliction, or because his retention is not clearly consistent with the interests of national security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56be31a5-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/10/C"},"text":"Pub. L. 88–130, § 1(10)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/187"},"text":"77 Stat. 187","children":[],"tail":", § 321; renumbered § 2158, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s112/b"},"text":"Pub. L. 115–282, title I, § 112(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4216"},"text":"132 Stat. 4216","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7223/a"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7223(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1702"},"text":"139 Stat. 1702","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56be31a6-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56be31a7-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56be31a8-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “shall prescribe, by regulation, procedures” for “may at any time convene a board of officers” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s321"},"text":"section 321 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
