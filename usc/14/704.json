{"tag":"section","attrib":{"id":"id569cc740-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s704"},"text":null,"children":[{"tag":"num","attrib":{"value":"704"},"text":"§ 704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of the Army and Department of the Air Force","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id569cc741-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army or the Secretary of the Air Force at the request of the Secretary may, with or without reimbursement for the cost thereof, as agreed, receive members of the Coast Guard for instruction in any school, including any aviation school, maintained by the Army or the Air Force, and such members shall be subject to the regulations governing such schools.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id569cc742-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Officers and enlisted members of the Coast Guard shall be permitted to purchase quartermaster supplies from the Army at the same price as is charged the officers and enlisted members of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id569cc743-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Articles of ordnance property may be sold by the Secretary of the Army to officers of the Coast Guard for their use in the public service in the same manner as these articles are sold to officers of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id569cc744-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/506"},"text":"63 Stat. 506","children":[],"tail":", § 144; "},{"tag":"ref","attrib":{"href":"/us/pl/94/546/s1/10"},"text":"Pub. L. 94–546, § 1(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-18"},"text":"Oct. 18, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2519"},"text":"90 Stat. 2519","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s15/a/3/D"},"text":"Pub. L. 98–557, § 15(a)(3)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2865"},"text":"98 Stat. 2865","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3533/c/1"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3533(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2321"},"text":"132 Stat. 2321","children":[],"tail":"; renumbered § 704, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s106/b"},"text":"Pub. L. 115–282, title I, § 106(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4203"},"text":"132 Stat. 4203","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id569cc745-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id569cc746-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsection (a) is based on title 14, U.S.C., 1946 ed., § 28 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-29/ch417"},"text":"Aug. 29, 1916, ch. 417","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/601"},"text":"39 Stat. 601","children":[],"tail":"). Section has been enlarged to include the Air Force as well as the Army, and to include all schools maintained by the Army or Air Force, rather than aviation schools only. Reimbursement is made optional depending upon agreement of the Secretaries."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) is based on title 14, U.S.C., 1946 ed., § 31 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-03-06/ch94/s1"},"text":"Mar. 6, 1920, ch. 94, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/506"},"text":"41 Stat. 506","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c) is based on title 14, U.S.C., 1946 ed., § 31a (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-03/ch252"},"text":"Mar. 3, 1909, ch. 252","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/751"},"text":"35 Stat. 751","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1937-04-15/ch101"},"text":"Apr. 15, 1937, ch. 101","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/65"},"text":"50 Stat. 65","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id569cc747-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id569cc748-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 704 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s3704"},"text":"section 3704 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id569cc749-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s144"},"text":"section 144 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “enlisted members” for “enlisted men” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557"},"text":"Pub. L. 98–557","children":[],"tail":" substituted “members” for “officers and enlisted men” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/546/s1/10/a"},"text":"Pub. L. 94–546, § 1(10)(a)","children":[],"tail":", substituted “at the request of the Secretary” for “at the request of the Secretary of the Treasury”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/546/s1/10/b"},"text":"Pub. L. 94–546, § 1(10)(b)","children":[],"tail":", substituted “Secretary of the Army” for “Chief of Ordnance”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
