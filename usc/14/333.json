{"tag":"section","attrib":{"id":"id5689b40d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333"},"text":null,"children":[{"tag":"num","attrib":{"value":"333"},"text":"§ 333.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training courses on workings of Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5689b40e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5689b40f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training course.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5689b410-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant, and such other individuals and organizations as the Commandant considers appropriate, shall develop a training course on the workings of Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5689b411-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"id5689b412-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The training course developed in subparagraph (A) shall be offered at least once each year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5689b413-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The training developed under subparagraph (A) may be provided more than once a year to facilitate timely receipt by covered recipients.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5689b414-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual basis.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5689b415-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At least once each year, any covered recipients shall receive the training developed under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5689b416-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered recipients","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this paragraph, the term “covered recipients” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5689b417-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flag officers serving in the Coast Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5689b418-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the senior executive service (career reserved) serving in positions in the Coast Guard; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5689b419-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" political appointees—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5689b41a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/2/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serving in positions in the Coast Guard; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5689b41b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/2/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the Department of Homeland Security with Coast Guard in their portfolio, including any Senior Advisor to the Secretary for the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5689b41c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Course subject matter","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The training course required by this subsection shall provide an overview and introduction to Congress and the Federal legislative process, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5689b41d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the history and structure of Congress and the committee systems of the House of Representatives and the Senate, including the functions and responsibilities of the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5689b41e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the documents produced by Congress, including bills, resolutions, committee reports, and conference reports, and the purposes and functions of such documents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5689b41f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the legislative processes and rules of the House of Representatives and the Senate, including similarities and differences between the 2 processes and 2 sets of rules, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5689b420-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional budget process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5689b421-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional authorization and appropriation processes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5689b422-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Senate advice and consent process for Presidential nominees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5689b423-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/3/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Senate advice and consent process for treaty ratification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5689b424-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/3/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all relevant notification and reporting requirements in statute, policy, or any other agreement to Congress;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5689b425-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the roles of Members of Congress and congressional staff in the legislative process; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5689b426-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the concept and underlying purposes of congressional oversight within the governance framework of separation of powers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5689b427-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the roles of independent oversight entities, including the Offices of the Inspector Generals, the Government Accountability Office, and other independent entities, with respect ","children":[{"tag":"ref","attrib":{"idref":"fn002005"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002005"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “to”."}],"tail":" oversight of the Coast Guard;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5689b428-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the legal and ethical requirements of complying with oversight conducted by such independent oversight entities, including compliance with congressionally mandated oversight;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5689b429-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an overview of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":" (popularly known at the Privacy Act of 1974) with respect to working with Congress and independent oversight;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5689b42a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an overview of the right of all Coast Guard members and staff to engage with Congress as a constitutionally protected right; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5689b42b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to Coast Guard covered recipients, an overview of any law administered by the Coast Guard and any policy implemented by the Coast Guard the understanding of which is necessary to improve—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5689b42c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/3/J/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with such law and policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5689b42d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/3/J/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ethics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5689b42e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/3/J/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professionalism; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5689b42f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/a/3/J/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" timeliness of response to Congressional oversight requests, including requests from independent oversight entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5689b430-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training for Congressional Affairs Personnel.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5689b431-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall develop a training course on the workings of Congress, which shall be administered in person for to ","children":[{"tag":"ref","attrib":{"idref":"fn002006"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002006"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original."}],"tail":" any required participant."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5689b432-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required participant","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “required participant” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5689b433-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any member of the Coast Guard Office of Congressional and Governmental Affairs selected for a position as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5689b434-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fellow;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5689b435-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a liaison;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5689b436-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a counsel; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5689b437-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative staff;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5689b438-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Coast Guard district or area governmental affairs officer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5689b439-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who reviews, makes edits, or transmits formal or informal correspondence with respect to the Coast Guard to Congress, including relevant program level personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5689b43a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an individual who serves in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5689b43b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Coordination, Programs, and Accountability or successor office; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5689b43c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Force Design 2028 office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5689b43d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/b/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coast Guard Office of General Law personnel, including such personnel detailed to the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5689b43e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Course subject matter.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5689b43f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The training course required under this subsection shall provide an overview and introduction to Congress and the Federal legislative process, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5689b440-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the items described in subparagraphs (C) through (K) of subsection (a)(2); ","children":[{"tag":"ref","attrib":{"idref":"fn002007"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002007"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be “subparagraphs (C) through (J) of subsection (a)(3);”."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5689b441-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the roles of Coast Guard fellows, liaisons, counsels, governmental affairs officers, the Coast Guard Office of Program Review, the Coast Guard Headquarters program offices, and any other entity the Commandant considers relevant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5689b442-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the roles and responsibilities of Coast Guard public affairs and external communications personnel with respect to Members of Congress and the staff of such Members necessary to enhance communication between Coast Guard units, sectors, and districts and Member offices and committees of jurisdiction so as to ensure visibility of Coast Guard activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5689b443-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/b/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to Coast Guard required participants, an overview of any law administered by the Coast Guard and any policy implemented by the Coast Guard the understanding of which is necessary to improve—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5689b444-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/b/3/A/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with such law and policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5689b445-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/b/3/A/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ethics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5689b446-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/b/3/A/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professionalism; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5689b447-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/b/3/A/iv/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" timeliness of response to Congressional oversight requests, including requests from independent oversight entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5689b448-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Detail within coast guard office of budget and programs.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5689b449-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At the written request of a receiving congressional office, the training course required under this section shall include a multi-day detail within the Coast Guard Office of Coordination, Programs,","children":[{"tag":"ref","attrib":{"idref":"fn002008"},"text":"4","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002008"},"text":null,"children":[{"tag":"num","attrib":{},"text":"4","children":[],"tail":" So in original. Probably should be followed by “and”."}],"tail":" Accountability to ensure adequate exposure to Coast Guard policy, oversight, and requests from Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5689b44a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonconsecutive detail permitted","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A detail under this paragraph is not required to be consecutive with the balance of the training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5689b44b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Completion of required training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of the Coast Guard selected for a position described in subsection (a) shall complete the training required by this section before the date on which such member reports for duty for such position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5689b44c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lecturers and Panelists.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5689b44d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Outside experts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall ensure that not less than 60 percent of the lecturers, panelists, and other individuals providing education and instruction as part of the training courses required under this section are experts on Congress and the Federal legislative process who are not employed by the executive branch of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5689b44e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s333/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to accept pro bono services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In satisfying the requirement under paragraph (1), the Commandant shall seek, and may accept, educational and instructional services of lecturers, panelists, and other individuals and organizations provided to the Coast Guard on a pro bono basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5689b44f-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7201/e/7"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7201(e)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1681"},"text":"139 Stat. 1681","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5689b450-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5689b451-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5689b452-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 333, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/tII/s214/b/1"},"text":"Pub. L. 114–120, title II, § 214(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/43"},"text":"130 Stat. 43","children":[],"tail":", § 60; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dC/tXXXV/s3503/a"},"text":"Pub. L. 114–328, div. C, title XXXV, § 3503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2775"},"text":"130 Stat. 2775","children":[],"tail":"; "},{"tag":"ref","attr