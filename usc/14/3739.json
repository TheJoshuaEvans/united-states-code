{"tag":"section","attrib":{"id":"id56d5ffdc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3739"},"text":null,"children":[{"tag":"num","attrib":{"value":"3739"},"text":"§ 3739.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion of Reserve officers on active duty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56d5ffdd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3739/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Reserve officer on active duty, other than for training, duty on a board, or duty of a limited or temporary nature if assigned to active duty from an inactive duty status, shall not be eligible for consideration for promotion under this subchapter; but shall be considered for promotion under chapter 21 of this title. If promoted while serving on active duty the officer shall be considered as having been promoted under this subchapter and shall be an extra number in the grade to which promoted for the purpose of grade distribution as prescribed in this subchapter. Upon release from active duty the officer shall be included in the grade distribution authorized by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d5ffde-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3739/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding subsection (a) of this section, a Reserve officer who has been selected for promotion to the next higher grade under this subchapter at the time the officer reports for active duty, shall be promoted to that grade under chapter 21 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d848cf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3739/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Reserve officer who, at the time the officer is released from active duty, has been selected for promotion to the next higher grade under chapter 21 of this title, shall be promoted to that grade as though selected under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d848d0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3739/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A failure of selection for promotion to the next higher grade occurring under this subchapter or under chapter 21 of this title shall count for all purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56d848d1-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/322/s1"},"text":"Pub. L. 96–322, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-04"},"text":"Aug. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1009"},"text":"94 Stat. 1009","children":[],"tail":", § 728; renumbered § 3739 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 118(b), 123(c)(2)(B), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4233"},"text":"132 Stat. 4233","children":[],"tail":", 4241.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d848d2-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56d848d3-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id56d848d4-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s791"},"text":"section 791 of this title","children":[],"tail":" prior to the complete revision of former chapter 21 of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/96/322"},"text":"Pub. L. 96–322","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56d848d5-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/c/2/B"},"text":"Pub. L. 115–282, § 123(c)(2)(B)","children":[],"tail":", substituted “chapter 21” for “chapter 11” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s118/b"},"text":"Pub. L. 115–282, § 118(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s728"},"text":"section 728 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
