{"tag":"section","attrib":{"id":"id56ad68f8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1158"},"text":null,"children":[{"tag":"num","attrib":{"value":"1158"},"text":"§ 1158.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to enter into transactions other than contracts and grants to procure cost-effective, advanced technology for mission-critical needs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56ad68f9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1158/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsections (b) and (c), the Commandant may enter into transactions (other than contracts, cooperative agreements, and grants) to operate, test, and acquire cost-effective technology for the purpose of meeting the mission needs of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ad68fa-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1158/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operation, Testing, and Acquisition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Operation, testing, and acquisition of technologies under subsection (a) shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ad68fb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1158/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carried out in accordance with Coast Guard policies and guidance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ad68fc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1158/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with the operational requirements of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ad68fd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1158/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant may not enter into a transaction under subsection (a) with respect to a technology that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ad68fe-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1158/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not comply with the cybersecurity standards of the Coast Guard; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ad68ff-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1158/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is sourced from an entity domiciled in the People’s Republic of China, unless the Commandant determines that the prototype or procurement of such a technology is for the purpose of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56ad6900-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1158/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" counter-UAS or surrogate testing; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ad6901-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1158/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intelligence, electronic warfare, and information warfare, testing, and analysis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ad6902-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1158/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Education and Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall ensure that management, technical, and contracting personnel of the Coast Guard involved in the award or administration of transactions under this section are provided adequate education and training with respect to the authority under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ad6903-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1158/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall prescribe regulations as necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ad6904-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1158/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Counter-UAS Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “counter-UAS” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44801"},"text":"section 44801 of title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56ad6905-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXII/s11205/a"},"text":"Pub. L. 117–263, div. K, title CXII, § 11205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4009"},"text":"136 Stat. 4009","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
