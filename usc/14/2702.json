{"tag":"section","attrib":{"id":"id56ca192d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2702"},"text":null,"children":[{"tag":"num","attrib":{"value":"2702"},"text":"§ 2702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Coast Guard may make expenditures for the training of personnel, including books, school supplies, correspondence courses, motion picture equipment, and other equipment for instructional purposes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56ca192e-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/531"},"text":"63 Stat. 531","children":[],"tail":", § 469; renumbered § 2702, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s116/b"},"text":"Pub. L. 115–282, title I, § 116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4226"},"text":"132 Stat. 4226","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56ca192f-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56ca1930-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on the following language contained in the Coast Guard appropriation act for 1949, “Pay and Allowances” and preceding years: ","children":[{"tag":"quotedContent","attrib":{},"text":"“motion picture and other equipment for instructional purposes; . . . training of enlisted personnel, including textbooks, school supplies, and correspondence courses;”","children":[],"tail":"\n ("},{"tag":"date","attrib":{"date":"1948-06-19"},"text":"June 19, 1948","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/562"},"text":"62 Stat. 562","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56ca1931-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id56ca1932-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2702 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s4902"},"text":"section 4902 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56ca1933-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s469"},"text":"section 469 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
