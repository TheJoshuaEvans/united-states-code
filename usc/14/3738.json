{"tag":"section","attrib":{"id":"id56d5ffd4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3738"},"text":null,"children":[{"tag":"num","attrib":{"value":"3738"},"text":"§ 3738.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Constructive credit upon initial appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Under regulations prescribed by the Secretary, an individual, appointed as a Reserve officer, may be assigned a date of rank and precedence which reflects that individual’s experience, education, or other qualifications. For the purpose of this subchapter only, an individual appointed for the purpose of assignment or designation as a judge advocate in the Reserve shall be credited with a minimum of one year service in an active status. An individual holding a doctor of philosophy, or a comparable degree, in medicine or in a science allied to medicine as determined by the Secretary, may be credited with a minimum of three years service in an active status if appointed for an assignment comparable to that of an officer in the Navy Medical Department.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56d5ffd5-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/322/s1"},"text":"Pub. L. 96–322, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-04"},"text":"Aug. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1009"},"text":"94 Stat. 1009","children":[],"tail":", § 727; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/293/tII/s208"},"text":"Pub. L. 108–293, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1035"},"text":"118 Stat. 1035","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/tII/s218/b/1"},"text":"Pub. L. 109–241, title II, § 218(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/526"},"text":"120 Stat. 526","children":[],"tail":"; renumbered § 3738, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s118/b"},"text":"Pub. L. 115–282, title I, § 118(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4233"},"text":"132 Stat. 4233","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8505(a)(53), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4750"},"text":"134 Stat. 4750","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d5ffd6-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56d5ffd7-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id56d5ffd8-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s773"},"text":"section 773 of this title","children":[],"tail":" prior to the complete revision of former chapter 21 of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/96/322"},"text":"Pub. L. 96–322","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56d5ffd9-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “an individual” for “a person” in two places, and substituted “individual’s” for “person’s” and “An individual” for “A person”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s727"},"text":"section 727 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241"},"text":"Pub. L. 109–241","children":[],"tail":" substituted “judge advocate” for “law specialist”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293"},"text":"Pub. L. 108–293","children":[],"tail":" substituted “one year” for “three years” in second sentence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
