{"tag":"section","attrib":{"id":"id56a18221-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722"},"text":null,"children":[{"tag":"num","attrib":{"value":"722"},"text":"§ 722.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation with eligible entities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56a18222-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a18223-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provision of assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the availability of appropriations and for the purpose of mitigating the impacts of Coast Guard actions including expansion of bases, including direct or indirect impacts, to natural resources and cultural resources, the Commandant may provide Federal financial assistance, except for loans or loan guarantees, or make grants to an eligible entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a18224-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Financial assistance or grants made under paragraph (1) may be used to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56a18225-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit any development or use of such natural resources and cultural resources as a result of such Coast Guard actions described in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a18226-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" maintain and maintain access to, such natural resources and cultural resources, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56a18227-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tribal treaty fisheries and shellfish harvest, and usual and accustomed fishing areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56a18228-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsistence fisheries, or any other fishery or shellfish harvest, of an Indian Tribe;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a18229-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a means to replace, repair, or restore such natural resources and cultural resources of an Indian Tribe or Native Hawaiian organization if such property is damaged by Coast Guard actions described in paragraph (1), in consultation with the affected Indian Tribe or Native Hawaiian organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a1822a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain and improve natural resources located outside a Coast Guard installation, if the purpose of the agreement is to relieve or eliminate current or anticipated challenges that could restrict, impede, or otherwise interfere with, directly or indirectly, current or anticipated Coast Guard actions described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a1822b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Financial assistance or grants made under paragraph (1) may not be used for the purpose of the Coast Guard receiving any funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a1822c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification; Availability of Agreements to Congress.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a1822d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall notify the Committee on Commerce, Science, and Transportation or the Committee on Homeland Security and Governmental Affairs of the Senate (and the Committee on Indian Affairs of the Senate in the case of an eligible entity that is an Indian Tribe, Tribal organization or Native Hawaiian organization) and the Committee on Transportation and Infrastructure of the House of Representatives in writing not later than the date that is 3 full business days prior to any day on which the Commandant intends to enter into such an agreement or contract, or make a grant under subsection (a), and include in such notification the anticipated costs of carrying out the agreement, to the extent practicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a1822e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A copy of such financial assistance or grant made under subsection (a) shall be provided to the Committee on Commerce, Science, and Transportation or the Committee on Homeland Security and Governmental Affairs of the Senate or the Committee on Transportation and Infrastructure of the House of Representatives not later than 5 full business days after the date on which such request is submitted to the Commandant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a1822f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section may be construed to undermine the rights of any Indian Tribe to seek full and meaningful government-to-government consultation under this section or under any other law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a18230-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a18231-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cultural resource","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “cultural resource” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56a18232-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A building, structure, site, district, or object eligible for or included in the National Register of Historic Places maintained under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s302101"},"text":"section 302101 of title 54","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a18233-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cultural items, as such term is defined in section 2(3) of the Native American Graves Protection and Repatriation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3001/3"},"text":"25 U.S.C. 3001(3)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a18234-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An archaeological resource, as such term is defined in section 3(1) of the Archaeological Resources Protection Act of 1979 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s470bb/1"},"text":"16 U.S.C. 470bb(1)","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a18235-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An archaeological artifact collection and associated records covered by part 79 of title 36, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a18236-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A sacred site, as such term is defined in section 1(b) of Executive Order No. 13007 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1996"},"text":"42 U.S.C. 1996","children":[],"tail":" note; relating to Indian sacred sites)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a18237-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Treaty or trust resources of an Indian Tribe, including the habitat associated with such resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a18238-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/d/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsistence resources of an Indian Tribe or Native Hawaiian organization including the habitat associated with such resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a18239-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible entity","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56a1823a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State, or a political subdivision of a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a1823b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A local government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a1823c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Indian Tribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a1823d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Native Hawaiian organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a1823e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Tribal organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a1823f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Indian tribe","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Indian Tribe” has the meaning given that term in section 4 of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"25 U.S.C. 5304","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a18240-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Native hawaiian organization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Native Hawaiian organization” has the meaning given such term in section 6207 of the Elementary and Secondary Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7517"},"text":"20 U.S.C. 7517","children":[],"tail":") except the term includes the Department of Hawaiian Home Lands and the Office of Hawaiian Affairs."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a18241-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Natural resource","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “natural resource” means land, fish, wildlife, biota, air, water, ground water, drinking water supplies, and other such resources belonging to, managed by, held in trust by, appertaining to, or otherwise controlled by the United States (including the resources of the waters of the United States), any State or local government, any Indian Tribe, any member of an Indian Tribe, or Native Hawaiian organization, if such resources are subject to a trust restriction on alienation and have been categorized into 1 of the following groups:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56a18242-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Surface water resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a18243-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ground water resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a18244-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Air resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a18245-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/d/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Geologic resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a18246-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/d/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Biological resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a18247-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “State” includes each of the several States, the District of Columbia, the Commonwealth of Puerto Rico, the Commonwealth of the Northern Mariana Islands, and the territories and possessions of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a18248-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s722/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tribal organization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Tribal organization” has the meaning given such term in section 4 of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"25 U.S.C. 5304","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56a18249-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7204/a"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1688"},"text":"139 Stat. 1688","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
