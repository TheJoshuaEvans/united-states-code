{"tag":"section","attrib":{"id":"id568742b3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s317"},"text":null,"children":[{"tag":"num","attrib":{"value":"317"},"text":"§ 317.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special Advisor to Commandant for Tribal and Native Hawaiian Affairs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id568742b4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s317/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with Federal trust responsibilities and treaty obligations, laws, and policies relevant to Indian Tribes and in support of the principles of self-determination, self-governance, and co-management with respect to Indian Tribes, and to support engagement with Native Hawaiians, there shall be in the Coast Guard a Special Advisor to the Commandant for Tribal and Native Hawaiian Affairs (in this section referred to as the “Special Advisor”), who shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id568742b5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s317/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be selected by the Secretary and the Commandant through a competitive search process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id568742b6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s317/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have expertise in Federal Indian law and policy, including government-to-government consultation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id568742b7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s317/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, have expertise in legal and policy issues affecting Native Hawaiians; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id568742b8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s317/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have an established record of distinguished service and achievement working with Indian Tribes, Tribal organizations, and Native Hawaiian organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id568742b9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s317/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Career Reserved Position","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The position of Special Advisor shall be a career reserved position at the GS–15 level or greater.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id568742ba-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s317/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Special Advisor shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id568742bb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s317/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the Federal government upholds the Federal trust responsibility and conducts consistent, meaningful, and timely government-to-government consultation and engagement with Indian Tribes, which shall meet or exceed the standards of the Federal Government and the Coast Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id568742bc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s317/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure meaningful and timely engagement with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id568742bd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s317/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Native Hawaiian organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id568742be-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s317/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tribal organizations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id568742bf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s317/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Commandant on all policies of the Coast Guard that have Tribal implications in accordance with applicable law and policy, including Executive Orders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id568742c0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s317/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" work to ensure that the policies of the Federal Government regarding consultation and engagement with Indian Tribes and engagement with Native Hawaiian organizations and Tribal organizations are implemented in a meaningful manner, working through Coast Guard leadership and across the Coast Guard, together with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id568742c1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s317/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" liaisons located within Coast Guard districts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id568742c2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s317/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of Coast Guard Governmental and Public Affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id568742c3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s317/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Coast Guard leadership and programs and other Federal partners; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id568742c4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s317/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support Indian Tribes, Native Hawaiian organizations, and Tribal organizations in all matters under the jurisdiction of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id568742c5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s317/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Direct Access to Secretary and Commandant","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No officer or employee of the Coast Guard or the Department of Homeland Security may interfere with the ability of the Special Advisor to give direct and independent advice to the Secretary and the Commandant on matters related to this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id568742c6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s317/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id568742c7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s317/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Indian tribe","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Indian Tribe” has the meaning given such term in section 4 of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"25 U.S.C. 5304","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id568742c8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s317/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Native hawaiian organization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Native Hawaiian organization” has the meaning given such term in section 6207 of the Elementary and Secondary Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7517"},"text":"20 U.S.C. 7517","children":[],"tail":") except the term includes the Department of Hawaiian Home Lands and the Office of Hawaiian Affairs."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id568742c9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s317/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tribal organization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Tribal organization” has the meaning given the term in section 4 of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"25 U.S.C. 5304","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id568742ca-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7201/e/6"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7201(e)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1679"},"text":"139 Stat. 1679","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id568742cb-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id568742cc-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id568742cd-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 317 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s311"},"text":"section 311 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id568742ce-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id568742cf-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7201/h/3/C"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7201(h)(3)(C)","children":[],"tail":", (D), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1686"},"text":"139 Stat. 1686","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dG/tLXXII/s7201/h/3/C"},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection [enacting this note and provisions not set out in the Code]:","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Indian tribe","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Indian Tribe’ has the meaning given such term in section 4 of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"25 U.S.C. 5304","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Native hawaiian organization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Native Hawaiian organization’ has the meaning given such term in section 6207 of the Elementary and Secondary Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7517"},"text":"20 U.S.C. 7517","children":[],"tail":") except the term includes the Department of Hawaiian Home Lands and the Office of Hawaiian Affairs."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tribal organization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Tribal organization’ has the meaning given the such [sic] in section 4 of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"25 U.S.C. 5304","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of construction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subsection, or an amendment made by subsection (d)(6) [sic, there is no ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7201/d/6"},"text":"section 7201(d)(6) of Pub. L. 119–60","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7201/e/6"},"text":"section 7201(e)(6) of Pub. L. 119–60","children":[],"tail":" enacted sections 316, 317, and 318 of this title], shall be construed to impact—"}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right of any Indian Tribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any government-to-government consultation.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
