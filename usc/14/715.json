{"tag":"section","attrib":{"id":"id569f10b7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s715"},"text":null,"children":[{"tag":"num","attrib":{"value":"715"},"text":"§ 715.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oceanographic research","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Coast Guard shall conduct such oceanographic research, use such equipment or instruments, and collect and analyze such oceanographic data, in cooperation with other agencies of the Government, or not, as may be in the national interest.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id569f10b8-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/396/s1"},"text":"Pub. L. 87–396, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-10-05"},"text":"Oct. 5, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/827"},"text":"75 Stat. 827","children":[],"tail":", § 94; renumbered § 715, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s106/b"},"text":"Pub. L. 115–282, title I, § 106(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4203"},"text":"132 Stat. 4203","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id569f10b9-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id569f10ba-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id569f10bb-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"