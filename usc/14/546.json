{"tag":"section","attrib":{"id":"id569a568a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s546"},"text":null,"children":[{"tag":"num","attrib":{"value":"546"},"text":"§ 546.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of damage payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever an aid to navigation or other property belonging to the Coast Guard is damaged or destroyed by a private person, and such private person or his agent shall pay to the satisfaction of the proper official of the Coast Guard for the cost of repair or replacement of such property, the Commandant may accept and deposit such payments, through proper officers of the Fiscal Service, Treasury Department, in special deposit accounts in the Treasury, for payment therefrom to the person or persons repairing or replacing the damaged property and refundment of amounts collected in excess of the cost of the repairs or replacements concerned. In the event that repair or replacement of the damaged property is effected by the Coast Guard, the appropriations bearing the cost thereof and current at the time collection is made shall be reimbursed from the special deposit account.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id569a568b-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/547"},"text":"63 Stat. 547","children":[],"tail":", § 642; renumbered § 546, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s105/b"},"text":"Pub. L. 115–282, title I, § 105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4200"},"text":"132 Stat. 4200","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id569a568c-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id569a568d-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 33, U.S.C., 1946 ed., § 721a (","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-08-16/ch665/s2"},"text":"Aug. 16, 1937, ch. 665, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/667"},"text":"50 Stat. 667","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id569a568e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id569a568f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s642"},"text":"section 642 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
