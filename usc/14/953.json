{"tag":"section","attrib":{"id":"id56a63ceb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953"},"text":null,"children":[{"tag":"num","attrib":{"value":"953"},"text":"§ 953.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support for Coast Guard Academy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56a63cec-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a63ced-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracts and cooperative agreements.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56a63cee-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant may enter contract and cooperative agreements with 1 or more qualified organizations for the purpose of supporting the athletic programs of the Coast Guard Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a63cef-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3201/e"},"text":"section 3201(e) of title 10","children":[],"tail":", the Commandant may enter into such contracts and cooperative agreements on a sole source basis pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3204/a"},"text":"section 3204(a) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a63cf0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding chapter 63 of title 31, a cooperative agreement under this section may be used to acquire property or services for the direct benefit or use of the Coast Guard Academy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63cf1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Financial controls.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56a63cf2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before entering into a contract or cooperative agreement under paragraph (1), the Commandant shall ensure that the contract or agreement includes appropriate financial controls to account for the resources of the Coast Guard Academy and the qualified organization concerned in accordance with accepted accounting principles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a63cf3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any such contract or cooperative agreement shall contain a provision that allows the Commandant to review, as the Commandant considers necessary, the financial accounts of the qualified organization to determine whether the operations of the qualified organization—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56a63cf4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with the terms of the contract or cooperative agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56a63cf5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would compromise the integrity or appearance of integrity of any program of the Department of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63cf6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Leases","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purpose of supporting the athletic programs of the Coast Guard Academy, the Commandant may, consistent with section 504(a)(13), rent or lease real property located at the Coast Guard Academy to a qualified organization, except that proceeds from such a lease shall be retained and expended in accordance with subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a63cf7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Support Services.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a63cf8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the extent required by a contract or cooperative agreement under subsection (a), the Commandant may provide support services to a qualified organization while the qualified organization conducts support activities at the Coast Guard Academy only if the Commandant determines that the provision of such services is essential for the support of the athletic programs of the Coast Guard Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63cf9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No liability of the united states","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Support services may only be provided without any liability of the United States to a qualified organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63cfa-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Support services defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the term “support services” includes utilities, office furnishings and equipment, communications services, records staging and archiving, audio and video support, and security systems, in conjunction with the leasing or licensing of property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a63cfb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfers From Nonappropriated Fund Operation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a63cfc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the Commandant may, subject to the acceptance of the qualified organization concerned, transfer to the qualified organization all title to and ownership of the assets and liabilities of the Coast Guard nonappropriated fund instrumentality, the function of which includes providing support for the athletic programs of the Coast Guard Academy, including bank accounts and financial reserves in the accounts of such fund instrumentality, equipment, supplies, and other personal property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63cfd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant may not transfer under paragraph (1) any interest in real property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a63cfe-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceptance of Support From Qualified Organization.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a63cff-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":", the Commandant may accept from a qualified organization funds, supplies, and services for the support of the athletic programs of the Coast Guard Academy."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63d00-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employees of qualified organization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, employees or personnel of the qualified organization may not be considered to be employees of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63d01-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funds received from ncaa","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant may accept funds from the National Collegiate Athletic Association to support the athletic programs of the Coast Guard Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63d02-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant shall ensure that contributions under this subsection and expenditure of funds pursuant to subsection (f) do not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56a63d03-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflect unfavorably on the ability of the Coast Guard, any employee of the Coast Guard, or any member of the armed forces (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a"},"text":"section 101(a) of title 10","children":[],"tail":") to carry out any responsibility or duty in a fair and objective manner; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a63d04-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compromise the integrity or appearance of integrity of any program of the Coast Guard, or any individual involved in such a program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a63d05-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Trademarks and Service Marks.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a63d06-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Licensing, marketing, and sponsorship agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An agreement under subsection (a) may, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2260"},"text":"section 2260 of title 10","children":[],"tail":" (other than subsection (d) of such section), authorize a qualified organization to enter into licensing, marketing, and sponsorship agreements relating to trademarks and service marks identifying the Coast Guard Academy, subject to the approval of the Commandant."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63d07-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A licensing, marketing, or sponsorship agreement may not be entered into under paragraph (1) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56a63d08-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such agreement would reflect unfavorably on the ability of the Coast Guard, any employee of the Coast Guard, or any member of the armed forces to carry out any responsibility or duty in a fair and objective manner; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a63d09-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commandant determines that the use of the trademark or service mark would compromise the integrity or appearance of integrity of any program of the Coast Guard or any individual involved in such a program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a63d0a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention and Use of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds received by the Commandant under this section may be retained for use to support the athletic programs of the Coast Guard Academy and shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a63d0b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The authority provided in this section with respect to a qualified organization is available only so long as the qualified organization continues—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a63d0c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to operate in accordance with this section, the law of the State of Connecticut, and the constitution and bylaws of the qualified organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63d0d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to operate exclusively to support the athletic programs of the Coast Guard Academy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a63d0e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualified Organization Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “qualified organization” means an organization—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a63d0f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that operates as an organization under subsection (c)(3) of section 501 of the Internal Revenue Code of 1986 and exempt from taxation under subsection (a) of that section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63d10-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which authorization under sections 1033(a) and 1589(a) of title 10 may be provided; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63d11-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s953/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" established by the Coast Guard Academy Alumni Association solely for the purpose of supporting Coast Guard athletics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56a63d12-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXII/s11250/a"},"text":"Pub. L. 117–263, div. K, title CXII, § 11250(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4049"},"text":"136 Stat. 4049","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56a63d13-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56a63d14-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id56a63d15-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsection (c)(3) of section 501 of the Internal Revenue Code of 1986, referred to in subsec. (h)(1), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
