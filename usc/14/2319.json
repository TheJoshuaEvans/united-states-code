{"tag":"section","attrib":{"id":"id56c07b7f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2319"},"text":null,"children":[{"tag":"num","attrib":{"value":"2319"},"text":"§ 2319.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Critical skill training bonus","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56c07b80-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2319/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may provide a bonus, not to exceed $20,000, to an enlisted member who completes training in a skill designated as critical, if at least four years of obligated active service remain on the member’s enlistment at the time the training is completed. A bonus under this section may be paid in a single lump sum or in periodic installments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56c07b81-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2319/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an enlisted member voluntarily or because of misconduct does not complete the member’s term of obligated active service, the Secretary may require the member to repay the United States, on a pro rata basis, all sums paid under this section. The Secretary may charge interest on the amount repaid at a rate, to be determined quarterly, equal to 150 percent of the average of the yields on the 91-day Treasury bills auctioned during the calendar quarter preceding the date on which the amount to be repaid is determined.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56c07b82-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293/tII/s204/a"},"text":"Pub. L. 108–293, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1032"},"text":"118 Stat. 1032","children":[],"tail":", § 374; renumbered § 2319, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s113/b"},"text":"Pub. L. 115–282, title I, § 113(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4221"},"text":"132 Stat. 4221","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56c07b83-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56c07b84-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56c07b85-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s374"},"text":"section 374 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
