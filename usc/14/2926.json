{"tag":"section","attrib":{"id":"id56d38e5d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2926"},"text":null,"children":[{"tag":"num","attrib":{"value":"2926"},"text":"§ 2926.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Family child care providers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56d38e5e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2926/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not less frequently than quarterly, the Commandant shall ensure that each family child care provider is subject to inspection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56d38e5f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2926/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibility for Inspections","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the quarterly inspections under subsection (a) each year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56d38e60-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2926/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 inspections shall be carried out by a representative of the Coast Guard installation served by the family child care provider concerned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56d38e61-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2926/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 inspection shall be carried out by a representative of the Coast Guard child development services work-life programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56d38e62-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8237(b)(1), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4665"},"text":"134 Stat. 4665","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
