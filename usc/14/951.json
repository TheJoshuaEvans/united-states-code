{"tag":"section","attrib":{"id":"id56a63cd4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s951"},"text":null,"children":[{"tag":"num","attrib":{"value":"951"},"text":"§ 951.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aircraft accident investigations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56a63cd5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s951/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whenever the Commandant conducts an accident investigation of an accident involving an aircraft under the jurisdiction of the Commandant, the records and report of the investigation shall be treated in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a63cd6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s951/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Disclosure of Certain Accident Investigation Information.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a63cd7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s951/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraph (2), the Commandant, upon request, shall publicly disclose unclassified tapes, scientific reports, and other factual information pertinent to an aircraft accident investigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63cd8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s951/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant shall only disclose information requested pursuant to paragraph (1) if the Commandant determines—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56a63cd9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s951/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that such tapes, reports, or other information would be included within and releasable with the final accident investigation report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56a63cda-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s951/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that release of such tapes, reports, or other information—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56a63cdb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s951/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would not undermine the ability of accident or safety investigators to continue to conduct the investigation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56a63cdc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s951/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would not compromise national security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63cdd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s951/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restriction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A disclosure under paragraph (1) may not be made by or through officials with responsibility for, or who are conducting, a safety investigation with respect to the accident.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a63cde-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s951/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Opinions Regarding Causation of Accident","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Following an aircraft accident referred to in subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a63cdf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s951/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the evidence surrounding the accident is sufficient for the investigators who conduct the accident investigation to come to an opinion as to the cause or causes of the accident, the final report of the accident investigation shall set forth the opinion of the investigators as to the cause or causes of the accident; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63ce0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s951/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the evidence surrounding the accident is not sufficient for the investigators to come to an opinion as to the cause or causes of the accident, the final report of the accident investigation shall include a description of those factors, if any, that, in the opinion of the investigators, substantially contributed to or caused the accident.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a63ce1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s951/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Information in Civil or Criminal Proceedings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of any civil or criminal proceeding arising from an aircraft accident referred to in subsection (a), any opinion of the accident investigators as to the cause of, or the factors contributing to, the accident set forth in the accident investigation report may not be considered as evidence in such proceeding, nor may such report be considered an admission of liability by the United States or by any person referred to in such report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a63ce2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s951/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56a63ce3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s951/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “accident investigation” means any form of investigation by Coast Guard personnel of an aircraft accident referred to in subsection (a), other than a safety investigation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56a63ce4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s951/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “safety investigation” means an investigation by Coast Guard personnel of an aircraft accident referred to in subsection (a) that is conducted solely to determine the cause of the accident and to obtain information that may prevent the occurrence of similar accidents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56a63ce5-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213/tII/s214/a"},"text":"Pub. L. 112–213, title II, § 214(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1553"},"text":"126 Stat. 1553","children":[],"tail":", § 678; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3531/c/5"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3531(c)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2320"},"text":"132 Stat. 2320","children":[],"tail":"; renumbered § 951, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s107/b"},"text":"Pub. L. 115–282, title I, § 107(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4205"},"text":"132 Stat. 4205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56a63ce6-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56a63ce7-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56a63ce8-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s678"},"text":"section 678 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “Commandant conducts” for “Commandant of the Coast Guard conducts”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
