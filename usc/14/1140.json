{"tag":"section","attrib":{"id":"id56ab1f9e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1140"},"text":null,"children":[{"tag":"num","attrib":{"value":"1140"},"text":"§ 1140.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts that provide best value for taxpayer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56ab1f9f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1140/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out a Level 1 or Level 2 acquisition project or program under this subchapter, the Commandant may publicly announce all construction, design, and engineering requirements and negotiate contracts for construction, design, and engineering services on the basis of demonstrated competence and qualification for the type of professional services required and at fair and reasonable prices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ab1fa0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1140/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection Procedure","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following procedures may apply to the procurement of Level 1 or Level 2 acquisition project or program under this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ab1fa1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1140/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statements of qualification and performance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall require prospective contractors to submit a statement of qualifications and performance data.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1fa2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1140/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evaluation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each proposed project, the Commandant shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56ab1fa3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1140/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate statements of qualifications and performance submitted by firms regarding the proposed project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ab1fa4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1140/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct discussions with firms to consider anticipated concepts and compare alternative methods for furnishing services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1fa5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1140/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"From the firms with which discussions have been conducted under paragraph (2)(B), the Commandant shall select, in order of preference, that the Commandant considers most highly qualified to provide the services required, based on criteria established and published by the Commandant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ab1fa6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1140/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Negotiation of Contract.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ab1fa7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1140/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall negotiate 1 or more contracts for construction, design, and engineering services under this section at compensation which the Commandant determines is fair and reasonable to the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1fa8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1140/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fair and reasonable compensation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In determining fair and reasonable compensation, the Commandant shall consider the scope, complexity, professional nature, and estimated value of the services to be rendered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1fa9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1140/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Negotiation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall attempt to negotiate a contract or contracts with the most highly qualified firm or firms selected under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1faa-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1140/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Further negotiation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Commandant is unable to negotiate a satisfactory contract or contracts with the firm or firms under paragraph (3), the Commandant shall formally terminate negotiations with such firm or firms and undertake negotiations with the next most qualified of the selected firms, continuing the process until an agreement is reached.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ab1fab-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1140/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional firms","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Commandant is unable to negotiate a satisfactory contract or contracts with any of the selected firms, the Commandant shall select additional firms in order of competence and qualification and continue negotiations in accordance with this section until 1 or more agreements are reached.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56ab1fac-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7212/a"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7212(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1694"},"text":"139 Stat. 1694","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
