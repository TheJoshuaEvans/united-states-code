{"tag":"section","attrib":{"id":"id56d14489-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2778"},"text":null,"children":[{"tag":"num","attrib":{"value":"2778"},"text":"§ 2778.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advancement of public funds to personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commandant, under regulations prescribed by the Secretary, may advance public funds to personnel when required to meet expenses of members detailed on emergency shore duty. Funds so advanced shall not exceed a reasonable estimate of the actual expenditures to be made and for which reimbursement is authorized by law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56d1448a-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/534"},"text":"63 Stat. 534","children":[],"tail":", § 488; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s15/a/3/I"},"text":"Pub. L. 98–557, § 15(a)(3)(I)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2865"},"text":"98 Stat. 2865","children":[],"tail":"; renumbered § 2778, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s116/b"},"text":"Pub. L. 115–282, title I, § 116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4226"},"text":"132 Stat. 4226","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d1448b-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56d1448c-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Derived from title 34, U.S.C., 1946 ed., § 885, and title 14, U.S.C., 1946 ed., § 3a (","children":[{"tag":"ref","attrib":{"href":"/us/act/1928-05-22/ch688"},"text":"May 22, 1928, ch. 688","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/712"},"text":"45 Stat. 712","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1942-10-26/ch623"},"text":"Oct. 26, 1942, ch. 623","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/987"},"text":"56 Stat. 987","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Said section 885 was made applicable to the Coast Guard by title 14, U.S.C., 1946 ed., § 3a whenever the Coast Guard is operating with the Navy. Experience has shown the advantage of having such a provision applicable to the Coast Guard at all times.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Said section would in no way be affected. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56d1448d-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56d1448e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s488"},"text":"section 488 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557"},"text":"Pub. L. 98–557","children":[],"tail":" substituted reference to members for reference to officers and men."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
