{"tag":"section","attrib":{"id":"id569f1099-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s713"},"text":null,"children":[{"tag":"num","attrib":{"value":"713"},"text":"§ 713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonappropriated fund instrumentalities: contracts with other agencies and instrumentalities to provide or obtain goods and services","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Coast Guard Exchange System, or a morale, welfare, and recreation system of the Coast Guard, may enter into a contract or other agreement with any element or instrumentality of the Coast Guard or with another Federal department, agency, or instrumentality to provide or obtain goods and services beneficial to the efficient management and operation of the Coast Guard Exchange System or that morale, welfare, and recreation system.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id569f109a-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293/tII/s202/a"},"text":"Pub. L. 108–293, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1031"},"text":"118 Stat. 1031","children":[],"tail":", § 152; renumbered § 713, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s106/b"},"text":"Pub. L. 115–282, title I, § 106(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4203"},"text":"132 Stat. 4203","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id569f109b-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id569f109c-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id569f109d-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 713 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s3714"},"text":"section 3714 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id569f109e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s152"},"text":"section 152 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
