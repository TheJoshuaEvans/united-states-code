{"tag":"section","attrib":{"id":"id568bfdae-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s338"},"text":null,"children":[{"tag":"num","attrib":{"value":"338"},"text":"§ 338.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redistricting notification requirement","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Commandant shall notify the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate at least 180 days before—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id568bfdaf-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s338/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing any plan to reduce the number of, change the location of, or change the geographic area covered by any existing Coast Guard Districts; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id568bfdb0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s338/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permanently transferring more than 10 percent of the personnel or equipment from a district office where such personnel or equipment is based.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id568bfdb1-2930-11f1-a4c1-c531e6569a02"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8501(a)(1), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4745"},"text":"134 Stat. 4745","children":[],"tail":", § 322; renumbered § 338, "},{"tag":"ref","attrib":{"href":"/us/pl/1