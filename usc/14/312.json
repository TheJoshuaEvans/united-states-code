{"tag":"section","attrib":{"id":"id5684f981-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312"},"text":null,"children":[{"tag":"num","attrib":{"value":"312"},"text":"§ 312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Western Alaska Oil Spill Planning Criteria Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5684f982-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established within the Coast Guard a Western Alaska Oil Spill Planning Criteria Program (referred to in this section as the “Program”) to develop and administer the Western Alaska oil spill planning criteria.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5684f983-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Manager.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5684f984-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of enactment of this section, the Commandant shall select a permanent civilian career employee through a competitive search process for a term of not less than 5 years to serve as the Western Alaska Oil Spill Criteria Program Manager (referred to in this section as the “Program Manager”)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5684f985-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the primary duty of whom shall be to administer the Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5684f986-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who shall not be subject to frequent or routine reassignment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5684f987-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conflicts of interest","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The individual selected to serve as the Program Manager shall not have conflicts of interest relating to entities regulated by the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5684f988-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56874279-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Development of guidance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Program Manager shall develop guidance for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5687427a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approval, drills, and testing relating to the Western Alaska oil spill planning criteria; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5687427b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gathering input concerning such planning criteria from Federal agencies, State and local governments, Tribes, and relevant industry and nongovernmental entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5687427c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessments","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less frequently than once every 5 years, the Program Manager shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5687427d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess whether such existing planning criteria adequately meet the needs of vessels operating in the geographic area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5687427e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify methods for advancing response capability so as to achieve, with respect to a vessel, compliance with national planning criteria.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5687427f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Onsite verifications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Program Manager shall address the relatively small number and limited nature of verifications of response capabilities for vessel response plans by increasing, within the Coast Guard Arctic District, the quantity and frequency of onsite verifications of the providers identified in vessel response plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56874280-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant shall enhance the knowledge and proficiency of Coast Guard personnel with respect to the Program by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56874281-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" developing formalized training on the Program that, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56874282-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides in-depth analysis of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56874283-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national planning criteria described in part 155 of title 33, Code of Federal Regulations (as in effect on the date of enactment of this section);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56874284-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alternative planning criteria;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56874285-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Western Alaska oil spill planning criteria;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56874286-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/c/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Captain of the Port and Federal On-Scene Coordinator authorities related to activation of a vessel response plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56874287-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/c/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the responsibilities of vessel owners and operators in preparing a vessel response plan for submission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56874288-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/c/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" responsibilities of the Area Committee, including risk analysis, response capability, and development of alternative planning criteria;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56874289-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explains the approval processes of vessel response plans that involve alternative planning criteria or Western Alaska oil spill planning criteria; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5687428a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides instruction on the processes involved in carrying out the actions described in paragraphs (9)(D) and (9)(F) of section 311(j) of the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1321/j"},"text":"33 U.S.C. 1321(j)","children":[],"tail":"), including instruction on carrying out such actions—"}],"tail":null},{"tag":"clause","attrib":{"id":"id5687428b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any geographic area in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5687428c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifically in the Coast Guard Arctic District; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5687428d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing such training to all Coast Guard personnel involved in the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5687428e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5687428f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternative planning criteria","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “alternative planning criteria” means criteria submitted under section 155.1065 or 155.5067 of title 33, Code of Federal Regulations (as in effect on the date of enactment of this section), for vessel response plans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56874290-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tribe","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Tribe” has the meaning given the term “Indian Tribe” in section 4 of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"25 U.S.C. 5304","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56874291-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessel response plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “vessel response plan” means a plan required to be submitted by the owner or operator of a tank vessel or a nontank vessel under regulations issued by the President under section 311(j)(5) of the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1321/j/5"},"text":"33 U.S.C. 1321(j)(5)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56874292-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s312/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Western alaska oil spill planning criteria","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Western Alaska oil spill planning criteria” means the criteria required to be established under paragraph (9) of section 311(j) of the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1321/j"},"text":"33 U.S.C. 1321(j)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56874293-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXIII/s11309/a/1"},"text":"Pub. L. 117–263, div. K, title CXIII, § 11309(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4079"},"text":"136 Stat. 4079","children":[],"tail":"; renumbered § 312 and amended, "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7201/b"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7201(b)","children":[],"tail":", title LXXVII, § 7701(k), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1675"},"text":"139 Stat. 1675","children":[],"tail":", 1837.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56874294-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56874295-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id56874296-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsecs. (b)(1), (c)(1)(A)(i), and (d)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id56874297-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 312 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s339"},"text":"section 339 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 312, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/520"},"text":"63 Stat. 520","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1950-08-03/ch536/s14"},"text":"Aug. 3, 1950, ch. 536, § 14","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/407"},"text":"64 Stat. 407","children":[],"tail":", related to relief of retired warrant officer promoted while on active duty, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/10/A"},"text":"Pub. L. 88–130, § 1(10)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/177"},"text":"77 Stat. 177","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56874298-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7201/b"},"text":"Pub. L. 119–60, § 7201(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s323"},"text":"section 323 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b)(3)(C), (c)(1)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7701/k"},"text":"Pub. L. 119–60, § 7701(k)","children":[],"tail":", which directed amendment of "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s324"},"text":"section 324 of this title","children":[],"tail":" by substituting “Coast Guard Arctic District” for “Seventeenth Coast Guard District” wherever appearing, was executed to this section, to reflect the probable intent of Congress and the renumbering of "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s323"},"text":"section 323 of this title","children":[],"tail":" as this section by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", see above. There is no "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s324"},"text":"section 324 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id56874299-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5687429a-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in amendment made by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" to be construed to satisfy any requirement for government-to-government consultation with Tribal governments or to affect or modify any treaty or other right of any Tribal government, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11003"},"text":"section 11003 of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s245"},"text":"section 245 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
