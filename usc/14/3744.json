{"tag":"section","attrib":{"id":"id56d84920-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3744"},"text":null,"children":[{"tag":"num","attrib":{"value":"3744"},"text":"§ 3744.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendation for promotion of an officer previously removed from an active status","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A Reserve officer recommended for promotion by a selection board but not promoted because of removal from an active status shall be reconsidered by a selection board after returning to an active status and if selected shall be placed on a recommended list of selectees for promotion. A Reserve officer to whom this section applies is not considered to have failed of selection when eliminated from a list of selectees for promotion solely as a result of being removed from an active status.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id56d84921-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/322/s1"},"text":"Pub. L. 96–322, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-04"},"text":"Aug. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1012"},"text":"94 Stat. 1012","children":[],"tail":", § 733; renumbered § 3744, "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s118/b"},"text":"Pub. L. 115–282, title I, § 118(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4233"},"text":"132 Stat. 4233","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56d84922-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56d84923-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id56d84924-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s777"},"text":"section 777 of this title","children":[],"tail":" prior to the complete revision of former chapter 21 of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/96/322"},"text":"Pub. L. 96–322","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56d84925-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s733"},"text":"section 733 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
