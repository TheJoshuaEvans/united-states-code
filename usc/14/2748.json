{"tag":"section","attrib":{"id":"id56ced2f2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2748"},"text":null,"children":[{"tag":"num","attrib":{"value":"2748"},"text":"§ 2748.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presentation of United States flag upon retirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56ced2f3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2748/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Presentation of Flag","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon the release of a member of the Coast Guard from active duty for retirement, the Secretary shall present a United States flag to the member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ced2f4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2748/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multiple Presentations Not Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member is not eligible for a presentation of a flag under subsection (a) if the member has previously been presented a flag under this section or any other provision of law providing for the presentation of a United States flag incident to release from active service for retirement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56ced2f5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s2748/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Cost to Recipient","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The presentation of a flag under this section shall be at no cost to the recipient.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56ced2f6-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tVI/s644/d/1"},"text":"Pub. L. 105–261, div. A, title VI, § 644(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2049"},"text":"112 Stat. 2049","children":[],"tail":", § 516; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVI/s652/e"},"text":"Pub. L. 106–65, div. A, title VI, § 652(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/666"},"text":"113 Stat. 666","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/a"},"text":"Pub. L. 107–296, title XVII, § 1704(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tX/s1062/b/2"},"text":"Pub. L. 107–314, div. A, title X, § 1062(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2650"},"text":"116 Stat. 2650","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/213/tII/s217/6"},"text":"Pub. L. 112–213, title II, § 217(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1557"},"text":"126 Stat. 1557","children":[],"tail":"; renumber