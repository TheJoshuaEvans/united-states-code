{"tag":"section","attrib":{"id":"id56dab9c8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3902"},"text":null,"children":[{"tag":"num","attrib":{"value":"3902"},"text":"§ 3902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of the Coast Guard Auxiliary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56dab9c9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3902/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purpose of the Auxiliary is to assist the Coast Guard as authorized by the Commandant, in performing any Coast Guard function, power, duty, role, mission, or operation authorized by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56dab9ca-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3902/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Auxiliary may conduct a patrol of a waterway, or a portion thereof, only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56dab9cb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3902/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commandant has determined such waterway, or portion thereof, is navigable for purposes of the jurisdiction of the Coast Guard; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56dab9cc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s3902/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or other proper authority has requested such patrol pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s701"},"text":"section 701 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s13109"},"text":"section 13109 of title 46","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56dab9cd-2930-11f1-a4c1-c531e6569a02"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/555"},"text":"63 Stat. 555","children":[],"tail":", § 822; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tIV/s402/a"},"text":"Pub. L. 104–324, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3923"},"text":"110 Stat. 3923","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tII/s205/a"},"text":"Pub. L. 114–120, title II, § 205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/36"},"text":"130 Stat. 36","children":[],"tail":"; renumbered § 3902 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 119(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4236"},"text":"132 Stat. 4236","children":[],"tail":", 4240.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56dab9ce-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id56dab9cf-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 14, U.S.C., 1946 ed., § 261 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1941-02-19/ch8"},"text":"Feb. 19, 1941, ch. 8","children":[],"tail":", title I, § 2, "},{"tag":"ref","attrib":{"href":"/us/stat/55/9"},"text":"55 Stat. 9","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1944-09-30/ch453/s1"},"text":"Sept. 30, 1944, ch. 453, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/759"},"text":"58 Stat. 759","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology. 81st Congress, House Report No. 557.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56dab9d0-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56dab9d1-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s119/b"},"text":"Pub. L. 115–282, § 119(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s822"},"text":"section 822 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 701” for “section 141”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120"},"text":"Pub. L. 114–120","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Pub. L. 104–324","children":[],"tail":" inserted “of the Coast Guard Auxiliary” after “Purpose” in section catchline and amended text generally. Prior to amendment, text read as follows: “The purpose of the Auxiliary is to assist the Coast Guard:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) to promote safety and to effect rescues on and over the high seas and on navigable waters;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) to promote efficiency in the operation of motorboats and yachts;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) to foster a wider knowledge of, and better compliance with, the laws, rules, and regulations governing the operation of motorboats and yachts; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(d) to facilitate other operations of the Coast Guard.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
