{"tag":"section","attrib":{"id":"id56a18279-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s904"},"text":null,"children":[{"tag":"num","attrib":{"value":"904"},"text":"§ 904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local hire","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id56a1827a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other law, each contract awarded by the Coast Guard for construction or services to be performed in whole or in part in a State that has an unemployment rate in excess of the national average rate of unemployment (as determined by the Secretary of Labor) shall include a provision requiring the contractor to employ, for the purpose of performing that portion of the contract in that State, individuals who are local residents and who, in the case of any craft or trade, possess or would be able to acquire promptly the necessary skills. The Secretary of the department in which the Coast Guard is operating may waive the requirements of this subsection in the interest of national security or economic efficiency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id56a1827b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Local Resident Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As used in this section, “local resident” means a resident of, or an individual who commutes daily to, a State described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56a1827c-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","childr