{"tag":"section","attrib":{"id":"id569f10e6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719"},"text":null,"children":[{"tag":"num","attrib":{"value":"719"},"text":"§ 719.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research projects; transactions other than contracts and grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id569f10e7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Forms of Transactions Authorized.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id569f10e8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant may enter into—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id569f10e9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transactions (other than contracts, cooperative agreements, and grants) in carrying out basic, applied, and advanced research projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id569f10ea-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agreements with the Director of the Defense Advanced Research Projects Agency, the Secretary of a military department, or any other official designated by the Secretary of Defense under section 2371b ","children":[{"tag":"ref","attrib":{"idref":"fn002018"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002018"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 10 to participate in prototype projects and follow-on production contracts or transactions that are being carried out by such official and are directly relevant to the Coast Guard’s cyber capability and Command, Control, Communications, Computers, and intelligence initiatives."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f10eb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority under this subsection is in addition to the authority provided in section 717 to use contracts, cooperative agreements, and grants in carrying out such projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f10ec-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out paragraph (1)(B), the Commandant may use funds made available to the extent provided in advance in appropriations Acts for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id569f10ed-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operations and support;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id569f10ee-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research, development, test, and evaluation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id569f10ef-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procurement, construction, and improvement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id569f10f0-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recovery of Funds.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id569f10f1-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (d), a cooperative agreement for performance of basic, applied, or advanced research authorized by section 717, and a transaction authorized by subsection (a), may include a clause that requires a person or other entity to make payments to the Coast Guard or any other department or agency of the Federal Government as a condition for receiving support under the agreement or transaction, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f10f2-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of any payment received by the Federal Government pursuant to a requirement imposed under paragraph (1) shall be deposited in the general fund of the Treasury. Amounts so deposited shall be available for the purposes of carrying out this section, to the extent provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id569f10f3-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id569f10f4-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall ensure that to the extent that the Commandant determines practicable, no cooperative agreement containing a clause described in subsection (c)(1),","children":[{"tag":"ref","attrib":{"idref":"fn002019"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002019"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “subsection (b)(1)”."}],"tail":" and no transaction entered into under subsection (a), provides for research that duplicates research being conducted under existing programs carried out by the Coast Guard."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f10f5-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other agreements not feasible","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A cooperative agreement containing a clause described in subsection (c)(1),","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" or under a transaction authorized by subsection (a), may be used for a research project only if the use of a standard contract, grant, or cooperative agreement for such project is not feasible or appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id569f10f6-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Education and Training","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id569f10f7-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that management, technical, and contracting personnel of the Coast Guard involved in the award or administration of transactions under this section or other innovative forms of contracting are afforded opportunities for adequate education and training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f10f8-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish minimum levels and requirements for continuous and experiential learning for such personnel, including levels and requirements for acquisition certification programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id569f10f9-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protection of Certain Information From Disclosure.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id569f10fa-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Disclosure of information described in paragraph (2) is not required, and may not be compelled, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":" for 5 years after the date on which the information is received by the Coast Guard."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f10fb-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id569f10fc-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) applies to information described in subparagraph (B) that is in the records of the Coast Guard only if the information was submitted to the Coast Guard in a competitive or noncompetitive process having the potential for resulting in an award, to the party submitting the information, of a cooperative agreement for performance of basic, applied, or advanced research authorized by section 717 or another transaction authorized by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id569f10fd-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information referred to in subparagraph (A) is the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id569f10fe-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A proposal, proposal abstract, and supporting documents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id569f10ff-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A business plan submitted on a confidential basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id569f1100-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/e/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Technical information submitted on a confidential basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id569f1101-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall prescribe regulations, as necessary, to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id569f1102-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"On the date on which the President submits to Congress a budget pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", the Commandant shall submit to the Committees on Appropriations and Transportation and Infrastructure of the House of Representatives and the Committees on Appropriations and Commerce, Science, and Transportation of the Senate a report describing each use of the authority provided under this section during the most recently completed fiscal year, including details of each use consisting of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id569f1103-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of each transaction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f1104-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entities or organizations involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f1105-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the product or service received;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f1106-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the research project for which the product or service was required; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id569f1107-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s719/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of the cost sharing among Federal Government and non-Federal sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id569f1108-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8218(a), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4653"},"text":"134 Stat. 4653","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id569f1109-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id569f110a-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id569f110b-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2371b"},"text":"Section 2371b of title 10","children":[],"tail":", referred to in subsec. (a)(1)(B), was renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4022"},"text":"section 4022 of title 10","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1841/b/1"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1841(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4243"},"text":"134 Stat. 4243","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/u/2/B"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(u)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2151"},"text":"135 Stat. 2151","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
