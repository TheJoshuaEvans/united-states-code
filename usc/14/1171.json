{"tag":"section","attrib":{"id":"id56ad6916-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171"},"text":null,"children":[{"tag":"num","attrib":{"value":"1171"},"text":"§ 1171.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id56ad6917-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate congressional committees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “appropriate congressional committees” means the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ad6918-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chief acquisition officer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Chief Acquisition Officer” means the officer appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s308"},"text":"section 308 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ad6919-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Customer of a major acquisition program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “customer of a major acquisition program” means the operating field unit of the Coast Guard that will field the system or systems acquired under a major acquisition program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ad691a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Level 1 acquisition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Level 1 acquisition” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56ad691b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an acquisition by the Coast Guard—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56ad691c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated life-cycle costs of which exceed $1,000,000,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56ad691d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated total acquisition costs of which exceed $300,000,000; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ad691e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any acquisition that the Chief Acquisition Officer of the Coast Guard determines to have a special interest—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id56ad691f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" due to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id56ad6920-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/4/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the experimental or technically immature nature of the asset;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id56ad6921-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/4/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the technological complexity of the asset;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id56ad6922-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/4/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the commitment of resources; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id56ad6923-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/4/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature of the capability or set of capabilities to be achieved; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id56ad6924-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because such acquisition is a joint acquisition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ad6925-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Level 2 acquisition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Level 2 acquisition” means an acquisition by the Coast Guard—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56ad6926-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated life-cycle costs of which are equal to or less than $1,000,000,000, but greater than $300,000,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ad6927-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated total acquisition costs of which are equal to or less than $300,000,000, but greater than $100,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ad6928-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Life-cycle cost","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “life-cycle cost” means all costs for development, procurement, construction, and operations and support for a particular capability or asset, without regard to funding source or management control.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ad6929-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Major acquisition program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “major acquisition program” means an ongoing acquisition undertaken by the Coast Guard with a life-cycle cost estimate greater than or equal to $300,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ad692a-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Project or program manager defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “project or program manager” means an individual designated—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56ad692b-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop, produce, and deploy a new asset to meet identified operational requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ad692c-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to manage cost, schedule, and performance of the acquisition, project, or program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ad692d-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Safety concern","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “safety concern” means any hazard associated with a capability or asset or a subsystem of a capability or asset that is likely to cause serious bodily injury or death to a typical Coast Guard user in testing, maintaining, repairing, or operating the capability, asset, or subsystem or any hazard associated with the capability, asset, or subsystem that is likely to cause major damage to the capability, asset, or subsystem during the course of its normal operation by a typical Coast Guard user.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ad692e-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Developmental test and evaluation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “developmental test and evaluation” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56ad692f-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the testing of a capability or asset and the subsystems of the capability or asset to determine whether they meet all contractual performance requirements, including technical performance requirements, supportability requirements, and interoperability requirements and related specifications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ad6930-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the evaluation of the results of such testing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id56ad6931-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operational test and evaluation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “operational test and evaluation” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id56ad6932-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the testing of a capability or asset and the subsystems of the capability or asset, under conditions similar to those in which the capability or asset and subsystems will actually be deployed, for the purpose of determining the effectiveness and suitability of the capability or asset and subsystems for use by typical Coast Guard users to conduct those missions for which the capability or asset and subsystems are intended to be used; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id56ad6933-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s1171/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the evaluation of the results of such testing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id56ad6934-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tIV/s402/a"},"text":"Pub. L. 111–281, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2948"},"text":"124 Stat. 2948","children":[],"tail":", § 581; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tII/s209/8"},"text":"Pub. L. 114–120, title II, § 209(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/41"},"text":"130 Stat. 41","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s899/b/1/F"},"text":"Pub. L. 114–328, div. A, title VIII, § 899(b)(1)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2334"},"text":"130 Stat. 2334","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3531/c/8"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3531(c)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2320"},"text":"132 Stat. 2320","children":[],"tail":"; renumbered § 1171 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 108(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4208"},"text":"132 Stat. 4208","children":[],"tail":", 4240.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id56ad6935-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id56ad6936-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id56ad6937-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s108/b"},"text":"Pub. L. 115–282, § 108(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s581"},"text":"section 581 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 308” for “section 56”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (4) to (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" redesignated pars. (5) to (12) as (4) to (11), respectively, and struck out former par. (4) which defined “Commandant” as the Commandant of the Coast Guard."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s899/b/1/F/ii"},"text":"Pub. L. 114–328, § 899(b)(1)(F)(ii)","children":[],"tail":", added par. (3). Former par. (3) redesignated (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s899/b/1/F/i"},"text":"Pub. L. 114–328, § 899(b)(1)(F)(i)","children":[],"tail":", redesignated pars. (3) and (4) as (4) and (5), respectively. Former par. (5) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120"},"text":"Pub. L. 114–120","children":[],"tail":" substituted “$300,000,000,” for “$300,000,0000,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s899/b/1/F/i"},"text":"Pub. L. 114–328, § 899(b)(1)(F)(i)","children":[],"tail":", redesignated pars. (5) and (6) as (6) and (7), respectively. Former par. (7) redesignated (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s899/b/1/F/iii"},"text":"Pub. L. 114–328, § 899(b)(1)(F)(iii)","children":[],"tail":", added par. (8). Former par. (8) redesignated (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (9) to (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s899/b/1/F/i"},"text":"Pub. L. 114–328, § 899(b)(1)(F)(i)","children":[],"tail":", redesignated pars. (7) to (10) as (9) to (12), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
