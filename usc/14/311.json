{"tag":"section","attrib":{"id":"id5684f972-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s311"},"text":null,"children":[{"tag":"num","attrib":{"value":"311"},"text":"§ 311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Coast Guard Band; composition; director","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5684f973-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s311/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Coast Guard Band shall be composed of a director and other personnel in such numbers and grades as the Secretary determines to be necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5684f974-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s311/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may designate as the director any individual determined by the Secretary to possess the necessary qualifications. Upon the recommendation of the Secretary, an individual so designated may be appointed by the President, by and with the advice and consent of the Senate, to a commissioned grade in the Regular Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5684f975-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s311/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The initial appointment to a commissioned grade of an individual designated as director of the Coast Guard Band shall be in the grade determined by the Secretary to be most appropriate to the qualifications and experience of the appointed individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5684f976-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s311/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual who is designated and commissioned under this section shall not be included on the active duty promotion list. He shall be promoted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s2126"},"text":"section 2126 of this title","children":[],"tail":". However, the grade of the director may not be higher than captain."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5684f977-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s311/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may revoke any designation as director of the Coast Guard Band. When an individual’s designation is revoked, his appointment to commissioned grade under this section terminates and he is entitled, at his option—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5684f978-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s311/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be discharged from the Coast Guard; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5684f979-2930-11f1-a4c1-c531e6569a02","identifier":"/us/usc/t14/s311/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to revert to the grade and status he held at the time of his designation as director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5684f97a-2930-11f1-a4c1-c531e6569a02"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/189/s1/1"},"text":"Pub. L. 89–189, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-09-17"},"text":"Sept. 17, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/820"},"text":"79 Stat. 820","children":[],"tail":", § 336; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tV/s5201"},"text":"Pub. L. 102–587, title V, § 5201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5071"},"text":"106 Stat. 5071","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/295/tIII/s311"},"text":"Pub. L. 107–295, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2102"},"text":"116 Stat. 2102","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/tII/s204/a"},"text":"Pub. L. 109–241, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/520"},"text":"120 Stat. 520","children":[],"tail":"; renumbered § 317 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI"},"text":"Pub. L. 115–282, title I","children":[],"tail":", §§ 104(b), 123(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4196"},"text":"132 Stat. 4196","children":[],"tail":", 4240; renumbered § 311, "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7201/b"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1675"},"text":"139 Stat. 1675","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5684f97b-2930-11f1-a4c1-c531e6569a02"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5684f97c-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5684f97d-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 311 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s314"},"text":"section 314 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 311, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-04/ch393"},"text":"Aug. 4, 1949, ch. 393","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/519"},"text":"63 Stat. 519","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1950-08-03/ch536/s13"},"text":"Aug. 3, 1950, ch. 536, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/407"},"text":"64 Stat. 407","children":[],"tail":", related to recall of warrant officers to active duty with consent of the officer, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/88/130/s1/10/A"},"text":"Pub. L. 88–130, § 1(10)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/177"},"text":"77 Stat. 177","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5684f97e-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s317"},"text":"section 317 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s104/b"},"text":"Pub. L. 115–282, § 104(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s336"},"text":"section 336 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/2"},"text":"Pub. L. 115–282, § 123(b)(2)","children":[],"tail":", substituted “section 2126” for “section 276”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241/s204/a/1"},"text":"Pub. L. 109–241, § 204(a)(1)","children":[],"tail":", in first sentence, substituted “The Secretary may designate as the director any individual determined by the Secretary to possess the necessary qualifications.” for “The Secretary shall designate the director from among qualified members of the Coast Guard.”, and, in second sentence, substituted “an individual so designated” for “a member so designated”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241/s204/a/2"},"text":"Pub. L. 109–241, § 204(a)(2)","children":[],"tail":", substituted “of an individual” for “of a member” and “determined by the Secretary to be most appropriate to the qualifications and experience of the appointed individual” for “of lieutenant (junior grade) or lieutenant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241/s204/a/3"},"text":"Pub. L. 109–241, § 204(a)(3)","children":[],"tail":", substituted “An individual” for “A member”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241/s204/a/4"},"text":"Pub. L. 109–241, § 204(a)(4)","children":[],"tail":", substituted “When an individual’s designation is revoked,” for “When a member’s designation is revoked,” and “option—” for “option:”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295"},"text":"Pub. L. 107–295","children":[],"tail":" substituted “captain” for “commander”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587"},"text":"Pub. L. 102–587","children":[],"tail":" substituted “commander” for “lieutenant commander”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5684f97f-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5684f980-2930-11f1-a4c1-c531e6569a02"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Current Director","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241/tII/s204/b"},"text":"Pub. L. 109–241, title II, § 204(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/520"},"text":"120 Stat. 520","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/241/tII/s204/b"},"text":"“The individual serving as Coast Guard band director on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":"] may be immediately promoted to a commissioned grade, not to exceed captain, determined by the Secretary of the department in which the Coast Guard is operating to be most appropriate to the qualifications and experience of that individual.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
